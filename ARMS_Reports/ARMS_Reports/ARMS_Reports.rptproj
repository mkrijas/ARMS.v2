<?xml version="1.0" encoding="utf-8"?>
<Project ToolsVersion="Current" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <PropertyGroup Condition=" '$(Configuration)' == 'Debug' ">
    <FullPath>Debug</FullPath>
    <OutputPath>bin\Debug</OutputPath>
    <ErrorLevel>2</ErrorLevel>
    <OverwriteDatasets>True</OverwriteDatasets>
    <OverwriteDataSources>True</OverwriteDataSources>
    <TargetServerVersion>SSRS2016</TargetServerVersion>
    <Platform>Win32</Platform>
    <TargetReportFolder>ARMS_V2/ARMS_Reports</TargetReportFolder>
    <TargetDatasetFolder>ARMS_V2/Datasets</TargetDatasetFolder>
    <TargetDatasourceFolder>ARMS_V2/Data Sources</TargetDatasourceFolder>
    <TargetReportPartFolder>Report Parts</TargetReportPartFolder>
    <TargetServerURL>http://10.200.90.30/ReportServer</TargetServerURL>
  </PropertyGroup>
  <PropertyGroup Condition=" '$(Configuration)' == 'DebugLocal' ">
    <FullPath>DebugLocal</FullPath>
    <OutputPath>bin\DebugLocal</OutputPath>
    <ErrorLevel>2</ErrorLevel>
    <OverwriteDatasets>False</OverwriteDatasets>
    <OverwriteDataSources>False</OverwriteDataSources>
    <TargetServerVersion>SSRS2016</TargetServerVersion>
    <Platform>Win32</Platform>
    <TargetReportFolder>ARMS_Reports</TargetReportFolder>
    <TargetDatasetFolder>Datasets</TargetDatasetFolder>
    <TargetDatasourceFolder>Data Sources</TargetDatasourceFolder>
    <TargetReportPartFolder>Report Parts</TargetReportPartFolder>
    <TargetServerURL>http://localhost/reportserver</TargetServerURL>
  </PropertyGroup>
  <PropertyGroup Condition=" '$(Configuration)' == 'Release' ">
    <FullPath>Release</FullPath>
    <OutputPath>bin\Release</OutputPath>
    <ErrorLevel>2</ErrorLevel>
    <OverwriteDatasets>False</OverwriteDatasets>
    <OverwriteDataSources>False</OverwriteDataSources>
    <TargetServerVersion>SSRS2016</TargetServerVersion>
    <Platform>Win32</Platform>
    <TargetReportFolder>ARMS_Reports</TargetReportFolder>
    <TargetDatasetFolder>Datasets</TargetDatasetFolder>
    <TargetDatasourceFolder>Data Sources</TargetDatasourceFolder>
    <TargetReportPartFolder>Report Parts</TargetReportPartFolder>
    <TargetServerURL>http://localhost/reportserver</TargetServerURL>
  </PropertyGroup>
  <PropertyGroup>
    <State>$base64$</State>
    <DataSources>@(DataSource)</DataSources>
    <DataSets>@(DataSet)</DataSets>
    <Reports>@(Report)</Reports>
  </PropertyGroup>
  <ItemGroup>
    <DataSet Include="Branches.rsd" />
  </ItemGroup>
  <ItemGroup>
    <DataSource Include="ARMSV2DataBase.rds" />
  </ItemGroup>
  <ItemGroup>
    <Report Include="AnnexureToInvoice.rdl" />
    <Report Include="AssetDocumentExpiryReport.rdl" />
    <Report Include="AssetTransferReport.rdl" />
    <Report Include="BankLedgerReport.rdl" />
    <Report Include="CashLedgerReport.rdl" />
    <Report Include="ConsignmentNoteReport.rdl" />
    <Report Include="DriverIncentiveReport.rdl" />
    <Report Include="FInanceAccountLedger.rdl" />
    <Report Include="FinanceDayBook.rdl" />
    <Report Include="FinanceFundBalanceSummary.rdl" />
    <Report Include="FinancePartyBalanceSummary.rdl" />
    <Report Include="FinanceTrialBalance.rdl" />
    <Report Include="FinanceTrialBalanceColumnar.rdl" />
    <Report Include="FuelConsumptionReport.rdl" />
    <Report Include="HaltingReport.rdl" />
    <Report Include="InsuranceStatusReport.rdl" />
    <Report Include="InventoryItemsDetailsReport.rdl" />
    <Report Include="InventorySummaryReport.rdl" />
    <Report Include="MileageReport.rdl" />
    <Report Include="OperationSummaryReport.rdl" />
    <Report Include="OperationTripExpenseReport.rdl" />
    <Report Include="PartyLedgerReport.rdl" />
    <Report Include="PointOfDeliveryReport.rdl" />
    <Report Include="PrintConsignmentNoteBill.rdl" />
    <Report Include="PrintPaymentMemo.rdl" />
    <Report Include="PrintSalesInvoice.rdl" />
    <Report Include="PrintSundryPayment.rdl" />
    <Report Include="PrintSundryReceipt.rdl" />
    <Report Include="PrintTaxInvoice.rdl" />
    <Report Include="PrintVoucherTripSettlement.rdl" />
    <Report Include="PurchaseRegisterReport.rdl" />
    <Report Include="StocklistFreightCollectedReport.rdl" />
    <Report Include="TruckDocumentsCurrent.rdl" />
    <Report Include="TruckPerformanceReport.rdl" />
    <Report Include="TruckStatusReport.rdl" />
    <Report Include="truckUtilization.rdl" />
    <Report Include="truckUtilizationSummary.rdl" />
    <Report Include="UnsettledTripAdvanceReport.rdl" />
    <Report Include="UsageCodePnL.rdl" />
    <Report Include="UsageCodeReport.rdl" />
  </ItemGroup>
  <Import Project="$(MSBuildExtensionsPath)\Reporting Services\Microsoft.ReportingServices.MSBuilder.targets" />
</Project>