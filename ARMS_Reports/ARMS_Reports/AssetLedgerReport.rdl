                      <CellContents>
                        <Textbox Name="opBal">
                          <CanGrow>true</CanGrow>
                          <KeepTogether>true</KeepTogether>
                          <Paragraphs>
                            <Paragraph>
                              <TextRuns>
                                <TextRun>
                                  <Label>Op Bal</Label>
                                  <Value>= Code.SumLookup( LookupSet(
   Fields!SubArdCode.Value,
   Fields!SubArdCode.Value,
 Fields!Amount.Value,
"Balance"))</Value>
                                  <Style>
                                    <FontFamily />
                                    <FontSize>11pt</FontSize>
                                    <FontWeight>Bold</FontWeight>
                                    <Format>'₹' #,0.00;'₹' -#,0.00;'-'</Format>
                                    <Color>Maroon</Color>
                                    <rd:FormatSymbolCulture>en-IN</rd:FormatSymbolCulture>
                                  </Style>
                                </TextRun>
                              </TextRuns>
                              <Style>
