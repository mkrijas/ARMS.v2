    <DataSet Name="BankInfo">
      <Query>
        <DataSourceName>ARMSV2DataBase</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@ARDCode">
            <Value>=Parameters!ArdCode.Value</Value>
            <rd:UserDefined>true</rd:UserDefined>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT b.BankTitle,b.AccountNumber,b.BankBranch FROM [Finance.BankAccount.Own] o 
JOIN [Finance.BankAccount] b ON o.BankAccountID = b.BankAccountID
WHERE o.BankCode =  @ARDCode</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="BankTitle">
          <DataField>BankTitle</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="AccountNumber">
          <DataField>AccountNumber</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="BankBranch">
          <DataField>BankBranch</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
