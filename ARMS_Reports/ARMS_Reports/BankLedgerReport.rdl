                            <Paragraph>
                              <TextRuns>
                                <TextRun>
                                  <Label>Op Bal</Label>
                                  <Value>=iif(Fields!TranType.Value="Account", 
Lookup(
  Fields!BranchID.Value &amp; Fields!SubArdCode.Value,
  Fields!BranchID.Value &amp; Fields!SubArdCode.Value,
 Fields!Amount.Value,
"Balance"),"")</Value>
                                  <Style>
                                    <FontStyle>Italic</FontStyle>
                                    <FontFamily />
                                    <FontSize>11pt</FontSize>
                                    <FontWeight>Bold</FontWeight>
                                    <Format>'₹' #,0.00;'₹' -#,0.00;'-'</Format>
                                    <rd:FormatSymbolCulture>en-IN</rd:FormatSymbolCulture>
                                  </Style>
                                </TextRun>
