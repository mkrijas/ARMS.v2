                                    <FontSize>12pt</FontSize>
                                    <FontWeight>Bold</FontWeight>
                                  </Style>
                                </TextRun>
                                <TextRun>
                                  <Label>OpBalance</Label>
                                  <Value>= Sum(Fields!Amount.Value, "Balance") + Sum(Fields!Amount.Value)</Value>
                                  <Style>
                                    <FontStyle>Normal</FontStyle>
                                    <FontFamily />
                                    <FontSize>12pt</FontSize>
