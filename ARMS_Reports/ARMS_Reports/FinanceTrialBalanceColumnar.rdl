                          <CanGrow>true</CanGrow>
                          <KeepTogether>true</KeepTogether>
                          <Paragraphs>
                            <Paragraph>
                              <TextRuns>
                                <TextRun>
                                  <Value>=Sum(Fields!Amount.Value)</Value>
                                  <Style>
                                    <FontSize>11pt</FontSize>
                                    <Format>n2</Format>
                                    <Color>DarkViolet</Color>
                                  </Style>
                                </TextRun>
                              </TextRuns>
