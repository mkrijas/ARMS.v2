                              <TextRuns>
                                <TextRun>
                                  <Value>   Balance as on </Value>
                                  <Style>
                                    <FontSize>12pt</FontSize>
                                    <FontWeight>Bold</FontWeight>
                                    <Color>#963634</Color>
                                  </Style>
                                </TextRun>
                                <TextRun>
                                  <Value>=Parameters!ToDate.Value</Value>
                                  <Style>
                                    <FontSize>12pt</FontSize>
                                    <FontWeight>Bold</FontWeight>
                                    <Format>dd-MMM-yy</Format>
