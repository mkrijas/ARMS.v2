                                    <FontSize>12pt</FontSize>
                                    <FontWeight>Bold</FontWeight>
                                    <Color>#963634</Color>
                                  </Style>
                                </TextRun>
                                <TextRun>
                                  <Label>Balance</Label>
                                  <Value>= Sum(Fields!Amount.Value, "Balance") + Sum(Max(Fields!Amount.Value,  "MID"))</Value>
                                  <Style>
                                    <FontStyle>Normal</FontStyle>
                                    <FontFamily />
                                    <FontSize>12pt</FontSize>
                                    <FontWeight>Bold</FontWeight>
                                    <Format>'₹' #,0.00;'₹' -#,0.00;'-'</Format>
                                    <Color>#963634</Color>
                                    <rd:FormatSymbolCulture>en-IN</rd:FormatSymbolCulture>
                                  </Style>
                                </TextRun>
                                <TextRun>
                                  <Value xml:space="preserve">  </Value>
