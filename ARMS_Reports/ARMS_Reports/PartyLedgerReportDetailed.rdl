                    <TablixCell>
                      <CellContents>
                        <Textbox Name="ClosingBal">
                          <CanGrow>true</CanGrow>
                          <KeepTogether>true</KeepTogether>
                          <Paragraphs>
                            <Paragraph>
                              <TextRuns>
                                <TextRun>
                                  <Label>Closing</Label>
                                  <Value>=ReportItems!opBal.Value + Sum(Max(Fields!Amount.Value,  "MID"))</Value>
                                  <Style>
                                    <FontFamily />
                                    <FontSize>11pt</FontSize>
                                    <FontWeight>Bold</FontWeight>
                                    <Format>'₹'#,0.00;'₹'-#,0.00;'-'</Format>
                                    <Color>Maroon</Color>
                                    <rd:FormatSymbolCulture>en-IN</rd:FormatSymbolCulture>
                                  </Style>
                                </TextRun>
                              </TextRuns>
                              <Style>
                                <TextAlign>Right</TextAlign>
                              </Style>
                            </Paragraph>
                          </Paragraphs>
                          <Style>
