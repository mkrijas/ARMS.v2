                          <Paragraphs>
                            <Paragraph>
                              <TextRuns>
                                <TextRun>
                                  <Label>TripPercentage</Label>
                                  <Value>=IIf(IsNothing(ReportItems!TripID.Value) Or ReportItems!TripID.Value = 0, "-", Count(Fields!TripID.Value) / ReportItems!TripID.Value)</Value>
                                  <Style>
                                    <FontFamily />
                                    <Format>0.00 %</Format>
                                  </Style>
                                </TextRun>
