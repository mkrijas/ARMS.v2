                            <Border>
                              <Style>None</Style>
                            </Border>
                            <BottomBorder>
                              <Color>Black</Color>
                              <Style>Solid</Style>
                              <Width>1pt</Width>
                            </BottomBorder>
                            <RightBorder>
                              <Color>Black</Color>
                              <Style>Solid</Style>
                              <Width>1pt</Width>
                            </RightBorder>
                            <VerticalAlign>Middle</VerticalAlign>
                            <PaddingLeft>2pt</PaddingLeft>
                            <PaddingRight>2pt</PaddingRight>
                            <PaddingTop>2pt</PaddingTop>
                            <PaddingBottom>2pt</PaddingBottom>
                          </Style>
                        </Textbox>
                      </CellContents>
                      <DataElementOutput>Output</DataElementOutput>
                    </TablixCell>
                    <TablixCell>
                      <CellContents>
                        <Textbox Name="Textbox3120">
                          <CanGrow>true</CanGrow>
                          <KeepTogether>true</KeepTogether>
                          <Paragraphs>
                            <Paragraph>
                              <TextRuns>
                                <TextRun>
                                  <Label>GROSS PROFIT</Label>
                                  <Value>= Sum(IIF(Fields!AccountType.Value = "REVENUE",Fields!TotalAmount.Value,NOTHING))
- (Fields!ActualFuelCost.Value + Fields!MileageReceiptAmount.Value - Fields!AllowanceAmount.Value)
- Fields!ActualBatta.Value 
- Fields!ActualToll.Value 
- Fields!ActualLoading.Value
-  Fields!ActualTagging.Value
- Fields!ActualUnloading.Value 
- Fields!ActualADBLUECost.Value
- Sum(IIF(Fields!AccountType.Value = "EXPENSES",Fields!TotalAmount.Value,NOTHING))</Value>
                                  <Style>
                                    <Format>n2</Format>
                                  </Style>
                                </TextRun>
