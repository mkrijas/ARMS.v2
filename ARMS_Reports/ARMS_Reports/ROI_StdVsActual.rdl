                    <TablixCell>
                      <CellContents>
                        <Textbox Name="Textbox5838">
                          <CanGrow>true</CanGrow>
                          <KeepTogether>true</KeepTogether>
                          <Paragraphs>
                            <Paragraph>
                              <TextRuns>
                                <TextRun>
                                  <Label>NET PROFIT</Label>
                                  <Value>= Sum(IIF(Fields!AccountType.Value = "REVENUE",Fields!TotalAmount.Value,NOTHING))
- Fields!StdFuelCost.Value
- Fields!StdBatta.Value 
- Fields!StdToll.Value 
- Fields!StdTagging.Value
- Fields!StdUnloading.Value 
- Fields!StdLoadingCharges.Value
- Fields!StdAdblueCost.Value
- Sum(IIF(Fields!AccountType.Value = "EXPENSES",Fields!TotalAmount.Value,NOTHING))
- Fields!HOAdmin.Value
- Fields!BranchAdmin.Value
- (Fields!Tyre.Value *  Fields!SystemKM.Value)
- (Fields!Maintenance.Value  * Fields!SystemKM.Value)
- ReportItems!tbTaxStd.Value
- ReportItems!tbFcStd.Value</Value>
                                  <Style>
                                    <Format>n2</Format>
                                  </Style>
                                </TextRun>
                              </TextRuns>
                              <Style>
                                <TextAlign>Right</TextAlign>
                              </Style>
                            </Paragraph>
                          </Paragraphs>
                          <rd:DefaultName>Textbox5838</rd:DefaultName>
                          <Style>
                            <Border>
                              <Style>None</Style>
                            </Border>
                            <BottomBorder>
                              <Color>Black</Color>
                              <Style>Solid</Style>
                              <Width>1pt</Width>
                            </BottomBorder>
                            <RightBorder>
                              <Color>Black</Color>
                              <Style>Solid</Style>
                              <Width>1pt</Width>
                            </RightBorder>
                            <VerticalAlign>Middle</VerticalAlign>
                            <PaddingLeft>2pt</PaddingLeft>
                            <PaddingRight>2pt</PaddingRight>
                            <PaddingTop>2pt</PaddingTop>
                            <PaddingBottom>2pt</PaddingBottom>
                          </Style>
                        </Textbox>
                      </CellContents>
                      <DataElementOutput>Output</DataElementOutput>
                    </TablixCell>
                    <TablixCell>
                      <CellContents>
                        <Textbox Name="tbNetProfitActual">
                          <CanGrow>true</CanGrow>
                          <KeepTogether>true</KeepTogether>
                          <Paragraphs>
                            <Paragraph>
                              <TextRuns>
                                <TextRun>
                                  <Label>NET PROFIT</Label>
                                  <Value>= Sum(IIF(Fields!AccountType.Value = "REVENUE",Fields!TotalAmount.Value,NOTHING))
- (Fields!ActualFuelCost.Value + Fields!MileageReceiptAmount.Value - Fields!AllowanceAmount.Value)
- Fields!ActualBatta.Value 
- Fields!ActualToll.Value 
- Fields!ActualLoading.Value
-  Fields!ActualTagging.Value
- Fields!ActualUnloading.Value 
- Fields!ActualADBLUECost.Value
- Sum(IIF(Fields!AccountType.Value = "EXPENSES",Fields!TotalAmount.Value,NOTHING))
- Fields!HOAdmin.Value
- Fields!BranchAdmin.Value
- (Fields!Tyre.Value *  Fields!RunningKm.Value)
- (Fields!Maintenance.Value  * Fields!RunningKm.Value)
- (Fields!TaxAndInsurance.Value *  Fields!TotalTimeDiff.Value/24)
- (Fields!FC.Value *  Fields!TotalTimeDiff.Value/24)</Value>
                                  <Style>
                                    <Format>n2</Format>
                                  </Style>
                                </TextRun>
                              </TextRuns>
                              <Style>
                                <TextAlign>Right</TextAlign>
                              </Style>
                            </Paragraph>
                          </Paragraphs>
                          <Style>
                            <Border>
                              <Style>None</Style>
                            </Border>
                            <BottomBorder>
                              <Style>Solid</Style>
                            </BottomBorder>
                            <RightBorder>
                              <Style>Solid</Style>
                            </RightBorder>
                            <VerticalAlign>Middle</VerticalAlign>
                            <PaddingLeft>2pt</PaddingLeft>
                            <PaddingRight>2pt</PaddingRight>
                            <PaddingTop>2pt</PaddingTop>
                            <PaddingBottom>2pt</PaddingBottom>
                          </Style>
                        </Textbox>
                      </CellContents>
                      <DataElementOutput>Output</DataElementOutput>
                    </TablixCell>
                    <TablixCell>
                      <CellContents>
                        <Textbox Name="Textbox218">
                          <CanGrow>true</CanGrow>
                          <KeepTogether>true</KeepTogether>
                          <Paragraphs>
                            <Paragraph>
                              <TextRuns>
                                <TextRun>
                                  <Value>= 
ReportItems!tbNetProfitActual.Value/
Sum(IIF(Fields!AccountType.Value = "REVENUE",Fields!TotalAmount.Value,NOTHING))</Value>
                                  <Style>
                                    <Format>0.00%</Format>
                                  </Style>
                                </TextRun>
                              </TextRuns>
                              <Style>
