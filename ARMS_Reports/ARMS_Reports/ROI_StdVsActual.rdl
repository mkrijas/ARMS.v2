                    </TablixCell>
                    <TablixCell>
                      <CellContents>
                        <Textbox Name="Textbox3110">
                          <CanGrow>true</CanGrow>
                          <KeepTogether>true</KeepTogether>
                          <Paragraphs>
                            <Paragraph>
                              <TextRuns>
                                <TextRun>
                                  <Label>Total Exp</Label>
                                  <Value>=Fields!ActualFuelCost.Value + Fields!ActualBatta.Value - (Fields!MileageReceiptAmount.Value- Fields!AllowanceAmount.Value)
+ Fields!ActualToll.Value + Fields!ActualTagging.Value
+ Fields!ActualUnloading.Value + Fields!ActualADBLUECost.Value
+ Sum(IIF(Fields!AccountType.Value = "EXPENSES",Fields!TotalAmount.Value,NOTHING))</Value>
                                  <Style />
                                </TextRun>
                              </TextRuns>
                              <Style>
                                <TextAlign>Right</TextAlign>
                              </Style>
                            </Paragraph>
                          </Paragraphs>
                          <rd:DefaultName>Textbox3110</rd:DefaultName>
                          <Style>
                            <Border>
                              <Style>None</Style>
                            </Border>
                            <BottomBorder>
                              <Color>Black</Color>
                              <Style>Solid</Style>
                              <Width>1pt</Width>
                            </BottomBorder>
                            <RightBorder>
                              <Color>Black</Color>
                              <Style>Solid</Style>
                              <Width>1pt</Width>
                            </RightBorder>
                            <VerticalAlign>Middle</VerticalAlign>
                            <PaddingLeft>2pt</PaddingLeft>
                            <PaddingRight>2pt</PaddingRight>
                            <PaddingTop>2pt</PaddingTop>
                            <PaddingBottom>2pt</PaddingBottom>
                          </Style>
                        </Textbox>
                      </CellContents>
                      <DataElementOutput>Output</DataElementOutput>
                    </TablixCell>
                    <TablixCell>
                      <CellContents>
                        <Textbox Name="Textbox79">
                          <CanGrow>true</CanGrow>
                          <KeepTogether>true</KeepTogether>
                          <Paragraphs>
                            <Paragraph>
                              <TextRuns>
                                <TextRun>
                                  <Label>GROSS PROFIT std</Label>
                                  <Value>= Sum(IIF(Fields!AccountType.Value = "REVENUE",Fields!TotalAmount.Value,NOTHING))
- Fields!StdFuelCost.Value
- Fields!StdBatta.Value 
- Fields!StdToll.Value 
- Fields!StdTagging.Value
- Fields!StdUnloading.Value 
- Fields!StdLoadingCharges.Value
- Fields!StdAdblueCost.Value
- Sum(IIF(Fields!AccountType.Value = "EXPENSES",Fields!TotalAmount.Value,NOTHING))</Value>
                                  <Style>
                                    <Format>n2</Format>
                                  </Style>
                                </TextRun>
                              </TextRuns>
                              <Style>
                                <TextAlign>Right</TextAlign>
                              </Style>
                            </Paragraph>
                          </Paragraphs>
                          <rd:DefaultName>Textbox79</rd:DefaultName>
