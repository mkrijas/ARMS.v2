                <TablixRow>
                  <Height>0.35417in</Height>
                  <TablixCells>
                    <TablixCell>
                      <CellContents>
                        <Textbox Name="Textbox40">
                          <CanGrow>true</CanGrow>
                          <KeepTogether>true</KeepTogether>
                          <Paragraphs>
                            <Paragraph>
                              <TextRuns>
                                <TextRun>
                                  <Label>BranchName</Label>
                                  <Value>=Lookup( Fields!BranchID.Value,Fields!BranchID.Value , Fields!BranchName.Value, "Branches")</Value>
                                  <Style>
                                    <FontSize>14pt</FontSize>
                                    <FontWeight>Bold</FontWeight>
                                    <Color>Blue</Color>
                                  </Style>
                                </TextRun>
                                <TextRun>
                                  <Value> (</Value>
                                  <Style>
                                    <FontSize>14pt</FontSize>
                                    <FontWeight>Bold</FontWeight>
                                    <Color>Blue</Color>
                                  </Style>
                                </TextRun>
                                <TextRun>
                                  <Label>Count</Label>
                                  <Value>= RTrim(Count(Fields!TruckID.Value)) + " Trucks"</Value>
                                  <Style>
                                    <FontFamily />
                                    <FontSize>14pt</FontSize>
                                    <FontWeight>Bold</FontWeight>
                                    <Color>Blue</Color>
                                  </Style>
                                </TextRun>
                                <TextRun>
                                  <Value>)   ; </Value>
                                  <Style>
                                    <FontFamily />
                                    <FontSize>14pt</FontSize>
                                    <FontWeight>Bold</FontWeight>
                                    <Color>Blue</Color>
                                  </Style>
                                </TextRun>
                                <TextRun>
                                  <Value>Driverless Trucks : </Value>
                                  <Style>
                                    <FontFamily />
                                    <FontSize>14pt</FontSize>
                                    <FontWeight>Bold</FontWeight>
                                    <Color>Red</Color>
                                  </Style>
                                </TextRun>
                                <TextRun>
                                  <Label>CountNoDriver</Label>
                                  <Value>=Sum(IIF(Fields!NoDriverText.Value = "NO DRIVER",1,0))</Value>
                                  <Style>
                                    <FontFamily />
                                    <FontSize>14pt</FontSize>
                                    <FontWeight>Bold</FontWeight>
                                    <Color>Red</Color>
                                  </Style>
                                </TextRun>
                              </TextRuns>
                              <Style>
                                <TextAlign>Left</TextAlign>
                              </Style>
                            </Paragraph>
                          </Paragraphs>
                          <rd:DefaultName>Textbox40</rd:DefaultName>
                          <Style>
