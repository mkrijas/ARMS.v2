                      <TextRun>
                        <Label>Branches</Label>
                        <Value>=Join(Multilookup(Split(Parameters!BranchIDS.Value,",") , CStr(Fields!BranchID.Value),Fields!BranchName.Value,"Branches"),",")</Value>
                        <Style>
