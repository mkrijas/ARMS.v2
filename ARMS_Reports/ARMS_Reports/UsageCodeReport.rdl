    <DataSet Name="UsageCode">
      <Query>
        <DataSourceName>ARMSV2DataBase</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@ArdCode">
            <Value>=Parameters!ArdCode.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT u.[Description],u.Area,r.[Description] Rate from [Finance.Taxes.Gst.UsageID] u 
JOIN [Finance.Taxes.Gst.Rates] r ON u.RID = r.RID  
WHERE UsageCode = @ArdCode</CommandText>
      </Query>
      <Fields>
        <Field Name="Description">
          <DataField>Description</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Area">
          <DataField>Area</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Rate">
          <DataField>Rate</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
