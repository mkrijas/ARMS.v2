                      <CellContents>
                        <Textbox Name="Textbox53">
                          <CanGrow>true</CanGrow>
                          <KeepTogether>true</KeepTogether>
                          <Paragraphs>
                            <Paragraph>
                              <TextRuns>
                                <TextRun>
                                  <Value>Branch : </Value>
                                  <Style>
                                    <FontFamily>Arial</FontFamily>
                                    <FontSize>12pt</FontSize>
                                    <FontWeight>Bold</FontWeight>
                                  </Style>
                                </TextRun>
                                <TextRun>
                                  <Label>BranchName</Label>
                                  <Value>=Lookup( Fields!BranchID.Value,Fields!BranchID.Value , Fields!BranchName.Value, "Branches")</Value>
                                  <Style>
                                    <FontFamily>Arial</FontFamily>
                                    <FontSize>12pt</FontSize>
                                    <FontWeight>Bold</FontWeight>
                                  </Style>
                                </TextRun>
                                <TextRun>
                                  <Value>                  ( Balance as on </Value>
                                  <Style>
                                    <FontFamily>Arial</FontFamily>
                                    <FontSize>12pt</FontSize>
                                    <FontWeight>Bold</FontWeight>
                                  </Style>
                                </TextRun>
