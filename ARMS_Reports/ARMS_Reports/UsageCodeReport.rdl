                                    <FontSize>12pt</FontSize>
                                    <FontWeight>Bold</FontWeight>
                                    <Format>dd-MMM-yy</Format>
                                  </Style>
                                </TextRun>
                                <TextRun>
                                  <Value> : </Value>
                                  <Style>
                                    <FontFamily>Arial</FontFamily>
                                    <FontSize>12pt</FontSize>
                                    <FontWeight>Bold</FontWeight>
                                    <Format>dd-MMM-yy</Format>
                                  </Style>
                                </TextRun>
                                <TextRun>
                                  <Label>BranchBalance</Label>
                                  <Value>
																		= Code.SumLookup( LookupSet(
																		Fields!BranchID.Value,
																		Fields!BranchID.Value,
																		Fields!Amount.Value,
																		"Balance")) + Sum(Fields!Amount.Value)
																	</Value>
                                  <Style>
                                    <FontStyle>Normal</FontStyle>
                                    <FontFamily />
                                    <FontSize>12pt</FontSize>
                                    <FontWeight>Bold</FontWeight>
                                    <Format>'₹' #,0.00;'₹' -#,0.00;'-'</Format>
                                    <Color>#333333</Color>
                                    <rd:FormatSymbolCulture>en-IN</rd:FormatSymbolCulture>
                                  </Style>
                                </TextRun>
                                <TextRun>
                                  <Value> )</Value>
                                  <Style>
                                    <FontStyle>Normal</FontStyle>
                                    <FontFamily />
                                    <FontSize>12pt</FontSize>
                                    <FontWeight>Bold</FontWeight>
                                    <Format>'₹' #,0.00;'₹' -#,0.00;'-'</Format>
