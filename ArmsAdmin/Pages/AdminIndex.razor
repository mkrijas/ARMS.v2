@page "/Admin"
@layout AdminMainLayout
@attribute [Authorize(Policy = "Admin")]
@using Core.IDataServices.User
@using MudBlazor.Charts
@inject IUserService UserService
@inject IDeviceService DeviceService
@inject IDataAuthorizationService das

<AuthorizeView>
    <Authorized>
        <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-8 mb-12">
            <!-- Header Section -->
            <div class="header-section mb-10">
                <div class="d-flex justify-space-between align-end">
                    <div>
                        <MudText Typo="Typo.h4" Class="admin-title mb-2"><b>Admin Dashboard</b></MudText>
                        <div class="title-accent mb-4"></div>
                        <MudText Typo="Typo.body1" Class="admin-subtitle" Style="color: #667085;">
                            Welcome back! Monitor system health, user trends, and device activity.
                        </MudText>
                    </div>
                    <div class="date-badge pa-3 mb-1">
                        <MudIcon Icon="@Icons.Material.Filled.CalendarToday" Size="Size.Small" Class="mr-2" />
                        <MudText Typo="Typo.subtitle2"><b>@DateTime.Now.ToString("dd MMM yyyy")</b></MudText>
                    </div>
                </div>
            </div>

            <MudGrid Spacing="4">
                <!-- Stats Cards Row -->
                <MudItem xs="12" sm="6" md="3">
                    <div class="admin-card-wrapper">
                        <MudPaper Class="admin-glass-card pa-8" Elevation="0">
                            <div class="d-flex justify-space-between align-start">
                                <div>
                                    <MudText Typo="Typo.body2" Class="stat-label mb-1">Total Users</MudText>
                                    <MudText Typo="Typo.h3" Class="stat-value"><b>@TotalUsers</b></MudText>
                                    <div class="stat-trend positive mt-4">
                                        <MudIcon Icon="@Icons.Material.Filled.ArrowUpward" Size="Size.Small" />
                                        <MudText Typo="Typo.caption">ARMS Integrated</MudText>
                                    </div>
                                </div>
                                <div class="icon-badge primary-badge">
                                    <MudIcon Icon="@Icons.Material.Filled.People" Size="Size.Large" />
                                </div>
                            </div>
                        </MudPaper>
                    </div>
                </MudItem>

                <MudItem xs="12" sm="6" md="3">
                    <div class="admin-card-wrapper">
                        <MudPaper Class="admin-glass-card pa-8" Elevation="0">
                            <div class="d-flex justify-space-between align-start">
                                <div>
                                    <MudText Typo="Typo.body2" Class="stat-label mb-1">Pending Users</MudText>
                                    <MudText Typo="Typo.h3" Class="stat-value"><b>@PendingUsers</b></MudText>
                                    <div class="stat-trend warning mt-4">
                                        <MudIcon Icon="@Icons.Material.Filled.HourglassEmpty" Size="Size.Small" />
                                        <MudText Typo="Typo.caption">Awaiting Approval</MudText>
                                    </div>
                                </div>
                                <div class="icon-badge warning-badge">
                                    <MudIcon Icon="@Icons.Material.Filled.PendingActions" Size="Size.Large" />
                                </div>
                            </div>
                        </MudPaper>
                    </div>
                </MudItem>

                <MudItem xs="12" sm="6" md="3">
                    <div class="admin-card-wrapper">
                        <MudPaper Class="admin-glass-card pa-8" Elevation="0">
                            <div class="d-flex justify-space-between align-start">
                                <div>
                                    <MudText Typo="Typo.body2" Class="stat-label mb-1">Total Devices</MudText>
                                    <MudText Typo="Typo.h3" Class="stat-value"><b>@TotalDevices</b></MudText>
                                    <div class="stat-trend info mt-4">
                                        <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Size="Size.Small" />
                                        <MudText Typo="Typo.caption">Active Mobile</MudText>
                                    </div>
                                </div>
                                <div class="icon-badge info-badge">
                                    <MudIcon Icon="@Icons.Material.Filled.PhoneAndroid" Size="Size.Large" />
                                </div>
                            </div>
                        </MudPaper>
                    </div>
                </MudItem>

                <MudItem xs="12" sm="6" md="3">
                    <div class="admin-card-wrapper">
                        <MudPaper Class="admin-glass-card pa-8" Elevation="0">
                            <div class="d-flex justify-space-between align-start">
                                <div>
                                    <MudText Typo="Typo.body2" Class="stat-label mb-1">Device Requests</MudText>
                                    <MudText Typo="Typo.h3" Class="stat-value"><b>@pendingDevices</b></MudText>
                                    <div class="stat-trend danger mt-4">
                                        <MudIcon Icon="@Icons.Material.Filled.PriorityHigh" Size="Size.Small" />
                                        <MudText Typo="Typo.caption">Requires Attention</MudText>
                                    </div>
                                </div>
                                <div class="icon-badge danger-badge">
                                    <MudIcon Icon="@Icons.Material.Filled.WarningAmber" Size="Size.Large" />
                                </div>
                            </div>
                        </MudPaper>
                    </div>
                </MudItem>

                <!-- Visualization Row -->
                <MudItem xs="12" lg="8">
                    <MudPaper Class="admin-glass-card pa-8 h-100" Elevation="0">
                        <div class="d-flex justify-space-between align-center mb-8">
                            <div>
                                <MudText Typo="Typo.h6" Class="card-title">Registration Trends</MudText>
                                <MudText Typo="Typo.caption" Style="color: #667085;">Monthly overview of system growth</MudText>
                            </div>
                            <MudIcon Icon="@Icons.Material.Filled.BarChart" Color="Color.Primary" />
                        </div>
                        <MudChart T="double" ChartType="ChartType.Line" ChartSeries="@Series" XAxisLabels="@XAxisLabels" Width="100%" Height="350px" ChartOptions="@chartOptions" />
                    </MudPaper>
                </MudItem>

                <MudItem xs="12" lg="4">
                    <MudPaper Class="admin-glass-card pa-8 h-100" Elevation="0">
                        <div class="d-flex justify-space-between align-center mb-6">
                            <MudText Typo="Typo.h6" Class="card-title">Recent Activity Log</MudText>
                            <MudIconButton Icon="@Icons.Material.Filled.History" Size="Size.Small" />
                        </div>
                        <div class="activity-timeline">
                            @foreach (var item in authData.Take(6))
                            {
                                <div class="timeline-item pb-4">
                                    <div class="timeline-dot"></div>
                                    <div class="timeline-content">
                                        <div class="d-flex justify-space-between align-center">
                                            <MudText Typo="Typo.caption" Class="timeline-time">@item.UserInfo.TimeStampField?.ToString("g")</MudText>
                                            <MudChip T="string" Size="Size.Small" Variant="Variant.Text" Color="Color.Primary" Class="px-2">@item.DocType</MudChip>
                                        </div>
                                        <MudText Typo="Typo.body2" Class="mt-1">
                                            <b>@item.UserInfo.UserID</b> performed <b>@item.AuthType</b>
                                        </MudText>
                                    </div>
                                </div>
                            }
                        </div>
                        @if (authData.Count > 6)
                        {
                            <div class="d-flex justify-center mt-4">
                                <MudButton Variant="Variant.Text" Color="Color.Primary" EndIcon="@Icons.Material.Filled.ChevronRight" Href="/ActivityLogView">View All</MudButton>
                            </div>
                        }
                    </MudPaper>
                </MudItem>
            </MudGrid>
        </MudContainer>
    </Authorized>
    <NotAuthorized>
        <div class="auth-placeholder-wrapper">
             <MudGrid Spacing="0">
                <MudItem xs="12" md="8">
                    <div class="auth-bg-panel" style="background-image: url('ArmsStaticFiles/bgImage.jpg');">
                        <div class="auth-overlay"></div>
                        <div class="auth-content pa-12">
                            <MudText Typo="Typo.h2" Class="white-text mb-4">Premium Admin Experience</MudText>
                            <MudText Typo="Typo.h5" Class="white-text opacity-70">Secure, Innovative, Seamless</MudText>
                        </div>
                    </div>
                </MudItem>
                <MudItem xs="12" md="4">
                    <div class="auth-truck-panel" style="background-image: url('ArmsStaticFiles/Truck.jpg');">
                         <div class="auth-overlay-secondary"></div>
                    </div>
                </MudItem>
            </MudGrid>
        </div>
    </NotAuthorized>
</AuthorizeView>

<style>
    /* Header & Branding */
    .admin-title {
        font-family: 'Outfit', sans-serif;
        font-weight: 800;
        color: #141A46;
        letter-spacing: -0.5px;
    }

    .title-accent {
        width: 60px;
        height: 4px;
        background: linear-gradient(90deg, #367588 0%, #FF9F43 100%);
        border-radius: 2px;
    }

    .date-badge {
        background: rgba(54, 117, 136, 0.1);
        color: #367588;
        border-radius: 12px;
        display: flex;
        align-items: center;
    }

    /* Glass Cards */
    .admin-glass-card {
        background: rgba(255, 255, 255, 0.7) !important;
        backdrop-filter: blur(12px) !important;
        -webkit-backdrop-filter: blur(12px) !important;
        border: 1px solid rgba(255, 255, 255, 0.3) !important;
        border-radius: 24px !important;
        box-shadow: 0 8px 32px 0 rgba(31, 38, 135, 0.05) !important;
        height: 100%;
        transition: transform 0.3s ease, box-shadow 0.3s ease !important;
    }

    .admin-card-wrapper:hover .admin-glass-card {
        transform: translateY(-8px);
        box-shadow: 0 12px 40px 0 rgba(31, 38, 135, 0.1) !important;
    }

    /* Icon Badges */
    .icon-badge {
        width: 64px;
        height: 64px;
        border-radius: 20px;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.3s ease;
    }

    .primary-badge { 
        background: rgba(54, 117, 136, 0.1); 
        color: #367588;
        box-shadow: 0 4px 15px rgba(54, 117, 136, 0.1);
    }
    .warning-badge { 
        background: rgba(255, 159, 67, 0.1); 
        color: #FF9F43;
        box-shadow: 0 4px 15px rgba(255, 159, 67, 0.1);
    }
    .info-badge { 
        background: rgba(0, 200, 83, 0.1); 
        color: #00C853;
        box-shadow: 0 4px 15px rgba(0, 200, 83, 0.1);
    }
    .danger-badge { 
        background: rgba(244, 67, 54, 0.1); 
        color: #F44336;
        box-shadow: 0 4px 15px rgba(244, 67, 54, 0.1);
    }

    /* Stat Typography */
    .stat-value {
        font-family: 'Outfit', sans-serif;
        font-weight: 800;
        color: #141A46;
        line-height: 1;
        letter-spacing: -1px;
    }

    .stat-label {
        color: #64748b;
        font-weight: 600;
        font-family: 'Inter', sans-serif;
        text-transform: uppercase;
        font-size: 0.75rem;
        letter-spacing: 0.5px;
    }

    /* Trends */
    .stat-trend {
        display: flex;
        align-items: center;
        gap: 4px;
        font-weight: 600;
    }

    .positive { color: #00C853; }
    .warning { color: #FF9F43; }
    .info { color: #594AE2; }
    .danger { color: #F44336; }

    /* Timeline */
    .timeline-item {
        position: relative;
        padding-left: 24px;
        border-left: 2px solid rgba(54, 117, 136, 0.1);
    }

    .timeline-dot {
        position: absolute;
        left: -7px;
        top: 4px;
        width: 12px;
        height: 12px;
        background: #367588;
        border-radius: 50%;
        border: 2px solid white;
    }

    .timeline-time {
        color: #94a3b8;
        font-weight: 500;
    }

    /* Auth Placeholder */
    .auth-placeholder-wrapper {
        height: 80vh;
        border-radius: 32px;
        overflow: hidden;
        margin-top: 2rem;
        box-shadow: 0 20px 50px rgba(0,0,0,0.1);
    }

    .auth-bg-panel {
        height: 100%;
        background-size: cover;
        background-position: center;
        position: relative;
        display: flex;
        align-items: center;
    }

    .auth-overlay {
        position: absolute;
        top: 0; left: 0; width: 100%; height: 100%;
        background: linear-gradient(135deg, rgba(20, 26, 70, 0.9) 0%, rgba(54, 117, 136, 0.7) 100%);
    }

    .auth-content {
        position: relative;
        z-index: 2;
    }

    .auth-truck-panel {
        height: 100%;
        background-size: cover;
        background-position: center;
        position: relative;
    }

    .auth-overlay-secondary {
        position: absolute;
        top: 0; left: 0; width: 100%; height: 100%;
        background: rgba(255, 159, 67, 0.2);
    }

    .white-text { color: white; }
    .opacity-70 { opacity: 0.7; }
</style>

@code {

    int TotalUsers = 0;
    int pendingDevices = 0;
    int TotalDevices = 0;
    int PendingUsers = 0;
    List<DataAuthorizationModel> authData = new();

    private LineChartOptions chartOptions = new LineChartOptions()
    {
        InterpolationOption = InterpolationOption.NaturalSpline,
        LineStrokeWidth = 3,
        ChartPalette = new[] { "#367588", "#FF9F43", "#00C853", "#F44336" }
    };

    public List<ChartSeries<double>> Series = new List<ChartSeries<double>>()
    {
         new ChartSeries<double>() { Name = "New Users", Data = new double[] { 40, 55, 45, 60, 75, 85, 80, 95, 110 } },
    };
    public string[] XAxisLabels = { "Jan", "Feb", "Mar", "Apr", "May", "Jun", "Jul", "Aug", "Sep" };

    protected override async Task OnInitializedAsync()
    {
        chartOptions.YAxisTicks = 10;
        Load();
    }

    void Load()
    {
       var users =    UserService.Select(null).ToList();
       var ApprovedDevices = DeviceService.Select("Approved").ToList();
       var pendDev = DeviceService.Select("Pending").ToList();

        authData = das.GetAll().ToList();

        TotalUsers = users.Count();
        PendingUsers = users.Where(x => !x.EmailConfirmed).Count();
        TotalDevices = ApprovedDevices.Count();
        pendingDevices = pendDev.Count();
        
    }
}