@page "/Admin"
@layout AdminMainLayout
@attribute [Authorize(Policy = "Admin")]

<AuthorizeView>
    <Authorized>
        <MudContainer MaxWidth="MaxWidth.Large" Class="mt-4">
            <div class="d-flex justify-content-between align-center mb-4">
                <div>
                    <MudText Typo="Typo.h5" Color="Color.Primary" Class="mb-1"><b>Welcome back, Admin!</b></MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">Here's what's happening today.</MudText>
                </div>
                <MudText Typo="Typo.subtitle2" Class="mud-text-secondary">@DateTime.Now.ToString("dd MMM yyyy")</MudText>
            </div>

            <MudGrid>
                <!-- Stats Cards -->
                <MudItem xs="12" sm="6" md="3">
                    <MudPaper Elevation="2" Class="pa-4 d-flex flex-column gap-2" Style="border-left: 4px solid #594AE2;">
                        <MudText Typo="Typo.subtitle2" Color="Color.Secondary">Total Users</MudText>
                        <div class="d-flex justify-content-between align-center">
                             <MudText Typo="Typo.h4"><b>1,240</b></MudText>
                             <MudIcon Icon="@Icons.Material.Filled.People" Color="Color.Primary" Size="Size.Large" />
                        </div>
                        <MudText Typo="Typo.caption" Color="Color.Success">+12% from last month</MudText>
                    </MudPaper>
                </MudItem>
                <MudItem xs="12" sm="6" md="3">
                    <MudPaper Elevation="2" Class="pa-4 d-flex flex-column gap-2" Style="border-left: 4px solid #00C853;">
                         <MudText Typo="Typo.subtitle2" Color="Color.Secondary">Total Revenue</MudText>
                         <div class="d-flex justify-content-between align-center">
                             <MudText Typo="Typo.h4"><b>$45,200</b></MudText>
                             <MudIcon Icon="@Icons.Material.Filled.AttachMoney" Color="Color.Success" Size="Size.Large" />
                         </div>
                         <MudText Typo="Typo.caption" Color="Color.Success">+5% from last month</MudText>
                    </MudPaper>
                </MudItem>
                <MudItem xs="12" sm="6" md="3">
                    <MudPaper Elevation="2" Class="pa-4 d-flex flex-column gap-2" Style="border-left: 4px solid #FF9800;">
                         <MudText Typo="Typo.subtitle2" Color="Color.Secondary">Active Orders</MudText>
                         <div class="d-flex justify-content-between align-center">
                             <MudText Typo="Typo.h4"><b>85</b></MudText>
                             <MudIcon Icon="@Icons.Material.Filled.ShoppingCart" Color="Color.Warning" Size="Size.Large" />
                         </div>
                         <MudText Typo="Typo.caption" Color="Color.Error">-2% from last week</MudText>
                    </MudPaper>
                </MudItem>
                <MudItem xs="12" sm="6" md="3">
                    <MudPaper Elevation="2" Class="pa-4 d-flex flex-column gap-2" Style="border-left: 4px solid #F44336;">
                         <MudText Typo="Typo.subtitle2" Color="Color.Secondary">Pending Requests</MudText>
                         <div class="d-flex justify-content-between align-center">
                             <MudText Typo="Typo.h4"><b>12</b></MudText>
                             <MudIcon Icon="@Icons.Material.Filled.PendingActions" Color="Color.Error" Size="Size.Large" />
                         </div>
                         <MudText Typo="Typo.caption" Color="Color.Secondary">Requires attention</MudText>
                    </MudPaper>
                </MudItem>

                <!-- Charts & Recent Activity -->
                <MudItem xs="12" md="8">
                    <MudPaper Elevation="2" Class="pa-4">
                        <MudText Typo="Typo.h6" Class="mb-4">User Registration Trends</MudText>
                        <MudChart ChartType="ChartType.Line" ChartSeries="@Series" XAxisLabels="@XAxisLabels" Width="100%" Height="300px"></MudChart>
                    </MudPaper>
                </MudItem>
                <MudItem xs="12" md="4">
                     <MudPaper Elevation="2" Class="pa-4" Style="height: 100%;">
                        <MudText Typo="Typo.h6" Class="mb-3">Recent Activities</MudText>
                        <MudList T="string" Clickable="false" Dense="true">
                            <MudListItem T="string" Icon="@Icons.Material.Filled.PersonAdd" IconColor="Color.Primary">
                                <ChildContent>New user registered: <b>John Doe</b></ChildContent>
                            </MudListItem>
                            <MudListItem T="string" Icon="@Icons.Material.Filled.CheckCircle" IconColor="Color.Success">
                                <ChildContent>Order #1023 completed</ChildContent>
                            </MudListItem>
                            <MudListItem T="string" Icon="@Icons.Material.Filled.Warning" IconColor="Color.Warning">
                                <ChildContent>Stock alert: Item #445 low</ChildContent>
                            </MudListItem>
                             <MudListItem T="string" Icon="@Icons.Material.Filled.Payment" IconColor="Color.Info">
                                <ChildContent>Payment received: $150.00</ChildContent>
                            </MudListItem>
                        </MudList>
                    </MudPaper>
                </MudItem>

                <!-- Transactions Table -->
                 <MudItem xs="12">
                    <MudPaper Elevation="2" Class="pa-4">
                         <MudText Typo="Typo.h6" Class="mb-3">Recent Transactions</MudText>
                         <MudTable Items="@Elements" Hover="true" Breakpoint="Breakpoint.Sm" >
                            <HeaderContent>
                                <MudTh>Date</MudTh>
                                <MudTh>Transaction ID</MudTh>
                                <MudTh>User</MudTh>
                                <MudTh>Amount</MudTh>
                                <MudTh>Status</MudTh>
                            </HeaderContent>
                            <RowTemplate Context="transaction">
                                <MudTd DataLabel="Date">@transaction.Date</MudTd>
                                <MudTd DataLabel="Transaction ID">@transaction.Id</MudTd>
                                <MudTd DataLabel="User">@transaction.User</MudTd>
                                <MudTd DataLabel="Amount">@transaction.Amount</MudTd>
                                <MudTd DataLabel="Status">
                                    <MudChip T="string" Color="@transaction.StatusColor" Size="Size.Small">@transaction.Status</MudChip>
                                </MudTd>
                            </RowTemplate>
                        </MudTable>
                    </MudPaper>
                </MudItem>

            </MudGrid>
        </MudContainer>
    </Authorized>
    <NotAuthorized>
        <MudGrid>
            <MudItem xs="8">
                <MudPaper Class="pa-4" Elevation="3">
                    <img src="ArmsStaticFiles/bgImage.jpg" />
                </MudPaper>
            </MudItem>
            <MudItem xs="4">
                <div class="truckImg">
                    <MudPaper Class="pa-4 " Elevation="3">
                        <img src="ArmsStaticFiles/Truck.jpg" />
                    </MudPaper>
                </div>
            </MudItem>
        </MudGrid>
    </NotAuthorized>
</AuthorizeView>

@code {
    public List<ChartSeries> Series = new List<ChartSeries>()
    {
        new ChartSeries() { Name = "New Users", Data = new double[] { 40, 20, 25, 27, 46, 60, 48, 80, 15 } },
         new ChartSeries() { Name = "Active Sessions", Data = new double[] { 19, 24, 35, 13, 28, 15, 13, 16, 31 } },
    };
    public string[] XAxisLabels = { "Jan", "Feb", "Mar", "Apr", "May", "Jun", "Jul", "Aug", "Sep" };

    private IEnumerable<Transaction> Elements = new List<Transaction>()
    {
        new Transaction { Date = "2023-10-25", Id = "TRX-9871", User = "Alice Smith", Amount = "$120.50", Status = "Completed", StatusColor = Color.Success },
        new Transaction { Date = "2023-10-24", Id = "TRX-9872", User = "Bob Jones", Amount = "$75.00", Status = "Pending", StatusColor = Color.Warning },
        new Transaction { Date = "2023-10-24", Id = "TRX-9873", User = "Charlie Day", Amount = "$250.00", Status = "Completed", StatusColor = Color.Success },
        new Transaction { Date = "2023-10-23", Id = "TRX-9874", User = "Dana White", Amount = "$35.00", Status = "Failed", StatusColor = Color.Error },
        new Transaction { Date = "2023-10-22", Id = "TRX-9875", User = "Eve Black", Amount = "$190.00", Status = "Completed", StatusColor = Color.Success },
    };

    public class Transaction
    {
        public string Date { get; set; }
        public string Id { get; set; }
        public string User { get; set; }
        public string Amount { get; set; }
        public string Status { get; set; }
        public Color StatusColor { get; set; }
    }
}