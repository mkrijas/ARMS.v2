@inject IStoreService Iservice
@inject MudBlazor.ISnackbar snackbar
@inject IBranchService branchIservice
@inject AuthenticationStateProvider auth
@attribute [Authorize]
@inject IDialogService DialogService

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.Build" Class="mr-3 mb-n1" />
            Create Store
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudContainer Style="min-height:300px;max-height: 800px;">
            <EditForm id="formtdsRate" Model="@model" OnValidSubmit="OnValidSubmit">
                <ObjectGraphDataAnnotationsValidator />
                <ValidationSummary />
                <MudGrid Spacing="2">
                    <MudItem xs="12" md="12">
                        <MudTextField @bind-Value="model.StoreName" Label="Store Name" Variant="Variant.Outlined" Margin="Margin.Normal" For="@(() => model.StoreName)"></MudTextField>
                    </MudItem>
                    <MudItem xs="12" md="12">
                        <MudSelect Label="Select Branch" @bind-Value="model.BranchID" T="int?" Variant="Variant.Outlined" Margin="Margin.Normal" AdornmentColor="Color.Secondary">
                            @foreach (var ditem in branches)
                            {
                                <MudSelectItem Value="@ditem.BranchID">@ditem.BranchName</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                </MudGrid>
            </EditForm>
        </MudContainer>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Disabled="@_busy" form="formtdsRate" Variant="Variant.Filled" Color="Color.Success" ButtonType="ButtonType.Submit">Submit</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [Parameter]
    public StoreModel model { get; set; }
    private List<BranchModel> branches = new();
    private bool _busy;
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; }

    protected override async Task OnInitializedAsync()
    {
        // Fetching branches from the branch service
        branches = branchIservice.Select().ToList();
    }

    private async Task OnValidSubmit(EditContext context)
    {
        // Method to handle form submission 
        if (_busy)
        {
            // Check if a submission is already in progress
            snackbar.Add("Please wait while form is being submitted!", Severity.Warning);
            return;
        }

        // Check if a branch is selected
        if (model.BranchID == null)
        {
            snackbar.Add("Select Branch", Severity.Success);
            return;
        }
        _busy = true;

        // Close the dialog and pass the model data
        MudDialog.Close(model);

        await Task.Delay(200);
        _busy = false;
    }

    private void Cancel()
    {
        // Cancel the dialog
        MudDialog.Cancel();
    }
}