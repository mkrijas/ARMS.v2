@inject IUserService iservice
@inject IRoleService<RoleModel> Irole
@inject RoleManager<RoleModel> rolemngr


@inject UserManager<UserModel> Usmg
@inject MudBlazor.ISnackbar snackbar
@inject AuthenticationStateProvider auth
@attribute [Authorize]
@inject IDialogService DialogService
@using System.Globalization
@using System.Security.Claims
@using System.Threading
@using System.Linq

<MudGrid>
    <MudItem xs="12">
        <MudTable Items="@Claims">          
            <HeaderContent>
                <MudTh>Page</MudTh>                
                <MudTh>Rights</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Claim Type">@context.ClaimType</MudTd>
                <MudTd DataLabel="Value"> 
                @foreach(var item in @context.ClaimValues) 
                    {
                     <MudCheckBox CheckedChanged="@((bool val) => Roleupdate(val,context.ClaimType,item))"   Class="mr-2" Checked="@UserClaimList.Any(x=> x.Type == @context.ClaimType && x.Value == item)" Label="@item"  Color="Color.Primary"></MudCheckBox>                     
                    }
                </MudTd>
            </RowTemplate>
            <PagerContent>
                <MudTablePager PageSizeOptions="new int[] { 5, 10, 20, 50, 100 }" />
            </PagerContent>
        </MudTable>
    </MudItem>
</MudGrid>

@code {
    [Parameter]
    public RoleModel RoleModel{ get; set; }

    private RoleModel model = new RoleModel();
    public IList<Claim> UserClaimList { get; set; }
    private string searchTruck = "";
    private string id = "";
    private UserModel usmodel= new UserModel();
    private List<RoleModel> collection = new List<RoleModel>();
    private List<Claim> clamelist = new List<Claim>();
    public string csroleid { get; set; } = "";

    public bool checkbox { get; set; } = false;


    class roleClaimView
    {        
        public string ClaimType { get; set; }
        public List<string> ClaimValues { get; set; } = new();
    }
    private List<roleClaimView> Claims = new();

    protected override async Task OnInitializedAsync()
    {
        UserClaimList = await rolemngr.GetClaimsAsync(RoleModel);
        await Task.Run(() => GetAll());
        GetClaim();
    }

    private void GetAll()
    {
        collection.Clear();
        collection = Irole.Select(null).ToList();

    }

    private void GetClaim()
    {
        CancellationTokenSource ctc = new CancellationTokenSource();
        clamelist= Irole.GetAllClaims(ctc.Token).Result.ToList();
        foreach(var claimName in clamelist.DistinctBy(x => x.Type).Select(y => y.Type))
        {
            Claims.Add(new roleClaimView()
                {
                    ClaimType = claimName,
                    ClaimValues = new(clamelist.Where(x => x.Type == claimName).Select(y => y.Value).ToList())
                });
        }

    }
    private void Edit(RoleModel editModel)
    {

    }
    private void Delete(int? id)
    {

        snackbar.Add("Deleted Successfully", Severity.Success);
        GetAll();
    }


    private bool search(RoleModel roles)
    {
        if (roles.RoleNo != null && roles.RoleID.Contains(searchTruck, StringComparison.OrdinalIgnoreCase))
        {
            return true;
        }
        else if (roles.RoleID == null) return true;
        return false;
    }

    private void Roleupdate(bool val,String Claimtype,String claimvalue)
    { 
        Claim claim = new Claim(Claimtype, claimvalue);

        try
        {

            if(val==true)
            {

                rolemngr.AddClaimAsync(RoleModel,claim);
                UserClaimList.Add(claim);

                //snackbar.Add("Claim Added", Severity.Success);

            }
            else
            {
                rolemngr.RemoveClaimAsync(RoleModel, claim);
                UserClaimList.Remove(UserClaimList.FirstOrDefault(s=>s.Type == claim.Type && s.Value == claim.Value ));
                //UserClaimList =  UserClaimList.Except(x => x.ValueType == claim.ValueType).ToList();


                //snackbar.Add("Claim Removed", Severity.Success);

            }
        }

        catch(Exception ex)
        {
            snackbar.Add(ex.Message, Severity.Error);
        }
    }

}

