@inject IDataAuthorizationSettingsService Iservice
@inject IRoleService<RoleModel> Iroleservice
@inject MudBlazor.ISnackbar snackbar
@inject AuthenticationStateProvider auth
@attribute [Authorize]
@inject IDialogService DialogService

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.Build" Class="mr-3 mb-n1" />
            Data Authorization Settings
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudContainer Style="max-height: 450px; overflow-y: scroll">
            <EditForm id="formDataAuthorizationDialog" Model="@model" OnValidSubmit="Submit">
                <DataAnnotationsValidator />
                <ValidationSummary />
                <MudGrid Spacing="4">

                    <MudItem xs="12" md="12">
                        <MudSelect Label="Authorize Type" @bind-Value="model.AuthLevelID" T="int?" Variant="Variant.Outlined" Margin="Margin.Dense" AdornmentColor="Color.Secondary">
                            @foreach (var ditem in dataAuthorizationTypes)
                            {
                                <MudSelectItem Value="@ditem.AuthLevelID">@ditem.Description</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12" md="12">
                        <MudSelect Label="Document Type" ReadOnly="true" @bind-Value="model.DocTypeID" T="int?" Variant="Variant.Outlined" Margin="Margin.Dense" AdornmentColor="Color.Secondary">
                            @foreach (var ditem in doctypelist)
                            {
                                <MudSelectItem Value="@ditem.Key">@ditem.Value</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                </MudGrid>
            </EditForm>
        </MudContainer>
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Filled" Color="Color.Warning" OnClick="Cancel">Cancel</MudButton>
        <MudButton Disabled="@_busy" form="formDataAuthorizationDialog" Variant="Variant.Filled" Color="Color.Success" ButtonType="ButtonType.Submit">Submit</MudButton>
    </DialogActions>
</MudDialog>

@code {

    [Parameter]
    public DataAuthorizationSettingsModel model { get; set; }
    private List<DataAuthorizationTypeModel> dataAuthorizationTypes = new();
    private IDictionary<int?, string> doctypelist;
    private List<RoleModel> rolecollection = new List<RoleModel>();
    private bool _busy;
    [CascadingParameter]
    MudDialogInstance MudDialog { get; set; }

    void Cancel() => MudDialog.Cancel();

    protected override void OnInitialized()
    {
        dataAuthorizationTypes = Iservice.GetAuthTypes().ToList();
        doctypelist = Iservice.GetDocTypes();
        rolecollection = Iroleservice.Select(null).ToList();
    }

    public async Task Submit()
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is being submitted!", Severity.Warning);
            return;
        }
        _busy = true;

        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;
        model.UserInfo.UserID = user.Identity.Name;
        try
        {
            Iservice.Update(model);

            snackbar.Add("Saved Successfully", Severity.Success);
            model = new();
        }
        catch (Exception ex)
        {
            snackbar.Add(ex.Message, Severity.Warning);
        }
        MudDialog.Close();
        await Task.Delay(200);
        _busy = false;
    }
}