@page "/DataAuthorizationSettingsView"
@layout AdminMainLayout
@inject IDataAuthorizationSettingsService Iservice
@inject NavigationManager uriHelper;
@inject MudBlazor.ISnackbar snackbar
@inject AuthenticationStateProvider auth
@attribute [Authorize]
@inject IDialogService DialogService

<MudPaper>
    <MudContainer Style="padding-top:30px; padding-bottom:30px;">
        <MudGrid Spacing="4">
            <MudItem xs="12" md="10">
                <MudSelect Label="Document Type" @bind-Value="model.DocTypeID" T="int?" Variant="Variant.Outlined" Margin="Margin.Dense" OffsetY="true" Direction="Direction.Top" AdornmentColor="Color.Secondary">
                    @foreach (var ditem in doctypelist)
                    {
                        <MudSelectItem Value="@ditem.Key">@ditem.Value</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" md="2">
                <MudButton OnClick="FetchDocData" Variant="Variant.Filled" Color="Color.Primary">Fetch Data</MudButton>
            </MudItem>
            <MudItem xs="12">
                <MudTable Items="@collection" Dense="true" Hover="true" Striped="true" Elevation="10" @bind-place="model">
                    <HeaderContent>
                        <MudTh><MudTableSortLabel SortBy="new Func<DataAuthorizationSettingsModel, object>(x=> x.AuthorizeType)" InitialDirection="SortDirection.Ascending">AuthorizeType</MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<DataAuthorizationSettingsModel, object>(x=> x.DocType)" InitialDirection="SortDirection.Ascending">DocType</MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<DataAuthorizationSettingsModel, object>(x=> x.RoleID)" InitialDirection="SortDirection.Ascending">RoleID</MudTableSortLabel></MudTh>
                        <MudTh>Actions</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="AuthorizeType">@context.AuthorizeType</MudTd>
                        <MudTd DataLabel="DocType">@context.DocType</MudTd>
                        <MudTd DataLabel="RoleID">@context.RoleID</MudTd>
                        <MudTd DataLabel="">
                            <MudTooltip Text="Edit">
                                <MudFab @onclick="@(()=> OpenDialog(context))" Color="Color.Primary" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" IconSize="Size.Small" />
                            </MudTooltip>
                            @*   @if(@context.ApprovedInfo.RecordStatus!=1)
                            {
                            <MudTooltip Text="Approve">
                            <MudFab @onclick="@(()=> Approve(context))" Color="Color.Success" Icon="@Icons.Material.Filled.Check" Size="Size.Small" IconSize="Size.Small" />
                            </MudTooltip>
                            }*@
                        </MudTd>
                    </RowTemplate>
                    <ChildRowContent>
                        @if (@collection.Count == 0)
                        {
                            <MudText>There is no authentication settings</MudText>
                        }
                    </ChildRowContent>
                    <PagerContent>
                        <MudTablePager PageSizeOptions="new int[] { 5, 10, 20, 50, 100 }" />
                        @*  <MudButton OnClick="selected" Variant="Variant.Filled" Color="Color.Success" ButtonType="ButtonType.Submit">Submit</MudButton>*@
                    </PagerContent>
                </MudTable>
            </MudItem>
        </MudGrid>
        <MudCardActions>
            <MudGrid>
                <MudItem xs="12" md="10"></MudItem>
                <MudItem xs="12" md="2">
                    <MudButton Style="margin-left:80px; margin-top:18px;" OnClick="AddNewAuthentiction" Variant="Variant.Filled" Color="Color.Primary">Add New</MudButton>
                </MudItem>
            </MudGrid>
        </MudCardActions>
    </MudContainer>
</MudPaper>

@code {

    private DataAuthorizationSettingsModel model = new DataAuthorizationSettingsModel();
    private List<DataAuthorizationSettingsModel> collection = new List<DataAuthorizationSettingsModel>();
    DialogOptions maxWidth = new DialogOptions() { MaxWidth = MaxWidth.Medium, FullWidth = true };

    private IDictionary<int?, string> doctypelist;

    protected override void OnInitialized()
    {
        model = new();
        doctypelist = Iservice.GetDocTypes();
    }

    public void FetchDocData()
    {
        if (model.DocTypeID == null)
        {
            snackbar.Add("Please Select Doctype", Severity.Warning);
            return;
        }
        GetAll();
    }

    public async Task AddNewAuthentiction()
    {
        var authprov = await auth.GetAuthenticationStateAsync();

        DataAuthorizationSettingsModel modelParameter = new DataAuthorizationSettingsModel();
        modelParameter.DocTypeID = model.DocTypeID;
        DialogParameters parms = new DialogParameters();
        parms.Add("model", modelParameter);
        var dialog = DialogService.Show<DataAuthorizationSettingsDialog>(model.ID == null ? "ADD" : "EDIT", parms, maxWidth);
        var result = await dialog.Result;

        if (!result.Cancelled)
        {
            GetAll();
        }
        GetAll();
    }

    public async Task OpenDialog(DataAuthorizationSettingsModel dtaumodel)
    {
        var authprov = await auth.GetAuthenticationStateAsync();

        DialogParameters parms = new DialogParameters();
        parms.Add("model", dtaumodel);
        var dialog = DialogService.Show<DataAuthorizationSettingsDialog>(dtaumodel.ID == null ? "ADD" : "EDIT", parms, maxWidth);
        var result = await dialog.Result;

        if (!result.Cancelled)
        {
            GetAll();
        }
        GetAll();
    }

    public void GetAll()
    {
        collection = Iservice.Select(model.DocTypeID).ToList();
    }
}