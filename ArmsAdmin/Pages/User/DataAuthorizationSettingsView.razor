@page "/DataAuthorizationSettingsView"
@layout AdminMainLayout
@inject IDataAuthorizationSettingsService Iservice
@inject NavigationManager uriHelper;
@inject MudBlazor.ISnackbar snackbar
@inject AuthenticationStateProvider auth
@attribute [Authorize]
@inject IDialogService DialogService


<MudTable Items="@doctypelist" Hover Bordered Striped Filter="new Func<DocTypeModel,bool>(Search)">
    <ToolBarContent>
        <MudText Typo="Typo.h6">Authorization Settings for Documents</MudText>
        <MudSpacer />
        <MudTextField @bind-Value="searchString1" Placeholder="Search" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0"></MudTextField>
    </ToolBarContent>
    <HeaderContent>
        <MudTh>Document Name</MudTh>
        <MudTh>Authorization Types</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd DataLabel="Nr">@context.Description</MudTd>
            <MudTd DataLabel="auths">
            <MudStack Row="true" Spacing="5">
                @foreach (var item in authTypelist)
            {
                <MudCheckBox T="bool" Checked="@IsSelected(context.ID ,@item.AuthLevelID)" CheckedChanged="@((e) => CheckedChanged(context.ID ,@item.AuthLevelID,e))" Dense="true" Color="Color.Primary" Class="ml-2 mr-2">@item.Description</MudCheckBox>
            }
            </MudStack>
        </MudTd>
    </RowTemplate>
    <PagerContent>
        <MudTablePager />
    </PagerContent>
</MudTable>

@code {


    List<DataAuthorizationSettingsModel> collection = new List<DataAuthorizationSettingsModel>();
    List<DataAuthorizationTypeModel> authTypelist = new List<DataAuthorizationTypeModel>();
    List<DocTypeModel> doctypelist = new List<DocTypeModel>();
    string searchString1 = string.Empty;
    string UserID = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;
        UserID = user.Identity.Name;

        collection = Iservice.Select(0).ToList();
        doctypelist = Iservice.GetDocTypesList().Where(x => x.AuthImplemented).ToList();
        authTypelist = Iservice.GetAuthTypes().OrderBy(x => x.AuthLevelID).ToList();
    }

    private bool Search(DocTypeModel doc)
    {  
        // if text is null or empty, show complete list
        if (string.IsNullOrEmpty(searchString1))
            return true;
        if (doc.Description.Contains(searchString1, StringComparison.OrdinalIgnoreCase))
            return true;
        return false;
    }

    private bool IsSelected(int? DoctypeID, int? AuthLevelID)
    {
        return collection.Any(y => y.AuthLevelID == AuthLevelID && y.DocTypeID == DoctypeID);
    }
    private void CheckedChanged(int? DoctypeID, int? AuthLevelID, bool val)
    {
        if (val)
        {
            DataAuthorizationSettingsModel updateModel = new()
                {
                    AuthLevelID = AuthLevelID,
                    DocTypeID = DoctypeID,
                    UserInfo = new ArmsModels.SharedModels.UserInfoModel() { UserID = UserID }
                };

            Iservice.Update(updateModel);
            collection.Add(updateModel);
        }
        else
        {
            if(AuthLevelID == 99)
            {
                snackbar.Add("Cannot disable Approval !", Severity.Warning);
            }
            else{
            Iservice.Delete(DoctypeID, AuthLevelID, UserID);
            collection.Remove(collection.First(x => x.AuthLevelID == AuthLevelID && x.DocTypeID == DoctypeID));
            }
        }
    }

}