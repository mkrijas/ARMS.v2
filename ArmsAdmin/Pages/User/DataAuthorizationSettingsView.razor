@page "/DataAuthorizationSettingsView"
@layout AdminMainLayout
@inject IDataAuthorizationSettingsService Iservice
@inject NavigationManager uriHelper;
@inject MudBlazor.ISnackbar snackbar
@inject AuthenticationStateProvider auth
@attribute [Authorize]
@inject IDialogService DialogService


@if (_isLoading)
{
@*     <div style="display: flex; justify-content: center; align-items: center; min-height: 400px;">
 *@        <LoaderComponent IsFullScreen="true" 
                        ShowLogo="false" 
                        Size="medium" 
                        LoadingText="Loading Authorization Settings" 
                        SubText="Please wait..." />
@*     </div>
 *@}


<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-8 mb-12">
    <!-- Header Section -->
    <div class="header-section mb-10">
        <div class="d-flex justify-space-between align-end">
            <div>
                <MudText Typo="Typo.h4" Class="admin-title mb-2"><b>Authorization Matrix</b></MudText>
                <div class="title-accent mb-4"></div>
                <MudText Typo="Typo.body1" Class="admin-subtitle" Style="color: #667085;">
                    Configure granular data access permissions and approval workflows across all system documents.
                </MudText>
            </div>
        </div>
    </div>

    <div class="admin-glass-card">
        <MudTable Items="@doctypelist" Elevation="0" Dense="true" Hover="true" Bordered="false" Striped="false" Filter="new Func<DocTypeModel,bool>(Search)" Breakpoint="Breakpoint.Sm">
            <ToolBarContent>
                <div class="d-flex align-center gap-4 w-100">
                    <MudText Typo="Typo.h6" Class="card-title" Style="color: #367588;"><b>Document Access Rules</b></MudText>
                    <MudSpacer />
                    <MudTextField @bind-Value="searchString1" Placeholder="Filter by document name..." Adornment="Adornment.Start" Variant="Variant.Outlined" Margin="Margin.Dense" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="search-field" Style="max-width: 300px; background: white;"></MudTextField>
                </div>
            </ToolBarContent>
            <HeaderContent>
                <MudTh Style="width: 250px;">Document Workspace</MudTh>
                <MudTh>Authorization Level Controls</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Workspace">
                    <MudText Typo="Typo.body2" Style="font-weight: 500; color: #1e293b; font-size: 0.95rem;">@context.Description</MudText>
                </MudTd>
                <MudTd DataLabel="Permissions">
                    <div class="d-flex flex-nowrap gap-2 overflow-x-auto">
                        @foreach (var item in authTypelist)
                        {
                            bool isSet = IsSelected(context.ID, item.AuthLevelID);
                            <div class="auth-pill @(isSet ? "active" : "")" style="white-space: nowrap; flex-shrink: 0;">
                                <MudCheckBox T="bool" 
                                             Value="@isSet" 
                                             ValueChanged="@((bool e) => CheckedChanged(context.ID, item.AuthLevelID, e))" 
                                             Dense="true" 
                                             Color="Color.Primary" 
                                             Label="@item.Description" />
                            </div>
                        }
                    </div>
                </MudTd>
            </RowTemplate>
            <PagerContent>
                <div class="pa-4">
                    <MudTablePager />
                </div>
            </PagerContent>
        </MudTable>
    </div>
</MudContainer>



@code {

    private bool _isLoading = true;
    private DateTime _loadStartTime;


    List<DataAuthorizationSettingsModel> collection = new List<DataAuthorizationSettingsModel>();
    List<DataAuthorizationTypeModel> authTypelist = new List<DataAuthorizationTypeModel>();
    List<DocTypeModel> doctypelist = new List<DocTypeModel>();
    string searchString1 = string.Empty;
    string UserID = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        _loadStartTime = DateTime.Now;
        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;
        UserID = user.Identity.Name;

        collection = Iservice.Select(0).ToList(); // Fetch existing authorization settings
        doctypelist = Iservice.GetDocTypesList().Where(x => x.AuthImplemented).ToList(); // Fetch document types with authorization implemented
        authTypelist = Iservice.GetAuthTypes().OrderBy(x => x.AuthLevelID).ToList(); // Fetch and order authorization types
        await EnsureMinimumLoadTime();
        _isLoading = false;
    }

    private async Task EnsureMinimumLoadTime()
    {
        var elapsed = (DateTime.Now - _loadStartTime).TotalMilliseconds;
        if (elapsed < 100)
        {
            await Task.Delay(100 - (int)elapsed);
        }
    }

    // Method to filter document types based on search string
    private bool Search(DocTypeModel doc)
    {  
        // if text is null or empty, show complete list
        if (string.IsNullOrEmpty(searchString1))
            return true;
        if (doc.Description.Contains(searchString1, StringComparison.OrdinalIgnoreCase))
            return true;
        return false;
    }

    // Method to check if an authorization type is selected for a document type
    private bool IsSelected(int? DoctypeID, int? AuthLevelID)
    {
        return collection.Any(y => y.AuthLevelID == AuthLevelID && y.DocTypeID == DoctypeID); // Check if the combination exists in the collection
    }

    // Method to handle checkbox state changes
    private void CheckedChanged(int? DoctypeID, int? AuthLevelID, bool val)
    {
        if (val)
        {
            DataAuthorizationSettingsModel updateModel = new() // Create a new model for the selected authorization
                {
                    AuthLevelID = AuthLevelID,
                    DocTypeID = DoctypeID,
                    UserInfo = new ArmsModels.SharedModels.UserInfoModel() { UserID = UserID }
                };

            Iservice.Update(updateModel); // Update the authorization settings in the service
            collection.Add(updateModel); // Add the new model to the collection
        }
        else
        {
            if(AuthLevelID == 99)
            {
                snackbar.Add("Cannot disable Approval !", Severity.Warning);
            }
            else{
                Iservice.Delete(DoctypeID, AuthLevelID, UserID); // Delete the authorization setting from the service
                collection.Remove(collection.First(x => x.AuthLevelID == AuthLevelID && x.DocTypeID == DoctypeID)); // Remove from the collection
            }
        }
    }

}