@page "/Devices"
@attribute [Authorize(Policy = "Admin")]
@layout AdminMainLayout
@inject AuthenticationStateProvider auth
@inject MudBlazor.ISnackbar snackbar
@inject IDialogService DialogService
@inject IDeviceService IDeviceService
@using System.Globalization
@using Core.BaseModels.User
@using Core.IDataServices.User
@using Microsoft.AspNetCore.Identity

@if (_isLoading)
{
@*     <div @key="@("loader")" style="display: flex; justify-content: center; align-items: center; min-height: 400px;">
 *@        <LoaderComponent IsFullScreen="true" 
                        ShowLogo="false" 
                        Size="medium" 
                        LoadingText="Loading Devices" 
                        SubText="Please wait..." />
@*     </div>
 *@}
else
{
    <div @key="@("content")">


<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-8 mb-12">
    <!-- Header Section -->
    <div class="header-section mb-10">
        <div class="d-flex justify-space-between align-end">
            <div>
                <MudText Typo="Typo.h4" Class="admin-title mb-2"><b>Device Management</b></MudText>
                <div class="title-accent mb-4"></div>
                <MudText Typo="Typo.body1" Class="admin-subtitle" Style="color: #667085;">
                    Monitor device authorization, approve active connections, and manage security.
                </MudText>
            </div>
            <div class="admin-top-actions mb-1">
                <MudSelect Dense="true" T="int" Value="@SelectedDeviceList" ValueChanged="SelectedValueChanged" 
                           Variant="Variant.Filled" Margin="Margin.Dense" Class="rounded-lg shadow-sm"
                           Style="width: 200px; background: white;" AnchorOrigin="Origin.BottomCenter">
                    <MudSelectItem Value="1">Pending Approval</MudSelectItem>
                    <MudSelectItem Value="2">Active Devices</MudSelectItem>
                </MudSelect>
            </div>
        </div>
    </div>

    <div class="admin-glass-card">
        <MudTable Items="@collection" Elevation="0" Dense="true" Filter="new Func<DeviceModel, bool>(search)" @bind-Truck="model" Hover="true" Breakpoint="Breakpoint.Sm">
            <ToolBarContent>
                <div class="d-flex align-center gap-4 w-100">
                    <MudText Typo="Typo.h6" Class="card-title" Style="color: #367588;"><b>@SelectedDevice Registry</b></MudText>
                    <MudSpacer />
                    <MudTextField @bind-Value="searchUser" Placeholder="Search by User ID..." Adornment="Adornment.Start" Variant="Variant.Outlined" Margin="Margin.Dense" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="search-field" Style="max-width: 300px; background: white;"></MudTextField>
                </div>
            </ToolBarContent>
            <HeaderContent>
                <MudTh><MudTableSortLabel SortBy="new Func<DeviceModel, object>(x=> x.UserID)" InitialDirection="SortDirection.Ascending">User ID</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<DeviceModel, object>(x=> x.DeviceID)">Device Unique ID</MudTableSortLabel></MudTh>
                <MudTh Style="text-align: right;">Actions</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="UserID"><b>@context.UserID</b></MudTd>
                <MudTd DataLabel="DeviceID" Style="font-family: 'Inter', monospace; font-size: 0.8rem; color: #64748b;">@context.DeviceID</MudTd>
                <MudTd DataLabel="" Style="text-align: right;">
                    <div class="d-flex justify-end gap-2">
                        @if (context.RecordStatus == 1)
                        {
                            <MudButton OnClick="@(e => Approve(context))" Variant="Variant.Filled" Color="Color.Success" Size="Size.Small" StartIcon="@Icons.Material.Filled.Check" Class="rounded-pill px-4">Approve</MudButton>
                        }
                        <MudButton OnClick="@(e => Deny(context))" Variant="Variant.Outlined" Color="Color.Error" Size="Size.Small" StartIcon="@(context.RecordStatus == 3 ? Icons.Material.Filled.RemoveCircle : Icons.Material.Filled.Block)" Class="rounded-pill px-4">
                            @(context.RecordStatus == 3 ? "Remove" : "Deny")
                        </MudButton>
                    </div>
                </MudTd>
            </RowTemplate>
            <PagerContent>
                <div class="pa-4">
                    <MudTablePager PageSizeOptions="new int[] { 10, 20, 50, 100 }" />
                </div>
            </PagerContent>
        </MudTable>
    </div>
</MudContainer>
</div>
}



@code {

    private bool _isLoading = true;
    private DateTime _loadStartTime;

    private DeviceModel model = new DeviceModel();
    private List<DeviceModel> collection = new List<DeviceModel>();
    DialogOptions maxWidth = new DialogOptions() { MaxWidth = MaxWidth.Large, FullWidth = true };
    DialogOptions maxWidthMedium = new DialogOptions() { MaxWidth = MaxWidth.Medium, FullWidth = true };
    private string SelectedDevice = "Approval";
    public string searchUser = "";
    int SelectedDeviceList = 1;

    protected async override Task OnInitializedAsync()
    {
        _loadStartTime = DateTime.Now;
        await GetAll(SelectedDeviceList);
        await EnsureMinimumLoadTime();
        _isLoading = false;
    }

    private async Task EnsureMinimumLoadTime()
    {
        var elapsed = (DateTime.Now - _loadStartTime).TotalMilliseconds;
        if (elapsed < 100)
        {
            await Task.Delay(100 - (int)elapsed);
        }
    }

    // Method to fetch devices based on the selected type
    private async Task GetAll(int a)
    {
        if (a == 1)
        {
            SelectedDeviceList = 1; // Set the selected device list to Approval     
            SelectedDevice = "Approval"; // Update the selected device type
            collection = IDeviceService.Select("PENDING").ToList(); // Fetch pending devices 
        }
        if (a == 2)
        {
            SelectedDeviceList = 2; // Set the selected device list to Active 
            SelectedDevice = "Active"; // Update the selected device type
            collection = IDeviceService.Select("APPROVED").ToList(); // Fetch approved devices
        }
    }

    // Method to handle changes in the selected device type from the dropdown
    public async Task SelectedValueChanged(int val)
    {
        await GetAll(val);
        StateHasChanged(); // Request a re-render of the component
    }

    // Method to approve a device
    private async Task Approve(DeviceModel model)
    {
        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;
        model.UserID = user.Identity.Name;

        try
        {
            int a = await IDeviceService.Approve(model);
        }
        catch (Exception ex)
        {
            snackbar.Add(ex.Message, Severity.Warning);
        }
         // Call the service to approve the device
        await GetAll(SelectedDeviceList);
    }

    // Method to deny or remove a device
    private async Task Deny(DeviceModel model)
    {
        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;
        model.UserID = user.Identity.Name;

        bool? result = await DialogService.ShowMessageBoxAsync(
        "Warning !",
        "Are you sure, you want to Remove/Deny - " + model.UserID + " (" + model.DeviceID + ") ?");
        if (result == true)
        {
            try
            {
                int a = await IDeviceService.Deny(model); // Call the service to deny the device
            }
            catch (Exception ex)
            {
                snackbar.Add(ex.Message, Severity.Warning);
            }
            
        }
        await GetAll(SelectedDeviceList);
    }

    // Method to filter the device list based on the search input
    private bool search(DeviceModel model)
    {
        if (model.UserID != null && model.UserID.Contains(searchUser, StringComparison.OrdinalIgnoreCase))
        {
            return true;
        }
        else if (model.UserID == null) return true;
        return false;
    }
}