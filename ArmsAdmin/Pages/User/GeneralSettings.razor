@page "/GeneralSettings"
@using ArmsModels.BaseModels.General;
@using System.Threading;
@using ArmsModels.SharedModels
@layout AdminMainLayout
@attribute [Authorize]
@inject IGeneralSettingsService IGeneralSettings
@inject AuthenticationStateProvider auth
@inject MudBlazor.ISnackbar snackbar
@inject IRoleService<RoleModel> Irole
@inject IDialogService DialogService
@inject NavigationManager Navigation

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-8 mb-12">
    <!-- Header Section -->
    <div class="header-section mb-10">
        <div class="d-flex justify-space-between align-end">
            <div>
                <MudText Typo="Typo.h4" Class="admin-title mb-2"><b>System Configuration</b></MudText>
                <div class="title-accent mb-4"></div>
                <MudText Typo="Typo.body1" Class="admin-subtitle" Style="color: #667085;">
                    Adjust global application settings, feature toggles, and system-wide parameters.
                </MudText>
            </div>
        </div>
    </div>

    <div class="admin-glass-card">
        <MudTable Items="@collection" Elevation="0" Dense="true" Hover="true" Breakpoint="Breakpoint.Sm">
            <ToolBarContent>
                <MudText Typo="Typo.h6" Class="card-title" Style="color: #367588;"><b>General System Parameters</b></MudText>
            </ToolBarContent>
            <HeaderContent>
                <MudTh Style="width:40%;">SETTING IDENTIFIER</MudTh>
                <MudTh Style="width:40%;">CONFIGURATION VALUE</MudTh>
                <MudTh Style="width:20%; text-align: right;">OPERATIONS</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Options">
                    <MudText Typo="Typo.body2" Style="font-weight: 600; color: #141A46;">@context.SettingName</MudText>
                </MudTd>
                <MudTd DataLabel="Value">
                    @if (context.ValueSelectType == "CHECK")
                    {
                        <MudCheckBox T="bool" Checked="@(bool.Parse(context.Value))" CheckedChanged="(bool e) => Submit(e.ToString(), context)" Color="Color.Primary"></MudCheckBox>
                    }
                    @if (context.ValueSelectType == "TEXT")
                    {
                        @if (!context.HideTextField)
                        {
                            <MudText Style="font-weight: 500; color: #141A46;">@context.Value</MudText>
                        }
                        @if (context.HideTextField)
                        {
                            <MudTextField @bind-Value="@context.Value" Variant="Variant.Outlined" Margin="Margin.Dense" Class="rounded-lg bg-white" Style="max-width: 300px;"></MudTextField>
                        }
                    }
                    @if (context.ValueSelectType == "QUERY")
                    {
                        <MudItem Style="width:100%">
                            @if (!context.HideTextField)
                            {
                                <MudText Style="font-weight: 500; color: #141A46;">@context.Value</MudText>
                            }
                            @if (context.HideTextField)
                            {
                                <MudAutocomplete T="KeyValuePair<string, string>"
                                                 @bind-Value="@context.selectedValue"
                                                 ToStringFunc="@((item) => item.Value)"
                                                 SearchFunc="@Search"
                                                 ResetValueOnEmptyText="@resetValueOnEmptyText"
                                                 CoerceText="@coerceText"
                                                 CoerceValue="@coerceValue"
                                                 Variant="Variant.Outlined"
                                                 Margin="Margin.Dense"
                                                 AdornmentIcon="@Icons.Material.Filled.Search"
                                                 AdornmentColor="Color.Primary"
                                                 Class="rounded-lg bg-white"
                                                 Style="max-width: 300px;">
                                </MudAutocomplete>
                            }
                        </MudItem>
                    }
                </MudTd>
                <MudTd DataLabel="Actions" Style="text-align: right;">
                    <div class="d-flex justify-end gap-2">
                        @if (context.ValueSelectType == "TEXT")
                        {
                            @if (!context.HideTextField)
                            {
                                <MudIconButton OnClick="@(()=> Edit(context))" Color="Color.Primary" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Variant="Variant.Filled" />
                            }
                            @if (context.HideTextField)
                            {
                                <MudIconButton OnClick="@(value => Submit(context.Value, context))" Color="Color.Success" Icon="@Icons.Material.Filled.Save" Size="Size.Small" Variant="Variant.Filled" />
                                <MudIconButton OnClick="@(()=> Cancel(context))" Color="Color.Error" Icon="@Icons.Material.Filled.Cancel" Size="Size.Small" Variant="Variant.Outlined" />
                            }
                        }
                        @if (context.ValueSelectType == "QUERY")
                        {
                            @if (!context.HideTextField)
                            {
                                <MudIconButton OnClick="@(()=> Edit(context))" Color="Color.Primary" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Variant="Variant.Filled" />
                            }
                            @if (context.HideTextField)
                            {
                                <MudIconButton OnClick="@(value => Submit1(context.selectedValue, context.KeyString, context))" Color="Color.Success" Icon="@Icons.Material.Filled.Save" Size="Size.Small" Variant="Variant.Filled" />
                                <MudIconButton OnClick="@(()=> Cancel(context))" Color="Color.Error" Icon="@Icons.Material.Filled.Cancel" Size="Size.Small" Variant="Variant.Outlined" />
                            }
                        }
                    </div>
                </MudTd>
            </RowTemplate>
        </MudTable>
    </div>
</MudContainer>

@code {

    private List<GeneralSettingsModel> collection = new();
    private bool resetValueOnEmptyText;
    private bool coerceText;
    private bool coerceValue;
    private Dictionary<string, string> options = new Dictionary<string, string>();
    private bool hideTextField = false;

    protected override async Task OnInitializedAsync()
    {
        // Fetch the general settings from the service and populate the collection
        collection = IGeneralSettings.Select().ToList();
    }

    // Method to search for options based on user input
    private Task<IEnumerable<KeyValuePair<string, string>>> Search(string value, CancellationToken token)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return Task.FromResult(options.AsEnumerable());
        }
        else
        {
            return Task.FromResult(options.Where(x => x.Value.Contains(value, StringComparison.InvariantCultureIgnoreCase)).ToList().AsEnumerable());
        }
    }

    // Overloaded search method for querying specific context 
    private Task<IEnumerable<string>> Search(string text, GeneralSettingsModel context) // This might not be used by MudAutocomplete directly if it's a custom call
    {
        if (string.IsNullOrWhiteSpace(text))
        {
            return Task.FromResult(context.ValueOptionsList.AsEnumerable());
        }
        else
        {
            var result = context.ValueOptionsList.Where(item => item.Contains(text, StringComparison.InvariantCultureIgnoreCase));
            return Task.FromResult(result);
        }
    }

    // Method to initiate editing of a setting
    private void Edit(GeneralSettingsModel context)
    {
        // Fetch the available values for the setting and prepare for editing
        options = IGeneralSettings.SelectValues(context).ToDictionary(vo => vo.id, vo => vo.val);
        context.HideTextField = true; // Hide the display field and show the editable field
    }

    // Method to cancel editing of a setting
    private void Cancel(GeneralSettingsModel context)
    {
        context.HideTextField = false; // Show the display field again
        StateHasChanged();      
    }

    // Method to submit changes for query settings
    private async Task Submit1(KeyValuePair<string, string> selectedValue, string KeyString, GeneralSettingsModel context)
    {
        try
        {
            var authprov = await auth.GetAuthenticationStateAsync();
            var user = authprov.User;

            string? key = selectedValue.Key; // Get the selected key
            string? value = selectedValue.Value; // Get the selected value

            // Create a new model for the setting
            GeneralSettingsModel model = new GeneralSettingsModel();
            UserInfoModel userInfo = new UserInfoModel();
            model.UserInfo = userInfo;
            model.UserInfo.UserID = user.Identity.Name;
            model.KeyString = KeyString;
            model.SettingId = key.ToString();
            model.Value = value;
            context.Value = value;
            context.selectedValue = selectedValue;

            // Update the general settings using the service
            IGeneralSettings.Update(model);
            context.HideTextField = false; // Hide the text field after submission
            StateHasChanged();
        }
        catch (Exception ex)
        {
            snackbar.Add(ex.Message, Severity.Error);
        }
    }

    // Method to submit changes for text settings
    private async Task Submit(string? newValue, GeneralSettingsModel model)
    {
        try
        {
            var authprov = await auth.GetAuthenticationStateAsync();
            var user = authprov.User;

            model.UserInfo.UserID = user.Identity.Name;
            model.Value = newValue;
            model.SettingId = newValue;

            // Update the general settings using the service
            IGeneralSettings.Update(model);
            model.HideTextField = false; // Hide the text field after submission
            StateHasChanged(); 
        }
        catch (Exception ex)
        {
            snackbar.Add(ex.Message, Severity.Error);
        }
    }
}
