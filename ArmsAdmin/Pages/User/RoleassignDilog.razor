
@page "/rolesadd"

@inject IUserService Iservice
@inject IRoleService<RoleModel> Irole
@inject RoleManager<RoleModel> imgr
@inject MudBlazor.ISnackbar snackbar
@inject AuthenticationStateProvider auth
@attribute [Authorize]

@using System.Globalization
@using Microsoft.AspNetCore.Identity




<MudDialog >
 
    <DialogActions>
    

 <MudItem xs="12">
     
            <EditForm Model="@UserRModel" OnValidSubmit="OnValidSubmit">
                <DataAnnotationsValidator />
                <ValidationSummary />'
                <MudItem xs="12">
              <MudCardContent>
                    <MudTextField @bind-Value="@UserRModel.Branch" Label="Truck Type" Variant="Variant.Outlined" Margin="Margin.Normal" For="@(() => UserRModel.Branch)"></MudTextField>
                    <MudTextField @bind-Value="@UserRModel.Role" Label="Unladen Weight" Variant="Variant.Outlined" Margin="Margin.Normal" For="@(() => UserRModel.Role)"></MudTextField>
                   
                    <MudButton Variant="Variant.Filled" Color="Color.Success" ButtonType="ButtonType.Submit">Save TruckType</MudButton>

                </MudCardContent>
                </MudItem>
            </EditForm>
     
    </MudItem>
  
    </DialogActions>
    </MudDialog>

@code {

    [Parameter]
    public UserBranchRoleModel UserRModel { get; set; }

    private string searchUser = "";
    private List<UserBranchRoleModel> collection = new List<UserBranchRoleModel>();

    private async void OnValidSubmit(EditContext context)
    {

        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;
        UserRModel.User.UserID = user.Identity.Name;
        try
        {
           //UserRModel = Iservice.SetBranchesNRoles(collection,user.ToString());

            snackbar.Add("Saved Successfully", Severity.Success);
            if (collection.Exists(x => x.Branch == UserRModel.Branch))
            {
                collection[collection.FindIndex(x => x.Branch == UserRModel.Branch)] =  UserRModel;
            }
            else
            {
                collection.Add( UserRModel);
            }
             UserRModel = new UserBranchRoleModel();           
        }
        catch (Exception ex)
        {
            snackbar.Add(ex.Message, Severity.Warning);
        }
    }
    

    }