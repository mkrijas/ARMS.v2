@layout AdminMainLayout
@inject IUserService Iservice
@inject UserManager<UserModel> Usmg
@inject MudBlazor.ISnackbar snackbar
@inject AuthenticationStateProvider auth
@attribute [Authorize]
@inject IDialogService DialogService
@using System.Globalization
@using Microsoft.AspNetCore.Identity

<div style="height:400px;overflow-y:scroll">
    <MudDialog>
        <TitleContent><MudIconButton OnClick="Cancel" Icon=@Icons.Material.Filled.Close></MudIconButton></TitleContent>
        <DialogContent>
            <h3>Approval Pending</h3>
            <MudItem>
                <MudTable Items="@collection" Dense="true" Filter="new Func<UserModel, bool>(search)" @bind-SelectedItem="model">
                    <HeaderContent>
                        <MudTh><MudTableSortLabel SortBy="new Func<UserModel, object>(x=> x.UserID)" InitialDirection="SortDirection.Ascending">UserID</MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<UserModel, object>(x=> x.UserName)" InitialDirection="SortDirection.Ascending">UserName</MudTableSortLabel></MudTh>
                        <MudTh>Actions</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="UserID">@context.UserID</MudTd>
                        <MudTd DataLabel="UserName">@context.UserName</MudTd>
                        <MudTd DataLabel="">
                            <MudFab style="font-size:5px" @onclick="@(()=> Approve(context.UserID))" Color="Color.Primary" StartIcon="@Icons.Material.Filled.AddTask" Size="Size.Small" IconSize="Size.Small" />
                        </MudTd>
                    </RowTemplate>
                    <PagerContent>
                        <MudTablePager PageSizeOptions="new int[] { 5, 10, 20, 50, 100 }" />
                    </PagerContent>
                </MudTable>
            </MudItem>
        </DialogContent>
    </MudDialog>
</div>

@code {

    [CascadingParameter] IMudDialogInstance MudDialog { get; set; }
    void Cancel() => MudDialog.Cancel();
    private UserModel model = new UserModel();
    private List<UserModel> collection = new List<UserModel>();

    private string searchTruck = "";

    protected override void OnInitialized()
    {
        GetAll();
    }

    // Method to fetch all users pending approval
    private void GetAll()
    {
        collection.Clear();
        // Fetch users where EmailConfirmed is false (pending approval)
        collection = Iservice.Select(null).Where(x => x.EmailConfirmed == false).ToList();
    }

    // Method to edit a user (not currently used in the provided code)
    private void Edit(UserModel editModel)
    {
        DialogParameters parms = new();
        parms.Add("EditModel", editModel.Clone()); // Add the model to the parameters
        DialogService.Show<UserDilogue>("ADD/EDIT", parms); // Show the edit dialog
    }

    // Method to approve a user
    private async Task Approve(String id)
    {
        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;
        var usrmdl = collection.First(x => x.UserID == id);
        usrmdl.EmailConfirmed = true;
        usrmdl.UpdatedBy = user.Identity.Name;
        await Usmg.UpdateAsync(usrmdl); // Update the user in the database
        collection.Remove(usrmdl);
        snackbar.Add("User Approved", Severity.Success);
        void Cancel() => MudDialog.Cancel();
    }

    // Method to delete (disable) a user
    private async Task Delete(String id)
    {
        bool? result = await DialogService.ShowMessageBox(
            "Warning !",
            "Are you sure, you want to disable User ?");
        if (result == true)
        {
            var usrmdl = collection.First(x => x.UserID == id); // Find the user in the collection
            await Usmg.DeleteAsync(usrmdl); // Delete the user from the databas
            snackbar.Add("Disabled User", Severity.Success);
        }
        GetAll();
    }

    // Method to filter users based on the search input
    private bool search(UserModel users)
    {
        if (users.UserID != null && users.UserID.Contains(searchTruck, StringComparison.OrdinalIgnoreCase))
        {
            return true;
        }
        else if (users.UserID == null) return true;
        return false;
    }
}
