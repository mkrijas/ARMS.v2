
@inject IUserService iservice
@inject IRoleService<RoleModel> Irole
@inject RoleManager<RoleModel> imgr
@inject MudBlazor.ISnackbar snackbar
@inject AuthenticationStateProvider auth
@attribute [Authorize]
@using System.Globalization
@using Microsoft.AspNetCore.Identity

<div style="padding:5%">


 <EditForm Model="@EditModel" OnValidSubmit="OnValidSubmit">
            
  <MudItem xs="12">
<MudTextField Class="dropstyle"   @bind-Value="EditModel.RoleID"  Label="Role ID" Variant="Variant.Text" Margin="Margin.Normal" For="@(() => EditModel.RoleID)"></MudTextField>
<MudTextField Class="dropstyle"   @bind-Value="EditModel.RoleDesc"  Label="Role  Description" Variant="Variant.Text" Margin="Margin.Normal" For="@(() => EditModel.RoleDesc)"></MudTextField>
</MudItem>
 <br />
 <MudButton Disabled=@_busy Variant="Variant.Filled" Color="Color.Success" ButtonType="ButtonType.Submit">Create Role</MudButton>
  <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Cancel">Cancel</MudButton>
</EditForm>
</div>
@code {


    [Parameter]
    public RoleModel EditModel { get; set; }

    private bool _busy;

    private List<RoleModel> collection = new List<RoleModel>();
    [CascadingParameter] MudDialogInstance MudDialog { get; set; }
    void Cancel() => MudDialog.Cancel();
    private async void OnValidSubmit(EditContext context)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is being submitted!", Severity.Warning);
            return;
        }
        _busy = true;

        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;
        EditModel.UserInfo.UserID = user.Identity.Name;
        try
        {
            await imgr.CreateAsync(EditModel);

            snackbar.Add("Saved Successfully", Severity.Success);
            if (collection.Exists(x => x.RoleNo == EditModel.RoleNo))
            {
                collection[collection.FindIndex(x => x.RoleNo == EditModel.RoleNo)] =  EditModel;

            }
            else
            {
                collection.Add( EditModel);
            }
            EditModel = new RoleModel();  
            MudDialog.Cancel();
        }
        catch (Exception ex)
        {
            snackbar.Add(ex.Message, Severity.Warning);
        }

        await Task.Delay(2000);
        _busy = false;
    }



}
