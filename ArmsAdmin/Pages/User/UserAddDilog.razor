@inject IUserService iservice
@inject IRoleService<RoleModel> Irole
@inject RoleManager<RoleModel> imgr
@inject MudBlazor.ISnackbar snackbar
@inject AuthenticationStateProvider auth
@attribute [Authorize]
@using System.Globalization
@using Microsoft.AspNetCore.Identity

<MudDialog Class="admin-dialog-glass">
    <DialogContent>
        <div class="header-section mb-6">
            <div class="d-flex align-center">
                <div class="icon-badge primary-badge mr-4">
                    <MudIcon Icon="@Icons.Material.Filled.Security" Size="Size.Large" />
                </div>
                <div>
                    <MudText Typo="Typo.h5" Class="admin-title"><b>Role Configuration</b></MudText>
                    <MudText Typo="Typo.body2" Class="admin-subtitle" Style="color: #667085;">
                        Define system permissions and access levels.
                    </MudText>
                </div>
            </div>
            <div class="title-accent mt-4"></div>
        </div>

        <EditForm Model="@EditModel" OnValidSubmit="OnValidSubmit">
            <div class="admin-glass-card pa-6">
                <MudItem xs="12">
                    <MudTextField @bind-Value="EditModel.RoleID" 
                                 Label="Role Identity" 
                                 Variant="Variant.Outlined" 
                                 Margin="Margin.Normal" 
                                 Placeholder="Enter a unique role identifier"
                                 Adornment="Adornment.Start"
                                 AdornmentIcon="@Icons.Material.Filled.Key"
                                 For="@(() => EditModel.RoleID)"
                                 Class="modern-input"></MudTextField>

                    <MudTextField @bind-Value="EditModel.RoleDesc" 
                                 Label="Role Description" 
                                 Variant="Variant.Outlined" 
                                 Margin="Margin.Normal" 
                                 Placeholder="Briefly describe this role's purpose"
                                 Lines="2"
                                 Adornment="Adornment.Start"
                                 AdornmentIcon="@Icons.Material.Filled.Description"
                                 For="@(() => EditModel.RoleDesc)"
                                 Class="modern-input mt-4"></MudTextField>
                </MudItem>

                <div class="action-section mt-8 d-flex gap-3">
                    <MudButton Disabled="@_busy" 
                               Variant="Variant.Filled" 
                               Color="Color.Primary" 
                               ButtonType="ButtonType.Submit"
                               StartIcon="@Icons.Material.Filled.Save"
                               Class="action-btn-primary flex-grow-1"
                               Style="background: #367588 !important; color: white !important;">
                        @(EditModel.RoleNo > 0 ? "Update Role" : "Create Role")
                    </MudButton>
                    <MudButton Variant="Variant.Outlined" 
                               Color="Color.Default" 
                               OnClick="Cancel"
                               Class="action-btn-secondary"
                               Style="border-color: rgba(54, 117, 136, 0.2) !important;">
                        Cancel
                    </MudButton>
                </div>
            </div>
        </EditForm>
    </DialogContent>
</MudDialog>

<style>
    .admin-dialog-glass {
        background: rgba(255, 255, 255, 0.8) !important;
        backdrop-filter: blur(20px) !important;
        -webkit-backdrop-filter: blur(20px) !important;
        border-radius: 32px !important;
    }

    .admin-title {
        font-family: 'Outfit', sans-serif;
        font-weight: 800;
        color: #141A46;
        letter-spacing: -0.5px;
    }

    .title-accent {
        width: 100%;
        height: 1px;
        background: linear-gradient(90deg, #367588 0%, rgba(54, 117, 136, 0.1) 100%);
    }

    .icon-badge {
        width: 48px;
        height: 48px;
        border-radius: 14px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .primary-badge { 
        background: rgba(54, 117, 136, 0.1); 
        color: #367588;
    }

    .admin-glass-card {
        background: rgba(255, 255, 255, 0.5) !important;
        border: 1px solid rgba(54, 117, 136, 0.1) !important;
        border-radius: 20px !important;
    }

    .modern-input {
        background: white !important;
        border-radius: 12px !important;
    }

    .modern-input .mud-input-outlined-border {
        border-color: rgba(54, 117, 136, 0.1) !important;
    }

    .modern-input:focus-within .mud-input-outlined-border {
        border-color: #367588 !important;
        border-width: 2px !important;
    }

    .action-btn-primary, .action-btn-secondary {
        border-radius: 12px !important;
        padding: 10px 24px !important;
        font-weight: 600 !important;
        text-transform: none !important;
    }

    .action-btn-primary:hover {
        background: #2a5c6b !important;
        box-shadow: 0 4px 12px rgba(54, 117, 136, 0.3) !important;
    }
</style>

@code {

    [Parameter]
    public RoleModel EditModel { get; set; }
    private bool _busy;
    private List<RoleModel> collection = new List<RoleModel>();
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; }

    void Cancel() => MudDialog.Cancel();

    // Method to handle form submission
    private async Task OnValidSubmit(EditContext context)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is being submitted!", Severity.Warning);
            return;
        }
        _busy = true;

        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;
        EditModel.UserInfo.UserID = user.Identity.Name;
        try
        {
            await imgr.CreateAsync(EditModel);
            snackbar.Add("Saved Successfully", Severity.Success);

            // Check if the role already exists in the collection
            if (collection.Exists(x => x.RoleNo == EditModel.RoleNo))
            {
                // Update the existing role in the collection 
                collection[collection.FindIndex(x => x.RoleNo == EditModel.RoleNo)] = EditModel;
            }
            else
            {
                collection.Add(EditModel); // Add the new role to the collection
            }
            EditModel = new RoleModel();
            MudDialog.Cancel();
        }
        catch (Exception ex)
        {
            snackbar.Add(ex.Message, Severity.Warning);
        }
        await Task.Delay(200);
        _busy = false;
    }
}
