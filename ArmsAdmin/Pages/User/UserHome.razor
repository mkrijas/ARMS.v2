@page "/userhome"
@layout AdminMainLayout
@inject IUserService Iservice
@inject UserManager<UserModel> Usmg
@inject MudBlazor.ISnackbar snackbar
@inject AuthenticationStateProvider auth
@attribute [Authorize(Policy = "Admin")]
@inject IDialogService DialogService
@using System.Globalization
@using Microsoft.AspNetCore.Identity

<div style="padding-top:16px;">
    <MudPaper Elevation="4" Class="pa-4 mb-4" Style="background: linear-gradient(135deg, #367588 0%, #2C5D6C 100%); color: white; border-radius: 8px;">
        <div class="d-flex justify-space-between align-center">
            <MudText Typo="Typo.h6" Style="font-weight: 500;">
                <MudIcon Icon="@Icons.Material.Filled.People" Class="mr-2" Style="margin-bottom: -4px;" /> User List
            </MudText>
            <div>
                <MudButton OnClick="DeletedUsersDialog" StartIcon="@Icons.Material.Outlined.PersonOff" Variant="Variant.Outlined" Color="Color.Inherit" Class="mr-2" Style="border-color: rgba(255,255,255,0.5);">
                    Disabled Users
                </MudButton>
                <MudButton OnClick="Undilog" StartIcon="@Icons.Material.Outlined.PersonAddDisabled" Variant="Variant.Outlined" Color="Color.Inherit" Style="border-color: rgba(255,255,255,0.5);">
                    Unapproved User
                </MudButton>
            </div>
        </div>
    </MudPaper>

    <MudTable Items="@collection" Dense="true" Filter="new Func<UserModel, bool>(search)" @bind-SelectedItem="model">
        <ToolBarContent>
            <MudTextField @bind-Value="searchUser" Placeholder="Search User..." Adornment="Adornment.Start" Variant="Variant.Outlined" Margin="Margin.Dense" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium"></MudTextField>
        </ToolBarContent>
        <HeaderContent>
            <MudTh><MudTableSortLabel SortBy="new Func<UserModel, object>(x=> x.UserID)" InitialDirection="SortDirection.Ascending">UserID</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel SortBy="new Func<UserModel, object>(x=> x.UserName)" InitialDirection="SortDirection.Ascending">UserName</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel SortBy="new Func<UserModel, object>(x=> x.Email)" InitialDirection="SortDirection.Ascending">Email</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel SortBy="new Func<UserModel, object>(x=> x.PhoneNumber)" InitialDirection="SortDirection.Ascending">Phone</MudTableSortLabel></MudTh>
            <MudTh>Actions</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="UserID">@context.UserID</MudTd>
            <MudTd DataLabel="UserName">@context.UserName</MudTd>
            <MudTd DataLabel="Email">@context.Email</MudTd>
            <MudTd DataLabel="PhoneNumber">@context.PhoneNumber</MudTd>
            <MudTd DataLabel="">
                <MudFab style="font-size:5px" @onclick="@(()=> Edit(context))" Color="Color.Primary" StartIcon="@Icons.Material.Filled.ManageAccounts" Size="Size.Small" IconSize="Size.Small" />
                <MudFab @onclick="@(()=> Delete(context))" Color="Color.Error" StartIcon="@Icons.Material.Filled.Delete" Size="Size.Small" IconSize="Size.Small" />
            </MudTd>
        </RowTemplate>
        <PagerContent>
            <MudTablePager PageSizeOptions="new int[] { 10, 20, 50, 100 }" />
        </PagerContent>
    </MudTable>
</div>

@code {

    private UserModel model = new UserModel();

    private string searchUser = "";

    private List<UserModel> collection = new List<UserModel>();
    DialogOptions maxWidth = new DialogOptions() { MaxWidth = MaxWidth.Large, FullWidth = true };
    DialogOptions maxWidthMedium = new DialogOptions() { MaxWidth = MaxWidth.Medium, FullWidth = true };

    protected async override Task OnInitializedAsync()
    {
        await GetAll();
    }

    // Method to fetch all users
    private async Task GetAll()
    {
        collection.Clear();
        collection = Iservice.Select(null).ToList(); // Fetch users from the user service
    }

    // Method to edit a user
    private void Edit(UserModel editModel)
    {
        DialogParameters parms = new();
        parms.Add("UserRmodel", editModel.Clone()); // Add the user model to the parameters
        DialogService.Show<RoleassignDilog>("ADD/EDIT", parms); // Show the edit dialog

    }

    // Method to delete a user
    private async Task Delete(UserModel model)
    {
        bool? result = await DialogService.ShowMessageBox(
            "Warning !",
            "Are you sure, you want to delete - " + model.UserName + " (" + model.UserID + ") ?");
        if (result == true)
        {
            var CurrentElement = collection.First(x => x.UserID == model.UserID);
            var authprov = await auth.GetAuthenticationStateAsync();
            var user = authprov.User;
            int value = Iservice.DeleteUser(CurrentElement.UserID, user.Identity.Name); // Delete the user
            if (value != -1)
            {
                snackbar.Add("Deleted Successfully", Severity.Success);
            }
        }
        await GetAll();
    }
    
    // Method to filter users based on the search input
    private bool search(UserModel users)
    {
        if (users.UserID != null && users.UserID.Contains(searchUser, StringComparison.OrdinalIgnoreCase))
        {
            return true;
        }
        else if (users.UserID == null) return true;
        return false;
    }

    // Method to open a dialog (not currently used in the provided code)
    private void OpenDialog()
    {
        DialogParameters parms = new DialogParameters();
        parms.Add("EditModel", new UserDilogue());
    }

    // Method to show the dialog for deleted users
    private void DeletedUsersDialog()
    {
        DialogService.Show<DeletedUserDialog>("", maxWidthMedium); // Show the deleted users dialog
    }

    // Method to show the dialog for unapproved users
    private void Undilog()
    {
        DialogService.Show<UnaprovedDilog>("", maxWidthMedium); // Show the unapproved users dialog
    }
    
    // Method to show the dialog for assigning roles (not currently used in the provided code)
    private void Roledilog(String UserRModel)
    {
        DialogParameters parms = new();
        parms.Add("UserRModel", UserRModel);
        DialogService.Show<RoleassignDilog>("Assign Branches", parms, maxWidth); // Show the role assignment dialog
    }
}
