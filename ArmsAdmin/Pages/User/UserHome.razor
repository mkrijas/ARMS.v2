@page "/userhome"
@layout AdminMainLayout
@inject IUserService Iservice
@inject UserManager<UserModel> Usmg
@inject MudBlazor.ISnackbar snackbar
@inject AuthenticationStateProvider auth
@attribute [Authorize(Policy = "Admin")]
@inject IDialogService DialogService
@using System.Globalization
@using Microsoft.AspNetCore.Identity

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-8 mb-12">
    <!-- Header Section -->
    <div class="header-section mb-10">
        <div class="d-flex justify-space-between align-end">
            <div>
                <MudText Typo="Typo.h4" Class="admin-title mb-2"><b>User Management</b></MudText>
                <div class="title-accent mb-4"></div>
                <MudText Typo="Typo.body1" Class="admin-subtitle" Style="color: #667085;">
                    Manage system users, approve registrations, and oversee access levels.
                </MudText>
            </div>
            <div class="d-flex gap-4 mb-1">
                <MudButton OnClick="Undilog" StartIcon="@Icons.Material.Filled.PersonAddDisabled" Variant="Variant.Filled" Color="Color.Primary" Class="rounded-lg py-2 px-6 shadow-sm">Unapproved Users</MudButton>
                <MudButton OnClick="DeletedUsersDialog" StartIcon="@Icons.Material.Filled.PersonOff" Variant="Variant.Outlined" Color="Color.Primary" Class="rounded-lg py-2 px-6">Disabled Users</MudButton>
            </div>
        </div>
    </div>

    <div class="admin-glass-card">
        <MudTable Items="@collection" Elevation="0" Dense="true" Filter="new Func<UserModel, bool>(search)" @bind-SelectedItem="model" Hover="true" Breakpoint="Breakpoint.Sm">
            <ToolBarContent>
                <div class="d-flex align-center gap-4 w-100">
                    <MudText Typo="Typo.h6" Class="card-title" Style="color: #367588;"><b>Active Users</b></MudText>
                    <MudSpacer />
                    <MudTextField @bind-Value="searchUser" Placeholder="Search by User ID..." Adornment="Adornment.Start" Variant="Variant.Outlined" Margin="Margin.Dense" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="search-field" Style="max-width: 300px; background: white;"></MudTextField>
                </div>
            </ToolBarContent>
            <HeaderContent>
                <MudTh><MudTableSortLabel SortBy="new Func<UserModel, object>(x=> x.UserID)" InitialDirection="SortDirection.Ascending">User ID</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<UserModel, object>(x=> x.UserName)">User Name</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<UserModel, object>(x=> x.Email)">Email Address</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<UserModel, object>(x=> x.PhoneNumber)">Contact Phone</MudTableSortLabel></MudTh>
                <MudTh Style="text-align: right;">Actions</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="UserID"><b>@context.UserID</b></MudTd>
                <MudTd DataLabel="UserName">@context.UserName</MudTd>
                <MudTd DataLabel="Email">@context.Email</MudTd>
                <MudTd DataLabel="PhoneNumber">@context.PhoneNumber</MudTd>
                <MudTd DataLabel="" Style="text-align: right;">
                    <div class="d-flex justify-end gap-2">
                        <MudIconButton OnClick="@(()=> Edit(context))" Color="Color.Primary" Icon="@Icons.Material.Filled.ManageAccounts" Size="Size.Small" Variant="Variant.Filled" />
                        <MudIconButton OnClick="@(()=> Delete(context))" Color="Color.Error" Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Variant="Variant.Filled" />
                    </div>
                </MudTd>
            </RowTemplate>
            <PagerContent>
                <div class="pa-4">
                    <MudTablePager PageSizeOptions="new int[] { 10, 20, 50, 100 }" />
                </div>
            </PagerContent>
        </MudTable>
    </div>
</MudContainer>

@code {

    private UserModel model = new UserModel();

    private string searchUser = "";

    private List<UserModel> collection = new List<UserModel>();
    DialogOptions maxWidth = new DialogOptions() { MaxWidth = MaxWidth.Large, FullWidth = true };
    DialogOptions maxWidthMedium = new DialogOptions() { MaxWidth = MaxWidth.Medium, FullWidth = true };

    protected async override Task OnInitializedAsync()
    {
        await GetAll();
    }

    // Method to fetch all users
    private async Task GetAll()
    {
        collection.Clear();
        collection = Iservice.Select(null).ToList(); // Fetch users from the user service
    }

    // Method to edit a user
    private async Task Edit(UserModel editModel)
    {
        DialogParameters parms = new();
        parms.Add("UserRmodel", editModel.Clone()); // Add the user model to the parameters
        await DialogService.ShowAsync<RoleassignDilog>("ADD/EDIT", parms); // Show the edit dialog

    }

    // Method to delete a user
    private async Task Delete(UserModel model)
    {
        bool? result = await DialogService.ShowMessageBoxAsync(
            "Warning !",
            "Are you sure, you want to delete - " + model.UserName + " (" + model.UserID + ") ?");
        if (result == true)
        {
            var CurrentElement = collection.First(x => x.UserID == model.UserID);
            var authprov = await auth.GetAuthenticationStateAsync();
            var user = authprov.User;
            int value = Iservice.DeleteUser(CurrentElement.UserID, user.Identity.Name); // Delete the user
            if (value != -1)
            {
                snackbar.Add("Deleted Successfully", Severity.Success);
            }
        }
        await GetAll();
    }
    
    // Method to filter users based on the search input
    private bool search(UserModel users)
    {
        if (users.UserID != null && users.UserID.Contains(searchUser, StringComparison.OrdinalIgnoreCase))
        {
            return true;
        }
        else if (users.UserID == null) return true;
        return false;
    }

    // Method to open a dialog (not currently used in the provided code)
    private void OpenDialog()
    {
        DialogParameters parms = new DialogParameters();
        parms.Add("EditModel", new UserDilogue());
    }

    // Method to show the dialog for deleted users
    private async Task DeletedUsersDialog()
    {
        await DialogService.ShowAsync<DeletedUserDialog>("", maxWidthMedium); // Show the deleted users dialog
    }

    // Method to show the dialog for unapproved users
    private async Task Undilog()
    {
        await DialogService.ShowAsync<UnaprovedDilog>("", maxWidthMedium); // Show the unapproved users dialog
    }
    
    // Method to show the dialog for assigning roles (not currently used in the provided code)
    private async Task Roledilog(String UserRModel)
    {
        DialogParameters parms = new();
        parms.Add("UserRModel", UserRModel);
        await DialogService.ShowAsync<RoleassignDilog>("Assign Branches", parms, maxWidth); // Show the role assignment dialog
    }
}
