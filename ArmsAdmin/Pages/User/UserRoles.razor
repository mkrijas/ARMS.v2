@page "/userrole"
@layout AdminMainLayout
@inject IUserService iservice
@inject IRoleService<RoleModel> Irole
@inject RoleManager<RoleModel> rolemngr
@inject UserManager<UserModel> Usmg
@inject MudBlazor.ISnackbar snackbar
@inject AuthenticationStateProvider auth
@attribute [Authorize(Policy = "Admin")]
@inject IDialogService DialogService
@using System.Globalization
@using System.Security.Claims
@using System.Threading

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-8 mb-12">
    <!-- Header Section -->
    <div class="header-section mb-10">
        <div class="d-flex justify-space-between align-end">
            <div>
                <MudText Typo="Typo.h4" Class="admin-title mb-2"><b>Role & Permissions</b></MudText>
                <div class="title-accent mb-4"></div>
                <MudText Typo="Typo.body1" Class="admin-subtitle" Style="color: #667085;">
                    Define system roles, manage access levels, and configure granular permissions.
                </MudText>
            </div>
            <div class="admin-top-actions mb-1">
                <MudButton StartIcon="@Icons.Material.Filled.AddModerator" Variant="Variant.Filled" Color="Color.Primary" Class="rounded-lg py-2 px-6 shadow-sm" @onclick="OpenDialog">Create New Role</MudButton>
            </div>
        </div>
    </div>

    <div class="admin-glass-card">
        <MudTable Items="@collection" Elevation="0" Dense="true" Filter="new Func<RoleModel, bool>(search)" @bind-SelectedItem="model" Hover="true" Breakpoint="Breakpoint.Sm">
            <ToolBarContent>
                <div class="d-flex align-center gap-4 w-100">
                    <MudText Typo="Typo.h6" Class="card-title" Style="color: #367588;"><b>Defined System Roles</b></MudText>
                    <MudSpacer />
                    <MudTextField @bind-Value="searchRole" Placeholder="Filter roles..." Adornment="Adornment.Start" Variant="Variant.Outlined" Margin="Margin.Dense" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="search-field" Style="max-width: 300px; background: white;"></MudTextField>
                </div>
            </ToolBarContent>
            <HeaderContent>
                <MudTh><MudTableSortLabel SortBy="new Func<RoleModel, object>(x => x.RoleNo)" InitialDirection="SortDirection.Ascending">Role ID</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<RoleModel, object>(x => x.RoleID)">Role Key</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<RoleModel, object>(x => x.RoleDesc)">Description</MudTableSortLabel></MudTh>
                <MudTh Style="text-align: right;">Actions</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Role No"><b>@context.RoleNo</b></MudTd>
                <MudTd @onclick="@(()=>croleid(context.RoleID))" DataLabel="Role ID"><code style="color: #367588;">@context.RoleID</code></MudTd>
                <MudTd DataLabel="Role Desc">@context.RoleDesc</MudTd>
                <MudTd DataLabel="" Style="text-align: right;">
                    <div class="d-flex justify-end gap-2">
                        <MudIconButton OnClick="@(()=>PermissionsDilogue(context))" Color="Color.Primary" Icon="@Icons.Material.Filled.Security" Size="Size.Small" Variant="Variant.Filled" title="Manage Permissions" />
                        <MudIconButton OnClick="@(()=> Edit(context))" Color="Color.Info" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Variant="Variant.Filled" title="Edit Role" />
                        <MudIconButton OnClick="@(()=> Delete(context))" Color="Color.Error" Icon="@Icons.Material.Filled.DeleteOutline" Size="Size.Small" Variant="Variant.Filled" title="Delete Role" />
                    </div>
                </MudTd>
            </RowTemplate>
            <PagerContent>
                <div class="pa-4">
                    <MudTablePager PageSizeOptions="new int[] { 10, 20, 50, 100 }" />
                </div>
            </PagerContent>
        </MudTable>
    </div>
</MudContainer>

@code {

    private string id = "";
    public string searchRole = "";

    private RoleModel model = new RoleModel();
    private UserModel usmodel = new UserModel();
    private List<RoleModel> collection = new List<RoleModel>();
    private List<Claim> clamelist = new List<Claim>();
    public string csroleid { get; set; } = "";
    public bool checkbox { get; set; } = false;
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; }

    void Cancel() => MudDialog.Cancel();

    // Class to represent a view of role claims
    class roleClaimView
    {
        public string ClaimType { get; set; }
        public List<string> ClaimValues { get; set; } = new();
    }

    private List<roleClaimView> Claims = new();

    protected override async Task OnInitializedAsync()
    {
        await GetAll();
        await GetClaim();
    }

    // Method to fetch all roles
    private async Task GetAll()
    {
        if (collection != null)
        {
            collection.Clear();
        }
        collection = Irole.Select(null).ToList(); // Fetch roles from the role service
    }

    // Method to fetch all claims associated with roles 
    private async Task GetClaim()
    {
        CancellationTokenSource ctc = new CancellationTokenSource();
        clamelist = Irole.GetAllClaims(ctc.Token).Result.ToList(); // Fetch all claims
        foreach (var claimName in clamelist.DistinctBy(x => x.Type).Select(y => y.Type)) // Group claims by type
        {
            Claims.Add(new roleClaimView()
                {
                    ClaimType = claimName, // Set the claim type
                    ClaimValues = new(clamelist.Where(x => x.Type == claimName).Select(y => y.Value).ToList()) // Set the claim values
                });
        }
    }

    // Method to open the dialog for adding a new role
    private async Task OpenDialog()
    {
        DialogParameters parms = new DialogParameters();
        parms.Add("EditModel", new RoleModel()); // Add a new role model to the parameters
        var dialog = await DialogService.ShowAsync<UserAddDilog>("Add Roles", parms); // Show the add role dialog
        var result = await dialog.Result; // Wait for the dialog result

        // Check if the modal was cancelled
        var isCancelled = result.Canceled;

        await GetAll();
        await GetClaim();
    }

    // Method to edit an existing role
    private async Task Edit(RoleModel editModel)
    {
        DialogParameters parms = new DialogParameters();
        parms.Add("EditModel", editModel.Clone()); // Add the cloned role model to the parameters
        var dialog = await DialogService.ShowAsync<UserAddDilog>("Add Roles", parms); // Show the edit role dialog
        var result = await dialog.Result; // Wait for the dialog result

        // you can check if the modal was cancelled
        var isCancelled = result.Canceled;
        if (!isCancelled)
        {
            await GetAll();
            await GetClaim();
        }
    }

    // Method to delete a role
    private async Task Delete(RoleModel editModel)
    {
        bool? result = await DialogService.ShowMessageBoxAsync(
            "Warning",
            "Are you sure you want to delete this entry?",
            yesText: "Delete!", cancelText: "Cancel");
        var state = result == null ? "Cancelled" : "Deleted!";
        if (state == "Deleted!")
        {
            await rolemngr.DeleteAsync(editModel); // Delete the role
            snackbar.Add("Deleted Successfully", Severity.Success);
            await GetAll();
            await GetClaim();
        }
    }

    // Method to filter roles based on the search input
    private bool search(RoleModel roles)
    {
        if (roles.RoleNo != null && roles.RoleID.Contains(searchRole, StringComparison.OrdinalIgnoreCase) || roles.RoleDesc.Contains(searchRole, StringComparison.OrdinalIgnoreCase))
        {
            return true;
        }
        else if (roles.RoleID == null) return true;
        return false;
    }

    // Method to open the dialog for managing permissions
    private async Task PermissionsDilogue(RoleModel editModel)
    {
        DialogParameters parms = new DialogParameters();
        parms.Add("RoleModel", editModel.Clone()); // Add the cloned role model to the parameters
        DialogOptions maxWidth = new DialogOptions() { MaxWidth = MaxWidth.Medium };
        await DialogService.ShowAsync<ClaimDilogue>("Manage Permissions", parms, maxWidth); // Show the permissions dialog
    } 

    // Method to set the current role ID
    private void croleid(String rid)
    {
        csroleid = rid;
    }

    // Method to update role claims
    private async Task Roleupdate(bool val, String Claimtype, String claimvalue)
    {
        Claim claim = new Claim(Claimtype, claimvalue);
        model.RoleID = csroleid;
        if (val == true)
        {
            rolemngr.AddClaimAsync(model, claim); // Add the claim to the role
            snackbar.Add("Claim Added", Severity.Success);
            await GetAll();
        }
        else
        {
            rolemngr.RemoveClaimAsync(model, claim); // Remove the claim from the role
            snackbar.Add("Claim Removed", Severity.Success);
            await GetAll();
        }
    }
}