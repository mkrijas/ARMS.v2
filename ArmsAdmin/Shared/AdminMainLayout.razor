@inject IDialogService DialogService
@inject AuthenticationStateProvider auth
@inherits LayoutComponentBase
@using System.Security.Claims
@inject IUserService _user
@inject NavigationManager uriHelper;
@inject MudBlazor.ISnackbar snackbar

<CascadingValue Value="this">
    <div class="fixed-background">
        <div class="mesh-gradient"></div>
        <div class="pattern-overlay"></div>
    </div>

    <div class="page">
        <AuthorizeView>
            <Authorized>
                <ArmsAdmin.Shared.NavMenuAdmin />
            </Authorized>
        </AuthorizeView>

        <div class="main">
            <!-- Top navbar removed as per design requirement -->

            <article class="content" style="padding: 20px 20px 20px 70px; background: transparent !important;">
                @Body
            </article>
        </div>
    </div>
</CascadingValue>
<MudDialogProvider FullWidth="true"
                   MaxWidth="MaxWidth.Small"
                   CloseButton="true"
                   NoHeader="false"
                   Position="DialogPosition.Center" />
<MudPopoverProvider />
<MudThemeProvider Theme="@AdminTheme" />
<MudSnackbarProvider />


<style>


    body {
        /* background-color: #f0f0f0 !important; */
        margin: 0;
        padding: 0;
        min-height: 100vh;
    }

    /* Header & Branding */
    .admin-title {
        font-family: 'Outfit', sans-serif;
        font-weight: 800;
        color: #141A46;
        letter-spacing: -0.5px;
    }

    .title-accent {
        width: 60px;
        height: 4px;
        background: linear-gradient(90deg, #367588 0%, #FF9F43 100%);
        border-radius: 2px;
    }

    /* Glass Cards */
    .admin-glass-card {
        background: rgba(255, 255, 255, 0.7) !important;
        backdrop-filter: blur(12px) !important;
        -webkit-backdrop-filter: blur(12px) !important;
        border: 1px solid rgba(255, 255, 255, 0.3) !important;
        border-radius: 24px !important;
        box-shadow: 0 8px 32px 0 rgba(31, 38, 135, 0.05) !important;
        transition: transform 0.3s ease, box-shadow 0.3s ease !important;
    }

    .admin-card-hover:hover {
        transform: translateY(-8px);
        box-shadow: 0 12px 40px 0 rgba(31, 38, 135, 0.1) !important;
    }

    /* Modern Table Styling */
    .admin-glass-card .mud-table {
        background: transparent !important;
    }

    .admin-glass-card .mud-table-toolbar {
        background: transparent !important;
        padding: 24px !important;
    }

    .admin-glass-card .mud-table-container {
        padding: 0 24px 24px 24px !important;
    }

    .admin-glass-card .mud-table-head {
        background: rgba(54, 117, 136, 0.05) !important;
    }

    .admin-glass-card .mud-th {
        font-weight: 800 !important;
        color: #141A46 !important;
        text-transform: uppercase;
        font-size: 0.85rem !important;
        letter-spacing: 1px !important;
        padding-top: 20px !important;
        padding-bottom: 20px !important;
        border-bottom: 2px solid rgba(54, 117, 136, 0.15) !important;
    }

    .admin-glass-card .mud-table-row:hover {
        background: rgba(54, 117, 136, 0.02) !important;
    }

    .admin-glass-card .mud-td {
        color: #141A46 !important;
        border-bottom: 1px solid rgba(54, 117, 136, 0.05) !important;
    }
    .auth-pill {
        padding: 2px 8px;
        border-radius: 12px;
        background: rgba(54, 117, 136, 0.03);
        border: 1px solid rgba(54, 117, 136, 0.1);
        transition: all 0.3s ease;
        display: flex;
        align-items: center;
        min-width: fit-content;
    }
    .auth-pill:hover {
        background: rgba(54, 117, 136, 0.08);
        border-color: rgba(54, 117, 136, 0.3);
        transform: translateY(-1px);
    }
    .auth-pill.active {
        background: rgba(54, 117, 136, 0.1);
        border-color: rgba(54, 117, 136, 0.4);
        box-shadow: 0 2px 6px rgba(54, 117, 136, 0.05);
    }
    .auth-pill .mud-checkbox {
        margin: 0;
        padding: 4px;
    }
    .auth-pill .mud-checkbox-label {
        font-size: 0.8rem;
        font-weight: 500;
        color: #4a5568;
    }
    .auth-pill.active .mud-checkbox-label {
        color: #1a202c;
        font-weight: 600;
    }
</style>


@code
{
    MudTheme AdminTheme = new MudTheme()
    {
        PaletteLight = new PaletteLight()
        {
            Primary = "#367588", // Custom Teal Blue
            Secondary = "#000000",
            AppbarBackground = "#367588",
            AppbarText = "#FFFFFF",
            DrawerBackground = "#FFFFFF", // Keep sidebar white for cleanliness
            DrawerText = "#5E5873",
            DrawerIcon = "#5E5873",
            Surface = "#FFFFFF",
            Background = "#F8F9FA",
            TextPrimary = "#5E5873",
            ActionDefault = "#367588",
            Success = "#00897B",
        },
        Typography = new Typography()
        {
            Default = new DefaultTypography() { FontFamily = new[] { "Inter", "sans-serif" } },
            H1 = new H1Typography() { FontFamily = new[] { "Outfit", "sans-serif" }, FontWeight = "700" },
            H2 = new H2Typography() { FontFamily = new[] { "Outfit", "sans-serif" }, FontWeight = "700" },
            H3 = new H3Typography() { FontFamily = new[] { "Outfit", "sans-serif" }, FontWeight = "700" },
            H4 = new H4Typography() { FontFamily = new[] { "Outfit", "sans-serif" }, FontWeight = "700" },
            H5 = new H5Typography() { FontFamily = new[] { "Outfit", "sans-serif" }, FontWeight = "700" },
            H6 = new H6Typography() { FontFamily = new[] { "Outfit", "sans-serif" }, FontWeight = "700" },
            Button = new ButtonTypography() { FontFamily = new[] { "Inter", "sans-serif" }, FontWeight = "600", TextTransform = "none" },
            Body1 = new Body1Typography() { FontFamily = new[] { "Inter", "sans-serif" } },
            Body2 = new Body2Typography() { FontFamily = new[] { "Inter", "sans-serif" } },
            Subtitle1 = new Subtitle1Typography() { FontFamily = new[] { "Inter", "sans-serif" }, FontWeight = "600" },
            Subtitle2 = new Subtitle2Typography() { FontFamily = new[] { "Inter", "sans-serif" }, FontWeight = "500" }
        }
    };
}
