@inject IDialogService DialogService
@inject AuthenticationStateProvider auth
@inherits LayoutComponentBase
@using System.Security.Claims
@inject IUserService _user
@inject NavigationManager uriHelper;
@inject MudBlazor.ISnackbar snackbar

<CascadingValue  Value="this">
    <div class="page">
        <AuthorizeView>
            <Authorized>
                <div class="sidebar">
                      <ArmsAdmin.Shared.NavMenuAdmin />
                </div>
            </Authorized>
        </AuthorizeView>

        <div class="main">
        <div class="top-row px-4" style="background-color: #367588 !important; border-bottom: 1px solid #2C5D6C;">
                <BarDisplay />
        </div>

        <article class="content px-4">
            @Body
        </article>
        </div>
    </div>
</CascadingValue>
<MudDialogProvider FullWidth="true"
                   MaxWidth="MaxWidth.Small"
                   CloseButton="true"
                   NoHeader="false"
                   Position="DialogPosition.Center" />
<MudPopoverProvider />
<MudThemeProvider Theme="@AdminTheme" />
<MudSnackbarProvider />


<style>


    body{background-color:#f0f0f0 !important;}
</style>


@code
{
    MudTheme AdminTheme = new MudTheme()
    {
        PaletteLight = new PaletteLight()
        {
            Primary = "#367588", // Custom Teal Blue
            Secondary = "#000000",
            AppbarBackground = "#367588",
            AppbarText = "#FFFFFF",
            DrawerBackground = "#FFFFFF", // Keep sidebar white for cleanliness
            DrawerText = "#5E5873",
            DrawerIcon = "#5E5873",
            Surface = "#FFFFFF",
            Background = "#F8F9FA",
            TextPrimary = "#5E5873",
            ActionDefault = "#367588",
        }
    };
}
