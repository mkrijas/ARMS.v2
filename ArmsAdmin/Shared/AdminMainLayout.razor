@inject IDialogService DialogService
@inject AuthenticationStateProvider auth
@inherits LayoutComponentBase
@using System.Security.Claims
@inject IUserService _user
@inject NavigationManager uriHelper;
@inject MudBlazor.ISnackbar snackbar

<CascadingValue Value="this">
    <div class="page">
        <AuthorizeView>
            <Authorized>
                <ArmsAdmin.Shared.NavMenuAdmin />
            </Authorized>
        </AuthorizeView>

        <div class="main">
            <!-- Top navbar removed as per design requirement -->

            <article class="content" style="padding: 20px 20px 20px 70px;">
                @Body
            </article>
        </div>
    </div>
</CascadingValue>
<MudDialogProvider FullWidth="true"
                   MaxWidth="MaxWidth.Small"
                   CloseButton="true"
                   NoHeader="false"
                   Position="DialogPosition.Center" />
<MudPopoverProvider />
<MudThemeProvider Theme="@AdminTheme" />
<MudSnackbarProvider />


<style>


    body {
        background-color: #f0f0f0 !important;
    }
</style>


@code
{
    MudTheme AdminTheme = new MudTheme()
    {
        PaletteLight = new PaletteLight()
        {
            Primary = "#367588", // Custom Teal Blue
            Secondary = "#000000",
            AppbarBackground = "#367588",
            AppbarText = "#FFFFFF",
            DrawerBackground = "#FFFFFF", // Keep sidebar white for cleanliness
            DrawerText = "#5E5873",
            DrawerIcon = "#5E5873",
            Surface = "#FFFFFF",
            Background = "#F8F9FA",
            TextPrimary = "#5E5873",
            ActionDefault = "#367588",
        }
    };
}
