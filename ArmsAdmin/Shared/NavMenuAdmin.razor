<div id="global-tooltip">Tooltip</div>

<script>
    const menu = document.getElementById("menu");
    const toggleBtn = document.getElementById("toggleBtn");
    const arrowBtnForward = document.getElementById("arrowBtnForward");
    const arrowBtnBackward = document.getElementById("arrowBtnBackward");
    const listings = document.getElementById("listings");

    let rotation = 10;
    const step = 36 * 3; // Move 3 items at a time

    toggleBtn.addEventListener("click", () => {
      const willOpen = !menu.classList.contains("open");

      if (willOpen) {
        menu.classList.add("open");
        listings.style.transform = `scale(1) rotate(${rotation}deg)`;
      } else {
        menu.classList.remove("open");
        listings.style.transform = ""; // IMPORTANT: remove inline transform
        rotation = 10; // optional reset
      }
    });

    arrowBtnForward.addEventListener("click", (e) => {
      e.preventDefault();
      e.stopPropagation();

      if (!menu.classList.contains("open")) return;

      rotation += step;
      listings.style.transform = `scale(1) rotate(${rotation}deg)`;
    });

    arrowBtnBackward.addEventListener("click", (e) => {
      e.preventDefault();
      e.stopPropagation();

      if (!menu.classList.contains("open")) return;

      rotation -= step;
      listings.style.transform = `scale(1) rotate(${rotation}deg)`;
    });

    // Global Tooltip Logic
    const tooltip = document.getElementById("global-tooltip");
    const menuBtns = document.querySelectorAll(".menu-btn");

    function updateTooltipPosition(btn) {
         if (tooltip.style.display === 'block') {
            const rect = btn.getBoundingClientRect();
            // Position to the right of the button with a small gap
            tooltip.style.left = (rect.right + 15) + "px";
            // Center vertically relative to the button
            tooltip.style.top = (rect.top + (rect.height / 2) - (tooltip.offsetHeight / 2)) + "px";
         }
    }

    menuBtns.forEach(btn => {
        btn.addEventListener("mouseenter", () => {
            const text = btn.getAttribute("data-tooltip");
            if (text) {
                tooltip.textContent = text;
                tooltip.style.display = "block";
                updateTooltipPosition(btn);
            }
        });

        btn.addEventListener("mouseleave", () => {
            tooltip.style.display = "none";
        });
        
        // Ensure position updates if the menu is rotating while hovering (though mouseleave usually fires)
        // We can just rely on hover for now.
    });
</script>
