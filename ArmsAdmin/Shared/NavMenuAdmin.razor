<div id="global-tooltip">Tooltip</div>

<script>
    // Simplified Global Tooltip Logic for Blazor
    function initAdminMenuTooltips() {
        const tooltip = document.getElementById("global-tooltip");
        const menuBtns = document.querySelectorAll(".menu-btn");

        function updatePosition(btn) {
            const rect = btn.getBoundingClientRect();
            tooltip.style.left = (rect.right + 20) + "px";
            tooltip.style.top = (rect.top + (rect.height / 2) - (tooltip.offsetHeight / 2)) + "px";
        }

        menuBtns.forEach(btn => {
            btn.addEventListener("mouseenter", () => {
                const text = btn.getAttribute("data-tooltip");
                if (text) {
                    tooltip.textContent = text;
                    tooltip.style.display = "block";
                    // Add a tiny delay to ensure offsetHeight is calculated
                    requestAnimationFrame(() => {
                        updatePosition(btn);
                        tooltip.classList.add("visible");
                    });
                }
            });
            btn.addEventListener("mouseleave", () => {
                tooltip.classList.remove("visible");
                setTimeout(() => {
                    if (!tooltip.classList.contains("visible")) {
                         tooltip.style.display = "none";
                    }
                }, 200);
            });
        });
    }
</script>
@inject IJSRuntime JSRuntime

@code {
    private bool _isOpen = false;
    private int _rotation = 10;
    private const int Step = 36 * 3;

    private string GetCounterRotation(int index)
    {
        int totalStatic = 108 + 18 + 180 + (36 * index);
        return $"{-(_rotation + totalStatic)}deg;";
    }

    private string GetDelay(int index)
    {
        return _isOpen ? $"{(index * 0.05).ToString("0.00", System.Globalization.CultureInfo.InvariantCulture)}s" : "0s";
    }

    private string IsActive(string href)
    {
        var currentUri = NavigationManager.Uri;
        return currentUri.Contains(href, StringComparison.OrdinalIgnoreCase) ? "active" : "";
    }

    private string ListingsStyle => _isOpen 
        ? $"transform: scale(1) rotate({_rotation}deg);" 
        : "";

    private void ToggleMenu()
    {
        _isOpen = !_isOpen;
        if (!_isOpen)
        {
            _rotation = 10; // Reset rotation on close
        }
    }

    private void RotateForward()
    {
        if (_isOpen)
        {
            _rotation += Step;
        }
    }

    private void RotateBackward()
    {
        if (_isOpen)
        {
            _rotation -= Step;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        // Re-initialize tooltips after every render to ensure they bind correctly
        // especially after navigation or state changes.
        await JSRuntime.InvokeVoidAsync("initAdminMenuTooltips");
    }

    private async Task Logout()
    {
        if (AuthStateProvider is ICustomAuthenticationService customAuthProvider)
        {
            await customAuthProvider.Logout();
            NavigationManager.NavigateTo("/", true);
        }
    }
}
