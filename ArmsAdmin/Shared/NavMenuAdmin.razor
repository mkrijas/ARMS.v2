

<style>
    /* Force Admin Menu to Teal Blue, overriding global Orange !important rules */
    .MenuClass .mud-nav-link.active:not(.mud-nav-group-item) {
        background: linear-gradient(118deg, #367588, rgba(54, 117, 136, 0.7)) !important;
        box-shadow: 0 0 10px 1px rgba(54, 117, 136, 0.7) !important;
        color: #FFFFFF !important;
    }

    .MenuClass .mud-nav-link:hover:not(.active) {
        color: #367588 !important;
    }

    .MenuClass .mud-nav-link:hover .mud-nav-link-icon {
        color: #367588 !important;
    }
</style>
<MudPaper Width="250px" Class="d-inline-flex MenuClass" Style="height:100%" Square="true">
    <MudNavMenu Class="mud-width-full">
        <div class="px-6 py-2 logo" style="background-color: #367588 !important;">
            <a class="navbar-brand" href=""><img src="images/logoarms.png?v=5" style="margin-bottom:1%; filter: brightness(0) invert(1);" width="160px" /></a>
            <MudText Typo="Typo.subtitle2" Class="text-black-50 mt-2" Style="align-self:center"></MudText>
        </div>
        <MudDivider />
        <div class="py-3 menuContainer">
            <MudNavLink Href="/Userhome" Icon="@Icons.Material.Filled.VerifiedUser" IconColor="Color.Inherit">Users</MudNavLink>
            <MudNavLink Href="/Devices" Icon="@Icons.Material.Filled.VerifiedUser" IconColor="Color.Inherit">Devices</MudNavLink>
            <MudNavLink Href="/userrole" Icon="@Icons.Material.Filled.VerifiedUser" IconColor="Color.Inherit">Roles</MudNavLink>
            <MudNavGroup Title="Masters" Icon="@Icons.Material.Filled.Settings" IconColor="Color.Inherit">
                <MudNavLink Href="/branch" Icon="@Icons.Material.Filled.BarChart" IconColor="Color.Inherit">Branches</MudNavLink>
                <MudNavLink Href="/TariffTypes" Icon="@Icons.Material.Filled.Settings" IconColor="Color.Inherit">Tariff Types</MudNavLink>
                @* new NavMenuModel(){ID = 11105,  Title = "Tariff Master",  href = "/TariffTypes" ,IconColor = Color.Info  }, *@

            </MudNavGroup>
            <MudNavGroup Title="Settings" Icon="@Icons.Material.Filled.Settings" IconColor="Color.Inherit">
                <MudNavLink Href="/DataAuthorizationSettingsView" Icon="@Icons.Material.Filled.Store" IconColor="Color.Inherit">Authorization Settings</MudNavLink>
                <MudNavLink Href="/GeneralSettings" Icon="@Icons.Material.Filled.Settings" IconColor="Color.Inherit">Genaral Settings</MudNavLink>
            </MudNavGroup>
            <MudNavLink Href="/TripReviewManager" Icon="@Icons.Material.Filled.FireTruck" IconColor="Color.Inherit">Trip Manager</MudNavLink>
        </div>
    </MudNavMenu>
</MudPaper>

