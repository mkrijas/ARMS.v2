<link rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" />

<style>
    :root {
        --background-color: #ffff;
        --menu-color: rgba(54, 117, 136, 1); /* #ffffff */
        --icon-hover-color: #c1264e;
        --arrow-hover-color: #ff947f;
        --hamburger-width: 20px;
        --hamburger-height: 2px;
        --anim: 0.45s;
        --arrow-size: 20px;
        --menu-toggle-size: 200px;
        --li-angle: 36deg;
        --skew-angle: -54deg;
        --skew-angle-content: 54deg;
        --li-angle-content: 18deg;
        --circle-rotate: 108deg;
        --glass-bg: rgba(54, 117, 136, 0.7);
        --glass-border: rgba(255, 255, 255, 0.2);
    }

    @@keyframes pulse-glow {
        0% { box-shadow: 0 0 0 0 rgba(54, 117, 136, 0.4); }
        70% { box-shadow: 0 0 0 15px rgba(54, 117, 136, 0); }
        100% { box-shadow: 0 0 0 0 rgba(54, 117, 136, 0); }
    }

    @@keyframes fan-in {
        from { transform: scale(0.1) rotate(150deg); opacity: 0; }
        to { transform: scale(1) rotate(var(--rotation, 10deg)); opacity: 1; }
    }

    html, body {
        /* height: 100%; */
        margin: 0;
        /* overflow: hidden; */
        background: var(--background-color);
        font-family: Arial, sans-serif;
    }

    .menu--circle {
        position: fixed;
        top: 0;
        left: 0;
        z-index: 999;
        width: 260px;
        height: 260px;
        overflow: visible; /* Changed to visible so tooltips show */
        background: transparent !important;
        pointer-events: none; /* Let clicks pass through empty areas */
    }

    /* Re-enable pointer events for interactive elements */
    .menu__toggle, .menu__listings, .menu__arrowBtn, .menu-tooltip {
        pointer-events: auto;
    }

    .menu__toggle {
        position: absolute;
        top: calc(var(--menu-toggle-size) / -2);
        left: calc(var(--menu-toggle-size) / -2);
        width: var(--menu-toggle-size);
        height: var(--menu-toggle-size);
        border-radius: 50%;
        background: var(--menu-color);
        border: 2px solid var(--glass-border);
        cursor: pointer;
        display: block;
        z-index: 50;
        box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);
        animation: pulse-glow 3s infinite;
        transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .menu__toggle:hover {
        transform: scale(1.05);
        background: #3d869c;
    }

    .icon {
        position: absolute;
        top: 70%;
        left: 70%;
        transform: translate(-50%, -50%);
        width: 40px;
        height: 40px;
        display: grid;
        place-items: center;
    }

    .hamburger {
        position: relative;
        width: var(--hamburger-width);
        height: 10px;
    }

        .hamburger span,
        .hamburger span::before,
        .hamburger span::after {
            display: block;
            content: "";
            position: absolute;
            left: 0;
            width: var(--hamburger-width);
            height: var(--hamburger-height);
            background: var(--background-color);
            border-radius: 5px;
            transition: transform var(--anim), top var(--anim), opacity var(--anim), background var(--anim);
        }

        .hamburger span {
            top: 4px;
        }

            .hamburger span::before {
                top: -6px;
            }

            .hamburger span::after {
                top: 6px;
            }

    .menu__listings {
        position: absolute;
        top: calc(var(--menu-toggle-size) * -1);
        left: calc(var(--menu-toggle-size) * -1);
        width: calc(var(--menu-toggle-size) * 2);
        height: calc(var(--menu-toggle-size) * 2);
        border-radius: 50%;
        transform: scale(0.1) rotate(150deg);
        opacity: 0;
        transition: transform 0.6s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.4s ease;
        z-index: 10;
        pointer-events: none;
    }

    .menu--circle.open .menu__listings {
        opacity: 1;
        pointer-events: auto;
    }

    .circle {
        position: relative;
        width: 100%;
        height: 100%;
        margin: 0;
        padding: 0;
        list-style: none;
        border-radius: 50%;
        background: var(--menu-color);
        overflow: hidden;
        transform: rotate(var(--circle-rotate));
        box-shadow: rgba(0, 0, 0, 0.7) 0 3px 12px;
    }

    .circle li {
        position: absolute;
        top: 0;
        right: 0;
        width: 50%;
        height: 50%;
        transform-origin: 0 100%;
        background: var(--glass-bg);
        backdrop-filter: blur(10px);
        -webkit-backdrop-filter: blur(10px);
        border: 1px solid var(--glass-border);
        pointer-events: none;
        transition: background 0.3s ease, transform 0.6s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .circle li:hover {
        background: rgba(54, 117, 136, 0.9);
    }

            .circle li:nth-child(1) {
                transform: rotate(calc(0 * var(--li-angle))) skewY(var(--skew-angle));
            }

            .circle li:nth-child(2) {
                transform: rotate(calc(1 * var(--li-angle))) skewY(var(--skew-angle));
            }

            .circle li:nth-child(3) {
                transform: rotate(calc(2 * var(--li-angle))) skewY(var(--skew-angle));
            }

            .circle li:nth-child(4) {
                transform: rotate(calc(3 * var(--li-angle))) skewY(var(--skew-angle));
            }

            .circle li:nth-child(5) {
                transform: rotate(calc(4 * var(--li-angle))) skewY(var(--skew-angle));
            }

            .circle li:nth-child(6) {
                transform: rotate(calc(5 * var(--li-angle))) skewY(var(--skew-angle));
            }

            .circle li:nth-child(7) {
                transform: rotate(calc(6 * var(--li-angle))) skewY(var(--skew-angle));
            }

            .circle li:nth-child(8) {
                transform: rotate(calc(7 * var(--li-angle))) skewY(var(--skew-angle));
            }

            .circle li:nth-child(9) {
                transform: rotate(calc(8 * var(--li-angle))) skewY(var(--skew-angle));
            }

            .circle li:nth-child(10) {
                transform: rotate(calc(9 * var(--li-angle))) skewY(var(--skew-angle));
            }

    .placeholder {
        position: absolute;
        left: -100%;
        width: 200%;
        height: 200%;
        padding-top: 1.5em;
        text-align: center;
        transform: skewY(var(--skew-angle-content)) rotate(var(--li-angle-content));
        pointer-events: none;
    }

    .upside {
        transform: rotate(180deg);
    }

    .menu-btn {
        font-size: 2.3em;
        background: transparent;
        border: none;
        color: rgba(255, 255, 255, 0.7);
        cursor: pointer;
        pointer-events: auto;
        transition: transform 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275), color 0.4s ease, filter 0.4s ease;
        display: inline-block;
        filter: drop-shadow(0 2px 4px rgba(0,0,0,0.2));
        transform: rotate(var(--icon-rotation, 0deg));
    }

    .menu-btn.active {
        color: #FFFFFF !important;
        filter: drop-shadow(0 0 10px rgba(255, 255, 255, 0.5));
    }

    .menu-btn:hover {
        color: #FFFFFF !important;
        transform: rotate(var(--icon-rotation, 0deg)) scale(1.3) translateY(-3px);
        filter: drop-shadow(0 0 15px rgba(255, 255, 255, 0.9));
    }

    .menu-btn:active {
        transform: scale(0.95);
    }

    .menu__arrowBtn {
        position: absolute;
        top: 10px;
        right: 18px;
        z-index: 40;
        width: 44px;
        height: 44px;
        border: none;
        background: transparent;
        cursor: pointer;
        display: none;
    }
    
    .menu__arrowBtn.backward {
        top: auto;
        bottom: 20px;
        right: auto;
        left: 10px; /* Position at the start of the arc */
        rotate: 90deg;
    }

        .menu__arrowBtn i {
            font-size: 32px;
            color: var(--menu-color);
            transition: color 0.2s;
        }

        .menu__arrowBtn:hover i {
            color: var(--arrow-hover-color);
        }

    /* Open state */
    .menu--circle.open .menu__listings {
        /* Handled by inline style in Blazor now */
    }

    .menu--circle.open .menu__toggle {
        background: var(--background-color);
        box-shadow: none;
    }

    .menu--circle.open .hamburger span {
        background: transparent;
    }

        .menu--circle.open .hamburger span::before {
            top: 0;
            transform: rotate(45deg);
            background: var(--menu-color);
        }

        .menu--circle.open .hamburger span::after {
            top: 0;
            transform: rotate(-45deg);
            background: var(--menu-color);
        }

    .menu--circle.open .menu__arrowBtn {
        display: block;
    }





    .menu-tooltip {
        display: none;
        position: absolute;
        /* Center on the button first to ignore parent's rotated positioning */
        top: 50%;
        left: 50%; 
        transform-origin: center center;
        background: rgba(0, 0, 0, 0.9); 
        color: #fff;
        padding: 6px 12px;
        border-radius: 4px;
        font-size: 14px;
        font-weight: bold;
        white-space: nowrap;
        pointer-events: none;
        box-shadow: 0 2px 8px rgba(0,0,0,0.4);
        z-index: 2000;
    }

    .menu-btn {
        position: relative;
    }

    /* Global Tooltip Styles - Modern Glassmorphism */
    #global-tooltip {
        position: fixed;
        display: none;
        background: rgba(20, 26, 70, 0.85);
        backdrop-filter: blur(8px);
        -webkit-backdrop-filter: blur(8px);
        color: #fff;
        padding: 8px 16px;
        border-radius: 12px;
        font-size: 13px;
        font-weight: 600;
        letter-spacing: 0.3px;
        white-space: nowrap;
        pointer-events: none;
        z-index: 10000;
        box-shadow: 0 8px 32px rgba(0, 0, 0, 0.2), inset 0 0 0 1px rgba(255,255,255,0.1);
        border: 1px solid rgba(255,255,255,0.1);
        transform: scale(0.9) translateY(5px);
        transition: transform 0.2s cubic-bezier(0.175, 0.885, 0.32, 1.275), opacity 0.2s ease;
        opacity: 0;
    }

    #global-tooltip.visible {
        opacity: 1;
        transform: scale(1) translateY(0);
    }
</style>
