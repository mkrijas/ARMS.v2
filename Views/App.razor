<Router AppAssembly="@typeof(Program).Assembly" AdditionalAssemblies="@AdminAssembly" >
    <Found Context="routeData">
        <AuthorizeRouteView RouteData="@routeData" DefaultLayout="@typeof(MainLayout)">
            <NotAuthorized>
                @if (context.User.Identity?.IsAuthenticated == true)
                {
                    <div class="d-flex flex-column align-center justify-center" style="height: 70vh; width: 100%;">
                        <MudIcon Icon="@Icons.Material.Filled.GppBad" Color="Color.Error" Style="font-size: 8rem; opacity: 0.8;" Class="mb-4" />
                        <MudText Typo="Typo.h4" Color="Color.Primary" Class="mb-3" Style="font-weight: 700;">Access Denied</MudText>
                        <MudText Typo="Typo.body1" Class="mb-6 text-center" Style="max-width: 400px; color: var(--mud-palette-text-secondary) !important;">
                            You do not have the required permissions to view this page. If you believe this is an error, please contact your administrator.
                        </MudText>
                        <MudButton Href="/" Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large" Class="rounded-pill px-8">
                            <MudIcon Icon="@Icons.Material.Filled.Home" Class="mr-2" /> Return to Home
                        </MudButton>
                    </div>
                }
                else
                {
                    <div class="d-flex flex-column align-center justify-center" style="height: 70vh; width: 100%;">
                        <MudIcon Icon="@Icons.Material.Filled.Lock" Color="Color.Warning" Style="font-size: 8rem; opacity: 0.8;" Class="mb-4" />
                        <MudText Typo="Typo.h4" Color="Color.Primary" Class="mb-3" Style="font-weight: 700;">Authentication Required</MudText>
                        <MudText Typo="Typo.body1" Class="mb-6 text-center" Style="max-width: 400px; color: var(--mud-palette-text-secondary) !important;">
                            Please sign in to access this page. Ensure you are using the correct credentials.
                        </MudText>
                        <MudButton Href="/" Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large" Class="rounded-pill px-8">
                            <MudIcon Icon="@Icons.Material.Filled.Login" Class="mr-2" /> Go to Sign In
                        </MudButton>
                    </div>
                }
            </NotAuthorized>
        </AuthorizeRouteView>
    </Found>
    <NotFound>
        <CascadingAuthenticationState>
            <LayoutView Layout="@typeof(MainLayout)">
                <div class="d-flex flex-column align-center justify-center" style="height: 70vh; width: 100%;">
                    <MudIcon Icon="@Icons.Material.Filled.ErrorOutline" Color="Color.Default" Style="font-size: 8rem; opacity: 0.5;" Class="mb-4" />
                    <MudText Typo="Typo.h2" Color="Color.Primary" Class="mb-2" Style="font-weight: 800;">404</MudText>
                    <MudText Typo="Typo.h5" Class="mb-3" Style="color: var(--mud-palette-text-primary) !important; font-weight: 600;">Page Not Found</MudText>
                    <MudText Typo="Typo.body1" Class="mb-6 text-center" Style="max-width: 400px; color: var(--mud-palette-text-secondary) !important;">
                        Sorry, there's nothing at this address. The page might have been removed or the link might be broken.
                    </MudText>
                    <MudButton Href="/" Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large" Class="rounded-pill px-8">
                        <MudIcon Icon="@Icons.Material.Filled.Home" Class="mr-2" /> Return to Home
                    </MudButton>
                </div>
            </LayoutView>
        </CascadingAuthenticationState>
    </NotFound>
</Router>
@code
{
    private List<System.Reflection.Assembly> AdminAssembly = new()
        {           
            typeof(ArmsAdmin.Pages.User.UserHome).Assembly,            
        };


}
