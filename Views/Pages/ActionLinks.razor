@page "/action-links"
@layout Views.Shared.MainLayout
@inject NavigationManager nav

<AuthorizeView>
    <Authorized>
        <!-- Background Layer -->
        <div class="fixed-background-light" @key="@("bg-auth")">
            <div class="mesh-gradient"></div>
            <div class="pattern-overlay"></div>
        </div>

        <!-- Content Container -->
        <div class="dashboard-wrapper" @key="@("content-auth")">
             <!-- Main Grid Content -->
             <MudContainer MaxWidth="MaxWidth.False" Class="mt-12 py-4 px-8 flex-grow-1 d-flex flex-column justify-center relative z-10" Style="min-height: 85vh;">
                
                <!-- Header / Welcome Area -->
                <div class="d-flex flex-column align-center mb-8 header-animate">
                    <MudText Typo="Typo.h3" Class="mb-2" Style="font-weight: 800; color: #5E5873; text-transform: uppercase; letter-spacing: 2px;">
                        Quick<span style="color: #FF9F43;">Links</span>
                    </MudText>
                    <MudText Typo="Typo.h6" Class="fade-text" Style="color: #6E6B7B; opacity: 0.9; font-weight: 400;">Access your essential tools and reports</MudText>
                </div>

                <!-- Bento Grid -->
                <div class="bento-grid">
                    
                    <!-- Accounting / Transactions -->
                    <div class="white-card" @onclick="@(() => nav.NavigateTo("/billing-index"))">
                        <div class="card-bg"></div>
                         <div class="card-content">
                            <div class="icon-box"><MudIcon Icon="@Icons.Material.Filled.ReceiptLong" /></div>
                            <div class="card-text">
                                <div class="card-title">Transactions</div>
                                <div class="card-desc">Manage contracts, tariffs and generate invoices</div>
                            </div>
                        </div>
                    </div>
                    
                    <!-- QMS / Reports -->
                    <div class="white-card" @onclick="@(() => nav.NavigateTo("/reports-index"))">
                        <div class="card-bg"></div>
                        <div class="card-content">
                            <div class="icon-box"><MudIcon Icon="@Icons.Material.Filled.Analytics" /></div>
                            <div class="card-text">
                                <div class="card-title">Reports</div>
                                <div class="card-desc">Performance reports and data insights</div>
                            </div>
                        </div>
                    </div>

                    <!-- Return to Home -->
                    <div class="white-card" @onclick="@(() => nav.NavigateTo("/"))">
                        <div class="card-bg"></div>
                        <div class="card-content">
                            <div class="icon-box"><MudIcon Icon="@Icons.Material.Filled.Home" /></div>
                            <div class="card-text">
                                <div class="card-title">Home</div>
                                <div class="card-desc">Return to main dashboard</div>
                            </div>
                        </div>
                    </div>

                </div>
             </MudContainer>
        </div>
    </Authorized>
</AuthorizeView>

