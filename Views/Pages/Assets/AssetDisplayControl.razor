@using Views.Pages.Assets
@inject IDialogService DialogService
@inject NavigationManager _navigationManager
@inject IAssetService Iservice
@inject MudBlazor.ISnackbar snackbar

<MudPaper Outlined Class="pa-2">
     <MudGrid Justify="Justify.FlexEnd">
         <MudItem xs="1" md="1" Class="ia">
            @if (this.hasChildren)
            {
                <MudIconButton Icon="@btnIcon" @onclick="ToggleShow" Size="Size.Small" IconSize="Size.Small"></MudIconButton>
            }
        </MudItem>
        <MudItem xs="12" md="1">
            <MudText> @this.Model.Parent.AssetCode</MudText>
        </MudItem>
        <MudItem xs="12" md="2">
            <MudText> @this.Model.Parent.Description</MudText>
        </MudItem>
        <MudItem xs="12" md="2">
            <MudText> @this.Model.Parent.NatureOfAsset</MudText>
        </MudItem>
        <MudItem xs="12" md="2">
            <MudText> @this.Model.Parent.SerialNumber</MudText>
        </MudItem>
        <MudItem xs="12" md="2">
            <MudText> @(this.Model.Parent.IsComplex ? "Complex" : "Simple")</MudText>
        </MudItem>
        <MudItem xs="12" md="2">
            @if (this.Model.Parent.IsComplex)
            {
                <MudTooltip Text="Add Simple Assets">
                    <MudIconButton @onclick="@(()=> OpenDialogComplexAsset(this.Model.Parent))" Color="Color.Primary" Icon="@Icons.Material.Filled.Add" Size="Size.Small" IconSize="Size.Small" />
                </MudTooltip>
            }
            <MudTooltip Text="Edit">
                <MudIconButton @onclick="@(()=> EditComplexAsset(this.Model.Parent))" Color="Color.Primary" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" IconSize="Size.Small" />
            </MudTooltip>
            @if (this.Model.Parent.ParentAssetID == null)
            {
                <MudTooltip Text="Move Asset">
                    <MudIconButton @onclick="@(()=> MoveAsset(this.Model.Parent))" Color="Color.Primary" Icon="@Icons.Material.Filled.MoveUp" Size="Size.Small" IconSize="Size.Small" />
                </MudTooltip>
            }
            @if ((this.Model.Parent.ParentAssetID != null))
            {
                <MudTooltip Text="Remove Asset">
                    <MudIconButton @onclick="@(()=> RemoveAsset(this.Model.Parent))" Color="Color.Primary" Icon="@Icons.Material.Filled.Remove" Size="Size.Small" IconSize="Size.Small" />
                </MudTooltip>
            }
            @if ((this.Model.Parent != null))
            {
                <MudTooltip Text="Show Ledger Report">
                    <MudIconButton @onclick="@(()=> OpenAssetLedgerViews(this.Model.Parent))" Color="Color.Primary" Icon="@Icons.Material.Filled.TableView" Size="Size.Small" IconSize="Size.Small" />
                </MudTooltip>
            }
        </MudItem>
    </MudGrid>
</MudPaper>

@if (this.Show)
{
    @if (this.hasChildren)
    {
        @foreach (var child in this.Model.Children)
        {
            <MudGrid>
                <MudItem xs="1"></MudItem>
                <MudItem xs="11">
                    <AssetDisplayControl Model="child"></AssetDisplayControl>
                </MudItem>
            </MudGrid>
        }
    }
}

@code {

    [Parameter] 
    public AssetViewModel Model { get; set; }
    DialogOptions maxWidth = new DialogOptions() { MaxWidth = MaxWidth.Medium, FullWidth = true };
    private bool Show;
    private bool _busy;
    private string btnIcon = Icons.Material.Filled.ArrowDownward;

    private void ToggleShow()
    {
        this.Show = !this.Show;
        btnIcon = this.Show ? Icons.Material.Filled.ArrowUpward : Icons.Material.Filled.ArrowDownward;
    }

    private bool hasChildren => this.Model?.Children?.Count > 0;

    private string HeaderCols => this.hasChildren ? "col-11" : "col-12";

    private async Task OpenDialogComplexAsset(AssetModel tds)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }

        if (!tds.IsComplex)
        {
            snackbar.Add("Can not create asset under simple asset.", Severity.Error);
            return;
        }
        _busy = true;
        AssetModel assetModel = new AssetModel();
        assetModel.IsComplex = false;
        if (tds.AssetID != null)
        {
            assetModel.ParentAssetID = tds.AssetID;
        }
        DialogParameters parms = new DialogParameters();
        parms.Add("model", assetModel.Clone());
        var dialog = DialogService.Show<AssetSimpleDialog>(assetModel.AssetID == null ? "ADD" : "EDIT", parms, maxWidth);
        var result = await dialog.Result;
        if (!result.Canceled)
        {
            _navigationManager.NavigateTo("AssetSimpleView", true);
        }
        await Task.Delay(200);
        _busy = false;
    }

    private async Task EditComplexAsset(AssetModel tds)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        _busy = true;

        AssetModel assetModel = Iservice.SelectByID(tds?.AssetID ?? 0);
        if (assetModel != null && assetModel.SubClass != null && assetModel.SubClass.ID == null && assetModel.SubClass.AssetSubClassID != null)
        {
            assetModel.SubClass.ID = assetModel.SubClass.AssetSubClassID;
        }
        DialogParameters parms = new DialogParameters();
        parms.Add("model", assetModel.Clone());
        var dialog = DialogService.Show<AssetSimpleDialog>(assetModel.AssetID == null ? "ADD" : "EDIT", parms, maxWidth);
        var result = await dialog.Result;
        if (!result.Canceled)
        {
            _navigationManager.NavigateTo("AssetSimpleView", true);
        }
        await Task.Delay(200);
        _busy = false;
    }

    private async Task MoveAsset(AssetModel tds)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        _busy = true;

        DialogParameters parms = new DialogParameters();
        parms.Add("model", tds.Clone());
        var dialog = DialogService.Show<AssetMoveDialog>(tds.AssetID == null ? "ADD" : "EDIT", parms, maxWidth);
        var result = await dialog.Result;
        if (!result.Canceled)
        {
            _navigationManager.NavigateTo("AssetSimpleView", true);
        }
        await Task.Delay(200);
        _busy = false;
    }

    private async Task RemoveAsset(AssetModel tds)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        _busy = true;

        DialogParameters parms = new DialogParameters();
        parms.Add("model", tds.Clone());
        var dialog = DialogService.Show<AssetMoveDialog>(tds.AssetID == null ? "ADD" : "EDIT", parms, maxWidth);
        var result = await dialog.Result;
        if (!result.Cancelled)
        {
            _navigationManager.NavigateTo("AssetSimpleView", true);
        }
        await Task.Delay(200);
        _busy = false;
    }

    private void OpenAssetLedgerViews(AssetModel Asset)
    {
        if (Asset != null && Asset.AssetID != null)
        {
            _navigationManager.NavigateTo("/AssetLedgerView/" + Asset.AssetID.ToString());
        }
    }
}