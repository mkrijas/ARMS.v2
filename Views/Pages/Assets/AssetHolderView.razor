                    {
               <MudFab @onclick="@(()=> GetAccountDetails(context))" Color="Color.Info" StartIcon="@Icons.Material.Filled.CurrencyExchange" title="Accounts" Size="Size.Small" />
                    }*@
                    
                  
                    </MudTd>
            </RowTemplate>
            <PagerContent>
                <MudTablePager PageSizeOptions="new int[] { 5, 10, 20, 50, 100 }" />
            </PagerContent>
        </MudTable>
    </MudItem>
