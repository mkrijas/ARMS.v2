@page "/AssetHolderView"
@inject IAssetService Iservice
@inject IAssetClassService assetclassIservice
@inject IGstUsageIDService gstIservice
@inject IPartyService partyIservice
@inject MudBlazor.ISnackbar snackbar

@inject AuthenticationStateProvider auth
@attribute [Authorize]
@inject IDialogService DialogService


@if (_isLoading)
{
    <LoaderComponent IsFullScreen="true" 
                    ShowLogo="false" 
                    Size="medium" 
                    LoadingText="Loading Asset Holders" 
                    SubText="Please wait..." />
}

<div class="admin-page-container">
    <div class="admin-header-tiered mb-6">
        <div class="d-flex align-center justify-space-between">
            <div>
                <MudText Typo="Typo.h4" Class="admin-title">Asset Registry</MudText>
                <MudText Typo="Typo.body2" Class="admin-subtitle">Maintain records of asset holders and system-wide asset classifications.</MudText>
            </div>
            <MudButton StartIcon="@Icons.Material.Filled.Add" Variant="Variant.Filled" Color="Color.Primary" Class="admin-register-btn" OnClick="@(()=> OpenDialog(new AssetHolderModel()))">REGISTER ASSET</MudButton>
        </div>
    </div>

    <div class="admin-glass-card pa-0 overflow-hidden">
        <MudTable Items="@collection" Dense="true" Hover="true" Elevation="0" @bind-place="model" Class="modern-admin-table">
            <HeaderContent>
                <MudTh><MudTableSortLabel SortBy="new Func<AssetHolderModel, object>(x=> x.Description)" InitialDirection="SortDirection.Ascending"><span class="admin-header-text">DESCRIPTION</span></MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<AssetHolderModel, object>(x=> x.BranchID)" InitialDirection="SortDirection.Ascending"><span class="admin-header-text">BRANCH ID</span></MudTableSortLabel></MudTh>
                <MudTh Style="text-align: right;"><span class="admin-header-text">ACTIONS</span></MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Description"><MudText Typo="Typo.body2" Class="admin-td-primary">@context.Description</MudText></MudTd>
                <MudTd DataLabel="BranchID"><MudText Typo="Typo.body2" Class="admin-td-secondary">@context.BranchID</MudText></MudTd>
                <MudTd DataLabel="Actions" Style="text-align: right;">
                    <div class="d-flex justify-end gap-1">
                        <MudTooltip Text="Edit">
                            <MudIconButton OnClick="@(()=> OpenDialog(context))" Color="Color.Primary" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Variant="Variant.Text" />
                        </MudTooltip>
                    </div>
                </MudTd>
            </RowTemplate>
            <PagerContent>
                <div class="pa-4">
                    <MudTablePager PageSizeOptions="new int[] { 10, 20, 50, 100 }" />
                </div>
            </PagerContent>
        </MudTable>
    </div>
</div>


}


@code {

    private bool _isLoading = true;
    private DateTime _loadStartTime;
     private AssetHolderModel model = new AssetHolderModel();
    private List<AssetHolderModel> collection = new List<AssetHolderModel>();
    DialogOptions maxWidth = new DialogOptions() { MaxWidth = MaxWidth.Medium, FullWidth = true };
    protected override async Task OnInitializedAsync()
    {
        _loadStartTime = DateTime.Now;
        model = new();
        await GetAll();
        await EnsureMinimumLoadTime();
        _isLoading = false;
    }

    private async Task EnsureMinimumLoadTime()
    {
        var elapsed = (DateTime.Now - _loadStartTime).TotalMilliseconds;
        if (elapsed < 100)
        {
            await Task.Delay(100 - (int)elapsed);
        }
    }
      private  async Task GetAll()
    {
        var authprov = await auth.GetAuthenticationStateAsync();
        var brancIDString = authprov.User.Claims.First(x => x.Type == "BranchID").Value;
        int brancID = int.Parse(brancIDString);
        collection = new List<AssetHolderModel>();
        foreach (var item in Iservice.SelectByBranch(brancID))
        {
            collection.Add(item);
        }


    }  
     private async Task OpenDialog(AssetHolderModel tds)
    {
        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;
        
        DialogParameters parms = new DialogParameters();
        parms.Add("model",tds);
        var dialog = await DialogService.ShowAsync<AssetSimpleDialog>(tds.AssetHolderID == null?"ADD":"EDIT",parms,maxWidth);
        var result = await dialog.Result;

        if(!result.Canceled)
        {   

            GetAll();


        }
    }
}

