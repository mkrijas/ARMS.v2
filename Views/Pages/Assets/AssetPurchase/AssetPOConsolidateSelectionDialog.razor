@inject IAssetService iservice
@inject MudBlazor.ISnackbar snackbar
@inject IPartyService partyIservice
@inject ITdsRateService tdsService

<MudDialog Class="admin-dialog-glass">
    <TitleContent>
        <div class="admin-header-tiered px-8 pt-8 pb-4 text-center">
            <div class="admin-header-icon-badge mb-3 mx-auto">
                <MudIcon Icon="@Icons.Material.Filled.AddBusiness" Color="Color.Primary" Style="font-size: 3rem; color: #FF9F43 !important;" />
            </div>
            <MudText Typo="Typo.h5" Style="font-weight: 800; color: #141A46; letter-spacing: -0.5px;">Select Assets to Purchase</MudText>
            <MudText Typo="Typo.body2" Style="color: #667085; font-weight: 500;" Class="mt-1">Choose assets from the queue to initiate the purchase and invoicing process. Currently <b>@selectedItems?.Count</b> selected.</MudText>
            <div class="header-accent-divider mx-auto mt-4" style="background: linear-gradient(90deg, transparent, #FF9F43, transparent); width: 100%; height: 1px;"></div>
        </div>
    </TitleContent>
    <DialogContent>
        <div class="dialog-content-wrapper pa-4">
            <div class="modern-admin-table border rounded-xl overflow-hidden shadow-sm">
                <MudTable T="AssetModel" Items="@Asset" MultiSelection="true" @bind-SelectedItems="selectedItems" Hover="true" SelectOnRowClick Dense="true" Elevation="0">
                    <HeaderContent>
                        <MudTh><span class="admin-header-text">DESCRIPTION</span></MudTh>
                        <MudTh><span class="admin-header-text">ASSET CODE</span></MudTh>
                        <MudTh><span class="admin-header-text">BOOK VALUE</span></MudTh>
                        <MudTh><span class="admin-header-text">STATUS</span></MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="Description"><MudText Typo="Typo.body2" Style="font-weight: 600;">@context.Description</MudText></MudTd>
                        <MudTd DataLabel="AssetCode"><MudChip T="string" Size="Size.Small" Variant="Variant.Text" Color="Color.Primary" Style="font-weight: 700;">@context.AssetCode</MudChip></MudTd>
                        <MudTd DataLabel="BookValue"><MudText Typo="Typo.body2" Style="font-weight: 700; color: #FF9F43;">₹ @context.BookValue</MudText></MudTd>
                        <MudTd DataLabel="AssetStatus">@context.AssetStatus</MudTd>
                    </RowTemplate>
                </MudTable>
            </div>
        </div>
    </DialogContent>
    <DialogActions>
        <div class="px-8 pb-8 d-flex gap-4 w-100">
            <MudButton OnClick="@(()=> MudDialog.Cancel())" Variant="Variant.Outlined" FullWidth="true" Style="border-radius: 12px; height: 50px; font-weight: 700; color: #141A46; border: 2px solid #E2E8F0;">CANCEL</MudButton>
            <MudButton Disabled="@_busy" Variant="Variant.Filled" Color="Color.Primary" FullWidth="true" ButtonType="ButtonType.Button" OnClick="Submit" Style="background: #FF9F43; border-radius: 12px; height: 50px; font-weight: 700;">INITIATE PURCHASE</MudButton>
        </div>
    </DialogActions>
</MudDialog>


