@code {
    bool IsOpen = false;
    private TaxPurchaseModel model = new TaxPurchaseModel();
    private List<TaxPurchaseModel> collection = new List<TaxPurchaseModel>();
    private int numberOfRecords = 100;
    //private AssetPOModel model = new AssetPOModel();
    //private List<AssetPOModel> collection = new List<AssetPOModel>();
    //private List<AssetViewModel> assetView = new List<AssetViewModel>();

    DialogOptions maxWidth = new DialogOptions() { MaxWidth = MaxWidth.Large, FullWidth = true, CloseOnEscapeKey = true };
    private string searchTerm = "";
    int BranchID; string UserID;
    private bool _busy;
    public bool IsApproved { get; set; } = false;
    public int TaxPurchaseDocTypeID = 9;

    #region SignaIR Notification

    private PushNotificationModel notificationMessage = new PushNotificationModel();
    #endregion

    private async Task HandleSearchKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await GetAll(IsApproved, NumberOfRecords);
        }
    }

    private int NumberOfRecords
    {
        get => numberOfRecords;
        set
        {
            if (numberOfRecords != value)
            {
                numberOfRecords = value;
                _ = GetAll(IsApproved, NumberOfRecords);
            }
        }
    }

    protected override async Task OnInitializedAsync()
    {
        var authprov = await auth.GetAuthenticationStateAsync();
        BranchID = int.Parse(authprov.User.Claims.First(x => x.Type == "BranchID").Value);
        UserID = authprov.User.Identity.Name;
        GetAll(IsApproved, NumberOfRecords);
    }

    private async Task SelectAssets()
    {
        TaxPurchaseModel tds = new TaxPurchaseModel();
        DialogParameters parms = new DialogParameters();
        parms.Add("BranchID", BranchID);
        var dialog = DialogService.Show<AssetPOConsolidateSelectionDialog>("Asset Purchase", parms, maxWidth);
        var result = await dialog.Result;
        if (!result.Canceled)
        {
            var data = (List<AssetPOModel>)result.Data;

            AssetPurchaseModel PI = new AssetPurchaseModel()
                {
                    //TotalAmount = data.Sum(x => x.TotalAmount),
                    BranchID = BranchID,
                    UserInfo = new ArmsModels.SharedModels.UserInfoModel() { UserID = UserID },
                    SelectedAssets = data,
                };
            parms = new DialogParameters();
            parms.Add("model", model.Clone());
            //parms.Add("PageToRedirectLink", "/TaxPurchase");
            parms.Add("PI", PI);
            parms.Add("ReadOnly", false);
            var dialog2 = DialogService.Show<AssetPurchaseConsolidateDialog>("Asset Purchase", parms, maxWidth);
            var result2 = await dialog2.Result;
            if (!result2.Canceled)
            {
                var UpdatedPI = (TaxPurchaseModel)result2.Data;
                //IAssetService.Update(PI);
                GetAll(IsApproved, NumberOfRecords);
            }
        }
    }


    public async Task GetAll(bool val, int numberOfRecords)
    {
        // //collection = Iservice.PendingForCompletion(BranchID, searchTerm).ToList();
        // if (collection != null)
        // {
        //     collection.Clear();
        // }
        // Iservice.ClearAssets();
        // collection = Iservice.GetAssetList(BranchID, null, NumberOfRecords, searchTerm).ToList();
        var authprov = await auth.GetAuthenticationStateAsync();
        var brancIDString = authprov.User.Claims.First(x => x.Type == "BranchID").Value;
        int? brancID = int.Parse(brancIDString);
        int NumberOfRecords = numberOfRecords;

        if (val)
        {
            collection = Iservice1.SelectByApproved(brancID, NumberOfRecords, searchTerm, "Asset").ToList();
        }
        else
        {
            collection = Iservice1.SelectByUnapproved(brancID, NumberOfRecords, searchTerm, "Asset").ToList();
        }
        await Task.Delay(200);
    }

    public async void ViewAsset(AssetPOModel pim)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        _busy = true;
        // pim.Children = IAssetService.SelectInitiated(pim.AssetID).ToList();
        // DialogParameters parms = new DialogParameters();
        // parms.Add("PI", pim);
        // parms.Add("ReadOnly", true);
        // var dialog = DialogService.Show<PaymentConsolidateDialog>("Asset", parms, maxWidth);
        await Task.Delay(200);
        _busy = false;
    }

    private async Task OpenDialog(TaxPurchaseModel tds, bool ReadOnly, bool View)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        _busy = true;
        DialogParameters parms = new DialogParameters();
        parms.Add("model", tds.Clone());
        parms.Add("PageToRedirectLink", "/TaxPurchase");
        parms.Add("ReadOnly", ReadOnly);
        // var dialog = DialogService.Show<TaxPurchaseDialog>(tds.PID == null ? "ADD" : "EDIT", parms, maxWidth);
        var dialog = DialogService.Show<AssetTaxPurchaseDialog>(tds.PID == null ? "ADD" : "VIEW", parms, maxWidth);
        var result = await dialog.Result;
        var isCancelled = result.Cancelled;
        if (!isCancelled)
        {
            var ReturnData = (TaxPurchaseModel)result.Data;
            notificationMessage.InitiateBranch = new BranchModel() { BranchID = ReturnData.BranchID };
            notificationMessage.ReceivedBranch = new BranchModel() { BranchID = ReturnData.BranchID };
            notificationMessage.MessageTitle = IpushNotificationService.GetMessageTitle(ReturnData.NatureOfTransaction, ReturnData.DocumentNumber, "Level 1 Verification");
            notificationMessage.MessageBody = IpushNotificationService.GetMessageBody(ReturnData.NatureOfTransaction, ReturnData.DocumentNumber, "Level 1 Verification", ReturnData.DocumentDate);
            notificationMessage.RedirectedTo = 0;
            notificationMessage.ExpiredBy = 7;
            notificationMessage.DocumentID = ReturnData.PID;
            notificationMessage.MessageGroupID = "PendingVerification";
            notificationMessage.PageToRedirectLink = "/TaxPurchase";
            notificationMessage.ClaimValue = "Verify 1";
            notificationMessage.DocumentTypeID = TaxPurchaseDocTypeID;
            notificationMessage.MsgDate = DateTime.Now;
            await signalRService.Send(notificationMessage);
        }
        await GetAll(IsApproved, NumberOfRecords);
        await Task.Delay(200);
        _busy = false;
    }
}
