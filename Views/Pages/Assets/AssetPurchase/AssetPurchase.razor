@code {
    bool IsOpen = false;
    private TaxPurchaseModel model = new TaxPurchaseModel();
    private List<TaxPurchaseModel> collection = new List<TaxPurchaseModel>();
    private int numberOfRecords = 100;

    [Parameter]
    public int? id { get; set; } = null;

    DialogOptions maxWidth = new DialogOptions() { MaxWidth = MaxWidth.Large, FullWidth = true, CloseOnEscapeKey = true };
    private string searchTerm = "";
    int BranchID; string UserID;
    private bool _busy;
    public bool IsApproved { get; set; } = false;

    public bool DeletePermission { get; set; } = false;
    public bool EditPermission { get; set; } = false;
    public bool ViewPermission { get; set; } = false;
    public int DocTypeID = 117;

    #region SignaIR Notification

    private PushNotificationModel notificationMessage = new PushNotificationModel();
    #endregion

    // Method to handle key up event for search input
    private async Task HandleSearchKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await GetAll(IsApproved, NumberOfRecords);
        }
    }

    private int NumberOfRecords
    {
        get => numberOfRecords;
        set
        {
            if (numberOfRecords != value)
            {
                numberOfRecords = value;
                _ = GetAll(IsApproved, NumberOfRecords);
            }
        }
    }

    // Method to toggle the approved entries filter
    async Task ApprovedToggled(bool value)
    {
        IsApproved = value;
        await GetAll(IsApproved, NumberOfRecords);
    }

    // Method to initialize the component
    protected override async Task OnInitializedAsync()
    {
        CancellationTokenSource ctc = new CancellationTokenSource();
        DeletePermission = await Irole.HasClaim(DocTypeID.ToString(), "Delete", ctc.Token);
        EditPermission = await Irole.HasClaim(DocTypeID.ToString(), "Edit", ctc.Token);
        ViewPermission = await Irole.HasClaim(DocTypeID.ToString(), "View", ctc.Token);
        var authprov = await auth.GetAuthenticationStateAsync();
        BranchID = int.Parse(authprov.User.Claims.First(x => x.Type == "BranchID").Value);
        UserID = authprov.User.Identity.Name;
        await GetAll(IsApproved, NumberOfRecords);

        if (id != null && collection != null && collection.Any(g => g.PID == id))
        {
            await Edit(collection.FirstOrDefault(s => s.PID == id), true, true);
        }
    }

    // Method to select assets for purchase
    private async Task SelectAssets()
    {
        if (EditPermission)
        {
            TaxPurchaseModel tds = new TaxPurchaseModel();
            DialogParameters parms = new DialogParameters();
            parms.Add("BranchID", BranchID);
            var dialog = DialogService.Show<AssetPOConsolidateSelectionDialog>("Asset Purchase", parms, maxWidth);
            var result = await dialog.Result;
            if (!result.Canceled)
            {
                var data = (List<AssetModel>)result.Data;
                AssetPurchaseModel PI = new AssetPurchaseModel()
                    {
                        BranchID = BranchID,
                        UserInfo = new ArmsModels.SharedModels.UserInfoModel() { UserID = UserID },
                        SelectedAssets = new(),
                    };
                foreach(var item in data)
                {
                    var AssetPO = new AssetPOModel();
                    AssetPO.CoaID = item.AssetStatus == "WIP" ? Iservice.GetCWIPCoaID(item.AssetID) : Iservice.GetCapitalizationCoaID(item.AssetID);
                    AssetPO.SubARDCode = item.AssetStatus == "WIP" ? "ASTCWIP" : "ASTCAP";
                    AssetPO.AccountName = accountService.SelectByID(AssetPO.CoaID).AccountName;
                    AssetPO.AssetID = item.AssetID;
                    AssetPO.AssetCode = item.AssetCode;
                    AssetPO.AssetStatus = item.AssetStatus;
                    AssetPO.TaxRate = item.TaxRate;
                    AssetPO.BookValue = item.BookValue;
                    AssetPO.BranchID = item.BranchID;
                    AssetPO.GstMechanism = item.GstMechanism;
                    AssetPO.Description = item.Description;
                    AssetPO.GSTValue = item.GSTValue;
                    AssetPO.PID = item.PID;
                    PI.SelectedAssets.Add(AssetPO);
                }

                
                
                parms = new DialogParameters();
                parms.Add("model", model.Clone());
                parms.Add("PI", PI);
                parms.Add("ReadOnly", false);
                var dialog2 = DialogService.Show<AssetPurchaseConsolidateDialog>("Asset Purchase", parms, maxWidth);
                var result2 = await dialog2.Result;
                if (!result2.Canceled)
                {
                    var ResultData = (TaxPurchaseModel)result2.Data;
                    IpushNotificationService.CreateAuthNotifications(BranchID, DocTypeID, ResultData.PID.Value);
                    await GetAll(IsApproved, NumberOfRecords);
                }
            }

        }
        else
        {
            bool? result = await DialogService.ShowMessageBox(
            "Permission denied!",
            "You don't have any permission to Create AssetPurchase.");
        }
    }

    // Method to get all asset purchases
    public async Task GetAll(bool val, int numberOfRecords)
    {

        var authprov = await auth.GetAuthenticationStateAsync();
        var brancIDString = authprov.User.Claims.First(x => x.Type == "BranchID").Value;
        int? brancID = int.Parse(brancIDString);
        int NumberOfRecords = numberOfRecords;

        if (val)
        {
            collection = Iservice1.SelectByApproved(brancID, NumberOfRecords, searchTerm, "Asset", "").ToList();
        }
        else
        {
            collection = Iservice1.SelectByUnapproved(brancID, NumberOfRecords, searchTerm, "Asset","").ToList();
        }
        await Task.Delay(200);
    }

    // Method to view asset details
    public async void ViewAsset(AssetPOModel pim)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        _busy = true;
        // pim.Children = IAssetService.SelectInitiated(pim.AssetID).ToList();
        // DialogParameters parms = new DialogParameters();
        // parms.Add("PI", pim);
        // parms.Add("ReadOnly", true);
        // var dialog = DialogService.Show<PaymentConsolidateDialog>("Asset", parms, maxWidth);
        await Task.Delay(200);
        _busy = false;
    }

    // Method to edit an asset purchase
    private async Task Edit(TaxPurchaseModel tds, bool ReadOnly, bool View)
    {
        if (ViewPermission)
        {
            if (_busy)
            {
                snackbar.Add("Please wait while form is closing!", Severity.Warning);
                return;
            }
            _busy = true;
            DialogParameters parms = new DialogParameters();
            parms.Add("model", tds.Clone());
            parms.Add("PageToRedirectLink", "/TaxPurchase");
            parms.Add("ReadOnly", ReadOnly);

            var dialog = DialogService.Show<AssetTaxPurchaseDialog>(tds.PID == null ? "ADD" : "EDIT", parms, maxWidth);
            var result = await dialog.Result;

            if (!result.Canceled)
            {
                var ResultData = (TaxPurchaseModel)result.Data;

            }
            await GetAll(IsApproved, NumberOfRecords);
            await Task.Delay(200);
            _busy = false;
        }
        else
        {
            bool? result = await DialogService.ShowMessageBox(
                "Permission denied!",
                "You don't have any permission to View AssetPurchase.");
        }
    }

    // Method to delete an asset purchase
    private async Task Delete(TaxPurchaseModel model)
    {
        if (DeletePermission)
        {
            bool? result = await DialogService.ShowMessageBox(
                "Warning !",
                "Are you sure, you want to delete - " + model.InvoiceNo + " (" + model.InvoiceDate + ") ?");
            if (result == true)
            {
                var authprov = await auth.GetAuthenticationStateAsync();
                var user = authprov.User;
                Iservice1.Delete(model.PID, user.Identity.Name);
                IpushNotificationService.CancelAuthNotifications(DocTypeID, model.PID.Value);
                snackbar.Add("Deleted Successfully", Severity.Success);
            }
            await GetAll(IsApproved, NumberOfRecords);
        }
        else
        {
            bool? result = await DialogService.ShowMessageBox(
                "Permission denied!",
                "You don't have any permission to Delete TaxPurchase.");
        }
    }
}
