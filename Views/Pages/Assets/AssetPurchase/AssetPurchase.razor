@page "/AssetPurchaseOrder"
@inject IAssetService Iservice
@inject IAssetClassService assetclassIservice
@inject IGstUsageIDService gstIservice
@inject IPartyService partyIservice
@inject MudBlazor.ISnackbar snackbar
@inject NavigationManager _navigationManager
@inject AuthenticationStateProvider auth
@attribute [Authorize]
@inject IDialogService DialogService


<MudGrid Spacing="4">
    <MudItem xs="12">
        <MudTable Items="@collection" Dense="true" Hover="true" Striped="true" Elevation="10">
            <ToolBarContent>
                <MudText Typo="Typo.h6">Asset Purchase</MudText>
                <MudTooltip Text="Asset PO">
                    <MudIconButton Disabled="@_busy" Icon="@Icons.Material.Filled.Add" Title="Add" @onclick="@(()=> SelectAssets())" Color="Color.Dark" Size="Size.Small"></MudIconButton>
                </MudTooltip>
                <MudSpacer></MudSpacer>
                <MudTextField @bind-Value="searchTerm" Placeholder="Search Assets..." Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0" @onkeyup="HandleSearchKeyUp">
                </MudTextField>
                <MudTextField Class="pt-3" @bind-Value="@NumberOfRecords" Variant="Variant.Outlined" Margin="Margin.Dense" Style="width: 80px;"></MudTextField>

            </ToolBarContent>
            <HeaderContent>
                <MudTh><MudTableSortLabel SortBy="new Func<AssetModel, object>(x=> x.Description)" InitialDirection="SortDirection.Ascending">Description</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<AssetModel, object>(x=> x.NatureOfAsset)" InitialDirection="SortDirection.Ascending">Nature Of Asset</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<AssetModel, object>(x=> x.SerialNumber)" InitialDirection="SortDirection.Ascending">Serial Number</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<AssetModel, object>(x=> x.IsComplex)" InitialDirection="SortDirection.Ascending">Simple/Complex</MudTableSortLabel></MudTh>
                <MudTh>Actions</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Description">@context.Description</MudTd>
                    <MudTd DataLabel="NatureOfAsset">@context.NatureOfAsset</MudTd>
                    <MudTd DataLabel="SerialNumber">@context.SerialNumber</MudTd>
                    <MudTd DataLabel="@(context.IsComplex ? "Complex" : "Simple")">
                        @if (context.IsComplex)
                    {
                        <div>Complex</div>
                    }
                    else
                    {
                        <div>Simple</div>
                    }
                </MudTd>

                <MudTooltip Text="View">
                    <MudFab @onclick="@(()=> ViewAsset(context))" Color="Color.Primary" Title="View asset" Icon="@Icons.Material.Filled.Fullscreen" Size="Size.Small" IconSize="Size.Small" />
                </MudTooltip>

            </RowTemplate>
            <PagerContent>
                <MudTablePager PageSizeOptions="new int[] { 5, 10, 20, 50, 100 }" />
            </PagerContent>
        </MudTable>

    </MudItem>
</MudGrid>



@code {
    bool IsOpen = false;

    private int numberOfRecords = 100;
    private AssetModel model = new AssetModel();
    private List<AssetModel> collection = new List<AssetModel>();
    private List<AssetViewModel> assetView = new List<AssetViewModel>();

    DialogOptions maxWidth = new DialogOptions() { MaxWidth = MaxWidth.Large, FullWidth = true, CloseOnEscapeKey = true };
    private string searchTerm = "";
    int BranchID; string UserID;
    private bool _busy;

    private async Task HandleSearchKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await GetAll();
        }
    }

    private int NumberOfRecords
    {
        get => numberOfRecords;
        set
        {
            if (numberOfRecords != value)
            {
                numberOfRecords = value;
                _ = GetAll();
            }
        }
    }

    protected override async Task OnInitializedAsync()
    {
        var authprov = await auth.GetAuthenticationStateAsync();
        BranchID = int.Parse(authprov.User.Claims.First(x => x.Type == "BranchID").Value);
        UserID = authprov.User.Identity.Name;
        GetAll();
    }

    private async Task SelectAssets()
    {
        TaxPurchaseModel tds = new TaxPurchaseModel();
        DialogParameters parms = new DialogParameters();
        parms.Add("BranchID", BranchID);
        var dialog = DialogService.Show<AssetPOConsolidateSelectionDialog>("Asset Purchase", parms, maxWidth);
        var result = await dialog.Result;
        if (!result.Canceled)
        {
            var data = (List<AssetModel>)result.Data;

            AssetPurchaseModel PI = new AssetPurchaseModel()
                {
                    //TotalAmount = data.Sum(x => x.TotalAmount),
                    BranchID = BranchID,
                    UserInfo = new ArmsModels.SharedModels.UserInfoModel() { UserID = UserID },
                    SelectedAssets = data,
                };
            parms = new DialogParameters();
            parms.Add("model", tds.Clone());
            //parms.Add("PageToRedirectLink", "/TaxPurchase");
            parms.Add("PI", PI);
            parms.Add("ReadOnly", false);
            var dialog2 = DialogService.Show<AssetPurchaseConsolidateDialog>("Asset Purchase", parms, maxWidth);
            var result2 = await dialog2.Result;
            if (!result2.Canceled)
            {
                var UpdatedPI = (AssetPurchaseModel)result2.Data;
                //IAssetService.Update(PI);
                GetAll();
            }
        }
    }


    public async Task GetAll()
    {
        //collection = Iservice.PendingForCompletion(BranchID, searchTerm).ToList();
        if (collection != null)
        {
            collection.Clear();
        }
        Iservice.ClearAssets();
        collection = Iservice.GetAssetList(BranchID, null, NumberOfRecords, searchTerm).ToList();
    }

    public async void ViewAsset(AssetModel pim)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        _busy = true;
        // pim.Children = IAssetService.SelectInitiated(pim.AssetID).ToList();
        // DialogParameters parms = new DialogParameters();
        // parms.Add("PI", pim);
        // parms.Add("ReadOnly", true);
        // var dialog = DialogService.Show<PaymentConsolidateDialog>("Asset", parms, maxWidth);
        await Task.Delay(200);
        _busy = false;
    }
}
