@page "/AssetPurchase"
@page "/AssetPurchase/{id:int}"
@using System.Threading
@using Views.Pages.Finance.Transactions.PurchaseAndPayment
@inject IAssetService Iservice
@inject IAssetClassService assetclassIservice
@inject IGstUsageIDService gstIservice
@inject IPartyService partyIservice
@inject MudBlazor.ISnackbar snackbar
@inject NavigationManager _navigationManager
@inject AuthenticationStateProvider auth
@attribute [Authorize]
@inject IDialogService DialogService
@inject ITaxPurchaseService Iservice1
@inject SignalRService signalRService
@inject IPushNotificationService IpushNotificationService
@inject IRoleService<RoleModel> Irole
@inject IChartOfAccountService accountService

<div class="admin-page-container pa-6">
    <div class="admin-header-tiered mb-6">
        <div class="d-flex align-center justify-space-between">
            <div>
                <MudText Typo="Typo.h4" Style="font-weight: 800; color: #141A46; letter-spacing: -1px;">Asset Purchase</MudText>
                <MudText Typo="Typo.body2" Style="color: #667085; font-weight: 500;">Manage capitalization, CWIP, and tax-inclusive asset acquisition records.</MudText>
            </div>
            <MudButton StartIcon="@Icons.Material.Filled.AddBusiness" Variant="Variant.Filled" Color="Color.Primary" Style="background: #FF9F43; border-radius: 12px; height: 48px; font-weight: 700;" OnClick="@(()=> SelectAssets())" Disabled="@_busy">REGISTER PURCHASE</MudButton>
        </div>
    </div>

    <div class="admin-glass-card pa-0 overflow-hidden">
        <MudTable Items="@collection" Dense="true" Hover="true" Elevation="0" Class="modern-admin-table" @bind-SearchString="searchTerm">
            <ToolBarContent>
                <div class="d-flex align-center gap-4 w-100 px-4 py-2">
                    <MudTextField @bind-Value="searchTerm" Placeholder="Search by Invoice or Document No..." Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Variant="Variant.Outlined" Margin="Margin.Dense" Class="admin-input-group flex-grow-1" @onkeyup="HandleSearchKeyUp" Clearable />
                    <MudSelect T="int" @bind-Value="@NumberOfRecords" Label="Limit" Variant="Variant.Outlined" Margin="Margin.Dense" Style="width: 100px;" Class="admin-input-group">
                        <MudSelectItem Value="10">10</MudSelectItem>
                        <MudSelectItem Value="50">50</MudSelectItem>
                        <MudSelectItem Value="100">100</MudSelectItem>
                        <MudSelectItem Value="500">500</MudSelectItem>
                    </MudSelect>
                    <div class="d-flex align-center px-4 py-1 rounded-lg" style="background: rgba(255, 159, 67, 0.05); border: 1px solid rgba(255, 159, 67, 0.1);">
                        <MudCheckBox Label="Show Approved" ValueChanged="((bool value)=>ApprovedToggled(value))" Value="@IsApproved" Size="Size.Small" Color="Color.Primary" UncheckedColor="Color.Default" T="bool" />
                    </div>
                </div>
            </ToolBarContent>
            <HeaderContent>
                <MudTh><span class="admin-header-text">INVOICE DATE</span></MudTh>
                <MudTh><span class="admin-header-text">INVOICE NO</span></MudTh>
                <MudTh><span class="admin-header-text">DOC DATE</span></MudTh>
                <MudTh><span class="admin-header-text">DOC NO</span></MudTh>
                <MudTh><span class="admin-header-text">TOTAL AMOUNT</span></MudTh>
                <MudTh><span class="admin-header-text">STATUS</span></MudTh>
                <MudTh Style="text-align: right;"><span class="admin-header-text">ACTIONS</span></MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="InvoiceDate">
                    <div class="d-flex flex-column">
                        <MudText Typo="Typo.body2" Style="font-weight: 700; color: #141A46;">@context.InvoiceDate?.ToString("dd MMM yyyy")</MudText>
                    </div>
                </MudTd>
                <MudTd DataLabel="InvoiceNo">
                    <MudChip T="string" Size="Size.Small" Variant="Variant.Text" Color="Color.Primary" Style="font-weight: 700;">@context.InvoiceNo</MudChip>
                </MudTd>
                <MudTd DataLabel="DocumentDate">@context.DocumentDate?.ToString("dd/MM/yyyy")</MudTd>
                <MudTd DataLabel="DocumentNumber">
                    <div class="d-flex align-center gap-2">
                        <MudText Typo="Typo.body2" Style="font-weight: 600;">@context.DocumentNumber</MudText>
                        @if (context.AuthLevelId == 100)
                        {
                            <MudChip T="string" Size="Size.Small" Color="Color.Error" Variant="Variant.Filled" Style="font-size: 0.7rem; height: 20px;">REJECTED</MudChip>
                        }
                    </div>
                </MudTd>
                <MudTd DataLabel="TotalAmount">
                    <MudText Typo="Typo.body2" Style="font-weight: 800; color: #FF9F43;">₹ @context.TotalAmount?.ToString("N2")</MudText>
                </MudTd>
                <MudTd DataLabel="Status">
                    @if (context.AuthLevelId == 99)
                    {
                        <MudChip T="string" Size="Size.Small" Color="Color.Success" Variant="Variant.Text" Icon="@Icons.Material.Filled.Verified" Style="font-weight: 700;">APPROVED</MudChip>
                    }
                    else if (context.AuthLevelId == 100)
                    {
                        <MudChip T="string" Size="Size.Small" Color="Color.Error" Variant="Variant.Text" Icon="@Icons.Material.Filled.Error" Style="font-weight: 700;">REJECTED</MudChip>
                    }
                    else
                    {
                        <MudChip T="string" Size="Size.Small" Color="Color.Warning" Variant="Variant.Text" Icon="@Icons.Material.Filled.Pending" Style="font-weight: 700;">PENDING</MudChip>
                    }
                </MudTd>
                <MudTd DataLabel="Actions" Style="text-align: right;">
                    <div class="d-flex justify-end gap-1">
                        <MudTooltip Text="View Details">
                            <MudIconButton OnClick="@(()=> Edit(context,true,false))" Color="Color.Info" Icon="@Icons.Material.Filled.Visibility" Size="Size.Small" Variant="Variant.Text" />
                        </MudTooltip>
                        @if (context.AuthLevelId == null || context.AuthLevelId == 100)
                        {
                            <MudTooltip Text="Edit Entry">
                                <MudIconButton OnClick="@(()=> Edit(context,false,false))" Color="Color.Primary" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Variant="Variant.Text" />
                            </MudTooltip>
                            <MudTooltip Text="Delete Entry">
                                <MudIconButton OnClick="@(()=> Delete(context))" Color="Color.Error" Icon="@Icons.Material.Filled.DeleteOutline" Size="Size.Small" Variant="Variant.Text" />
                            </MudTooltip>
                        }
                        @if (context.AuthLevelId != 99 && context.AuthLevelId != 100)
                        {
                            <MudTooltip Text="Verify & Approve">
                                <MudIconButton OnClick="@(()=> Edit(context,true,false))" Color="Color.Warning" Icon="@Icons.Material.Filled.Gavel" Size="Size.Small" Variant="Variant.Text" />
                            </MudTooltip>
                        }
                    </div>
                </MudTd>
            </RowTemplate>
            <PagerContent>
                <div class="px-6 py-4">
                    <MudTablePager PageSizeOptions="new int[] { 10, 20, 50, 100 }" />
                </div>
            </PagerContent>
        </MudTable>
    </div>
</div>



@code {
    bool IsOpen = false;
    private TaxPurchaseModel model = new TaxPurchaseModel();
    private List<TaxPurchaseModel> collection = new List<TaxPurchaseModel>();
    private int numberOfRecords = 100;

    [Parameter]
    public int? id { get; set; } = null;

    DialogOptions maxWidth = new DialogOptions() { MaxWidth = MaxWidth.Large, FullWidth = true, CloseOnEscapeKey = true };
    private string searchTerm = "";
    int BranchID; string UserID;
    private bool _busy;
    public bool IsApproved { get; set; } = false;

    public bool DeletePermission { get; set; } = false;
    public bool EditPermission { get; set; } = false;
    public bool ViewPermission { get; set; } = false;
    public int DocTypeID = 117;

    #region SignaIR Notification

    private PushNotificationModel notificationMessage = new PushNotificationModel();
    #endregion

    // Method to handle key up event for search input
    private async Task HandleSearchKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await GetAll(IsApproved, NumberOfRecords);
        }
    }

    private int NumberOfRecords
    {
        get => numberOfRecords;
        set
        {
            if (numberOfRecords != value)
            {
                numberOfRecords = value;
                _ = GetAll(IsApproved, NumberOfRecords);
            }
        }
    }

    // Method to toggle the approved entries filter
    async Task ApprovedToggled(bool value)
    {
        IsApproved = value;
        await GetAll(IsApproved, NumberOfRecords);
    }

    // Method to initialize the component
    protected override async Task OnInitializedAsync()
    {
        var authprov = await auth.GetAuthenticationStateAsync();
        BranchID = int.Parse(authprov.User.Claims.First(x => x.Type == "BranchID").Value);
        UserID = authprov.User.Identity.Name;
        await GetAll(IsApproved, NumberOfRecords);

        if (id != null && collection != null && collection.Any(g => g.PID == id))
        {
            await Edit(collection.FirstOrDefault(s => s.PID == id), true, true);
        }
    }

    // Permissions are checked here (after first render) because Blazor prerendering
    // returns an unauthenticated state in OnInitializedAsync — claims are only
    // available once the SignalR circuit is fully established.
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            CancellationTokenSource ctc = new CancellationTokenSource();
            DeletePermission = await Irole.HasClaim(DocTypeID.ToString(), "Delete", ctc.Token);
            EditPermission = await Irole.HasClaim(DocTypeID.ToString(), "Edit", ctc.Token);
            ViewPermission = await Irole.HasClaim(DocTypeID.ToString(), "View", ctc.Token);
            StateHasChanged();
        }
    }

    // Method to select assets for purchase
    private async Task SelectAssets()
    {
        if (EditPermission)
        {
            TaxPurchaseModel tds = new TaxPurchaseModel();
            DialogParameters parms = new DialogParameters();
            parms.Add("BranchID", BranchID);
            var dialog = DialogService.Show<AssetPOConsolidateSelectionDialog>("Asset Purchase", parms, maxWidth);
            var result = await dialog.Result;
            if (!result.Canceled)
            {
                var data = (List<AssetModel>)result.Data;
                AssetPurchaseModel PI = new AssetPurchaseModel()
                    {
                        BranchID = BranchID,
                        UserInfo = new ArmsModels.SharedModels.UserInfoModel() { UserID = UserID },
                        SelectedAssets = new(),
                    };
                foreach(var item in data)
                {
                    var AssetPO = new AssetPOModel();
                    AssetPO.CoaID = item.AssetStatus == "WIP" ? Iservice.GetCWIPCoaID(item.AssetID) : Iservice.GetCapitalizationCoaID(item.AssetID);
                    AssetPO.SubARDCode = item.AssetStatus == "WIP" ? "ASTCWIP" : "ASTCAP";
                    AssetPO.AccountName = accountService.SelectByID(AssetPO.CoaID).AccountName;
                    AssetPO.AssetID = item.AssetID;
                    AssetPO.AssetCode = item.AssetCode;
                    AssetPO.AssetStatus = item.AssetStatus;
                    AssetPO.TaxRate = item.TaxRate;
                    AssetPO.BookValue = item.BookValue;
                    AssetPO.BranchID = item.BranchID;
                    AssetPO.GstMechanism = item.GstMechanism;
                    AssetPO.Description = item.Description;
                    AssetPO.GSTValue = item.GSTValue;
                    AssetPO.PID = item.PID;
                    PI.SelectedAssets.Add(AssetPO);
                }

                
                
                parms = new DialogParameters();
                parms.Add("model", model.Clone());
                parms.Add("PI", PI);
                parms.Add("ReadOnly", false);
                var dialog2 = DialogService.Show<AssetPurchaseConsolidateDialog>("Asset Purchase", parms, maxWidth);
                var result2 = await dialog2.Result;
                if (!result2.Canceled)
                {
                    var ResultData = (TaxPurchaseModel)result2.Data;
                    IpushNotificationService.CreateAuthNotifications(BranchID, DocTypeID, ResultData.PID.Value);
                    await GetAll(IsApproved, NumberOfRecords);
                }
            }

        }
        else
        {
            bool? result = await DialogService.ShowMessageBox(
            "Permission denied!",
            "You don't have any permission to Create AssetPurchase.");
        }
    }

    // Method to get all asset purchases
    public async Task GetAll(bool val, int numberOfRecords)
    {

        var authprov = await auth.GetAuthenticationStateAsync();
        var brancIDString = authprov.User.Claims.First(x => x.Type == "BranchID").Value;
        int? brancID = int.Parse(brancIDString);
        int NumberOfRecords = numberOfRecords;

        if (val)
        {
            collection = Iservice1.SelectByApproved(brancID, NumberOfRecords, searchTerm, "Asset", "").ToList();
        }
        else
        {
            collection = Iservice1.SelectByUnapproved(brancID, NumberOfRecords, searchTerm, "Asset","").ToList();
        }
        await Task.Delay(200);
    }

    // Method to view asset details
    public async void ViewAsset(AssetPOModel pim)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        _busy = true;
        // pim.Children = IAssetService.SelectInitiated(pim.AssetID).ToList();
        // DialogParameters parms = new DialogParameters();
        // parms.Add("PI", pim);
        // parms.Add("ReadOnly", true);
        // var dialog = DialogService.Show<PaymentConsolidateDialog>("Asset", parms, maxWidth);
        await Task.Delay(200);
        _busy = false;
    }

    // Method to edit an asset purchase
    private async Task Edit(TaxPurchaseModel tds, bool ReadOnly, bool View)
    {
        if (ViewPermission)
        {
            if (_busy)
            {
                snackbar.Add("Please wait while form is closing!", Severity.Warning);
                return;
            }
            _busy = true;
            DialogParameters parms = new DialogParameters();
            parms.Add("model", tds.Clone());
            parms.Add("PageToRedirectLink", "/TaxPurchase");
            parms.Add("ReadOnly", ReadOnly);

            var dialog = DialogService.Show<AssetTaxPurchaseDialog>(tds.PID == null ? "ADD" : "EDIT", parms, maxWidth);
            var result = await dialog.Result;

            if (!result.Canceled)
            {
                var ResultData = (TaxPurchaseModel)result.Data;

            }
            await GetAll(IsApproved, NumberOfRecords);
            await Task.Delay(200);
            _busy = false;
        }
        else
        {
            bool? result = await DialogService.ShowMessageBox(
                "Permission denied!",
                "You don't have any permission to View AssetPurchase.");
        }
    }

    // Method to delete an asset purchase
    private async Task Delete(TaxPurchaseModel model)
    {
        if (DeletePermission)
        {
            bool? result = await DialogService.ShowMessageBox(
                "Warning !",
                "Are you sure, you want to delete - " + model.InvoiceNo + " (" + model.InvoiceDate + ") ?");
            if (result == true)
            {
                var authprov = await auth.GetAuthenticationStateAsync();
                var user = authprov.User;
                Iservice1.Delete(model.PID, user.Identity.Name);
                IpushNotificationService.CancelAuthNotifications(DocTypeID, model.PID.Value);
                snackbar.Add("Deleted Successfully", Severity.Success);
            }
            await GetAll(IsApproved, NumberOfRecords);
        }
        else
        {
            bool? result = await DialogService.ShowMessageBox(
                "Permission denied!",
                "You don't have any permission to Delete TaxPurchase.");
        }
    }
}

