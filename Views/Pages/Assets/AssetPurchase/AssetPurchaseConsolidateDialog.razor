@attribute [Authorize]
@using System.Threading;

@inject AuthenticationStateProvider auth
@inject IAssetService iservice
@inject MudBlazor.ISnackbar snackbar
@inject AuthenticationStateProvider auth
@using System.Text;
@using Views.Pages.Finance.Transactions
@inject IJSRuntime JSRuntime
@inject IPartyService partyIservice
@inject IRoleService<RoleModel> Irole
@inject ITaxPurchaseService Iservice
@inject IDialogService DialogService
@inject ITdsRateService tdsService
@inject IPushNotificationService notiService


<DialogForm @ref="@dialogForm" ReadOnly="@ReadOnly" Title="Asset Purchase Consolidation" Subtitle="Consolidate multiple asset records into a single purchase invoice with shared tax attributes." Icon="@Icons.Material.Filled.LibraryAdd" AdminStyle="true" formID="formAssetPurchase" DocumentDetails="DocumentDetails" model="@model" _busy="_busy">
    <FormContent>
        <div class="dialog-content-wrapper">
             @if (editContext != null)
            {
                <EditForm id="formAssetPurchase" OnValidSubmit="OnValidSubmit" EditContext="editContext" autocomplete="off">
                    <ObjectGraphDataAnnotationsValidator />
                    
                    <div class="admin-glass-card pa-6 mb-6">
                        <span class="admin-section-label">Vendor & Timeline</span>
                        <MudGrid Spacing="3">
                            <MudItem xs="12" md="4">
                                <MudDatePicker ReadOnly="ReadOnly" Label="Document Date" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.DocumentDate)" DisableToolbar="true" Editable="true" @bind-Date="model.DocumentDate" DateFormat="dd/MM/yyyy" Class="admin-input-group" />
                            </MudItem>
                            <MudItem xs="12" md="8">
                                <PartySelector Value="model.PartyInfo" For="@(()=> model.PartyInfo)" ValueChanged="PartyChanged" NatureOfBusiness="Supplier" BranchID="@branchID" Class="admin-input-group"></PartySelector>
                            </MudItem>
                            <MudItem xs="12" md="4">
                                <MudDatePicker ReadOnly="ReadOnly" Label="Invoice Date" Variant="Variant.Outlined" Margin="Margin.Dense" DisableToolbar="true" Editable="true" DateFormat="dd/MM/yyyy" @bind-Date="model.InvoiceDate" For="@(() => model.InvoiceDate)" Class="admin-input-group" />
                            </MudItem>
                            <MudItem xs="12" md="4">
                                <MudTextField ReadOnly="ReadOnly" @bind-Value="model.InvoiceNo" Label="Invoice No" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.InvoiceNo)" Class="admin-input-group"></MudTextField>
                            </MudItem>
                            <MudItem xs="12">
                                <MudTextField ReadOnly="ReadOnly" @bind-Value="model.Narration" Lines="3" Label="Narration / Consolidation Notes" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.Narration)" Class="admin-input-group"></MudTextField>
                            </MudItem>
                        </MudGrid>
                    </div>

                    <div class="admin-glass-card pa-0 overflow-hidden">
                        <MudTabs Elevation="0" Rounded="true" ApplyEffectsToContainer="true" PanelClass="pa-0" SliderColor="Color.Primary">
                            <MudTabPanel Text="Consolidated Assets" Icon="@Icons.Material.Filled.HomeWork">
                                <div class="px-6 py-4 border-bottom-subtle d-flex align-center justify-space-between" style="background: rgba(255, 159, 67, 0.03); border-bottom: 1px solid rgba(255, 159, 67, 0.3);">
                                    <span class="admin-section-label mb-0">Consolidated Assets</span>
                                </div>
                                <div class="modern-admin-table">
                                    <MudTable T="AssetPOModel" Items="@PI.SelectedAssets" Hover="true" SelectOnRowClick Elevation="0" Dense="true" Class="mx-0">
                                        <HeaderContent>
                                            <MudTh><span class="admin-header-text">ASSET NAME</span></MudTh>
                                            <MudTh><span class="admin-header-text">ACCOUNT</span></MudTh>
                                            <MudTh><span class="admin-header-text">VALUE</span></MudTh>
                                            <MudTh><span class="admin-header-text">GST %</span></MudTh>
                                            <MudTh><span class="admin-header-text">MECHANISM</span></MudTh>
                                            <MudTh><span class="admin-header-text">CGST</span></MudTh>
                                            <MudTh><span class="admin-header-text">SGST</span></MudTh>
                                            <MudTh><span class="admin-header-text">IGST</span></MudTh>
                                            <MudTh><span class="admin-header-text">TDS</span></MudTh>
                                        </HeaderContent>
                                        <RowTemplate Context="rowCtx">
                                            <MudTd DataLabel="Asset Name">
                                                <MudText Typo="Typo.body2" Style="font-weight: 700; color: #141A46;">@rowCtx.Description</MudText>
                                            </MudTd>
                                            <MudTd DataLabel="NatureOfAsset">@rowCtx.AccountName</MudTd>

                                            <MudTd DataLabel="BookValue">
                                                @if (PI.SelectedAssets.Any(asset => asset.AssetStatus == "WIP"))
                                                {
                                                    <MudNumericField T="decimal?" Value="@rowCtx.BookValue" Immediate="true" ValueChanged="((e)=> CalcBookValue(e,rowCtx))" Variant="Variant.Outlined" Margin="Margin.Dense" Class="admin-input-group" HideSpinButtons />
                                                }
                                                else
                                                {
                                                    <MudText Typo="Typo.body2" Style="font-weight: 700; color: #FF9F43;">₹ @rowCtx.BookValue</MudText>
                                                }
                                            </MudTd>
                                            <MudTd DataLabel="GST Rate">
                                                <MudNumericField T="decimal?" Value="@rowCtx.TaxRate" Immediate="true" ValueChanged="((e)=> CalcTax(e,rowCtx))" Variant="Variant.Outlined" Margin="Margin.Dense" Class="admin-input-group" HideSpinButtons />
                                            </MudTd>
                                            <MudTd>
                                                <GstMechanismSelector page="Asset" @bind-Value="@rowCtx.GstMechanism"></GstMechanismSelector>
                                            </MudTd>
                                            <MudTd DataLabel="CGSTValue">@string.Format("{0:F2}", rowCtx.CGSTValue)</MudTd>
                                            <MudTd DataLabel="SGSTValue">@string.Format("{0:F2}", rowCtx.SGSTValue)</MudTd>
                                            <MudTd DataLabel="IGSTValue">@string.Format("{0:F2}", rowCtx.IGSTValue)</MudTd>
                                            <MudTd DataLabel="TDS">
                                                @if (PI.SelectedAssets.Any(asset => asset.AssetStatus == "WIP"))
                                                {
                                                    <MudNumericField T="decimal?" @bind-Value="@rowCtx.TDS" Variant="Variant.Outlined" Margin="Margin.Dense" Class="admin-input-group" HideSpinButtons />
                                                }
                                                else
                                                {
                                                    @string.Format("{0:F2}", rowCtx.TDS)
                                                }
                                            </MudTd>
                                        </RowTemplate>
                                    </MudTable>
                                </div>
                            </MudTabPanel>
                            <MudTabPanel Text="Expenses & Particulars" Icon="@Icons.Material.Filled.ReceiptLong">
                                <div class="px-6 py-4 border-bottom-subtle" style="background: rgba(255, 159, 67, 0.03); border-bottom: 1px solid rgba(255, 159, 67, 0.3);">
                                    <span class="admin-section-label mb-0">Expenses & Particulars</span>
                                </div>
                                <div class="modern-admin-table">
                                    <ExpenseListView OnExpenseAdded="AddExpense" OnAmountChange="SetTotal" DocDate="@model.InvoiceDate" BranchID="@branchID" PartyInfo="@model.PartyInfo" Local="@Local" ExpenseList="@model.Expenses" ReadOnly="@ReadOnly" />
                                </div>
                            </MudTabPanel>
                        </MudTabs>
                    </div>
                </EditForm>
            }
        </div>
    </FormContent>
    <VerificationStatus>
        <AutherizationStatusComponent CreatedBy="@model.UserInfo" DocTypeID="@DocTypeID" DocDate="@DocDate" DocType="@DocType" DocNumber="@DocNumber" PageToRedirectLink="@PageToRedirectLink" DocumentID="@model.PID" OnApprove="ApproveEntry"></AutherizationStatusComponent>
    </VerificationStatus>
</DialogForm>


@code {

    [Parameter]
    public TaxPurchaseModel model { get; set; }
    [Parameter]
    public bool ReadOnly { get; set; } = true;
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; }
    string docNum;
    string UserID;
    private bool _busy;
    public AssetDocumentTypeModel DocumentType { get; set; }
    public string DocNumber { get; set; }
    public DateTime? DocDate { get; set; }
    public string DocType { get; set; }
    private EditContext editContext;
    private int? branchID = null;
    private bool Local;
    public bool HasPermissionTaxPurchaseServiceEdit { get; set; } = false;
    public bool HasPermissionTaxPurchaseServiceApprove { get; set; } = false;
    int DocTypeID = 117;
    DialogForm dialogForm;
    public DocumentInfoModel DocumentDetails { get; set; } = new();
    [Parameter]
    public string PageToRedirectLink { get; set; }

    [Parameter]
    public AssetPurchaseModel PI { get; set; }
    [Parameter]
    public List<AssetPOModel> ListPI { get; set; }
    ValidationMessageStore messageStore;

    // Method to initialize the component
    protected override async Task OnInitializedAsync()
    {
        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;
        UserID = user.Identity.Name;
        branchID = int.Parse(user.Claims.First(x => x.Type == "BranchID").Value);
        model.Assets = PI.SelectedAssets;

        if (editContext == null)
        {
            editContext = new EditContext(model);
        }

        if (model.PID != null)
        {
            model.PartyInfo = partyIservice.SelectByID(model.PartyInfo.PartyID); // Fetch party info
            model.Expenses = Iservice.GetExpenses(model.PID).ToList(); // Fetch expenses
            model.Items = Iservice.GetItems(model.PID).ToList(); // Fetch items
        }
        else
        {
            model.NatureOfTransaction = "TaxPurchase";
            model.BranchID = branchID;
            model.NonStoreInventory = model.GRNID == null;
        }
        DocNumber = model.DocumentNumber;
        DocDate = model.DocumentDate;
        DocType = model.NatureOfTransaction;
    }

    // Permissions checked after first render — auth claims are empty during prerendering
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            CancellationTokenSource ctc = new CancellationTokenSource();
            HasPermissionTaxPurchaseServiceEdit = await Irole.HasClaim(DocTypeID.ToString(), "Edit", ctc.Token);
            HasPermissionTaxPurchaseServiceApprove = await Irole.HasClaim(DocTypeID.ToString(), "Approve", ctc.Token);
            StateHasChanged();
        }
    }

    protected override void OnParametersSet()
    {
        if (editContext == null)
        {
            editContext = new EditContext(model);
        }
        DocumentDetails.DocumentTypeID = DocTypeID;
        DocumentDetails.DocumentID = model.PID;
        SetTotal();
    }

    // Method to handle party changes
    void PartyChanged(PartyModel party)
    {
        model.PartyInfo = party;
        if (party != null)
        {
            Local = partyIservice.IsLocal(model.PartyInfo.PartyID, branchID); // Check if the party is local
            AddTax(model.Assets);
            SetTotal();
        }
        else { Local = false; }

    }

    // Method to handle form submission
    private async Task OnValidSubmit(EditContext context)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is being submitted!", Severity.Warning);
            return;
        }
        _busy = true;

        if (HasPermissionTaxPurchaseServiceEdit)
        {
            try
            {
                TaxPurchaseModel check = Iservice.CheckInvoiceDuplication(model); // Check for duplicate invoices
                if (check == null || (check.PID != null && check.PID == model.PID && check.DocumentNumber == model.DocumentNumber))
                {
                    model.UserInfo.UserID = UserID;

                    decimal? amt = 0;
                    foreach (var asset in model.Assets)
                    {
                        // if (asset.AssetStatus == "WIP")
                        // {
                        //     asset.CoaID = iservice.GetCWIPCoaID(asset.AssetID);
                        // }
                        // else
                        // {
                        //     asset.CoaID = iservice.GetCapitalizationCoaID(asset.AssetID);
                        // }
                        if (asset.CoaID is null)
                        {
                            snackbar.Add(string.Format("Capitalization Account is not mapped for {0}", asset.AssetCode), Severity.Error);
                            return;
                        }
                        // decimal? cgst = asset.CGSTValue ?? 0;
                        // decimal? sgst = asset.SGSTValue ?? 0;
                        // decimal? igst = asset.IGSTValue ?? 0;
                        // amt = asset.BookValue + cgst + sgst + igst;
                        //asset.GSTValue = cgst + sgst + igst;
                    }
                    //model.TotalAmount = amt;
                    //SetTotal();
                    var result = Iservice.Update(model); // Update the model
                    snackbar.Add("Saved Successfully", Severity.Success);
                    dialogForm.Close(result);
                    model = new();
                }
                else
                {
                    bool? result = await DialogService.ShowMessageBoxAsync(
                        "Warning",
                        new MarkupString("Invoice already entered On <b>" + check.DocumentDate + "</b> as <b>" + check.DocumentNumber + "</b>!"));
                }
            }
            catch (Exception ex)
            {
                snackbar.Add(ex.Message, Severity.Error);
            }
        }
        else
        {
            bool? result = await DialogService.ShowMessageBoxAsync(
                "Permission denied!",
                "You don't have any permission to Edit TaxPurchase.");
        }
        await Task.Delay(200);
        _busy = false;
    }

    // Method to approve an entry
    protected void ApproveEntry(DataApprovedStatus aprvd)
    {
        if (aprvd.IsApprove)
        {
            try
            {
                Iservice.Approve(model.PID, UserID, aprvd.Remarks); // Approve the entry
                snackbar.Add("Approved Successfully", Severity.Success);
                model.AuthLevelId = 99;
                model.AuthStatus = "Approved";
                notiService.AcknowledgeAuthNotification(99, DocTypeID, model.PID.Value, UserID);
            }
            catch (Exception ex)
            {
                snackbar.Add(ex.Message, Severity.Error);
            }
        }
    }

    // Method to add an expense
    async Task AddExpense(TaxPurchaseExpenseModel expenseModel)
    {
        model.Expenses.Add(expenseModel); // Add the expense to the model
        SetTotal();
    }

    // Method to set the total amount
    void SetTotal()
    {
        model.TotalAmount =
     (model.Expenses.Where(x => x != null).Sum(x => x.Amount) ?? 0)
       + (model.Expenses.Where(x => x != null && x.GstMechanism != "RCM").Sum(x => x.IGST + x.CGST + x.SGST) ?? 0)
       + (model.Items.Where(y => y != null).Sum(y => y.Amount + y.IGST + y.CGST + y.SGST) ?? 0)
       + (model.Assets.Where(z => z != null).Sum(z => z.BookValue) ?? 0)
       + (model.Assets.Where(z => z != null && z.GstMechanism != "RCM").Sum(z => z.GSTValue) ?? 0);
    }

    // Method to add tax to assets
    private bool AddTax(List<AssetPOModel> asset)
    {

        if (model.PartyInfo == null)
        {
            snackbar.Add("select party", Severity.Error);
            return false;
        }
        //Model.GstRateID = usageIservice.GetGstRate(Model.UsageCode, DateTime.Now);

        foreach (var item in asset)
        {
            item.IGSTValue = item.CGSTValue = item.SGSTValue = 0;
            decimal taxRate = item.TaxRate ?? 0;
            if (!Local)
            {
                item.IGSTValue = Math.Round(item.BookValue.Value * taxRate / 100, 2);
                item.GSTValue = item.IGSTValue;
            }
            else
            {
                item.SGSTValue = item.CGSTValue = Math.Round(item.BookValue.Value * taxRate / 200, 2);
                item.GSTValue = item.SGSTValue * 2;
            }
            if (model.PartyInfo != null)
            {
                decimal tdsRate = tdsService.GetTdsRate(model.PartyInfo.PartyID, item.CoaID);
                item.TDS = Math.Round((item.BookValue.Value * tdsRate) / 100, 2);
            }
            //asset.Add(item);
        }

        return true;
    }

    // Method to calculate tax for an asset
    private void CalcTax(decimal? tax, AssetPOModel item)
    {
        //AssetPOModel item = new AssetPOModel();
        decimal taxRate = tax ?? 0;
        item.IGSTValue = item.CGSTValue = item.SGSTValue = 0;
        item.TaxRate = taxRate;
        if (!Local)
        {
            item.IGSTValue = Math.Round(item.BookValue.Value * taxRate / 100, 2);
        }
        else
        {
            item.SGSTValue = item.CGSTValue = Math.Round(item.BookValue.Value * taxRate / 200, 2);
        }
        if (model.PartyInfo != null)
        {
            decimal tdsRate = tdsService.GetTdsRate(model.PartyInfo.PartyID, item.CoaID);
            item.TDS = Math.Round((item.BookValue.Value * tdsRate) / 100, 2);
        }
        item.GSTValue = item.IGSTValue + item.CGSTValue + item.SGSTValue;
        //asset.Add(item);
        SetTotal();
    }

    // Method to calculate book value for an asset
    private void CalcBookValue(decimal? BookValue, AssetPOModel item)
    {
        //AssetPOModel item = new AssetPOModel();
        decimal Val = BookValue ?? 0;
        item.BookValue = Val;
        if (!Local)
        {
            item.IGSTValue = Math.Round(item.BookValue.Value * item.TaxRate.GetValueOrDefault(0) / 100, 2);
            item.GSTValue = item.IGSTValue;
        }
        else
        {
            item.SGSTValue = item.CGSTValue = Math.Round(item.BookValue.Value * item.TaxRate.GetValueOrDefault(0) / 200, 2);
            item.GSTValue = item.SGSTValue * 2;
        }
        if (model.PartyInfo != null)
        {
            decimal tdsRate = tdsService.GetTdsRate(model.PartyInfo.PartyID, item.CoaID);
            item.TDS = Math.Round((item.BookValue.Value * tdsRate) / 100, 2);
        }
        //asset.Add(item);
        SetTotal();
    }
}
