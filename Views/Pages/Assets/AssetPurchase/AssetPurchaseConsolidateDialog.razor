@attribute [Authorize]
@using System.Threading;
@using Core.BaseModels.General;
@inject AuthenticationStateProvider auth
@inject IAssetService iservice
@inject MudBlazor.ISnackbar snackbar
@inject AuthenticationStateProvider auth
@using System.Text;
@using Views.Pages.Finance.Transactions
@inject IJSRuntime JSRuntime
@inject IPartyService partyIservice
@inject IRoleService<RoleModel> Irole
@inject ITaxPurchaseService Iservice
@inject IDialogService DialogService
@inject ITdsRateService tdsService


<DialogForm @ref="@dialogForm" ReadOnly="@ReadOnly" Title="Asset Purchase" formID="formAssetPurchase" DocumentDetails="DocumentDetails" model="@model" _busy="_busy">
    <FormContent>

        <TitleContent>
            <MudText Typo="Typo.h6">
                <MudIcon Icon="@Icons.Material.Filled.Build" Class="mr-3 mb-n1" />
                Create Asset Purchase  : @docNum
            </MudText>
        </TitleContent>
        <DialogContent>
            <EditForm id="formAssetPurchase" OnValidSubmit="OnValidSubmit" EditContext="editContext" autocomplete="off">
                <ObjectGraphDataAnnotationsValidator />
                <ValidationSummary />
                <MudGrid>
                    <MudItem xs="12" md="6">
                        <MudDatePicker ReadOnly="ReadOnly" Label="Document Date" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.DocumentDate)" DisableToolbar="true" Editable="true" @bind-Date="model.DocumentDate" DateFormat="dd/MM/yyyy" />
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <PartySelector Value="model.PartyInfo" For="@(()=> model.PartyInfo)" ValueChanged="PartyChanged" NatureOfBusiness="Supplier" BranchID="@branchID"></PartySelector>
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudDatePicker ReadOnly="ReadOnly" Label="Invoice Date" Variant="Variant.Outlined" Margin="Margin.Dense" DisableToolbar="true" Editable="true" DateFormat="dd/MM/yyyy" @bind-Date="model.InvoiceDate" For="@(() => model.InvoiceDate)" />
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudTextField ReadOnly="ReadOnly" @bind-Value="model.InvoiceNo" Label="Invoice No" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.InvoiceNo)"></MudTextField>
                    </MudItem>
                    @* <MudItem xs="12" md="6">
                    <MudTextField ReadOnly="ReadOnly" @bind-Value="model.AdditionalTDS" Label="Additional TDS" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.AdditionalTDS)"></MudTextField>
                    </MudItem> *@
                    <MudItem xs="12" md="12">
                        <MudTextField ReadOnly="ReadOnly" @bind-Value="model.Narration" Lines="2" Label="Narration" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.Narration)"></MudTextField>
                    </MudItem>
                    <MudItem xs="12">
                        <ExpenseListView OnExpenseAdded="AddExpense" OnAmountChange="SetTotal" BranchID="@branchID" PartyInfo="@model.PartyInfo" Local="@Local" ExpenseList="@model.Expenses" ReadOnly="@ReadOnly" />
                    </MudItem>
                    @* <MudItem xs="12">
                    <ItemsListView OnItemAdded="AddItems" OnAmountChange="SetTotal" BranchID="@branchID" PartyInfo="@model.PartyInfo" Local="@Local" ItemList="@model.Items" ReadOnly="@ReadOnly" EditMode="@(model.PID != null)" />
                    </MudItem> *@
                </MudGrid>
            </EditForm>
            <h6> <u>Assets</u></h6>
            <MudTable Class="mb-3" T="AssetPOModel" Items="@PI.SelectedAssets" Hover="true" SelectOnRowClick>
                <HeaderContent>
                    <MudTh>Description</MudTh>
                    <MudTh>Capitalization (A/C)</MudTh>
                    <MudTh>Book Value</MudTh>
                    <MudTh>GST Rate</MudTh>
                    <MudTh>CGST</MudTh>
                    <MudTh>SGST</MudTh>
                    <MudTh>IGST</MudTh>
                    <MudTh>TDS</MudTh>
                    @* <MudTh>Actions</MudTh> *@
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Description">@context.Description</MudTd>
                        <MudTd DataLabel="NatureOfAsset">@context.AccountName</MudTd>
                        
                    <MudTd DataLabel="BookValue">@context.BookValue</MudTd>
                        <MudTd DataLabel="CurrentValue">@context.TaxRate</MudTd>
                        <MudTd DataLabel="CGSTValue">
                            @string.Format("{0:F3}", context.CGSTValue)
                    </MudTd>
                    <MudTd DataLabel="SGSTValue">
                            @string.Format("{0:F3}", context.SGSTValue)
                    </MudTd>
                    <MudTd DataLabel="IGSTValue">
                        @string.Format("{0:F3}", context.IGSTValue)
                    </MudTd>
                    <MudTd DataLabel="TDS">
                        @string.Format("{0:F3}", context.TDS)
                    </MudTd>
                        @* <MudTd>
                    <MudIconButton Title="Delete" Color="Color.Error" @onclick="@(()=> Delete(@context))" Icon="@Icons.Material.Filled.Delete" Size="Size.Small" />
                    </MudTd> *@
                    </RowTemplate>
                </MudTable>
                @* @if (ReadOnly)
            {
            <AutherizationStatusComponent DocTypeID="15" DocDate="@PI.InitiatedDocumentDate" DocType="PaymentInitiate" DocNumber="@PI.DocumentNumber" DocumentID="@PI.PaymentInitiatedID" OnApprove="ApproveEntry"></AutherizationStatusComponent>
            } *@
            </DialogContent>
            @*         <DialogActions>
        <MudButton OnClick="@(()=> MudDialog.Cancel())">Cancel</MudButton>
        @if (!ReadOnly)
        {
        <MudButton Disabled="@_busy" form="InitiatePaymentForm" Variant="Variant.Filled" Color="Color.Success" ButtonType="ButtonType.Submit">Submit</MudButton>
        }
        else
        {
        <MudButton OnClick="@ExportToCsv">Export Memos</MudButton>
        }
        </DialogActions> *@
        </FormContent>
        <VerificationStatus>
            <AutherizationStatusComponent DocTypeID="@TaxPurchaseDocTypeID" DocDate="@DocDate" DocType="@DocType" DocNumber="@DocNumber" PageToRedirectLink="@PageToRedirectLink" DocumentID="@model.PID" OnApprove="ApproveEntry"></AutherizationStatusComponent>
        </VerificationStatus>
    </DialogForm>


@code {

    [Parameter]
    public TaxPurchaseModel model { get; set; }
    [Parameter]
    public bool ReadOnly { get; set; } = true;
    [CascadingParameter] MudDialogInstance MudDialog { get; set; }
    string docNum;
    string UserID;
    private bool _busy;
    public AssetDocumentTypeModel DocumentType { get; set; }
    public string DocNumber { get; set; }
    public DateTime? DocDate { get; set; }
    public string DocType { get; set; }
    private EditContext editContext;
    private int? branchID = null;
    private bool Local;
    public bool HasPermissionTaxPurchaseServiceEdit { get; set; } = false;
    public bool HasPermissionTaxPurchaseServiceApprove { get; set; } = false;
    int TaxPurchaseDocTypeID = 9;
    DialogForm dialogForm;
    public DocumentDetailsModel DocumentDetails { get; set; } = new();
    [Parameter]
    public string PageToRedirectLink { get; set; }

    [Parameter]
    public AssetPurchaseModel PI { get; set; }
    [Parameter]
    public List<AssetPOModel> ListPI { get; set; }
    ValidationMessageStore messageStore;


    protected override async Task OnInitializedAsync()
    {
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionTaxPurchaseServiceEdit = await Irole.HasClaim(TaxPurchaseDocTypeID.ToString(), "Edit", ctc.Token);
        HasPermissionTaxPurchaseServiceApprove = await Irole.HasClaim(TaxPurchaseDocTypeID.ToString(), "Approve", ctc.Token);

        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;
        UserID = user.Identity.Name;
        branchID = int.Parse(user.Claims.First(x => x.Type == "BranchID").Value);
        model.Assets = PI.SelectedAssets;
        model.PartyInfo = PI.SelectedAssets[0].VendorInfo;
        model.PartyInfo = partyIservice.SelectByID(model.PartyInfo.PartyID);
        if (model.PartyInfo != null)
        {
            Local = partyIservice.IsLocal(model.PartyInfo.PartyID, branchID);
        }
        else { Local = false; }
        if (model.PID == null && model.PartyInfo != null)
        {
            PartyChanged(model.PartyInfo);
        }

        if (model.PID != null)
        {
            model.PartyInfo = partyIservice.SelectByID(model.PartyInfo.PartyID);
            model.Expenses = Iservice.GetExpenses(model.PID).ToList();
            model.Items = Iservice.GetItems(model.PID).ToList();
        }
        else
        {
            model.NatureOfTransaction = "TaxPurchase";
            model.BranchID = branchID;
            model.NonStoreInventory = model.GRNID == null;
        }
        DocNumber = model.DocumentNumber;
        DocDate = model.DocumentDate;
        DocType = model.NatureOfTransaction;
        AddTax(model.Assets);
        // if (PI.PaymentInitiatedID == null)
        // {
        //     docNum = "New";
        // }
        // else
        // {
        //     docNum = PI.DocumentNumber;
        // }
    }

    protected override void OnParametersSet()
    {
        if (editContext == null)
        {
            editContext = new EditContext(model);
        }
        DocumentDetails.DocumentTypeID = TaxPurchaseDocTypeID;
        DocumentDetails.DocumentID = model.PID;
        SetTotal();
    }

    void PartyChanged(PartyModel party)
    {
        model.PartyInfo = party;
        if (party != null)
        {
            Local = partyIservice.IsLocal(model.PartyInfo.PartyID, branchID);
        }
        else { Local = false; }
    }

    private async Task OnValidSubmit(EditContext context)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is being submitted!", Severity.Warning);
            return;
        }
        _busy = true;

        if (HasPermissionTaxPurchaseServiceEdit)
        {
            try
            {
                TaxPurchaseModel check = Iservice.CheckInvoiceDuplication(model);
                if (check == null || (check.PID != null && check.PID == model.PID && check.DocumentNumber == model.DocumentNumber))
                {
                    model.UserInfo.UserID = UserID;
                    var result = Iservice.Update(model);
                    snackbar.Add("Saved Successfully", Severity.Success);
                    dialogForm.Close(result);
                    model = new();
                }
                else
                {
                    bool? result = await DialogService.ShowMessageBox(
                        "Warning",
                        new MarkupString("Invoice already entered On <b>" + check.DocumentDate + "</b> as <b>" + check.DocumentNumber + "</b>!"));
                }
            }
            catch (Exception ex)
            {
                snackbar.Add(ex.Message, Severity.Error);
            }
        }
        else
        {
            bool? result = await DialogService.ShowMessageBox(
                "Permission denied!",
                "You dont have any permission to Edit TaxPurchase.");
        }
        await Task.Delay(200);
        _busy = false;
    }

    protected void ApproveEntry(DataApprovedStatus aprvd)
    {
        if (aprvd.IsApprove)
        {
            try
            {
                //iservice.Approve(PI.PaymentInitiatedID, UserID, aprvd.Remarks);
                snackbar.Add("Approved Successfully", Severity.Success);
                PI.AuthLevelId = 99;
                PI.AuthStatus = "Approved";
            }
            catch (Exception ex)
            {
                snackbar.Add(ex.Message, Severity.Error);
            }
        }
    }

    async Task AddExpense(TaxPurchaseExpenseModel expenseModel)
    {
        model.Expenses.Add(expenseModel);
        SetTotal();
    }

    void SetTotal()
    {
        model.TotalAmount = (model.Expenses.Where(x => x != null).Sum(x => x.Amount + x.IGST + x.CGST + x.SGST) ?? 0) + (model.Assets.Where(y => y != null).Sum(y => y.BookValue + y.GSTValue) ?? 0);
    }

    private bool AddTax(List<AssetPOModel> asset)
    {

        if (model.PartyInfo == null)
        {
            snackbar.Add("select party", Severity.Error);
            return false;
        }
        //Model.GstRateID = usageIservice.GetGstRate(Model.UsageCode, DateTime.Now);
        foreach(var item in asset)
        {
            decimal taxRate = item.TaxRate ?? 0;
            if (!Local)
            {
                item.IGSTValue = Math.Round(item.BookValue.Value * taxRate / 100, 2);
            }
            else
            {
                item.SGSTValue = item.CGSTValue = Math.Round(item.BookValue.Value * taxRate / 200, 2);
            }
            decimal tdsRate = tdsService.GetTdsRate(model.PartyInfo.PartyID, item.CoaID);
            item.TDS = Math.Round((item.BookValue.Value * tdsRate) / 100, 2);
            //asset.Add(item);
        }
        
        return true;
    }
}
