    protected override async Task OpenForm(TaxPurchaseModel _model, bool ReadOnly, bool DisableAddition = false)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        _busy = true;

        var DialogOptions = new DialogOptions() { MaxWidth = MaxWidth.Large, FullWidth = true };

        AssetPurchaseModel PI = new AssetPurchaseModel()
        {
            BranchID = BranchID,
            UserInfo = new ArmsModels.SharedModels.UserInfoModel() { UserID = UserID },
            SelectedAssets = new(),
        };

        if (_model.PID is null || _model.PID == 0)
        {
            //TaxPurchaseModel tds = new TaxPurchaseModel();
            DialogParameters parms = new DialogParameters();
            parms.Add("BranchID", BranchID);
            var dialogSelected = await dialogService.ShowAsync<AssetPOConsolidateSelectionDialog>("Select Assets", parms, DialogOptions);
            var resultSelecetdAssets = await dialogSelected.Result;
            if (!resultSelecetdAssets.Canceled)
            {
                var data = (List<AssetModel>)resultSelecetdAssets.Data;
                foreach (var item in data)
                {
                    var AssetPO = new AssetPOModel();
                    AssetPO.CoaID = item.AssetStatus == "WIP" ? IassetService.GetCWIPCoaID(item.AssetID) : IassetService.GetCapitalizationCoaID(item.AssetID);
                    AssetPO.SubARDCode = item.AssetStatus == "WIP" ? "ASTCWIP" : "ASTCAP";
                    AssetPO.AccountName = accountService.SelectByID(AssetPO.CoaID).AccountName;
                    AssetPO.AssetID = item.AssetID;
                    AssetPO.AssetCode = item.AssetCode;
                    AssetPO.AssetStatus = item.AssetStatus;
                    AssetPO.TaxRate = item.TaxRate;
                    AssetPO.BookValue = item.BookValue;
                    AssetPO.BranchID = item.BranchID;
                    AssetPO.GstMechanism = item.GstMechanism;
                    AssetPO.Description = item.Description;
                    AssetPO.GSTValue = item.GSTValue;
                    AssetPO.PID = item.PID;
                    PI.SelectedAssets.Add(AssetPO);
                }
            }
            DialogParameters parmsMain = new DialogParameters();
            parmsMain.Add("model", _model.Clone());
            parmsMain.Add("PI", PI);
            parmsMain.Add("ReadOnly", ReadOnly);
            var dialog = await dialogService.ShowAsync<AssetPurchaseConsolidateDialog>("ADD", parmsMain, new DialogOptions() { MaxWidth = MaxWidth.Large, FullWidth = true });
            var result = await dialog.Result;
            if (!result.Canceled)
            {
                var ReturnData = (TaxPurchaseModel)result.Data;
                await _table.ReloadServerData();
            }
        }
        else
        {
            DialogParameters parmsPur = new DialogParameters();
            parmsPur.Add("model", _model.Clone());
            parmsPur.Add("ReadOnly", ReadOnly);
            parmsPur.Add("PageToRedirectLink", "/TaxPurchase");
            //parmsPur.Add("OnApproved", new EventCallbackFactory().Create(this, async () => await _table.ReloadServerData()));
            var dialogPur = await dialogService.ShowAsync<AssetTaxPurchaseDialog>("Edit", parmsPur, new DialogOptions() { MaxWidth = MaxWidth.Large, FullWidth = true });
            var result = await dialogPur.Result;
            if (!result.Canceled)
            {
                var ReturnData = (TaxPurchaseModel)result.Data;
                await _table.ReloadServerData();
            }
        }

         await Task.Delay(200);
            _busy = false;
    }
    //Load Data to table based on search and filters
    protected override async Task<TableData<TaxPurchaseModel>> LoadServerData(TableState state, CancellationToken token)
    {

        var list = Iservice.SelectAll(BranchID, searchTerm, "Asset", model.TaxPurchaseType, state.Page, state.PageSize, ShowApproved);

        _collection = list.Items;

        StateHasChanged();

        return new TableData<TaxPurchaseModel>
        {
            Items = _collection,
            TotalItems = list.TotalRecords ?? 0
        };
    }


