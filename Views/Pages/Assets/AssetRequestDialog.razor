@inject IAssetDocumentService IDocumentService
@inject MudBlazor.ISnackbar snackbar
@inject AuthenticationStateProvider auth
@attribute [Authorize]
@using System.Threading;
@inject IRoleService<RoleModel> Irole
@inject IDialogService DialogService

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.Edit" Class="mr-3" /> Edit Document
        </MudText>
    </TitleContent>
    <DialogContent>
        @* <MudContainer Style="max-height: 400px; overflow-y: scroll; margin-left:20px"> *@
        <EditForm id="formDriver" Model="@model" OnValidSubmit="Submit">
            <ObjectGraphDataAnnotationsValidator />
            <ValidationSummary />
            <MudGrid>
                <MudItem xs="12" md="12">
                    <MudTextField ReadOnly @bind-Value="model.DocumentType.DocumentTypeName" Label="Reference" Variant="Variant.Outlined" Margin="Margin.Dense"></MudTextField>
                </MudItem>
                <MudItem xs="6" md="6">
                    <MudDatePicker Editable @bind-Date="@(model.StartDate)" DateFormat="dd-MM-yyyy" Label="Start Date" Variant="Variant.Outlined" Margin="Margin.Dense" AnchorOrigin="Origin.BottomCenter" />
                </MudItem>
                <MudItem xs="6" md="6">
                    <MudDatePicker Editable @bind-Date="@(model.EndDate)" DateFormat="dd-MM-yyyy" Label="End Date" Variant="Variant.Outlined" Margin="Margin.Dense" AnchorOrigin="Origin.BottomCenter" />
                </MudItem>
                <MudItem xs="12" md="12">
                    <MudTextField @bind-Value="model.Refference" Label="Reference" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.Refference)"></MudTextField>
                </MudItem>
                <MudItem xs="12" md="12">
                    <MudTextField ReadOnly @bind-Value="model.Asset.Description" Label="Description" Variant="Variant.Outlined" Margin="Margin.Dense"></MudTextField>
                </MudItem>
            </MudGrid>
        </EditForm>
        @* </MudContainer> *@
    </DialogContent>
    <DialogActions>
        <MudButton Disabled="@_busy" Style="margin: 0px 14px 14px 0px;" Variant="Variant.Filled" Color="Color.Primary" OnClick="Submit" Class="px-12">Submit</MudButton>
    </DialogActions>
</MudDialog>

@code {

    [CascadingParameter] IMudDialogInstance MudDialog { get; set; }
    [Parameter]
    public AssetDocumentModel model { get; set; } = new();
    public int BranchID { get; set; } = 0;
    private bool _busy;

    public bool HasPermissionAssetDocumentRequestServiceEdit { get; set; } = false;
    public int AssetDocumentRequestDocTypeID = 114;

    // Lifecycle method called when the component is initialized
    protected override async Task OnInitializedAsync()
    {
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionAssetDocumentRequestServiceEdit = await Irole.HasClaim(AssetDocumentRequestDocTypeID.ToString(), "Edit", ctc.Token);

        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;
        var brancIDString = authprov.User.Claims.First(x => x.Type == "BranchID").Value;
        BranchID = int.Parse(brancIDString);

        if (model.DocumentType == null)
        {
            model.DocumentType = new();
        }
    }

    // Method to cancel the dialog
    void Cancel()
    {
        MudDialog.Cancel();
    }

    // Method to submit the form
    public async Task Submit()
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is being submitted!", Severity.Warning);
            return;
        }
        _busy = true;

        if (HasPermissionAssetDocumentRequestServiceEdit)
        {
            var authprov = await auth.GetAuthenticationStateAsync();
            var user = authprov.User;

            if (model != null)
            {
                // Validate the document period
                var validationOls = IDocumentService.ValidatePeriod(model).ToList();

                if (validationOls.Any(x => x.DocumentID != model.DocumentID))
                {
                    snackbar.Add("Document Period cannot overlap! Please check the period ", Severity.Warning);
                    _busy = false;
                    return;
                }
                model.UserInfo.UserID = user.Identity.Name;
                model.UserInfo.RecordStatus = 3;

                // Update the asset document request in the service
                IDocumentService.Update(model);
            }
        }
        else
        {
            bool? result = await DialogService.ShowMessageBox(
                "Permission denied!",
                "You don't have any permission to Edit AssetDocumentRequest.");
        }
        MudDialog.Close(DialogResult.Ok(true));
        await Task.Delay(200);
        _busy = false;
    }
}
