@inject IAssetDocumentRequestService Iservice
@inject IAssetDocumentService IDocumentService
@inject MudBlazor.ISnackbar snackbar
@inject AuthenticationStateProvider auth
@attribute [Authorize]
@using System.Threading;
@inject IRoleService<RoleModel> Irole
@inject IDialogService DialogService

<MudDialog>
    <TitleContent>
        @if (model.ID == null || model.ID == 0)
        {
            <MudText Typo="Typo.h6">
                <MudIcon Icon="@Icons.Material.Filled.Edit" Class="mr-3" /> Add Asset Request
            </MudText>
        }
        else
        {
            <MudText Typo="Typo.h6">
                <MudIcon Icon="@Icons.Material.Filled.Edit" Class="mr-3" /> Edit Asset Request
            </MudText>
        }
    </TitleContent>
    <DialogContent>
        @* <MudContainer Style="max-height: 400px; overflow-y: scroll; margin-left:20px"> *@
        <EditForm id="formDriver" Model="@model" OnValidSubmit="Submit">
            <ObjectGraphDataAnnotationsValidator />
            <ValidationSummary />
            <MudGrid>
                <MudItem xs="12" md="12">
                    <MudSelect ReadOnly T="int?" @bind-Value="@(model.DocumentType.DocumentTypeID)" Label="Select Document Type" Variant="Variant.Outlined" Margin="Margin.Dense" AdornmentColor="Color.Secondary" AnchorOrigin="Origin.BottomCenter">
                        @foreach (AssetDocumentTypeModel item in DocumentTypes)
                        {
                            <MudSelectItem Value="@(item.DocumentTypeID)">@item.DocumentTypeName</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="6" md="6">
                    <MudDatePicker @bind-Date="@(model.StartDate)" Label="Start Date" Variant="Variant.Outlined" Margin="Margin.Dense" AnchorOrigin="Origin.BottomCenter" />
                </MudItem>
                <MudItem xs="6" md="6">
                    <MudDatePicker @bind-Date="@(model.EndDate)" Label="End Date" Variant="Variant.Outlined" Margin="Margin.Dense" AnchorOrigin="Origin.BottomCenter" />
                </MudItem>
                <MudItem xs="12" md="12">
                    <MudTextField ReadOnly @bind-Value="model.Remarks" Label="Remarks" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.Remarks)"></MudTextField>
                </MudItem>
                <MudGrid Class="m-0">
                    @foreach (var item in PassedListAssets)
                    {
                        <MudItem xs="12" md="12">
                            <MudTextField ReadOnly @bind-Value="item.Description" Label="Description" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => item.Description)"></MudTextField>
                        </MudItem>
                    }
                </MudGrid>
            </MudGrid>
        </EditForm>
        @* </MudContainer> *@
    </DialogContent>
    <DialogActions>
        <MudButton Disabled="@_busy" Style="margin: 0px 14px 14px 0px;" Variant="Variant.Filled" Color="Color.Primary" OnClick="Submit" Class="px-12">Submit</MudButton>
    </DialogActions>
</MudDialog>

@code {

    [CascadingParameter] MudDialogInstance MudDialog { get; set; }
    [Parameter]
    public AssetDocumentRequestModel model { get; set; } = new();
    public AssetModel SelectedAsset { get; set; }
    public List<AssetModel> PassedListAssets { get; set; }
    List<AssetDocumentTypeModel> DocumentTypes = new();
    public int BranchID { get; set; } = 0;
    private bool _busy;

    public bool HasPermissionAssetDocumentRequestServiceEdit { get; set; } = false;
    public int AssetDocumentRequestDocTypeID = 114;

    public void SetAssets()
    {
        if (PassedListAssets == null)
        {
            PassedListAssets = new List<AssetModel>();
        }
        if (SelectedAsset != null && SelectedAsset.AssetID != 0 && (!PassedListAssets.Any(s => s.AssetID == SelectedAsset.AssetID)))
        {
            PassedListAssets.Add(SelectedAsset);
            SelectedAsset = null;
        }
    }

    public void RemoveAssets()
    {
        SelectedAsset = null;
    }

    public void DeleteAssets(int AssetId = 0)
    {
        if (AssetId != 0)
        {
            if (PassedListAssets != null && PassedListAssets.Where(s => s.AssetID == AssetId).Count() != 0)
            {
                if (PassedListAssets.Any(s => s.AssetID != AssetId))
                {
                    var itemToRemove = PassedListAssets.First(r => r.AssetID == AssetId);
                    PassedListAssets.Remove(itemToRemove);
                }
                else
                {
                    PassedListAssets.Clear();
                }
            }
        }
    }

    protected override async Task OnInitializedAsync()
    {
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionAssetDocumentRequestServiceEdit = await Irole.HasClaim(AssetDocumentRequestDocTypeID.ToString(), "Edit", ctc.Token);

        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;
        var brancIDString = authprov.User.Claims.First(x => x.Type == "BranchID").Value;
        BranchID = int.Parse(brancIDString);

        if (model.DocumentType == null)
        {
            model.DocumentType = new();
        }
        if (PassedListAssets == null)
        {
            PassedListAssets = new List<AssetModel>();
            if (model != null && model.Assets != null && model.Assets.Count() != 0)
            {
                PassedListAssets.AddRange(model.Assets);
            }
        }
    }

    protected override void OnParametersSet()
    {
        DocumentTypes = IDocumentService.GetDocumentTypes().ToList();
    }

    void Cancel()
    {
        MudDialog.Cancel();
    }

    public async Task Submit()
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is being submitted!", Severity.Warning);
            return;
        }
        _busy = true;

        if (HasPermissionAssetDocumentRequestServiceEdit)
        {
            var authprov = await auth.GetAuthenticationStateAsync();
            var user = authprov.User;
            if (model != null)
            {
                if (model.Assets != null)
                {
                    model.Assets.Clear();
                }
                else
                {
                    model.Assets = new();
                }
                model.Assets.AddRange(PassedListAssets);
                model.UserInfo.UserID = user.Identity.Name;
                Iservice.Update(model);
            }
        }
        else
        {
            bool? result = await DialogService.ShowMessageBox(
                "Permission denied!",
                "You don't have any permission to Edit AssetDocumentRequest.");
        }
        MudDialog.Close(DialogResult.Ok(true));
        await Task.Delay(200);
        _busy = false;
    }
}