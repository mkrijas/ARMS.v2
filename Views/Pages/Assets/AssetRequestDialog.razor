@inject IAssetDocumentRequestService Iservice
@inject IAssetDocumentService IDocumentService
@inject MudBlazor.ISnackbar snackbar
@inject AuthenticationStateProvider auth
@attribute [Authorize]
@using System.Threading;
@inject IRoleService<RoleModel> Irole
@inject IDialogService DialogService

<MudDialog>
    <TitleContent>
        @if (model.ID == null || model.ID == 0)
        {
            <MudText Typo="Typo.h6">
                <MudIcon Icon="@Icons.Material.Filled.Edit" Class="mr-3" /> Add Asset Request
            </MudText>
        }
        else
        {
            <MudText Typo="Typo.h6">
                <MudIcon Icon="@Icons.Material.Filled.Edit" Class="mr-3" /> Edit Asset Request
            </MudText>
        }
    </TitleContent>
    <DialogContent>
        <MudContainer Style="max-height: 400px; overflow-y: scroll; margin-left:20px">
            <EditForm id="formDriver" Model="@model" OnValidSubmit="Submit">
                <ObjectGraphDataAnnotationsValidator />
                <ValidationSummary />
                <MudItem xs="11" md="11">
                    <MudSelect T="int?" @bind-Value="@(model.DocumentType.DocumentTypeID)" Variant="Variant.Outlined" Margin="Margin.Dense" AdornmentColor="Color.Secondary" Label="Select Document Type">
                        @foreach (AssetDocumentTypeModel item in DocumentTypes)
                        {
                            <MudSelectItem Value="@(item.DocumentTypeID)">@item.DocumentTypeName</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudGrid>
                    <MudItem xs="5" md="5">
                        <MudDatePicker Variant="Variant.Outlined" Margin="Margin.Dense" Label="Start Date" @bind-Date="@(model.StartDate)" />
                    </MudItem>
                    <MudItem xs="1" md="1">
                    </MudItem>
                    <MudItem xs="5" md="5">
                        <MudDatePicker Variant="Variant.Outlined" Margin="Margin.Dense" Label="End Date" @bind-Date="@(model.EndDate)" />
                    </MudItem>
                </MudGrid>
                <MudItem xs="11" md="11" Class="mb-6">
                    <MudTextField @bind-Value="model.Remarks" Label="Remarks" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.Remarks)"></MudTextField>
                </MudItem>
                <MudItem xs="11" md="11">
                    <MudGrid>
                        @foreach (var item in @PassedListAssets)
                        {
                            <MudItem Style="border:1px solid #c4c4c4; height:fit-content; border-radius:4px;" Class="m-2 mb-3 p-0 pl-2 ml-2 mt-4 mb-4">
                                @item.Description
                                <MudTooltip Text="Remove">
                                    <ChildContent>
                                        <MudIconButton Class="mr-1" Color="Color.Primary" Size="@Size.Small" Icon="@Icons.Material.Filled.Remove" OnClick="(() => DeleteAssets((item.AssetID != null ? (int)item.AssetID:0)))" />
                                    </ChildContent>
                                    <TooltipContent>
                                        <MudText Typo="Typo.inherit">Remove @item.Description</MudText>
                                    </TooltipContent>
                                </MudTooltip>
                            </MudItem>
                        }
                    </MudGrid>
                </MudItem>
                <MudGrid>
                    <MudItem xs="10" md="10" sm="10">
                        <AssetSelector @bind-Value="SelectedAsset" BranchID="@BranchID" SetAssets="SetAssets" PassedListAssets="PassedListAssets"></AssetSelector>
                    </MudItem>
                    <MudItem xs="2" md="2" sm="2">
                        <MudIconButton Class="ml-4 mt-1" Variant="Variant.Filled" Icon="@Icons.Material.Filled.Add" Color="Color.Primary" OnClick="SetAssets">ADD Selected</MudIconButton>
                    </MudItem>
                </MudGrid>
            </EditForm>
        </MudContainer>
    </DialogContent>
    <DialogActions>
        <MudButton Disabled="@_busy" Variant="Variant.Filled" Color="Color.Primary" OnClick="Submit" Class="px-12">Submit</MudButton>
    </DialogActions>
</MudDialog>

@code {

    [CascadingParameter] MudDialogInstance MudDialog { get; set; }
    [Parameter]
    public AssetDocumentRequestModel model { get; set; } = new();
    public AssetModel SelectedAsset { get; set; }
    public List<AssetModel> PassedListAssets { get; set; }
    List<AssetDocumentTypeModel> DocumentTypes = new();
    public int BranchID { get; set; } = 0;
    private bool _busy;

    public bool HasPermissionAssetDocumentRequestServiceEdit { get; set; } = false;
    public int AssetDocumentRequestDocTypeID = 114;

    public void SetAssets()
    {
        if (PassedListAssets == null)
        {
            PassedListAssets = new List<AssetModel>();
        }
        if (SelectedAsset != null && SelectedAsset.AssetID != 0 && (!PassedListAssets.Any(s => s.AssetID == SelectedAsset.AssetID)))
        {
            PassedListAssets.Add(SelectedAsset);
            SelectedAsset = null;
        }
    }

    public void RemoveAssets()
    {
        SelectedAsset = null;
    }

    public void DeleteAssets(int AssetId = 0)
    {
        if (AssetId != 0)
        {
            if (PassedListAssets != null && PassedListAssets.Where(s => s.AssetID == AssetId).Count() != 0)
            {
                if (PassedListAssets.Any(s => s.AssetID != AssetId))
                {
                    var itemToRemove = PassedListAssets.First(r => r.AssetID == AssetId);
                    PassedListAssets.Remove(itemToRemove);
                }
                else
                {
                    PassedListAssets.Clear();
                }
            }
        }
    }

    protected override async Task OnInitializedAsync()
    {
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionAssetDocumentRequestServiceEdit = await Irole.HasClaim(AssetDocumentRequestDocTypeID.ToString(), "Edit", ctc.Token);

        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;
        var brancIDString = authprov.User.Claims.First(x => x.Type == "BranchID").Value;
        BranchID = int.Parse(brancIDString);

        if (model.DocumentType == null)
        {
            model.DocumentType = new();
        }
        if (PassedListAssets == null)
        {
            PassedListAssets = new List<AssetModel>();
            if (model != null && model.Assets != null && model.Assets.Count() != 0)
            {
                PassedListAssets.AddRange(model.Assets);
            }
        }
    }

    protected override void OnParametersSet()
    {
        DocumentTypes = IDocumentService.GetDocumentTypes().ToList();
    }

    void Cancel()
    {
        MudDialog.Cancel();
    }

    public async Task Submit()
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is being submitted!", Severity.Warning);
            return;
        }
        _busy = true;

        if (HasPermissionAssetDocumentRequestServiceEdit)
        {
            var authprov = await auth.GetAuthenticationStateAsync();
            var user = authprov.User;
            if (model != null)
            {
                if (model.Assets != null)
                {
                    model.Assets.Clear();
                }
                else
                {
                    model.Assets = new();
                }
                model.Assets.AddRange(PassedListAssets);
                model.UserInfo.UserID = user.Identity.Name;
                Iservice.Update(model);
            }
        }
        else
        {
            bool? result = await DialogService.ShowMessageBox(
                "Permission denied!",
                "You don't have any permission to Edit AssetDocumentRequest.");
        }
        MudDialog.Close(DialogResult.Ok(true));
        await Task.Delay(200);
        _busy = false;
    }
}