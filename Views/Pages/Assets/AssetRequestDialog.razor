@inject AuthenticationStateProvider auth
@inject IUnreconciledBankEntryService Iservice

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.Edit" Class="mr-3" /> Add New Un Recounciled Bank Entry
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudContainer Style="max-height: 300px; overflow-y: scroll">
            <EditForm id="formDriver" Model="@model" OnValidSubmit="Submit">
                <ObjectGraphDataAnnotationsValidator />
                <ValidationSummary />
                <MudItem>
                    <MudTextField @bind-Value="@(model.ArdCode)" Label="Bank Code" Variant="Variant.Filled" Disabled="true" />
                </MudItem>

                <MudItem xs="12" md="6">
                    <MudDatePicker Label="Transaction Date" @bind-Date="@(model.TransactionDate)" />
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudSelect T="int?" @bind-Value="@(model.Nature)" Label="Select Nature" HelperText="Nature" Placeholder="Please Select">
                        <MudSelectItem T="int?" Value="@(-1)">Payment</MudSelectItem>
                        <MudSelectItem T="int?" Value="@(1)">Receipt</MudSelectItem>
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" md="6">

                    <MudSelect @bind-Value="@(model.InstrumentType)" Label="Select Instrument Type" HelperText="Instrument Type" Placeholder="Please Select">
                        <MudSelectItem Value="@("Cheuque")">Cheuque</MudSelectItem>
                        <MudSelectItem Value="@("DD")">DD</MudSelectItem>
                        <MudSelectItem Value="@("E Transfer")">E Transfer</MudSelectItem>
                    </MudSelect>
                </MudItem>

                <MudItem xs="12" md="6">
                    <MudDatePicker Label="Instrument Date" @bind-Date="@(model.StartDate)" />
                </MudItem>

                <MudItem xs="12" md="6">
                    <MudDatePicker Label="Instrument Date" @bind-Date="@(model.EndDate)" />
                </MudItem>

                <MudItem xs="12" md="6">
                    <MudTextField @bind-Value="model.Remarks" Label="Instrument Reference" Variant="Variant.Outlined" Margin="Margin.Normal" For="@(() => model.InstrumentReference)"></MudTextField>
                </MudItem>

                <MudItem xs="12" md="6">
                    <MudTextField @bind-Value="model.Amount" Label="Amount" Variant="Variant.Outlined" Margin="Margin.Normal" For="@(() => model.Amount)"></MudTextField>
                </MudItem>

                <MudItem xs="12" md="6">
                    <MudTextField @bind-Value="model.PaymentRemarks" Label="Payment Remarks" Variant="Variant.Outlined" Margin="Margin.Normal" For="@(() => model.PaymentRemarks)"></MudTextField>
                </MudItem>
            </EditForm>
        </MudContainer>
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Submit" Class="px-10">Submit</MudButton>
    </DialogActions>
</MudDialog>

@code {
    
    [CascadingParameter] MudDialogInstance MudDialog { get; set; }

    [Parameter]
    public AssetDocumentRequestModel model { get; set; } = new();

    //Dictionary<int?, string> TransNature = new Dictionary<int?, string>()
    //{
    //   (1,"Receipt"),
    //   (-1,"Payment")
    //};

    void Cancel()
    {
        MudDialog.Cancel();
    }
    public async Task Submit() {
        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;
        model.UserInfo.UserID = user.Identity.Name;
        //Iservice.Update(model);
        MudDialog.Close(DialogResult.Ok(true));
    }
}
