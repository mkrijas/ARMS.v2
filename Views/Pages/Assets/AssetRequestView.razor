@page "/PendingDocuments"
@inject MudBlazor.ISnackbar snackbar
@inject AuthenticationStateProvider auth
@attribute [Authorize]
@using System.Threading;
@inject IRoleService<RoleModel> Irole
@inject IDialogService DialogService
@inject IAssetDocumentService IAssetDocumentService

@if (_isLoading)
{
        <LoaderComponent IsFullScreen="true" 
                        ShowLogo="false" 
                        Size="medium" 
                        LoadingText="Loading Pending Documents" 
                        SubText="Please wait..." />
}

<div class="admin-page-container">
    <div class="admin-header-tiered mb-6">
        <div class="d-flex align-center justify-space-between">
            <div>
                <MudText Typo="Typo.h4" Class="admin-title">Pending Documents</MudText>
                <MudText Typo="Typo.body2" Class="admin-subtitle">Review and manage pending asset documentation and expiry notices.</MudText>
            </div>
        </div>
    </div>

    <div class="admin-glass-card pa-0 overflow-hidden">
        <MudTable Items="@collection" Dense="true" Hover="true" Elevation="0" @bind-place="model" Class="modern-admin-table">
            <HeaderContent>
                <MudTh><MudTableSortLabel SortBy="new Func<AssetDocumentModel, object>(x=> x.DocumentType.DocumentTypeName)" InitialDirection="SortDirection.Ascending"><span class="admin-header-text">DOCUMENT TYPE</span></MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<AssetDocumentModel, object>(x=> x.StartDate)" InitialDirection="SortDirection.Ascending"><span class="admin-header-text">START DATE</span></MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<AssetDocumentModel, object>(x=> x.EndDate)" InitialDirection="SortDirection.Ascending"><span class="admin-header-text">END DATE</span></MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<AssetDocumentModel, object>(x=> x.Asset.Description)" InitialDirection="SortDirection.Ascending"><span class="admin-header-text">DESCRIPTION</span></MudTableSortLabel></MudTh>
                <MudTh Style="text-align: right;"><span class="admin-header-text">ACTIONS</span></MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="DocumentType"><MudText Typo="Typo.body2" Class="admin-td-primary">@context.DocumentType.DocumentTypeName</MudText></MudTd>
                <MudTd DataLabel="StartDate">@context.StartDate?.ToString("dd-MM-yyyy")</MudTd>
                <MudTd DataLabel="EndDate">@context.EndDate?.ToString("dd-MM-yyyy")</MudTd>
                <MudTd DataLabel="Remarks"><MudText Typo="Typo.body2" Class="admin-td-secondary">@context.Asset.Description</MudText></MudTd>
                <MudTd DataLabel="Actions" Style="text-align: right;">
                    <div class="d-flex justify-end gap-1">
                        <MudTooltip Text="Edit">
                            <MudIconButton OnClick="@(()=> OpenDialogEdit(context))" Color="Color.Primary" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Variant="Variant.Text" />
                        </MudTooltip>
                    </div>
                </MudTd>
            </RowTemplate>
            <PagerContent>
                <div class="pa-4">
                    <MudTablePager PageSizeOptions="new int[] { 10, 20, 50, 100 }" />
                </div>
            </PagerContent>
        </MudTable>
    </div>
</div>

}

@code {

    private bool _isLoading = true;
    private DateTime _loadStartTime;

    private AssetDocumentModel model = new();
    private List<AssetDocumentModel> collection = new();
    private bool _busy;

    public bool HasPermissionAssetDocumentRequestServiceDelete { get; set; } = false;
    public int AssetDocumentRequestDocTypeID = 114;

    string state = "Message box hasn't been opened yet";

    int BranchID;

    // Lifecycle method called when the component is initialized
    protected override async Task OnInitializedAsync()
    {
        _loadStartTime = DateTime.Now;
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionAssetDocumentRequestServiceDelete = await Irole.HasClaim(AssetDocumentRequestDocTypeID.ToString(), "Delete", ctc.Token);
        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;
        var brancIDString = authprov.User.Claims.First(x => x.Type == "BranchID").Value;
        BranchID = int.Parse(brancIDString);

        GetAll();
        await EnsureMinimumLoadTime();
        _isLoading = false;
    }

    private async Task EnsureMinimumLoadTime()
    {
        var elapsed = (DateTime.Now - _loadStartTime).TotalMilliseconds;
        if (elapsed < 100)
        {
            await Task.Delay(100 - (int)elapsed);
        }
    }

    // Method to retrieve all pending asset documents for the current branch
    void GetAll()
    {
        collection = IAssetDocumentService.SelectPendingByBranch(BranchID).ToList(); // Fetch documents from the service
    }

    // Method to open the dialog for editing an asset document
    private async Task OpenDialogEdit(AssetDocumentModel Model)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        _busy = true;

        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;
        var brancIDString = authprov.User.Claims.First(x => x.Type == "BranchID").Value;

        Model.UserInfo = new();
        if (Model.UserInfo != null)
        {
            Model.UserInfo.UserID = user.Identity.Name;
        }
        var model = new DialogParameters { ["model"] = Model.Clone() };
        var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Medium };
        var dialog = await DialogService.ShowAsync<AssetRequestDialog>("Simple Dialog", model, options);
        var result = await dialog.Result;

        // you can check if the modal was cancelled
        var isCancelled = result.Canceled;
        if (!isCancelled)
        {
            GetAll();
        }
        await Task.Delay(200);
        _busy = false;
    }
}
