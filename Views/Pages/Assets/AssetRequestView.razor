@page "/PendingDocuments"
@inject MudBlazor.ISnackbar snackbar
@inject AuthenticationStateProvider auth
@attribute [Authorize]
@using System.Threading;
@inject IRoleService<RoleModel> Irole
@inject IDialogService DialogService
@inject IAssetDocumentService IAssetDocumentService

<MudGrid Spacing="4">
    <MudItem xs="12">
        <MudTable Items="@collection" Dense="true" Hover="true" Striped="true" Elevation="10" @bind-place="model">
            <ToolBarContent>
                <MudText Typo="Typo.h6">Pending Documents</MudText>
            </ToolBarContent>
            <HeaderContent>
                <MudTh><MudTableSortLabel SortBy="new Func<AssetDocumentModel, object>(x=> x.DocumentType.DocumentTypeName)" InitialDirection="SortDirection.Ascending">Document Type</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<AssetDocumentModel, object>(x=> x.StartDate)" InitialDirection="SortDirection.Ascending">Start Date</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<AssetDocumentModel, object>(x=> x.EndDate)" InitialDirection="SortDirection.Ascending">End Date</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<AssetDocumentModel, object>(x=> x.Asset.Description)" InitialDirection="SortDirection.Ascending">Description</MudTableSortLabel></MudTh>
                <MudTh>Actions</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="DocumentType">@context.DocumentType.DocumentTypeName</MudTd>
                <MudTd DataLabel="StartDate">@context.StartDate</MudTd>
                <MudTd DataLabel="EndDate">@context.EndDate</MudTd>
                <MudTd DataLabel="Remarks">@context.Asset.Description</MudTd>
                <MudTd DataLabel="">
                    <MudTooltip Text="Edit">
                        <MudIconButton @onclick="@(()=> OpenDialogEdit(context))" Color="Color.Primary" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" IconSize="Size.Small" />
                    </MudTooltip>
                </MudTd>
            </RowTemplate>
            <PagerContent>
                <MudTablePager PageSizeOptions="new int[] { 10, 20, 50, 100 }" />
            </PagerContent>
        </MudTable>
    </MudItem>
</MudGrid>

@code {

    private AssetDocumentModel model = new();
    private List<AssetDocumentModel> collection = new();
    private bool _busy;

    public bool HasPermissionAssetDocumentRequestServiceDelete { get; set; } = false;
    public int AssetDocumentRequestDocTypeID = 114;

    string state = "Message box hasn't been opened yet";

    int BranchID;

    protected override async Task OnInitializedAsync()
    {
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionAssetDocumentRequestServiceDelete = await Irole.HasClaim(AssetDocumentRequestDocTypeID.ToString(), "Delete", ctc.Token);
        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;
        var brancIDString = authprov.User.Claims.First(x => x.Type == "BranchID").Value;
        BranchID = int.Parse(brancIDString);

        GetAll();
    }

    void GetAll()
    {
        collection = IAssetDocumentService.SelectPendingByBranch(BranchID).ToList();
    }

    private async Task OpenDialogEdit(AssetDocumentModel Model)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        _busy = true;

        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;
        var brancIDString = authprov.User.Claims.First(x => x.Type == "BranchID").Value;

        Model.UserInfo = new();
        if (Model.UserInfo != null)
        {
            Model.UserInfo.UserID = user.Identity.Name;
        }
        var model = new DialogParameters { ["model"] = Model.Clone() };
        var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Medium };
        var dialog = DialogService.Show<AssetRequestDialog>("Simple Dialog", model, options);
        var result = await dialog.Result;

        // you can check if the modal was cancelled
        var isCancelled = result.Canceled;
        if (!isCancelled)
        {
            GetAll();
        }
        await Task.Delay(200);
        _busy = false;
    }
}