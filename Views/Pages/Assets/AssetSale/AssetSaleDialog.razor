@using System.Threading;
@using Views.Pages.Finance.Transactions
@attribute [Authorize]
@inject AuthenticationStateProvider auth
@inherits DialogFormComponentBase<SaleModel>
@inject IRoleService<RoleModel> Irole
@inject ISaleService Iservice
@inject IPartyService partyIservice
@inject IInventoryItemService itemIservice
@inject IGstItemService gstitemIservice
@inject IInventoryGroupService inventoryGroupIservice
@inject IGstUsageIDService usageIservice
@inject IInventoryGrnService grnIservice
@inject IBranchService branchIservice
@inject MudBlazor.ISnackbar snackbar
@inject ITdsRateService tdsIService
@inject IDialogService DialogService
@inject IJSRuntime JsRuntime

<DialogForm @ref="@dialogForm" ReadOnly="@ReadOnly" Title="Asset Sale" Subtitle="Manage asset disposals with integrated tax invoicing and automated ledger entries." Icon="@Icons.Material.Filled.AssignmentTurnedIn" AdminStyle="true" formID="saleForm" DocumentDetails="DocumentDetails" model="@model" TotalAmount="model.TotalAmount" _busy="_busy">
    <FormContent>
        <div class="dialog-content-wrapper">
            <EditForm id="saleForm" Model="@model" OnValidSubmit="OnValidSubmit">
                <ObjectGraphDataAnnotationsValidator />
                
                <MudTabs Elevation="0" Rounded="true" ApplyEffectsToContainer="true" PanelClass="pa-0" SliderColor="Color.Primary" Class="admin-tabs-modern">
                    <MudTabPanel Text="SALE INVOICE" Icon="@Icons.Material.Filled.Description">
                        <div class="pa-6">
                            <div class="admin-glass-card pa-6 mb-6">
                                <span class="admin-section-label">General Information</span>
                                <MudGrid Spacing="3">
                                    <MudItem xs="12" md="8">
                                         <PartySelector For="@(() => model.PartyInfo)" Value="model.PartyInfo" ValueChanged="PartyChanged" NatureOfBusiness="Customer" BranchID="@BranchID" IncludeSisterConcern Class="admin-input-group"></PartySelector>
                                    </MudItem>
                                    <MudItem xs="12" md="4">
                                        <MudDatePicker Label="Operation Date" ReadOnly="ReadOnly" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.DocumentDate)" DisableToolbar="true" Editable="true" @bind-Date="model.DocumentDate" DateFormat="dd/MM/yyyy" Class="admin-input-group" />
                                    </MudItem>
                                    <MudItem xs="12">
                                        <MudTextField @bind-Value="model.Narration" ReadOnly="ReadOnly" Lines="2" Label="Execution Narration" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.Narration)" Class="admin-input-group"></MudTextField>
                                    </MudItem>
                                </MudGrid>
                            </div>

                            <div class="mb-6">
                                <ExpenseListView OnExpenseAdded="AddExpense" OnAmountChange="SetTotal" DocDate="@model.DocumentDate" BranchID="@BranchID" PartyInfo="@model.PartyInfo" Local="@Local" IsTaxable="@IsTaxable" ExpenseList="@model.Particulars" ReadOnly="@ReadOnly" />
                            </div>

                            <div>
                                <AssetsListView OnAssetAdded="AddAssets" OnAmountChange="SetTotal" BranchID="@BranchID" PartyInfo="@model.PartyInfo" Local="@Local" IsTaxable="@IsTaxable" AssetList="@model.Assets" ReadOnly="@ReadOnly" EditMode="@(model.Assets != null)" />
                            </div>
                        </div>
                    </MudTabPanel>
                    
                    <MudTabPanel Text="BILLING ADDRESS" Icon="@Icons.Material.Filled.LocationOn">
                        <div class="pa-6">
                            <span class="admin-section-label">Select Registered Address</span>
                            <MudRadioGroup T="AddressModel" @bind-Value="selectedAddress">
                                <MudGrid Spacing="3">
                                    @foreach (var address in addresses)
                                    {
                                        <MudItem xs="12" md="6" lg="4">
                                            <div class="admin-glass-card pa-4 h-100 @(selectedAddress == address ? "border-orange-active" : "")" style="cursor: pointer; transition: all 0.3s ease;">
                                                <div class="d-flex align-center mb-3">
                                                    <MudRadio T="AddressModel" Value="address" Color="Color.Primary" Dense="true" />
                                                    <MudText Typo="Typo.subtitle1" Style="font-weight: 800; color: #141A46;">@address.AddresseeName</MudText>
                                                </div>
                                                <div class="pl-8" style="color: #667085; font-size: 0.875rem; line-height: 1.6;">
                                                    <div>@address.Building, @address.Street</div>
                                                    <div>@address.City, @address.PinCode</div>
                                                    <div class="mt-2 d-inline-flex align-center px-2 py-0.5 rounded-pill" style="background: rgba(255,159,67,0.1); color: #FF9F43; font-size: 0.75rem; font-weight: 700;">
                                                        REGISTERED OFFICE
                                                    </div>
                                                </div>
                                            </div>
                                        </MudItem>
                                    }
                                </MudGrid>
                            </MudRadioGroup>
                        </div>
                    </MudTabPanel>
                </MudTabs>
            </EditForm>
        </div>
    </FormContent>
    <VerificationStatus>
        <AutherizationStatusComponent CreatedBy="@model.UserInfo" DocTypeID="@SaleDocTypeID" DocDate="@DocDate" DocType="@DocType" DocNumber="@DocNumber" PageToRedirectLink="@PageToRedirectLink" DocumentID="model.SID" OnApprove="Approve"></AutherizationStatusComponent>
    </VerificationStatus>
</DialogForm>

@code {

    [Parameter]
    public string PageToRedirectLink { get; set; }
    private bool Local;
    bool IsTaxable;
    private EditContext editContext;
    public string DocNumber { get; set; }
    public DateTime? DocDate { get; set; }
    public string DocType { get; set; }
    private bool _busy;
    string UserIDTemp;
    public DocumentInfoModel DocumentDetails { get; set; } = new();

    public bool HasPermissionSaleServiceEdit { get; set; } = false;
    public bool HasPermissionSaleServiceApprove { get; set; } = false;
    public int SaleDocTypeID = 13;
    private AddressModel selectedAddress;
    private List<AddressModel> addresses = new List<AddressModel>();

    // Document information model for the Sales 
    protected override DocumentInfoModel DocInfo { get; set; } = new();

    public GstUsageCodeModel gstusge = new();
    private GstModel taxModel = new GstModel();
    DialogOptions maxWidth = new DialogOptions() { MaxWidth = MaxWidth.Medium, FullWidth = true };

    // Lifecycle method called when the component is initialized
    protected override async Task OnInitializedAsync()
    {
        CancellationTokenSource ctc = new CancellationTokenSource();
        // Check user permissions for editing and approving sales
        HasPermissionSaleServiceEdit = await Irole.HasClaim(SaleDocTypeID.ToString(), "Edit", ctc.Token);
        HasPermissionSaleServiceApprove = await Irole.HasClaim(SaleDocTypeID.ToString(), "Approve", ctc.Token);

        DocInfo.DocumentTypeID = SaleDocTypeID;
        DocInfo.DocumentID = model.SID;

        await base.OnInitializedAsync();

        if (model?.SID != null)
        {
            addresses = partyIservice.GetAddress(model.PartyInfo.PartyID)?.ToList() ?? new List<AddressModel>();
            selectedAddress = addresses.FirstOrDefault(x => x.AddressID == model.AddressID);

            UserIDTemp = model.UserInfo.UserID;
            model.PartyInfo = partyIservice.SelectByID(model.PartyInfo.PartyID); // Get party info
            var ResultParticulars = Iservice.GetParticulars(model.SID); // Get particulars
            if (ResultParticulars != null)
            {
                model.Particulars = ResultParticulars.ToList(); // Assign particulars to the model
            }
            var ResultItems = Iservice.GetAssets(model.SID);  // Get assets
            if (ResultItems!= null)
            {
                model.Assets = ResultItems.ToList(); // Assign assets to the model
            }
        }
        else
        {
            model.NatureOfTransaction = "Sale";
            model.BranchID = BranchID;
        }
        DocNumber = model.DocumentNumber;
        DocDate = model.DocumentDate;
        DocType = model.NatureOfTransaction;
       
        StateHasChanged();
    }

    // Lifecycle method called when parameters are set
    protected override void OnParametersSet()
    {
        if (editContext == null)
        {
            editContext = new EditContext(model);
        }
        DocumentDetails.DocumentTypeID = SaleDocTypeID;
        DocumentDetails.DocumentID = model.SID;
        SetTotal();
    }

    // Method to calculate the total amount based on particulars and assets
    void SetTotal()
    {
        model.TotalAmount = (model.Particulars.Where(x => x != null).Sum(x => x.Amount + x.IGST + x.CGST + x.SGST) ?? 0) +
                            (model.Assets.Where(y => y != null).Sum(y => (y.SaleValue != null ? y.SaleValue : 0) +
                                                                       (y.IGSTValue != null ? y.IGSTValue : 0) +
                                                                       (y.CGSTValue != null ? y.CGSTValue : 0) +
                                                                       (y.SGSTValue != null ? y.SGSTValue : 0)) ?? 0);
    }

    // Method to handle changes in the selected party
    void PartyChanged(PartyModel party)
    {
        model.PartyInfo = party;
        if (party != null)
        {
            addresses = partyIservice.GetAddress(model.PartyInfo.PartyID)?.ToList() ?? new List<AddressModel>();
            if (addresses.Count == 1)
            {
                selectedAddress = addresses[0];
            }

            IsTaxable = party.GstType == "Registered" || party.GstType == "UnRegistered";
            Local = partyIservice.IsLocal(model.PartyInfo.PartyID, BranchID);
        }
        else { Local = false; }        
    }

    // Method to add an expense to the model
    async Task AddExpense(TaxPurchaseExpenseModel expenseModel)
    {
        model.Particulars.Add(expenseModel);
        SetTotal();
    }

    // Method to add an asset to the model
    async Task AddAssets(AssetSaleModel AssetModel)
    {
        model.Assets.Add(AssetModel);
        SetTotal();
    }

    // Method to update the Sale model
    protected override async Task<int> Update(SaleModel editModel)
    {      
        if (selectedAddress == null)
        {
            snackbar.Add("Please select billing address!", Severity.Warning);
            return 0;
        }

        if (await validate(model))
        {            
            model.SalesType = "Asset";
            model.AddressID = selectedAddress.AddressID;
            model = Iservice.Update(model); // Update the model using the service
            return model.SID ?? 0;
        }
        return 0;
    }

    // Method to approve the Sale model
    protected override int UpdateApproval(DataApprovedStatus aprvd)
    {
        int result = Iservice.Approve(model.SID, model.UserInfo.UserID, aprvd.Remarks); // Call the service to approve
        model.UserInfo.UserID = UserIDTemp;
        return result;
    }
}
