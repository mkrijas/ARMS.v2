@page "/AssetSale"
@page "/AssetSale/{id:int}"
@using System.Threading;
@using Inventory
@inherits ViewComponentBase<SaleModel>
@inject SignalRService signalRService
@inject ISaleService Iservice





<div @key="@("content")" class="admin-page-container">
    <div class="admin-header-tiered mb-6">
        <div class="d-flex align-center justify-space-between">
            <div>
                <MudText Typo="Typo.h4" Class="admin-title">Asset Sales</MudText>
                <MudText Typo="Typo.body2" Class="admin-subtitle">Track and manage vehicle and equipment divestments across all branches.</MudText>
            </div>
            <MudButton StartIcon="@Icons.Material.Filled.Add" Variant="Variant.Filled" Color="Color.Primary" Class="admin-register-btn" OnClick="@(()=> OpenForm(new SaleModel(),false))" Disabled="@_busy">REGISTER SALE</MudButton>
        </div>
    </div>
    <div class="admin-glass-card mb-6 pa-4">
        <div class="d-flex align-center gap-4">
            <div style="flex-grow: 1;">
                <MudTextField @bind-Value="searchTerm" Placeholder="Search Sales..." Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" Variant="Variant.Outlined" Margin="Margin.Dense" Class="admin-input-group" @onkeyup="HandleSearchKeyUp" Clearable="true" />
            </div>            
            <MudCheckBox T="bool" Label="Approved" ValueChanged="((bool value)=>ToggleData(value))" Value="@ShowApproved" Size="Size.Small" Color="Color.Primary" Class="fw-600" />
        </div>
    </div>
    <div class="admin-glass-card pa-0 overflow-hidden">
        <MudTable ServerData="LoadServerData" T="SaleModel" @ref="_table" Dense="true" Hover="true" Elevation="0" Class="modern-admin-table">
            <LoadingContent>
                <div @key="@("loader")" style="display: flex; justify-content: center; align-items: center; min-height: 400px;">
                    <LoaderComponent IsFullScreen="false"
                                     ShowLogo="false"
                                     Size="large"
                                     LoadingText="Loading...."
                                     SubText="Fetching Data..." />
                </div>
            </LoadingContent>
            <HeaderContent>
                <MudTh><MudTableSortLabel SortBy="new Func<SaleModel, object>(x=> x.PartyInfo.TradeName)" InitialDirection="SortDirection.Ascending"><span class="admin-header-text">TRADE NAME</span></MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<SaleModel, object>(x=> x.TotalAmount)" InitialDirection="SortDirection.Ascending"><span class="admin-header-text">TOTAL AMOUNT</span></MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<SaleModel, object>(x=> x.DocumentDate)" InitialDirection="SortDirection.Ascending"><span class="admin-header-text">DATE</span></MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<SaleModel, object>(x=> x.DocumentNumber)" InitialDirection="SortDirection.Ascending"><span class="admin-header-text">DOC NO.</span></MudTableSortLabel></MudTh>
                <MudTh Style="text-align: right;"><span class="admin-header-text">ACTIONS</span></MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="TradeName"><MudText Typo="Typo.body2" Class="admin-td-primary">@context.PartyInfo.TradeName</MudText></MudTd>
                <MudTd DataLabel="TotalAmount"><MudText Typo="Typo.body2" Class="admin-td-amount">@context.TotalAmount.ToString()</MudText></MudTd>
                <MudTd DataLabel="DocumentDate">@context.DocumentDate?.ToShortDateString()</MudTd>
                <MudTd DataLabel="DocumentNumber">
                    <div class="d-flex flex-column">
                        <MudText Typo="Typo.body2" Class="admin-td-secondary">@context.DocumentNumber</MudText>
                        @if (context.AuthLevelId == 100)
                        {
                            <MudChip T="string" Color="Color.Error" Size="Size.Small" Variant="Variant.Text" Class="fw-700 pa-0">REJECTED</MudChip>
                        }
                    </div>
                </MudTd>
                <MudTd DataLabel="Actions" Style="text-align: right;">
                    <div class="d-flex justify-end gap-1">
                        <MudTooltip Text="View Details">
                            <MudIconButton OnClick="@(()=> OpenForm(context,true))" Color="Color.Info" Icon="@Icons.Material.Filled.GridView" Size="Size.Small" Variant="Variant.Text" />
                        </MudTooltip>
                        <MudTooltip Text="Edit">
                            <MudIconButton Disabled="@(context.AuthLevelId != null)" OnClick="@(()=> OpenForm(context,false))" Color="Color.Primary" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Variant="Variant.Text" />
                        </MudTooltip>
                        <MudTooltip Text="Delete">
                            <MudIconButton Disabled="@(context.AuthLevelId != null)" OnClick="@(()=> Delete(context.SID))" Color="Color.Error" Icon="@Icons.Material.Filled.DeleteOutline" Size="Size.Small" Variant="Variant.Text" />
                        </MudTooltip>
                        @if (@context.AuthLevelId == 99)
                        {
                            <MudTooltip Text="Print Invoice">
                                <MudIconButton OnClick="@(()=> PrintInvoice(context.SID))" Color="Color.Secondary" Icon="@Icons.Material.Filled.Print" Size="Size.Small" Variant="Variant.Text" />
                            </MudTooltip>
                        }
                        else if (@context.AuthLevelId != 100)
                        {
                            <MudTooltip Text="Verify">
                                <MudIconButton OnClick="@(()=> OpenForm(context,true))" Color="Color.Warning" Icon="@Icons.Material.Filled.Verified" Size="Size.Small" Variant="Variant.Text" />
                            </MudTooltip>
                        }
                    </div>
                </MudTd>
            </RowTemplate>
            <PagerContent>
                <div class="pa-4">
                    <MudTablePager PageSizeOptions="new int[] { 10, 20, 50, 100 }" />
                </div>
            </PagerContent>
        </MudTable>
    </div>
</div>


@code { 

    protected override List<SaleModel> _collection { get; set; } = new List<SaleModel>();

    protected override DocumentInfoModel DocInfo { get; set; } = new DocumentInfoModel()
    {
        DocumentTypeID = 13,
        DocumentName = "Journal"
    };



    // Lifecycle method called when the component is initialized
    protected override async Task OnInitializedAsync()
    {        
        await base.OnInitializedAsync();        
        if (id != null && _collection != null && _collection.Any(g => g.SID == id))
        {
            await OpenForm(_collection.FirstOrDefault(s => s.SID == id), true);
        }       
    }
  

   
    // Method to retrieve all sales based on approval status and number of records
    protected override async Task<TableData<SaleModel>> LoadServerData(TableState state, CancellationToken token)
    {
        var list = Iservice.SelectAll(BranchID, state.Page, state.PageSize, searchTerm, ShowApproved, "Asset");
        _collection = list.Items;
        return new TableData<SaleModel>
        {
            Items = _collection,
            TotalItems = list.TotalRecords ?? 0
        };
    }


  

    // Method to open a dialog for adding or editing a sale
    protected override async Task OpenForm(SaleModel _model, bool ReadOnly, bool DisableAddition = false)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        _busy = true;
        DialogParameters parms = new DialogParameters();
        parms.Add("model", _model.Clone());
        parms.Add("PageToRedirectLink", "/Sale");
        parms.Add("ReadOnly", ReadOnly);
        parms.Add("OnApproved", new EventCallbackFactory().Create(this, async () => await _table.ReloadServerData()));
        var dialog = await dialogService.ShowAsync<AssetSaleDialog>(_model.SID == null ? "ADD" : "EDIT", parms, new DialogOptions() { MaxWidth = MaxWidth.Large, FullWidth = true });
        var result = await dialog.Result;
        if (!result.Canceled)
        {
            var ReturnData = (SaleModel)result.Data;
            await _table.ReloadServerData();
        }
        await Task.Delay(200);
        _busy = false;      
    }
   

    // Dictionary to hold report parameters
    public Dictionary<string, string> ReportParameters { get; set; } = new();

    // Method to print the invoice for a sale
    private async Task PrintInvoice(int? SID)
    {
        ReportParameters.Clear();
        ReportParameters.Add("SID", SID.ToString());
        var parameters = new DialogParameters();
        parameters.Add("Parameters", ReportParameters); // Add the dictionary as a parameter
        parameters.Add("ReportName", "PrintAssetSaleInvoice");

        DialogOptions maxWidth = new DialogOptions() { MaxWidth = MaxWidth.Medium, FullWidth = true };
        await dialogService.ShowAsync<PrintDialog>("PRINT", parameters, maxWidth);
    }
}
