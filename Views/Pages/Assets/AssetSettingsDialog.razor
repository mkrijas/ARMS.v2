@using ArmsModels.BaseModels.General;
@inject IAssetSettingsService Iservice
@attribute [Authorize]
@using System.Threading;
@inject IRoleService<RoleModel> Irole
@inject AuthenticationStateProvider auth
@inject IDialogService DialogService

<MudDialog Class="admin-dialog-glass">
    <DialogContent>
        <div class="header-section mb-6">
            <div class="d-flex align-center">
                <div class="icon-badge primary-badge mr-4">
                    <MudIcon Icon="@Icons.Material.Filled.SettingsSuggest" Size="Size.Large" />
                </div>
                <div>
                    <MudText Typo="Typo.h5" Class="admin-title"><b>Control Configuration</b></MudText>
                    <MudText Typo="Typo.body2" Class="admin-subtitle">
                        Configure advanced settings for asset management.
                    </MudText>
                </div>
            </div>
            <div class="title-accent mt-4"></div>
        </div>

        <div class="admin-glass-card pa-6">
            <MudGrid Spacing="4">
                @foreach (var i in SettingsList)
                {
                    <MudItem xs="12">
                        <div class="settings-item-row d-flex align-center pa-4 rounded-xl" style="background: rgba(255,255,255,0.2); border: 1px solid rgba(255,255,255,0.3);">
                            <div class="mr-6">
                                <MudSwitch Color="Color.Primary" Checked="@i.IsActive" T="bool" 
                                           CheckedChanged="((value)=>OnValueChanged(i,value))" />
                            </div>
                            <div class="flex-grow-1">
                                <MudText Typo="Typo.subtitle1" Style="font-weight: 700; color: #141A46;">@i.SettingsName</MudText>
                                <MudText Typo="Typo.body2" Style="color: #4A5568; line-height: 1.4;">@i.SettingsDescription</MudText>
                            </div>
                            <div class="ml-4">
                                <div class="status-indicator @(i.IsActive ? "active" : "inactive") pa-1 px-3 rounded-pill" 
                                     style="@(i.IsActive ? "background: rgba(54, 117, 136, 0.1); color: #367588;" : "background: rgba(0,0,0,0.05); color: #718096;")">
                                    <MudText Typo="Typo.caption" Style="font-weight: 800; font-family: 'Outfit', sans-serif;">
                                        @(i.IsActive ? "ENABLED" : "DISABLED")
                                    </MudText>
                                </div>
                            </div>
                        </div>
                    </MudItem>
                }
            </MudGrid>
        </div>
    </DialogContent>
</MudDialog>

@code {

    string UserID;
    [Parameter]
    public int? SubClassID { get; set; }
    private List<AssetSettingsModel> SettingsList;

    public bool HasPermissionAssetSettingsServiceEdit { get; set; } = false;
    public int AssetSettingsDocTypeID = 111;

    // Lifecycle method called when the component is initialized
    protected override async Task OnInitializedAsync()
    {
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionAssetSettingsServiceEdit = await Irole.HasClaim(AssetSettingsDocTypeID.ToString(), "Edit", ctc.Token);

        var authprov = await auth.GetAuthenticationStateAsync();
        UserID = authprov.User.Identity.Name;

        // Fetch the asset settings based on the subclass ID
        SettingsList = Iservice.SelectByID(SubClassID).ToList();
    }

    // Method to handle changes in asset settings
    private async Task OnValueChanged(AssetSettingsModel obj, bool value)
    {
        if (HasPermissionAssetSettingsServiceEdit)
        {
            if (SettingsList.Any(s => s.SettingsID == obj.SettingsID))
            {
                SettingsList.First(s => s.SettingsID == obj.SettingsID).IsActive = value;

                // Update the settings in the service
                Iservice.Update(SettingsList.First(s => s.SettingsID == obj.SettingsID), UserID);
            }
        }
        else
        {
            bool? result = await DialogService.ShowMessageBoxAsync(
                "Permission denied!",
                "You don't have any permission to Edit AssetSettings.");
        }
    }
}
