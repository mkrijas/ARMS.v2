@using ArmsModels.BaseModels.General;
@inject IAssetSettingsService Iservice
@inject AuthenticationStateProvider auth


<MudDialog Class="my-dialogue pb-3">
    <DialogContent>
        <div style="padding: 8px;">
            <MudGrid style="padding: 0px;">
                @foreach (var i in SettingsList)
                {
                    <MudItem sm="12">
                        <MudGrid>
                            <MudItem sm="4" Class="d-flex align-content-center">
                                <MudSwitch Color="Color.Primary" Checked="@i.IsActive" T="bool" Label="@i.SettingsName" CheckedChanged="((value)=>OnValueChanged(i,value))"></MudSwitch>
                            </MudItem>
                            <MudItem sm="8" Class="d-flex aalign-content-center">
                                <p Class="d-flex align-content-lg-between">@i.SettingsDescription</p>
                            </MudItem>
                        </MudGrid>
                    </MudItem>
                    <br />
                }
            </MudGrid>
        </div>
    </DialogContent>
</MudDialog>

@code {

    string UserID;

    [Parameter]
    public int? SubClassID { get; set; }

    private List<AssetSettingsModel> SettingsList;

    protected override async Task OnInitializedAsync()
    {
        var authprov = await auth.GetAuthenticationStateAsync();
        UserID = authprov.User.Identity.Name;


        SettingsList = Iservice.SelectByID(SubClassID).ToList();
    }


    private async Task OnValueChanged(AssetSettingsModel obj,bool value)
    {
        if (SettingsList.Any(s=>s.SettingsID==obj.SettingsID))
        {
            SettingsList.First(s => s.SettingsID == obj.SettingsID).IsActive = value;
            
            Iservice.Update(SettingsList.First(s => s.SettingsID == obj.SettingsID), UserID);
        }
    }

}
