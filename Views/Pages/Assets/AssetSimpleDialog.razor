@inject IAssetService Iservice
@inject IAssetClassService assetclassIservice
@inject IGstUsageIDService gstIservice
@inject IPartyService partyIservice
@inject MudBlazor.ISnackbar snackbar
@inject AuthenticationStateProvider auth
@attribute [Authorize]
@using System.Threading;
@inject IRoleService<RoleModel> Irole
@inject IDialogService DialogService

<MudDialog>
    <TitleContent>
       
        <MudText Typo="Typo.h6" Class="d-flex">
            <MudIcon Icon="@Icons.Material.Filled.WebAsset" Class="mr-3 mb-n1" />
            <h6>Asset Info</h6>
        </MudText>
    </TitleContent>
    <DialogContent>
        <EditForm id="assetForm" Model="model" OnValidSubmit="ValidSubmit">
            <DataAnnotationsValidator />
            <ValidationSummary />
            <MudContainer Style="max-height: 450px; overflow-y: scroll">
                <MudPaper Elevation="0">
                    <MudGrid>
                        <MudItem xs="12">
                            <h6>@model.AssetCode</h6>
                        </MudItem>
                        <MudItem xs="12" md="12">
                            <MudTextField @bind-Value="model.Description" Label="Asset Description" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.Description)"></MudTextField>
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <MudTextField @bind-Value="model.SerialNumber" Label="Serial Number" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.SerialNumber)"></MudTextField>
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <MudSelect Label="Nature Of Asset" @bind-Value="model.NatureOfAsset" T="string" Variant="Variant.Outlined" Margin="Margin.Dense" AdornmentColor="Color.Secondary">
                                @foreach (var ditem in NatureOfAssetList)
                                {
                                    <MudSelectItem Value="@ditem">@ditem</MudSelectItem>
                                }
                            </MudSelect>
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <MudSelect Label="Select AssetClass" @bind-Value="model.AssetClass" SelectedValuesChanged="getSubClass" T="AssetClassModel" Variant="Variant.Outlined" Margin="Margin.Dense" OffsetY="true" Direction="Direction.Top" AdornmentColor="Color.Secondary" ToStringFunc="@(e => e == null ? null : $"{e.AssetClassName}")">
                                @foreach (var ditem in assetclassList)
                                {
                                    <MudSelectItem Value="@ditem">@ditem.AssetClassName</MudSelectItem>
                                }
                            </MudSelect>
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <MudSelect Label="Select SubClass" @bind-Value="model.SubClass" T="AssetSubClassModel" Variant="Variant.Outlined" Margin="Margin.Dense" OffsetY="true" Direction="Direction.Top" AdornmentColor="Color.Secondary" ToStringFunc="@(e => e == null ? null : $"{e.AssetSubclass}")">
                                @foreach (var ditem in assetsubclassList)
                                {
                                    <MudSelectItem Value="@ditem">@ditem.AssetSubclass</MudSelectItem>
                                }
                            </MudSelect>
                        </MudItem>

                        <MudItem xs="12" md="6">
                            <MudTextField @bind-Value="model.HsnCode" Label="Hsn Code" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.HsnCode)" MaxLength="8"></MudTextField>
                        </MudItem>
                        @if (model.IsComplex == false)
                        {
                            <MudItem xs="12">
                                <MudDivider DividerType="DividerType.Middle"></MudDivider>
                                <h6>Supplier Info</h6>
                            </MudItem>
                            <MudItem xs="12" md="6">
                                <PartySelector NatureOfBusiness="Supplier" label="Vendor" @bind-Value="model.VendorInfo" For="@(() => model.VendorInfo)"></PartySelector>
                                @*    <MudSelect Label="Select Vendor Info" @bind-Value="model.VendorInfo" T="PartyModel" Variant="Variant.Outlined" Margin="Margin.Dense" OffsetY="true" Direction="Direction.Top" AdornmentColor="Color.Secondary" ToStringFunc="@(e => e == null ? null : $"{e.TradeName}")">
                            @foreach (var ditem in vendorListList)
                            {
                            <MudSelectItem Value="@ditem">@ditem.TradeName</MudSelectItem>
                            }
                            </MudSelect> *@
                            </MudItem>
                            <MudItem xs="12" md="6">
                                <MudDatePicker Label="Warrenty Date" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.WarrentyDate)" DisableToolbar="true" Editable="true" DateFormat="dd/MM/yyyy" @bind-Date="model.WarrentyDate" />
                            </MudItem>


                            <MudItem xs="12">
                                <MudDivider DividerType="DividerType.Middle"></MudDivider>
                                <h6>Gst Info</h6>
                            </MudItem>
                            <MudItem xs="12" md="6">
                                <MudSelect Label="Select GST Rate" @bind-Value="model.GstRateID" T="int?" Variant="Variant.Outlined" Margin="Margin.Dense" AdornmentColor="Color.Secondary">
                                    @foreach (var ditem in gstRate)
                                    {
                                        <MudSelectItem Value="@ditem.RID">@ditem.TaxRate</MudSelectItem>
                                    }
                                </MudSelect>
                            </MudItem>
                            <MudItem xs="12" md="6">
                                <MudSelect Label="Gst Mechanism" @bind-Value="model.GstMechanism" T="string" Variant="Variant.Outlined" Margin="Margin.Dense" AdornmentColor="Color.Secondary">
                                    @foreach (var ditem in gstMechanismList)
                                    {
                                        <MudSelectItem Value="@ditem">@ditem</MudSelectItem>
                                    }
                                </MudSelect>
                            </MudItem>

                            <MudItem xs="12">
                                <MudDivider DividerType="DividerType.Middle"></MudDivider>
                                <h6>Depreciation Info</h6>
                            </MudItem>
                            <MudItem xs="12" md="6">
                                <MudSelect Label="Select Depreciation Book Code" @bind-Value="model.DepreciationBookCode" T="string" Variant="Variant.Outlined" Margin="Margin.Dense" OffsetY="true" Direction="Direction.Top" AdornmentColor="Color.Secondary">
                                    <MudSelectItem Value="@("IncomeTax")">Income Tax</MudSelectItem>
                                    <MudSelectItem Value="@("CompanyAct")">Company Act</MudSelectItem>
                                </MudSelect>
                            </MudItem>
                            <MudItem xs="12" md="6">
                                <MudSelect Label="Select Depreciation Method" @bind-Value="model.DepreciationMethod" T="string" Variant="Variant.Outlined" Margin="Margin.Dense" OffsetY="true" Direction="Direction.Top" AdornmentColor="Color.Secondary">
                                    <MudSelectItem Value="@("StraigtLine")">Straigt Line</MudSelectItem>
                                    <MudSelectItem Value="@("DiminishingBalance")">Diminishing Balance</MudSelectItem>
                                    <MudSelectItem Value="@("SumofYearsDigits")">Sum of Years Digits</MudSelectItem>
                                </MudSelect>
                            </MudItem>
                            <MudItem xs="12" md="6">
                                <MudTextField @bind-Value="model.RateOfDepreciation" Label="Rate Of Depreciation" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.RateOfDepreciation)"></MudTextField>
                            </MudItem>
                            <MudItem xs="12" md="6">
                                <MudDatePicker Label="Depreciation Starting Date" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.DepreciationStartingDate)" DisableToolbar="true" Editable="true" DateFormat="dd/MM/yyyy" Date="model.DepreciationStartingDate" DateChanged="DepreciationStartingDateChanged" />
                            </MudItem>
                            <MudItem xs="12" md="6">
                                <MudDatePicker Label="Depreciation Ending Date" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.DepreciationEndingDate)" DisableToolbar="true" Editable="true" DateFormat="dd/MM/yyyy" @bind-Date="model.DepreciationEndingDate" />
                            </MudItem>
                            <MudItem xs="12" md="6">
                                <MudTextField @bind-Value="model.BookValue" Label="Book Value" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.BookValue)"></MudTextField>
                            </MudItem>
                            <MudItem xs="12" md="6">
                                <MudDatePicker Label="Projected Disposal Date" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.ProjectedDisposalDate)" DisableToolbar="true" Editable="true" DateFormat="dd/MM/yyyy" Date="model.ProjectedDisposalDate" DateChanged="ProjectedDisposalDateChanged" />
                            </MudItem>
                            <MudItem xs="12" md="6">
                                <MudTextField @bind-Value="model.SpanOfYear" Label="Span Of Year" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.SpanOfYear)" Disabled></MudTextField>
                             </MudItem>
                            <MudItem xs="12" md="6">
                                <MudTextField @bind-Value="model.SalvageValue" Label="Salvage Value" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.SalvageValue)"></MudTextField>
                            </MudItem>
                            <MudItem xs="12" md="6">
                                <MudTextField @bind-Value="model.CurrentValue" Label="Current Value" Variant="Variant.Outlined" Margin="Margin.Dense" Disabled="true"></MudTextField>
                            </MudItem>
                        }
                    </MudGrid>

                </MudPaper>              

            </MudContainer>
        </EditForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton form="assetForm" Disabled="@_busy" Variant="Variant.Filled" Color="Color.Success" ButtonType="ButtonType.Submit">Submit</MudButton>
    </DialogActions>
</MudDialog>

@code {

    [Parameter]
    public AssetModel model { get; set; }

    private List<string> NatureOfAssetList = new List<string>() { "Tangible", "Intangible" };
    private List<string> gstMechanismList = new List<string>() { "FCM", "RCM", "INELIGIBLE" };
    private List<AssetClassModel> assetclassList = new();
    private List<AssetSubClassModel> assetsubclassList = new();
    private List<PartyModel> vendorListList = new();
    private List<GstRateModel> gstRate = new();
    private bool _busy;
    [CascadingParameter] MudDialogInstance MudDialog { get; set; }

    bool HasPermissionAssetServiceEdit { get; set; } = false;
    int AssetDocTypeID = 112;

    int BranchID; 


    protected override async Task OnInitializedAsync()
    {
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionAssetServiceEdit = await Irole.HasClaim(AssetDocTypeID.ToString(), "Edit", ctc.Token);

        assetclassList = assetclassIservice.SelectClasses().ToList();
        vendorListList = partyIservice.GetVendors(string.Empty).ToList();
        gstRate = gstIservice.GetGstRates().ToList();
        if (model != null && model.AssetID != null)
        {
            if (model.AssetClass != null && assetclassList != null && assetclassList.Any(s => s.AssetClassID == model.AssetClass.AssetClassID))
            {
                model.AssetClass = assetclassList.FirstOrDefault(s => s.AssetClassID == model.AssetClass.AssetClassID);
                if (model.AssetClass != null && model.AssetClass.AssetClassID != null)
                {
                    assetsubclassList = assetclassIservice.SelectSubClassesByClass(model.AssetClass.AssetClassID.Value).ToList();
                    if (model.SubClass != null && model.SubClass.AssetSubClassID != null && assetsubclassList.Any(g => g.AssetSubClassID == model.SubClass.AssetSubClassID))
                    {
                        model.SubClass = assetsubclassList.FirstOrDefault(g => g.AssetSubClassID == model.SubClass.AssetSubClassID);
                    }
                }
            }
            if (model.VendorInfo != null && model.VendorInfo.PartyID != null && vendorListList != null && vendorListList.Any(d => d.PartyID == model.VendorInfo.PartyID))
            {
                model.VendorInfo = vendorListList.FirstOrDefault(d => d.PartyID == model.VendorInfo.PartyID);
            }
        }
    }

    public void getSubClass()
    {
        assetsubclassList = assetclassIservice.SelectSubClassesByClass(model.AssetClass.AssetClassID.Value).ToList();
    }
    public void ProjectedDisposalDateChanged(DateTime? date)
    {
        model.ProjectedDisposalDate = date;
        CalculateSpanOfYear();
    }
    public void DepreciationStartingDateChanged(DateTime? date)
    {
        model.DepreciationStartingDate = date;
        CalculateSpanOfYear();
    }
    public void CalculateSpanOfYear()
    {
        if (model.ProjectedDisposalDate != null && model.DepreciationStartingDate != null)
        {
            int spanOfYear = ((model.ProjectedDisposalDate.Value.Year) - (model.DepreciationStartingDate.Value.Year));
            model.SpanOfYear = spanOfYear;
        }
    }

    private void Cancel()
    {
        MudDialog.Cancel();
    }

    private async void ValidSubmit(EditContext context)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is being submitted!", Severity.Warning);
            return;
        }
        _busy = true;

        if (HasPermissionAssetServiceEdit)
        {
            var authprov = await auth.GetAuthenticationStateAsync();
            var user = authprov.User;
            var brancIDString = authprov.User.Claims.First(x => x.Type == "BranchID").Value;
            int brancID = int.Parse(brancIDString);
            model.BranchID = brancID;
            model.UserInfo.UserID = user.Identity.Name;
            try
            {
                Iservice.UpdateAsset(model);
                MudDialog.Close(model);
                model = new();
                snackbar.Add("Saved Successfully", Severity.Success);
            }
            catch (Exception ex)
            {
                snackbar.Add(ex.Message, Severity.Warning);
            }
        }
        else
        {
            bool? result = await DialogService.ShowMessageBox(
                "Permission denied!",
                "You dont have any permission to Edit Asset.");
        }
        await Task.Delay(200);
        _busy = false;
        StateHasChanged();
    }
}