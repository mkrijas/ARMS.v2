@page "/AssetSimpleView"
@inject ITaxPurchaseService Iservice
@inject MudBlazor.ISnackbar snackbar

@inject AuthenticationStateProvider auth
@attribute [Authorize]
@inject IDialogService DialogService


<MudGrid Spacing="4">
   <MudItem xs="12" md="12">
     <MudTextField @bind-Value="model.Description" Label="Description" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.Description)"></MudTextField>
        </MudItem>
         <MudItem xs="12" md="3">
     <MudTextField @bind-Value="model.AssetCode" Label="AssetCode" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.AssetCode)"></MudTextField>
        </MudItem>
          <MudItem xs="12" md="3">
     <MudTextField @bind-Value="model.SerialNumber" Label="SerialNumber" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.SerialNumber)"></MudTextField>
        </MudItem>
          <MudItem xs="12" md="3">
     <MudTextField @bind-Value="model.NatureOfAsset" Label="Description" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.Description)"></MudTextField>
        </MudItem>
          <MudItem xs="12" md="3">
     <MudTextField @bind-Value="model.AssetClass" Label="Description" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.Description)"></MudTextField>
        </MudItem>

  </MudGrid>

@code {
    public AssetModel model = new AssetModel();

}
