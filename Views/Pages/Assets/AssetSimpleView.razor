@page "/AssetSimpleVieww"
@inject IAssetService Iservice
@inject IAssetClassService assetclassIservice
@inject IGstUsageIDService gstIservice
@inject IPartyService partyIservice
@inject MudBlazor.ISnackbar snackbar

@inject AuthenticationStateProvider auth
@attribute [Authorize]
@inject IDialogService DialogService


<MudGrid Spacing="4">
     <MudItem xs="12">
          <MudText Typo="Typo.h6">Simple Asset</MudText>
                <MudTooltip Text="New Simple Asset">
                <MudIconButton  Icon="@Icons.Material.Filled.Add" Title="Add" @onclick="@(()=> OpenDialog(model))"  Color="Color.Dark" Size="Size.Small"></MudIconButton>
                </MudTooltip>
                  <MudTooltip Text="New Complex Asset">
                <MudIconButton  Icon="@Icons.Material.Filled.Add" Title="Add" @onclick="@(()=> OpenDialogComplexAsset(model))"  Color="Color.Dark" Size="Size.Small"></MudIconButton>
                </MudTooltip>
     </MudItem>
  

 <MudItem xs="12" md="12">
    <MudTable Hover="true" Breakpoint="Breakpoint.Sm" Height="500px" FixedHeader="true"
          Items="@collection"
          GroupBy="@_groupDefinition"
          GroupHeaderStyle="background-color:var(--mud-palette-background-grey)"
          GroupFooterClass="mb-4"
          Dense="true"
        >
    <HeaderContent>
        <MudTh>Description</MudTh>
        <MudTh>SerialNumber</MudTh>
        <MudTh>AssetCode</MudTh>
        <MudTh>NatureOfAsset</MudTh>
       <MudTh></MudTh>
    </HeaderContent>
    <GroupHeaderTemplate>
       
        <MudTh Class="mud-table-cell-custom-group" colspan="5">@($"{context.Key}")</MudTh>
   @*  <MudTd DataLabel="Nr">@context.Description</MudTd>
        <MudTd DataLabel="Sign">@context.SerialNumber</MudTd>
        <MudTd DataLabel="Name">@context.AssetCode</MudTd>
        <MudTd DataLabel="Group">@context.NatureOfAsset</MudTd>*@

   </GroupHeaderTemplate>
    <RowTemplate>
        <MudTd DataLabel="Nr">@context.Description</MudTd>
        <MudTd DataLabel="Sign">@context.SerialNumber</MudTd>
        <MudTd DataLabel="Name">@context.AssetCode</MudTd>
        <MudTd DataLabel="Group">@context.NatureOfAsset</MudTd>
         <MudTd DataLabel="">
            <MudFab @onclick="@(()=> OpenDialogComplexAsset(context))" Color="Color.Primary" Icon="@Icons.Material.Filled.Add" Size="Size.Small" IconSize="Size.Small" />
      </MudTd>
@*        <MudTd Style="text-align:right" DataLabel="Molar mass">@context.Molar</MudTd>
    *@</RowTemplate>
 @*   <GroupFooterTemplate>
        <MudTh Class="mud-table-cell-custom-group mud-table-cell-custom-group-footer" colspan="6">Total Mass: 12)</MudTh>
    </GroupFooterTemplate>*@
</MudTable>
</MudItem>
    </MudGrid>
@code {
    private AssetModel model = new AssetModel();
    private List<AssetModel> collection = new List<AssetModel>();
    DialogOptions maxWidth = new DialogOptions() { MaxWidth = MaxWidth.Medium, FullWidth = true };
    protected override async Task OnInitializedAsync()
    {
        model = new();
        await GetAll();
    }
    private  async Task GetAll()
    {
        var authprov = await auth.GetAuthenticationStateAsync();
        var brancIDString = authprov.User.Claims.First(x => x.Type == "BranchID").Value;
        int brancID = int.Parse(brancIDString);
        collection = new List<AssetModel>();
        collection = Iservice.SelectByBranch(brancID,false).ToList();
    }  
    private async Task OpenDialog(AssetModel tds)
    {
        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;
        model.IsComplex = false;
        DialogParameters parms = new DialogParameters();
        parms.Add("model",tds);
        var dialog =  DialogService.Show<AssetSimpleDialog>(tds.AssetID == null?"ADD":"EDIT",parms,maxWidth);
        var result = await dialog.Result;

        if(!result.Cancelled)
        { 
           await GetAll();
        }
    }
    private async Task OpenDialogComplexAsset(AssetModel tds)
    {
        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;
        model.IsComplex = true;
        if(tds.AssetID!=null)
        {
             model.ParentAssetID = tds.AssetID;
        }
       
        DialogParameters parms = new DialogParameters();
        parms.Add("model",model);
        var dialog =  DialogService.Show<AssetSimpleDialog>(model.AssetID == null?"ADD":"EDIT",parms,maxWidth);
        var result = await dialog.Result;
        if(!result.Cancelled)
        {
           await GetAll();
        }
    }
    private TableGroupDefinition<AssetModel> _groupDefinition = new TableGroupDefinition<AssetModel>()
    {
        GroupName = "Group",
        Indentation = false,
        Expandable = true,
        Selector = (e) => e.ParentAssetID,
        InnerGroup = new TableGroupDefinition<AssetModel>()
        {
            GroupName = "Asset",
            Expandable = false,
            Selector = (e) => e.AssetID
        }

    };
   
  
}
