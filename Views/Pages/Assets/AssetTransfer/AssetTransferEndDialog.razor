@inject AuthenticationStateProvider auth
@inject IAssetTransferService Iservice
@inject IAssetService Iassetservice
@inject ITruckService Itruckservice
@inject IBranchService Ibranchservice
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject IConfigTable config

@using System.Threading;
@inject IRoleService<RoleModel> Irole

<style>
    .completed {
        text-decoration: line-through;
    }

    .border {
        border: 10px solid black;
        border-radius: 10px;
        padding: 10px;
    }
</style>

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.Edit" Class="mr-3" /> Accept Or Reject Asset
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudContainer Style="max-height: 400px; overflow-y: scroll;">
            <EditForm Model="@model" OnValidSubmit="() => Accept(Checklist)">
                <ObjectGraphDataAnnotationsValidator />
                <ValidationSummary />
                <MudGrid>
                    <MudItem xs="12" md="12">
                        <MudTextField Value="model.Asset.Description" Label="Asset" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.Asset.Description)" Disabled></MudTextField>
                    </MudItem>
                    <MudItem xs="12" md="12">
                        @if (ChildAssets != null && ChildAssets.Any())
                        {
                            <MudText Typo="Typo.body1">Following assets will be transferred along with the above asset</MudText>
                            <div class="d-flex">
                                @foreach (var asset in ChildAssets)
                                {
                                    <div class="m-2"><b>@asset.Description</b></div>
                                    @if (!asset.Equals(ChildAssets.Last()))
                                    {
                                        <div class="m-2">|</div>
                                    }
                                }
                            </div>
                        }
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudTextField @bind-Value="model.InitiatedBranch.BranchName" Label="Initiated Branch" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.InitiatedBranch.BranchName)" Disabled></MudTextField>
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudDatePicker Label="Date" Variant="Variant.Outlined" Margin="Margin.Dense" DisableToolbar="true" Editable="true" @bind-Date="model.AssetTransferEndModel.TransferEndDate" DateFormat="dd/MM/yyyy" />
                    </MudItem>
                    <MudItem xs="12" md="12">
                        <MudTextField @bind-Value="model.AssetTransferEndModel.Remarks" Label="Remarks" Lines="3" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.Remarks)"></MudTextField>
                    </MudItem>
                    <MudItem xs="12" md="12">
                        @if (Checklist != null && Checklist.Any())
                        {
                            <MudText Typo="Typo.h6">Checklist</MudText>
                            <br />
                            <MudContainer>
                                <MudGrid class="border">
                                    @foreach (var item in Checklist)
                                    {
                                        <MudItem xs="3">
                                            <MudTextField Form="" @bind-Value="item.SettingsDescription" Label="@item.SettingsName" Variant="Variant.Text" Margin="Margin.Dense" ReadOnly></MudTextField>
                                        </MudItem>
                                        <MudItem xs="3">
                                            <MudCheckBox Color="Color.Primary" @bind-Checked="@item.IsRecieved"></MudCheckBox>
                                        </MudItem>
                                    }
                                </MudGrid>
                            </MudContainer>
                        }
                    </MudItem>
                    <MudItem xs="12" Class="d-flex">
                        <MudText Typo="Typo.h6">Transfer Images</MudText>
                        <MudSpacer />
                    </MudItem>
                    <MudGrid Style="padding: 24px;" Spacing="2" Justify="Justify.Center">
                        @foreach (var imagePath in model?.ImagePath)
                        {
                            @if (imagePath != "")
                            {
                                <MudItem xs="12" md="6" Class="d-flex">
                                    <MudPaper Class="p-2 position-relative" Elevation="3">
                                        <img src="@imagePath" alt="@imagePath" class="w-100" />
                                    </MudPaper>
                                </MudItem>
                            }
                        }
                    </MudGrid>
                </MudGrid>
            </EditForm>
        </MudContainer>
    </DialogContent>
    <DialogActions>
        <MudButton Disabled="@_busy" Variant="Variant.Filled" Color="Color.Primary" OnClick="() => Accept(Checklist)" Class="px-12">Accept Asset</MudButton>
        @if (model.AssetTransferEndModel.TransferStatus == null)
        {
            <MudButton Disabled="@_busy" Variant="Variant.Filled" Color="Color.Primary" OnClick="() => Reject(Checklist)" Class="px-12">Reject Asset</MudButton>
        }
    </DialogActions>
</MudDialog>

@code {

    [CascadingParameter] MudDialogInstance MudDialog { get; set; }
    [Parameter]
    public AssetTransferInitiationModel model { get; set; } = new();
    public int IsCompleted;
    [Parameter]
    public List<AssetModel> ChildAssets { get; set; } = new();
    [Parameter]
    public List<AssetSettingsModel> Checklist { get; set; } = new();
    public int? SubClassID { get; set; } = new();
    public int? TruckID { get; set; } = new();
    int? AssetSubClassID;
    private bool _busy;
    MyFileUpload Mfu;

    public bool HasPermissionAssetTransferServiceAccept { get; set; } = false;
    public bool HasPermissionAssetTransferServiceReject { get; set; } = false;
    public int AssetTransferDocTypeID = 110;

    // Lifecycle method called when the component is initialized
    protected override async Task OnInitializedAsync()
    {
        CancellationTokenSource ctc = new CancellationTokenSource();
        // Check user permissions for accepting and rejecting asset transfers
        HasPermissionAssetTransferServiceAccept = await Irole.HasClaim(AssetTransferDocTypeID.ToString(), "Accept", ctc.Token);
        HasPermissionAssetTransferServiceReject = await Irole.HasClaim(AssetTransferDocTypeID.ToString(), "Reject", ctc.Token);

        branchID = model?.DestinationBranch?.BranchID ?? 0;

        // Check user permissions for accepting and rejecting asset transfers
        Checklist = Iservice.GetCheckList(model.AssetTransferID).ToList();

        // Retrieve the subclass ID for the asset
        SubClassID = Iassetservice.SelectByID(model.Asset.AssetID).SubClass.AssetSubClassID;

        // Get the configuration model for asset subclasses related to trucks
        ConfigModel cModel = config.GetAssetSubclassForTrucks();
        AssetSubClassID = int.Parse(cModel.ValueString);
    }

    private int branchID { get; set; } = 0;

    // Method to cancel the dialog
    void Cancel()
    {
        MudDialog.Cancel();
    }

    // Method to accept the asset transfer
    public async Task Accept(List<AssetSettingsModel> context)
    {
        if (_busy)
        {
            Snackbar.Add("Please wait while form is being submitted!", Severity.Warning);
            return;
        }
        _busy = true;

        if (HasPermissionAssetTransferServiceAccept)
        {
            var authprov = await auth.GetAuthenticationStateAsync();
            var user = authprov.User;

            if (model != null)
            {
                model.IsAssetReject = 0; // Set rejection status to false
                try
                {
                    List<int?> RecievedList = context.Where(s => s.IsRecieved ?? false).Select(d => d.SettingsID).ToList();
                    model.UserInfo.UserID = user.Identity.Name;
                    model.AssetTransferEndModel.TransferStatus = true;
                    if (SubClassID == AssetSubClassID)
                    {
                        TruckID = Itruckservice.SelectByAsset(model.Asset.AssetID).TruckID; // Get the truck ID
                        Iservice.UpdateStatus(model, TruckID, RecievedList); // Update the status with truck ID
                    }
                    else
                    { 
                        Iservice.UpdateStatus(model, null, RecievedList); // Update the status without truck ID
                    }
                    Snackbar.Add("Transfered succesfully", Severity.Success);
                }
                catch (Exception ex)
                {
                    Snackbar.Add(ex.Message, Severity.Error);
                }
            }
            MudDialog.Close(model);
        }
        else
        {
            bool? result = await DialogService.ShowMessageBox(
                "Permission denied!",
                "You don't have any permission to Accept AssetTransfer.");
        }
        await Task.Delay(200);
        _busy = false;
    }

    // Method to reject the asset transfer
    public async Task Reject(List<AssetSettingsModel> context)
    {
        if (_busy)
        {
            Snackbar.Add("Please wait while form is being submitted!", Severity.Warning);
            return;
        }
        _busy = true;

        if (HasPermissionAssetTransferServiceReject)
        {
            var authprov = await auth.GetAuthenticationStateAsync();
            var user = authprov.User;
            if (model != null)
            {
                model.IsAssetReject = 1; // Set rejection status to true
                try
                {
                    List<int?> RecievedList = context.Where(s => s.IsRecieved ?? false).Select(d => d.SettingsID).ToList();
                    model.UserInfo.UserID = user.Identity.Name;
                    model.AssetTransferEndModel.TransferStatus = false;
                    if (SubClassID == AssetSubClassID)
                    {
                        TruckID = Itruckservice.SelectByAsset(model.Asset.AssetID).TruckID; // Get the truck ID
                        Iservice.UpdateStatus(model, TruckID, RecievedList); // Update the status with truck ID
                    }
                    else
                    {
                        Iservice.UpdateStatus(model, null, RecievedList); // Update the status without truck ID
                    }
                    Snackbar.Add("Asset Transfer Rejected", Severity.Error);

                }
                catch (Exception ex)
                {
                    Snackbar.Add(ex.Message, Severity.Error);
                }
            }
            MudDialog.Close(model);
        }
        else
        {
            bool? result = await DialogService.ShowMessageBox(
                "Permission denied!",
                "You don't have any permission to Reject AssetTransfer.");
        }
        await Task.Delay(200);
        _busy = false;
    }
}