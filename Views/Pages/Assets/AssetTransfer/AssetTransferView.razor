@page "/AssetTransferView"
@using ArmsModels.BaseModels.General
@using ArmsServices.DataServices.General
@using Microsoft.AspNetCore.SignalR.Client;
@using Views.Data
@using Core.BaseModels.Finance.Transactions;
@using Pages.Operations.Expenses
@inject IAssetService Iassetservice
@inject IAssetTransferService Iservice
@inject ITripFuelService tripFuelIservice
@inject ITruckService Itruckservice
@inject IPushNotificationService IpushNotificationService
@inject MudBlazor.ISnackbar snackbar
@inject IConfigTable config
@inject AuthenticationStateProvider auth
@attribute [Authorize]
@inject IDialogService DialogService
@inject IBranchService Ibranchservice
@inject NavigationManager NavigationManager
@inject SignalRService signalRService
@using System.Threading;
@inject IRoleService<RoleModel> Irole

<MudGrid Spacing="4">
    <MudItem xs="12">
        <MudTabs Elevation="2" Rounded="true" ApplyEffectsToContainer="true" PanelClass="px-4 py-6">
            <MudTabPanel Text="Outgoing" BadgeData="@(collectionOutGoing?.Count > 0 ? collectionOutGoing.Count : null)" BadgeColor="Color.Info" Visible="@(collectionOutGoing?.Count > 0)">
                <MudItem>
                    <MudText Typo="Typo.h6">
                        Initiate Transfer
                        <MudTooltip Text="New Asset Transfer">
                            <MudIconButton Disabled="@_busy" Icon="@Icons.Material.Filled.Add" Title="Add" @onclick="@(()=> OpenDialogEditOutGoing(new AssetTransferInitiationModel()))" Color="Color.Dark" Size="Size.Small"></MudIconButton>
                        </MudTooltip>
                    </MudText>
                </MudItem>
                <MudGrid Class="mud-cols-xs-1 mud-cols-md-2 mud-cols-lg-2">
                    @foreach (var item in collectionOutGoing)
                    {
                        <MudItem sm="12" xl="4" lg="6">
                            <MudCard Class="mt-3" Style="height:auto" Elevation="4">
                                <MudCardHeader>
                                    <CardHeaderAvatar>
                                        <MudAvatar Color="Color.Tertiary"><MudIcon Icon="@Icons.Material.Filled.ShoppingCart" Title="Trip Number" Color="Color.Primary" /></MudAvatar>
                                    </CardHeaderAvatar>
                                    <CardHeaderContent>
                                        <MudGrid>
                                            <MudItem xs="6">
                                                <MudText Typo="Typo.h6" GutterBottom="true">
                                                    <b>@item.Asset.AssetCode | @item.Asset.Description</b>
                                                </MudText>
                                            </MudItem>
                                        </MudGrid>
                                    </CardHeaderContent>
                                    <CardHeaderActions>
                                        <MudTooltip Text="Edit">
                                            <MudIconButton @onclick="@(()=> OpenDialogEditOutGoing(item))" Color="Color.Primary" Icon="@Icons.Material.Filled.Edit" Size="Size.Medium" IconSize="Size.Small" />
                                        </MudTooltip>
                                        <MudTooltip Text="Remove">
                                            <MudIconButton @onclick="@(()=> OpenDialogDeleteOutGoing(item))" Color="Color.Warning" Icon="@Icons.Material.Filled.Cancel" Size="Size.Medium" IconSize="Size.Small" />
                                        </MudTooltip>
                                    </CardHeaderActions>
                                </MudCardHeader>
                                <MudCardContent>
                                    <MudList Style="width:700px">
                                        <MudGrid>
                                            <MudItem md="5">
                                                <MudListItem Avatar="@Icons.Material.Filled.DateRange" IconColor="Color.Primary">
                                                    <b>@item.TransferInitiatedDate</b>
                                                </MudListItem>
                                                <MudListItem Avatar="@Icons.Material.Filled.Approval" IconColor="Color.Primary">
                                                    Status : <b>@item.AssetTransferEndModel.StatusText</b>
                                                </MudListItem>
                                                <MudListItem Avatar="@Icons.Material.Filled.MenuBook" IconColor="Color.Primary">
                                                    Total Expense : <b>@item?.Expenses</b>
                                                </MudListItem>
                                            </MudItem>

                                            <MudItem md="5">
                                                <MudListItem Avatar="@Icons.Material.Filled.Warehouse" IconColor="Color.Primary">
                                                    Destination Branch : <b>@item.DestinationBranch.BranchName</b>
                                                </MudListItem>
                                                <MudListItem Avatar="@Icons.Material.Filled.EditNote" IconColor="Color.Primary">
                                                    Remarks : <b>@item?.Remarks</b>
                                                </MudListItem>
                                                <MudListItem Avatar="@Icons.Material.Filled.LocalGasStation" IconColor="Color.Primary">
                                                    Total Fuel : <b>@item?.Fuel</b>
                                                </MudListItem>
                                            </MudItem>
                                        </MudGrid>
                                    </MudList>
                                </MudCardContent>
                            </MudCard>
                        </MudItem>
                    }
                </MudGrid>
            </MudTabPanel>
            <MudTabPanel Text="Incoming" BadgeData="@(collectionIncoming?.Count > 0 ? collectionIncoming.Count : null)" BadgeColor="Color.Info" Visible="@(collectionIncoming?.Count > 0)">
                <MudGrid Class="mud-cols-xs-1 mud-cols-md-2 mud-cols-lg-2">
                    @foreach (var item in collectionIncoming)
                    {
                        <MudItem sm="12" xl="4" lg="6">
                            <MudCard Class="mt-3" Style="height:auto" Elevation="4">
                                <MudCardHeader>
                                    <CardHeaderAvatar>
                                        <MudAvatar Color="Color.Tertiary"><MudIcon Icon="@Icons.Material.Filled.ShoppingCart" Title="Trip Number" Color="Color.Primary" /></MudAvatar>
                                    </CardHeaderAvatar>
                                    <CardHeaderContent>
                                        <MudGrid>
                                            <MudItem xs="6">
                                                <MudText Typo="Typo.h6" GutterBottom="true">
                                                    <b>@item.Asset.AssetCode | @item.Asset.Description</b>
                                                </MudText>
                                            </MudItem>
                                        </MudGrid>
                                    </CardHeaderContent>
                                    <CardHeaderActions>
                                        <MudTooltip Text="Add Fuel">
                                            <MudIconButton Icon="@Icons.Material.Filled.LocalGasStation" Size="Size.Large" Color="Color.Success" @onclick="@(()=> OpenFuelForm(new TripFuelModel(){AssetTransferID = item.AssetTransferID}))" />
                                        </MudTooltip>
                                        <MudTooltip Text="Add Expenses">
                                            <MudIconButton Icon="@Icons.Material.Filled.MenuBook" Color="Color.Success" Size="Size.Large" @onclick="@(()=> OpenExpenseForm(new OpTranModel(){AssetTransferID = item.AssetTransferID}))" />
                                        </MudTooltip>
                                        <MudTooltip Text="Add Mileage Shortage Receipt">
                                            <MudIconButton Icon="@Icons.Material.Filled.Toll" Color="Color.Success" Size="Size.Large" @onclick="@(()=> OpenMileageShortageReceipt(new MileageShortageReceiptModel(){AssetTransferID = item.AssetTransferID}))" />
                                        </MudTooltip>
                                        <MudTooltip Text="Accept/Reject">
                                            <MudIconButton @onclick="@(()=> OpenDialogEditIncoming(item))" Color="Color.Primary" Icon="@Icons.Material.Filled.AddTask" Size="Size.Medium" IconSize="Size.Small" />
                                        </MudTooltip>
                                    </CardHeaderActions>
                                </MudCardHeader>
                                <MudCardContent>
                                    <div class="TabStyle">
                                        <MudList Style="width:700px">
                                            <MudGrid>
                                                <MudItem md="5">
                                                    <MudListItem Avatar="@Icons.Material.Filled.DateRange" IconColor="Color.Primary">
                                                        <b>@item.TransferInitiatedDate</b>
                                                    </MudListItem>
                                                    <MudListItem Avatar="@Icons.Material.Filled.Approval" IconColor="Color.Primary">
                                                        Status : <b>@item.AssetTransferEndModel.StatusText</b>
                                                    </MudListItem>
                                                    <MudListItem Avatar="@Icons.Material.Filled.MenuBook" IconColor="Color.Primary">
                                                        Total Expense : <b>@item?.Expenses</b>
                                                    </MudListItem>
                                                </MudItem>
                                                <MudItem md="5">
                                                    <MudListItem Avatar="@Icons.Material.Filled.Warehouse" IconColor="Color.Primary">
                                                        Initiation Branch : <b>@item.InitiatedBranch.BranchName</b>
                                                    </MudListItem>
                                                    <MudListItem Avatar="@Icons.Material.Filled.EditNote" IconColor="Color.Primary">
                                                        Remarks : <b>@item?.Remarks</b>
                                                    </MudListItem>
                                                    <MudListItem Avatar="@Icons.Material.Filled.LocalGasStation" IconColor="Color.Primary">
                                                        Total Fuel : <b>@item?.Fuel</b>
                                                    </MudListItem>
                                                </MudItem>
                                            </MudGrid>
                                        </MudList>
                                    </div>
                                </MudCardContent>
                            </MudCard>
                        </MudItem>
                    }
                </MudGrid>
            </MudTabPanel>
        </MudTabs>
    </MudItem>
</MudGrid>

@code {

    int CurrentBranchId = 0;
    private List<BranchModel> BranchList = new();

    #region SignaIR Notification

    private PushNotificationModel notificationMessage = new PushNotificationModel();

    #endregion
    DialogOptions maxWidth = new DialogOptions() { MaxWidth = MaxWidth.Large, FullWidth = true, CloseButton = true, CloseOnEscapeKey = true };
    private List<OpTranModel> OptranList = new();
    private List<TripFuelModel> TFuelList = new();
    public int? SubClassID { get; set; } = new();
    public int? TruckID { get; set; } = new();
    int? AssetTrucksSubClassID;
    private bool _busy;

    public bool HasPermissionAssetTransferServiceDelete { get; set; } = false;
    public int AssetTransferDocTypeID = 110;

    protected override async Task OnInitializedAsync()
    {
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionAssetTransferServiceDelete = await Irole.HasClaim(AssetTransferDocTypeID.ToString(), "Delete", ctc.Token);

        BranchList = Ibranchservice.Select().ToList();
        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;
        var brancIDString = authprov.User.Claims.First(x => x.Type == "BranchID").Value;
        CurrentBranchId = int.Parse(brancIDString);
        await signalRService.StartAsync();

        await GetAll();
    }

    private async Task GetAll()
    {
        await GetAllOutGoing();
        await GetAllIncoming();
    }

    #region Outgoing

    private AssetTransferInitiationModel modelOutGoing = new();
    private List<AssetTransferInitiationModel> collectionOutGoing = new();
    string state = "Message box hasn't been opened yet";

    private async Task GetAllOutGoing()
    {
        collectionOutGoing = new();
        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;
        var brancIDString = authprov.User.Claims.First(x => x.Type == "BranchID").Value;
        if (modelOutGoing.InitiatedBranch == null)
        {
            modelOutGoing.InitiatedBranch = new();
        }
        modelOutGoing.InitiatedBranch.BranchID = int.Parse(brancIDString);
        foreach (var item in Iservice.SelectOutgoingAssets(modelOutGoing.InitiatedBranch.BranchID))
        {
            collectionOutGoing.Add(item);
        }
    }

    private async Task OpenDialogEditOutGoing(AssetTransferInitiationModel AssetTransferInitiation)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        _busy = true;

        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;
        var brancIDString = authprov.User.Claims.First(x => x.Type == "BranchID").Value;

        if (AssetTransferInitiation.InitiatedBranch == null)
        {
            AssetTransferInitiation.InitiatedBranch = new();
        }
        if (AssetTransferInitiation.DestinationBranch == null)
        {
            AssetTransferInitiation.DestinationBranch = new();
        }
        if (AssetTransferInitiation.Asset == null)
        {
            AssetTransferInitiation.Asset = new();
        }
        AssetTransferInitiation.InitiatedBranch.BranchID = int.Parse(brancIDString);

        List<AssetModel> childAssets = Iassetservice.GetAttachedAssets(AssetTransferInitiation.Asset.AssetID).Skip(1).ToList();

        var modelOutGoing = new DialogParameters
            {
                ["model"] = AssetTransferInitiation,
                ["childAssets"] = childAssets
            };

        var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Medium };
        var dialog = DialogService.Show<AssetTransferInitiationDialog>("Simple Dialog", modelOutGoing, options);
        var result = await dialog.Result;
        var isCancelled = result.Cancelled;
        if (!isCancelled)
        {
            var ReturnData = (AssetTransferInitiationModel)result.Data;
            notificationMessage.InitiateBranch = BranchList?.FirstOrDefault(s => s.BranchID == Convert.ToInt32(ReturnData?.InitiatedBranch?.BranchID ?? 0)) ?? null;
            notificationMessage.ReceivedBranch = BranchList?.FirstOrDefault(s => s.BranchID == Convert.ToInt32(ReturnData?.DestinationBranch?.BranchID ?? 0)) ?? null;
            notificationMessage.MessageTitle = "Asset " + (ReturnData?.Asset?.Description ?? "") + " is transfered to this branch.";
            notificationMessage.MessageBody = "Asset " + (ReturnData?.Asset?.Description ?? "") + " is transfered from " + (notificationMessage?.InitiateBranch?.BranchName ?? "") + " to this branch on " + (DateTime.Now).ToString() + ".";
            notificationMessage.RedirectedTo = 0;
            notificationMessage.ExpiredBy = 7;
            notificationMessage.DocumentID = ReturnData.AssetTransferID;
            notificationMessage.MessageGroupID = "AssetTransfer";
            notificationMessage.PageToRedirectLink = "/AssetTransferView";
            notificationMessage.ClaimValue = "Edit";
            notificationMessage.DocumentTypeID = AssetTransferDocTypeID;
            notificationMessage.MsgDate = DateTime.Now;
            await signalRService.Send(notificationMessage);

            await GetAll();
        }
        await Task.Delay(200);
        _busy = false;
    }

    private async Task OpenDialogDeleteOutGoing(AssetTransferInitiationModel AssetTransferInitiation)
    {
        if (HasPermissionAssetTransferServiceDelete)
        {
            bool? result = await DialogService.ShowMessageBox(
                "Warning",
                "Are you sure you want to delete this entry?",
                yesText: "Delete!", cancelText: "Cancel");
            state = result == null ? "Cancelled" : "Deleted!";
            if (state == "Deleted!")
            {
                var authprov = await auth.GetAuthenticationStateAsync();
                var user = authprov.User;
                var brancIDString = authprov.User.Claims.First(x => x.Type == "BranchID").Value;
                try
                {
                    var BranchID = int.Parse(brancIDString);
                    var UserID = user.Identity.Name;
                    SubClassID = Iassetservice.SelectByID(AssetTransferInitiation.Asset.AssetID).SubClass.AssetSubClassID;
                    ConfigModel cModel = config.GetAssetSubclassForTrucks();
                    AssetTrucksSubClassID = int.Parse(cModel.ValueString);
                    if (SubClassID == AssetTrucksSubClassID)
                    {
                        TruckID = Itruckservice.SelectByAsset(AssetTransferInitiation.Asset.AssetID).TruckID;
                        Iservice.DeleteInitiation(AssetTransferInitiation.AssetTransferID, BranchID, AssetTransferInitiation.Asset.AssetID, TruckID, UserID);
                    }
                    else
                    {
                        Iservice.DeleteInitiation(AssetTransferInitiation.AssetTransferID, BranchID, AssetTransferInitiation.Asset.AssetID, null, UserID);
                    }
                    snackbar.Add("Asset Transfer Canceled", Severity.Warning);
                }
                catch (Exception ex)
                {
                    snackbar.Add(ex.Message, Severity.Error);
                }
                await GetAll();
            }
        }
        else
        {
            bool? result = await DialogService.ShowMessageBox(
                "Permission denied!",
                "You don't have any permission to Delete AssetTransfer.");
        }
    }

    #endregion

    #region Incoming

    private AssetTransferInitiationModel modelIncoming = new();
    private List<AssetTransferInitiationModel> collectionIncoming = new();

    private async Task GetAllIncoming()
    {
        collectionIncoming = new();
        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;
        var brancIDString = authprov.User.Claims.First(x => x.Type == "BranchID").Value;

        if (modelIncoming.AssetTransferEndModel == null)
        {
            modelIncoming.AssetTransferEndModel = new();
        }
        if (modelIncoming.DestinationBranch == null)
        {
            modelIncoming.DestinationBranch = new();
        }
        modelIncoming.DestinationBranch.BranchID = int.Parse(brancIDString);
        foreach (var item in Iservice.SelectIncomingAssets(modelIncoming.DestinationBranch?.BranchID ?? 0))
        {
            collectionIncoming.Add(item);
        }
    }

    private async Task OpenDialogEditIncoming(AssetTransferInitiationModel AssetTransferEnd)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        _busy = true;

        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;
        var brancIDString = authprov.User.Claims.First(x => x.Type == "BranchID").Value;

        if (AssetTransferEnd.AssetTransferEndModel == null)
        {
            AssetTransferEnd.AssetTransferEndModel = new();
        }
        if (AssetTransferEnd.DestinationBranch == null)
        {
            AssetTransferEnd.DestinationBranch = new();
        }
        AssetTransferEnd.DestinationBranch.BranchID = int.Parse(brancIDString);

        // Get the child assets for the selected asset
        List<AssetModel> childAssets = Iassetservice.GetAttachedAssets(AssetTransferEnd.Asset.AssetID).Skip(1).ToList();

        var modelIncoming = new DialogParameters
            {
                ["model"] = AssetTransferEnd,
                ["childAssets"] = childAssets
            };

        var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Medium };
        var dialog = DialogService.Show<AssetTransferEndDialog>("Simple Dialog", modelIncoming, options);
        var result = await dialog.Result;
        var isCancelled = result.Cancelled;

        if (!isCancelled)
        {
            var ReturnData = (AssetTransferInitiationModel)result.Data;
            if (ReturnData.IsAssetReject == 1)
            {
                notificationMessage.InitiateBranch = BranchList?.FirstOrDefault(s => s.BranchID == Convert.ToInt32(ReturnData?.DestinationBranch?.BranchID ?? 0)) ?? null;
                notificationMessage.ReceivedBranch = BranchList?.FirstOrDefault(s => s.BranchID == Convert.ToInt32(ReturnData?.InitiatedBranch?.BranchID ?? 0)) ?? null;
                notificationMessage.MessageTitle = "Asset " + (ReturnData?.Asset?.Description ?? "") + " is rejected.";
                notificationMessage.MessageBody = "Asset " + (ReturnData?.Asset?.Description ?? "") + " is rejected from " + (notificationMessage?.InitiateBranch?.BranchName ?? "") + " on " + (DateTime.Now).ToString() + ".";
                notificationMessage.RedirectedTo = 0;
                notificationMessage.MsgDate = DateTime.Now;
                notificationMessage.ExpiredBy = 7;
                notificationMessage.DocumentID = ReturnData.AssetTransferID;
                notificationMessage.MessageGroupID = "AssetTransfer";
                notificationMessage.PageToRedirectLink = "/AssetTransferView";
                notificationMessage.ClaimValue = "Edit";
                notificationMessage.DocumentTypeID = AssetTransferDocTypeID;
                await signalRService.Send(notificationMessage);
            }
            await GetAll();
        }
        await Task.Delay(200);
        _busy = false;
    }

    private async Task OpenFuelForm(TripFuelModel fuelModel)
    {
        DialogParameters parms = new DialogParameters();
        parms.Add("Tmodel", new TripFuelModel() { AssetTransferID = fuelModel.AssetTransferID });
        var dialog = DialogService.Show<TripsFuelDialog>("ADD FUEL", parms, maxWidth);
        var result = await dialog.Result;
    }

    private async Task OpenExpenseForm(OpTranModel tranModel)
    {
        DialogParameters parms = new DialogParameters();
        tranModel.PaymentMode = "Cash"; tranModel.Area = "Operation";
        parms.Add("model", tranModel.Clone());
        var dialog = DialogService.Show<Finance.Transactions.OpTranDialog>("ADD", parms, maxWidth);
        var result = await dialog.Result;
    }

    private async Task OpenMileageShortageReceipt(MileageShortageReceiptModel morModel)
    {

        DialogParameters parms = new DialogParameters();
        parms.Add("model", new MileageShortageReceiptModel()
            {
                AssetTransferID = morModel.AssetTransferID
            });
        var dialog = DialogService.Show<Finance.Transactions.MileageShortageReceiptDialog>("ADD", parms, maxWidth);
        var result = await dialog.Result;
    }

    #endregion
}