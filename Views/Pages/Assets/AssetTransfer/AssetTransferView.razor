@page "/AssetTransferView"
@using ArmsModels.BaseModels.General
@using ArmsServices.DataServices.General
@using Microsoft.AspNetCore.SignalR.Client;
@using Views.Data
@using Core.BaseModels.Finance.Transactions;
@inject IAssetService Iassetservice
@inject IAssetTransferService Iservice
@inject IPushNotificationService IpushNotificationService
@inject MudBlazor.ISnackbar snackbar
@inject IConfigTable config
@inject AuthenticationStateProvider auth
@attribute [Authorize]
@inject IDialogService DialogService
@inject IBranchService Ibranchservice
@inject NavigationManager NavigationManager
@inject SignalRService signalRService
@using System.Threading;
@inject IRoleService<RoleModel> Irole

@if (_isLoading)
{
    <div style="position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(255,255,255,0.9); z-index: 9999; display: flex; justify-content: center; align-items: center;">
        <LoaderComponent IsFullScreen="true" 
                        ShowLogo="false" 
                        Size="medium" 
                        LoadingText="Loading Asset Transfers" 
                        SubText="Please wait..." />
    </div>
}

<div class="admin-page-container">
    <div class="admin-header-tiered mb-6">
        <div class="d-flex align-center justify-space-between">
            <div>
                <MudText Typo="Typo.h4" Class="admin-title">Asset Transfers</MudText>
                <MudText Typo="Typo.body2" Class="admin-subtitle">Coordinate vehicle and equipment shifts between branches with full handover tracking.</MudText>
            </div>
            <MudButton StartIcon="@Icons.Material.Filled.Add" Variant="Variant.Filled" Color="Color.Primary" Class="admin-register-btn" OnClick="@(()=> OpenDialogEditOutGoing(new AssetTransferInitiationModel(),false))" Disabled="@_busy">INITIATE TRANSFER</MudButton>
        </div>
    </div>

    <div class="admin-glass-card pa-0 overflow-hidden">
        <MudTabs Elevation="0" Rounded="false" ApplyEffectsToContainer="true" PanelClass="pa-0" Centered="false">
            <MudTabPanel Style="min-width: 200px;" Text="Outgoing Asset" BadgeData="@(collectionOutGoing?.Count > 0 ? collectionOutGoing.Count : null)" BadgeColor="Color.Info" Visible="@(collectionOutGoing?.Count > 0)">
                <div class="admin-glass-card border-none rounded-0 elevation-0 mb-0 pa-4" style="background: rgba(255,255,255,0.4);">
                    <div class="d-flex align-center gap-4">
                        <div style="flex-grow: 1;">
                            <MudTextField @bind-Value="searchTermOut" Placeholder="Search Outgoing..." Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" Variant="Variant.Outlined" Margin="Margin.Dense" Class="admin-input-group" @onkeyup="HandleSearchKeyUpOut" Clearable="true" />
                        </div>
                        <div class="d-flex align-center gap-2">
                            <MudText Typo="Typo.body2" Class="admin-td-secondary fw-600">Max Results:</MudText>
                            <MudTextField @bind-Value="@NumberOfRecordsOut" Variant="Variant.Outlined" Margin="Margin.Dense" Style="width: 80px; background: white;" />
                        </div>
                        <MudCheckBox T="bool" Label="Approved" ValueChanged="((bool value)=>ApprovedToggledOut(value))" Value="@IsOutApproved" Size="Size.Small" Color="Color.Primary" Class="fw-600" />
                    </div>
                </div>
                <MudTable Items="@collectionOutGoing" Dense="true" Hover="true" Elevation="0" Class="modern-admin-table">
                    <HeaderContent>
                        <MudTh><MudTableSortLabel SortBy="new Func<AssetTransferInitiationModel, object>(x=> x.DocumentNumber)" InitialDirection="SortDirection.Descending"><span class="admin-header-text">DOC NO.</span></MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<AssetTransferInitiationModel, object>(x=> x.DestinationBranch)" InitialDirection="SortDirection.Descending"><span class="admin-header-text">DESTINATION</span></MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<AssetTransferInitiationModel, object>(x=> x.TransferInitiatedDate)" InitialDirection="SortDirection.Descending"><span class="admin-header-text">INITIATED</span></MudTableSortLabel></MudTh>
                        @if (IsOutApproved)
                        {
                            <MudTh><MudTableSortLabel SortBy="new Func<AssetTransferInitiationModel, object>(x=> x.AssetTransferEndModel.TransferEndDate)" InitialDirection="SortDirection.Descending"><span class="admin-header-text">COMPLETED</span></MudTableSortLabel></MudTh>
                        }
                        <MudTh><MudTableSortLabel SortBy="new Func<AssetTransferInitiationModel, object>(x=> x?.AssetTransferEndModel.StatusText)" InitialDirection="SortDirection.Descending"><span class="admin-header-text">STATUS</span></MudTableSortLabel></MudTh>
                        <MudTh Style="text-align: right;"><span class="admin-header-text">ACTIONS</span></MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="Doc No."><MudText Typo="Typo.body2" Class="admin-td-primary">@context.DocumentNumber</MudText></MudTd>
                        <MudTd DataLabel="Destination"><MudText Typo="Typo.body2" Class="admin-td-secondary">@context.DestinationBranch.BranchName</MudText></MudTd>
                        <MudTd DataLabel="Initiated">@context.TransferInitiatedDate?.ToShortDateString()</MudTd>
                        @if (IsOutApproved)
                        {
                            <MudTd DataLabel="Completed">@context.AssetTransferEndModel.TransferEndDate?.ToShortDateString()</MudTd>
                        }
                        <MudTd DataLabel="Status">
                            <MudChip T="string" Size="Size.Small" Variant="Variant.Text" Color="@(context?.AssetTransferEndModel.StatusText == "Completed" ? Color.Success : Color.Warning)" Class="pa-0">@context?.AssetTransferEndModel.StatusText</MudChip>
                        </MudTd>
                        <MudTd DataLabel="Actions" Style="text-align: right;">
                            <div class="d-flex justify-end gap-1">
                                <MudTooltip Text="Edit">
                                    <MudIconButton Disabled="@(context.AuthLevelId != null)" OnClick="@(()=> OpenDialogEditOutGoing(context,false))" Color="Color.Primary" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Variant="Variant.Text" />
                                </MudTooltip>
                                <MudTooltip Text="Delete">
                                    <MudIconButton Disabled="@(context.AuthLevelId != null)" OnClick="@(()=> OpenDialogDeleteOutGoing(context))" Color="Color.Error" Icon="@Icons.Material.Filled.DeleteOutline" Size="Size.Small" Variant="Variant.Text" />
                                </MudTooltip>
                                @if (@context.AuthLevelId != 100)
                                {
                                    <MudTooltip Text="Verify">
                                        <MudIconButton Disabled="@(context.MID != null)" OnClick="@(()=> OpenDialogEditOutGoing(context,true))" Color="Color.Warning" Icon="@Icons.Material.Filled.Verified" Size="Size.Small" Variant="Variant.Text" />
                                    </MudTooltip>
                                }
                                <MudTooltip Text="View Details">
                                    <MudIconButton OnClick="@(()=> OpenDialogEditOutGoing(context,true))" Color="Color.Info" Icon="@Icons.Material.Filled.GridView" Size="Size.Small" Variant="Variant.Text" />
                                </MudTooltip>
                            </div>
                        </MudTd>
                    </RowTemplate>
                    <PagerContent>
                        <div class="pa-4">
                            <MudTablePager PageSizeOptions="new int[] { 10, 20, 50, 100 }" />
                        </div>
                    </PagerContent>
                </MudTable>
            </MudTabPanel>
            <MudTabPanel Style="min-width: 200px;" Text="Incoming Asset" BadgeData="@(collectionIncoming?.Count > 0 ? collectionIncoming.Count : null)" BadgeColor="Color.Info" Visible="@(collectionIncoming?.Count > 0)">
                <div class="admin-glass-card border-none rounded-0 elevation-0 mb-0 pa-4" style="background: rgba(255,255,255,0.4);">
                    <div class="d-flex align-center gap-4">
                        <div style="flex-grow: 1;">
                            <MudTextField @bind-Value="searchTermIn" Placeholder="Search Incoming..." Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" Variant="Variant.Outlined" Margin="Margin.Dense" Class="admin-input-group" @onkeyup="HandleSearchKeyUpIn" Clearable="true" />
                        </div>
                        <div class="d-flex align-center gap-2">
                            <MudText Typo="Typo.body2" Class="admin-td-secondary fw-600">Max Results:</MudText>
                            <MudTextField @bind-Value="@NumberOfRecordsIn" Variant="Variant.Outlined" Margin="Margin.Dense" Style="width: 80px; background: white;" />
                        </div>
                        <MudCheckBox T="bool" Label="Approved" ValueChanged="((bool value)=>ApprovedToggledIn(value))" Value="@IsInApproved" Size="Size.Small" Color="Color.Primary" Class="fw-600" />
                    </div>
                </div>
                <MudTable Items="@collectionIncoming" Dense="true" Hover="true" Elevation="0" Class="modern-admin-table">
                    <HeaderContent>
                        <MudTh><MudTableSortLabel SortBy="new Func<AssetTransferInitiationModel, object>(x=> x.InitiatedBranch.BranchName)" InitialDirection="SortDirection.Descending"><span class="admin-header-text">FROM BRANCH</span></MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<AssetTransferInitiationModel, object>(x=> x.TransferInitiatedDate)" InitialDirection="SortDirection.Descending"><span class="admin-header-text">INITIATED</span></MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<AssetTransferInitiationModel, object>(x=> x.DocumentNumber)" InitialDirection="SortDirection.Descending"><span class="admin-header-text">TRANSFER NO.</span></MudTableSortLabel></MudTh>
                        @if (IsInApproved)
                        {
                            <MudTh><MudTableSortLabel SortBy="new Func<AssetTransferInitiationModel, object>(x=> x.AssetTransferEndModel.TransferEndDate)" InitialDirection="SortDirection.Descending"><span class="admin-header-text">COMPLETED</span></MudTableSortLabel></MudTh>
                            <MudTh><MudTableSortLabel SortBy="new Func<AssetTransferInitiationModel, object>(x=> x.AssetTransferEndModel.DocumentNumber)" InitialDirection="SortDirection.Descending"><span class="admin-header-text">REC NO.</span></MudTableSortLabel></MudTh>
                        }
                        <MudTh><MudTableSortLabel SortBy="new Func<AssetTransferInitiationModel, object>(x=> x?.AssetTransferEndModel.StatusText)" InitialDirection="SortDirection.Descending"><span class="admin-header-text">STATUS</span></MudTableSortLabel></MudTh>
                        <MudTh Style="text-align: right;"><span class="admin-header-text">ACTIONS</span></MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="From Branch"><MudText Typo="Typo.body2" Class="admin-td-primary">@context.InitiatedBranch.BranchName</MudText></MudTd>
                        <MudTd DataLabel="Initiated">@context.TransferInitiatedDate?.ToShortDateString()</MudTd>
                        <MudTd DataLabel="Transfer No."><MudText Typo="Typo.body2" Class="admin-td-secondary">@context.DocumentNumber</MudText></MudTd>
                        @if (IsInApproved)
                        {
                            <MudTd DataLabel="Completed">@context.AssetTransferEndModel.TransferEndDate?.ToShortDateString()</MudTd>
                            <MudTd DataLabel="Rec No."><MudText Typo="Typo.body2" Class="admin-td-secondary">@context.AssetTransferEndModel.DocumentNumber</MudText></MudTd>
                        }
                        <MudTd DataLabel="Status">
                            <MudChip T="string" Size="Size.Small" Variant="Variant.Text" Color="@(context?.AssetTransferEndModel.StatusText == "Completed" ? Color.Success : Color.Warning)" Class="pa-0">@context?.AssetTransferEndModel.StatusText</MudChip>
                        </MudTd>
                        <MudTd DataLabel="Actions" Style="text-align: right;">
                             <div class="d-flex justify-end gap-1">
                                <MudTooltip Text="Accept/Reject">
                                    <MudIconButton Disabled="@(context.AuthLevelId != null || context.AssetTransferEndModel.TransferStatus != null)" OnClick="@(()=> OpenDialogEditIncoming(context,false))" Color="Color.Primary" Icon="@Icons.Material.Filled.AddTask" Size="Size.Small" Variant="Variant.Text" />
                                </MudTooltip>
                                @if (@context.AuthLevelId != 100)
                                {
                                    <MudTooltip Text="Verify">
                                        <MudIconButton Disabled="@(context.MID != null || context.AssetTransferEndModel.TransferStatus == null)" OnClick="@(()=> OpenDialogEditIncoming(context,true))" Color="Color.Warning" Icon="@Icons.Material.Filled.Verified" Size="Size.Small" Variant="Variant.Text" />
                                    </MudTooltip>
                                }
                                <MudTooltip Text="View Details">
                                    <MudIconButton OnClick="@(()=> OpenDialogEditIncoming(context,true))" Color="Color.Info" Icon="@Icons.Material.Filled.GridView" Size="Size.Small" Variant="Variant.Text" />
                                </MudTooltip>
                             </div>
                        </MudTd>
                    </RowTemplate>
                    <PagerContent>
                        <div class="pa-4">
                            <MudTablePager PageSizeOptions="new int[] { 10, 20, 50, 100 }" />
                        </div>
                    </PagerContent>
                </MudTable>
            </MudTabPanel>
        </MudTabs>
    </div>
</div>




@code {

    private bool _isLoading = true;
    private DateTime _loadStartTime;

    int CurrentBranchId = 0;
    private List<BranchModel> BranchList = new();

    #region SignaIR Notification

    private PushNotificationModel notificationMessage = new PushNotificationModel();

    #endregion
    DialogOptions maxWidth = new DialogOptions() { MaxWidth = MaxWidth.Large, FullWidth = true, CloseButton = true, CloseOnEscapeKey = true };
    private bool _busy;

    public bool HasPermissionAssetTransferServiceDelete { get; set; } = false;
    public int AssetTransferDocTypeID = 110;
    public int? branchID { get; set; }

    public bool IsOutApproved { get; set; } = false;
    public bool IsInApproved { get; set; } = false;
    private int numberOfRecordsOut = 100;
    private int numberOfRecordsIn = 100;
    private string searchTermOut = "";
    private string searchTermIn = "";
       
    private AssetTransferInitiationModel model = new();

    // Lifecycle method called when the component is initialized
    protected override async Task OnInitializedAsync()
    {
        _loadStartTime = DateTime.Now;
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionAssetTransferServiceDelete = await Irole.HasClaim(AssetTransferDocTypeID.ToString(), "Delete", ctc.Token);

        // Load the list of branches
        BranchList = Ibranchservice.Select().ToList();
        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;
        var brancIDString = authprov.User.Claims.First(x => x.Type == "BranchID").Value;
        CurrentBranchId = int.Parse(brancIDString);
        await signalRService.StartAsync();

        await GetAll();
        await EnsureMinimumLoadTime();
        _isLoading = false;
    }

    private async Task EnsureMinimumLoadTime()
    {
        var elapsed = (DateTime.Now - _loadStartTime).TotalMilliseconds;
        if (elapsed < 100)
        {
            await Task.Delay(100 - (int)elapsed);
        }
    }
        
    //Method to retrieve all outgoing and incoming asset transfers
    private async Task GetAll()
    {
        collectionOutGoing = Iservice.SelectOutgoingUnapproved(CurrentBranchId, numberOfRecordsOut, searchTermOut).ToList();
        collectionIncoming = Iservice.SelectIncomingUnapproved(CurrentBranchId, numberOfRecordsIn, searchTermIn).ToList();
    }

    #region Outgoing
    private List<AssetTransferInitiationModel> collectionOutGoing = new();
    string state = "Message box hasn't been opened yet";

    private int NumberOfRecordsOut
    {
        get => numberOfRecordsOut;
        set
        {
            if (numberOfRecordsOut != value)
            {
                numberOfRecordsOut = value;
                _ = ReloadTableOut();
            }
        }
    }

    private async Task HandleSearchKeyUpOut(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await ReloadTableOut();
        }
    }

    private async Task ReloadTableOut()
    {
        await GetAllOutGoing(IsOutApproved, NumberOfRecordsOut);
    }

    // Method to toggle the approval status and reload the table
    async Task ApprovedToggledOut(bool value)
    {
        IsOutApproved = value;
        await GetAllOutGoing(IsOutApproved, NumberOfRecordsOut);
    }

    // Method to retrieve all outgoing asset transfers
    async Task GetAllOutGoing(bool val, int numberOfRecords)
    {
        int NumberOfRecords = numberOfRecords;
        
        collectionOutGoing = new List<AssetTransferInitiationModel>();

        @if (val)
        {
            collectionOutGoing = Iservice.SelectOutgoingApproved(CurrentBranchId, NumberOfRecords, searchTermOut).ToList();
        }
        else
        {
            collectionOutGoing = Iservice.SelectOutgoingUnapproved(CurrentBranchId, NumberOfRecords, searchTermOut).ToList();
        }
    }

    // Method to open the dialog for editing outgoing asset transfers
    private async Task OpenDialogEditOutGoing(AssetTransferInitiationModel AssetTransferInitiation, bool ReadOnly)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        _busy = true;

        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;
        var brancIDString = authprov.User.Claims.First(x => x.Type == "BranchID").Value;

        if (AssetTransferInitiation.InitiatedBranch == null)
        {
            AssetTransferInitiation.InitiatedBranch = new();
        }
        if (AssetTransferInitiation.DestinationBranch == null)
        {
            AssetTransferInitiation.DestinationBranch = new();
        }
        if (AssetTransferInitiation.Asset == null)
        {
            AssetTransferInitiation.Asset = new();
        }
        AssetTransferInitiation.InitiatedBranch.BranchID = int.Parse(brancIDString);

        var model = new DialogParameters
            {
                ["model"] = AssetTransferInitiation,
                ["ReadOnly"] = ReadOnly
            };

        // Show the dialog for editing
        var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Large };
        var dialog = await DialogService.ShowAsync<AssetTransferInitiationDialog>("Simple Dialog", model, options);
        var result = await dialog.Result;
        var isCancelled = result.Canceled;
        if (!isCancelled)
        {
            var ReturnData = (AssetTransferInitiationModel)result.Data;

            // Prepare notification message for asset transfer
            notificationMessage.InitiateBranch = BranchList?.FirstOrDefault(s => s.BranchID == Convert.ToInt32(ReturnData?.InitiatedBranch?.BranchID ?? 0)) ?? null;
            notificationMessage.ReceivedBranch = BranchList?.FirstOrDefault(s => s.BranchID == Convert.ToInt32(ReturnData?.DestinationBranch?.BranchID ?? 0)) ?? null;
            notificationMessage.MessageTitle = "Asset " + (ReturnData?.Asset?.Description ?? "") + " is transfered to this branch.";
            notificationMessage.MessageBody = "Asset " + (ReturnData?.Asset?.Description ?? "") + " is transfered from " + (notificationMessage?.InitiateBranch?.BranchName ?? "") + " to this branch on " + (DateTime.Now).ToString() + ".";
            notificationMessage.RedirectedTo = 0;
            notificationMessage.ExpiredBy = 7;
            notificationMessage.DocumentID = ReturnData.AssetTransferID;
            notificationMessage.MessageGroupID = "AssetTransfer";
            notificationMessage.PageToRedirectLink = "/AssetTransferView";
            notificationMessage.ClaimValue = "Edit";
            notificationMessage.DocumentTypeID = AssetTransferDocTypeID;
            notificationMessage.MsgDate = DateTime.Now;

            // Send notification via SignalR
            await signalRService.Send(notificationMessage);

            await GetAll();
        }
        await Task.Delay(200);
        _busy = false;
    }

    // Method to open the dialog for deleting outgoing asset transfers
    private async Task OpenDialogDeleteOutGoing(AssetTransferInitiationModel AssetTransferInitiation)
    {
        if (HasPermissionAssetTransferServiceDelete)
        {
            bool? result = await DialogService.ShowMessageBoxAsync(
                "Warning",
                "Are you sure you want to delete this entry?",
                yesText: "Delete!", cancelText: "Cancel");
            state = result == null ? "Cancelled" : "Deleted!";
            if (state == "Deleted!")
            {
                var authprov = await auth.GetAuthenticationStateAsync();
                var user = authprov.User;
                var brancIDString = authprov.User.Claims.First(x => x.Type == "BranchID").Value;
                try
                {
                    var BranchID = int.Parse(brancIDString);
                    var UserID = user.Identity.Name;

                    Iservice.DeleteInitiation(AssetTransferInitiation.AssetTransferID, BranchID, AssetTransferInitiation.Asset.AssetID, UserID);
                    snackbar.Add("Asset Transfer Canceled", Severity.Warning);
                }
                catch (Exception ex)
                {
                    snackbar.Add(ex.Message, Severity.Error);
                }
                await GetAll();
            }
        }
        else
        {
            bool? result = await DialogService.ShowMessageBoxAsync(
                "Permission denied!",
                "You don't have any permission to Delete AssetTransfer.");
        }
    }

    #endregion

    #region Incoming
    private List<AssetTransferInitiationModel> collectionIncoming = new();


     private int NumberOfRecordsIn
    {
        get => numberOfRecordsIn;
        set
        {
            if (numberOfRecordsIn != value)
            {
                numberOfRecordsIn = value;
                _ = ReloadTableIn();
            }
        }
    }

    private async Task HandleSearchKeyUpIn(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await ReloadTableIn();
        }
    }

    private async Task ReloadTableIn()
    {
        await GetAllIncoming(IsInApproved, NumberOfRecordsIn);
    }

    // Method to toggle the approval status and reload the table
    async Task ApprovedToggledIn(bool value)
    {
        IsInApproved = value;
        await GetAllIncoming(IsInApproved, NumberOfRecordsIn);
    }

    // Method to retrieve all incoming asset transfers
    async Task GetAllIncoming(bool val, int numberOfRecords)
    {
        int NumberOfRecords = numberOfRecords;

        collectionIncoming = new List<AssetTransferInitiationModel>();

        @if (val)
        {
            collectionIncoming = Iservice.SelectIncomingApproved(CurrentBranchId, NumberOfRecords, searchTermIn).ToList();
        }
        else
        {
            collectionIncoming = Iservice.SelectIncomingUnapproved(CurrentBranchId, NumberOfRecords, searchTermIn).ToList();
        }
    }

    // Method to open the dialog for editing incoming asset transfers
    private async Task OpenDialogEditIncoming(AssetTransferInitiationModel AssetTransferEnd, bool ReadOnly)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        _busy = true;

        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;
        var brancIDString = authprov.User.Claims.First(x => x.Type == "BranchID").Value;

        if (AssetTransferEnd.AssetTransferEndModel == null)
        {
            AssetTransferEnd.AssetTransferEndModel = new();
        }
        if (AssetTransferEnd.DestinationBranch == null)
        {
            AssetTransferEnd.DestinationBranch = new();
        }
        AssetTransferEnd.DestinationBranch.BranchID = int.Parse(brancIDString);

        var model = new DialogParameters
            {
                ["model"] = AssetTransferEnd,
                ["ReadOnly"] = ReadOnly
            };

        // Show the dialog for editing
        var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Medium };
        var dialog = await DialogService.ShowAsync<AssetTransferEndDialog>("Simple Dialog", model, options);
        var result = await dialog.Result;
        var isCancelled = result.Canceled;

        if (!isCancelled)
        {
            var ReturnData = (AssetTransferInitiationModel)result.Data;
            // Prepare notification message for asset rejection
            if (ReturnData.IsAssetReject == 1)
            {
                notificationMessage.InitiateBranch = BranchList?.FirstOrDefault(s => s.BranchID == Convert.ToInt32(ReturnData?.DestinationBranch?.BranchID ?? 0)) ?? null;
                notificationMessage.ReceivedBranch = BranchList?.FirstOrDefault(s => s.BranchID == Convert.ToInt32(ReturnData?.InitiatedBranch?.BranchID ?? 0)) ?? null;
                notificationMessage.MessageTitle = "Asset " + (ReturnData?.Asset?.Description ?? "") + " is rejected.";
                notificationMessage.MessageBody = "Asset " + (ReturnData?.Asset?.Description ?? "") + " is rejected from " + (notificationMessage?.InitiateBranch?.BranchName ?? "") + " on " + (DateTime.Now).ToString() + ".";
                notificationMessage.RedirectedTo = 0;
                notificationMessage.MsgDate = DateTime.Now;
                notificationMessage.ExpiredBy = 7;
                notificationMessage.DocumentID = ReturnData.AssetTransferID;
                notificationMessage.MessageGroupID = "AssetTransfer";
                notificationMessage.PageToRedirectLink = "/AssetTransferView";
                notificationMessage.ClaimValue = "Edit";
                notificationMessage.DocumentTypeID = AssetTransferDocTypeID;
                // Send notification via SignalR
                await signalRService.Send(notificationMessage);
            }
            await GetAll();
        }
        await Task.Delay(200);
        _busy = false;
    }

    #endregion
        
}
