@page "/AssetSubClass"
@inject IAssetClassService Iservice
@inject MudBlazor.ISnackbar snackbar
@inject AuthenticationStateProvider auth
@attribute [Authorize]
@using System.Threading;
@inject IRoleService<RoleModel> Irole
@inject IDialogService DialogService

<MudGrid Spacing="4">
    <MudItem xs="12">
        <MudTable Items="@collection" RowsPerPage="10" Dense="true" Hover="true" Striped="true" Elevation="10" Filter="new Func<AssetSubClassModel, bool>(search)" @bind-Model="model">
            <ToolBarContent>
                <MudText Typo="Typo.h6">Asset SubClasses</MudText>
                <MudTooltip Text="New Asset Class">
                    <MudIconButton Disabled="@_busy" Icon="@Icons.Material.Filled.Add" Title="Add" @onclick="@(()=> OpenDialog(new AssetSubClassModel()))" Color="Color.Dark" Size="Size.Small"></MudIconButton>
                </MudTooltip>
                <MudSpacer></MudSpacer>
                <MudTextField @bind-Value="searchAssetSubclass" Placeholder="Search AssetSubclass... " Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0"></MudTextField>
            </ToolBarContent>
            <HeaderContent>
                <MudTh><MudTableSortLabel SortBy="new Func<AssetSubClassModel, object>(x=> x.AssetSubclass)" InitialDirection="SortDirection.Ascending">Asset SubClass Name</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<AssetSubClassModel, object>(x=> x.AssetSubAbbrev)" InitialDirection="SortDirection.Ascending">Serial Number Prefix</MudTableSortLabel></MudTh>
                <MudTh>Actions</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Asset SubClass Name">@context.AssetSubclass</MudTd>
                <MudTd DataLabel="Serial Number Prefix">@context.AssetSubAbbrev</MudTd>
                <MudTd DataLabel="">
                    <MudTooltip Text="Edit">
                        <MudFab @onclick="@(()=> OpenDialog(context))" Color="Color.Primary" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" IconSize="Size.Small" />
                    </MudTooltip>
                    <MudTooltip Text="Settings">
                        <MudFab Disabled="@_busy" @onclick="@(() => Settings(context.ID))" Title="Settings" Color="Color.Primary" Icon="@Icons.Material.Filled.Settings" Size="Size.Small" IconSize="Size.Small" />
                    </MudTooltip>
                </MudTd>
            </RowTemplate>
            <PagerContent>
                <MudTablePager PageSizeOptions="new int[] { 10, 20, 50, 100 }" />
            </PagerContent>
        </MudTable>
    </MudItem>
</MudGrid>

@code {

    private AssetSubClassModel model = new AssetSubClassModel();
    private List<AssetSubClassModel> collection = new List<AssetSubClassModel>();
    private string searchAssetSubclass = "";
    DialogOptions mediumWidth = new DialogOptions() { MaxWidth = MaxWidth.Medium, FullWidth = true };
    private bool _busy;

    public bool HasPermissionAssetClassServiceEdit { get; set; } = false;
    public int AssetClassDocTypeID = 115;

    protected override async Task OnInitializedAsync()
    {
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionAssetClassServiceEdit = await Irole.HasClaim(AssetClassDocTypeID.ToString(), "Edit", ctc.Token);

        model = new();
        GetAll();
    }

    private void GetAll()
    {
        collection = Iservice.SelectSubClasses(0).ToList();
    }

    public async Task OpenDialog(AssetSubClassModel acm)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        _busy = true;

        if (HasPermissionAssetClassServiceEdit)
        {
            DialogParameters parms = new DialogParameters();
            parms.Add("model", acm.Clone());
            var dialog = DialogService.Show<AssetSubClassDialog>(acm.AssetSubClassID == null ? "ADD" : "EDIT", parms);
            var result = await dialog.Result;
            if (!result.Canceled)
            {
                try
                {
                    AssetSubClassModel UpdatedModel = (AssetSubClassModel)result.Data;
                    Iservice.UpdateSubClass(UpdatedModel);
                    snackbar.Add("Saved Successfully", Severity.Success);
                }
                catch (Exception ex)
                {
                    snackbar.Add(ex.Message, Severity.Warning);
                }
            }
            GetAll();
        }
        else
        {
            bool? result = await DialogService.ShowMessageBox(
                "Permission denied!",
                "You dont have any permission to Edit AssetClass.");
        }
        await Task.Delay(200);
        _busy = false;
    }

    private async Task Settings(int? ID)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        _busy = true;

        DialogParameters parms = new DialogParameters();
        parms.Add("SubClassID", ID);
        var dialog = DialogService.Show<AssetSettingsDialog>("Asset Settings", parms, new DialogOptions() { MaxWidth = MaxWidth.Medium });

        await Task.Delay(200);
        _busy = false;
    }

    private bool search(AssetSubClassModel SubClassModel)
    {
        if (SubClassModel.ID != null && SubClassModel.AssetSubclass.Contains(searchAssetSubclass, StringComparison.OrdinalIgnoreCase))
        {
            return true;
        }
        return false;
    }
}