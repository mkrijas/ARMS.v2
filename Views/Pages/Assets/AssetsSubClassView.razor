@page "/AssetSubClass"
@inject IAssetClassService Iservice
@inject MudBlazor.ISnackbar snackbar
@inject AuthenticationStateProvider auth
@attribute [Authorize]
@using System.Threading;
@inject IRoleService<RoleModel> Irole
@inject IDialogService DialogService

@if (_isLoading)
{
    <div @key="@("loader")" style="display: flex; justify-content: center; align-items: center; min-height: 400px;">
        <LoaderComponent IsFullScreen="true" 
                        ShowLogo="false" 
                        Size="medium" 
                        LoadingText="Organizing Classifications" 
                        SubText="Structuring asset hierarchies..." />
    </div>
}
else
{
    <div class="fade-in">
        <div class="admin-header-tiered mb-6">
            <div class="d-flex align-center justify-space-between">
                <div>
                    <MudText Typo="Typo.h4" Class="admin-title">Asset Classification | Sub-Class Registry</MudText>
                    <MudText Typo="Typo.body2" Class="admin-subtitle">Hierarchical classification system for organizational assets. Define sub-categories, establish serial prefix conventions, and configure granular attribute settings for specialized asset clusters to ensure systematic inventory management.</MudText>
                </div>
            </div>
        </div>

        <div class="admin-glass-card mb-6 pa-4">
            <div class="d-flex align-center gap-4 flex-wrap">
                <div style="flex-grow: 1; min-width: 300px;">
                    <MudTextField @bind-Value="searchAssetSubclass" Placeholder="Search classification or prefix..." Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" Variant="Variant.Outlined" Margin="Margin.Dense" Class="admin-input-group" Clearable="true" />
                </div>
                <div class="d-flex align-center gap-4">
                    <div class="admin-icon-square-vibrant small accent-indigo clickable" @onclick="@(()=> OpenDialog(new AssetSubClassModel()))">
                        <MudIcon Icon="@Icons.Material.Filled.Add" Size="Size.Small" />
                    </div>
                </div>
            </div>
        </div>

        <div class="admin-glass-card pa-0 overflow-hidden shadow-sm">
            <MudTable Items="@collection" Elevation="0" Class="modern-admin-table" Hover="true" T="AssetSubClassModel" Filter="new Func<AssetSubClassModel, bool>(search)">
                <HeaderContent>
                    <MudTh><MudTableSortLabel SortBy="new Func<AssetSubClassModel, object>(x=> x.AssetSubclass)"><span class="admin-header-text">SUB-CLASS IDENTITY</span></MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<AssetSubClassModel, object>(x=> x.AssetSubAbbrev)"><span class="admin-header-text">SERIAL PREFIX</span></MudTableSortLabel></MudTh>
                    <MudTh Style="text-align: right;"><span class="admin-header-text pr-4">CONFIGURATIONS</span></MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Sub-Class">
                         <div class="d-flex align-center gap-2">
                             <div class="admin-icon-square-vibrant tiny accent-indigo">
                                <MudIcon Icon="@Icons.Material.Filled.Layers" Size="Size.Small" />
                            </div>
                            <span class="fw-700 admin-td-primary">@context.AssetSubclass</span>
                        </div>
                    </MudTd>
                    <MudTd DataLabel="Prefix">
                        <MudChip T="string" Color="Color.Info" Size="Size.Small" Variant="Variant.Text" Class="fw-900 tiny uppercase">@context.AssetSubAbbrev</MudChip>
                    </MudTd>
                    <MudTd DataLabel="Actions" Style="text-align: right;">
                        <div class="d-flex justify-end gap-1 mb-1">
                                <MudTooltip Text="Edit Parameters">
                                    <MudIconButton OnClick="@(()=> OpenDialog(context))" Color="Color.Primary" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Variant="Variant.Text" />
                                </MudTooltip>

                                <MudTooltip Text="Cluster Settings">
                                    <MudIconButton OnClick="@(() => Settings(context.ID))" Color="Color.Secondary" Icon="@Icons.Material.Filled.Settings" Size="Size.Small" Variant="Variant.Text" Disabled="@_busy" />
                                </MudTooltip>
                        </div>
                    </MudTd>
                </RowTemplate>
                <PagerContent>
                    <div class="pa-4">
                        <MudTablePager PageSizeOptions="new int[] { 10, 20, 50, 100 }" />
                    </div>
                </PagerContent>
            </MudTable>
        </div>
    </div>
}

@code {

    private bool _isLoading = true;
    private DateTime _loadStartTime;

    private AssetSubClassModel model = new AssetSubClassModel();
    private List<AssetSubClassModel> collection = new List<AssetSubClassModel>();
    private string searchAssetSubclass = "";
    DialogOptions mediumWidth = new DialogOptions() { MaxWidth = MaxWidth.Medium, FullWidth = true };
    private bool _busy;

    public bool HasPermissionAssetClassServiceEdit { get; set; } = false;
    public int AssetClassDocTypeID = 115;

    // Lifecycle method called when the component is initialized
    protected override async Task OnInitializedAsync()
    {
        _loadStartTime = DateTime.Now;
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionAssetClassServiceEdit = await Irole.HasClaim(AssetClassDocTypeID.ToString(), "Edit", ctc.Token);

        model = new();
        GetAll();
        await EnsureMinimumLoadTime();
        _isLoading = false;
    }

    private async Task EnsureMinimumLoadTime()
    {
        var elapsed = (DateTime.Now - _loadStartTime).TotalMilliseconds;
        if (elapsed < 100)
        {
            await Task.Delay(100 - (int)elapsed);
        }
    }

    // Method to retrieve all asset subclasses
    private void GetAll()
    {
        collection = Iservice.SelectSubClasses(0).ToList(); // Fetch subclasses from the service
    }

    // Method to open the dialog for adding or editing an asset subclass
    public async Task OpenDialog(AssetSubClassModel acm)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        _busy = true;

        if (HasPermissionAssetClassServiceEdit)
        {
            DialogParameters parms = new DialogParameters();
            parms.Add("model", acm.Clone());
            var dialog = await DialogService.ShowAsync<AssetSubClassDialog>(acm.AssetSubClassID == null ? "ADD" : "EDIT", parms);
            var result = await dialog.Result;
            if (!result.Canceled)
            {
                try
                {
                    AssetSubClassModel UpdatedModel = (AssetSubClassModel)result.Data;
                    Iservice.UpdateSubClass(UpdatedModel); // Update the subclass in the service
                    snackbar.Add("Saved Successfully", Severity.Success);
                }
                catch (Exception ex)
                {
                    snackbar.Add(ex.Message, Severity.Warning);
                }
            }
            GetAll();
        }
        else
        {
            bool? result = await DialogService.ShowMessageBoxAsync(
                "Permission denied!",
                "You don't have any permission to Edit AssetClass.");
        }
        await Task.Delay(200);
        _busy = false;
    }

    private async Task Settings(int? ID)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        _busy = true;

        DialogParameters parms = new DialogParameters();
        parms.Add("SubClassID", ID);
        var dialog = await DialogService.ShowAsync<AssetSettingsDialog>("Asset Settings", parms, new DialogOptions() { MaxWidth = MaxWidth.Medium });

        await Task.Delay(200);
        _busy = false;
    }

    // Method to open the settings dialog for a specific subclass
    private bool search(AssetSubClassModel SubClassModel)
    {
        if (SubClassModel.ID != null && SubClassModel.AssetSubclass.Contains(searchAssetSubclass, StringComparison.OrdinalIgnoreCase))
        {
            return true;
        }
        return false;
    }
}

