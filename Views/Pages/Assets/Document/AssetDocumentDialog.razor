@attribute [Authorize]
@using System.Threading;
@inject IRoleService<RoleModel> Irole
@inject AuthenticationStateProvider auth
@inject IAssetDocumentService Iservice
@inject MudBlazor.ISnackbar snackbar
@inject IDialogService DialogService

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudText Typo="Typo.h6">@(ReadOnly ? "View" : "Add/Edit") Documents</MudText>
        </MudText>
    </TitleContent>
    <DialogContent>
        <EditForm id="Docform" Model="@model" OnValidSubmit="OnValidSubmit">
            <DataAnnotationsValidator />
            <ValidationSummary />
            <MudGrid>
                <MudItem xs="6">
                    <MudSelect ReadOnly="ReadOnly" T="AssetDocumentTypeModel" @bind-Value="@model.DocumentType" ToStringFunc="@(e => e == null ? null : $"{e.DocumentTypeName}")" Label="Type" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.DocumentType)" AdornmentColor="Color.Secondary">
                        @foreach (var item in Dtypes)
                        {
                            <MudSelectItem Value="@item">@item.DocumentTypeName</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="6">
                    <MudDatePicker ReadOnly="ReadOnly" @bind-Date="@model.InvoiceDate" Label="Reference Date" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.InvoiceDate)" Editable="true"></MudDatePicker>
                </MudItem>
                <MudItem xs="6">
                    <MudDatePicker ReadOnly="ReadOnly" @bind-Date="@model.StartDate" Label="Begin On" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.StartDate)" Editable="true"></MudDatePicker>
                </MudItem>
                <MudItem xs="6">
                    <MudDatePicker ReadOnly="ReadOnly" @bind-Date="@model.EndDate" Label="Expire On" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.EndDate)" Editable="true"></MudDatePicker>
                </MudItem>
                <MudItem xs="6" md="6">
                    <MudTextField ReadOnly="ReadOnly" @bind-Value="@model.ReceiptNo" Label="Slip No" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.ReceiptNo)"></MudTextField>
                </MudItem>
                <MudItem xs="6" md="6">
                    <MudTextField ReadOnly="ReadOnly" @bind-Value="@model.Refference" Label="Refference No" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.Refference)"></MudTextField>
                </MudItem>
                @if (model.DocumentType?.DocumentTypeID == 19 || model.DocumentType?.DocumentTypeID == 20)
                {
                    <MudItem xs="6" md="6">
                        <MudTextField ReadOnly="ReadOnly" @bind-Value="@model.IDVAmount" Label="IDV Amount" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.IDVAmount)"></MudTextField>
                    </MudItem>
                    <MudItem xs="6">
                        <MudTextField ReadOnly="ReadOnly" @bind-Value="@model.NCBPercentage" Label="NCB Percentage" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.NCBPercentage)"> Percentage</MudTextField>
                    </MudItem>
                }
                <MudItem xs="6" md="6">
                    <MudTextField ReadOnly="ReadOnly" @bind-Value="@model.Amount" Label="Amount" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.Amount)"></MudTextField>
                </MudItem>
                <MudItem xs="6">
                    <MudDatePicker ReadOnly="ReadOnly" @bind-Date="@model.ExtendedEndDate" Label="Extended Validity Expire On" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.ExtendedEndDate)" Editable="true"></MudDatePicker>
                </MudItem>
            </MudGrid>
        </EditForm>
    </DialogContent>
    <DialogActions>
        @if (!ReadOnly)
        {
            <MudButton Disabled="@_busy" form="Docform" Variant="Variant.Filled" Color="Color.Success" ButtonType="ButtonType.Submit">Save</MudButton>
            @if (model.DocumentID != null)
            {
                <MudButton Disabled="@_busy" Variant="Variant.Filled" Color="Color.Error" OnClick="(()=> Delete(model))">Delete</MudButton>
            }
        }
    </DialogActions>
</MudDialog>

@code {

    [CascadingParameter]
    MudDialogInstance MudDialog { get; set; }
    [Parameter]
    public AssetModel Asset { get; set; }
    [Parameter]
    public AssetDocumentModel model { get; set; } = new();
    [Parameter]
    public List<AssetDocumentTypeModel> Dtypes { get; set; } = null;
    [Parameter]
    public bool ReadOnly { get; set; } = false;

    private bool _busy;

    public bool HasPermissionAssetDocumentServiceEdit { get; set; } = false;
    public bool HasPermissionAssetDocumentServiceDelete { get; set; } = false;
    public int AssetDocumentDocTypeID = 113;

    // Lifecycle method called when the component is initialize
    protected override async Task OnInitializedAsync()
    {
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionAssetDocumentServiceEdit = await Irole.HasClaim(AssetDocumentDocTypeID.ToString(), "Edit", ctc.Token);
        HasPermissionAssetDocumentServiceDelete = await Irole.HasClaim(AssetDocumentDocTypeID.ToString(), "Delete", ctc.Token);
    }

    // Method called when the form is submitted successfully 
    private async void OnValidSubmit(EditContext context)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is being submitted!", Severity.Warning);
            return;
        }
        _busy = true;

        if (HasPermissionAssetDocumentServiceEdit)
        {
            var authprov = await auth.GetAuthenticationStateAsync();
            var user = authprov.User;
            model.UserInfo = new();
            model.Asset = Asset;
            if (model.UserInfo != null)
            {
                model.UserInfo.UserID = user.Identity.Name;
            }

            // Validate document period if the document type is not 2, 3, or 5
            if (model.DocumentType.DocumentTypeID != 2 && model.DocumentType.DocumentTypeID != 3 && model.DocumentType.DocumentTypeID != 5)
            {
                var validationOls = Iservice.ValidatePeriod(model).ToList();

                // Check for overlapping document periods
                if (validationOls.Any(x => x.DocumentID != model.DocumentID))
                {
                    snackbar.Add("Document Period cannot overlap! Please check the period ", Severity.Warning);
                    _busy = false;
                    return;
                }
            }
            else
            {
                model.UserInfo.RecordStatus = 9;
            }

            try
            {
                if (Asset == null)
                {
                    snackbar.Add("Please select asset. ", Severity.Error);
                    _busy = false;
                    return;
                }
                if (model.Asset == null || model.Asset.AssetID == null || model.Asset.AssetID == 0)
                {
                    model.Asset = Asset;
                }

                // Update the asset document
                model = Iservice.Update(model);
                snackbar.Add("Saved Successfully", Severity.Success);
                MudDialog.Close(DialogResult.Ok(true));
            }
            catch (Exception ex)
            {
                snackbar.Add(ex.Message, Severity.Error);
            }
        }
        else
        {
            bool? result = await DialogService.ShowMessageBox(
                "Permission denied!",
                "You don't have any permission to Edit AssetDocument.");
        }
        await Task.Delay(200);
        _busy = false;
    }

    // Method to delete an asset document
    private async Task Delete(AssetDocumentModel model)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is being submitted!", Severity.Warning);
            return;
        }
        _busy = true;

        if (HasPermissionAssetDocumentServiceDelete)
        {
            bool? result = await DialogService.ShowMessageBox(
               "Warning !",
               "Are you sure, you want to delete - " + model.DocumentType.DocumentTypeName + " (" + model.InvoiceDate + ") ?");
            if (result == true)
            {
                var authprov = await auth.GetAuthenticationStateAsync();
                var user = authprov.User;
                model.UserInfo.UserID = user.Identity.Name;
                Iservice.Delete(model.DocumentID, model.UserInfo.UserID); // Perform deletion
                snackbar.Add("Deleted Successfully", Severity.Error);
                model = new();
                MudDialog.Close(DialogResult.Ok(true));
                StateHasChanged();
            }
        }
        else
        {
            bool? result = await DialogService.ShowMessageBox(
                "Permission denied!",
                "You don't have any permission to Delete AssetDocument.");
        }
        await Task.Delay(200);
        _busy = false;
    }
}