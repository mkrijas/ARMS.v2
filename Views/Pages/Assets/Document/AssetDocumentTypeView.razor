@page "/DocumentType"
@inject IAssetDocumentService Iservice

@inject MudBlazor.ISnackbar snackbar
@inject AuthenticationStateProvider auth

@attribute [Authorize]
@inject IDialogService DialogService



<MudGrid Spacing="4">
    <MudItem xs="12">
        <MudTable Items="@collection" Elevation="10" Filter="new Func<AssetDocumentTypeModel, bool>(search)" @bind-DocumentTypeModel="model">

            <ToolBarContent>
                <MudText Typo="Typo.h6">Document</MudText>
                <MudIconButton Icon="@Icons.Material.Filled.Add" Title="Add" @onclick="@(()=> Edit(0))" Color="Color.Dark" Size="Size.Small"></MudIconButton>

                <MudSpacer></MudSpacer>
                <MudTextField @bind-Value="searchDocumentType" Placeholder="Search DocumentTypes... "
                              Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                              IconSize="Size.Medium" Class="mt-0"></MudTextField>
            </ToolBarContent>
            <HeaderContent>
                <MudTh><MudTableSortLabel SortBy="new Func<AssetDocumentTypeModel, object>(x=> x.DocumentTypeName)" InitialDirection="SortDirection.Ascending">Document Type</MudTableSortLabel></MudTh>
                <MudTh><MudTh><MudTableSortLabel SortBy="new Func<AssetDocumentTypeModel, object>(x=> x.WarnBefore)" InitialDirection="SortDirection.Ascending">Warn Before</MudTableSortLabel></MudTh></MudTh>
                <MudTh><MudTh><MudTableSortLabel SortBy="new Func<AssetDocumentTypeModel, object>(x=> x.BlockAfter)" InitialDirection="SortDirection.Ascending">Block After</MudTableSortLabel></MudTh></MudTh>
                <MudTh>Actions</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="DocumentTypeName">@context.DocumentTypeName</MudTd>
                <MudTd DataLabel="WarnBefore">@context.WarnBefore</MudTd>
                <MudTd DataLabel="BlockAfter">@context.BlockAfter</MudTd>
                <MudTd DataLabel="">
                    <MudFab @onclick="@(()=> Edit(context.DocumentTypeID))" Color="Color.Primary" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" IconSize="Size.Small" />
                    <MudFab @onclick="@(()=> Delete(context.DocumentTypeID))" Color="Color.Primary" Icon="@Icons.Material.Filled.Delete" Size="Size.Small" IconSize="Size.Small" />
                </MudTd>
            </RowTemplate>
            <PagerContent>
                <MudTablePager PageSizeOptions="new int[] { 5, 10, 20, 50, 100 }" />
            </PagerContent>
        </MudTable>
    </MudItem>


</MudGrid>
@code {

    private AssetDocumentTypeModel model = new();

    private string searchDocumentType = "";
    private List<AssetDocumentTypeModel>
    collection = new();

    protected override async Task OnInitializedAsync()
    {
        await Task.Run(() => GetAll());
    }

    private void GetAll()
    {
        if (collection != null)
        {
            collection.Clear();
        }
        foreach (var item in Iservice.GetDocumentTypes())
        {
            collection.Add(item);
        }
    }


    private async Task Edit(int? id)
    {
        if (id == null || id != null && id == 0)
        {
            model = new();
        }
        else
        {
            model = collection.First(x => x.DocumentTypeID == id);

        }
        DialogParameters parms = new DialogParameters();
        parms.Add("model", model);

        var dialog = DialogService.Show<DocumentDilog>("ADD TRUCK", parms);

        var result = await dialog.Result;

        // you can check if the modal was cancelled
        var isCancelled = result.Canceled;
        if (!isCancelled)
        {
            AssetDocumentTypeModel UpdatedModel = (AssetDocumentTypeModel)result.Data;
            if (UpdatedModel != null)
            {

                if (collection.Exists(x => x.DocumentTypeID == UpdatedModel.DocumentTypeID))
                {
                    collection[collection.FindIndex(x => x.DocumentTypeID == UpdatedModel.DocumentTypeID)] = UpdatedModel;
                }
                else
                {
                    collection.Add(UpdatedModel);
                }
                UpdatedModel = new();
            }
        }
    }
    private async Task Delete(int? id)
    {

        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;
        int result = Iservice.DeleteType(id, user.Identity.Name);

        if (result != -1)
        {
            if (collection != null && collection.Any(s => s.DocumentTypeID == id))
            {
                collection.Remove(collection.FirstOrDefault(s => s.DocumentTypeID == id));
                snackbar.Add("Deleted Successfully", Severity.Success);
            }
        }
    }


    private bool search(AssetDocumentTypeModel DocumentType)
    {
        if (DocumentType.DocumentTypeName != null && DocumentType.DocumentTypeName.Contains(searchDocumentType, StringComparison.OrdinalIgnoreCase))
        {
            return true;
        }
        return false;
    }
    private void OpenDialog()
    {

        DialogParameters parms = new DialogParameters();
        parms.Add("model", model);
        DialogService.Show<DocumentDilog>("Add Document", parms);
    }
}


