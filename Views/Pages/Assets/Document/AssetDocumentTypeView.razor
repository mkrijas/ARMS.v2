                        }
                        snackbar.Add("Saved Successfully", Severity.Success);
                        model = new AssetDocumentTypeModel();
                    }
                    else
                    {
                        snackbar.Add("Error - " + UpdatedModel.DocumentTypeName + " already exist !", Severity.Error);
                    }
                    //GetAll();
                    // if (UpdatedModel != null)
                    // {
                    //     if (collection.Exists(x => x.DocumentTypeID == UpdatedModel.DocumentTypeID))
                    //     {
                    //         collection[collection.FindIndex(x => x.DocumentTypeID == UpdatedModel.DocumentTypeID)] = UpdatedModel;
                    //     }
                    //     else
                    //     {
                    //         collection.Add(UpdatedModel);
                    //     }
                    //     UpdatedModel = new();
                    // }
                    //========================
                    // if (collection.Exists(x => x.DocumentTypeName == UpdatedModel.DocumentTypeName)
                    //     && collection.Exists(x => x.DocumentTypeID == UpdatedModel.DocumentTypeID)
                    //     && collection.Exists(x => x.WarnBefore == UpdatedModel.WarnBefore)
                    //     && collection.Exists(x => x.BlockAfter == UpdatedModel.BlockAfter)
                    //     && collection.Exists(x => x.UsageCode == UpdatedModel.UsageCode))
                    // {
                    //     snackbar.Add("Error - " + UpdatedModel.DocumentTypeName + " already exist !", Severity.Error);
                    // }
                    // else if (collection.Exists(x => x.DocumentTypeID == UpdatedModel.DocumentTypeID))
                    // {
                    //     UpdatedModel = Iservice.UpdateDocumentType(UpdatedModel);
                    //     if (UpdatedModel != null)
                    //     {
                    //         collection[collection.FindIndex(x => x.DocumentTypeID == UpdatedModel.DocumentTypeID)] = UpdatedModel;
                    //         snackbar.Add("Saved Successfully", Severity.Success);
                    //     }
                    // }
                    // else if (UpdatedModel.DocumentTypeID == null)
                    // {
                    //     UpdatedModel = Iservice.UpdateDocumentType(UpdatedModel);
                    //     collection.Add(UpdatedModel);
                    //     snackbar.Add("Saved Successfully", Severity.Success);
                    // }
                    // UpdatedModel = new();
                    //========================
                }
                catch (Exception ex)
                {
                    snackbar.Add(ex.Message, Severity.Warning);
                }
            }
        }
        else
        {
            bool? result = await DialogService.ShowMessageBoxAsync(
                "Permission denied!",
                "You don't have any permission to EditType AssetDocument.");
        }
        await Task.Delay(200);
        _busy = false;
    }

    // Method to delete an asset document type
    private async Task Delete(AssetDocumentTypeModel model)
    {
        if (HasPermissionAssetDocumentServiceDeleteType)
        {
            bool? result = await DialogService.ShowMessageBoxAsync(
                "Warning !",
                "Are you sure, you want to delete - " + model.DocumentTypeName + " ?");
            if (result == true)
            {
                var authprov = await auth.GetAuthenticationStateAsync();
                var user = authprov.User;

                // Perform deletion and check the result
                int value = Iservice.DeleteType(model.DocumentTypeID, user.Identity.Name);
                if (value != -1)
                {
                    if (collection != null && collection.Any(s => s.DocumentTypeID == model.DocumentTypeID))
                    {
                        collection.Remove(collection.FirstOrDefault(s => s.DocumentTypeID == model.DocumentTypeID));
                        snackbar.Add("Deleted Successfully", Severity.Success);
                    }
                }
                else
                {
                    bool? error = await DialogService.ShowMessageBoxAsync(
                        "Failed !",
                        "DocumentType - " + model.DocumentTypeName + " is active with our Assets !");
                }
            }
        }
        else
        {
            bool? result = await DialogService.ShowMessageBoxAsync(
                "Permission denied!",
                "You don't have any permission to DeleteType AssetDocument.");
        }
    }

    // Method to search for document types based on the search string
    private bool search(AssetDocumentTypeModel DocumentType)
    {
        if (DocumentType.DocumentTypeName != null && DocumentType.DocumentTypeName.Contains(searchDocumentType, StringComparison.OrdinalIgnoreCase))
        {
            return true;
        }
        return false;
    }

    // Method to open the dialog for adding a new document type
    private async Task OpenDialog()
    {
        DialogParameters parms = new DialogParameters();
        parms.Add("model", model);
        await DialogService.ShowAsync<DocumentDilog>("Add Document", parms);
    }
}

