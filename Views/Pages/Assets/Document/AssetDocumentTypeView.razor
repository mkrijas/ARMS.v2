@page "/DocumentType"
@inject IAssetDocumentService Iservice
@inject MudBlazor.ISnackbar snackbar
@attribute [Authorize]
@using System.Threading;
@inject IRoleService<RoleModel> Irole
@inject AuthenticationStateProvider auth
@inject IDialogService DialogService

@if (_isLoading)
{
    <div @key="@("loader")" style="display: flex; justify-content: center; align-items: center; min-height: 400px;">
        <LoaderComponent IsFullScreen="true" 
                        ShowLogo="false" 
                        Size="medium" 
                        LoadingText="configuring Compliance Schema" 
                        SubText="Establishing document standards..." />
    </div>
}
else
{
    <div class="fade-in">
        <div class="admin-header-tiered mb-6">
            <div class="d-flex align-center justify-space-between">
                <div>
                    <MudText Typo="Typo.h4" Class="admin-title">Asset Compliance | Document Type Configuration</MudText>
                    <MudText Typo="Typo.body2" Class="admin-subtitle">Regulatory document metadata management. Configure mandatory document types, set archival standards, and establish classification rules for asset-specific documentation to ensure full operational compliance.</MudText>
                </div>
            </div>
        </div>

        <div class="admin-glass-card mb-6 pa-4">
            <div class="d-flex align-center gap-4 flex-wrap">
                <div style="flex-grow: 1; min-width: 300px;">
                    <MudTextField @bind-Value="searchDocumentType" Placeholder="Search document categories..." Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" Variant="Variant.Outlined" Margin="Margin.Dense" Class="admin-input-group" Clearable="true" />
                </div>
                <div class="d-flex align-center gap-4">
                    <div class="admin-icon-square-vibrant small accent-indigo clickable" @onclick="@(()=> Edit(model))">
                        <MudIcon Icon="@Icons.Material.Filled.Add" Size="Size.Small" />
                    </div>
                </div>
            </div>
        </div>

        <div class="admin-glass-card pa-0 overflow-hidden shadow-sm">
            <MudTable Items="@collection" Elevation="0" Class="modern-admin-table" Hover="true" T="AssetDocumentTypeModel" Filter="new Func<AssetDocumentTypeModel, bool>(search)">
                <HeaderContent>
                    <MudTh><MudTableSortLabel SortBy="new Func<AssetDocumentTypeModel, object>(x=> x.DocumentTypeName)"><span class="admin-header-text">DOCUMENT CATEGORY</span></MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<AssetDocumentTypeModel, object>(x=> x.WarnBefore)"><span class="admin-header-text">ALERT CYCLE (DAYS)</span></MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<AssetDocumentTypeModel, object>(x=> x.BlockAfter)"><span class="admin-header-text">EXPIRY LIMIT (DAYS)</span></MudTableSortLabel></MudTh>
                    <MudTh Style="text-align: right;"><span class="admin-header-text pr-4">ACTIONS</span></MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Type">
                         <div class="d-flex align-center gap-2">
                             <div class="admin-icon-square-vibrant tiny accent-indigo">
                                <MudIcon Icon="@Icons.Material.Filled.Assignment" Size="Size.Small" />
                            </div>
                            <span class="fw-700 admin-td-primary">@context.DocumentTypeName</span>
                        </div>
                    </MudTd>
                    <MudTd DataLabel="Warn">
                         <div class="d-flex align-center gap-2">
                            <MudIcon Icon="@Icons.Material.Filled.NotificationImportant" Size="Size.Small" Color="Color.Warning" Class="opa-60" />
                            <span class="fw-700">@context.WarnBefore</span>
                         </div>
                    </MudTd>
                    <MudTd DataLabel="Block">
                         <div class="d-flex align-center gap-2">
                            <MudIcon Icon="@Icons.Material.Filled.GppMaybe" Size="Size.Small" Color="Color.Error" Class="opa-60" />
                            <span class="fw-700">@context.BlockAfter</span>
                         </div>
                    </MudTd>
                    <MudTd DataLabel="Actions" Style="text-align: right;">
                        <div class="d-flex justify-end gap-1 mb-1">
                                <MudTooltip Text="Update Schema">
                                    <MudIconButton OnClick="@(()=> Edit(context))" Color="Color.Primary" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Variant="Variant.Text" />
                                </MudTooltip>

                                <MudTooltip Text="Purge Configuration">
                                    <MudIconButton OnClick="@(()=> Delete(context))" Color="Color.Error" Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Variant="Variant.Text" />
                                </MudTooltip>
                        </div>
                    </MudTd>
                </RowTemplate>
                <PagerContent>
                    <div class="pa-4">
                        <MudTablePager PageSizeOptions="new int[] { 10, 20, 50, 100 }" />
                    </div>
                </PagerContent>
            </MudTable>
        </div>
    </div>
}

@code {

    private bool _isLoading = true;
    private DateTime _loadStartTime;

    private AssetDocumentTypeModel model = new();

    private bool _busy;
    private string searchDocumentType = "";
    private List<AssetDocumentTypeModel> collection = new();

    public bool HasPermissionAssetDocumentServiceEditType { get; set; } = false;
    public bool HasPermissionAssetDocumentServiceDeleteType { get; set; } = false;
    public int AssetDocumentDocTypeID = 113;

    // Lifecycle method called when the component is initialized 
    protected override async Task OnInitializedAsync()
    {
        _loadStartTime = DateTime.Now;
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionAssetDocumentServiceEditType = await Irole.HasClaim(AssetDocumentDocTypeID.ToString(), "EditType", ctc.Token);
        HasPermissionAssetDocumentServiceDeleteType = await Irole.HasClaim(AssetDocumentDocTypeID.ToString(), "DeleteType", ctc.Token);

        await Task.Run(() => GetAll());
        await EnsureMinimumLoadTime();
        _isLoading = false;
    }

    private async Task EnsureMinimumLoadTime()
    {
        var elapsed = (DateTime.Now - _loadStartTime).TotalMilliseconds;
        if (elapsed < 100)
        {
            await Task.Delay(100 - (int)elapsed);
        }
    }

    // Method to retrieve all document types
    private void GetAll()
    {
        if (collection != null)
        {
            collection.Clear();
        }

        // Fetch document types from the service and add them to the collection
        foreach (var item in Iservice.GetDocumentTypes())
        {
            collection.Add(item);
        }
    }

    // Method to edit an asset document type
    private async Task Edit(AssetDocumentTypeModel model)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        _busy = true;

        if (HasPermissionAssetDocumentServiceEditType)
