@page "/DocumentType"
@inject IAssetDocumentService Iservice
@inject MudBlazor.ISnackbar snackbar
@attribute [Authorize]
@using System.Threading;
@inject IRoleService<RoleModel> Irole
@inject AuthenticationStateProvider auth
@inject IDialogService DialogService

<MudGrid Spacing="4">
    <MudItem xs="12">
        <MudTable Items="@collection" Elevation="10" Filter="new Func<AssetDocumentTypeModel, bool>(search)" @bind-DocumentTypeModel="model">
            <ToolBarContent>
                <MudText Typo="Typo.h6">Asset Document Type</MudText>
                <MudIconButton Disabled="@_busy" Icon="@Icons.Material.Filled.Add" Title="Add" @onclick="@(()=> Edit(model))" Color="Color.Dark" Size="Size.Small"></MudIconButton>
                <MudSpacer></MudSpacer>
                <MudTextField @bind-Value="searchDocumentType" Placeholder="Search DocumentTypes... " Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0"></MudTextField>
            </ToolBarContent>
            <HeaderContent>
                <MudTh><MudTableSortLabel SortBy="new Func<AssetDocumentTypeModel, object>(x=> x.DocumentTypeName)" InitialDirection="SortDirection.Ascending">Document Type</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<AssetDocumentTypeModel, object>(x=> x.WarnBefore)" InitialDirection="SortDirection.Ascending">Warn Before</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<AssetDocumentTypeModel, object>(x=> x.BlockAfter)" InitialDirection="SortDirection.Ascending">Block After</MudTableSortLabel></MudTh>
                <MudTh>Actions</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="DocumentTypeName">@context.DocumentTypeName</MudTd>
                <MudTd DataLabel="WarnBefore">@context.WarnBefore</MudTd>
                <MudTd DataLabel="BlockAfter">@context.BlockAfter</MudTd>
                <MudTd DataLabel="">
                    <MudFab @onclick="@(()=> Edit(context))" Color="Color.Primary" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" IconSize="Size.Small" />
                    <MudFab @onclick="@(()=> Delete(context))" Color="Color.Primary" Icon="@Icons.Material.Filled.Delete" Size="Size.Small" IconSize="Size.Small" />
                </MudTd>
            </RowTemplate>
            <PagerContent>
                <MudTablePager PageSizeOptions="new int[] { 10, 20, 50, 100 }" />
            </PagerContent>
        </MudTable>
    </MudItem>
</MudGrid>

@code {

    private AssetDocumentTypeModel model = new();

    private bool _busy;
    private string searchDocumentType = "";
    private List<AssetDocumentTypeModel> collection = new();

    public bool HasPermissionAssetDocumentServiceEditType { get; set; } = false;
    public bool HasPermissionAssetDocumentServiceDeleteType { get; set; } = false;
    public int AssetDocumentDocTypeID = 113;

    protected override async Task OnInitializedAsync()
    {
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionAssetDocumentServiceEditType = await Irole.HasClaim(AssetDocumentDocTypeID.ToString(), "EditType", ctc.Token);
        HasPermissionAssetDocumentServiceDeleteType = await Irole.HasClaim(AssetDocumentDocTypeID.ToString(), "DeleteType", ctc.Token);

        await Task.Run(() => GetAll());
    }

    private void GetAll()
    {
        if (collection != null)
        {
            collection.Clear();
        }
        foreach (var item in Iservice.GetDocumentTypes())
        {
            collection.Add(item);
        }
    }

    private async Task Edit(AssetDocumentTypeModel model)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        _busy = true;

        if (HasPermissionAssetDocumentServiceEditType)
        {
            // if (id == null || id != null && id == 0)
            // {
            //     model = new();
            // }
            // else
            // {
            //     model = collection.First(x => x.DocumentTypeID == id);
            // }
            DialogParameters parms = new DialogParameters();
            parms.Add("model", model.Clone());
            var dialog = DialogService.Show<DocumentDilog>("ADD TRUCK", parms);
            var result = await dialog.Result;

            // you can check if the modal was cancelled
            var isCancelled = result.Canceled;
            if (!isCancelled)
            {
                try
                {
                    AssetDocumentTypeModel UpdatedModel = (AssetDocumentTypeModel)result.Data;
                    //if (!collection.Exists(x => x.DocumentTypeName == UpdatedModel.DocumentTypeName))
                    if (UpdatedModel != null)
                    {
                        UpdatedModel = Iservice.UpdateDocumentType(UpdatedModel);
                        if (UpdatedModel != null)
                        {
                            if (collection.Exists(x => x.DocumentTypeID == UpdatedModel.DocumentTypeID))
                            {
                                collection[collection.FindIndex(x => x.DocumentTypeID == UpdatedModel.DocumentTypeID)] = UpdatedModel;
                            }
                            else
                            {
                                collection.Add(UpdatedModel);
                            }
                            UpdatedModel = new();
                        }
                        snackbar.Add("Saved Successfully", Severity.Success);
                        model = new AssetDocumentTypeModel();
                    }
                    else
                    {
                        snackbar.Add("Error - " + UpdatedModel.DocumentTypeName + " already exist !", Severity.Error);
                    }
                    //GetAll();
                    // if (UpdatedModel != null)
                    // {
                    //     if (collection.Exists(x => x.DocumentTypeID == UpdatedModel.DocumentTypeID))
                    //     {
                    //         collection[collection.FindIndex(x => x.DocumentTypeID == UpdatedModel.DocumentTypeID)] = UpdatedModel;
                    //     }
                    //     else
                    //     {
                    //         collection.Add(UpdatedModel);
                    //     }
                    //     UpdatedModel = new();
                    // }
                    //========================
                    // if (collection.Exists(x => x.DocumentTypeName == UpdatedModel.DocumentTypeName)
                    //     && collection.Exists(x => x.DocumentTypeID == UpdatedModel.DocumentTypeID)
                    //     && collection.Exists(x => x.WarnBefore == UpdatedModel.WarnBefore)
                    //     && collection.Exists(x => x.BlockAfter == UpdatedModel.BlockAfter)
                    //     && collection.Exists(x => x.UsageCode == UpdatedModel.UsageCode))
                    // {
                    //     snackbar.Add("Error - " + UpdatedModel.DocumentTypeName + " already exist !", Severity.Error);
                    // }
                    // else if (collection.Exists(x => x.DocumentTypeID == UpdatedModel.DocumentTypeID))
                    // {
                    //     UpdatedModel = Iservice.UpdateDocumentType(UpdatedModel);
                    //     if (UpdatedModel != null)
                    //     {
                    //         collection[collection.FindIndex(x => x.DocumentTypeID == UpdatedModel.DocumentTypeID)] = UpdatedModel;
                    //         snackbar.Add("Saved Successfully", Severity.Success);
                    //     }
                    // }
                    // else if (UpdatedModel.DocumentTypeID == null)
                    // {
                    //     UpdatedModel = Iservice.UpdateDocumentType(UpdatedModel);
                    //     collection.Add(UpdatedModel);
                    //     snackbar.Add("Saved Successfully", Severity.Success);
                    // }
                    // UpdatedModel = new();
                    //========================
                }
                catch (Exception ex)
                {
                    snackbar.Add(ex.Message, Severity.Warning);
                }
            }
        }
        else
        {
            bool? result = await DialogService.ShowMessageBox(
                "Permission denied!",
                "You dont have any permission to EditType AssetDocument.");
        }
        await Task.Delay(200);
        _busy = false;
    }

    private async Task Delete(AssetDocumentTypeModel model)
    {
        if (HasPermissionAssetDocumentServiceDeleteType)
        {
            bool? result = await DialogService.ShowMessageBox(
                "Warning !",
                "Are you sure, you want to delete - " + model.DocumentTypeName + " ?");
            if (result == true)
            {
                var authprov = await auth.GetAuthenticationStateAsync();
                var user = authprov.User;
                int value = Iservice.DeleteType(model.DocumentTypeID, user.Identity.Name);
                if (value != -1)
                {
                    if (collection != null && collection.Any(s => s.DocumentTypeID == model.DocumentTypeID))
                    {
                        collection.Remove(collection.FirstOrDefault(s => s.DocumentTypeID == model.DocumentTypeID));
                        snackbar.Add("Deleted Successfully", Severity.Success);
                    }
                }
                else
                {
                    bool? error = await DialogService.ShowMessageBox(
                        "Failed !",
                        "DocumentType - " + model.DocumentTypeName + " is active with our Assets !");
                }
            }
        }
        else
        {
            bool? result = await DialogService.ShowMessageBox(
                "Permission denied!",
                "You dont have any permission to DeleteType AssetDocument.");
        }
    }

    private bool search(AssetDocumentTypeModel DocumentType)
    {
        if (DocumentType.DocumentTypeName != null && DocumentType.DocumentTypeName.Contains(searchDocumentType, StringComparison.OrdinalIgnoreCase))
        {
            return true;
        }
        return false;
    }

    private void OpenDialog()
    {
        DialogParameters parms = new DialogParameters();
        parms.Add("model", model);
        DialogService.Show<DocumentDilog>("Add Document", parms);
    }
}