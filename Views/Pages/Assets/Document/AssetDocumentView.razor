@page "/Document"
@inject IAssetDocumentService Iservice
@inject IAssetService IAsset
@inject MudBlazor.ISnackbar snackbar
@inject AuthenticationStateProvider auth
@attribute [Authorize]
@inject IDialogService DialogService

@using System.Text.RegularExpressions

<MudPaper Class="p-2 my-4 d-flex align-center">
    <AssetSelector Value="Asset" ValueChanged="AssetSelected" BranchID="@BranchID" Class="mx-5 my-5 bg-white" />
    @if (Asset != null)
    {
        <MudIconButton OnClick="@(()=> Edit(new AssetDocumentModel()))" Color="Color.Primary" Icon="@Icons.Material.Filled.Add" Size="Size.Medium" Title="Add New" />
    }
</MudPaper>
<MudText Typo="Typo.h6">Active Documents</MudText>
<MudGrid Spacing="2">
    @foreach (var item in collection)
    {
        <MudItem xs="12" sm="6" md="4" xl="3">
            <MudCard>
                <iframe class="mt-1 mr-1 ml-1" src="@item.AttachedDocument" style="height:350px" alt="@item.AttachedDocument" />
                <MudCardContent Class="overflow-auto" Style="min-width:500px">
                    <MudText Typo="Typo.h6">@item.DocumentType.DocumentTypeName</MudText>
                    <MudText Typo="Typo.body2">Period:  @string.Format("{0} - {1}", item.StartDate?.ToShortDateString(), item.EndDate?.ToShortDateString())</MudText>
                    <MudText Typo="Typo.body2">Doc Date:  @item.InvoiceDate?.ToShortDateString()</MudText>
                </MudCardContent>
                <MudCardActions>
                    <MudButton Variant="Variant.Text" Color="Color.Primary" OnClick="(()=>Edit(item))">Edit</MudButton>
                    <MudButton Variant="Variant.Text" Color="Color.Primary" OnClick="(()=> Remove(item))">Remove</MudButton>
                    <MyFileUpload FileName="@(item.DocumentType.DocumentTypeName + Guid.NewGuid().ToString())" FolderName="AssetDocuments" Label="Upload" FilePath="@item.AttachedDocument" FilePathChanged="((e)=> SaveImagePath(e,item.DocumentID))"></MyFileUpload>
                </MudCardActions>
            </MudCard>
        </MudItem>
    }
</MudGrid>
<MudDialog @bind-IsVisible="visible" Options="dialogOptions">
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudText Typo="Typo.h6">Add/Edit Documents</MudText>
        </MudText>
    </TitleContent>
    <DialogContent>
        <EditForm id="Docform" Model="@model" OnValidSubmit="OnValidSubmit">
            <DataAnnotationsValidator />
            <ValidationSummary />
            <MudGrid Spacing="2">
                <MudItem xs="6">
                    <MudSelect T="AssetDocumentTypeModel" @bind-Value="@model.DocumentType" ToStringFunc="@(e => e == null ? null : $"{e.DocumentTypeName}")" Label="Type" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.DocumentType)" OffsetY="true" AdornmentColor="Color.Secondary">
                        @foreach (var item in Dtypes)
                        {
                            <MudSelectItem Value="@item">@item.DocumentTypeName</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="6">
                    <MudDatePicker PickerVariant="PickerVariant.Dialog" @bind-Date="@model.InvoiceDate" Label="Reference Date" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.InvoiceDate)" Editable="true"></MudDatePicker>
                </MudItem>
                <MudItem xs="6">
                    <MudDatePicker PickerVariant="PickerVariant.Dialog" @bind-Date="@model.StartDate" Label="Begin On" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.StartDate)" Editable="true"></MudDatePicker>
                </MudItem>
                <MudItem xs="6">
                    <MudDatePicker PickerVariant="PickerVariant.Dialog" @bind-Date="@model.EndDate" Label="Expire On" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.EndDate)" Editable="true"></MudDatePicker>
                </MudItem>
            </MudGrid>
        </EditForm>
    </DialogContent>
    <DialogActions>
        <MudButton form="Docform" Variant="Variant.Filled" Color="Color.Success" ButtonType="ButtonType.Submit">Save</MudButton>
        @if (model.DocumentID != null)
        {
            <MudButton Variant="Variant.Filled" Color="Color.Error" OnClick="(()=> Delete(model))">Delete</MudButton>
        }
    </DialogActions>
</MudDialog>

@code {

    [Parameter] public AssetModel Asset { get; set; }
    private AssetDocumentModel model = new();
    private List<AssetDocumentModel> collection = new();
    private List<AssetDocumentTypeModel> Dtypes = new();
    string UserID;
    int BranchID;
    private bool visible;

    private IBrowserFile DocImage;

    private DialogOptions dialogOptions = new() { FullWidth = true };

    protected override async Task OnInitializedAsync()
    {
        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;
        UserID = user.Identity.Name;
        BranchID = int.Parse(user.Claims.First(x => x.Type == "BranchID").Value);
        Dtypes = Iservice.GetDocumentTypes().ToList();

        GetAll();
    }

    private void GetAll()
    {
        collection = Iservice.SelectByAsset(Asset?.AssetID).ToList();
    }

    private async void OnValidSubmit(EditContext context)
    {
        model.UserInfo.UserID = UserID;
        var validationOls = Iservice.ValidatePeriod(model).ToList();
        if (validationOls.Any(x => x.DocumentID != model.DocumentID))
        {
            snackbar.Add("Document Period cannot overlap! Please check the period ", Severity.Warning);
            return;
        }
        try
        {
            if (Asset == null)
            {
                snackbar.Add("Please select asset. ", Severity.Error);
                return;
            }
            if (model.Asset == null || model.Asset.AssetID == null || model.Asset.AssetID == 0)
            {
                model.Asset = Asset;
            }
            model = Iservice.Update(model);
            snackbar.Add("Saved Successfully", Severity.Success);
            GetAll();
            model = new();
            visible = false;
        }
        catch (Exception ex)
        {
            snackbar.Add(ex.Message, Severity.Error);
        }
    }

    private void Edit(AssetDocumentModel doc)
    {
        visible = true;
        model = doc;
    }

    private async Task Delete(AssetDocumentModel model)
    {
        bool? result = await DialogService.ShowMessageBox(
           "Warning !",
           "Are you sure, you want to delete - " + model.DocumentType.DocumentTypeName + " (" + model.InvoiceDate + ") ?");
        if (result == true)
        {
            Iservice.Delete(model.DocumentID, UserID);
            snackbar.Add("Deleted Successfully", Severity.Error);
            model = new();
            visible = false;
        }
        GetAll();
    }

    private async Task Remove(AssetDocumentModel model)
    {
        model.UserInfo.UserID = UserID;
        Iservice.Remove(model);
        snackbar.Add("Removed " + model.DocumentType.DocumentTypeName + " From " + Asset.Description, Severity.Success);
        GetAll();
    }

    private void AssetSelected(AssetModel selectedAsset)
    {
        Asset = selectedAsset;
        model = new() { Asset = selectedAsset };
        GetAll();
    }

    private void SaveImagePath(string filePath, int? docID)
    {
        int e = Iservice.SaveFilePath(filePath, docID);
        GetAll();
    }
}