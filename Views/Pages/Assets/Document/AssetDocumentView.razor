@page "/Document"
@inject IAssetDocumentService Iservice
@inject IAssetService IAsset
@inject MudBlazor.ISnackbar snackbar
@attribute [Authorize]
@using System.Threading;
@inject IRoleService<RoleModel> Irole
@inject AuthenticationStateProvider auth
@inject IDialogService DialogService
@inject SignalRService signalRService
@inject IPushNotificationService IpushNotificationService
@using System.Text.RegularExpressions
@using Views.Pages.Finance.Transactions.PurchaseAndPayment;

<div class="fade-in">
    <div class="admin-header-tiered mb-6">
        <div class="d-flex align-center justify-space-between">
            <div>
                <MudText Typo="Typo.h4" Class="admin-title">Asset Document Vault | Compliance & Licensing</MudText>
                <MudText Typo="Typo.body2" Class="admin-subtitle">Centralized repository for critical asset documentation. Manage permits, insurance policies, and statutory certifications while tracking expiry cycles and ensuring regulatory compliance across the fleet.</MudText>
            </div>
        </div>
    </div>

    <div class="admin-glass-card mb-6 pa-4">
        <div class="d-flex align-center gap-6 flex-wrap">
            <div style="flex-grow: 1; min-width: 300px;">
                <AssetSelector Value="Asset" ValueChanged="AssetSelected" BranchID="@BranchID" Class="admin-input-group" />
            </div>
            @if (Asset != null)
            {
                <MudButton Disabled="@_busy" OnClick="@(()=> OpenDialogEdit(new AssetDocumentModel(), false))" Color="Color.Primary" Variant="Variant.Filled" Class="admin-register-btn" StartIcon="@Icons.Material.Filled.Add">NEW DOCUMENT</MudButton>
            }
        </div>
    </div>

    <div class="admin-glass-card pa-0 overflow-hidden shadow-sm">
        <div class="bg-indigo-lighten-5 px-6 py-3 border-b d-flex align-center justify-space-between">
             <div class="d-flex align-center gap-2">
                <div class="admin-icon-square-vibrant tiny accent-indigo">
                    <MudIcon Icon="@Icons.Material.Filled.FolderCopy" Size="Size.Small" />
                </div>
                <MudText Typo="Typo.subtitle2" Class="fw-700 text-indigo uppercase">@Title Documents</MudText>
            </div>
            <div class="d-flex align-center gap-4">
                <MudSwitch Color="Color.Primary" Value="@AllDocs" ValueChanged="@((bool a) => GetAll(a))" Label="Include Archived" Class="fw-700 opa-70" />
                <MudSwitch Color="Color.Primary" @bind-Value=@(ViewChange) Label="Visual Grid View" Class="fw-700 opa-70" />
            </div>
        </div>

        @if (!ViewChange)
        {
            <MudSimpleTable Dense="true" Hover="true" Class="modern-admin-table no-border-radius">
                <thead>
                    <tr>
                        <th style="width: 50px;"></th>
                        <th><span class="admin-header-text">DOCUMENT TYPE</span></th>
                        <th><span class="admin-header-text">ISSUANCE DATE</span></th>
                        <th><span class="admin-header-text">VALIDITY PERIOD</span></th>
                        <th><span class="admin-header-text">LAST UPDATED BY</span></th>
                        <th style="text-align: right;"><span class="admin-header-text pr-4">ACTIONS</span></th>
                    </tr>
                </thead>
                <tbody>
                    @{ int serialNumber = 1; }
                    @foreach (var item in collection)
                    {
                        <tr class="@GetRowClass(item)">
                            <td class="fw-700">@serialNumber</td>
                            <td>
                                <div class="d-flex align-center gap-2">
                                    <span class="@(item.AttachedDocument == null ? "text-orange fw-800" : "fw-700")">@item.DocumentType.DocumentTypeName</span>
                                </div>
                            </td>
                            <td><span class="fw-600 opa-70">@item.InvoiceDate?.ToString("dd MMM yyyy")</span></td>
                            <td><span class="fw-700">@item.StartDate?.ToString("dd/MM/yyyy") - @item.EndDate?.ToString("dd/MM/yyyy")</span></td>
                            <td><MudChip T="string" Size="Size.Small" Variant="Variant.Text" Class="fw-800 opa-50 uppercase">@item.UserInfo.UserID</MudChip></td>
                            <td style="text-align: right;">
                                <div class="d-flex justify-end gap-1 mb-1">
                                    @if (item.AttachedDocument != null)
                                    {
                                        <MudTooltip Text="Inspect">
                                            <MudIconButton Icon="@Icons.Material.Filled.Visibility" Size="Size.Small" Color="Color.Info" OnClick="(()=>OpenDialogEdit(item, true))" Variant="Variant.Text" />
                                        </MudTooltip>
                                        <a href="@item.AttachedDocument" download="Document" target="_blank">
                                            <MudIconButton Icon="@Icons.Material.Filled.CloudDownload" Size="Size.Small" Color="Color.Primary" Title="Download" Variant="Variant.Text" />
                                        </a>
                                    }
                                    
                                    <MudTooltip Text="Modify Configuration">
                                        <MudIconButton Icon="@Icons.Material.Filled.Settings" Size="Size.Small" Color="Color.Default" OnClick="(()=>OpenDialogEdit(item, false))" Variant="Variant.Text" />
                                    </MudTooltip>
                                    
                                    <MudTooltip Text="Decommission Record">
                                        <MudIconButton Icon="@Icons.Material.Filled.DeleteForever" Size="Size.Small" Color="Color.Error" OnClick="(()=> Remove(item))" Variant="Variant.Text" />
                                    </MudTooltip>
                                @if (item.AttachedDocument == null && item.DocumentID != 0)
                                {
                                    @* <div class="px-2"> *@
                                            <MyFileUpload FileName="@Guid.NewGuid().ToString()" FolderName="AssetDocuments" Label="UPLOAD REQUISITE" FilePath="@item.AttachedDocument" FilePathChanged="((e) => SaveImagePath(e, item.DocumentID))" AcceptOnlyPdf="true" RenderAsIconButton="true" Icon="@Icons.Material.Filled.CloudUpload" Style="padding: 0;" Size="Size.Small" Color="Color.Default"></MyFileUpload>
                                    @* </div> *@
                                }
                                </div>
                            </td>
                        </tr>
                        serialNumber++;
                    }
                </tbody>
            </MudSimpleTable>
        }
        else
        {
            <div class="pa-4 bg-glass-surface">
                <MudGrid Spacing="4">
                    @foreach (var item in collection)
                    {
                        <MudItem xs="12" sm="6" lg="4" xl="3">
                            <div class="admin-glass-card h-100 pa-0 overflow-hidden shadow-sm hover-elevate transition-all border-lighter">
                                <div class="relative w-100" style="height: 240px; background: #f0f2f5;">
                                     <iframe src="@item.AttachedDocument" style="width:100%; height:100%; border:none;" />
                                     @if ((item.ExtendedEndDate != null && item.ExtendedEndDate < DateTime.Today) || (item.EndDate < DateTime.Today))
                                     {
                                         <div class="absolute inset-0 d-flex align-center justify-center" style="background: rgba(244, 67, 54, 0.1); backdrop-filter: blur(2px);">
                                             <span class="text-white fw-900 uppercase tracking-widest px-4 py-2 rounded shadow-lg" style="background: var(--mud-palette-error); transform: rotate(-15deg); border: 4px solid white;">EXPIRED</span>
                                         </div>
                                     }
                                </div>
                                <div class="pa-4">
                                    <MudText Typo="Typo.subtitle1" Class="fw-800 text-indigo truncate">@item.DocumentType.DocumentTypeName</MudText>
                                    <div class="d-flex align-center gap-2 mt-1 opa-60">
                                        <MudIcon Icon="@Icons.Material.Filled.Event" Size="Size.Small" />
                                        <span class="tiny fw-700 uppercase">Valid until @item.EndDate?.ToString("dd MMM yyyy")</span>
                                    </div>
                                    
                                    <div class="d-flex align-center justify-space-between mt-4">
                                        <div class="d-flex gap-1">
                                            <MudTooltip Text="Edit">
                                                <MudIconButton OnClick="(()=>OpenDialogEdit(item, false))" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Variant="Variant.Text" Color="Color.Default" />
                                            </MudTooltip>
                                            <MudTooltip Text="Remove">
                                                <MudIconButton OnClick="(()=> Remove(item))" Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Variant="Variant.Text" Color="Color.Error" />
                                            </MudTooltip>
                                        </div>
                                        @if (!item.IsFinanciallyPosted && item.DocumentID != 0)
                                        {
                                            <MudButton OnClick="(()=> OpenDialogTaxPurchase(item))" Variant="Variant.Outlined" Color="Color.Info" Size="Size.Small" Class="fw-800" Style="font-size: 0.7rem;">FINANCE POST</MudButton>
                                        }
                                    </div>
                                    
                                    @if (item.DocumentID != 0)
                                    {
                                        <div class="mt-3 pt-3 border-t">
                                            <MyFileUpload FileName="@(Guid.NewGuid().ToString())" FolderName="AssetDocuments" Label="RE-UPLOAD" FilePath="@item.AttachedDocument" FilePathChanged="((e)=> SaveImagePath(e,item.DocumentID))" AcceptOnlyPdf="true"></MyFileUpload>
                                        </div>
                                    }
                                </div>
                            </div>
                        </MudItem>
                    }
                </MudGrid>
            </div>
        }
    </div>
</div>

@code {

    [Parameter] public AssetModel Asset { get; set; }
    private AssetDocumentModel model = new();
    private List<AssetDocumentModel> collection = new();
    private List<AssetDocumentTypeModel> Dtypes = new();
    string UserID;
    int BranchID;
    private bool visible;
    private bool _busy;
    private bool ViewChange = false;
    private string Title { get; set; } = "Active";
    private bool AllDocs = false;

    public int TaxPurchaseDocTypeID = 9;
    #region SignaIR Notification

    private PushNotificationModel notificationMessage = new PushNotificationModel();
    #endregion
    private IBrowserFile DocImage;

    private DialogOptions dialogOptions = new() { FullWidth = true };

    public bool HasPermissionAssetDocumentServiceEdit { get; set; } = false;
    public bool HasPermissionAssetDocumentServiceRemove { get; set; } = false;
    public int AssetDocumentDocTypeID = 113;

    // Lifecycle method called when the component is initialized
    protected override async Task OnInitializedAsync()
    {
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionAssetDocumentServiceEdit = await Irole.HasClaim(AssetDocumentDocTypeID.ToString(), "Edit", ctc.Token);
        HasPermissionAssetDocumentServiceRemove = await Irole.HasClaim(AssetDocumentDocTypeID.ToString(), "Remove", ctc.Token);

        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;
        UserID = user.Identity.Name;
        BranchID = int.Parse(user.Claims.First(x => x.Type == "BranchID").Value);
        Dtypes = Iservice.GetDocumentTypes().ToList();
        await signalRService.StartAsync();
        GetAll(AllDocs);
    }

    // Method to retrieve all asset documents based on the AllDocs flag
    private void GetAll(bool a)
    {
        AllDocs = a;
        if (a)
        {
            Title = "All";
        }
        else
        {
            Title = "Active";
        }
        collection = Iservice.SelectByAsset(Asset?.AssetID, a).ToList(); // Fetch documents for the asset
    }

    // Method to get the row class based on document status
    private string GetRowClass(AssetDocumentModel item)
    {
        if (item.AttachedDocument == null)
        {
            return "bg-warning-light";
        }
        else if ((item.ExtendedEndDate != null && item.ExtendedEndDate < DateTime.Today) || (item.EndDate < DateTime.Today))
        {
            return "bg-error-light";
        }
        return string.Empty;
    }

    // Method to handle asset selection
    private void AssetSelected(AssetModel selectedAsset)
    {
        Asset = selectedAsset;
        model = new() { Asset = selectedAsset };
        GetAll(AllDocs);
    }

    // Method to save the image path for a document
    private async Task SaveImagePath(string filePath, int? docID)
    {
        if (HasPermissionAssetDocumentServiceEdit)
        {
            int e = Iservice.SaveFilePath(filePath, docID); // Save the file path
            GetAll(AllDocs);
        }
        else
        {
            bool? result = await DialogService.ShowMessageBoxAsync(
                "Permission denied!",
                "You don't have any permission to Edit AssetDocument.");
        }
    }

    // Method to open the dialog for editing an asset document
    private async Task OpenDialogEdit(AssetDocumentModel model, bool ReadOnly)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        _busy = true;
        var param = new DialogParameters
            {
                ["model"] = model.Clone(),
                ["Asset"] = Asset,
                ["Dtypes"] = Dtypes,
                ["ReadOnly"] = ReadOnly
            };
        var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Medium };
        var dialog = await DialogService.ShowAsync<AssetDocumentDialog>("ADD/EDIT", param, options);
        var result = await dialog.Result;
        var isCancelled = result.Canceled;
        await Task.Delay(200);
        _busy = false;
        if (!isCancelled)
        {
        }
        GetAll(AllDocs);
    }

    // Method to open the dialog for tax purchase
    private async Task OpenDialogTaxPurchase(AssetDocumentModel doc)
    {

        DialogOptions maxWidth = new DialogOptions() { MaxWidth = MaxWidth.Large, FullWidth = true };
        TaxPurchaseModel taxPurchase = new TaxPurchaseModel();
        DialogParameters parms = new DialogParameters();
        parms.Add("model", taxPurchase);

        var dialog = await DialogService.ShowAsync<TaxPurchaseDialog>("ADD", parms, maxWidth);
        var result = await dialog.Result;
        var isCancelled = result.Canceled;
        if (!isCancelled)
        {
            try
            {
                var ReturnData = (TaxPurchaseModel)result.Data;
                doc.IsFinanciallyPosted = true;
            }
            catch (Exception ex)
            {
                bool? exResult = await DialogService.ShowMessageBoxAsync(
                "Error!", ex.Message);
            }
        }
    }

    // Method to remove an asset document
    private async Task Remove(AssetDocumentModel model)
    {
        if (HasPermissionAssetDocumentServiceRemove)
        {
            bool? result = await DialogService.ShowMessageBoxAsync(
                "Warning !",
                (MarkupString)$"This will remove further tracking of <B>{model.DocumentType.DocumentTypeName}</B>. Are you sure you want to proceed ?");
            if (result == true)
            {
                model.UserInfo.UserID = UserID;
                Iservice.Remove(model); // Remove the document
                snackbar.Add("Removed " + model.DocumentType.DocumentTypeName + " From " + Asset.Description, Severity.Success);
                GetAll(AllDocs);
            }
        }
        else
        {
            bool? result = await DialogService.ShowMessageBoxAsync(
                "Permission denied!",
                "You don't have any permission to Remove AssetDocument.");
        }
    }
}
