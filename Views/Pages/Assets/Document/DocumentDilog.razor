@inject IAssetDocumentService Iservice
@inject IDialogService DialogService
@inject MudBlazor.ISnackbar snackbar
@inject AuthenticationStateProvider auth
@inject IConfigTable config
@attribute [Authorize]

<MudDialog>
    <TitleContent>
        @if (model.DocumentTypeID == null || model.DocumentTypeID == 0)
        {
            <MudText Typo="Typo.h6">
                <MudIcon Icon="@Icons.Material.Filled.Edit" Class="mr-3" /> Add Document Type
            </MudText>
        }
        else
        {
            <MudText Typo="Typo.h6">
                <MudIcon Icon="@Icons.Material.Filled.Edit" Class="mr-3" /> Edit Document Type
            </MudText>
        }
    </TitleContent>
    <DialogContent>
        <MudContainer Style="max-height: 400px; overflow-y: scroll; margin-left:20px">
            <EditForm id="formDocumentDialog" Model="@model" OnValidSubmit="OnValidSubmit">
                <DataAnnotationsValidator />
                <ValidationSummary />
                <MudItem xs="11" md="11" Class="mb-6">
                    <MudTextField @bind-Value="@model.DocumentTypeName" Label="Document Type" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.DocumentTypeName)"></MudTextField>
                </MudItem>
                <MudItem xs="11" md="11" Class="mb-6">
                    <MudTextField @bind-Value="@model.WarnBefore" Label="Warn Before" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.WarnBefore)" Adornment="Adornment.End" AdornmentText="Days"></MudTextField>
                </MudItem>
                <MudItem xs="11" md="11" Class="mb-6">
                    <MudTextField @bind-Value="@model.BlockAfter" Label="Block After" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.BlockAfter)" Adornment="Adornment.End" AdornmentText="Days"></MudTextField>
                </MudItem>
                <MudItem xs="11" md="11">
                    <UsageCodeSelector @bind-Value="@model.UsageCode" LabelName="Select Usage Code" />
                </MudItem>
            </EditForm>
        </MudContainer>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Disabled="@_busy" form="formDocumentDialog" Variant="Variant.Filled" Color="Color.Success" ButtonType="ButtonType.Submit" Class="px-12">Submit</MudButton>
    </DialogActions>
</MudDialog>

@code {

    [Parameter]
    public AssetDocumentTypeModel model { get; set; }
    private string searchDocumentType = "";
    private List<AssetDocumentTypeModel>
    collection = new();
    [CascadingParameter] MudDialogInstance MudDialog { get; set; }
    private List<GstUsageCodeModel> usageList = new();
    private bool _busy;

    protected override async Task OnInitializedAsync()
    {

    }

    // Method called when the form is submitted successfully
    private async void OnValidSubmit(EditContext context)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is being submitted!", Severity.Warning);
            return;
        }
        _busy = true;

        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;
        model.UserInfo.UserID = user.Identity.Name;
        try
        {
            // Convert the document type name to camel case
            model.DocumentTypeName = FontStyle.ConvertToCamelCase(model.DocumentTypeName);
            MudDialog.Close(model);
            // model = Iservice.UpdateDocumentType(model);
            // snackbar.Add("Saved Successfully", Severity.Success);
            // if (collection.Exists(x => x.DocumentTypeID == model.DocumentTypeID))
            // {
            //     collection[collection.FindIndex(x => x.DocumentTypeID == model.DocumentTypeID)] = model;
            // }
            // else
            // {
            //     collection.Add(model);
            // }
        }
        catch (Exception ex)
        {
            snackbar.Add(ex.Message, Severity.Warning);
        }
        //MudDialog.Close(model);
        model = new();

        await Task.Delay(200);
        _busy = false;
    }

    // Method to edit an existing document type based on its ID
    private void Edit(int? id)
    {
        model = collection.First(x => x.DocumentTypeID == id);
    }

    // Method to cancel the dialog
    private void Cancel()
    {
        MudDialog.Cancel();
    }
}