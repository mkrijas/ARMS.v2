@page "/ScrapAssetView"
@inject IAssetService Iservice
@inject IAssetClassService assetclassIservice
@inject IGstUsageIDService gstIservice
@inject IPartyService partyIservice
@inject MudBlazor.ISnackbar snackbar

@inject AuthenticationStateProvider auth
@attribute [Authorize]
@inject IDialogService DialogService



<MudGrid Spacing="4">
    <MudItem xs="12">
        <MudTable Items="@collection" Dense="true" Hover="true" Striped="true" Elevation="10" @bind-place="model">


            <ToolBarContent>
                <MudText Typo="Typo.h6">Scrap Assets</MudText>


            </ToolBarContent>
            <HeaderContent>
                <MudTh><MudTableSortLabel SortBy="new Func<AssetModel, object>(x=> x.Description)" InitialDirection="SortDirection.Ascending">Description</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<AssetModel, object>(x=> x.SerialNumber)" InitialDirection="SortDirection.Ascending">SerialNumber</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<AssetModel, object>(x=> x.NatureOfAsset)" InitialDirection="SortDirection.Ascending">NatureOfAsset</MudTableSortLabel></MudTh>

                <MudTh><MudTableSortLabel SortBy="new Func<AssetModel, object>(x=> x.AssetCode)" InitialDirection="SortDirection.Ascending">AssetCode</MudTableSortLabel></MudTh>

                <MudTh>Actions</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="DocumentDate">@context.Description</MudTd>

                <MudTd DataLabel="DocumentNumber">@context.SerialNumber</MudTd>
                <MudTd DataLabel="ContraModeHome">@context.NatureOfAsset</MudTd>
                <MudTd DataLabel="Amount">@context.AssetCode</MudTd>
                <MudTd DataLabel="">

                </MudTd>
            </RowTemplate>

            <PagerContent>
                <MudTablePager PageSizeOptions="new int[] { 5, 10, 20, 50, 100 }" />
                @*  <MudButton OnClick="selected" Variant="Variant.Filled" Color="Color.Success" ButtonType="ButtonType.Submit">Submit</MudButton>*@

            </PagerContent>
        </MudTable>
    </MudItem>
</MudGrid>
@code {
    private AssetModel model = new AssetModel();

    private List<AssetModel> collection = new List<AssetModel>();
    protected override async Task OnInitializedAsync()
    {

       await GetAll();
    }
    private async Task GetAll()
    {
        var authprov = await auth.GetAuthenticationStateAsync();
        var brancIDString = authprov.User.Claims.First(x => x.Type == "BranchID").Value;
        int brancID = int.Parse(brancIDString);
        collection = Iservice.SelectByBranch(brancID, true).ToList();
      
    }
}
