@page "/ScrapAssetView"
@inject IAssetService Iservice
@inject IAssetClassService assetclassIservice
@inject IGstUsageIDService gstIservice
@inject IPartyService partyIservice
@inject MudBlazor.ISnackbar snackbar
@inject AuthenticationStateProvider auth
@attribute [Authorize]
@inject IDialogService DialogService

@if (_isLoading)
{
    <div @key="@("loader")" style="position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(255,255,255,0.9); z-index: 9999; display: flex; justify-content: center; align-items: center;">
        <LoaderComponent IsFullScreen="true"
                         ShowLogo="false"
                         Size="medium"
                         LoadingText="Loading Scrap Assets"
                         SubText="Please wait..." />
    </div>
}
else
{
    <div @key="@("content")">

        <MudGrid Spacing="4">
            <MudItem xs="12">
                <MudTable Items="@collection" Dense="true" Hover="true" Striped="true" Elevation="10" @bind-place="model">
                    <ToolBarContent>
                        <MudText Typo="Typo.h6">Scrap Assets</MudText>
                    </ToolBarContent>
                    <HeaderContent>
                        <MudTh><MudTableSortLabel SortBy="new Func<AssetModel, object>(x => x.Description)" InitialDirection="SortDirection.Ascending">Description</MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<AssetModel, object>(x => x.SerialNumber)" InitialDirection="SortDirection.Ascending">Serial Number</MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<AssetModel, object>(x => x.NatureOfAsset)" InitialDirection="SortDirection.Ascending">Nature Of Asset</MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<AssetModel, object>(x => x.AssetCode)" InitialDirection="SortDirection.Ascending">Asset Code</MudTableSortLabel></MudTh>
                        <MudTh>Actions</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="DocumentDate">@context.Description</MudTd>
                        <MudTd DataLabel="DocumentNumber">@context.SerialNumber</MudTd>
                        <MudTd DataLabel="ContraModeHome">@context.NatureOfAsset</MudTd>
                        <MudTd DataLabel="Amount">@context.AssetCode</MudTd>
                        <MudTd DataLabel="">
                        </MudTd>
                    </RowTemplate>
                    <PagerContent>
                        <MudTablePager PageSizeOptions="new int[] { 10, 20, 50, 100 }" />
                    </PagerContent>
                </MudTable>
            </MudItem>
        </MudGrid>

    </div>
}

@code {

    private bool _isLoading = true;
    private DateTime _loadStartTime;

    private AssetModel model = new AssetModel();
    private List<AssetModel> collection = new List<AssetModel>();

    // Lifecycle method called when the component is initialized
    protected override async Task OnInitializedAsync()
    {
        _loadStartTime = DateTime.Now;
        await GetAll();
        await EnsureMinimumLoadTime();
        _isLoading = false;
    }

    private async Task EnsureMinimumLoadTime()
    {
        var elapsed = (DateTime.Now - _loadStartTime).TotalMilliseconds;
        if (elapsed < 100)
        {
            await Task.Delay(100 - (int)elapsed);
        }
    }

    // Method to retrieve all assets for the current branch
    private async Task GetAll()
    {
        var authprov = await auth.GetAuthenticationStateAsync();
        var brancIDString = authprov.User.Claims.First(x => x.Type == "BranchID").Value;
        int brancID = int.Parse(brancIDString);

        // Fetch assets for the current branch and populate the collection
        collection = Iservice.SelectByBranch(brancID, true, null, "").ToList();
    }
}
