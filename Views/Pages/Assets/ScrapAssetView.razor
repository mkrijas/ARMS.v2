@page "/ScrapAssetView"
@inject IAssetService Iservice
@inject IAssetClassService assetclassIservice
@inject IGstUsageIDService gstIservice
@inject IPartyService partyIservice
@inject MudBlazor.ISnackbar snackbar
@inject AuthenticationStateProvider auth
@attribute [Authorize]
@inject IDialogService DialogService

@if (_isLoading)
{
    <div @key="@("loader")" style="display: flex; justify-content: center; align-items: center; min-height: 400px;">
        <LoaderComponent IsFullScreen="true" 
                        ShowLogo="false" 
                        Size="medium" 
                        LoadingText="Auditing Retired Assets" 
                        SubText="Retrieving scrap inventory..." />
    </div>
}
else
{
    <div class="fade-in">
        <div class="admin-header-tiered mb-6">
            <div class="d-flex align-center justify-space-between">
                <div>
                    <MudText Typo="Typo.h4" Class="admin-title">Asset Disposal & Recovery | Scrap Inventory</MudText>
                    <MudText Typo="Typo.body2" Class="admin-subtitle">Decommissioning terminal for organizational capital assets. Monitor retired equipment, verify scrap conditions, and maintain permanent archival records of the asset lifecycle across all terminal nodes.</MudText>
                </div>
            </div>
        </div>

        <div class="admin-glass-card pa-0 overflow-hidden shadow-sm">
            <MudTable Items="@collection" Elevation="0" Class="modern-admin-table" Hover="true" T="AssetModel">
                <HeaderContent>
                    <MudTh><MudTableSortLabel SortBy="new Func<AssetModel, object>(x => x.Description)"><span class="admin-header-text">ASSET DESCRIPTION</span></MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<AssetModel, object>(x => x.SerialNumber)"><span class="admin-header-text">SERIAL NUMBER</span></MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<AssetModel, object>(x => x.NatureOfAsset)"><span class="admin-header-text">NATURE OF ASSET</span></MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<AssetModel, object>(x => x.AssetCode)"><span class="admin-header-text">ASSET CODE</span></MudTableSortLabel></MudTh>
                    <MudTh Style="text-align: right;"><span class="admin-header-text">ACTIONS</span></MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Description">
                        <span class="fw-700 admin-td-primary">@context.Description</span>
                    </MudTd>
                    <MudTd DataLabel="Serial">
                        <span class="fw-800 text-indigo small">@context.SerialNumber</span>
                    </MudTd>
                    <MudTd DataLabel="Nature">
                        <div class="d-flex align-center gap-2">
                             <div class="admin-icon-square-vibrant tiny accent-indigo">
                                <MudIcon Icon="@Icons.Material.Filled.Category" Size="Size.Small" />
                            </div>
                            <span class="fw-600">@context.NatureOfAsset</span>
                        </div>
                    </MudTd>
                    <MudTd DataLabel="Code">
                        <MudChip T="string" Color="Color.Default" Size="Size.Small" Variant="Variant.Text" Class="fw-800 opa-50">@context.AssetCode</MudChip>
                    </MudTd>
                    <MudTd DataLabel="Actions" Style="text-align: right;">
                        <MudTooltip Text="Inspect Disposal Data">
                            <MudIconButton Icon="@Icons.Material.Filled.Search" Color="Color.Info" Size="Size.Small" Variant="Variant.Text" />
                        </MudTooltip>
                    </MudTd>
                </RowTemplate>
                <PagerContent>
                    <div class="pa-4">
                        <MudTablePager PageSizeOptions="new int[] { 10, 20, 50, 100 }" />
                    </div>
                </PagerContent>
            </MudTable>
        </div>
    </div>
}

@code {

    private bool _isLoading = true;
    private DateTime _loadStartTime;

    private AssetModel model = new AssetModel();
    private List<AssetModel> collection = new List<AssetModel>();

    // Lifecycle method called when the component is initialized
    protected override async Task OnInitializedAsync()
    {
        _loadStartTime = DateTime.Now;
        await GetAll();
        await EnsureMinimumLoadTime();
        _isLoading = false;
    }

    private async Task EnsureMinimumLoadTime()
    {
        var elapsed = (DateTime.Now - _loadStartTime).TotalMilliseconds;
        if (elapsed < 100)
        {
            await Task.Delay(100 - (int)elapsed);
        }
    }

    // Method to retrieve all assets for the current branch
    private async Task GetAll()
    {
        var authprov = await auth.GetAuthenticationStateAsync();
        var brancIDString = authprov.User.Claims.First(x => x.Type == "BranchID").Value;
        int brancID = int.Parse(brancIDString);

        // Fetch assets for the current branch and populate the collection
        collection = Iservice.SelectByBranch(brancID, true, null, "").ToList();
    }
}
