@page "/AssetSimpleView"
@inject IAssetService Iservice
@inject IAssetClassService assetclassIservice
@inject IGstUsageIDService gstIservice
@inject IPartyService partyIservice
@inject MudBlazor.ISnackbar snackbar
@inject NavigationManager _navigationManager
@inject AuthenticationStateProvider auth
@attribute [Authorize]
@inject IDialogService DialogService

@if (_isLoading)
{
    <div @key="@("loader")" style="display: flex; justify-content: center; align-items: center; min-height: 400px;">
        <LoaderComponent IsFullScreen="true" 
                        ShowLogo="false" 
                        Size="medium" 
                        LoadingText="Mapping Asset Inventory" 
                        SubText="Cataloging equipment nodes..." />
    </div>
}
else
{
    <div class="fade-in">
        <div class="admin-header-tiered mb-6">
            <div class="d-flex align-center justify-space-between">
                <div>
                    <MudText Typo="Typo.h4" Class="admin-title">Asset Repository | Fleet & Equipment</MudText>
                    <MudText Typo="Typo.body2" Class="admin-subtitle">Comprehensive database of organizational assets. Categorize equipment, track serial identifiers, and delineate between simple and complex asset architectures to optimize lifecycle management.</MudText>
                </div>
                <div class="d-flex gap-2">
                    <MudButton OnClick="@(()=> OpenDialog())" Variant="Variant.Filled" Color="Color.Primary" Class="admin-register-btn" StartIcon="@Icons.Material.Filled.Add" Disabled="@_busy">SIMPLE ASSET</MudButton>
                    <MudButton OnClick="@(()=> OpenDialogComplexAsset())" Variant="Variant.Outlined" Color="Color.Secondary" Class="admin-register-btn" StartIcon="@Icons.Material.Filled.AccountTree" Disabled="@_busy">COMPLEX ASSET</MudButton>
                </div>
            </div>
        </div>

        <div class="admin-glass-card mb-6 pa-4">
            <div class="d-flex align-center gap-4 flex-wrap">
                <div style="flex-grow: 1; min-width: 300px;">
                    <MudTextField @bind-Value="searchTerm" Placeholder="Search by description, serial #, or category..." Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" Variant="Variant.Outlined" Margin="Margin.Dense" Class="admin-input-group" Clearable="true" OnKeyUp="HandleSearchKeyUp" />
                </div>
                <div class="d-flex align-center gap-4">
                    <div class="d-flex align-center bg-glass rounded-pill px-4 py-1">
                        <MudText Typo="Typo.caption" Class="fw-700 opa-50 uppercase mr-2">Limit</MudText>
                        <MudNumericField @bind-Value="@NumberOfRecords" Variant="Variant.Text" Margin="Margin.Dense" Style="width: 50px;" Class="fw-700 mt-0" HideSpinButtons="true" />
                    </div>
                </div>
            </div>
        </div>

        <div class="admin-glass-card pa-0 overflow-hidden shadow-sm">
             <div class="modern-table-header-row px-4 py-3 d-none d-md-flex align-center">
                <div style="width: 50px;"></div>
                <div style="flex: 2;"><span class="admin-header-text">DESCRIPTION</span></div>
                <div style="flex: 2;"><span class="admin-header-text">NATURE OF ASSET</span></div>
                <div style="flex: 1.5;"><span class="admin-header-text">SERIAL NUMBER</span></div>
                <div style="flex: 1.5;"><span class="admin-header-text">TYPE</span></div>
                <div style="width: 120px; text-align: right;"><span class="admin-header-text pr-4">ACTIONS</span></div>
            </div>
            
            <div class="pa-2">
                @foreach (var child in Model)
                {
                    <AssetDisplayControl Model="child" AssetChanged="ChangeAsset"/>
                }

                @if (Model == null || !Model.Any())
                {
                    <div class="pa-12 d-flex flex-column align-center justify-center">
                        <MudIcon Icon="@Icons.Material.Filled.Analytics" Size="Size.Large" Color="Color.Default" Class="opa-10 mb-4" />
                        <MudText Typo="Typo.h6" Class="fw-700 opa-20">NO ASSETS INDEXED</MudText>
                    </div>
                }
            </div>
        </div>
    </div>
}

@code {

    private bool _isLoading = true;
    private DateTime _loadStartTime;

    private int numberOfRecords = 1000;
    private string searchTerm = "";
    private bool _busy;
    private List<AssetViewModel> Model = new List<AssetViewModel>();
    [Parameter]
    public EventCallback <bool> AssetChanged { get; set; }

    DialogOptions maxWidth = new DialogOptions() { MaxWidth = MaxWidth.Medium, FullWidth = true };

    // Method to handle asset changesc
    private async Task ChangeAsset(bool val)
    {
        await GetAll();
        await AssetChanged.InvokeAsync(true);
    }

    // Method to handle search input when the Enter key is pressed
    private async Task HandleSearchKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await GetAll();
        }
    }

    // Property to manage the number of records displayed
    private int NumberOfRecords
    {
        get => numberOfRecords;
        set
        {
            if (numberOfRecords != value)
            {
                numberOfRecords = value;
                _ = GetAll();
            }
        }
    }

    // Lifecycle method called when the component is initialized
    protected override async Task OnInitializedAsync()
    {
        _loadStartTime = DateTime.Now;
        await GetAll();
        await EnsureMinimumLoadTime();
        _isLoading = false;
    }

    private async Task EnsureMinimumLoadTime()
    {
        var elapsed = (DateTime.Now - _loadStartTime).TotalMilliseconds;
        if (elapsed < 100)
        {
            await Task.Delay(100 - (int)elapsed);
        }
    }

    // Method to retrieve all assets based on the current branch and search term
    public async Task GetAll()
    {
        var authprov = await auth.GetAuthenticationStateAsync();
        var claim = authprov.User.Claims.FirstOrDefault(x => x.Type == "BranchID");
        if (claim == null) return;
        var brancIDString = claim.Value;
        int brancID = int.Parse(brancIDString);
        if (Model != null)
        {
            Model.Clear();
        }
        Iservice.ClearAssets(); // Clear any existing assets in the service
        // Fetch assets based on branch ID, number of records, and search term
        Model = Iservice.GetAssetView(brancID, null, NumberOfRecords, searchTerm).ToList();
    }

    // Method to open a dialog for adding a simple asset
    private async Task OpenDialog()
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        _busy = true;

        var authprov = await auth.GetAuthenticationStateAsync();
        AssetModel assetModel = new AssetModel();
        var user = authprov.User;
        assetModel.IsComplex = false;
        DialogParameters parms = new DialogParameters();
        parms.Add("model", assetModel.Clone());
        var dialog = await DialogService.ShowAsync<AssetSimpleDialog>("Simple Asset", parms, maxWidth);
        var result = await dialog.Result;

        if (!result.Canceled)
        {
            await GetAll();
            //_navigationManager.NavigateTo("AssetSimpleView", true);
        }
        await Task.Delay(200);
        _busy = false;
    }

    // Method to open a dialog for adding a complex asset
    private async Task OpenDialogComplexAsset()
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        _busy = true;

        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;
        AssetModel assetModel = new AssetModel();
        assetModel.IsComplex = true;
        DialogParameters parms = new DialogParameters();
        parms.Add("model", assetModel.Clone());
        var dialog = await DialogService.ShowAsync<AssetSimpleDialog>("Complex Asset", parms, maxWidth);
        var result = await dialog.Result;
        if (!result.Canceled)
        {
            await GetAll();
            //_navigationManager.NavigateTo("AssetSimpleView", true);
        }
        await Task.Delay(200);
        _busy = false;
    }
}
