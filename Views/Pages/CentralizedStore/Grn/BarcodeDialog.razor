@inject IBarcodeService barcodeService
@inject IJSRuntime JS

<MudDialog>
    <DialogContent>
        @if (!string.IsNullOrEmpty(barcodeBase64))
        {
            <img src="@barcodeBase64" style="display:block; margin:10px auto 0 auto;" />
        }
        else
        {
            <MudText Color="Color.Error">Barcode could not be generated.</MudText>
        }
    </DialogContent>
    <DialogActions>
        <MudButton Color="Color.Primary" OnClick="Print">Print</MudButton>
        <MudButton OnClick="@MudDialog.Cancel">Close</MudButton>
    </DialogActions>
</MudDialog>

<script>
    function printImage(base64DataUrl) {
        var win = window.open("");
        win.document.write('<img src="' + base64DataUrl + '" onload="window.print(); window.close();" />');
        win.document.close();
    }
</script>

@code {
    [CascadingParameter] MudDialogInstance MudDialog { get; set; }
    [Parameter] public string Code { get; set; }

    private string barcodeBase64;

    protected override void OnInitialized()
    {
        barcodeBase64 = barcodeService.GenerateBase64Barcode(Code);
    }

    private async Task Print()
    {
        await JS.InvokeVoidAsync("printImage", barcodeBase64);
    }
}

