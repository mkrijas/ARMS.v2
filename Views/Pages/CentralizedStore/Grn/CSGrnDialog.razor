@attribute [Authorize]
@inherits DialogFormComponentBase<CSGrnModel>
@inject AuthenticationStateProvider auth
@inject ICSGrnService Iservice
@inject IInventoryGrnService grnIservice
@inject IInventoryItemService itemIservice
@inject IGstItemService gstitemIservice
@inject IInventoryGroupService inventoryGroupIservice
@inject ITdsRateService tdsIService
@inject IJSRuntime JSRuntime

<DialogForm @ref="@dialogForm" ReadOnly="@ReadOnly" Title="Centralized Store GRN" formID="formCSGrn" DocumentDetails="DocInfo" OnFileRemoved="RemoveFileChange" model="@model" _busy="_busy">
    <FormContent>
        <MudPaper Class="p-3">
            <EditForm autocomplete="off" id="formCSGrn" OnValidSubmit="OnValidSubmit" EditContext="editContext">
                <ObjectGraphDataAnnotationsValidator />
                <ValidationSummary />
                <MudGrid>
                    <MudItem xs="12" md="6">
                        <MudDatePicker Disabled="@Disable" ReadOnly="ReadOnly" Label="Document Date" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.DocumentDate)" DisableToolbar="true" Editable="true" @bind-Date="model.DocumentDate" DateFormat="dd/MM/yyyy" MaxDate="DateTime.Now" />
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <PartySelector Value="model.PartyInfo" For="@(()=> model.PartyInfo)" ValueChanged="PartyChanged" BranchID="BranchID" ReadOnly></PartySelector>
                        <MudText Typo="Typo.caption"> @model.PartyInfo?.GstRegType  @model.PartyInfo?.GstNo</MudText>
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudDatePicker ReadOnly="ReadOnly" Label="Invoice Date" Variant="Variant.Outlined" Margin="Margin.Dense" DisableToolbar="true" Editable="true" DateFormat="dd/MM/yyyy" @bind-Date="model.InvoiceDate" For="@(() => model.InvoiceDate)" />
                    </MudItem>
                    <MudItem xs="12" md="6">
                        @* <MudTextField ReadOnly="ReadOnly" @bind-Value="model.InvoiceNo" Label="Invoice No" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.InvoiceNo)"></MudTextField> *@
                        <MudTextField ReadOnly="ReadOnly" 
                            Value="model.InvoiceNo" 
                            T="string"
                            Immediate=true
                            Label="Invoice No" 
                            Variant="Variant.Outlined" 
                            Margin="Margin.Dense" 
                            For="@(() => model.InvoiceNo)"
                            ValueChanged="((e)=> OnInputChange(e))">
                        </MudTextField>
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudNumericField HideSpinButtons T="decimal?" Immediate=true Label="Roundoff" Value="model.RoundOff" Variant="Variant.Outlined" Margin="Margin.Dense" ValueChanged="((e)=> OnRoundOffChanged(e))"></MudNumericField>
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudNumericField HideSpinButtons Label="Billed Amount" @bind-Value="TotalBillAmount" Variant="Variant.Outlined" Margin="Margin.Dense" Required></MudNumericField>
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudTextField ReadOnly="ReadOnly" @bind-Value="model.Reference" Lines="2" Label="Narration" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.Reference)"></MudTextField>
                    </MudItem>
                    <MudItem xs="12" md="12">
                        <MudTextField ReadOnly="ReadOnly" @bind-Value="model.Narration" Lines="2" Label="Narration" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.Narration)"></MudTextField>
                    </MudItem>
                    <MudItem xs="12">                       
                        <CSItemsListView OnItemAdded="AddItems" OnAmountChange="SetTotal" BranchID="@BranchID" PartyInfo="@model.PartyInfo" Local="@Local" IsTaxable="@IsTaxable" ItemList="@model.Items" ReadOnly="@ReadOnly" EditMode="@(model.POID != null)" />
                    </MudItem>
                </MudGrid>
            </EditForm>
        </MudPaper>
    </FormContent>
    <VerificationStatus>
        <AutherizationStatusComponent CreatedBy="@model.UserInfo" DocTypeID="@DocInfo.DocumentTypeID" DocumentID="@model.GrnID" OnApprove="Approve"></AutherizationStatusComponent>
    </VerificationStatus>
</DialogForm>

@code {

    [Parameter]
    public override CSGrnModel model { get { return _model; } set { _model = value; } }
    private CSGrnModel _model;
    bool Disable;
    int branchID;
    string UserID;
    string UserIDTemp;
    private decimal? TotalBillAmount;

    ValidationMessageStore messageStore;

    // Method to handle input changes for the invoice number
    private void OnInputChange(string value)
    {
        model.InvoiceNo = value.Replace(" ", string.Empty);
    }

    // Document information model for the tax purchase
    protected override DocumentInfoModel DocInfo { get; set; } = new DocumentInfoModel()
        {
            DocumentTypeID = 146,
        };

    // Lifecycle method called when the component is initialized
    protected override async Task OnInitializedAsync()
    {        
        DocInfo.DocumentID = model.GrnID;

        await base.OnInitializedAsync();

        if (model.PartyInfo != null)
        {
            PartyChanged(model.PartyInfo);
        }
        if (model.GrnID != null)
        {
            UserIDTemp = model.UserInfo.UserID;
            model.PartyInfo = partyService.SelectByID(model.PartyInfo.PartyID); // Fetch party info
            model.Items = Iservice.GetItems(model.GrnID).ToList(); // Fetch items related to the tax purchase
            TotalBillAmount = model.TotalAmount;
        }
        else
        {
            model.NatureOfTransaction = "Centralized Store Grn";
            model.BranchID = BranchID;
            model.RoundOff = (decimal)0.00;
        }
    }

    private void OnRoundOffChanged(decimal? value)
    {
        model.RoundOff = value; // Update the model with the new RoundOff value
        SetTotal(); // Recalculate total amount based on changes
    }


    // Method to set the total amount based on expenses, items, and assets
    void SetTotal()
    {
        model.TotalAmount = (model.Items.Where(y => y != null).Sum(y => y.Amount + y.IGST + y.CGST + y.SGST) ?? 0) + model.RoundOff;
    }

    // Method to handle changes in the selected party
    void PartyChanged(PartyModel party)
    {
        model.PartyInfo = party;
        if (party != null)
        {
            IsTaxable = party.GstType == "Registered" || party.GstType == "SEZ";
            Local = partyService.IsLocal(model.PartyInfo.PartyID, BranchID); // Check if the party is local
        }
        else { Local = false; }
    }

    // Method to add an item to the tax purchase model
    async Task AddItems(CSGrnItemModel ItemModel)
    {
        model.Items.Add(ItemModel);
        SetTotal();
    }

    // Method to update the tax purchase model
    protected override async Task<int> Update(CSGrnModel editModel)
    {
        if (await validate(model))
        {
            foreach (var item in model.Items)
            {
                var uomList = itemIservice.GetConversionFactor(item.ItemID.Value, item.UoM).ToList();
                var selected = uomList.FirstOrDefault(u => u.UoM == item.UoM);
                if (selected != null)
                {
                    var checkQty = Math.Round((item.ItemQty ?? 0) * selected.ConversionFactor.Value, 2);
                    if (item.BaseQty < checkQty)
                    {
                        snackbar.Add("Qty cannot be greater than PO Qty", Severity.Error);
                        return 0; // Return 0 if validation fails
                    }
                }                
            }
            model = Iservice.Update(model); // Update the model using the service
            return model.GrnID.Value;
        }
        return 0;
    }

    // Method to approve the tax purchase model
    protected override int UpdateApproval(DataApprovedStatus aprvd)
    {
        int result = Iservice.Approve(model.GrnID, model.UserInfo.UserID, aprvd.Remarks); // Call the service to approve
        model.UserInfo.UserID = UserIDTemp; 
        return result;
    }

    // Method to validate the tax purchase model
    public async Task<bool> validate(CSGrnModel editModel)
    {
        if (!DayOpenService.ValidateDayOpen(editModel.DocumentDate, DocInfo.DocumentTypeID, editModel.BranchID).Value)
        {
            bool? result = await dialogService.ShowMessageBox(
                "Oops !",
                new MarkupString("The specified DocumentDate : <b>" + editModel.DocumentDate.Value.ToString("dd/MM/yyyy") + "</b> is closed ! <br>Please create a request to open the date."));
            return false;
        }
        SetTotal();
        if (TotalBillAmount != editModel.TotalAmount)
        {
            snackbar.Add("Please Set Billed amount", Severity.Warning);
            return false;
        }
        return true;
    }
       
}