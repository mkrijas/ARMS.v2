@page "/CentralizedStore/PurchaseOrder"
@page "/CentralizedStore/PurchaseOrder/{id:int}"
@using System.Threading;
@inject ICSPurchaseOrderService Iservice
@inject MudBlazor.ISnackbar snackbar
@inject AuthenticationStateProvider auth
@inject IRoleService<RoleModel> Irole
@attribute [Authorize]
@inject IDialogService DialogService
@inject SignalRService signalRService
@inject IPushNotificationService IpushNotificationService


<MudGrid Spacing="4">
    <MudItem xs="12">
        <MudTable Items="@collection" RowStyleFunc="TableRowStyle" Dense="true" Hover="true" Striped="true" Elevation="10" Filter="new Func<CSPurchaseOrderModel, bool>(search)" @bind-place="model">
            <ToolBarContent>
                <MudText Typo="Typo.h6">Centralized Store Purchase Order</MudText>
                <MudIconButton Disabled="@_busy" Icon="@Icons.Material.Filled.Add" Title="Add" @onclick="@(()=> OpenDialog(new CSPurchaseOrderModel(),false,false))" Color="Color.Dark" Size="Size.Small"></MudIconButton>
                <MudSpacer></MudSpacer>
                <MudTextField @bind-Value="searchPurchase" Placeholder="Search Purchase order... " Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0"></MudTextField>
                <MudCheckBox Label="Approved Entries" CheckedChanged="((bool value)=>ApprovedChanged(value))" Checked="@IsApproved" Size="Size.Medium" Color="Color.Primary"></MudCheckBox>
            </ToolBarContent>
            <HeaderContent>
                <MudTh><MudTableSortLabel SortBy="new Func<CSPurchaseOrderModel, object>(x=> x.PONo)">PO No</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<CSPurchaseOrderModel, object>(x=> x.EntryDate)" InitialDirection="SortDirection.Descending">Entry Date</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<CSPurchaseOrderModel, object>(x=> x.PartyName)">Party</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<CSPurchaseOrderModel, object>(x=> x.Status)">Status</MudTableSortLabel></MudTh>
                <MudTh>Actions</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="PONo">@context.PONo</MudTd>
                <MudTd DataLabel="EntryDate">@context.EntryDate?.ToShortDateString()</MudTd>
                <MudTd DataLabel="Party">@context.PartyName</MudTd>
                <MudTd DataLabel="Status">@context.Status</MudTd>
                <MudTd DataLabel="">
                    @if (@context.AuthLevelID == null)
                    {
                        <MudFab @onclick="@(()=> OpenDialog(context,false,false))" Color="Color.Primary" Icon="@Icons.Material.Filled.Edit" title="Edit" Size="Size.Small" IconSize="Size.Small" />
                        <MudFab @onclick="@(()=> Delete(context))" Color="Color.Error" Icon="@Icons.Material.Filled.Delete" title="Delete" Size="Size.Small" IconSize="Size.Small" />
                    }
                    @if (@context.AuthLevelID != 99)
                    {
                        <MudFab @onclick="@(()=> OpenDialog(context,true,false))" Color="Color.Warning" Icon="@Icons.Material.Filled.Verified" title="Verify" Size="Size.Small" IconSize="Size.Small" />
                    }
                    <MudFab @onclick="@(()=> OpenDialog(context,true,true))" Color="Color.Info" Icon="@Icons.Material.Filled.GridView" title="View" Size="Size.Small" IconSize="Size.Small" />
                </MudTd>
            </RowTemplate>
            <PagerContent>
                <MudTablePager PageSizeOptions="new int[] { 10, 20, 50, 100 }" />
            </PagerContent>
        </MudTable>
    </MudItem>
</MudGrid>

@code {

    private CSPurchaseOrderModel model = new CSPurchaseOrderModel();
    private List<CSPurchaseOrderModel> collection = new List<CSPurchaseOrderModel>();
    public bool IsApproved { get; set; } = false;
    private string searchPurchase = "";
    private bool _busy;
    [Parameter]
    public int? id { get; set; } = null;

    public bool HasPermissionPurchaseOrderServiceView { get; set; } = false;
    public bool HasPermissionPurchaseOrderServiceDelete { get; set; } = false;
    public int DocTypeID = 145;

    #region SignaIR Notification

    private PushNotificationModel notificationMessage = new PushNotificationModel();
    #endregion

    protected override async Task OnInitializedAsync()
    {
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionPurchaseOrderServiceView = await Irole.HasClaim(DocTypeID.ToString(), "View", ctc.Token);
        HasPermissionPurchaseOrderServiceDelete = await Irole.HasClaim(DocTypeID.ToString(), "Delete", ctc.Token);

        model = new();
        await GetAll(IsApproved);
        await Task.Delay(200);
        await signalRService.StartAsync();
        if (id != null && collection != null && collection.Any(g => g.POID == id))
        {
            await OpenDialog(collection.FirstOrDefault(s => s.POID == id), true, false);
        }
    }

    async Task ApprovedChanged(bool value)
    {
        IsApproved = value;
        await GetAll(IsApproved);
    }

    private async Task GetAll(bool val)
    {
        var authprov = await auth.GetAuthenticationStateAsync();
        var brancIDString = authprov.User.Claims.First(x => x.Type == "BranchID").Value;
        int brancID = int.Parse(brancIDString);
        if (val)
        {
            collection = Iservice.SelectPending(brancID).Where(x => x.AuthLevelID == 99).ToList();
        }
        else
        {
            collection = Iservice.SelectPending(brancID).Where(x => x.AuthLevelID != 99 && x.AuthLevelID != 100).ToList();
        }
    }

    private async Task OpenDialog(CSPurchaseOrderModel tds, bool ReadOnly, bool View)
    {
        if (HasPermissionPurchaseOrderServiceView)
        {
            if (_busy)
            {
                snackbar.Add("Please wait while form is closing!", Severity.Warning);
                return;
            }
            _busy = true;
            DialogOptions maxWidth = new DialogOptions() { MaxWidth = MaxWidth.Large, FullWidth = true };
            var authprov = await auth.GetAuthenticationStateAsync();
            var user = authprov.User;
            DialogParameters parms = new DialogParameters();
            parms.Add("model", tds.Clone());
            parms.Add("PageToRedirectLink", "/CentralizedStore/PurchaseOrder");
            parms.Add("ReadOnly", ReadOnly);
            parms.Add("IsView", View);
            var dialog = DialogService.Show<CSPurchaseOrderDialog>(tds.POID == null ? "ADD" : "EDIT", parms, maxWidth);
            var result = await dialog.Result;
            if (!result.Canceled)
            {
                CSPurchaseOrderModel UpatedModel = (CSPurchaseOrderModel)result.Data;
                try
                {
                    UpatedModel.UserInfo.UserID = user.Identity.Name;
                    var ReturnData = Iservice.Update(UpatedModel);

                    var brancIDString = authprov.User.Claims.First(x => x.Type == "BranchID").Value;
                    int brancID = int.Parse(brancIDString);

                    notificationMessage.InitiateBranch = new BranchModel() { BranchID = brancID };
                    notificationMessage.ReceivedBranch = new BranchModel() { BranchID = brancID };
                    notificationMessage.MessageTitle = IpushNotificationService.GetMessageTitle("Centralized StorePurchase Order", ReturnData.PONo, "Level 1 Verification");
                    notificationMessage.MessageBody = IpushNotificationService.GetMessageBody("Centralized Store Purchase Order", ReturnData.PONo, "Level 1 Verification", ReturnData.EntryDate);
                    notificationMessage.RedirectedTo = 0;
                    notificationMessage.ExpiredBy = 7;
                    notificationMessage.DocumentID = ReturnData.POID;
                    notificationMessage.MessageGroupID = "PendingVerification";
                    notificationMessage.PageToRedirectLink = "/CentralizedStore/PurchaseOrder";
                    notificationMessage.ClaimValue = "Verify 1";
                    notificationMessage.DocumentTypeID = DocTypeID;
                    notificationMessage.MsgDate = DateTime.Now;
                    await signalRService.Send(notificationMessage);
                    model = new();
                    snackbar.Add("Saved Successfully", Severity.Success);
                    model = new CSPurchaseOrderModel();
                }
                catch (Exception ex)
                {
                    snackbar.Add(ex.Message, Severity.Warning);
                }
            }
            await GetAll(IsApproved);
            await Task.Delay(200);
            _busy = false;
        }
        else
        {
            bool? result = await DialogService.ShowMessageBox(
                "Permission denied!",
                "You don't have any permission to View PurchaseOrder.");
        }
    }

    private async Task Delete(CSPurchaseOrderModel tds)
    {
        if (HasPermissionPurchaseOrderServiceDelete)
        {
            bool? result = await DialogService.ShowMessageBox(
                "Warning !",
                "Are you sure, you want to delete - " + model.PONo + " ?");
            if (result == true)
            {
                var authprov = await auth.GetAuthenticationStateAsync();
                var user = authprov.User;
                Iservice.Delete(tds.POID, user.Identity.Name);
                snackbar.Add("Deleted Successfully", Severity.Success);
                await GetAll(IsApproved);
            }
        }
        else
        {
            bool? result = await DialogService.ShowMessageBox(
                "Permission denied!",
                "You don't have any permission to delete PurchaseOrder.");
        }
    }

    private bool search(CSPurchaseOrderModel tds)
    {
        if (tds.PONo != null && tds.PONo.Contains(searchPurchase, StringComparison.OrdinalIgnoreCase))
        {
            return true;
        }
        else if (tds.PONo == null)
            return true;
        return false;
    }

    private string TableRowStyle(CSPurchaseOrderModel PO, int index)
    {
        if (PO.UserInfo.RecordStatus == 9)
        {
            return "background-color:#ff8080";
        }
        if (PO.AuthLevelID == 99)
        {
            return "background-color:#CCCCFF";
        }
        return string.Empty;
    }
}