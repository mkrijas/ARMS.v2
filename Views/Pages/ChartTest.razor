@page "/charttest"

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-16">
    <MudText Typo="Typo.h4" Class="mb-4">Chart Test Page</MudText>

    <style>
        .test-svg svg {
            overflow: visible !important;
            border: 1px solid red;
        }
    </style>
    <MudGrid>
        <MudItem xs="12" sm="6">
            <MudPaper Class="pa-4 test-svg">
                <MudText Typo="Typo.h6">Raw MudChart - Donut (v9 API Test)</MudText>
                @* In v9, InputData is ChartSeries maybe? Let's test passing a single series for Donut *@
                <MudChart T="double" ChartType="ChartType.Donut" Width="300px" Height="300px" ChartSeries="@DonutSeries" ChartLabels="@labels">
                    <CustomGraphics>
                        <text class="donut-inner-text" x="50%" y="35%" dominant-baseline="middle" text-anchor="middle" fill="black" font-family="Helvetica" font-size="2" font-weight="bold">Total</text>
                        <text class="donut-inner-text" x="50%" y="50%" dominant-baseline="middle" text-anchor="middle" fill="blue" font-family="Helvetica" font-size="5" font-weight="bold">100</text>
                    </CustomGraphics>
                </MudChart>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="6">
            <MudPaper Class="pa-4 wide_chart">
                <MudText Typo="Typo.h6">MudChart Bar (v9 ChartLabels Test)</MudText>
                <MudChart T="double" ChartType="ChartType.Bar" ChartSeries="@Series" ChartLabels="@XAxisLabels" Width="100%" Height="350px"></MudChart>
            </MudPaper>
        </MudItem>
    </MudGrid>
</MudContainer>

@code {
    public double[] data = { 25, 77, 28, 5 };
    public string[] labels = { "Uranium", "Plutonium", "Thorium", "Venus" };

    public List<ChartSeries<double>> DonutSeries = new List<ChartSeries<double>>()
    {
        new ChartSeries<double>() { Name = "Elements", Data = new double[] { 25, 77, 28, 5 } }
    };

    public List<ChartSeries<double>> Series = new List<ChartSeries<double>>()
    {
        new ChartSeries<double>() { Name = "Fossil", Data = new double[] { 90, 79, 72, 69, 62, 62, 55, 65, 70 } },
        new ChartSeries<double>() { Name = "Renewable", Data = new double[] { 10, 41, 35, 51, 49, 62, 69, 91, 148 } },
    };
    public string[] XAxisLabels = { "Jan", "Feb", "Mar", "Apr", "May", "Jun", "Jul", "Aug", "Sep" };
}
