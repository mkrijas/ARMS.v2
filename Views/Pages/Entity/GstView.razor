@page "/gst"
@page "/gst/{partyID:int}"
@inject IGstService Iservice
@inject IPartyService Iparty
@inject MudBlazor.ISnackbar snackbar
@attribute [Authorize]
@inject AuthenticationStateProvider auth


<MudGrid Spacing="4">
    <MudItem xs="6">
        <MudAutocomplete T="PartyModel" Label="Party" ResetValueOnEmptyText="true" @bind-Value="party"  IsOpenChanged="GetAll"
            SearchFunc="@Search" Placeholder="Select Party"  ToStringFunc="@(e=> e==null?null : $"{e.PartyName}")"></MudAutocomplete>
    </MudItem>
    <MudItem xs="12" md="12">
        <MudCard Elevation="10">
            <EditForm Model="@model" OnValidSubmit="OnValidSubmit">
                <ObjectGraphDataAnnotationsValidator />
                <ValidationSummary />
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6">Add/Edit Gsts</MudText>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent>
                    <MudGrid Spacing="4">
                        <MudItem xs="12" md="4">
                            <MudTextField @bind-Value="@model.GstNo" Label="GST No" Variant="Variant.Outlined" Margin="Margin.Normal" For="@(() => model.GstNo)"></MudTextField>
                        </MudItem>
                        <MudItem xs="12" md="4">
                            <MudTextField @bind-Value="@model.RegName" Label="Registered Name" Variant="Variant.Outlined" Margin="Margin.Normal" For="@(() => model.RegName)"></MudTextField>
                        </MudItem>
                        <MudItem xs="12" md="4">
                            <MudTextField @bind-Value="@model.TradeName" Label="Trade Name" Variant="Variant.Outlined" Margin="Margin.Normal" For="@(() => model.TradeName)"></MudTextField>
                        </MudItem>
                        <MudItem xs="12" md="4">
                            <MudTextField @bind-Value="@model.TanNo" Label="TAN No" Variant="Variant.Outlined" Margin="Margin.Normal" For="@(() => model.TanNo)"></MudTextField>
                        </MudItem>
                        <MudItem xs="12" md="4">
                            <MudTextField @bind-Value="@model.Phone" Label="Phone" Variant="Variant.Outlined" Margin="Margin.Normal" For="@(() => model.Phone)"></MudTextField>
                        </MudItem>
                        <MudItem xs="12" md="4">
                            <MudTextField @bind-Value="@model.Email" Label="Email" Variant="Variant.Outlined" Margin="Margin.Normal" For="@(() => model.Email)"></MudTextField>
                        </MudItem>
                        <MudItem xs="12">
                            <MudText Typo="Typo.subtitle2">Address Info</MudText>
                        </MudItem>
                        <MudItem xs="12" md="4">
                            <MudTextField @bind-Value="@model.Address.Building" Label="Building" Variant="Variant.Outlined" Margin="Margin.Normal" For="@(() => model.Address.Building)"></MudTextField>
                        </MudItem>
                        <MudItem xs="12" md="4">
                            <MudTextField @bind-Value="@model.Address.Street" Label="Street" Variant="Variant.Outlined" Margin="Margin.Normal" For="@(() => model.Address.Street)"></MudTextField>
                        </MudItem>
                        <MudItem xs="12" md="4">
                            <MudTextField @bind-Value="@model.Address.Place" Label="Place" Variant="Variant.Outlined" Margin="Margin.Normal" For="@(() => model.Address.Place)"></MudTextField>
                        </MudItem>
                        <MudItem xs="12" md="4">
                            <MudTextField @bind-Value="@model.Address.City" Label="City" Variant="Variant.Outlined" Margin="Margin.Normal" For="@(() => model.Address.City)"></MudTextField>
                        </MudItem>
                        <MudItem xs="12" md="4">
                            <MudTextField @bind-Value="@model.Address.PinCode" Label="PinCode" Variant="Variant.Outlined" Margin="Margin.Normal" For="@(() => model.Address.PinCode)"></MudTextField>
                        </MudItem>
                    </MudGrid>
                    <MudButton Variant="Variant.Filled" Color="Color.Success" ButtonType="ButtonType.Submit">Save Gst</MudButton>

                </MudCardContent>
            </EditForm>
        </MudCard>
    </MudItem>
    <MudItem xs="12" md="12">
        <MudTable Items="@collection" Elevation="10" Filter="new Func<GstModel, bool>(search)" @bind-model="model">
            <ToolBarContent>
                <MudText Typo="Typo.h6">Gsts</MudText>
                <MudToolBarSpacer></MudToolBarSpacer>
                <MudTextField @bind-Value="searchGst" Placeholder="Search Gsts... "
                              Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                              IconSize="Size.Medium" Class="mt-0"></MudTextField>
            </ToolBarContent>
            <HeaderContent>
                <MudTh><MudTableSortLabel SortBy="new Func<GstModel, object>(x=> x.GstNo)" InitialDirection="SortDirection.Ascending">GST</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<GstModel, object>(x=> x.TanNo)" InitialDirection="SortDirection.Ascending">TAN</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<GstModel, object>(x=> x.Phone)" InitialDirection="SortDirection.Ascending">Phone</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<GstModel, object>(x=> x.Address.Place)" InitialDirection="SortDirection.Ascending">Place</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<GstModel, object>(x=> x.Address.PinCode)" InitialDirection="SortDirection.Ascending">PinCode</MudTableSortLabel></MudTh>                
                <MudTh>Actions</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Gst">@context.GstNo</MudTd>
                <MudTd DataLabel="Tan">@context.TanNo</MudTd>
                <MudTd DataLabel="Phone">@context.Phone</MudTd>
                <MudTd DataLabel="Place">@context.Address.Place</MudTd>
                <MudTd DataLabel="Pin">@context.Address.PinCode</MudTd>
                <MudTd DataLabel="">
                    <MudFab @onclick="@(()=> Edit(context.GstID))" Color="Color.Primary" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" IconSize="Size.Small" />
                    <MudFab @onclick="@(()=> Delete(context.GstID))" Color="Color.Primary" Icon="@Icons.Material.Filled.Delete" Size="Size.Small" IconSize="Size.Small" />
                </MudTd>
            </RowTemplate>
            <PagerContent>
                <MudTablePager PageSizeOptions="new int[] { 5, 10, 20, 50, 100 }" />
            </PagerContent>
        </MudTable>
    </MudItem>


</MudGrid>
@code {



    private GstModel model = new GstModel();
    private List<GstModel> collection = new List<GstModel>();
    private List<PartyModel> parties = new List<PartyModel>();
    [Parameter]
    public int partyID { get; set; }
    private PartyModel party = new PartyModel();

    private string searchGst = "";

    protected override async Task OnInitializedAsync()
    {
        await foreach (var party in Iparty.Select(0))
        {
            parties.Add(party);
        }
        if(partyID != 0)
        {
            party = parties.First(x => x.PartyID == partyID);
            await GetAll(false);
        }
    }


    private async Task<IEnumerable<PartyModel>> Search(string searchString)
    {
        return await Task.FromResult(parties.Where(x => x.PartyName.Contains(searchString == null ? string.Empty : searchString, StringComparison.InvariantCultureIgnoreCase)));
    }


    private async Task GetAll(bool p)
    {
        collection = new List<GstModel>();

        if (party?.PartyID != null && party?.PartyID != 0)
            await foreach (var item in Iservice.SelectByParty(party.PartyID))
            {
                collection.Add(item);
            }
    }



    private async Task OnValidSubmit(EditContext context)
    {
        if (!parties.Select(x => x.PartyName).Contains(party.PartyName))
        {
            snackbar.Add("Invalid Party", Severity.Error);
            return;
        }

        model.Party = party;
        model.PartyID = party.PartyID;
        model.Address.AddresseeName = model.TradeName;

        var authprov = await auth.GetAuthenticationStateAsync();
        model.UserInfo.UserID = authprov.User.Identity.Name;
        try
        {
            model = await Iservice.Update(model);
            snackbar.Add("Saved Successfully", Severity.Success);
            if (collection.Exists(x => x.GstID == model.GstID))
            {
                collection[collection.FindIndex(x => x.GstID == model.GstID)] = model;
            }
            else
            {
                collection.Add(model);
            }
            model = new GstModel();
        }
        catch (Exception ex)
        {
            snackbar.Add(ex.Message, Severity.Warning);
        }
    }
    private void Edit(int? id)
    {
        model = collection.FirstOrDefault(x => x.GstID == id);
    }
    private async void Delete(int? id)
    {
        await Iservice.Delete(id, "Rijas");
        snackbar.Add("Deleted Successfully", Severity.Success);
        //GetAll(party.PartyName);
    }

    private bool search(GstModel model)
    {
        if (model.GstNo != null && model.GstNo.Contains(searchGst, StringComparison.OrdinalIgnoreCase))
        {
            return true;
        }
        return false;
    }
}



