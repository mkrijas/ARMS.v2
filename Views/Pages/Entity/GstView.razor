@page "/gst"
@page "/gst/{partyID:int}"
@inject IPartyBranchService Iservice
@inject IPartyService Iparty
@inject IContactService Icontact
@inject MudBlazor.ISnackbar snackbar
@attribute [Authorize]
@inject AuthenticationStateProvider auth
@inject IDialogService DialogService


<MudGrid Spacing="4">
    <MudItem xs="6">
        <MudAutocomplete T="PartyModel" Label="Party" ResetValueOnEmptyText="true" Value="party" ValueChanged="PartyChanged"
                         SearchFunc="@Search" Placeholder="Select Party" ToStringFunc="@(e=> e==null?null : $"{e.PartyName}")"></MudAutocomplete>
    </MudItem>

    <MudItem xs="12" md="12">
        <MudTable Items="@collection" Elevation="10" Filter="new Func<PartyBranchModel, bool>(search)" @bind-model="model">
            <ToolBarContent>
                <MudText Typo="Typo.h6">Locations</MudText>
                <MudIconButton Icon="@Icons.Material.Filled.Add" Title="Add" @onclick="@(()=>OpenDialog(new PartyBranchModel()))" Color="Color.Dark" Size="Size.Small"></MudIconButton>
                <MudSpacer></MudSpacer>
                <MudTextField @bind-Value="searchGst" Placeholder="Search Gsts... "
                              Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                              IconSize="Size.Medium" Class="mt-0"></MudTextField>
            </ToolBarContent>
            <HeaderContent>
                <MudTh><MudTableSortLabel SortBy="new Func<PartyBranchModel, object>(x=> x.GstNo)" InitialDirection="SortDirection.Ascending">GST</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<PartyBranchModel, object>(x=> x.TanNo)" InitialDirection="SortDirection.Ascending">TAN</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<PartyBranchModel, object>(x=> x.Address.Place)" InitialDirection="SortDirection.Ascending">Place</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<PartyBranchModel, object>(x=> x.Address.PinCode)" InitialDirection="SortDirection.Ascending">PinCode</MudTableSortLabel></MudTh>
                <MudTh>Actions</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Gst">@context.GstNo</MudTd>
                <MudTd DataLabel="Tan">@context.TanNo</MudTd>
                <MudTd DataLabel="Place">@context.Address.Place</MudTd>
                <MudTd DataLabel="Pin">@context.Address.PinCode</MudTd>
                <MudTd DataLabel="">
                    <MudFab @onclick="@(()=> OpenDialog(context))" Color="Color.Primary" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" IconSize="Size.Small" />
                    <MudFab @onclick="@(()=> Delete(context.GstID))" Color="Color.Primary" Icon="@Icons.Material.Filled.Delete" Size="Size.Small" IconSize="Size.Small" />
                </MudTd>
            </RowTemplate>
            <PagerContent>
                <MudTablePager PageSizeOptions="new int[] { 5, 10, 20, 50, 100 }" />
            </PagerContent>
        </MudTable>
    </MudItem>


</MudGrid>
@code {



    private PartyBranchModel model = new PartyBranchModel();
    private List<PartyBranchModel> collection = new List<PartyBranchModel>();
    private List<PartyModel> parties = new List<PartyModel>();
    [Parameter]
    public int partyID { get; set; }
    private PartyModel party = new PartyModel();

    private string searchGst = "";

    protected override async Task OnInitializedAsync()
    {
        await foreach (var party in Iparty.Select(0))
        {
            parties.Add(party);
        }
        if (partyID != 0)
        {
            party = parties.First(x => x.PartyID == partyID);
            GetAll(false);
        }
    }

    private void PartyChanged(PartyModel value)
    {
        party = value;
        model.Party = value;
        model.PartyID = value.PartyID;
        GetAll(false);
    }

    private void AddContact()
    {
        model.Contacts.Add(new ContactModel()
            {
                RefTable = "GST"
            });
    }

    private async Task<IEnumerable<PartyModel>> Search(string searchString)
    {
        return await Task.FromResult(parties.Where(x => x.PartyName.Contains(searchString == null ? string.Empty : searchString, StringComparison.InvariantCultureIgnoreCase)));
    }


    private void GetAll(bool p)
    {
        if (party?.PartyID != null && party?.PartyID != 0)
            collection = Iservice.SelectByParty(party.PartyID).ToList();
    }

    private async Task OnValidSubmit(EditContext context)
    {
        if (!parties.Select(x => x.PartyName).Contains(party.PartyName))
        {
            snackbar.Add("Invalid Party", Severity.Error);
            return;
        }
        model.Address.AddresseeName = model.TradeName;

        var authprov = await auth.GetAuthenticationStateAsync();
        model.UserInfo.UserID = authprov.User.Identity.Name;
        try
        {
            var contacts = model.Contacts;
            model = Iservice.Update(model);
            snackbar.Add("Saved Successfully", Severity.Success);
            if (collection.Exists(x => x.GstID == model.GstID))
            {
                collection[collection.FindIndex(x => x.GstID == model.GstID)] = model;
            }
            else
            {
                collection.Add(model);
            }
            foreach (var item in contacts)
            {
                item.RefKey = model.GstID;
                item.UserInfo = model.UserInfo;
                Icontact.Update(item);
            }

            model = new PartyBranchModel();
        }
        catch (Exception ex)
        {
            snackbar.Add(ex.Message, Severity.Warning);
        }
    }

    private void Delete(int? id)
    {
        Iservice.Delete(id, "Rijas");
        snackbar.Add("Deleted Successfully", Severity.Success);
        GetAll(false);
    }

    private bool search(PartyBranchModel model)
    {
        if (model.GstNo != null && model.GstNo.Contains(searchGst, StringComparison.OrdinalIgnoreCase))
        {
            return true;
        }
        return false;
    }

    private async Task OpenDialog(PartyBranchModel model)
    {
        if (model.GstID == null)
        {
            model.PartyID = party.PartyID;
            model.Party = party;
        }
        else
        {
            model.Contacts = Icontact.Select(model.GstID, "GST").ToList();
        }
        DialogOptions options = new DialogOptions() { FullWidth = true, MaxWidth = MaxWidth.ExtraLarge };
        DialogParameters parms = new DialogParameters();
        parms.Add("model", model);
        var dialog = DialogService.Show<GstDiloge>(model.GstID == null ? "Add Address" : "Edit Address", parms, options);
        var result = await dialog.Result;

        if (!result.Cancelled)
        {
            PartyBranchModel UpatedModel = (PartyBranchModel)result.Data;
            var authprov = await auth.GetAuthenticationStateAsync();
            UpatedModel.UserInfo.UserID = authprov.User.Identity.Name;


            try
            {
                var contacts = UpatedModel.Contacts;
                UpatedModel = Iservice.Update(UpatedModel);
                foreach (var item in contacts)
                {
                    item.RefKey = UpatedModel.GstID;
                    item.UserInfo = UpatedModel.UserInfo;
                    Icontact.Update(item);
                }
                snackbar.Add("Saved Successfully", Severity.Success);
                GetAll(false);
            }
            catch (Exception ex)
            {
                snackbar.Add(ex.Message, Severity.Warning);
            }

        }

    }
}



