@page "/Breakdown"
@attribute [Authorize]
@inject IBreakdownService Iservice
@inject ITripService Itrip
@inject MudBlazor.ISnackbar snackbar
@inject AuthenticationStateProvider auth
@using System.Threading;
@inject IRoleService<RoleModel> Irole
@inject IDialogService DialogService
@inject IEventService Ievent

<MudDialog Class="admin-dialog-glass">
    <TitleContent>
        <div class="header-section mb-2 pt-4 px-4">
            <div class="d-flex align-center justify-space-between">
                <div class="d-flex align-center">
                    <div class="icon-badge primary-badge mr-4">
                        <div class="admin-header-icon-badge mb-3">
                            <MudIcon Icon="@Icons.Material.Filled.Build" Color="Color.Secondary" Style="font-size: 3rem;" />
                        </div>
                    </div>
                    <div>
                        <MudText Typo="Typo.h5" Class="admin-title"><b>Work Order Initiation</b></MudText>
                        <MudText Typo="Typo.body2" Class="admin-subtitle">Document and authorize technical interventions for reported vehicle incidents.</MudText>
                    </div>
                </div>
            </div>
            <div class="title-accent mt-4"></div>
        </div>
    </TitleContent>
    <DialogContent>
        <MudContainer Class="admin-dialog-container">
            <div class="dialog-content-wrapper pa-4">
                @if (model == null)
                {
                    <div class="d-flex justify-center pa-12">
                        <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
                    </div>
                }
                else
                {
                    <EditForm id="formBreakdown" Model="@model" OnValidSubmit="OnValidSubmit">
                        <ObjectGraphDataAnnotationsValidator />
                        
                        <div class="admin-glass-card pa-6 mb-6">
                            <div class="d-flex align-center mb-6">
                                <div class="icon-badge primary-badge-soft mr-3">
                                    <MudIcon Icon="@Icons.Material.Filled.Assignment" Size="Size.Small" />
                                </div>
                                <span class="admin-section-label mb-0">Incident Classification</span>
                            </div>

                            <MudGrid Spacing="3">
                                <MudItem xs="12" md="6">
                                    <MudSelect For="@(() => model.BreakdownType)" Label="Operational Category" @bind-Value="model.BreakdownType" Variant="Variant.Outlined" Margin="Margin.Dense" Class="modern-input" AdornmentIcon="@Icons.Material.Filled.Category" AnchorOrigin="MudBlazor.Origin.BottomLeft">
                                        @foreach (var ditem in BreakdownTypes)
                                        {
                                            <MudSelectItem Value="@ditem">@ditem</MudSelectItem>
                                        }
                                    </MudSelect>
                                </MudItem>
                                <MudItem xs="12" md="6">
                                    <MudTextField Label="Incident Timestamp" Format="s" Variant="Variant.Outlined" @bind-Value="@model.BreakdownTime" InputType="InputType.DateTimeLocal" Disabled Class="modern-input" AdornmentIcon="@Icons.Material.Filled.AccessTime" />
                                </MudItem>
                            </MudGrid>
                        </div>

                        <div class="admin-glass-card pa-6 mb-6">
                            <div class="d-flex align-center mb-6">
                                <div class="icon-badge secondary-badge-soft mr-3">
                                    <MudIcon Icon="@Icons.Material.Filled.ContactPhone" Size="Size.Small" />
                                </div>
                                <span class="admin-section-label mb-0">Reporting Channel</span>
                            </div>
                            <MudTextField @bind-Value="model.ContactNumber" MaxLength="10" InputType="InputType.Telephone" Label="Reporter Contact Coordinate" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.ContactNumber)" Class="modern-input" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Phone" Placeholder="Enter 10-digit mobile..." />
                        </div>

                        <div class="admin-glass-card pa-6">
                            <div class="d-flex align-center mb-6">
                                <div class="icon-badge info-badge-soft mr-3">
                                    <MudIcon Icon="@Icons.Material.Filled.Description" Size="Size.Small" />
                                </div>
                                <span class="admin-section-label mb-0">Technical Narrative</span>
                            </div>
                            <MudTextField Lines="4" @bind-Value="model.Detail" Label="Incident Analysis & Details" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.Detail)" Class="modern-input" Placeholder="Describe the technical failure or requirement in detail..." />
                        </div>
                    </EditForm>
                }
            </div>
        </MudContainer>
    </DialogContent>
    <DialogActions>
        <div class="d-flex w-100 flex-wrap pa-4 gap-3 align-center">
            <MudSpacer />
            <MudButton @onclick="Cancel" Variant="Variant.Outlined" Color="Color.Default" Style="border-radius: 12px; font-weight: 700; text-transform: none; border-color: rgba(0,0,0,0.15);">Discard</MudButton>
            <MudButton Disabled="@_busy" form="formBreakdown" Variant="Variant.Filled" ButtonType="ButtonType.Submit" Color="Color.Success" Style="background: var(--mud-palette-success); color: white; font-weight: 800; border-radius: 12px; text-transform: none; white-space: nowrap; padding: 8px 32px;" StartIcon="@Icons.Material.Filled.CheckCircle">Initiate Work Order</MudButton>
        </div>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; }
    [Parameter] public TruckModel Truck { get; set; }
    [Parameter] public TripModel CurrentTrip { get; set; }
    [Parameter] public int PendingGcs { get; set; }
    [Parameter] public bool IsGcRemoved { get; set; }
    [Parameter] public int CurentEventTypeId { get; set; }
    [Parameter] public BreakdownModel model { get; set; } = new();  
    private EventModel PreEvent { get; set; }


    private List<string> BreakdownTypes = new() 
    { "Accident Claim", "Accident Non Claim", "Work Order", "General Service", "FC Work", "Periodic Service", "Special Work" , "Tyre Work", "Engine Work", "Body Work", "Gear Box Work", "Differential Work", "Clutch Work", "Battery"};

    public bool HasPermissionBreakdownServiceEdit { get; set; } = false;
    public int BreakdownDocTypeID = 84;

    private bool _busy;

    private void Cancel()
    {
        MudDialog.Cancel();
    }

    protected override async Task OnInitializedAsync()
    {
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionBreakdownServiceEdit = await Irole.HasClaim(BreakdownDocTypeID.ToString(), "Edit", ctc.Token);

        var e = await auth.GetAuthenticationStateAsync();
        string BranchIDString = e.User.Claims.First(x => x.Type == "BranchID").Value;

        var TruckID = Truck?.TruckID ?? model?.TruckID;

        if(TruckID != null)
        {
         PreEvent = Ievent.GetCurrentEvent(TruckID);       
        }
        model.BranchID = int.Parse(BranchIDString);
        model.TruckID = Truck?.TruckID ?? model?.TruckID;
    }

    private async Task OnValidSubmit(EditContext context)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is being submitted!", Severity.Warning);
            return;
        }
        if (PreEvent != null && model.BreakdownTime <= PreEvent.EventTime)
        {
            snackbar.Add("Event Time cannot be before preivious event", Severity.Error);
            return;
        }
        _busy = true;
        if (HasPermissionBreakdownServiceEdit)
        {
            var authprov = await auth.GetAuthenticationStateAsync();
            model.UserInfo.UserID = authprov.User.Identity.Name;
            try
            {
                if (IsGcRemoved)
                {
                    if (CurrentTrip != null && !Itrip.IsClosed(CurrentTrip.TripID))
                    {
                        var authState = auth.GetAuthenticationStateAsync().Result;
                        if (PendingGcs > 0)
                        {
                            Itrip.Cancel(CurrentTrip.TripID, authState.User.Identity.Name);
                        }

                        Itrip.CloseTrip(CurrentTrip.TripID, int.Parse(authState.User.Claims.First(x => x.Type == "BranchID").Value), model.BreakdownTime, authState.User.Identity.Name);
                    }
                }

                model = Iservice.Update(model);
                snackbar.Add("Saved Successfully", Severity.Success);
                MudDialog.Close(DialogResult.Ok(model));                
            }
            catch (Exception ex)
            {
                snackbar.Add(ex.Message, Severity.Warning);
            }
        }
        else
        {
            bool? ResultModel = await DialogService.ShowMessageBoxAsync(
                "Permission denied!",
                "You don't have any permission to Edit Work Order.");
        }
        await Task.Delay(200);
        _busy = false;
    }
}
