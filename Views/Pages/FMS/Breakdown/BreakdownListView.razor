@page "/Breakdowns"
@attribute [Authorize]
@inject AuthenticationStateProvider auth
@inject IBreakdownService IBreakdown

<MudPaper Style="padding-bottom: 1px;">
    <MudToolBar>
        <MudText Typo="Typo.h6">Reported Breakdowns/Accidents</MudText>
    </MudToolBar>
    <MudDivider />
    @foreach (BreakdownModel item in BreakdownList)
    {
        <div style="margin: 24px;">
            <BreakdownComponent MainModel="@item" HideControls=false ReadOnly=false OnBreakdownRejected="@OnBreakdownRejected"></BreakdownComponent>
        </div>
    }
</MudPaper>

@code {

    private List<BreakdownModel> BreakdownList = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadBreakdowns();
    }

    private async Task LoadBreakdowns()
    {
        var e = await auth.GetAuthenticationStateAsync();
        int BranchID = int.Parse(e.User.Claims.First(x => x.Type == "BranchID").Value);
        BreakdownList = IBreakdown.SelectPending(BranchID).ToList();
    }

    private async Task OnBreakdownRejected()
    {
        // Option 1: Refresh the entire list
        await LoadBreakdowns();

        // Option 2: (Alternative) Remove the rejected item without refreshing all data
        // BreakdownList.Remove(BreakdownList.FirstOrDefault(b => b.BreakdownID == rejectedBreakdownId));
        StateHasChanged();
    }
}
