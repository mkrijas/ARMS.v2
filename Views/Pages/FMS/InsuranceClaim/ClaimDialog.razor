@attribute [Authorize]
@using System.Threading;
@inject AuthenticationStateProvider auth
@inject IRoleService<RoleModel> Irole
@inject IInsuranceClaimService IInsuranceClaim
@inject IBreakdownService IBreakdown
@inject IAssetDocumentService IAssetDocument
@inject IDialogService DialogService
@inject MudBlazor.ISnackbar snackbar

<DialogForm Title="@(Model.InsuranceClaimID == null ? "Initiate Insurance Claim" : "Manage Claim Dossier")"
            Subtitle="@(Model.InsuranceClaimID == null ? "Register a new incident and establish legal documentation." : $"Asset Account: {Model.TruckRegNo} | Lifecycle Status: {(Model.IsOpen ? "ACTIVE" : "CLOSED")}")"
            OnSubmit="OnValidSubmit"
            IsBusy="_busy"
            SubmitButtonText="Commit Record"
            CancelButtonText="Dismiss"
            @ref="dialogForm">

    <FormContent>
        <div class="admin-glass-card pa-6 mb-6">
            <div class="d-flex align-center mb-4">
                <div class="icon-badge primary-badge-soft mr-3">
                    <MudIcon Icon="@Icons.Material.Filled.Assignment" Size="Size.Small" />
                </div>
                <MudText Typo="Typo.subtitle1" Class="fw-700">Incident Classification</MudText>
            </div>
            
            <MudGrid Spacing="3">
                <MudItem xs="12" md="6">
                    <MudTextField ReadOnly @bind-Value="@Model.TruckRegNo" Label="Vehicle Registration" Variant="Variant.Outlined" Margin="Margin.Dense" Class="modern-input" 
                                 Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.LocalShipping" />
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudDatePicker ReadOnly="@ReadOnly" Date="@Model?.DateOfAccident" DateChanged="DateChanged" Label="Accident Chronology" Variant="Variant.Outlined" Margin="Margin.Dense" Class="modern-input"
                                 Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Event" />
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudTextField ReadOnly @bind-Value="@Model.PolicyNo" Label="Policy Identifier" Variant="Variant.Outlined" Margin="Margin.Dense" Class="modern-input"
                                 Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Policy" />
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudTextField ReadOnly="@ReadOnly" @bind-Value="@Model.ClaimNo" Label="Claim Reference" Variant="Variant.Outlined" Margin="Margin.Dense" Class="modern-input"
                                 Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Numbers" />
                </MudItem>
            </MudGrid>
        </div>

        <div class="admin-glass-card pa-6 mb-6">
            <div class="d-flex align-center mb-4">
                <div class="icon-badge primary-badge-soft mr-3">
                    <MudIcon Icon="@Icons.Material.Filled.Payments" Size="Size.Small" />
                </div>
                <MudText Typo="Typo.subtitle1" Class="fw-700">Financial Valuation</MudText>
            </div>

            <MudGrid Spacing="3">
                <MudItem xs="12" md="4">
                    <MudNumericField ReadOnly="@(Jobcard && Model.IsOpen)" HideSpinButtons @bind-Value="@Model.EstimateAmount" Label="Estimated Cost" Variant="Variant.Outlined" Margin="Margin.Dense" Class="modern-input"
                                     Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Calculate" Format="N2" />
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudNumericField ReadOnly="@(Jobcard && Model.IsOpen)" HideSpinButtons @bind-Value="@Model.InvoiceAmount" Label="Invoiced Cost" Variant="Variant.Outlined" Margin="Margin.Dense" Class="modern-input"
                                     Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Description" Format="N2" />
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudNumericField ReadOnly="@(Jobcard)" HideSpinButtons @bind-Value="@Model.ApprovedAmount" Label="Authorized Settlement" Variant="Variant.Outlined" Margin="Margin.Dense" Class="modern-input"
                                     Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Verified" Format="N2" />
                </MudItem>
                <MudItem xs="12">
                    <MudTextField ReadOnly="@ReadOnly" @bind-Value="@Model.Notes" Label="Administrative Narrative" Variant="Variant.Outlined" Margin="Margin.Dense" Lines="4" Class="modern-input" />
                </MudItem>
            </MudGrid>
        </div>

        <div class="admin-glass-card pa-6 mb-6">
            <div class="d-flex align-center justify-space-between mb-4">
                <div class="d-flex align-center">
                    <div class="icon-badge primary-badge-soft mr-3">
                        <MudIcon Icon="@Icons.Material.Filled.PhotoLibrary" Size="Size.Small" />
                    </div>
                    <MudText Typo="Typo.subtitle1" Class="fw-700">Forensic Documentation</MudText>
                </div>
                @if (Model.InsuranceClaimID == null || (!Jobcard && Model.IsOpen))
                {
                    <MyFileUpload @ref="Mfu" AllowMultiple="true" Resize="true" DeleteExistingFile="false" FileName="@Guid.NewGuid().ToString()" FolderName="@("InsuranceClaim/Breakdown-"+Model.BreakdownID.ToString())" Label="Upload Assets" FilePathChanged="FileUploaded"></MyFileUpload>
                }
            </div>

            <div class="admin-asset-grid mt-4">
                @foreach (var imagePath in Model?.Images)
                {
                    @if (!string.IsNullOrEmpty(imagePath))
                    {
                        <div class="admin-asset-card p-2">
                            <div class="position-relative">
                                <img src="@imagePath" alt="Incident Asset" class="rounded-lg w-100" style="height: 150px; object-fit: cover;" />
                                @if (Model.IsOpen && !Jobcard || (Jobcard && Model.InsuranceClaimID == null))
                                {
                                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small" Class="position-absolute top-0 right-0 m-2 bg-white-glass shadow-sm" OnClick="() => DeleteImage(imagePath)" />
                                }
                            </div>
                        </div>
                    }
                }
                @if (!Model.Images.Any())
                {
                    <div class="text-center pa-12 border-dashed rounded-lg opacity-40 w-100 grid-span-all">
                        <MudIcon Icon="@Icons.Material.Filled.NoPhotography" Size="Size.Large" Class="mb-2" />
                        <MudText Typo="Typo.body2">No forensic assets recorded.</MudText>
                    </div>
                }
            </div>
        </div>

        @if (Model.InsuranceClaimID != null)
        {
            <div class="admin-glass-card pa-6 overflow-hidden">
                <div class="d-flex align-center mb-4">
                    <div class="icon-badge primary-badge-soft mr-3">
                        <MudIcon Icon="@Icons.Material.Filled.History" Size="Size.Small" />
                    </div>
                    <MudText Typo="Typo.subtitle1" Class="fw-700">Protocol Progression Log</MudText>
                </div>

                <div class="modern-admin-table-container">
                    <table class="modern-admin-table w-100">
                        <thead>
                            <tr>
                                <th class="admin-header-text">EVENT STRATUM</th>
                                <th class="admin-header-text" style="text-align: right;">TIMESTAMP</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (ClaimEvents?.Any() == true)
                            {
                                @foreach (var item in ClaimEvents)
                                {
                                    <tr>
                                        <td>
                                            <div class="d-flex align-center">
                                                <div class="bullet-indicator bg-primary mr-3"></div>
                                                <span class="fw-600">@item.Title</span>
                                            </div>
                                        </td>
                                        <td style="text-align: right;"><span class="small opacity-70">@item.EventDate?.ToString("dd MMM yyyy")</span></td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="2" class="text-center pa-4 opacity-50">No events recorded in progression log.</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                @if (!Jobcard && Model.IsOpen && EventMasterSource?.Any() == true)
                {
                    <div class="mt-6 pa-4 border-t gray-bg rounded-lg">
                        <MudGrid Spacing="3" Class="align-end">
                            <MudItem xs="12" md="5">
                                <MudSelect T="int?" Label="Operational Milestone" Value="UpdateStatusModel.IcemID" ValueChanged="EventSelected" Variant="Variant.Outlined" Margin="Margin.Dense" Class="modern-input" Required>
                                    @foreach (var item in EventMasterSource)
                                    {
                                        <MudSelectItem T="int?" Value="item.IcemID">@item.Title</MudSelectItem>
                                    }
                                </MudSelect>
                            </MudItem>
                            <MudItem xs="12" md="4">
                                <MudDatePicker Label="Milestone Date" @bind-Date="UpdateStatusModel.EventDate" Variant="Variant.Outlined" Margin="Margin.Dense" Class="modern-input" Required />
                            </MudItem>
                            <MudItem xs="12" md="3">
                                <MudButton OnClick="UpdateStatus" Variant="Variant.Filled" Color="Color.Primary" FullWidth="true" Class="rounded-pill shadow-none py-2">Update Log</MudButton>
                            </MudItem>
                        </MudGrid>
                    </div>
                }
            </div>
        }

        @if (!Jobcard && Model.IsOpen && (EventMasterSource?.Any(x => x.IsMandatory) != true))
        {
            <div class="d-flex justify-end mt-4">
                <MudButton Variant="Variant.Outlined" Color="Color.Error" OnClick="CloseClaim" StartIcon="@Icons.Material.Filled.Lock" Class="rounded-pill px-6">Finalize & Close Dossier</MudButton>
            </div>
        }
    </FormContent>
</DialogForm>

@code {

    DialogForm dialogForm;
    [CascadingParameter]
    IMudDialogInstance MudDialog { get; set; }
    [Parameter]
    public InsuranceClaimModel Model { get; set; } = new();
    [Parameter]
    public bool ReadOnly { get; set; }
    [Parameter]
    public bool Jobcard { get; set; }
    public DateTime? TimeOfDamage { get; set; } = DateTime.Today;
    private AssetDocumentModel Insurance = new();
    private List<InsuranceClaimEventMasterModel> EventMasterSource;
    private List<InsuranceClaimEventStatusModel> ClaimEvents;
    private InsuranceClaimEventStatusModel UpdateStatusModel = new();
    MyFileUpload Mfu;
    private bool _busy;

    public bool HasPermissionInsuranceClaimServiceEdit { get; set; } = false;
    public bool HasPermissionInsuranceClaimServiceUpdateList { get; set; } = false;
    public int InsuranceClaimDocTypeID = 83;

    // Lifecycle method that runs when parameters are set or changed
    protected override void OnParametersSet()
    {
        try
        {
            if (Model.InsuranceClaimID != null)
            {
                // Retrieve the insurance document associated with the asset
                Insurance = IAssetDocument.SelectByAsset(Model.Asset.AssetID, false).FirstOrDefault(x => x.DocumentType.DocumentTypeName.ToUpper().Contains("INSURANCE") && IAssetDocument.IsValid(x, Model.DateOfAccident));
                Model.PolicyNo = Insurance.Refference;
                Model.InsuranceID = Insurance.DocumentID;
                ClaimEvents = IInsuranceClaim.GetEventStatusList(Model.InsuranceClaimID).ToList(); // Get claim event statuses
                SetEventMaster();
            }
            else
            {
                // if (Model.BreakdownID != null)
                // {
                //     TimeOfDamage = IBreakdown.SelectByID(Model.BreakdownID).BreakdownTime;
                // }
                // Insurance = IAssetDocument.SelectByAsset(Model.Asset.AssetID).FirstOrDefault(x => x.DocumentType.DocumentTypeName.ToUpper().Contains("INSURANCE") && IAssetDocument.IsValid(x, Model?.DateOfAccident));
                // Model.InsuranceID = Insurance.DocumentID;
            }
            PermissionSet();
        }
        catch (Exception ex)
        {
            snackbar.Add(ex.Message, Severity.Warning);
        }
    }

    // Method to set permissions for the current user
    private async Task PermissionSet()
    {
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionInsuranceClaimServiceEdit = await Irole.HasClaim(InsuranceClaimDocTypeID.ToString(), "Edit", ctc.Token);
        HasPermissionInsuranceClaimServiceUpdateList = await Irole.HasClaim(InsuranceClaimDocTypeID.ToString(), "UpdateList", ctc.Token);
    }

    // Method to delete an image associated with the insurance claim
    private async Task DeleteImage(string imagePath)
    {
        try
        {
            var authState = await auth.GetAuthenticationStateAsync();

            InsuranceClaimModel model = new();
            model.InsuranceClaimID = Model.InsuranceClaimID;
            model.RemoveImage = imagePath.Normalize();
            model.UserInfo.UserID = authState.User.Identity.Name;

            // Attempt to remove the photo
            int a = IInsuranceClaim.RemovePhoto(model);
            if (a == 1)
            {
                if (Mfu.DeleteFile(imagePath))
                {
                    Model.Images.Remove(imagePath); // Remove the image path from the model
                }
                snackbar.Add("Photo removed Successfully", Severity.Success);
                return;
            }
            else
            {
                snackbar.Add("Photo not removed !", Severity.Error);
                return;
            }
        }
        catch (Exception ex)
        {
            snackbar.Add(ex.Message, Severity.Warning);
        }
    }

    // Method to set the event master list based on the current claim events
    private void SetEventMaster()
    {
        int? maxval = null;
        if (ClaimEvents.Any() == true)
        {
            maxval = ClaimEvents?.Max(x => x.IcesID).Value;
        }
        EventMasterSource = IInsuranceClaim.GetEventList(maxval).ToList(); // Fetch the event master list
    }

    // Method to handle the selection of an event
    private void EventSelected(int? IcemID)
    {
        var SelectedEvent = EventMasterSource.First(x => x.IcemID == IcemID);
        if (EventMasterSource.Any(y => y.Order < SelectedEvent.Order && y.IsMandatory))
        {
            snackbar.Add("Other Mandatory Events are Missing!", Severity.Error);
            return;
        }
        UpdateStatusModel.IcemID = IcemID;
    }

    // Method to handle changes in the date of the accident
    private async Task DateChanged(DateTime? a)
    {
        if (a != null)
        {
            //TimeOfDamage = IBreakdown.SelectByID(Model.BreakdownID).BreakdownTime;
            Model.DateOfAccident = a;
            // Insurance = IAssetDocument.SelectByAsset(Model.Asset.AssetID, false).FirstOrDefault(x => x.DocumentType.DocumentTypeName.ToUpper().Contains("INSURANCE") && IAssetDocument.IsValid(x, Model.DateOfAccident));

            // Retrieve the insurance document based on the accident date
            Insurance = IAssetDocument.SelectByAccidentDate(Model.Asset.AssetID, false).FirstOrDefault(x => x.DocumentType.DocumentTypeName.ToUpper().Contains("INSURANCE") && IAssetDocument.IsValid(x, Model.DateOfAccident));
            if (Insurance == null)
            {
                snackbar.Add("Insurance is Not Found !", Severity.Error);
                return;
            }
            Model.PolicyNo = Insurance.Refference;
            Model.InsuranceID = Insurance.DocumentID;
        }
    }

    // Method to update the status of the insurance claim
    private async Task UpdateStatus()
    {
        if (HasPermissionInsuranceClaimServiceUpdateList)
        {
            try
            {
                var authState = await auth.GetAuthenticationStateAsync();
                UpdateStatusModel.UserInfo.UserID = authState.User.Identity.Name;
                UpdateStatusModel.InsuranceClaimID = Model.InsuranceClaimID;
                UpdateStatusModel = IInsuranceClaim.UpdateClaimEvent(UpdateStatusModel); // Update the claim event status
                ClaimEvents.Add(UpdateStatusModel);
                UpdateStatusModel = new()
                    {
                        InsuranceClaimID = Model.InsuranceClaimID,
                    };
                SetEventMaster();
            }
            catch (Exception ex)
            {
                snackbar.Add(ex.Message, Severity.Warning);
            }
        }
        else
        {
            bool? result = await DialogService.ShowMessageBoxAsync(
                "Permission denied!",
                "You don't have any permission to UpdateList InsuranceClaim.");
        }
    }

    // Method to handle file uploads
    private void FileUploaded(string filePath)
    {
        Model.Images.Add(filePath);
    }

    // Method to cancel the dialog and potentially delete uploaded images
    private void Cancel()
    {
        bool success = true;
        // foreach (var item in Model.Images.ToList())
        // {
        //     if (Mfu.DeleteFile(item))
        //     {
        //         Model.Images.Remove(item);
        //     }
        //     else
        //     {
        //         success = false;
        //     }
        // }
        if (success)
        {
            MudDialog.Cancel();
        }
    }

    // Method to close the insurance claim
    private async Task CloseClaim()
    {
        if (HasPermissionInsuranceClaimServiceEdit)
        {
            try
            {
                if (Model.EstimateAmount == null)
                {
                    snackbar.Add("EstimateAmount is Missing!", Severity.Error);
                    return;
                }
                if (Model.InvoiceAmount == null)
                {
                    snackbar.Add("InvoiceAmount is Missing!", Severity.Error);
                    return;
                }
                if (Model.ApprovedAmount == null)
                {
                    snackbar.Add("ApprovedAmount is Missing!", Severity.Error);
                    return;
                }
                var authState = await auth.GetAuthenticationStateAsync();
                Model.IsOpen = false;
                Model.UserInfo.UserID = authState.User.Identity.Name;
                IInsuranceClaim.Update(Model); // Update the insurance claim in the service
                snackbar.Add("Claim Closed Successfully!", Severity.Success);
            }
            catch (Exception ex)
            {
                snackbar.Add(ex.Message, Severity.Warning);
            }
        }
        else
        {
            bool? result = await DialogService.ShowMessageBoxAsync(
                "Permission denied!",
                "You don't have any permission to Edit InsuranceClaim.");
        }
    }

    // Method to handle form submission when the form is valid
    private async Task OnValidSubmit(EditContext context)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is being submitted!", Severity.Warning);
            return;
        }
        _busy = true;
        if (HasPermissionInsuranceClaimServiceEdit)
        {
            try
            {
                var authState = await auth.GetAuthenticationStateAsync();
                Model.UserInfo.UserID = authState.User.Identity.Name;
                //model.Images.AddRange(ImagePaths);
                IInsuranceClaim.Update(Model); // Update the insurance claim in the service
                snackbar.Add("Saved Successfully", Severity.Success);
                MudDialog.Close(DialogResult.Ok(Model));
            }
            catch (Exception ex)
            {
                snackbar.Add(ex.Message, Severity.Warning);
            }
        }
        else
        {
            bool? result = await DialogService.ShowMessageBoxAsync(
                "Permission denied!",
                "You don't have any permission to Edit InsuranceClaim.");
        }
        await Task.Delay(200);
        _busy = false;
    }
}

