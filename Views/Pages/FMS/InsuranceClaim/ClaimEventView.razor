@page "/InsClaimMaster"
@inject IInsuranceClaimService Iservice
@inject MudBlazor.ISnackbar snackbar
@attribute [Authorize]
@inject AuthenticationStateProvider auth
@using System.Threading;
@inject IRoleService<RoleModel> Irole
@inject IDialogService DialogService

@if (_isLoading)
{
    <div @key="@("loader")" style="display: flex; justify-content: center; align-items: center; min-height: 400px;">
        <LoaderComponent IsFullScreen="true" 
                        ShowLogo="false" 
                        Size="medium" 
                        LoadingText="Loading Insurance Claim Events" 
                        SubText="Please wait..." />
    </div>
}
else
{
    <div @key="@("content")" class="admin-page-container">
        <div class="admin-header-tiered mb-6">
            <div class="d-flex align-center justify-space-between">
                <div>
                    <MudText Typo="Typo.h4" Class="admin-title">Claim Protocol Management</MudText>
                    <MudText Typo="Typo.body2" Class="admin-subtitle">Define and sequence mandatory operational events for insurance workflow compliance.</MudText>
                </div>
            </div>
        </div>

        <div class="admin-glass-card pa-0 overflow-hidden">
            <MudForm @bind-IsValid="@formValid" @ref="form">
                <MudTable Items="@ClaimEventList" Hover="true" Elevation="0" CanCancelEdit="true" Filter="new Func<InsuranceClaimEventMasterModel,bool>(FilterFunc)" RowEditPreview="BackupItem" RowEditCancel="ResetItemToOriginalValues" RowEditCommit="ItemHasBeenCommitted" Class="modern-admin-table no-border-radius">
                    <ToolBarContent>
                        <div class="d-flex align-center w-100 pa-4">
                            <div class="icon-badge primary-badge-soft mr-3">
                                <MudIcon Icon="@Icons.Material.Filled.List" Size="Size.Small" />
                            </div>
                            <MudText Typo="Typo.h6" Class="fw-700">Protocol Sequencing</MudText>
                            <MudSpacer />
                            <MudTextField @bind-Value="searchString" Placeholder="Filter protocols..." Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="modern-input" Clearable="true" Style="max-width: 300px;" />
                        </div>
                    </ToolBarContent>
                    <ColGroup>
                        <col style="width: 100px;" />
                        <col style="width: 25%;" />
                        <col style="width: 15%;" />
                        <col />
                        <col style="width: 120px;" />
                    </ColGroup>
                    <HeaderContent>
                        <MudTh><MudTableSortLabel InitialDirection="SortDirection.Ascending" SortBy="new Func<InsuranceClaimEventMasterModel, object>(x=>x.Order)"><span class="admin-header-text">SEQ</span></MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<InsuranceClaimEventMasterModel, object>(x=>x.Title)"><span class="admin-header-text">EVENT TITLE</span></MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<InsuranceClaimEventMasterModel, object>(x=>x.IsMandatory)"><span class="admin-header-text">OBLIGATORY</span></MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<InsuranceClaimEventMasterModel, object>(x=>x.Description)"><span class="admin-header-text">OPERATIONAL CONTEXT</span></MudTableSortLabel></MudTh>
                        <MudTh Style="text-align: right;"><span class="admin-header-text">EDIT</span></MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="Order">
                            <div class="d-flex align-center">
                                <span class="fw-700 color-primary mr-2">#@context.Order</span>
                                <MudIconButton Icon="@Icons.Material.Filled.KeyboardArrowUp" Color="Color.Primary" Size="Size.Small" OnClick="@(()=>MoveUp(context.Order))" Class="bg-light-primary rounded-pill" />
                            </div>
                        </MudTd>
                        <MudTd DataLabel="Title"><span class="fw-600">@context.Title</span></MudTd>
                        <MudTd DataLabel="Is Mandatory">
                            @if (context.IsMandatory)
                            {
                                <MudChip T="string" Size="Size.Small" Color="Color.Error" Variant="Variant.Text" Icon="@Icons.Material.Filled.Info" Class="fw-700">MANDATORY</MudChip>
                            }
                            else
                            {
                                <MudChip T="string" Size="Size.Small" Color="Color.Default" Variant="Variant.Text" Class="opacity-50">OPTIONAL</MudChip>
                            }
                        </MudTd>
                        <MudTd DataLabel="Description"><span class="small opacity-70">@context.Description</span></MudTd>
                    </RowTemplate>
                    <RowEditingTemplate>
                        <MudTd DataLabel="Order"><span class="fw-700">#@context.Order</span></MudTd>
                        <MudTd DataLabel="Title">
                            <MudTextField @bind-Value="@context.Title" Margin="Margin.Dense" Variant="Variant.Outlined" Required Class="modern-input" />
                        </MudTd>
                        <MudTd DataLabel="Is Mandatory">
                            <MudCheckBox T="bool" @bind-Value="@context.IsMandatory" Color="Color.Error" />
                        </MudTd>
                        <MudTd DataLabel="Description">
                            <MudTextField @bind-Value="@context.Description" Margin="Margin.Dense" Variant="Variant.Outlined" Required Class="modern-input" />
                        </MudTd>
                    </RowEditingTemplate>
                    <FooterContent>
                        <MudTd colspan="5" Class="pa-0">
                            <div class="pa-6 border-t bg-light-surface">
                                <div class="d-flex align-center mb-4">
                                    <div class="icon-badge success-badge-soft mr-3">
                                        <MudIcon Icon="@Icons.Material.Filled.Add" Size="Size.Small" />
                                    </div>
                                    <MudText Typo="Typo.subtitle1" Class="fw-700">Append New Protocol Event</MudText>
                                </div>
                                <MudGrid Spacing="3" Class="align-end">
                                    <MudItem xs="12" md="4">
                                        <MudTextField @bind-Value="@InsertElement.Title" Label="Event Title" Required Variant="Variant.Outlined" Margin="Margin.Dense" Class="modern-input" />
                                    </MudItem>
                                    <MudItem xs="12" md="2">
                                        <MudCheckBox T="bool" @bind-Value="@InsertElement.IsMandatory" Label="Mandatory State" Color="Color.Error" Dense="true" />
                                    </MudItem>
                                    <MudItem xs="12" md="4">
                                        <MudTextField @bind-Value="@InsertElement.Description" Label="Protocol Description" Required Variant="Variant.Outlined" Margin="Margin.Dense" Class="modern-input" />
                                    </MudItem>
                                    <MudItem xs="12" md="2">
                                        <MudButton Disabled="@(!formValid)" OnClick="(()=>ItemHasBeenCommitted(InsertElement))" Variant="Variant.Filled" Color="Color.Primary" FullWidth="true" Class="rounded-pill shadow-none py-2 mt-1">Append</MudButton>
                                    </MudItem>
                                </MudGrid>
                            </div>
                        </MudTd>
                    </FooterContent>
                </MudTable>
            </MudForm>
        </div>
    </div>
}



@code {

    private bool _isLoading = true;
    private DateTime _loadStartTime;

    MudForm form;
    bool formValid;
    private List<InsuranceClaimEventMasterModel> ClaimEventList = new();
    private InsuranceClaimEventMasterModel elementBeforeEdit;
    private InsuranceClaimEventMasterModel InsertElement = new();
    private InsuranceClaimEventMasterModel selectedItem1 = null;
    private InsuranceClaimEventMasterModel selectedItem2 = null;
    private HashSet<InsuranceClaimEventMasterModel> selectedItems1 = new();
    private HashSet<InsuranceClaimEventMasterModel> selectedItems2 = new();

    public bool HasPermissionInsuranceClaimServiceUpdateList { get; set; } = false;
    public bool HasPermissionInsuranceClaimServiceUpdateOrder { get; set; } = false;
    public int InsuranceClaimDocTypeID = 83;

    private string searchString = "";

    // Lifecycle method that runs when the component is initialized
    protected override async Task OnInitializedAsync()
    {
        _loadStartTime = DateTime.Now;
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionInsuranceClaimServiceUpdateList = await Irole.HasClaim(InsuranceClaimDocTypeID.ToString(), "UpdateList", ctc.Token);
        HasPermissionInsuranceClaimServiceUpdateOrder = await Irole.HasClaim(InsuranceClaimDocTypeID.ToString(), "UpdateList", ctc.Token);

        // Load the initial list of claim eventsc
        ClaimEventList = Iservice.GetEventList(null).ToList();
        await EnsureMinimumLoadTime();
        _isLoading = false;
    }

    private async Task EnsureMinimumLoadTime()
    {
        var elapsed = (DateTime.Now - _loadStartTime).TotalMilliseconds;
        if (elapsed < 100)
        {
            await Task.Delay(100 - (int)elapsed);
        }
    }

    // Method to move an event up in the order
    private async Task MoveUp(int? Order)
    {
        if (HasPermissionInsuranceClaimServiceUpdateOrder)
        {
            try
            {
                // Move the event upward in the order
                int retVal = Iservice.OrderMoveUpward(Order);
                // Refresh the event list after moving
                ClaimEventList = Iservice.GetEventList(null).ToList();
            }
            catch (Exception ex)
            {
                snackbar.Add(ex.Message, Severity.Warning);
            }
        }
        else
        {
            bool? result = await DialogService.ShowMessageBoxAsync(
                "Permission denied!",
                "You don't have any permission to UpdateOrder InsuranceClaim.");
        }
    }

    // Method to backup the item before editing
    private void BackupItem(object element)
    {
        var item = (InsuranceClaimEventMasterModel)element;
        elementBeforeEdit = new()
            {
                Description = item.Description,
                IcemID = item.IcemID,
                IsMandatory = item.IsMandatory,
                Order = item.Order,
                Title = item.Title
            };
    }

    // Method to commit changes to an item after editing
    private async void ItemHasBeenCommitted(object element)
    {
        if (HasPermissionInsuranceClaimServiceUpdateList)
        {
            var item = (InsuranceClaimEventMasterModel)element;
            var authState = auth.GetAuthenticationStateAsync().Result;
            item.UserInfo.UserID = authState.User.Identity.Name;
            item.Order = item.Order ?? ((ClaimEventList.Max(x => x.Order) ?? 0) + 1);
            try
            {
                // Update the event list with the modified item
                Iservice.UpdateEventList(item);

                // Refresh the event list after updating
                ClaimEventList = Iservice.GetEventList(null).ToList();
                await form.ResetAsync();
                snackbar.Add("Successfully Submitted", Severity.Success);
            }
            catch (Exception ex)
            {
                snackbar.Add(ex.Message, Severity.Error);
            }
        }
        else
        {
            bool? result = await DialogService.ShowMessageBoxAsync(
                "Permission denied!",
                "You don't have any permission to UpdateList InsuranceClaim.");
        }
    }

    // Method to reset an item to its original values
    private void ResetItemToOriginalValues(object element)
    {
        var item = (InsuranceClaimEventMasterModel)element;
        item.Description = elementBeforeEdit.Description;
        item.IcemID = elementBeforeEdit.IcemID;
        item.IsMandatory = elementBeforeEdit.IsMandatory;
        item.Order = elementBeforeEdit.Order;
        item.Title = elementBeforeEdit.Title;
    }

    // Method to filter the event list based on the search string
    private bool FilterFunc(InsuranceClaimEventMasterModel element)
    {
        if (string.IsNullOrWhiteSpace(searchString))
            return true;
        if (element.Title.Contains(searchString, StringComparison.OrdinalIgnoreCase))
            return true;
        if (element.Description.Contains(searchString, StringComparison.OrdinalIgnoreCase))
            return true;
        return false;
    }
}
