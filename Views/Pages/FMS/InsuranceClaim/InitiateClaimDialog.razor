@attribute [Authorize]
@inject IInsuranceClaimService Iservice
@inject IAssetDocumentService IdocService
@inject IBreakdownService Ibreakdown
@inject MudBlazor.ISnackbar snackbar
@inject AuthenticationStateProvider auth
@using System.IO
@using System.Threading;
@inject IRoleService<RoleModel> Irole
@inject IDialogService DialogService

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.Build" Class="mr-3 mb-n1" />
            Initiate Insurance Claim for Asset :  @Asset?.Description
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudContainer Style="min-height:300px;max-height: 800px;">
            <EditForm id="formInsuranceClaim" Model="@model" OnValidSubmit="OnValidSubmit">
                <ObjectGraphDataAnnotationsValidator />
                <ValidationSummary />
                <MudGrid Spacing="2">
                    <MudItem xs="12">
                        <MudTextField @bind-Value="@model.Notes" Variant="Variant.Outlined" Lines="6" Label="Notes"></MudTextField>
                    </MudItem>
                    <MudItem xs="12">
                        <MudGrid>
                            @foreach (var imagePath in ImagePaths)
                            {
                                <MudItem xs="6" md="4" xl="3">
                                    <iframe class="mt-1 mr-1 ml-1" src="@imagePath" height="300" alt="@imagePath" />
                                </MudItem>
                            }
                        </MudGrid>
                    </MudItem>
                </MudGrid>
            </EditForm>
        </MudContainer>
    </DialogContent>
    <DialogActions>
        <MyFileUpload @ref="Mfu" Resize="true" FolderName="@("InsuranceClaim/Breakdown-"+model.BreakdownID.ToString())" Label="Upload Photos" FilePathChanged="FileUploaded"></MyFileUpload>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        @if (Insurance != null)
        {
            <MudButton Disabled="@_busy" form="formInsuranceClaim" Variant="Variant.Filled" Color="Color.Success" ButtonType="ButtonType.Submit">Submit</MudButton>
        }
        else
        {
            <MudTooltip Text="Please check if you have valid insurance at the time of incident!">
                <MudText title="" Typo="Typo.body1" Color="Color.Error">No Active Insurance Found</MudText>
            </MudTooltip>
        }
    </DialogActions>
</MudDialog>

@code {

    [CascadingParameter] MudDialogInstance MudDialog { get; set; }
    [Parameter] public int? BreakdownID { get; set; }
    [Parameter] public AssetModel Asset { get; set; }
    [Parameter] public DateTime? TimeOfDamage { get; set; } = DateTime.Today;
    private AssetDocumentModel Insurance = new();
    private InsuranceClaimModel model = new();
    private bool _busy;
    private List<string> ImagePaths = new();
    MyFileUpload Mfu;

    public bool HasPermissionInsuranceClaimServiceEdit { get; set; } = false;
    public int InsuranceClaimDocTypeID = 83;

    protected override async Task OnInitializedAsync()
    {
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionInsuranceClaimServiceEdit = await Irole.HasClaim(InsuranceClaimDocTypeID.ToString(), "Edit", ctc.Token);

        var e = await auth.GetAuthenticationStateAsync();
        if (BreakdownID != null)
        {
            TimeOfDamage = Ibreakdown.SelectByID(BreakdownID).BreakdownTime;
        }
        Insurance = IdocService.SelectByAsset(Asset.AssetID).FirstOrDefault(x => x.DocumentType.DocumentTypeName.ToUpper().Contains("INSURANCE") && IdocService.IsValid(x, TimeOfDamage));
        model.BreakdownID = BreakdownID;
        model.IsOpen = true;
        model.InsuranceID = Insurance?.DocumentID;
        model.UserInfo.UserID = e.User.Identity.Name;
    }

    private void Cancel()
    {
        bool success = true;
        foreach (var item in ImagePaths.ToList())
        {
            if (Mfu.DeleteFile(item))
            {
                ImagePaths.Remove(item);
            }
            else
            {
                success = false;
            }
        }
        if (success)
        {
            MudDialog.Cancel();
        }
    }

    private async Task OnValidSubmit(EditContext context)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is being submitted!", Severity.Warning);
            return;
        }
        _busy = true;
        if (HasPermissionInsuranceClaimServiceEdit)
        {
            try
            {
                model.Images.AddRange(ImagePaths);
                Iservice.Update(model);
                snackbar.Add("Saved Successfully", Severity.Success);
                MudDialog.Close(DialogResult.Ok(model));
            }
            catch (Exception ex)
            {
                snackbar.Add(ex.Message, Severity.Warning);
            }
        }
        else
        {
            bool? result = await DialogService.ShowMessageBox(
                "Permission denied!",
                "You dont have any permission to Edit InsuranceClaim.");
        }
        await Task.Delay(200);
        _busy = false;
    }

    private void FileUploaded(string filePath)
    {
        ImagePaths.Add(filePath);
    }
}