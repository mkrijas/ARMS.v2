@page "/ManageClaims"
@attribute [Authorize]
@inject IInsuranceClaimService Iservice
@inject IAssetDocumentService IdocService
@inject ITruckService Itruck
@inject IAssetService IAsset
@inject IBreakdownService Ibreakdown
@inject MudBlazor.ISnackbar snackbar
@inject AuthenticationStateProvider auth
@using System.Threading;
@inject IRoleService<RoleModel> Irole
@inject IDialogService DialogService

<MudTable Items="@Collection" Elevation="8" Filter="new Func<InsuranceClaimModel, bool>(search)" @bind-Model="model">
    <ToolBarContent>
        <MudText Typo="Typo.h6">Active Claims</MudText>
        <MudSpacer></MudSpacer>
        <MudTextField @bind-Value="SearchClaim" Placeholder="Search Claim... " Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium"></MudTextField>
    </ToolBarContent>
    <HeaderContent>
        <MudTh><MudTableSortLabel SortBy="new Func<InsuranceClaimModel, object>(x=> x.TruckRegNo)" InitialDirection="SortDirection.Ascending">Truck RegNo</MudTableSortLabel></MudTh>
        <MudTh><MudTableSortLabel SortBy="new Func<InsuranceClaimModel, object>(x=> x.BranchName)" InitialDirection="SortDirection.Ascending">Branch Name</MudTableSortLabel></MudTh>
        <MudTh><MudTableSortLabel SortBy="new Func<InsuranceClaimModel, object>(x=> x.DateOfAccident)" InitialDirection="SortDirection.Ascending">Date Of Accident</MudTableSortLabel></MudTh>
        <MudTh><MudTableSortLabel SortBy="new Func<InsuranceClaimModel, object>(x=> x.UserInfo.TimeStampField)" InitialDirection="SortDirection.Ascending">Entry DateTime</MudTableSortLabel></MudTh>
        <MudTh>Actions</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd DataLabel="TruckReg">@context.TruckRegNo</MudTd>
        <MudTd DataLabel="BranchName">@context.BranchName</MudTd>
        <MudTd DataLabel="DateOfAccident">@context.DateOfAccident?.ToString("dd/MM/yyy")</MudTd>
        <MudTd DataLabel="TimeStampField">@context.UserInfo.TimeStampField</MudTd>
        <MudTd DataLabel="">
            <MudTooltip Text="Edit">
                <MudFab style="font-size:5px" @onclick="@(()=> Edit(context))" Color="Color.Primary" Icon="@Icons.Material.Filled.EditNote" Size="Size.Small" IconSize="Size.Small" />
            </MudTooltip>
            @* <MudTooltip Text="Delete">
            <MudFab @onclick="@(()=> Delete(context))" Color="Color.Primary" Icon="@Icons.Material.Filled.Delete" Size="Size.Small" IconSize="Size.Small" />
            </MudTooltip> *@
        </MudTd>
    </RowTemplate>
    <PagerContent>
        <MudTablePager PageSizeOptions="new int[] { 10, 20, 50, 100 }" />
    </PagerContent>
</MudTable>
