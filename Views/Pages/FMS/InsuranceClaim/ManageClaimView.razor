@page "/ManageClaims"
@attribute [Authorize]
@inject IInsuranceClaimService Iservice
@inject IAssetDocumentService IdocService
@inject ITruckService Itruck
@inject IBreakdownService Ibreakdown
@inject MudBlazor.ISnackbar snackbar
@inject AuthenticationStateProvider auth

<MudGrid>
    <MudItem xs="4" lg="3">
        <MudPaper Width="100%" Class="p-2">
            <MudList Clickable="true" SelectedItem="SelectedItem" SelectedItemChanged="SelectedItemChanged">
                <MudListSubheader>
                    Active Claims
                </MudListSubheader>
                @if (listOfItems?.Any() == true)
                {
                    @foreach (var item in listOfItems)
                    {
                        string regNo = Ibreakdown.SelectByID(item.BreakdownID).RegNo;
                        <MudListItem Value="item">
                            <MudText Typo=Typo.subtitle1> @regNo </MudText>
                            <MudText Typo="Typo.overline">Since : @item.UserInfo.TimeStampField?.ToString("dd/MM/yy")</MudText>
                        </MudListItem>
                    }
                }
            </MudList>
        </MudPaper>
    </MudItem>
    <MudItem xs="8" lg="9">
        @if (SelectedItem != null)
        {
            <MudPaper Width="100%" Class="p-2">
                @SelectedItem?.ChildContent
                @if (EventMasterSource?.Any(x => x.IsMandatory) != true && SelectedModel.IsOpen)
                {
                    <MudButton Color="Color.Primary" OnClick="CloseClaim">Close Claim</MudButton>
                }
                <MudList>
                    <MudListSubheader>
                        Event History
                    </MudListSubheader>
                    @if (ClaimEvents?.Any() == true)
                    {
                        <MudDivider></MudDivider>
                        @foreach (var item in ClaimEvents)
                        {
                            <MudListItem>
                                @item.Title On @item.EventDate?.ToString("dd/MM/yy")
                            </MudListItem>
                            <MudDivider></MudDivider>
                        }
                    }
                    @if (EventMasterSource?.Any() == true && SelectedModel.IsOpen)
                    {
                        <MudListItem>
                            <MudGrid>
                                <MudItem xs="5">
                                    <MudSelect T="int?" Label="Event" Value="UpdateStatusModel.IcemID" ValueChanged="EventSelected" OffsetY="true" AdornmentColor="Color.Secondary" Variant="Variant.Outlined" Required>
                                        @if (EventMasterSource?.Any() == true)
                                        {
                                            @foreach (var item in EventMasterSource)
                                            {
                                                <MudSelectItem T="int?" Value="item.IcemID">@item.Title</MudSelectItem>
                                            }
                                        }
                                    </MudSelect>
                                </MudItem>
                                <MudItem xs="5">
                                    <MudDatePicker Label="Date of Event" @bind-Date="UpdateStatusModel.EventDate" Variant=Variant.Outlined Required></MudDatePicker>
                                </MudItem>
                                <MudItem xs="2">
                                    <MudButton OnClick="UpdateStatus" Color="Color.Primary">Update</MudButton>
                                </MudItem>
                            </MudGrid>
                        </MudListItem>
                    }
                </MudList>
            </MudPaper>
            <h5>Images</h5>
            <MudGrid Spacing="2" Justify="Justify.Center">
                @foreach (var imagePath in SelectedModel?.Images)
                {
                    <MudItem xs="12" md="6" Class="d-flex">
                        <MudPaper Class="p-2" Elevation="3">
                            <img src="@imagePath" alt="@imagePath" />
                        </MudPaper>
                    </MudItem>
                }
            </MudGrid>
        }
    </MudItem>
</MudGrid>

@code {

    [Parameter] public int? BreakdownID { get; set; }
    private TruckModel Truck = new();
    private AssetDocumentModel Insurance = new();
    private List<InsuranceClaimModel> listOfItems = new();
    private List<InsuranceClaimEventStatusModel> ClaimEvents;
    private List<InsuranceClaimEventMasterModel> EventMasterSource;
    InsuranceClaimModel SelectedModel = new();
    private MudListItem SelectedItem;
    private InsuranceClaimEventStatusModel UpdateStatusModel = new();
    MyFileUpload Mfu;

    protected override async Task OnInitializedAsync()
    {
        listOfItems = Iservice.Select(null).ToList();
    }

    protected async Task SelectedItemChanged(object obj)
    {
        SelectedItem = (MudListItem)obj;
        SelectedModel = (InsuranceClaimModel)SelectedItem.Value;
        var e = await auth.GetAuthenticationStateAsync();
        BreakdownModel breakdown = Ibreakdown.SelectByID(BreakdownID);
        int TruckID = breakdown.TruckID.Value;
        Truck = Itruck.SelectByID(TruckID);
        Insurance = IdocService.SelectByAsset(TruckID).FirstOrDefault(x => x.DocumentType.DocumentTypeName.ToUpper().Contains("INSURANCE") && IdocService.IsValid(x, breakdown.BreakdownTime));
        ClaimEvents = Iservice.GetEventStatusList(SelectedModel.InsuranceClaimID).ToList();
        UpdateStatusModel = new()
            {
                InsuranceClaimID = SelectedModel.InsuranceClaimID,
            };

        SetEventMaster();
    }

    private void SetEventMaster()
    {
        int? maxval = null;
        if (ClaimEvents.Any() == true)
        {
            maxval = ClaimEvents?.Max(x => x.IcesID).Value;
        }
        EventMasterSource = Iservice.GetEventList(maxval).ToList();
    }

    private async Task OnValidSubmit(EditContext context)
    {
        try
        {
            Iservice.Update(SelectedModel);
            snackbar.Add("Saved Successfully", Severity.Success);
        }
        catch (Exception ex)
        {
            snackbar.Add(ex.Message, Severity.Warning);
        }
    }

    private async Task UpdateStatus()
    {
        try
        {
            var authState = await auth.GetAuthenticationStateAsync();
            UpdateStatusModel.UserInfo.UserID = authState.User.Identity.Name;
            UpdateStatusModel = Iservice.UpdateClaimEvent(UpdateStatusModel);
            ClaimEvents.Add(UpdateStatusModel);
            UpdateStatusModel = new()
                {
                    InsuranceClaimID = SelectedModel.InsuranceClaimID,
                };
            SetEventMaster();
        }
        catch { }
    }

    private void EventSelected(int? IcemID)
    {
        var SelectedEvent = EventMasterSource.First(x => x.IcemID == IcemID);
        if (EventMasterSource.Any(y => y.Order < SelectedEvent.Order && y.IsMandatory))
        {
            snackbar.Add("Other Mandatory Events are Missing!", Severity.Error);
            return;
        }
        UpdateStatusModel.IcemID = IcemID;
    }

    private async Task CloseClaim()
    {
        var authState = await auth.GetAuthenticationStateAsync();
        SelectedModel.IsOpen = false;
        SelectedModel.UserInfo.UserID = authState.User.Identity.Name;
        Iservice.Update(SelectedModel);
    }

    private void FileUploaded(string filePath)
    {
        SelectedModel.Images.Add(filePath);
    }
}