@code {

    [Parameter] public int? BreakdownID { get; set; }
    private TruckModel Truck = new();
    private AssetDocumentModel Insurance = new();
    private List<InsuranceClaimModel> Collection = new();
    private List<InsuranceClaimEventStatusModel> ClaimEvents;
    private List<InsuranceClaimEventMasterModel> EventMasterSource;
    InsuranceClaimModel SelectedModel = new();
    private MudListItem SelectedItem;
    private InsuranceClaimEventStatusModel UpdateStatusModel = new();
    private BreakdownModel Breakdown = new();
    MyFileUpload Mfu;

    private InsuranceClaimModel model = new InsuranceClaimModel();
    private string SearchClaim = "";
    private int BranchID;

    public bool HasPermissionInsuranceClaimServiceEdit { get; set; } = false;
    public bool HasPermissionInsuranceClaimServiceUpdateList { get; set; } = false;
    public int InsuranceClaimDocTypeID = 83;
    [Parameter]
    public EventCallback<MudListItem> OnClaimAdded { get; set; }
    private bool dialogVisible = false;

    // Lifecycle method that runs when the component is initialized
    protected override async Task OnInitializedAsync()
    {
        await GetAll();
    }

    // Method to fetch all insurance claims based on the user's branch ID
    private async Task GetAll()
    {
        var authprov = await auth.GetAuthenticationStateAsync();
        var brancIDString = authprov.User.Claims.First(x => x.Type == "BranchID").Value;
        int? brancID = int.Parse(brancIDString);
        Collection = Iservice.Select(null, brancID).ToList(); // Get claims for the branch
    }

    // Method to handle the selection of an item from the list
    protected async Task SelectedItemChanged(object obj)
    {
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionInsuranceClaimServiceEdit = await Irole.HasClaim(InsuranceClaimDocTypeID.ToString(), "Edit", ctc.Token);
        HasPermissionInsuranceClaimServiceUpdateList = await Irole.HasClaim(InsuranceClaimDocTypeID.ToString(), "UpdateList", ctc.Token);

        SelectedItem = (MudListItem)obj;
        SelectedModel = (InsuranceClaimModel)SelectedItem.Value;
        var e = await auth.GetAuthenticationStateAsync();
        BreakdownModel breakdown = Ibreakdown.SelectByID(BreakdownID); // Get breakdown details
        int TruckID = breakdown.TruckID.Value;
        Truck = Itruck.SelectByID(TruckID);

        // Fetch insurance document related to the truck
        Insurance = IdocService.SelectByAsset(TruckID, false).FirstOrDefault(x => x.DocumentType.DocumentTypeName.ToUpper().Contains("INSURANCE") && IdocService.IsValid(x, breakdown.BreakdownTime));
        ClaimEvents = Iservice.GetEventStatusList(SelectedModel.InsuranceClaimID).ToList(); // Get claim events
        UpdateStatusModel = new()
            {
                InsuranceClaimID = SelectedModel.InsuranceClaimID,
            };
        dialogVisible = true;
        SetEventMaster();
    }

    // Method to set up the event master data based on claim events
    private void SetEventMaster()
    {
        int? maxval = null;
        if (ClaimEvents.Any() == true)
        {
            maxval = ClaimEvents?.Max(x => x.IcesID).Value;
        }
        EventMasterSource = Iservice.GetEventList(maxval).ToList(); // Fetch event master list
    }

    // Method to handle the submission of a valid form
    private async Task OnValidSubmit(EditContext context)
    {
        if (HasPermissionInsuranceClaimServiceEdit)
        {
            try
            {
                Iservice.Update(SelectedModel); // Update the selected claim
                snackbar.Add("Saved Successfully", Severity.Success);
            }
            catch (Exception ex)
            {
                snackbar.Add(ex.Message, Severity.Warning);
            }
        }
        else
        {
            bool? result = await DialogService.ShowMessageBox(
                "Permission denied!",
                "You don't have any permission to Edit InsuranceClaim.");
        }
    }

    // Method to update the status of a claim
    private async Task UpdateStatus()
    {
        if (HasPermissionInsuranceClaimServiceUpdateList)
        {
            try
            {
                var authState = await auth.GetAuthenticationStateAsync();
                UpdateStatusModel.UserInfo.UserID = authState.User.Identity.Name;
                UpdateStatusModel = Iservice.UpdateClaimEvent(UpdateStatusModel); // Update claim event
                ClaimEvents.Add(UpdateStatusModel);
                UpdateStatusModel = new()
                    {
                        InsuranceClaimID = SelectedModel.InsuranceClaimID,
                    };
                SetEventMaster();
            }
            catch (Exception ex)
            {
                snackbar.Add(ex.Message, Severity.Warning);
            }
        }
        else
        {
            bool? result = await DialogService.ShowMessageBox(
                "Permission denied!",
                "You don't have any permission to UpdateList InsuranceClaim.");
        }
    }

    // Method to handle the selection of an event
    private void EventSelected(int? IcemID)
    {
        var SelectedEvent = EventMasterSource.First(x => x.IcemID == IcemID);
        if (EventMasterSource.Any(y => y.Order < SelectedEvent.Order && y.IsMandatory))
        {
            snackbar.Add("Other Mandatory Events are Missing!", Severity.Error);
            return;
        }
        UpdateStatusModel.IcemID = IcemID;
    }

    // Method to close a claim
    private async Task CloseClaim()
    {
        if (HasPermissionInsuranceClaimServiceEdit)
        {
            try
            {
                var authState = await auth.GetAuthenticationStateAsync();
                SelectedModel.IsOpen = false;
                SelectedModel.UserInfo.UserID = authState.User.Identity.Name;
                Iservice.Update(SelectedModel); // Update the claim
            }
            catch (Exception ex)
            {
                snackbar.Add(ex.Message, Severity.Warning);
            }
        }
        else
        {
            bool? result = await DialogService.ShowMessageBox(
                "Permission denied!",
                "You don't have any permission to Edit InsuranceClaim.");
        }
    }

    // Method to handle file uploads
    private void FileUploaded(string filePath)
    {
        SelectedModel.Images.Add(filePath);
    }

    // Method to add claims to the list
    async Task AddClaims(MudListItem MudListItem)
    {
        SelectedItem = MudListItem;
        //model.Assets.Add(MudListItem);
    }

    // Method to edit an existing insurance claim
    private async Task Edit(InsuranceClaimModel model)
    {
        InsuranceClaimModel Model = new();
        Breakdown = Ibreakdown.SelectByID(model.BreakdownID); // Get breakdown details
        var asset = IAsset.SelectByTruckID(Breakdown.TruckID); // Get asset details
        model.Asset = asset;
        Model = model;
        DialogOptions options = new DialogOptions()
            {
                MaxWidth = MaxWidth.Large,
            };
        DialogParameters parameters = new();
        parameters.Add("Model", Model.Clone());
        parameters.Add("ReadOnly", false);
        parameters.Add("Jobcard", false);
        var dialog = DialogService.Show<ClaimDialog>("Manage Claim", parameters, options);
        var result = await dialog.Result;
        if (!result.Canceled)
        {
            model = (InsuranceClaimModel)result.Data;
        }
        Model = new();
        await GetAll();
    }

    // Method to search for claims based on the truck registration number
    private bool search(InsuranceClaimModel model)
    {
        if (model?.TruckRegNo != null && model.TruckRegNo.Contains(SearchClaim, StringComparison.OrdinalIgnoreCase))
        {
            return true;
        }
        else
            return false;
    }
}