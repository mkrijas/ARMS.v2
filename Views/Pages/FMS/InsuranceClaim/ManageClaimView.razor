@page "/ManageClaims"
@attribute [Authorize]
@inject IInsuranceClaimService Iservice
@inject IAssetDocumentService IdocService
@inject ITruckService Itruck
@inject IAssetService IAsset
@inject IBreakdownService Ibreakdown
@inject MudBlazor.ISnackbar snackbar
@inject AuthenticationStateProvider auth
@using System.Threading;
@inject IRoleService<RoleModel> Irole
@inject IDialogService DialogService

@if (_isLoading)
{
    <div @key="@("loader")" style="display: flex; justify-content: center; align-items: center; min-height: 400px;">
        <LoaderComponent IsFullScreen="true" 
                        ShowLogo="false" 
                        Size="medium" 
                        LoadingText="Loading Active Claims" 
                        SubText="Please wait..." />
    </div>
}
else
{
    <div @key="@("content")" class="admin-page-container">
        <div class="admin-header-tiered mb-6">
            <div class="d-flex align-center justify-space-between">
                <div>
                    <MudText Typo="Typo.h4" Class="admin-title">Insurance Lifecycle Hub</MudText>
                    <MudText Typo="Typo.body2" Class="admin-subtitle">Comprehensive oversight and administrative management of active vehicle insurance claims.</MudText>
                </div>
            </div>
        </div>

        <div class="admin-glass-card pa-0 overflow-hidden">
            <div class="pa-6 border-b gray-bg">
                <MudGrid Spacing="3" Class="align-center">
                    <MudItem xs="12" md="6">
                        <div class="d-flex align-center">
                            <div class="icon-badge primary-badge-soft mr-3">
                                <MudIcon Icon="@Icons.Material.Filled.Search" Size="Size.Small" />
                            </div>
                            <MudTextField @bind-Value="SearchClaim" Placeholder="Search by Registration Number..." Variant="Variant.Outlined" Margin="Margin.Dense" Class="modern-input" Clearable="true" Immediate="true" />
                        </div>
                    </MudItem>
                    <MudItem xs="12" md="6" Class="d-flex justify-end">
                        <MudChip T="string" Color="Color.Primary" Variant="Variant.Text" Class="fw-700">@Collection.Count Active Dossiers</MudChip>
                    </MudItem>
                </MudGrid>
            </div>

            <MudTable Items="@Collection" Elevation="0" Filter="new Func<InsuranceClaimModel, bool>(search)" @bind-Model="model" Hover="true" Class="modern-admin-table no-border-radius">
                <HeaderContent>
                    <MudTh><MudTableSortLabel SortBy="new Func<InsuranceClaimModel, object>(x=> x.TruckRegNo)" InitialDirection="SortDirection.Ascending"><span class="admin-header-text">VEHICLE IDENTITY</span></MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<InsuranceClaimModel, object>(x=> x.BranchName)"><span class="admin-header-text">OPERATIONAL BRANCH</span></MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<InsuranceClaimModel, object>(x=> x.DateOfAccident)"><span class="admin-header-text">INCIDENT DATE</span></MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<InsuranceClaimModel, object>(x=> x.UserInfo.TimeStampField)"><span class="admin-header-text">REGISTRATION</span></MudTableSortLabel></MudTh>
                    <MudTh Style="text-align: right;"><span class="admin-header-text">ACTIONS</span></MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="TruckReg">
                        <div class="d-flex align-center">
                            <div class="icon-badge primary-badge-soft mr-3">
                                <MudIcon Icon="@Icons.Material.Filled.LocalShipping" Size="Size.Small" />
                            </div>
                            <span class="fw-700 color-primary">@context.TruckRegNo</span>
                        </div>
                    </MudTd>
                    <MudTd DataLabel="BranchName">
                        <MudChip T="string" Size="Size.Small" Variant="Variant.Text" Color="Color.Secondary" Class="fw-500">@context.BranchName</MudChip>
                    </MudTd>
                    <MudTd DataLabel="DateOfAccident">@context.DateOfAccident?.ToString("dd MMM yyyy")</MudTd>
                    <MudTd DataLabel="TimeStampField">
                        <div class="d-flex flex-column">
                            <span class="small opacity-70">@context.UserInfo.TimeStampField?.ToString("dd/MM/yyyy")</span>
                            <span class="small opacity-40">@context.UserInfo.TimeStampField?.ToString("HH:mm")</span>
                        </div>
                    </MudTd>
                    <MudTd DataLabel="Actions" Style="text-align: right;">
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="@(()=> Edit(context))" StartIcon="@Icons.Material.Filled.EditNote" Size="Size.Small" Class="rounded-pill shadow-none px-4">Manage</MudButton>
                    </MudTd>
                </RowTemplate>
                <PagerContent>
                    <div class="pa-4 border-t">
                        <MudTablePager PageSizeOptions="new int[] { 10, 20, 50, 100 }" />
                    </div>
                </PagerContent>
                <NoRecordsContent>
                    <div class="pa-12 text-center color-muted border-dashed m-4 rounded-lg">
                        <MudIcon Icon="@Icons.Material.Filled.SearchOff" Size="Size.Large" Class="mb-2 opacity-30" />
                        <MudText Typo="Typo.body2">No active insurance claims match your current investigation.</MudText>
                    </div>
                </NoRecordsContent>
            </MudTable>
        </div>
    </div>
}



@code {

    private bool _isLoading = true;
    private DateTime _loadStartTime;

    [Parameter] public int? BreakdownID { get; set; }
    private TruckModel Truck = new();
    private AssetDocumentModel Insurance = new();
    private List<InsuranceClaimModel> Collection = new();
    private List<InsuranceClaimEventStatusModel> ClaimEvents;
    private List<InsuranceClaimEventMasterModel> EventMasterSource;
    InsuranceClaimModel SelectedModel = new();
    private InsuranceClaimEventStatusModel UpdateStatusModel = new();
    private BreakdownModel Breakdown = new();
    MyFileUpload Mfu;

    private InsuranceClaimModel model = new InsuranceClaimModel();
    private string SearchClaim = "";
    private int BranchID;

    public bool HasPermissionInsuranceClaimServiceEdit { get; set; } = false;
    public bool HasPermissionInsuranceClaimServiceUpdateList { get; set; } = false;
    public int InsuranceClaimDocTypeID = 83;
    [Parameter]
    public EventCallback<InsuranceClaimModel> OnClaimAdded { get; set; } // Changed type
    private bool dialogVisible = false;

    // Lifecycle method that runs when the component is initialized
    protected override async Task OnInitializedAsync()
    {
        _loadStartTime = DateTime.Now;
        await GetAll();
        await EnsureMinimumLoadTime();
        _isLoading = false;
    }

    private async Task EnsureMinimumLoadTime()
    {
        var elapsed = (DateTime.Now - _loadStartTime).TotalMilliseconds;
        if (elapsed < 100)
        {
            await Task.Delay(100 - (int)elapsed);
        }
    }

    // Method to fetch all insurance claims based on the user's branch ID
    private async Task GetAll()
    {
        var authprov = await auth.GetAuthenticationStateAsync();
        var brancIDString = authprov.User.Claims.First(x => x.Type == "BranchID").Value;
        int? brancID = int.Parse(brancIDString);
        Collection = Iservice.Select(null, brancID).ToList(); // Get claims for the branch
    }

    // Method to handle the selection of an item 
    protected async Task Edit(InsuranceClaimModel obj)
    {
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionInsuranceClaimServiceEdit = await Irole.HasClaim(InsuranceClaimDocTypeID.ToString(), "Edit", ctc.Token);
        HasPermissionInsuranceClaimServiceUpdateList = await Irole.HasClaim(InsuranceClaimDocTypeID.ToString(), "UpdateList", ctc.Token);

        SelectedModel = obj;
        await OpenEditDialog((InsuranceClaimModel)obj);
    }

    // Method to set up the event master data based on claim events
    private void SetEventMaster()
    {
        int? maxval = null;
        if (ClaimEvents.Any() == true)
        {
            maxval = ClaimEvents?.Max(x => x.IcesID).Value;
        }
        EventMasterSource = Iservice.GetEventList(maxval).ToList(); // Fetch event master list
    }

    // Method to handle the submission of a valid form
    private async Task OnValidSubmit(EditContext context)
    {
        if (HasPermissionInsuranceClaimServiceEdit)
        {
            try
            {
                Iservice.Update(SelectedModel); // Update the selected claim
                snackbar.Add("Saved Successfully", Severity.Success);
            }
            catch (Exception ex)
            {
                snackbar.Add(ex.Message, Severity.Warning);
            }
        }
        else
        {
            bool? result = await DialogService.ShowMessageBoxAsync(
                "Permission denied!",
                "You don't have any permission to Edit InsuranceClaim.");
        }
    }

    // Method to update the status of a claim
    private async Task UpdateStatus()
    {
        if (HasPermissionInsuranceClaimServiceUpdateList)
        {
            try
            {
                var authState = await auth.GetAuthenticationStateAsync();
                UpdateStatusModel.UserInfo.UserID = authState.User.Identity.Name;
                UpdateStatusModel = Iservice.UpdateClaimEvent(UpdateStatusModel); // Update claim event
                ClaimEvents.Add(UpdateStatusModel);
                UpdateStatusModel = new()
                    {
                        InsuranceClaimID = SelectedModel.InsuranceClaimID,
                    };
                SetEventMaster();
            }
            catch (Exception ex)
            {
                snackbar.Add(ex.Message, Severity.Warning);
            }
        }
        else
        {
            bool? result = await DialogService.ShowMessageBoxAsync(
                "Permission denied!",
                "You don't have any permission to UpdateList InsuranceClaim.");
        }
    }

    // Method to handle the selection of an event
    private void EventSelected(int? IcemID)
    {
        var SelectedEvent = EventMasterSource.First(x => x.IcemID == IcemID);
        if (EventMasterSource.Any(y => y.Order < SelectedEvent.Order && y.IsMandatory))
        {
            snackbar.Add("Other Mandatory Events are Missing!", Severity.Error);
            return;
        }
        UpdateStatusModel.IcemID = IcemID;
    }

    // Method to close a claim
    private async Task CloseClaim()
    {
        if (HasPermissionInsuranceClaimServiceEdit)
        {
            try
            {
                var authState = await auth.GetAuthenticationStateAsync();
                SelectedModel.IsOpen = false;
                SelectedModel.UserInfo.UserID = authState.User.Identity.Name;
                Iservice.Update(SelectedModel); // Update the claim
            }
            catch (Exception ex)
            {
                snackbar.Add(ex.Message, Severity.Warning);
            }
        }
        else
        {
            bool? result = await DialogService.ShowMessageBoxAsync(
                "Permission denied!",
                "You don't have any permission to Edit InsuranceClaim.");
        }
    }

    // Method to handle file uploads
    private void FileUploaded(string filePath)
    {
        SelectedModel.Images.Add(filePath);
    }

    // Method to add claims - Signature updated/removed
    async Task AddClaims(InsuranceClaimModel claim)
    {
       // SelectedItem = MudListItem; 
       // Logic removed as MudListItem is gone.
    }

    // Method to edit an existing insurance claim
    private async Task OpenEditDialog(InsuranceClaimModel model)
    {
        InsuranceClaimModel Model = new();
        Breakdown = Ibreakdown.SelectByID(model.BreakdownID); // Get breakdown details
        var asset = IAsset.SelectByTruckID(Breakdown.TruckID); // Get asset details
        model.Asset = asset;
        Model = model;
        DialogOptions options = new DialogOptions()
            {
                MaxWidth = MaxWidth.Large,
            };
        DialogParameters parameters = new();
        parameters.Add("Model", Model.Clone());
        parameters.Add("ReadOnly", false);
        parameters.Add("Jobcard", false);
        var dialog = await DialogService.ShowAsync<ClaimDialog>("Manage Claim", parameters, options);
        var result = await dialog.Result;
        if (!result.Canceled)
        {
            model = (InsuranceClaimModel)result.Data;
        }
        Model = new();
        await GetAll();
    }

    // Method to search for claims based on the truck registration number
    private bool search(InsuranceClaimModel model)
    {
        if (model?.TruckRegNo != null && model.TruckRegNo.Contains(SearchClaim, StringComparison.OrdinalIgnoreCase))
        {
            return true;
        }
        else
            return false;
    }
}

