@using ArmsModels.BaseModels
@using MudBlazor
@inject ISnackbar snackbar

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.AddAlert" Class="mr-3" /> Add New Job in @(CurrentWorkshop?.WorkshopName)
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudContainer Style="max-height: 500px; overflow-y: auto" Class="pa-0 pa-md-4">
            <JobInProgressView workshop="CurrentWorkshop" model="NewJob" @ref="jipView"></JobInProgressView>
        </MudContainer>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel" Variant="Variant.Text">Cancel</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" OnClick="Add" Class="fw-bold px-6" Style="border-radius: 6px;">Create Job</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; }
    [Parameter] public WorkshopModel CurrentWorkshop { get; set; }
    [Parameter] public JobInProgressModel NewJob { get; set; }
    
    JobInProgressView jipView;

    private async Task Add()
    {
        if (NewJob.RepairJobID == null || NewJob.RepairJobID == 0)
        {
            snackbar.Add("Please select a job.", Severity.Error);
            return;
        }

        try {
            await jipView.UpdateJob(NewJob);
            MudDialog.Close(DialogResult.Ok(true));
        } catch (Exception ex) {
            snackbar.Add(ex.Message, Severity.Error);
        }
    }
    
    void Cancel() => MudDialog.Cancel();
}
