@using ArmsModels.BaseModels
@using MudBlazor
@inject ISnackbar snackbar
@inject IDialogService DialogService

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.People" Class="mr-3" /> Assign Mechanics
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudContainer Style="height: 300px; overflow-y: auto">
            <MudSelect T="MechanicModel" MultiSelection="true" Label="Assign Mechanic/s" ToStringFunc="@(p => p.MechanicName)" @bind-SelectedValues="SelectedMechanics" Variant="Variant.Outlined" Margin="Margin.Dense" AnchorOrigin="Origin.BottomCenter" AdornmentColor="Color.Secondary">
                @foreach (var item in Mechanics)
                {
                    <MudSelectItem T="MechanicModel" Value="@item">@item.MechanicName</MudSelectItem>
                }
            </MudSelect>
        </MudContainer>
    </DialogContent>
    <DialogActions>
        <MudButton Color="Color.Success" OnClick="Add">Add</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; }
    [Parameter] public List<MechanicModel> Mechanics { get; set; } = new();
    
    public IReadOnlyCollection<MechanicModel> SelectedMechanics { get; set; } = new HashSet<MechanicModel>();

    private void Add()
    {
        if (SelectedMechanics != null && SelectedMechanics.Any())
        {
            MudDialog.Close(DialogResult.Ok(SelectedMechanics));
        }
        else 
        {
            snackbar.Add("Please select at least one mechanic.", Severity.Warning);
        }
    }
}
