@page "/completedjobcard"
@page "/completedjobcard/{TruckID:int}"

@inject IJobcardService Iservice
@inject IBreakdownService Ibreakdownservice
@inject MudBlazor.ISnackbar snackbar
@attribute [Authorize]
@inject AuthenticationStateProvider auth
@inject NavigationManager nav
@inject IDialogService DialogService
@using System.Threading;
@inject IRoleService<RoleModel> Irole

<MudTable Items="@collection" Elevation="10" Filter="new Func<JobcardModel, bool>(search)" @bind-model="model">
    <ToolBarContent>
        <MudText Typo="Typo.h6">Jobcards</MudText>
        <MudSpacer></MudSpacer>
        <MudTextField @bind-Value="searchString" Placeholder="Search JobcardNumber or Truck..." Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0"></MudTextField>
    </ToolBarContent>
    <HeaderContent>
        <MudTh><MudTableSortLabel SortBy="new Func<JobcardModel, object>(x=> x.JobcardID)" InitialDirection="SortDirection.Descending">Jobcard No</MudTableSortLabel></MudTh>
        @* <MudTh><MudTableSortLabel SortBy="new Func<JobcardModel, object>(x=> x.workshop)">Workshop</MudTableSortLabel></MudTh> *@
        <MudTh><MudTableSortLabel SortBy="new Func<JobcardModel, object>(x=> x.RegNo)" >Truck</MudTableSortLabel></MudTh>
        <MudTh><MudTableSortLabel SortBy="new Func<JobcardModel, object>(x=> x.CreatedOn)" >Created on</MudTableSortLabel></MudTh>
        <MudTh>Actions</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd DataLabel="JobcardNumber"> <MudHighlighter Style="background-color:cornflowerblue;font-weight:bold" Text="@context.JobcardNumber" HighlightedText="@searchString" /></MudTd>
        @* <MudTd DataLabel="Workshop">@context.workshop</MudTd> *@
        <MudTd DataLabel="Truck">@context.RegNo</MudTd>
        <MudTd DataLabel="Date">@context.CreatedOn</MudTd>
        <MudTd DataLabel="">
            <MudIconButton @onclick="@(()=> Edit(context))" Title="Edit" Color="Color.Primary" Icon="@Icons.Material.Filled.Edit" Size="Size.Small"  />
            <MudIconButton @onclick="@(()=> Delete(context))" Title="Delete" Color="Color.Primary" Icon="@Icons.Material.Filled.Delete" Size="Size.Small" />
        </MudTd>
    </RowTemplate>
    <PagerContent>
        <MudTablePager PageSizeOptions="new int[] { 10, 20, 50, 100 }" />
    </PagerContent>
</MudTable>

@code {

    private JobcardModel model;
    private List<JobcardModel> collection = new();
    private string searchString = string.Empty;

    public bool HasPermissionJobcardServiceDelete { get; set; } = false;
    public int JobcardDocTypeID = 82;

    [Parameter]
    public int? TruckID { get; set; }

    int? BranchID;

    protected override async Task OnInitializedAsync()
    {
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionJobcardServiceDelete = await Irole.HasClaim(JobcardDocTypeID.ToString(), "Edit", ctc.Token);
        var authState = await auth.GetAuthenticationStateAsync();
        BranchID = int.Parse(authState.User.Claims.First(x => x.Type == "BranchID").Value);
        model = new();
        GetAll();
    }

    private void GetAll()
    { 
        if (TruckID is not null)
        {
            collection = Iservice.SelectByTruck(TruckID, false).ToList();
        }
        else
        {
            collection = Iservice.SelectByBranch(BranchID, false).ToList();
        }
    }

    private void Edit(JobcardModel Jobcard)
    {
        nav.NavigateTo(string.Concat("jobcard/",Jobcard.TruckID,"/",Jobcard.JobcardID));
    }

    private async Task Delete(JobcardModel model)
    {
        if (HasPermissionJobcardServiceDelete)
        {
            bool? result = await DialogService.ShowMessageBox(
                "Warning !",
                "Are you sure, you want to delete - " + model.JobcardNumber + " ?");
            if (result == true)
            {
                var authprov = await auth.GetAuthenticationStateAsync();
                var user = authprov.User;
                Iservice.Delete(model.JobcardID, user.Identity.Name);
                snackbar.Add("Deleted Successfully", Severity.Success);
            }
        }
        else
        {
            bool? result = await DialogService.ShowMessageBox(
                "Permission denied!",
                "You don't have any permission to Delete Jobcard.");
        }
        GetAll();
    }

    private bool search(JobcardModel model)
    {
        if (model.JobcardNumber != null && model.JobcardNumber.Contains(searchString, StringComparison.OrdinalIgnoreCase) || model.RegNo.Contains(searchString, StringComparison.OrdinalIgnoreCase))
        {
            return true;
        }
        return false;
    }
}