@page "/completedjobcard"
@page "/completedjobcard/{TruckID:int}"

@inject IJobcardService Iservice
@inject IBreakdownService Ibreakdownservice
@inject MudBlazor.ISnackbar snackbar
@attribute [Authorize]
@inject AuthenticationStateProvider auth
@inject NavigationManager nav
@inject IDialogService DialogService
@using System.Threading;
@inject IRoleService<RoleModel> Irole

    <div class="admin-page-container fade-in" @key="@("content")">
        <div class="admin-header-tiered mb-6">
            <div class="d-flex align-center justify-space-between">
                <div>
                    <MudText Typo="Typo.h4" Class="admin-title">Workshop Archive</MudText>
                    <MudText Typo="Typo.body2" Class="admin-subtitle">Access comprehensive historical records of completed vehicle maintenance and structural repairs.</MudText>
                </div>
            </div>
        </div>

        <div class="admin-glass-card pa-6 mb-6">
            <MudGrid Spacing="3" Class="align-center">
                <MudItem xs="12" md="6">
                    <MudTextField @bind-Value="searchString" Placeholder="Search by Jobcard Number or Vehicle Registration..." Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" AdornmentColor="Color.Primary" Variant="Variant.Outlined" Margin="Margin.Dense" Clearable="true" Class="modern-input"></MudTextField>
                </MudItem>
                <MudItem xs="12" md="6" Class="d-flex justify-end">
                    <div class="d-flex align-center gap-2">
                        <MudText Typo="Typo.caption" Class="admin-subtitle">ARCHIVED RECORDS: @(collection?.Count ?? 0)</MudText>
                    </div>
                </MudItem>
            </MudGrid>
        </div>

        <div class="admin-glass-card overflow-hidden">
            <MudTable Items="@collection" Elevation="0" Filter="new Func<JobcardModel, bool>(search)" @bind-model="model" Hover="true" Breakpoint="Breakpoint.Sm" Class="modern-admin-table">
                <HeaderContent>
                    <MudTh><MudTableSortLabel SortBy="new Func<JobcardModel, object>(x=> x.JobcardID)" InitialDirection="SortDirection.Descending"><span class="admin-header-text">ARCHIVE NO</span></MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<JobcardModel, object>(x=> x.RegNo)"><span class="admin-header-text">ASSET ID</span></MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<JobcardModel, object>(x=> x.CreatedOn)"><span class="admin-header-text">COMPLETION</span></MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<JobcardModel, object>(x=> x.BreakdownType)"><span class="admin-header-text">JOB CATEGORY</span></MudTableSortLabel></MudTh>
                    <MudTh Style="text-align: right;"><span class="admin-header-text">ACTIONS</span></MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="JobcardNumber">
                        <span class="admin-td-primary fw-600 font-mono">
                            <MudHighlighter Text="@context.JobcardNumber" HighlightedText="@searchString" />
                        </span>
                    </MudTd>
                    <MudTd DataLabel="Truck"><span class="fw-500">@context.RegNo</span></MudTd>
                    <MudTd DataLabel="Date"><span class="opacity-70">@context.CreatedOn?.ToString("dd MMM yyyy")</span></MudTd>
                    <MudTd DataLabel="BreakdownType">
                        <MudChip T="string" Size="Size.Small" Color="@(context.BreakdownType == "Major" ? Color.Error : Color.Info)" Variant="Variant.Text" Class="fw-600">@context.BreakdownType</MudChip>
                    </MudTd>
                    <MudTd DataLabel="Actions" Style="text-align: right;">
                        <MudTooltip Text="Review Archive Details">
                            <MudIconButton OnClick="@(()=> Edit(context))" Color="Color.Primary" Icon="@Icons.Material.Filled.Assignment" Size="Size.Small" Variant="Variant.Text" />
                        </MudTooltip>
                        @if (HasPermissionJobcardServiceDelete)
                        {
                            <MudTooltip Text="Remove from Archive">
                                <MudIconButton OnClick="@(()=> Delete(context))" Color="Color.Error" Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Variant="Variant.Text" />
                            </MudTooltip>
                        }
                    </MudTd>
                </RowTemplate>
                <PagerContent>
                    <div class="pa-4">
                        <MudTablePager PageSizeOptions="new int[] { 10, 20, 50, 100 }" />
                    </div>
                </PagerContent>
            </MudTable>
        </div>
    </div>

@code {

    private JobcardModel model;
    private List<JobcardModel> collection = new();
    private string searchString = string.Empty;

    public bool HasPermissionJobcardServiceDelete { get; set; } = false;
    public int JobcardDocTypeID = 82;

    [Parameter]
    public int? TruckID { get; set; }

    int? BranchID;

    // Lifecycle method that runs when the component is initialized
    protected override async Task OnInitializedAsync()
    {
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionJobcardServiceDelete = await Irole.HasClaim(JobcardDocTypeID.ToString(), "Edit", ctc.Token);
        var authState = await auth.GetAuthenticationStateAsync();
        BranchID = int.Parse(authState.User.Claims.First(x => x.Type == "BranchID").Value);
        model = new();
        GetAll();
    }

    // Method to fetch job cards based on Truck ID or Branch ID
    private void GetAll()
    {        
        if (TruckID is not null)
        {
            collection = Iservice.SelectByTruck(TruckID, false).ToList();  // If TruckID is provided, fetch job cards for that truck
        }
        else
        {
            collection = Iservice.SelectByBranch(BranchID, false).ToList(); // Otherwise, fetch job cards for the branch
        }
    }

    // Method to navigate to the edit page for a specific job card
    private void Edit(JobcardModel Jobcard)
    {
        nav.NavigateTo(string.Concat("jobcard/",Jobcard.TruckID,"/",Jobcard.JobcardID));
    }

    // Method to delete a specific job card
    private async Task Delete(JobcardModel model)
    {
        if (HasPermissionJobcardServiceDelete)
        {
            bool? result = await DialogService.ShowMessageBoxAsync(
                "Warning !",
                "Are you sure, you want to delete - " + model.JobcardNumber + " ?");
            if (result == true)
            {
                var authprov = await auth.GetAuthenticationStateAsync();
                var user = authprov.User;

                // Call the service to delete the job card
                Iservice.Delete(model.JobcardID, user.Identity.Name);
                snackbar.Add("Deleted Successfully", Severity.Success);
            }
        }
        else
        {
            bool? result = await DialogService.ShowMessageBoxAsync(
                "Permission denied!",
                "You don't have any permission to Delete Jobcard.");
        }
        GetAll();
    }

    // Method to search for job cards based on job card number or registration number
    private bool search(JobcardModel model)
    {
        if (model.JobcardNumber != null && model.JobcardNumber.Contains(searchString, StringComparison.OrdinalIgnoreCase) || model.RegNo.Contains(searchString, StringComparison.OrdinalIgnoreCase))
        {
            return true;
        }
        return false;
    }
}
