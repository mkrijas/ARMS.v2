
@attribute [Authorize]

@inject IJobcardService Iservice
@inject IWorkshopService Iworkshop
@inject IJobcardWorkshopService Ijw
@inject IBreakdownService IBreakdownservice
@inject MudBlazor.ISnackbar snackbar
@inject AuthenticationStateProvider auth

@inject IPushNotificationService IpushNotificationService
@inject SignalRService signalRService
@inject ITripService Itrip
@inject ITruckService Itruck
@inject IDialogService DialogService

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.Build" Class="mr-3 mb-n1" />
            Create Jobcard for @Breakdown.RegNo
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudContainer Style="min-height:300px;max-height: 800px;">
            <EditForm id="formJobcard" Model="@model" OnValidSubmit="OnValidSubmit">
                <ObjectGraphDataAnnotationsValidator />
                <ValidationSummary />
                <MudGrid Spacing="2">
@*                    @if (PeriodicMaintenanceId != null)
                    {*@
                        <MudItem xs="12">
                            <MudTextField @bind-Value="@(Breakdown.BreakdownType)" Label="Breakdown Type" Variant="Variant.Outlined" Margin="Margin.Dense" Disabled></MudTextField>
                        </MudItem>
                        
                    @*}*@
                    <MudItem xs="12">
                        <MudSelect Label="Select Workshop" Value="SelectedWorkshop" ValueChanged="OnWorkshopChanged" T="WorkshopModel" ToStringFunc="@((p) => p?.WorkshopName)" Variant="Variant.Outlined" Margin="Margin.Dense" OffsetY="true" Direction="Direction.Top" AdornmentColor="Color.Secondary">
                            @foreach (var ditem in Workshops)
                            {
                                <MudSelectItem Value="@ditem">@ditem.WorkshopName</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12">
                        @foreach (var item in model.Jobs)
                        {
                            <JobInProgressView model="item" workshop="SelectedWorkshop" @ref="JipComp"></JobInProgressView>
                        }
                        </MudItem>
                </MudGrid>
            </EditForm>
        </MudContainer>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="DeleteJob" Hidden="@(model.Jobs.Count<2)">Delete Job</MudButton>
        <MudButton OnClick="AddJob">Add More Jobs</MudButton>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton form="formJobcard" Variant="Variant.Filled" Color="Color.Success" ButtonType="ButtonType.Submit">Submit</MudButton>

    </DialogActions>
</MudDialog>


@code {

    [Parameter]
    public JobcardModel model { get; set; }
    [CascadingParameter] MudDialogInstance MudDialog { get; set; }
    [Parameter] public BreakdownModel Breakdown { get; set; } = new();
    private WorkshopModel SelectedWorkshop = new();

    private JobInProgressView JipComp;

    [Parameter]
    public int? PeriodicMaintenanceId { get; set; } = null;
    private List<WorkshopModel> Workshops = new();


    public string UserID { get; set; }

    #region SignaIR Notification
    private List<PushNotificationModel> currentNotificationMessages = new List<PushNotificationModel>();
    private PushNotificationModel notificationMessage = new PushNotificationModel();
    #endregion

    protected override async Task OnInitializedAsync()
    {
        var e = await auth.GetAuthenticationStateAsync();
        string BranchIDString = e.User.Claims.First(x => x.Type == "BranchID").Value;
        if(model == null)
        {
            model = new();
        }
        model.TruckID = Breakdown.TruckID;
        model.BreakdownID = Breakdown?.BreakdownID??null;
        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;
        UserID = user.Identity.Name;
        Workshops = Iworkshop.Select(null).ToList();
        await signalRService.StartAsync();
        AddJob();
    }

    private void OnWorkshopChanged(WorkshopModel obj)
    {
        SelectedWorkshop = obj;
        if(obj != null)
        {
            model.workshop = obj.WorkshopID.ToString(); 
        }
        else
        {
            model.workshop = null;
        }
    }
    private void Cancel()
    {
        MudDialog.Cancel();
    }

    private void AddJob()
    {
        model.Jobs.Add(new JobInProgressModel() {JobStatus = 1});
    }

    private void DeleteJob()
    {
        model.Jobs.RemoveAt(model.Jobs.Count - 1);
    }

    private async Task OnValidSubmit(EditContext context)
    {
        var CurrentTrip = Itrip.Select(Itruck.GetCurrentTrip(Breakdown.TruckID));
        if (CurrentTrip != null && PeriodicMaintenanceId != null && !Itrip.IsClosed(CurrentTrip.TripID))
        {
            Breakdown = IBreakdownservice.Update(Breakdown);
            model.BreakdownID = Breakdown?.BreakdownID??null;
            model.PMIID = PeriodicMaintenanceId;
        }
        var authprov = await auth.GetAuthenticationStateAsync();
        model.UserInfo.UserID = authprov.User.Identity.Name;

        int BranchID = int.Parse(authprov.User.Claims.First(x => x.Type == "BranchID").Value);
        model.BranchID = BranchID;
        if (SelectedWorkshop.WorkshopID == null)
        {
            bool? result = await DialogService.ShowMessageBox(
            "Warning",
            "Please, Select workshop.", yesText: "OK");

            return;
        }

        if (model.Jobs == null)
        {
            bool? result = await DialogService.ShowMessageBox(
            "Warning",
            "Please, Select a job and mechanic.", yesText: "OK");

            return;
        }
        
        try {
            model.JobcardID = Iservice.Update(model).JobcardID;
            JobcardWorkshopModel Jwm = new()
            {
                WorkshopID = SelectedWorkshop.WorkshopID,
                JobCardID = model.JobcardID,
                EnteredOn = DateTime.Now,
                UserInfo = model.UserInfo
            };
            Ijw.Update(Jwm);

            foreach(var item in model.Jobs)
            {
                item.JobCardID = model.JobcardID;
                item.WorkshopID = SelectedWorkshop.WorkshopID;                
                item.UserInfo = model.UserInfo;
                JipComp.UpdateJob(item);
            }
            snackbar.Add("Saved Successfully", Severity.Success);
            if(PeriodicMaintenanceId != null)
            {
                notificationMessage = new();
                notificationMessage.DocumentID = PeriodicMaintenanceId;
                notificationMessage.MessageGroupID = "PeriodicMaintainence";
                notificationMessage.DocumentTypeID = 59;

                currentNotificationMessages = IpushNotificationService.SelectNotificationsBasedOnBranchDocumentIdDocumentTypeId(BranchID, PeriodicMaintenanceId, 59).ToList();
                string MessageIDs = string.Join(",", currentNotificationMessages.Select(d => d.MessageID).ToList());
                try
                {
                    IpushNotificationService.AknowledgedSelectedItems(MessageIDs, UserID);
                }
                catch (Exception ex)
                {

                }

                await signalRService.Send(notificationMessage);
            }
            MudDialog.Close(DialogResult.Ok(model));            
        }
        catch (Exception ex)
        {
            snackbar.Add(ex.Message, Severity.Warning);
        }
    }
}



