@inject IJobcardService Iservice
@inject IWorkshopService Iworkshop
@inject ITripService Itrip
@inject ITruckService Itruck
@inject IJobcardWorkshopService Ijw
@inject SignalRService signalRService
@inject MudBlazor.ISnackbar snackbar
@inject AuthenticationStateProvider auth
@inject IRoleService<RoleModel> Irole
@inject IDialogService DialogService

<MudDialog Class="admin-dialog-glass">
    <TitleContent>
        <div class="header-section mb-2 pt-4 px-4">
            <div class="d-flex align-center justify-space-between">
                <div class="d-flex align-center">
                    <div class="icon-badge primary-badge mr-4">
                        <div class="admin-header-icon-badge mb-3">
                            <MudIcon Icon="@Icons.Material.Filled.Construction" Color="Color.Secondary" Style="font-size: 3rem;" />
                        </div>
                    </div>
                    <div>
                        <MudText Typo="Typo.h5" Class="admin-title"><b>Create New Jobcard</b></MudText>
                        <MudText Typo="Typo.body2" Class="admin-subtitle">@($"Initialize repair workflow for vehicle {Breakdown.RegNo}.")</MudText>
                    </div>
                </div>
            </div>
            <div class="title-accent mt-4"></div>
        </div>
    </TitleContent>
    <DialogContent>
        <MudContainer Class="admin-dialog-container">
            <div class="dialog-content-wrapper pa-4 fade-in">
                <EditForm id="formJobcard" Model="@model" OnValidSubmit="OnValidSubmit">
                    <ObjectGraphDataAnnotationsValidator />
                    
                    <div class="admin-glass-card pa-6 mb-6">
                        <div class="d-flex align-center mb-6">
                            <div class="icon-badge primary-badge-soft mr-3">
                                <MudIcon Icon="@Icons.Material.Filled.Info" Size="Size.Small" />
                            </div>
                            <span class="admin-section-label mb-0">Order Identification</span>
                        </div>

                        <MudGrid Spacing="3">
                            <MudItem xs="12" md="6">
                                <MudTextField @bind-Value="@(Breakdown.BreakdownType)" Label="Work Order Type" Variant="Variant.Outlined" Margin="Margin.Dense" Disabled Class="modern-input" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Category" />
                            </MudItem>
                            <MudItem xs="12" md="6">
                                <MudTextField @bind-Value="@(model.Odometer)" Label="Arrival Odometer" Variant="Variant.Outlined" Margin="Margin.Dense" Class="modern-input" Adornment="Adornment.End" AdornmentText="KM" />
                            </MudItem>
                            <MudItem xs="12">
                                <MudAutocomplete Label="Primary Workshop Facility" Value="SelectedWorkshop" ValueChanged="OnWorkshopChanged" T="WorkshopModel" SearchFunc="SearchWorkshops" ToStringFunc="@((p) => p?.WorkshopName)" Variant="Variant.Outlined" Margin="Margin.Dense" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Warehouse" Class="modern-input" />
                            </MudItem>
                        </MudGrid>
                    </div>

                    <div class="admin-glass-card pa-6">
                        <div class="d-flex align-center justify-space-between mb-6">
                            <div class="d-flex align-center">
                                <div class="icon-badge secondary-badge-soft mr-3">
                                    <MudIcon Icon="@Icons.Material.Filled.PlaylistAddCheck" Size="Size.Small" />
                                </div>
                                <span class="admin-section-label mb-0">Repair Scope & Jobs</span>
                            </div>
                            <div class="d-flex gap-2">
                                <MudButton StartIcon="@Icons.Material.Filled.RemoveCircleOutline" Color="Color.Error" OnClick="DeleteJob" Hidden="@(model.Jobs.Count < 2)" Size="Size.Small" Variant="Variant.Text">Remove Last</MudButton>
                                <MudButton StartIcon="@Icons.Material.Filled.AddCircleOutline" Color="Color.Primary" OnClick="AddJob" Size="Size.Small" Variant="Variant.Text">Add More</MudButton>
                            </div>
                        </div>

                        <div class="job-items-container">
                            @foreach (var item in model.Jobs)
                            {
                                <div class="job-item-entry pa-4 rounded-lg mb-4 border-subtle bg-light-surface">
                                    <JobInProgressView model="item" workshop="SelectedWorkshop" @ref="JipComp" SetJobs="SetJob"></JobInProgressView>
                                </div>
                            }
                        </div>
                    </div>
                </EditForm>
            </div>
        </MudContainer>
    </DialogContent>
    <DialogActions>
        <div class="d-flex w-100 flex-wrap pa-4 gap-3 align-center">
            <MudSpacer />
            <MudButton @onclick="Cancel" Variant="Variant.Outlined" Color="Color.Default" Style="border-radius: 12px; font-weight: 700; text-transform: none; border-color: rgba(0,0,0,0.15);">Discard</MudButton>
            <MudButton Disabled="@_busy" form="formJobcard" Variant="Variant.Filled" ButtonType="ButtonType.Submit" Color="Color.Success" Style="background: var(--mud-palette-success); color: white; font-weight: 800; border-radius: 12px; text-transform: none; white-space: nowrap; padding: 8px 24px;" StartIcon="@Icons.Material.Filled.DoneAll">Create Jobcard</MudButton>
        </div>
    </DialogActions>
</MudDialog>

@code {
    [Parameter]
    public JobcardModel model { get; set; }
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; }
    [Parameter] public BreakdownModel Breakdown { get; set; } = new();
    private WorkshopModel SelectedWorkshop = new();
    private JobInProgressView JipComp;
    private bool _busy;    
    private List<WorkshopModel> Workshops = new();
    public string UserID { get; set; }

    #region SignaIR Notification
    private List<PushNotificationModel> currentNotificationMessages = new List<PushNotificationModel>();
    private PushNotificationModel notificationMessage = new PushNotificationModel();
    #endregion

    public bool HasPermissionJobcardServiceEdit { get; set; } = false;
    public int JobcardDocTypeID = 82;

    // Lifecycle method that runs when the component is initialized
    protected override async Task OnInitializedAsync()
    {
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionJobcardServiceEdit = await Irole.HasClaim(JobcardDocTypeID.ToString(), "Edit", ctc.Token);

        var e = await auth.GetAuthenticationStateAsync();
        string BranchIDString = e.User.Claims.First(x => x.Type == "BranchID").Value;
        if (model == null)
        {
            model = new();
        }
        model.TruckID = Breakdown.TruckID;
        model.BreakdownID = Breakdown?.BreakdownID ?? null;
        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;
        UserID = user.Identity.Name;

        // Fetch the list of workshops
        Workshops = Iworkshop.Select(null).ToList();
        await signalRService.StartAsync();
        AddJob();
    }

    // Method to search for workshops based on a search string
    private async Task<IEnumerable<WorkshopModel>> SearchWorkshops(string searchString, CancellationToken token)
    {
        if (string.IsNullOrEmpty(searchString))
            return Workshops;

        return await Task.FromResult(Workshops.Where(x => x.WorkshopName.Contains(searchString, StringComparison.InvariantCultureIgnoreCase)));
    }

    // Method to handle changes in the selected workshop
    private void OnWorkshopChanged(WorkshopModel obj)
    {
        SelectedWorkshop = obj;
        if (obj != null)
        {
            model.workshop = obj.WorkshopID.ToString();
        }
        else
        {
            model.workshop = null;
        }
    }

    // Method to set job details in the model
    private void SetJob()
    {
        if (model.Jobs != null && model.Jobs.Count() != 0 && model.Jobs.Any(g => g.RepairJobID != null))
        {
            model.job = string.Join(",", model.Jobs.Select(g => g.RepairJobID));
        }
        else
        {
            model.job = null;
        }
        if (model.Jobs != null && model.Jobs.Count() != 0 && model.Jobs.Any(g => g.RepairJobID == null))
        {
            model.job = null;
        }
        if (model.Jobs != null && model.Jobs.Count() != 0 && model.Jobs.Any(g => g.Mechanics != null && g.Mechanics.Count() != 0))
        {
            model.mechanic = string.Join(",", model.Jobs.Select(g => g.Mechanics.Select(c => c.MechanicID)));
        }
        else
        {
            model.mechanic = null;
        }
        if (model.Jobs != null && model.Jobs.Count() != 0 && model.Jobs.Any(g => g.Mechanics == null || g.Mechanics.Count() == 0))
        {
            model.mechanic = null;
        }
    }

    // Method to cancel the dialog
    private void Cancel()
    {
        MudDialog.Cancel();
    }

    // Method to add a new job to the model
    private void AddJob()
    {
        model.Jobs.Add(new JobInProgressModel() { JobStatus = 1 });
    }

    // Method to delete the last job from the model
    private void DeleteJob()
    {
        model.Jobs.RemoveAt(model.Jobs.Count - 1);
        SetJob();
    }

    // Method to handle form submission
    private async Task OnValidSubmit(EditContext context)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is being submitted!", Severity.Warning);
            return;
        }
        _busy = true;
        if (HasPermissionJobcardServiceEdit)
        {
            // Get the current trip for the truck
            var CurrentTrip = Itrip.Select(Itruck.GetCurrentTrip(Breakdown.TruckID));
            if (CurrentTrip != null && !Itrip.IsClosed(CurrentTrip.TripID))
            {
                // Breakdown = IBreakdownservice.Update(Breakdown);
                model.BreakdownID = Breakdown?.BreakdownID ?? null;                
            }
            var authprov = await auth.GetAuthenticationStateAsync();
            model.UserInfo.UserID = authprov.User.Identity.Name;
            int BranchID = int.Parse(authprov.User.Claims.First(x => x.Type == "BranchID").Value);
            model.BranchID = BranchID;
            try
            {
                // Update the job card and get the new JobcardID
                model.JobcardID = Iservice.Update(model).JobcardID;
                JobcardWorkshopModel Jwm = new()
                    {
                        WorkshopID = SelectedWorkshop.WorkshopID,
                        JobCardID = model.JobcardID,
                        EnteredOn = DateTime.Now,
                        UserInfo = model.UserInfo,
                        Odometer = model.Odometer
                    };
                Ijw.Update(Jwm); // Update the job card workshop
                foreach (var item in model.Jobs)
                {
                    item.JobCardID = model.JobcardID;
                    item.WorkshopID = SelectedWorkshop.WorkshopID;
                    item.UserInfo = model.UserInfo;
                    item.Odometer = model.Odometer;
                    await JipComp.UpdateJob(item); // Update job in progress component
                }
                snackbar.Add("Saved Successfully", Severity.Success);                
                MudDialog.Close(DialogResult.Ok(model));

            }
            catch (Exception ex)
            {
                snackbar.Add(ex.Message, Severity.Warning);
            }
        }
        else
        {
            bool? result = await DialogService.ShowMessageBoxAsync(
                "Permission denied!",  "You don't have any permission to Edit Jobcard.");
        }
        await Task.Delay(200);
        _busy = false;
    }
}
