@inject IRepairWorkService Ijob
@inject IMechanicService Imechanic
@inject IMechanicJobService Imjp
@inject IJobInProgressService Ijip
@inject MudBlazor.ISnackbar snackbar
@inject IDialogService DialogService
@using Views.Pages.Operations.Driver
@using System.Threading;
@inject AuthenticationStateProvider auth

<MudGrid Spacing="4">
    <MudItem xs="12" md="6">
        <MudAutocomplete T="RepairJobModel" Variant="Variant.Outlined" Margin="Margin.Dense" Label="Select Job Group" Value="SelectedGroup" ValueChanged="GroupChanged" ResetValueOnEmptyText="true"
                         SearchFunc="SearchGroup" ToStringFunc="@(e => (e.JobGroup == null || e.JobSubGroup == null) ? null : string.Format("{0} | {1}",e?.JobGroup.Title,e?.JobSubGroup.Title))"></MudAutocomplete>
    </MudItem>
    <MudItem xs="12" md="6">
        <MudAutocomplete T="RepairJobModel" Variant="Variant.Outlined" Margin="Margin.Dense" Label="Select Job" Value="SelectedJob" ValueChanged="JobChanged" ResetValueOnEmptyText="true"
                         SearchFunc="SearchJob" ToStringFunc="@(e => e == null ? null : $"{e.Title}")"></MudAutocomplete>
    </MudItem>
    <MudItem xs="12" md="6">
        <MudSelect T="MechanicModel" MultiSelection="true" Label="Assign Mechanic/s" ToStringFunc="@(p=> p.MechanicName)"
                   SelectedValuesChanged="mechanicChanged" SelectedValues="SelectedMechanics" Variant="Variant.Outlined" Margin="Margin.Dense" AnchorOrigin="Origin.BottomCenter" AdornmentColor="Color.Secondary">
            @foreach (var item in Mechanics)
            {
                <MudSelectItem T="MechanicModel" Value="@item">@item.MechanicName</MudSelectItem>
            }
        </MudSelect>
    </MudItem>
    <MudItem xs="12" md="3">
        <MudCheckBox @bind-Checked="UnderWarranty" T="bool" ValueChanged="@(UnderWarranty => WarrantyCheck(UnderWarranty))">Under Warranty</MudCheckBox>
    </MudItem>
    <MudItem xs="12" md="3">
        @if (UnderWarranty)
        {
            <MudDatePicker @bind-Date="model.WarrantyExpiryDate" Label="Warranty Expiry Date" Variant="Variant.Outlined" Margin="Margin.Dense" DisableToolbar="true" Editable="true" DateFormat="dd/MM/yyyy" Required />
        }
    </MudItem>
    <MudItem xs="12" md="12" Style="padding-top: 0px;">
        <MudTextField T="string" @bind-Text="model.Remarks" Style="margin-bottom: 10px;" Label="Remarks" Variant="Variant.Outlined" Margin="Margin.Dense"></MudTextField>
    </MudItem>
</MudGrid>

@code {

    [Parameter] public JobInProgressModel model { get; set; }
    [Parameter] public WorkshopModel workshop { get; set; }
    [Parameter] public EventCallback<bool> SetJobs { get; set; }
    [Parameter] public bool ClearOnSelect { get; set; } = false;
    private MudAutocomplete<RepairJobModel> _autoComplete { get; set; } = new();
    public RepairJobModel SelectedGroup = new();
    public RepairJobModel SelectedJob = new();
    private WorkshopModel SelectedWorkshop = new();
    private List<RepairJobModel> Grouplist = new();
    private List<RepairJobModel> Joblist = new();
    private List<MechanicModel> Mechanics = new();
    public HashSet<MechanicModel> SelectedMechanics;
    public bool UnderWarranty = false;

    protected override void OnInitialized()
    {
        Grouplist = Ijob.SelectJobGroupAndSub().ToList();
        model.WorkshopID = workshop?.WorkshopID;
        Mechanics = Imechanic.SelectByWorkshop(model?.WorkshopID).ToList();
    }

    private async Task<IEnumerable<RepairJobModel>> SearchGroup(string searchString)
    {
        return await Task.FromResult(Grouplist.Where(x => x.JobSubGroup.Title.Contains(searchString == null ? string.Empty : searchString, StringComparison.InvariantCultureIgnoreCase)
                                                        || x.JobGroup.Title.Contains(searchString == null ? string.Empty : searchString, StringComparison.InvariantCultureIgnoreCase)));
    }

    private async Task<IEnumerable<RepairJobModel>> SearchJob(string searchString)
    {
        return await Task.FromResult(Joblist.Where(x => x.JobSubGroup.Title.Contains(searchString == null ? string.Empty : searchString, StringComparison.InvariantCultureIgnoreCase)));
    }

    private async Task WarrantyCheck(bool a)
    {
        UnderWarranty = a;
        model.WarrantyCheck = UnderWarranty;
    }

    private async Task GroupChanged(RepairJobModel obj)
    {
        @if (obj != null && obj.JobSubGroup.ID != null)
        {
            Joblist = Ijob.SelectJob(null, null, null).ToList();
            Joblist = Joblist.Where(x => (x.JobSubGroup.ID == obj.JobSubGroup.ID)).ToList();
        }
        SelectedGroup = obj;
    }

    private async Task JobChanged(RepairJobModel obj)
    {
        SelectedJob = obj;
        model.RepairJobID = obj?.RepairJobID;
        await SetJobs.InvokeAsync();
    }

    private async Task mechanicChanged(IEnumerable<MechanicModel> obj)
    {
        model.Mechanics.Clear();
        SelectedMechanics = obj.ToHashSet();
        foreach (var item in obj)
        {
            model.Mechanics.Add(new MechanicJobModel
                {
                    AssignedOn = DateTime.Now,
                    MechanicID = item.MechanicID,
                    UserInfo = model.UserInfo,
                    JipID = model.JipID,
                });
        }
        await SetJobs.InvokeAsync();
    }

    public void clearmodel()
    {
        SelectedJob = new RepairJobModel();
        SelectedMechanics = new HashSet<MechanicModel>();
    }

    protected override async Task OnParametersSetAsync()
    {
        if (SelectedWorkshop?.WorkshopID != workshop.WorkshopID)
        {
            Mechanics = Imechanic.SelectByWorkshop(workshop?.WorkshopID).ToList();
            SelectedWorkshop = workshop;
            SelectedMechanics = new();
        }
        await base.OnParametersSetAsync();
    }

    public async Task UpdateJob(JobInProgressModel job)
    {
        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;
        job.UserInfo.UserID = user.Identity.Name;

        DriverFaultModel DriverFault = new();
        bool? result = await DialogService.ShowMessageBox("JOB CAUSE", string.Format("Is the job caused by a Driver Mistake ?"), "YES", "NO");
        if (result == true)
        {
            DriverFault.Driver = new();
            var parameters = new DialogParameters();
            parameters.Add("model", DriverFault);
            parameters.Add("DriverID", DriverFault.Driver.DriverID);
            DialogOptions maxWidth = new DialogOptions() { MaxWidth = MaxWidth.Medium, FullWidth = true };
            var dialog = DialogService.Show<DriverFaultDialog>("Driver Fault", parameters, maxWidth);
            var DriverFaultData = await dialog.Result;
            if (!DriverFaultData.Cancelled)
            {
                DriverFault = DriverFaultData.Data as DriverFaultModel;
                job.DriverFaultID = DriverFault.FaultID;
            }
        }

        try
        {
            var Createdjob = Ijip.Update(job);
            foreach (var item in job.Mechanics)
            {
                item.JipID = Createdjob.JipID;
                item.UserInfo.UserID = job.UserInfo.UserID;
                Imjp.Update(item);
            }
            snackbar.Add("Job Successfull Added.", Severity.Success);
        }
        catch (Exception ex)
        {
            snackbar.Add(ex.Message, Severity.Error);
        }

        UnderWarranty = false;
    }
}