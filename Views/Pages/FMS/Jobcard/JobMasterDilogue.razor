@inject IRepairWorkService Iservice
@inject MudBlazor.ISnackbar snackbar
@attribute [Authorize]
@inject AuthenticationStateProvider auth
@using System.Threading;
@inject IRoleService<RoleModel> Irole
@inject IDialogService DialogService

<DialogForm @ref="@dialogForm" Title="Repair Job Specification" Subtitle="Configure technical parameters, labor standards, and classifications for workshop operations." Icon="@Icons.Material.Filled.Construction" AdminStyle="true" formID="formjobmaster" model="@model" _busy="_busy">
    <FormContent>
        <div class="dialog-content-wrapper fade-in">
            <EditForm id="formjobmaster" Model="@model" OnValidSubmit="OnValidSubmit">
                <DataAnnotationsValidator />
                
                <div class="admin-glass-card pa-6">
                    <div class="d-flex align-center mb-6">
                        <div class="icon-badge primary-badge-soft mr-3">
                            <MudIcon Icon="@Icons.Material.Filled.Engineering" Size="Size.Small" />
                        </div>
                        <span class="admin-section-label mb-0">Technical Parameters</span>
                    </div>

                    <MudGrid Spacing="3">
                        <MudItem xs="12" md="8">
                            <MudTextField @bind-Value="@model.Title" Label="Operation Designation" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.Title)" Class="modern-input" Placeholder="Enter repair job name" />
                        </MudItem>
                        <MudItem xs="12" md="4">
                            <MudTextField @bind-Value="@model.MechanicalHours" Label="Standard Technical Hours" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.MechanicalHours)" Class="modern-input" Adornment="Adornment.End" AdornmentText="HRS" />
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <MudSelect T="RepairJobGroup" Value="@model.JobGroup" ValueChanged="SetGroup" Label="Primary Technical Group" ToStringFunc="@((e) => e?.Title)" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.JobGroup)" Class="modern-input" AdornmentIcon="@Icons.Material.Filled.AccountTree">
                                @foreach (var group in Groups)
                                {
                                    <MudSelectItem Value="group">@group?.Title</MudSelectItem>
                                }
                            </MudSelect>
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <MudSelect T="RepairJobGroup" Value="@model.JobSubGroup" ValueChanged="SetSubGroup" Label="Technical Sub-Classification" ToStringFunc="@((e) => e?.Title)" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.JobSubGroup)" Class="modern-input" AdornmentIcon="@Icons.Material.Filled.FormatListBulleted">
                                @foreach (var group in SubGroups)
                                {
                                    <MudSelectItem Value="group">@group?.Title</MudSelectItem>
                                }
                            </MudSelect>
                        </MudItem>
                    </MudGrid>
                </div>
            </EditForm>
        </div>
    </FormContent>
</DialogForm>

@code {
    private DialogForm dialogForm;

    [Parameter]
    public RepairJobModel model { get; set; }

    [CascadingParameter] IMudDialogInstance MudDialog { get; set; }  
    private bool _busy;

    public bool HasPermissionRepairWorkServiceEdit { get; set; } = false;
    public int RepairWorkDocTypeID = 76;

    private List<RepairJobGroup> Groups = new();
    private List<RepairJobGroup> SubGroups = new();

    // Initialization logic for the component
    protected override async Task OnInitializedAsync()
    {
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionRepairWorkServiceEdit = await Irole.HasClaim(RepairWorkDocTypeID.ToString(), "Edit", ctc.Token);
        Groups = Iservice.SelectGroup().ToList();  // Load the list of repair job groups
    }

    // Method to set the selected job group and load its subgroups
    void SetGroup(RepairJobGroup Group)
    {
        model.JobGroup = Group;
        SubGroups = Iservice.SelectSubGroup(Group.ID).ToList(); // Load the subgroups for the selected job group
    }
    
    // Method to set the selected job subgroup
    void SetSubGroup(RepairJobGroup SubGroup)
    {
        model.JobSubGroup = SubGroup;
    }

    // Method to cancel the dialog and close it
    private void Cancel()
    {
        MudDialog.Cancel();
    }

    // Method to handle form submission when the form is valid
    private async Task OnValidSubmit(EditContext context)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is being submitted!", Severity.Warning);
            return;
        }
        _busy = true;
        var authprov = await auth.GetAuthenticationStateAsync();
        model.UserInfo.UserID = authprov.User.Identity.Name;
        try
        {
            if (HasPermissionRepairWorkServiceEdit)
            {
                model = Iservice.Update(model); // Update the repair job model
                snackbar.Add("Saved Successfully", Severity.Success);                
                MudDialog.Close(model);
                model = new();
            }
            else
            {
                bool? result = await DialogService.ShowMessageBoxAsync(
                    "Permission denied!",
                    "You don't have any permission to Edit RepairWork.");
            }
        }
        catch (Exception ex)
        {
            snackbar.Add(ex.Message, Severity.Warning);
        }
        await Task.Delay(200);
        _busy = false;
    }
}
