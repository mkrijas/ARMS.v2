@inject IRepairJobService Iservice
@inject MudBlazor.ISnackbar snackbar
@attribute [Authorize]
@inject AuthenticationStateProvider auth 

<EditForm Model="@model" OnValidSubmit="OnValidSubmit">
                <DataAnnotationsValidator />
                <ValidationSummary />
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6">Add/Edit RepairJob</MudText>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent>
                    <MudGrid Spacing="4">
                        <MudItem xs="12" md="6">
                            <MudTextField @bind-Value="@model.RepairJobTitle" Label="Job Title" Variant="Variant.Outlined" Margin="Margin.Normal" For="@(() => model.RepairJobTitle)"></MudTextField>
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <MudTextField @bind-Value="@model.MechanicalHours" Label="Mechanical Hours" Variant="Variant.Outlined" Margin="Margin.Normal" For="@(() => model.MechanicalHours)"></MudTextField>
                        </MudItem>
                        <MudItem xs="12" md="12">
                            <MudTextField Lines="4" @bind-Value="@model.Description" Label="Description" Variant="Variant.Outlined" Margin="Margin.Normal" For="@(() => model.Description)"></MudTextField>
                        </MudItem>                       
                    </MudGrid>

                    <MudButton Variant="Variant.Filled" Color="Color.Success" ButtonType="ButtonType.Submit">Save</MudButton>

                </MudCardContent>
            </EditForm>
@code {
    [Parameter]
    public RepairJobModel model { get; set;}
    private List<RepairJobModel> collection = new();    

    private string searchString = string.Empty;

    protected override async Task OnInitializedAsync()
    {
      
        GetAll();
    }

    private void GetAll()
    {
        collection = Iservice.Select(null).ToList();
    }

    private async Task OnValidSubmit(EditContext context)
    {
        var authprov = await auth.GetAuthenticationStateAsync();
        model.UserInfo.UserID = authprov.User.Identity.Name;

        try
        {
            model = Iservice.Update(model);
            snackbar.Add("Saved Successfully", Severity.Success);
            collection.Add(model);

            model = new();
        }
        catch (Exception ex)
        {
            snackbar.Add(ex.Message, Severity.Warning);
        }
    }

}
