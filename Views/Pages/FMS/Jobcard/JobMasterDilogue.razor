@inject IRepairJobService Iservice
@inject MudBlazor.ISnackbar snackbar
@attribute [Authorize]
@inject AuthenticationStateProvider auth

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.Build" Class="mr-3 mb-n1" />
            Add/Edit RepairJob
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudContainer Style="min-height:200px;">
            <EditForm id="formjobmaster" Model="@model" OnValidSubmit="OnValidSubmit">
                <DataAnnotationsValidator />
                <ValidationSummary />
                <MudContainer>
                    <MudGrid Spacing="4">
                        <MudItem xs="12" md="6">
                            <MudTextField @bind-Value="@model.RepairJobTitle" Label="Job Title" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.RepairJobTitle)"></MudTextField>
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <MudTextField @bind-Value="@model.MechanicalHours" Label="Mechanical Hours" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.MechanicalHours)"></MudTextField>
                        </MudItem>
                        <MudItem xs="12" md="12">
                            <MudTextField Lines="4" @bind-Value="@model.Description" Label="Description" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.Description)"></MudTextField>
                        </MudItem>
                    </MudGrid>
                </MudContainer>
            </EditForm>
        </MudContainer>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton form="formjobmaster" Variant="Variant.Filled" Color="Color.Success" ButtonType="ButtonType.Submit">Save</MudButton>
    </DialogActions>
</MudDialog>


@code {
    [Parameter]
    public RepairJobModel model { get; set; }
    private List<RepairJobModel> collection = new();

    [CascadingParameter] MudDialogInstance MudDialog { get; set; }

    private string searchString = string.Empty;

    protected override async Task OnInitializedAsync()
    {

        GetAll();
    }

    private void GetAll()
    {
        collection = Iservice.Select(null).ToList();
    }

    private void Cancel()
    {
        MudDialog.Cancel();
    }
    private async Task OnValidSubmit(EditContext context)
    {
        var authprov = await auth.GetAuthenticationStateAsync();
        model.UserInfo.UserID = authprov.User.Identity.Name;

        try
        {
            model = Iservice.Update(model);
            snackbar.Add("Saved Successfully", Severity.Success);
            collection.Add(model);
            MudDialog.Close(model);
            model = new();
        }
        catch (Exception ex)
        {
            snackbar.Add(ex.Message, Severity.Warning);
        }
    }

}
