@inject IRepairWorkService Iservice
@inject MudBlazor.ISnackbar snackbar
@attribute [Authorize]
@inject AuthenticationStateProvider auth
@using System.Threading;
@inject IRoleService<RoleModel> Irole
@inject IDialogService DialogService

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.Build" Class="mr-3 mb-n1" />
            Repair Job
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudContainer Style="min-height:200px;">
            <EditForm id="formjobmaster" Model="@model" OnValidSubmit="OnValidSubmit">
                <DataAnnotationsValidator />
                <ValidationSummary />
                <MudContainer>
                    <MudGrid Spacing="4">
                        <MudItem xs="12" md="6">
                            <MudTextField @bind-Value="@model.Title" Label="Job Title" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.Title)"></MudTextField>
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <MudTextField @bind-Value="@model.MechanicalHours" Label="Mechanical Hours" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.MechanicalHours)"></MudTextField>
                        </MudItem>
                        <MudItem xs="12" md="12">
                            <MudSelect T = "RepairJobGroup" Value="@model.JobGroup" ValueChanged="SetGroup"  Label="Group" ToStringFunc="@((e) => e?.Title)" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.JobGroup)">
                                @foreach(var group in Groups){
                                   <MudSelectItem Value="group">@group?.Title</MudSelectItem>
                                }
                            </MudSelect>
                        </MudItem>
                        <MudItem xs="12" md="12">
                            <MudSelect T="RepairJobGroup" Value="@model.JobSubGroup" ValueChanged="SetSubGroup" Label="SubGroup" ToStringFunc="@((e) => e?.Title)" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.JobSubGroup)">
                                @foreach (var group in SubGroups)
                                {
                                    <MudSelectItem Value="group">@group?.Title</MudSelectItem>
                                }
                            </MudSelect>
                        </MudItem>
                    </MudGrid>
                </MudContainer>
            </EditForm>
        </MudContainer>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Disabled="@_busy" form="formjobmaster" Variant="Variant.Filled" Color="Color.Success" ButtonType="ButtonType.Submit">Save</MudButton>
    </DialogActions>
</MudDialog>

@code {

    [Parameter]
    public RepairJobModel model { get; set; }

    [CascadingParameter] IMudDialogInstance MudDialog { get; set; }  
    private bool _busy;

    public bool HasPermissionRepairWorkServiceEdit { get; set; } = false;
    public int RepairWorkDocTypeID = 76;

    private List<RepairJobGroup> Groups = new();
    private List<RepairJobGroup> SubGroups = new();

    // Initialization logic for the component
    protected override async Task OnInitializedAsync()
    {
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionRepairWorkServiceEdit = await Irole.HasClaim(RepairWorkDocTypeID.ToString(), "Edit", ctc.Token);
        Groups = Iservice.SelectGroup().ToList();  // Load the list of repair job groups
    }

    // Method to set the selected job group and load its subgroups
    void SetGroup(RepairJobGroup Group)
    {
        model.JobGroup = Group;
        SubGroups = Iservice.SelectSubGroup(Group.ID).ToList(); // Load the subgroups for the selected job group
    }
    
    // Method to set the selected job subgroup
    void SetSubGroup(RepairJobGroup SubGroup)
    {
        model.JobSubGroup = SubGroup;
    }

    // Method to cancel the dialog and close it
    private void Cancel()
    {
        MudDialog.Cancel();
    }

    // Method to handle form submission when the form is valid
    private async Task OnValidSubmit(EditContext context)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is being submitted!", Severity.Warning);
            return;
        }
        _busy = true;
        var authprov = await auth.GetAuthenticationStateAsync();
        model.UserInfo.UserID = authprov.User.Identity.Name;
        try
        {
            if (HasPermissionRepairWorkServiceEdit)
            {
                model = Iservice.Update(model); // Update the repair job model
                snackbar.Add("Saved Successfully", Severity.Success);                
                MudDialog.Close(model);
                model = new();
            }
            else
            {
                bool? result = await DialogService.ShowMessageBox(
                    "Permission denied!",
                    "You don't have any permission to Edit RepairWork.");
            }
        }
        catch (Exception ex)
        {
            snackbar.Add(ex.Message, Severity.Warning);
        }
        await Task.Delay(200);
        _busy = false;
    }
}
