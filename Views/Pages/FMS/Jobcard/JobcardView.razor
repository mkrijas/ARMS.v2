<MudDialog @bind-IsVisible="visibleMechanicSelector" DisableSidePadding="true">
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.People" Class="mr-3" /> Assign Mechanics
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudContainer Style="height: 300px; overflow-y: auto">
            <MudSelect T="MechanicModel" MultiSelection="true" Label="Assign Mechanic/s" ToStringFunc="@(p => p.MechanicName)" @bind-SelectedValues="SelectedMechanics" Variant="Variant.Outlined" Margin="Margin.Dense" AnchorOrigin="Origin.BottomCenter" AdornmentColor="Color.Secondary">
                @foreach (var item in Mechanics)
                {
                    <MudSelectItem T="MechanicModel" Value="@item">@item.MechanicName</MudSelectItem>
                }
            </MudSelect>
            <MudButton Color="Color.Success" OnClick="AddMechanic">Add</MudButton>
        </MudContainer>
    </DialogContent>
</MudDialog>

@code {

    [Parameter]
    public int? TruckID { get; set; }
    [Parameter]
    public int? JobcardID { get; set; }
    private TruckModel SelectedTruck = new();
    private BreakdownModel Breakdown = new();
    private JobcardModel SelectedJobcard = new();
    private WorkshopModel SelectedWorkshop = new();
    private WorkshopModel CurrentWorkshop;
    private List<JobcardWorkshopModel> jwList = new();
    private List<JobInProgressModel> JipList = new();
    private List<InventoryRequestModel> InvRequestList = new();
    private List<ExpenseModel> ExpenseList = new();
    private List<WorkshopModel> Workshops = new();
    public int? BranchID { get; set; }
    private JobInProgressModel NewJob = new JobInProgressModel();
    private List<EventTypeModel> EventTypes;
    string ColorInProgress = Colors.Indigo.Lighten5;
    string ColorFinished = Colors.Green.Lighten5;
    string ColorCancelled = Colors.Gray.Lighten5;
    JobInProgressView jipView;
    bool visibleMechanicSelector = false;
    private List<MechanicModel> Mechanics = new();
    private IEnumerable<MechanicModel> SelectedMechanics;
    private JobInProgressModel SelectedJob = new();
    private RepairJobModel EditedJob = new();
    private RepairJobModel EditedJobGroup = new();
    private bool _busy;
    JobInProgressModel EditingJob { get; set; } = null;
    
    private List<RepairJobModel> Grouplist = new();
    private List<RepairJobModel> Joblist = new();

    public bool HasPermissionInventoryRequestDelete { get; set; } = false;
    public int InventoryRequestDocTypeID = 67;

    public bool HasPermissionJobcardServiceEdit { get; set; } = false;
    public int JobcardDocTypeID = 82;

    InsuranceClaimModel InsModel = new();
    private InsuranceClaimModel SelectedItem;
    private bool dialogVisible = false;

    // Initialization logic
    protected async override Task OnInitializedAsync()
    {
        CancellationTokenSource ctc = new CancellationTokenSource();

        HasPermissionInventoryRequestDelete = await Irole.HasClaim(InventoryRequestDocTypeID.ToString(), "Delete", ctc.Token);
        HasPermissionJobcardServiceEdit = await Irole.HasClaim(JobcardDocTypeID.ToString(), "Edit", ctc.Token);

        var authprov = await auth.GetAuthenticationStateAsync();
        BranchID = int.Parse(authprov.User.Claims.First(x => x.Type == "BranchID").Value);

        // Load workshops and event types
        Workshops = Iworkshop.Select(0).ToList();
        EventTypes = Ievent.GetEventTypes().ToList();

        // Load data based on provided IDs
        if (JobcardID != null)
        {
            GetAll();
        }
        else if (TruckID != null)
        {
            await TruckSelected(Itruck.SelectByID(TruckID));
        }

    }

    // Method to retrieve all relevant data for the selected jobcard
    public void GetAll()
    {
        SelectedTruck = Itruck.SelectByID(TruckID);
        SelectedJobcard = Iservice.SelectByID(JobcardID);
        Breakdown = Ibreakdown.SelectByID(SelectedJobcard?.BreakdownID);
        jwList = Ijw.SelectByJobcard(SelectedJobcard?.JobcardID).ToList();
        setJipList(SelectedJobcard);
        InvRequestList = IInvRequestservice.SelectRequestReleaseByJobCardID(SelectedJobcard?.JobcardID ?? 0).ToList();
        ExpenseList = IInvRequestservice.SelectExpenseByJobCardID(SelectedJobcard?.JobcardID ?? 0).ToList();

        // Load insurance claim data if initiated
        if (Breakdown.IsClaimInitiated == true)
        {
            InsModel = IClaimservice.SelectByBreakdownID(Breakdown.BreakdownID);
            IEnumerable<InsuranceClaimEventStatusModel> statusModel;
            statusModel = IClaimservice.GetEventStatusList(InsModel.InsuranceClaimID);
            InsModel.Events = statusModel.ToList();
        }
    }

    // Method to handle truck selection
    private async Task TruckSelected(TruckModel obj)
    {
        SelectedTruck = obj;
        if (obj != null)
        {
            // Load jobcard and breakdown information based on selected truck
            SelectedJobcard = Iservice.SelectByTruck(SelectedTruck?.TruckID, true).OrderByDescending(s => s.JobcardID).FirstOrDefault();
            Breakdown = Ibreakdown.SelectByID(SelectedJobcard?.BreakdownID);
            jwList = Ijw.SelectByJobcard(SelectedJobcard?.JobcardID).ToList();
            setJipList(SelectedJobcard);
            if (InvRequestList != null)
            {
                InvRequestList.Clear();
            }
            InvRequestList = IInvRequestservice.SelectRequestReleaseByJobCardID(SelectedJobcard?.JobcardID).ToList();

            if (ExpenseList != null)
            {
                ExpenseList.Clear();
            }
            ExpenseList = IInvRequestservice.SelectExpenseByJobCardID(SelectedJobcard?.JobcardID ?? 0).ToList();

            if (jwList.Count(x => x.ExitOn == null) > 0)
            {
                CurrentWorkshop = Workshops.First(y => y.WorkshopID == jwList.First(x => x.ExitOn == null).WorkshopID);
            }
            var authProvider = await auth.GetAuthenticationStateAsync();
            NewJob = new()
                {
                    CreatedOn = DateTime.Now,
                    JobCardID = SelectedJobcard?.JobcardID,
                    WorkshopID = CurrentWorkshop?.WorkshopID,
                    JobStatus = 1,
                    UserInfo = new() { UserID = authProvider.User.Identity.Name }
                };
            if (Breakdown.IsClaimInitiated == true)
            {

                InsModel = IClaimservice.SelectByBreakdownID(Breakdown.BreakdownID);
                IEnumerable<InsuranceClaimEventStatusModel> statusModel;
                statusModel = IClaimservice.GetEventStatusList(InsModel.InsuranceClaimID);
                InsModel.Events = statusModel.ToList();
            }
        }
    }

    // Method to set the list of jobs in progress for a given jobcard
    void setJipList(JobcardModel jobcard)
    {
        JipList = Ijp.SelectByJobcard(jobcard?.JobcardID).ToList();
        foreach (JobInProgressModel item in JipList)
        {
            item.Mechanics = ImechanicJob.SelectByJob(item.JipID).ToList();
        }
    }

    void StartEditingJob(JobInProgressModel item)
    {
        EditingJob = item;
        EditedJob = Ijob.SelectByID(item.RepairJobID);
        EditedJobGroup = EditedJob;
        Grouplist = Ijob.SelectJobGroupAndSub().ToList();
        Joblist = Ijob.SelectJob(null, null, null).ToList();
        Joblist = Joblist.Where(x => (x.JobSubGroup.ID == EditedJob.JobSubGroup.ID)).ToList();
    }

    // Method to search for job groups based on user input
    private async Task<IEnumerable<RepairJobModel>> SearchGroup(string searchString, CancellationToken token)
    {
        return await Task.FromResult(Grouplist.Where(x => x.JobSubGroup.Title.Contains(searchString == null ? string.Empty : searchString, StringComparison.InvariantCultureIgnoreCase)
                                                        || x.JobGroup.Title.Contains(searchString == null ? string.Empty : searchString, StringComparison.InvariantCultureIgnoreCase)));
    }

    // Method to search for jobs based on user input
    private async Task<IEnumerable<RepairJobModel>> SearchJob(string searchString, CancellationToken token)
    {
        return await Task.FromResult(Joblist.Where(x => x.Title.Contains(searchString == null ? string.Empty : searchString, StringComparison.InvariantCultureIgnoreCase)));
    }

    // Method to handle changes in the selected job group
    private async Task GroupChanged(RepairJobModel obj)
    {
        @if (obj != null && obj.JobSubGroup.ID != null)
        {
            // Load jobs that belong to the selected job subgroup
            Joblist = Ijob.SelectJob(null, null, null).ToList();
            Joblist = Joblist.Where(x => (x.JobSubGroup.ID == obj.JobSubGroup.ID)).ToList();
        }
        EditedJobGroup = obj;
        EditedJob = null;
    }

    // Method to handle changes in the selected job
    private async Task JobChanged(RepairJobModel obj)
    {
        EditedJob = obj;
    }

    void SaveEditingJob(JobInProgressModel item)
    {
        item.RepairJobID = EditedJob.RepairJobID;
        Ijp.Update(item);

        snackbar.Add("Jobs Updated.", Severity.Success);
        setJipList(SelectedJobcard);
        EditingJob = null;
    }

    void CancelEditingJob()
    {
        EditingJob = null;
        // if you deep-cloned into NewJob, you can just discard it.
    }

    // Method to handle exiting a workshop
    private async Task ExitWorkshop(JobcardWorkshopModel jwModel)
    {
        if (HasPermissionJobcardServiceEdit)
        {
            if (JipList.Any(x => x.WorkshopID == jwModel.WorkshopID && x.FinishedOn == null))
            {
                snackbar.Add("Unfinished Jobs found!", Severity.Error);
                return;
            }
            jwModel.ExitOn = DateTime.Now;
            var authProvider = await auth.GetAuthenticationStateAsync();
            jwModel.UserInfo.UserID = authProvider.User.Identity.Name;
            try
            {
                Ijw.Update(jwModel);
            }
            catch (Exception a)
            {
                snackbar.Add(a.Message, Severity.Error);
            }
            jwList = Ijw.SelectByJobcard(SelectedJobcard?.JobcardID).ToList();
            CurrentWorkshop = null;
        }
        else
        {
            bool? result = await DialogService.ShowMessageBox(
                "Permission denied!",
                "You don't have any permission to Edit Jobcard.");
        }
    }

    // Method to handle entering a workshop
    private async Task EnterWorkshop()
    {
        if (HasPermissionJobcardServiceEdit)
        {
            if (SelectedWorkshop == null || SelectedWorkshop.WorkshopID == null)
            {
                snackbar.Add("Please select workshop.", Severity.Error);
                return;
            }
            JobcardWorkshopModel jwEnter = new();
            jwEnter.JobCardID = SelectedJobcard.JobcardID;
            jwEnter.WorkshopID = SelectedWorkshop.WorkshopID;
            jwEnter.EnteredOn = DateTime.Now;
            var authProvider = await auth.GetAuthenticationStateAsync();
            jwEnter.UserInfo.UserID = authProvider.User.Identity.Name;
            Ijw.Update(jwEnter);
            jwList = Ijw.SelectByJobcard(SelectedJobcard?.JobcardID).ToList();
            CurrentWorkshop = Workshops.First(y => y.WorkshopID == jwList.First(x => x.ExitOn == null).WorkshopID);
        }
        else
        {
            bool? result = await DialogService.ShowMessageBox(
                "Permission denied!",
                "You don't have any permission to Edit Jobcard.");
        }
    }

    // Method to update a job in progress
    private async Task UpdateJob(JobInProgressModel Ujip, int status)
    {
        if (HasPermissionJobcardServiceEdit)
        {
            var authProvider = await auth.GetAuthenticationStateAsync();
            Ujip.UserInfo.UserID = authProvider.User.Identity.Name;
            Ujip.JobStatus = status;
            Ujip.FinishedOn = DateTime.Now;
            foreach (var item in Ujip.Mechanics)
            {
                await RemoveMechanic(item);
            }
            Ijp.Update(Ujip);
            snackbar.Add("Jobs Updated.", Severity.Success);
            setJipList(SelectedJobcard);
        }
        else
        {
            bool? result = await DialogService.ShowMessageBox(
                "Permission denied!",
                "You don't have any permission to Edit Jobcard.");
        }
    }

    // Method to add a new job in progress
    private async Task AddJob()
    {
        var authProvider = await auth.GetAuthenticationStateAsync();
        NewJob.CreatedOn = DateTime.Now;
        if (NewJob.RepairJobID == null || NewJob.RepairJobID == 0)
        {
            snackbar.Add("Please select job.", Severity.Error);
            return;
        }
        // if (NewJob.Mechanics == null || NewJob.Mechanics.Count() == 0)
        // {
        //     snackbar.Add("Please select mechanic;", Severity.Error);
        //     return;
        // }
        if (NewJob.WarrantyCheck == true && NewJob.WarrantyExpiryDate == null)
        {
            snackbar.Add("Please enter Warranty Expiry Date.", Severity.Error);
            return;
        }
        try
        {
            NewJob.JobCardID = SelectedJobcard.JobcardID;
            jwList = Ijw.SelectByJobcard(SelectedJobcard?.JobcardID).ToList();
            CurrentWorkshop = Workshops.First(y => y.WorkshopID == jwList.First(x => x.ExitOn == null).WorkshopID);
            NewJob.WorkshopID = CurrentWorkshop.WorkshopID;

            await jipView.UpdateJob(NewJob);

            snackbar.Add("Jobs Added.", Severity.Success);
            setJipList(SelectedJobcard);
            NewJob = new();
            jipView.clearmodel();
        }
        catch (Exception ex)
        {
            snackbar.Add(ex.Message, Severity.Error);
        }
    }

    // Method to close the jobcard
    async Task CloseJobcard()
    {
        if (HasPermissionJobcardServiceEdit)
        {
            if (Breakdown.EstimateList.Any(x => x.UserInfo.RecordStatus != 3))
            {
                snackbar.Add("Close pending EstimateList !", Severity.Error);
                return;
            }
            if (Breakdown.EstimateList.Any(x => x.ImagePath == null))
            {
                snackbar.Add("File not uploaded for EstimateList !", Severity.Error);
                return;
            }
            if (InvRequestList.Any(x => x.IsClosed == false))
            {
                snackbar.Add("Close requested inventory items before closing Jobcard!", Severity.Error);
                return;
            }
            if (jwList.Any(x => x.ExitOn == null))
            {
                snackbar.Add("Exit from workshop before closing Jobcard!", Severity.Error);
                return;
            }
            var authProvider = await auth.GetAuthenticationStateAsync();

            try
            {
                Iservice.CloseJobcard(SelectedJobcard.JobcardID, authProvider.User.Identity.Name);
                await TruckSelected(SelectedTruck);

            }
            catch (Exception ex)
            {
                snackbar.Add(ex.Message, Severity.Error);
            }
        }
        else
        {
            bool? result = await DialogService.ShowMessageBox(
                "Permission denied!",
                "You don't have any permission to Edit Jobcard.");
        }
    }

    // Method to remove a mechanic from a job
    async Task RemoveMechanic(MechanicJobModel mj)
    {
        if (HasPermissionJobcardServiceEdit)
        {
            var authProvider = await auth.GetAuthenticationStateAsync();
            string UserID = authProvider.User.Identity.Name;
            ImechanicJob.Remove(mj.MjID, UserID);
            mj.EndedOn = DateTime.Now;
        }
        else
        {
            bool? result = await DialogService.ShowMessageBox(
                "Permission denied!",
                "You don't have any permission to Edit Jobcard.");
        }
    }

    // Method to open the mechanic selector dialog
    void OpenMechanicSelector(JobInProgressModel jipModel)
    {
        SelectedMechanics = new HashSet<MechanicModel>();
        Mechanics = Imechanic.SelectByWorkshop(CurrentWorkshop.WorkshopID).ToList()
            .Where(x => jipModel.Mechanics.Where(z => z.EndedOn == null).All(y => y.MechanicID != x.MechanicID)).ToList();
        SelectedJob = jipModel;
        visibleMechanicSelector = true;
    }

    // Method to add selected mechanics to a job
    async Task AddMechanic()
    {
        if (HasPermissionJobcardServiceEdit)
        {
            var authProvider = await auth.GetAuthenticationStateAsync();
            foreach (var item in SelectedMechanics)
            {
                ImechanicJob.Update(new MechanicJobModel()
                    {
                        AssignedOn = DateTime.Now,
                        JipID = SelectedJob.JipID,
                        MechanicID = item.MechanicID,
                        MechanicName = item.MechanicName,
                        UserInfo = new ArmsModels.SharedModels.UserInfoModel()
                        {
                            UserID = authProvider.User.Identity.Name
                        }
                    });
            }
            setJipList(SelectedJobcard);
            visibleMechanicSelector = false;
        }
        else
        {
            bool? result = await DialogService.ShowMessageBox(
                "Permission denied!",
                "You don't have any permission to Edit Jobcard.");
