@page "/jobcard"
@page "/jobcard/{TruckID:int}"
@page "/jobcard/{TruckID:int}/{JobcardID:int}"
@using ArmsServices.DataServices.Inventory;
@using Pages.FMS.InsuranceClaim
@using Views.Pages.Finance.Transactions.PurchaseAndPayment;
@using Views.Pages.Finance.Transactions;
@using Views.Pages.Inventory.InvRelease;
@using System.Transactions;
@using Views.Pages.Operations
@inject IJobcardService Iservice
@inject ITaxPurchaseService Ipurchaseservice
@inject ISundryPaymentService Isundrypaymentservice
@inject IBreakdownService Ibreakdown
@inject ITruckService Itruck
@inject IAssetService Iasset
@inject IEventService Ievent
@inject ITripService Itrip
@inject IJobcardWorkshopService Ijw
@inject IJobInProgressService Ijp
@inject IRepairWorkService Ijob
@inject IWorkshopService Iworkshop
@inject IMechanicJobService ImechanicJob
@inject IMechanicService Imechanic
@inject IEventService Ievent
@inject IInventoryRequestService IInvRequestservice
@inject IDialogService DialogService
@inject MudBlazor.ISnackbar snackbar
@attribute [Authorize]
@inject AuthenticationStateProvider auth
@using System.Threading;
@inject IRoleService<RoleModel> Irole
@inject IInsuranceClaimService IClaimservice

<style>
    .InActiveText {
        color: lightgray;
    }

    .ActiveText {
        color: cornflowerblue;
    }

    .jobcard-tabs .mud-tab {
        padding: 0 32px !important;
        font-size: 0.95rem;
        letter-spacing: 0.2px;
        min-height: 56px;
    }
    
    .jobcard-tabs .mud-tabs-panels {
        min-height: 450px !important;
    }

    .job-card-premium {
        background: rgba(var(--mud-palette-surface-rgb), 0.7);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border: 1px solid rgba(var(--mud-palette-surface-rgb), 0.3);
        border-radius: 16px;
        box-shadow: 0 8px 32px rgba(0, 0, 0, 0.05);
        transition: transform 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275), box-shadow 0.3s ease;
        position: relative;
        overflow: hidden;
    }
    .job-card-premium:hover {
        transform: translateY(-4px);
        box-shadow: 0 12px 40px rgba(0, 0, 0, 0.08);
    }
    .job-card-premium::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 6px;
        opacity: 0.8;
    }
    .status-finished::before {
        background: linear-gradient(90deg, var(--mud-palette-success) 0%, #81c784 100%);
    }
    .status-unfinished::before {
        background: linear-gradient(90deg, var(--mud-palette-warning) 0%, #ffb74d 100%);
    }

    .remarks-premium {
        background: linear-gradient(to right, rgba(var(--mud-palette-error-rgb), 0.05), transparent);
        border-left: 3px solid var(--mud-palette-error);
        border-radius: 0 8px 8px 0;
        padding: 12px 16px;
    }

    .add-job-card-premium {
        background: rgba(var(--mud-palette-primary-rgb), 0.02);
        border: 2px dashed rgba(var(--mud-palette-primary-rgb), 0.3);
        border-radius: 16px;
        transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    }
    .add-job-card-premium:hover {
        background: rgba(var(--mud-palette-primary-rgb), 0.05);
        border-color: var(--mud-palette-primary);
        transform: translateY(-4px);
        box-shadow: 0 12px 32px rgba(var(--mud-palette-primary-rgb), 0.12);
    }
    .hover-up { transition: transform 0.2s ease; }
    .hover-up:hover { transform: translateY(-2px); }
</style>

<div class="admin-page-container">
    <div class="admin-header-tiered mb-6">
        <div class="d-flex align-center justify-space-between">
            <div>
                <MudText Typo="Typo.h4" Class="admin-title">Fleet Maintenance & Job Cards</MudText>
                <MudText Typo="Typo.body2" Class="admin-subtitle">Monitor vehicle repairs, workshop throughput, and spare part utilization.</MudText>
            </div>
        </div>
    </div>

    <div class="admin-glass-card pa-6 mb-8">
        <div class="d-flex align-center mb-4">
            <div class="icon-badge primary-badge-soft mr-3">
                <MudIcon Icon="@Icons.Material.Filled.LocalShipping" Size="Size.Medium" />
            </div>
            <div>
                <MudText Typo="Typo.h6" Class="fw-700 color-navy">Vehicle Selection</MudText>
                <MudText Typo="Typo.caption" Class="opacity-60">Select a truck to view or manage its maintenance lifecycle.</MudText>
            </div>
        </div>
        <TruckSelector Value="SelectedTruck" ValueChanged="TruckSelected" BranchID="BranchID" Filter="All" Class="modern-selector" />
    </div>

    @if (SelectedJobcard?.JobcardID != null)
    {
        <div class="jobcard-dashboard-wrapper fade-in mb-8">
            <MudCard Class="admin-glass-card border-none overflow-hidden dashboard-card-primary" Elevation="0">
                <div class="card-gradient-overlay"></div>
                
                <MudCardContent Class="pa-8 relative-content">
                    <div class="d-flex align-center flex-wrap gap-8">
                        <div class="dashboard-avatar-container">
                            <div class="dashboard-avatar">
                                <MudIcon Icon="@Icons.Material.Filled.Construction" />
                            </div>
                            <div class="avatar-glow"></div>
                        </div>
                        
                        <div class="flex-grow-1">
                            <div class="d-flex justify-space-between align-start flex-wrap gap-4 mb-4">
                                <div>
                                    <div class="d-flex align-center gap-2 mb-1">
                                        <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Filled" Class="fw-800 px-3">ACTIVE JOB CARD</MudChip>
                                        <MudText Typo="Typo.caption" Class="opacity-70 fw-600">ID: @SelectedJobcard.JobcardID</MudText>
                                    </div>
                                    <MudText Typo="Typo.h3" Class="fw-900 admin-title-large mb-1">@SelectedJobcard.JobcardNumber</MudText>
                                    <div class="d-flex align-center gap-2 opacity-80">
                                        <MudIcon Icon="@Icons.Material.Filled.LocationOn" Size="Size.Small" />
                                        <MudText Typo="Typo.body2" Class="fw-600">@SelectedJobcard.BranchName Operations</MudText>
                                    </div>
                                </div>
                                <div class="d-flex gap-3 mt-2 mt-md-0 align-center flex-wrap justify-end">
                                    @if (!Breakdown.IsClaimInitiated)
                                    {
                                        <MudButton Variant="Variant.Filled" Color="Color.Primary" Class="text-white fw-700 dashboard-action-btn" StartIcon="@Icons.Material.Filled.Security" OnClick="BeginInsuranceClaim">INITIATE CLAIM</MudButton>
                                    }
                                    else
                                    {
                                        <MudButton Variant="Variant.Filled" Color="Color.Primary" Class="text-white fw-700 dashboard-action-btn" StartIcon="@Icons.Material.Filled.VerifiedUser" OnClick="ViewClaimStatus">CLAIM STATUS</MudButton>
                                    }
                                    
                                    <MudMenu ActivationEvent="@MouseEvent.MouseOver" AnchorOrigin="Origin.BottomCenter" TransformOrigin="Origin.TopCenter" Class="text-white-soft">
                                        <ActivatorContent>
                                            <MudButton Variant="Variant.Filled" Color="Color.Secondary" Class="text-white fw-700 dashboard-action-btn" StartIcon="@Icons.Material.Filled.Payment">
                                                FINANCIAL POSTINGS
                                            </MudButton>
                                        </ActivatorContent>
                                        <ChildContent>
                                            <MudMenuItem OnClick="OpenExpenses" Icon="@Icons.Material.Outlined.ShoppingCart">Procurement Purchase</MudMenuItem>
                                            <MudMenuItem OnClick="OpenSundrypayment" Icon="@Icons.Material.Outlined.AccountBalanceWallet">Sundry Payment</MudMenuItem>
                                        </ChildContent>
                                    </MudMenu>

                                    @if (SelectedJobcard?.UserInfo?.RecordStatus == 3)
                                    {
                                        <MudButton StartIcon="@Icons.Material.Filled.BuildCircle" Variant="Variant.Filled" Color="Color.Info" OnClick="(()=>OpenInventoryRequestDialog(new InventoryRequestModel()))" Class="text-white dashboard-action-btn fw-700">REQUEST SPARES</MudButton>
                                        <MudButton StartIcon="@Icons.Material.Filled.CheckCircle" Variant="Variant.Outlined" Color="Color.Info" OnClick="CloseJobcard" Class="dashboard-action-btn-outline fw-700">FINALIZE JOB</MudButton>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="d-flex align-center flex-wrap gap-4 mt-8 pt-6" style="border-top: 1px solid rgba(var(--mud-palette-surface-rgb), 0.2);">
                        <MudPaper Elevation="0" Class="pa-4 d-flex align-center gap-3 flex-grow-1" Style="min-width: 200px; background: rgba(var(--mud-palette-surface-rgb), 0.5); border-radius: 12px;">
                            <div class="icon-badge secondary-badge-soft">
                                <MudIcon Icon="@Icons.Material.Filled.Engineering" Size="Size.Small" />
                            </div>
                            <div>
                                <MudText Typo="Typo.caption" Class="fw-600 opacity-60 d-block">REPAIR JOBS</MudText>
                                <div class="d-flex align-baseline gap-1">
                                    <MudText Typo="Typo.h6" Class="fw-800 color-secondary lh-1">@JipList.Count</MudText>
                                    <MudText Typo="Typo.caption" Class="fw-600 text-muted">(@JipList.Count(x => x.JobStatus == 1).ToString() unfinished)</MudText>
                                </div>
                            </div>
                        </MudPaper>

                        <MudPaper Elevation="0" Class="pa-4 d-flex align-center gap-3 flex-grow-1" Style="min-width: 200px; background: rgba(var(--mud-palette-surface-rgb), 0.5); border-radius: 12px;">
                            <div class="icon-badge warning-badge-soft">
                                <MudIcon Icon="@Icons.Material.Filled.Build" Size="Size.Small" />
                            </div>
                            <div>
                                <MudText Typo="Typo.caption" Class="fw-600 opacity-60 d-block">SPARE REQUESTS</MudText>
                                <div class="d-flex align-baseline gap-1">
                                    <MudText Typo="Typo.h6" Class="fw-800 color-warning lh-1">@InvRequestList.Count</MudText>
                                    <MudText Typo="Typo.caption" Class="fw-600 text-muted">(@InvRequestList.Count(x => x.ReleaseSubDetails?.ItemQty == null).ToString() pending)</MudText>
                                </div>
                            </div>
                        </MudPaper>

                        <MudPaper Elevation="0" Class="pa-4 d-flex align-center gap-3 flex-grow-1" Style="min-width: 200px; background: rgba(var(--mud-palette-surface-rgb), 0.5); border-radius: 12px;">
                            <div class="icon-badge success-badge-soft">
                                <MudIcon Icon="@Icons.Material.Filled.Receipt" Size="Size.Small" />
                            </div>
                            <div>
                                <MudText Typo="Typo.caption" Class="fw-600 opacity-60 d-block">FINANCIAL ENTRIES</MudText>
                                <div class="d-flex align-baseline gap-1">
                                    <MudText Typo="Typo.h6" Class="fw-800 color-success lh-1">@ExpenseList.Count</MudText>
                                    <MudText Typo="Typo.caption" Class="fw-600 text-muted">(@ExpenseList.Count.ToString() total)</MudText>
                                </div>
                            </div>
                        </MudPaper>
                    </div>
                </MudCardContent>
            </MudCard>
        </div>
    }

@if (SelectedJobcard?.JobcardID != null)
{
    <MudTabs Elevation="4" Rounded="true" ApplyEffectsToContainer="true" PanelClass="pa-6" Color="Color.Surface" SliderColor="Color.Primary" MinimumTabWidth="auto" Class="jobcard-tabs" Style="border-radius: 16px; margin-top: 16px;">
        <MudTabPanel Text="WORK ORDER INFO" Icon="@Icons.Material.Filled.CarCrash" BadgeData="@Breakdown.EstimateList.Count.ToString()" BadgeColor="Color.Primary" Style="font-weight: 600;">
            <MudPaper Elevation="0" Class="pa-4">
                <div class="sub-panel ma-0 mb-4 pa-4 overflow-y-auto">
                    <BreakdownComponent MainModel="Breakdown" HideControls=true ReadOnly="@(SelectedJobcard.UserInfo.RecordStatus != 3 ? true : false)"></BreakdownComponent>
                </div>
            </MudPaper>
        </MudTabPanel>
        <MudTabPanel Text="WORKSHOP HISTORY" Icon="@Icons.Material.Filled.HomeRepairService" BadgeData="@jwList.Count.ToString()" BadgeColor="Color.Primary" Style="font-weight: 600;">
            <MudPaper Elevation="0" Class="pa-4" Style="min-height: 400px;">
                <MudTable Items="@jwList" Dense="true" Hover="true" Elevation="0" Class="modern-admin-table mb-4">
                    <HeaderContent>
                        <MudTh><span class="admin-header-text">WORKSHOP NAME</span></MudTh>
                        <MudTh><span class="admin-header-text">ENTRY TIME</span></MudTh>
                        <MudTh><span class="admin-header-text">EXIT TIME</span></MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="Workshop">
                            <div class="d-flex align-center gap-2">
                                <MudIcon Icon="@Icons.Material.Outlined.Storefront" Color="Color.Secondary" Size="Size.Small" />
                                <MudText Typo="Typo.body2" Class="admin-td-primary">@context.WorkshopName</MudText>
                            </div>
                        </MudTd>
                        <MudTd DataLabel="Entry Time">
                            <MudChip T="string" Color="Color.Info" Variant="Variant.Outlined" Size="Size.Small" Class="fw-bold">
                                @context.EnteredOn?.ToString("dd/MM/yy HH:mm tt")
                            </MudChip>
                        </MudTd>
                        <MudTd DataLabel="Exit Time">
                            @if (@context.ExitOn == null)
                            {
                                <MudButton Variant="Variant.Filled" Color="Color.Error" Size="Size.Small" OnClick="@(() => ExitWorkshop(context))" Class="fw-bold px-4" Style="border-radius: 6px;">Mark Exit</MudButton>
                            }
                            else
                            {
                                <MudChip T="string" Color="Color.Default" Variant="Variant.Filled" Size="Size.Small" Class="text-muted fw-bold">
                                    @context.ExitOn?.ToString("dd/MM/yy HH:mm tt")
                                </MudChip>
                            }
                        </MudTd>
                    </RowTemplate>
                </MudTable>

                @if (!jwList.Any(x => x.ExitOn == null) && SelectedJobcard?.UserInfo?.RecordStatus == 3)
                {
                    <MudCard Elevation="0" Class="sub-panel" Style="border: 1px dashed var(--mud-palette-primary);">
                        <MudCardContent Class="d-flex align-center gap-4">
                            <MudIcon Icon="@Icons.Material.Filled.AddBusiness" Color="Color.Primary" Size="Size.Large" />
                            <MudSelect For="@(() => SelectedWorkshop)" T="WorkshopModel" @bind-Value="SelectedWorkshop" Label="Assign New Workshop" Strict="true" Variant="Variant.Outlined" Margin="Margin.Dense" Class="flex-grow-1 bg-white">
                                @foreach (var workshop in Workshops)
                                {
                                    <MudSelectItem Value="workshop">@workshop.WorkshopName</MudSelectItem>
                                }
                            </MudSelect>
                            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="EnterWorkshop" Size="Size.Large" Class="fw-bold px-6" Style="height: 48px; border-radius: 8px;">Enter</MudButton>
                        </MudCardContent>
                    </MudCard>
                }
            </MudPaper>
        </MudTabPanel>
        <MudTabPanel Text="REPAIR JOBS" Icon="@Icons.Material.Filled.Engineering" BadgeData="@JipList.Count.ToString()" BadgeColor="Color.Primary" Style="font-weight: 600;">
            <MudPaper Elevation="0" Class="pa-4">
                <div style="margin-bottom: 8px;">
                    <MudGrid>
                            @foreach (var item in JipList)
                            {
                                <MudItem xs="12" md="6" lg="4">
                                    <div class="job-card-premium @(item.JobStatus == 1 ? "status-unfinished" : "status-finished") d-flex flex-column h-100">
                                        <div class="pa-5 pb-3">
                                            <div class="d-flex justify-space-between align-start mb-3">
                                                <div class="d-flex align-center gap-3">
                                                    <div class="icon-badge @(item.JobStatus == 1 ? "warning-badge-soft" : "success-badge-soft")" style="width: 48px; height: 48px; border-radius: 12px; display: flex; align-items: center; justify-content: center;">
                                                        <MudIcon Icon="@(item.JobStatus == 1 ? Icons.Material.Filled.Build : Icons.Material.Filled.CheckCircle)" Size="Size.Medium" />
                                                    </div>
                                                    <div>
                                                        @if (EditingJob == item)
                                                        {
                                                            <div class="d-flex flex-column gap-2 mb-2" style="min-width: 200px;">
                                                                <MudAutocomplete T="RepairJobModel"
                                                                                 Variant="Variant.Outlined"
                                                                                 Margin="Margin.Dense"
                                                                                 Label="Select Job Group"
                                                                                 Value="EditedJobGroup"
                                                                                 ValueChanged="GroupChanged"
                                                                                 ResetValueOnEmptyText="true"
                                                                                 SearchFunc="@(async (string s, CancellationToken t) => await SearchGroup(s, t))"
                                                                                 ToStringFunc="@(e => (e?.JobGroup == null || e?.JobSubGroup == null)
                                                                                 ? null
                                                                                 : $"{e.JobGroup.Title} | {e.JobSubGroup.Title}")" />
                                                                <MudAutocomplete T="RepairJobModel"
                                                                                 Variant="Variant.Outlined"
                                                                                 Margin="Margin.Dense"
                                                                                 Label="Select Job"
                                                                                 Value="EditedJob"
                                                                                 ValueChanged="JobChanged"
                                                                                 ResetValueOnEmptyText="true"
                                                                                 SearchFunc="@(async (string s, CancellationToken t) => await SearchJob(s, t))"
                                                                                 ToStringFunc="@(e => e == null ? null : e.Title)" />
                                                            </div>
                                                        }
                                                        else
                                                        {
                                                            <MudText Typo="Typo.h6" Class="fw-800" Style="line-height: 1.2;">@item.RepairJobTitle</MudText>
                                                            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="fw-600">@item.CreatedOn?.ToString("MMM dd, yyyy  •  HH:mm")</MudText>
                                                        }
                                                    </div>
                                                </div>
                                                <div>
                                                    @if (EditingJob == item)
                                                    {
                                                        <div class="d-flex gap-1" style="margin-left: -8px;">
                                                            <MudIconButton Icon="@Icons.Material.Filled.Save" Color="Color.Success" OnClick="@(() => SaveEditingJob(item))" Size="Size.Small" Variant="Variant.Outlined" />
                                                            <MudIconButton Icon="@Icons.Material.Filled.Cancel" Color="Color.Error" OnClick="CancelEditingJob" Size="Size.Small" Variant="Variant.Outlined" />
                                                        </div>
                                                    }
                                                    else
                                                    {
                                                        <MudIconButton Icon="@Icons.Material.Outlined.Edit" OnClick="@(() => StartEditingJob(item))" Size="Size.Small" Color="Color.Primary" Class="hover-bg-primary-soft rounded-circle" />
                                                    }
                                                </div>
                                            </div>
                                            @if (item.WarrantyCheck)
                                            {
                                                <div class="d-inline-flex align-center gap-1 mt-1 px-3 py-1 color-success" style="font-size: 0.75rem; border: 1px solid rgba(var(--mud-palette-success-rgb), 0.3); background: rgba(var(--mud-palette-success-rgb), 0.05); border-radius: 20px;">
                                                    <MudIcon Icon="@Icons.Material.Filled.VerifiedUser" Size="Size.Small" />
                                                    <span class="fw-bold">Warranty valid till @item.WarrantyExpiryDate</span>
                                                </div>
                                            }
                                        </div>

                                        <div class="px-5 flex-grow-1">
                                            @if (!string.IsNullOrEmpty(item.Remarks))
                                            {
                                                <div class="remarks-premium mb-4">
                                                    <div class="d-flex align-center gap-2 mb-1">
                                                        <MudIcon Icon="@Icons.Material.Outlined.Info" Size="Size.Small" Color="Color.Error" />
                                                        <MudText Typo="Typo.caption" Color="Color.Error" Class="fw-800" Style="letter-spacing: 0.5px;">REMARKS</MudText>
                                                    </div>
                                                    <MudText Typo="Typo.body2" Class="opacity-80 fw-500" Style="line-height: 1.5;">@item.Remarks</MudText>
                                                </div>
                                            }
                                        </div>
                                        
                                        <div class="px-5 pb-4 mt-auto">
                                            <div class="d-flex align-center justify-space-between pa-3" style="background: rgba(var(--mud-palette-surface-rgb), 0.5); border-radius: 12px; border: 1px solid rgba(var(--mud-palette-surface-rgb), 0.2);">
                                                <div class="d-flex align-center gap-3">
                                                    <div class="icon-badge success-badge-soft" style="width: 36px; height: 36px; border-radius: 50%; display: flex; align-items: center; justify-content: center;">
                                                        <MudIcon Icon="@Icons.Material.Outlined.Payments" Color="Color.Success" Size="Size.Small" />
                                                    </div>
                                                    <MudNumericField HideSpinButtons @bind-Value="item.TotalAmount" Variant="Variant.Text" Margin="Margin.Dense" For="@(() => item.TotalAmount)" Adornment="Adornment.Start" AdornmentText="₹" Style="font-weight: 800; font-size: 1.1rem; max-width: 100px; margin-top: 0;" Underline="false" />
                                                </div>
                                                
                                                <div class="d-flex gap-2 align-center">
                                                    @if (item.JobStatus == 2)
                                                    {
                                                        <MudButton Variant="Variant.Filled" Size="Size.Small" Color="Color.Success" OnClick="@(() => UpdateJob(item, 2))" Class="px-4 fw-800 rounded-pill shadow-sm" Style="height: 36px;">UPDATE</MudButton>
                                                    }
                                                    @if (item.JobStatus == 1 && EditingJob != item)
                                                    {
                                                        <MudTooltip Text="Mark Finished">
                                                            <MudIconButton Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" Size="Size.Medium" OnClick="@(() => UpdateJob(item, 2))" Class="shadow-sm bg-white hover-up" />
                                                        </MudTooltip>
                                                        <MudTooltip Text="Cancel Job">
                                                            <MudIconButton Icon="@Icons.Material.Filled.Cancel" Color="Color.Error" Size="Size.Medium" OnClick="@(() => UpdateJob(item, 0))" Class="shadow-sm bg-white hover-up" />
                                                        </MudTooltip>
                                                    }
                                                </div>
                                            </div>
                                        </div>

                                        <div class="px-5 py-3" style="background: rgba(var(--mud-palette-primary-rgb), 0.02); border-top: 1px solid rgba(var(--mud-palette-surface-rgb), 0.1);">
                                            <div class="d-flex align-center flex-wrap gap-2">
                                                <MudText Typo="Typo.caption" Class="fw-800 text-muted mr-1" Style="letter-spacing: 0.5px;">MECHANICS:</MudText>
                                                @foreach (var mech in item.Mechanics)
                                                {
                                                    bool isActive = mech.EndedOn == null;
                                                    <div class="d-inline-flex align-center gap-1 px-3 py-1 rounded-pill" style="font-size: 0.75rem; font-weight: 700; border: 1px solid @(isActive ? "rgba(var(--mud-palette-primary-rgb), 0.3)" : "rgba(var(--mud-palette-surface-rgb), 0.2)"); background: @(isActive ? "rgba(var(--mud-palette-primary-rgb), 0.05)" : "transparent"); color: @(isActive ? "var(--mud-palette-primary)" : "var(--mud-palette-text-secondary)")">
                                                        <MudIcon Icon="@Icons.Material.Filled.Person" Size="Size.Small" Style="font-size: 14px;" />
                                                        <span>@mech.MechanicName</span>
                                                        @if (isActive)
                                                        {
                                                            <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small" OnClick="@(() => RemoveMechanic(mech))" Style="padding: 2px; margin: -2px -4px -2px 2px; font-size: 12px;" />
                                                        }
                                                    </div>
                                                }
                                                @if (item.JobStatus == 1)
                                                {
                                                    <MudTooltip Text="Assign Mechanic">
                                                        <MudIconButton Size="Size.Small" Icon="@Icons.Material.Filled.Add" OnClick="(() => OpenMechanicSelector(item))" Color="Color.Primary" Variant="Variant.Outlined" Class="ml-auto rounded-circle border-dashed" Style="border-width: 2px;" />
                                                    </MudTooltip>
                                                }
                                            </div>
                                        </div>
                                    </div>
                                </MudItem>
                            }
                            @if (CurrentWorkshop != null && SelectedJobcard?.UserInfo?.RecordStatus == 3)
                            {
                                <MudItem xs="12" md="6" lg="4">
                                    <div class="add-job-card-premium d-flex align-center justify-center cursor-pointer h-100" style="min-height: 250px;" @onclick="OpenAddJobDialog">
                                        <div class="text-center pa-6">
