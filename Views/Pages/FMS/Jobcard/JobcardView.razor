@page "/jobcard"
@page "/jobcard/{TruckID:int}"
@page "/jobcard/{TruckID:int}/{JobcardID:int}"
@using ArmsServices.DataServices.Inventory;
@using Pages.FMS.InsuranceClaim
@using Views.Pages.Finance.Transactions.PurchaseAndPayment;
@using Views.Pages.Finance.Transactions;
@using Views.Pages.Inventory.InvRelease;
@using System.Transactions;
@using Views.Pages.Operations
@inject IJobcardService Iservice
@inject ITaxPurchaseService Ipurchaseservice
@inject ISundryPaymentService Isundrypaymentservice
@inject IBreakdownService Ibreakdown
@inject ITruckService Itruck
@inject IAssetService Iasset
@inject IEventService Ievent
@inject ITripService Itrip
@inject IJobcardWorkshopService Ijw
@inject IJobInProgressService Ijp
@inject IRepairWorkService Ijob
@inject IWorkshopService Iworkshop
@inject IMechanicJobService ImechanicJob
@inject IMechanicService Imechanic
@inject IEventService Ievent
@inject IInventoryRequestService IInvRequestservice
@inject IDialogService DialogService
@inject MudBlazor.ISnackbar snackbar
@attribute [Authorize]
@inject AuthenticationStateProvider auth
@using System.Threading;
@inject IRoleService<RoleModel> Irole
@inject IInsuranceClaimService IClaimservice

<style>
    .InActiveText {
        color: lightgray;
    }

    .ActiveText {
        color: cornflowerblue;
    }
</style>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-4 mb-4">   
    <MudGrid>
        <MudItem xs="12" md="12" Class="mb-4">
            <MudPaper Class="pa-4" Elevation="2">
                <TruckSelector Value="SelectedTruck" ValueChanged="TruckSelected" BranchID="BranchID" Filter="All" />
            </MudPaper>
        </MudItem>
    </MudGrid>

    @if (SelectedJobcard?.JobcardID != null)
    {
        <MudCard Class="mb-5 text-white" Elevation="6" Style="border-radius: 20px; background: linear-gradient(135deg, var(--mud-palette-primary) 0%, #ff8c00 100%); color: white; overflow: hidden; position: relative;">
            <div style="position: absolute; top: -50%; right: -20%; width: 400px; height: 400px; background: radial-gradient(circle, rgba(255,255,255,0.15) 0%, transparent 70%); border-radius: 50%; pointer-events: none;"></div>
            <div style="position: absolute; bottom: -30%; left: -10%; width: 300px; height: 300px; background: radial-gradient(circle, rgba(255,255,255,0.1) 0%, transparent 70%); border-radius: 50%; pointer-events: none;"></div>
            
            <MudCardContent Class="d-flex flex-column gap-6 py-8 px-10" Style="position: relative; z-index: 1;">
                
                <div class="d-flex align-center flex-wrap gap-8">
                    <MudPaper Elevation="8" Style="border-radius: 24px; padding: 4px; background: rgba(255,255,255,0.25); backdrop-filter: blur(10px);">
                        <MudAvatar Style="height: 100px; width: 100px; background: white; color: var(--mud-palette-primary); border-radius: 20px;">
                            <MudIcon Icon="@Icons.Material.Filled.Construction" Style="font-size: 3.5rem;" />
                        </MudAvatar>
                    </MudPaper>
                    
                    <div class="d-flex flex-column flex-grow-1">
                        <div class="d-flex justify-space-between align-start flex-wrap gap-4">
                            <div>
                                <MudText Typo="Typo.h3" Class="fw-bold mb-1" Style="text-shadow: 0px 2px 4px rgba(0,0,0,0.1); letter-spacing: -0.5px;">@SelectedJobcard.JobcardNumber</MudText>
                                <MudText Typo="Typo.h6" Style="opacity: 0.9;" Class="mb-2">
                                    <MudIcon Icon="@Icons.Material.Filled.AccountTree" Size="Size.Small" Class="mr-1"/> @SelectedJobcard.BranchName
                                </MudText>
                            </div>
                            <div class="d-flex gap-3 flex-wrap mt-2 mt-md-0">
                                @if (SelectedJobcard.UserInfo.RecordStatus == 3)
                                {
                                    <MudButton StartIcon="@Icons.Material.Filled.AddChart" Variant="Variant.Filled" Style="background: white; color: var(--mud-palette-primary); border-radius: 8px; font-weight: bold;" OnClick="(()=>OpenInventoryRequestDialog(new InventoryRequestModel()))" Elevation="2">Request Spareparts</MudButton>
                                    <MudButton StartIcon="@Icons.Material.Filled.Close" Variant="Variant.Outlined" Style="border-color: rgba(255,255,255,0.6); color: white; border-radius: 8px; border-width: 2px;" OnClick="CloseJobcard">Close</MudButton>
                                }
                            </div>
                        </div>

                        <div class="d-flex gap-4 flex-wrap align-center mt-3">
                            @if (!Breakdown.IsClaimInitiated)
                            {
                                <MudButton Variant="Variant.Text" Style="color: white; opacity: 0.95; font-weight: 500;" StartIcon="@Icons.Material.Filled.AppRegistration" OnClick="BeginInsuranceClaim">Initiate Claim</MudButton>
                            }
                            else
                            {
                                <MudButton Variant="Variant.Text" Style="color: white; opacity: 0.95; font-weight: 500;" StartIcon="@Icons.Material.Filled.AppRegistration" OnClick="ViewClaimStatus">View Claim Status</MudButton>
                            }

                            <MudMenu ActivationEvent="@MouseEvent.MouseOver" AnchorOrigin="Origin.BottomCenter" TransformOrigin="Origin.TopCenter">
                                <ActivatorContent>
                                    <MudButton Variant="Variant.Text" Style="color: white; opacity: 0.95; font-weight: 500;" StartIcon="@Icons.Material.Filled.AttachMoney">
                                        Post Expenses
                                    </MudButton>
                                </ActivatorContent>
                                <ChildContent>
                                    <MudMenuItem OnClick="OpenExpenses" Icon="@Icons.Material.Outlined.ShoppingCart">Purchase</MudMenuItem>
                                    <MudMenuItem OnClick="OpenSundrypayment" Icon="@Icons.Material.Outlined.Payment">Sundry Payment</MudMenuItem>
                                </ChildContent>
                            </MudMenu>
                        </div>
                    </div>
                </div>

                <MudDivider Style="background-color: rgba(255,255,255,0.25);" Class="my-4" />

                <div class="d-flex gap-10 flex-wrap">
                    <div class="d-flex flex-column">
                        <MudText Typo="Typo.caption" Style="opacity: 0.85; font-weight: 700; letter-spacing: 1px; text-transform: uppercase;">Estimates</MudText>
                        <MudText Typo="Typo.h5" Class="fw-bold" Style="text-shadow: 0px 1px 2px rgba(0,0,0,0.1);">@Breakdown.EstimateList.Count</MudText>
                    </div>
                    <div class="d-flex flex-column" style="border-left: 1px solid rgba(255,255,255,0.25); padding-left: 24px;">
                        <MudText Typo="Typo.caption" Style="opacity: 0.85; font-weight: 700; letter-spacing: 1px; text-transform: uppercase;">Active Jobs</MudText>
                        <MudText Typo="Typo.h5" Class="fw-bold" Style="text-shadow: 0px 1px 2px rgba(0,0,0,0.1);">@JipList.Count</MudText>
                    </div>
                    <div class="d-flex flex-column" style="border-left: 1px solid rgba(255,255,255,0.25); padding-left: 24px;">
                        <MudText Typo="Typo.caption" Style="opacity: 0.85; font-weight: 700; letter-spacing: 1px; text-transform: uppercase;">Expenses</MudText>
                        <MudText Typo="Typo.h5" Class="fw-bold" Style="text-shadow: 0px 1px 2px rgba(0,0,0,0.1);">@ExpenseList.Count</MudText>
                    </div>
                </div>
            </MudCardContent>
        </MudCard>
    }

@if (SelectedJobcard?.JobcardID != null)
{
    <MudTabs Elevation="4" Rounded="true" ApplyEffectsToContainer="true" PanelClass="pa-6" Color="Color.Surface" SliderColor="Color.Primary" MinimumTabWidth="160px" Style="border-radius: 16px; margin-top: 16px;">
        <MudTabPanel Text="BREAKDOWN INFO" Icon="@Icons.Material.Filled.CarCrash" BadgeData="@Breakdown.EstimateList.Count.ToString()" BadgeColor="Color.Primary" Style="font-weight: 600;">
            <MudPaper Elevation="0" Class="pa-4">
                <div style="margin-bottom: 8px; overflow-y: auto; border-radius: 12px; padding: 16px; background-color: var(--mud-palette-background-grey);">
                    <BreakdownComponent MainModel="Breakdown" HideControls=true ReadOnly="@(SelectedJobcard.UserInfo.RecordStatus != 3 ? true : false)"></BreakdownComponent>
                </div>
            </MudPaper>
        </MudTabPanel>
        <MudTabPanel Text="WORKSHOP HISTORY" Icon="@Icons.Material.Filled.HomeRepairService" BadgeData="@jwList.Count.ToString()" BadgeColor="Color.Primary" Style="font-weight: 600;">
            <MudPaper Elevation="0" Class="pa-4">
                <MudTable Items="@jwList" Dense="false" Hover="true" Elevation="2" Style="border-radius: 12px; overflow: hidden;" Class="mb-4" Outlined="true">
                    <HeaderContent>
                        <MudTh><MudText Typo="Typo.subtitle2" Class="fw-bold">WORKSHOP NAME</MudText></MudTh>
                        <MudTh><MudText Typo="Typo.subtitle2" Class="fw-bold">ENTRY TIME</MudText></MudTh>
                        <MudTh><MudText Typo="Typo.subtitle2" Class="fw-bold">EXIT TIME</MudText></MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="Workshop">
                            <div class="d-flex align-center gap-2">
                                <MudIcon Icon="@Icons.Material.Outlined.Storefront" Color="Color.Secondary" Size="Size.Small" />
                                <MudText Typo="Typo.body2" Class="fw-bold">@context.WorkshopName</MudText>
                            </div>
                        </MudTd>
                        <MudTd DataLabel="Entry Time">
                            <MudChip T="string" Color="Color.Info" Variant="Variant.Outlined" Size="Size.Small" Class="fw-bold">
                                @context.EnteredOn?.ToString("dd/MM/yy HH:mm tt")
                            </MudChip>
                        </MudTd>
                        <MudTd DataLabel="Exit Time">
                            @if (@context.ExitOn == null)
                            {
                                <MudButton Variant="Variant.Filled" Color="Color.Error" Size="Size.Small" OnClick="@(() => ExitWorkshop(context))" Class="fw-bold px-4" Style="border-radius: 6px;">Mark Exit</MudButton>
                            }
                            else
                            {
                                <MudChip T="string" Color="Color.Default" Variant="Variant.Filled" Size="Size.Small" Class="text-muted fw-bold">
                                    @context.ExitOn?.ToString("dd/MM/yy HH:mm tt")
                                </MudChip>
                            }
                        </MudTd>
                    </RowTemplate>
                </MudTable>

                @if (!jwList.Any(x => x.ExitOn == null) && SelectedJobcard?.UserInfo.RecordStatus == 3)
                {
                    <MudCard Elevation="2" Style="border-radius: 12px; background-color: var(--mud-palette-background-grey); border: 1px dashed var(--mud-palette-primary);">
                        <MudCardContent Class="d-flex align-center gap-4">
                            <MudIcon Icon="@Icons.Material.Filled.AddBusiness" Color="Color.Primary" Size="Size.Large" />
                            <MudSelect T="WorkshopModel" @bind-Value="SelectedWorkshop" Label="Assign New Workshop" Strict="true" Variant="Variant.Outlined" Margin="Margin.Dense" Class="flex-grow-1 bg-white">
                                @foreach (var workshop in Workshops)
                                {
                                    <MudSelectItem Value="workshop">@workshop.WorkshopName</MudSelectItem>
                                }
                            </MudSelect>
                            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="EnterWorkshop" Size="Size.Large" Class="fw-bold px-6" Style="height: 48px; border-radius: 8px;">Enter</MudButton>
                        </MudCardContent>
                    </MudCard>
                }
            </MudPaper>
        </MudTabPanel>
        <MudTabPanel Text="REPAIR JOBS" Icon="@Icons.Material.Filled.Engineering" BadgeData="@JipList.Count.ToString()" BadgeColor="Color.Primary" Style="font-weight: 600;">
            <MudPaper Elevation="0" Class="pa-4">
                <div style="margin-bottom: 8px;">
                    <MudGrid>
                            @foreach (var item in JipList)
                            {
                                <MudItem xs="12" md="6" lg="4">
                                    <MudCard Elevation="3" Style="border-radius: 12px; height: 100%; display: flex; flex-direction: column; overflow: visible;">
                                        <MudCardHeader Style="padding-bottom: 0;">
                                            <CardHeaderContent>
                                                @if (EditingJob == item)
                                                {
                                                    <div class="d-flex flex-column gap-2 mb-2">
                                                        <MudAutocomplete T="RepairJobModel"
                                                                         Variant="Variant.Outlined"
                                                                         Margin="Margin.Dense"
                                                                         Label="Select Job Group"
                                                                         Value="EditedJobGroup"
                                                                         ValueChanged="GroupChanged"
                                                                         ResetValueOnEmptyText="true"
                                                                         SearchFunc="@(async (string s, CancellationToken t) => await SearchGroup(s, t))"
                                                                         ToStringFunc="@(e => (e?.JobGroup == null || e?.JobSubGroup == null)
                                                                         ? null
                                                                         : $"{e.JobGroup.Title} | {e.JobSubGroup.Title}")" />
                                                        <MudAutocomplete T="RepairJobModel"
                                                                         Variant="Variant.Outlined"
                                                                         Margin="Margin.Dense"
                                                                         Label="Select Job"
                                                                         Value="EditedJob"
                                                                         ValueChanged="JobChanged"
                                                                         ResetValueOnEmptyText="true"
                                                                         SearchFunc="@(async (string s, CancellationToken t) => await SearchJob(s, t))"
                                                                         ToStringFunc="@(e => e == null ? null : e.Title)" />
                                                    </div>
                                                }
                                                else
                                                {
                                                    <MudText Typo="Typo.h6" Class="fw-bold">@item.RepairJobTitle</MudText>
                                                }
                                            </CardHeaderContent>
                                            <CardHeaderActions>
                                                @if (EditingJob == item)
                                                {
                                                    <MudIconButton Icon="@Icons.Material.Filled.Save" Color="Color.Success" OnClick="@(() => SaveEditingJob(item))" Title="Save" Size="Size.Small" />
                                                    <MudIconButton Icon="@Icons.Material.Filled.Cancel" Color="Color.Error" OnClick="CancelEditingJob" Title="Cancel" Size="Size.Small" />
                                                }
                                                else
                                                {
                                                    <MudIconButton Icon="@Icons.Material.Filled.Edit" OnClick="@(() => StartEditingJob(item))" Title="Edit" Size="Size.Small" />
                                                }
                                            </CardHeaderActions>
                                        </MudCardHeader>
                                        
                                        <MudCardContent Class="flex-grow-1" Style="padding-top: 8px;">
                                            <div class="d-flex justify-space-between align-center mb-4">
                                                <MudChip T="string" Size="Size.Small" Color="@(item.JobStatus == 1 ? Color.Warning : Color.Success)" Variant="Variant.Filled" Class="fw-bold">
                                                    @item.JobStatusText
                                                </MudChip>
                                                <MudText Typo="Typo.caption" Color="Color.Secondary">@item.CreatedOn?.ToString("MMM dd, yyyy HH:mm")</MudText>
                                            </div>

                                            @if (item.WarrantyCheck)
                                            {
                                                <MudAlert Severity="Severity.Success" Variant="Variant.Outlined" Class="mb-3 py-1 px-2" Style="font-size: 0.8rem;">
                                                    Under Warranty till @item.WarrantyExpiryDate
                                                </MudAlert>
                                            }

                                            @if (!string.IsNullOrEmpty(item.Remarks))
                                            {
                                                <div class="mb-3 p-2 rounded" style="background-color: var(--mud-palette-background-grey);">
                                                    <MudText Typo="Typo.caption" Color="Color.Error" Class="fw-bold d-block">REMARKS:</MudText>
                                                    <MudText Typo="Typo.body2">@item.Remarks</MudText>
                                                </div>
                                            }
                                            
                                            <div class="d-flex align-center justify-space-between mt-auto pt-3 border-t">
                                                <div class="d-flex align-center flex-grow-1">
                                                    <MudNumericField HideSpinButtons @bind-Value="item.TotalAmount" Label="Amount" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => item.TotalAmount)" Class="mr-2" />
                                                    @if (item.JobStatus == 2)
                                                    {
                                                        <MudButton Variant="Variant.Filled" Size="Size.Small" Color="Color.Success" OnClick="@(() => UpdateJob(item, 2))" Class="px-3" Style="height: fit-content; align-self: center;">Update</MudButton>
                                                    }
                                                </div>
                                                
                                                @if (item.JobStatus == 1 && EditingJob != item)
                                                {
                                                    <div class="d-flex gap-1 ml-2">
                                                        <MudTooltip Text="Finished">
                                                            <MudIconButton Icon="@Icons.Material.Filled.Check" Color="Color.Success" Variant="Variant.Outlined" Size="Size.Small" OnClick="@(() => UpdateJob(item, 2))" />
                                                        </MudTooltip>
                                                        <MudTooltip Text="Cancel">
                                                            <MudIconButton Icon="@Icons.Material.Filled.Cancel" Color="Color.Error" Variant="Variant.Outlined" Size="Size.Small" OnClick="@(() => UpdateJob(item, 0))" />
                                                        </MudTooltip>
                                                    </div>
                                                }
                                            </div>
                                        </MudCardContent>
                                        
                                        <MudDivider />
                                        
                                        <MudCardActions Class="px-4 py-2 flex-wrap gap-2" Style="background-color: rgba(var(--mud-palette-surface-rgb), 0.5);">
                                            <MudText Typo="Typo.caption" Class="fw-bold mr-2">Mechanics:</MudText>
                                            @foreach (var mech in item.Mechanics)
                                            {
                                                bool isActive = mech.EndedOn == null;
                                                <MudChip T="string" Size="Size.Small" Variant="@(isActive ? Variant.Filled : Variant.Outlined)" Color="@(isActive ? Color.Primary : Color.Default)" OnClose="@(isActive ? (() => RemoveMechanic(mech)) : null)">
                                                    @mech.MechanicName
                                                </MudChip>
                                            }
                                            @if (item.JobStatus == 1)
                                            {
                                                <MudTooltip Text="Assign Mechanic">
                                                    <MudIconButton Size="Size.Small" Icon="@Icons.Material.Filled.Add" OnClick="(() => OpenMechanicSelector(item))" Color="Color.Primary" Variant="Variant.Outlined" Class="ml-auto" />
                                                </MudTooltip>
                                            }
                                        </MudCardActions>
                                    </MudCard>
                                </MudItem>
                            }
                        </MudGrid>
                        @if (CurrentWorkshop != null && SelectedJobcard.UserInfo.RecordStatus == 3)
                        {
                            <MudCard Elevation="2" Class="mt-6" Style="border-radius: 12px; border: 1px dashed var(--mud-palette-primary); background-color: rgba(var(--mud-palette-primary-rgb), 0.02);">
                                <MudCardContent Class="d-flex align-end flex-wrap gap-4">
                                    <div class="flex-grow-1">
                                        <MudText Typo="Typo.subtitle2" Color="Color.Primary" Class="mb-3 fw-bold"><MudIcon Icon="@Icons.Material.Filled.AddAlert" Size="Size.Small" Class="mr-1" /> Add New Job in @CurrentWorkshop.WorkshopName:</MudText>
                                        <JobInProgressView workshop="CurrentWorkshop" model="NewJob" @ref="jipView"></JobInProgressView>
                                    </div>
                                    <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" OnClick="AddJob" Size="Size.Large" Class="fw-bold px-6" Style="border-radius: 8px; height: 48px; margin-bottom: 4px;">Create Job</MudButton>
                                </MudCardContent>
                            </MudCard>
                        }
                </div>
            </MudPaper>
        </MudTabPanel>
        <MudTabPanel Text="SPARE PARTS" Icon="@Icons.Material.Filled.Build" BadgeData="@InvRequestList.Count.ToString()" BadgeColor="Color.Primary" Style="font-weight: 600;">
            <MudPaper Elevation="0" Class="pa-4">
                <MudItem xs="12" md="12">
                    @if (InvRequestList.Count != 0)
                    {
                        <div style="margin-bottom: 8px; overflow-y: auto;">
                            <MudTable Items="@InvRequestList" Dense="false" Hover="true" Striped="true" Elevation="2" Style="border-radius: 12px; overflow: hidden;" Outlined="true">
                                    <HeaderContent>
                                        <MudTh><MudTableSortLabel SortBy="new Func<InventoryRequestModel, object>(x=> x.ReleaseSubDetails?.ItemDescription)" InitialDirection="SortDirection.Ascending">Item</MudTableSortLabel></MudTh>
                                        <MudTh><MudTableSortLabel SortBy="new Func<InventoryRequestModel, object>(x=> x.RequestNumber)" InitialDirection="SortDirection.Ascending">Document Date / Request Number</MudTableSortLabel></MudTh>
                                        <MudTh><MudTableSortLabel SortBy="new Func<InventoryRequestModel, object>(x=> x.ReleaseSubDetails?.RequestQty)" InitialDirection="SortDirection.Ascending">Request Qty</MudTableSortLabel></MudTh>
                                        <MudTh><MudTableSortLabel SortBy="new Func<InventoryRequestModel, object>(x=> x.ReleaseSubDetails?.ItemQty)" InitialDirection="SortDirection.Ascending">Release Qty</MudTableSortLabel></MudTh>
                                        <MudTh RowSpan="2">Actions</MudTh>
                                        <MudTh></MudTh>
                                    </HeaderContent>
                                    <RowTemplate>
                                        <MudTd DataLabel="Item">@context.ReleaseSubDetails?.ItemGroupDescription - @context.ReleaseSubDetails?.ItemDescription</MudTd>
                                        <MudTd DataLabel="Document Date / Request Number">@(context.RequestDate?.ToShortDateString()) / @(context.RequestNumber)</MudTd>
                                        <MudTd DataLabel="Request Qty">@context.ReleaseSubDetails?.RequestQty</MudTd>
                                        <MudTd DataLabel="Release Qty">@context.ReleaseSubDetails?.ItemQty</MudTd>
                                        <MudTd DataLabel="">
                                            @if (!context.IsClosed && @context.ReleaseSubDetails?.ItemQty != null)
                                            {
                                                <MudTooltip Text="Close Request">
                                                    <MudFab @onclick="@(()=> OpenInventoryReleaseClosedDialog(context))" Color="Color.Warning" StartIcon="@Icons.Material.Filled.Verified" Size="Size.Small" />
                                                </MudTooltip>
                                            }
                                        </MudTd>
                                        <MudTd DataLabel="">
                                            @if (@context.ReleaseSubDetails?.ItemQty == null)
                                            {
                                                <MudTooltip Text="Edit">
                                                    <MudFab @onclick="@(()=> OpenInventoryRequestDialog(context))" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Edit" Size="Size.Small" />
                                                </MudTooltip>
                                                <MudTooltip Text="Delete">
                                                    <MudFab @onclick="@(()=> DeleteInventoryRequest(context))" Color="Color.Error" title="Delete" StartIcon="@Icons.Material.Filled.Delete" Size="Size.Small" />
                                                </MudTooltip>
                                            }
                                        </MudTd>
                                    </RowTemplate>
                                    <PagerContent>
                                        <MudTablePager PageSizeOptions="new int[] { 10, 20, 50, 100 }" />
                                    </PagerContent>
                                </MudTable>
                            </div>
                        }
                </MudItem>
            </MudPaper>
        </MudTabPanel>
        <MudTabPanel Text="FINANCIALS" Icon="@Icons.Material.Filled.ReceiptLong" BadgeData="@ExpenseList.Count.ToString()" BadgeColor="Color.Primary" Style="font-weight: 600;">
            <MudPaper Elevation="0" Class="pa-4">
                <MudItem xs="12" md="12">
                    @if (ExpenseList.Count != 0)
                    {
                        <div style="margin-bottom: 8px; overflow-y: auto;">
                            <MudTable Items="@ExpenseList" Dense="false" Hover="true" Striped="true" Elevation="2" Style="border-radius: 12px; overflow: hidden;" Outlined="true">
                                    <HeaderContent>
                                        <MudTh><MudTableSortLabel SortBy="new Func<ExpenseModel, object>(x=> x.DocNumber)" InitialDirection="SortDirection.Ascending">Doc Number</MudTableSortLabel></MudTh>
                                        <MudTh><MudTableSortLabel SortBy="new Func<ExpenseModel, object>(x=> x.DocDate)" InitialDirection="SortDirection.Ascending">Document Date</MudTableSortLabel></MudTh>
                                        <MudTh><MudTableSortLabel SortBy="new Func<ExpenseModel, object>(x=> x.BranchName)" InitialDirection="SortDirection.Ascending">Branch</MudTableSortLabel></MudTh>
                                        <MudTh><MudTableSortLabel SortBy="new Func<ExpenseModel, object>(x=> x.RegName)" InitialDirection="SortDirection.Ascending">Vendor</MudTableSortLabel></MudTh>
                                        <MudTh><MudTableSortLabel SortBy="new Func<ExpenseModel, object>(x=> x.InvoiceNo)" InitialDirection="SortDirection.Ascending">Invoice No</MudTableSortLabel></MudTh>
                                        <MudTh><MudTableSortLabel SortBy="new Func<ExpenseModel, object>(x=> x.InvoiceDate)" InitialDirection="SortDirection.Ascending">Invoice Date</MudTableSortLabel></MudTh>
                                        <MudTh><MudTableSortLabel SortBy="new Func<ExpenseModel, object>(x=> x.BillReference)" InitialDirection="SortDirection.Ascending">Bill Ref</MudTableSortLabel></MudTh>
                                        <MudTh><MudTableSortLabel SortBy="new Func<ExpenseModel, object>(x=> x.Narration)" InitialDirection="SortDirection.Ascending">Narration</MudTableSortLabel></MudTh>
                                        <MudTh><MudTableSortLabel SortBy="new Func<ExpenseModel, object>(x=> x.UserID)" InitialDirection="SortDirection.Ascending">User</MudTableSortLabel></MudTh>
                                        <MudTh><MudTableSortLabel SortBy="new Func<ExpenseModel, object>(x=> x.AccountName)" InitialDirection="SortDirection.Ascending">Account Name</MudTableSortLabel></MudTh>
                                        <MudTh><MudTableSortLabel SortBy="new Func<ExpenseModel, object>(x=> x.CostCenter)" InitialDirection="SortDirection.Ascending">Cost Center</MudTableSortLabel></MudTh>
                                        <MudTh><MudTableSortLabel SortBy="new Func<ExpenseModel, object>(x=> x.Dimension)" InitialDirection="SortDirection.Ascending">Dimension</MudTableSortLabel></MudTh>
