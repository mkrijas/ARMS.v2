@page "/jobcard"
@page "/jobcard/{TruckID:int}"
@page "/jobcard/{TruckID:int}/{JobcardID:int}"
@using ArmsServices.DataServices.Inventory;
@using Pages.FMS.InsuranceClaim
@using Views.Pages.Finance.Transactions.PurchaseAndPayment;
@using Views.Pages.Finance.Transactions;
@using Views.Pages.Inventory.InvRelease;
@using System.Transactions;
@using Views.Pages.Operations
@inject IJobcardService Iservice
@inject ITaxPurchaseService Ipurchaseservice
@inject ISundryPaymentService Isundrypaymentservice
@inject IBreakdownService Ibreakdown
@inject ITruckService Itruck
@inject IAssetService Iasset
@inject IEventService Ievent
@inject ITripService Itrip
@inject IJobcardWorkshopService Ijw
@inject IJobInProgressService Ijp
@inject IRepairWorkService Ijob
@inject IWorkshopService Iworkshop
@inject IMechanicJobService ImechanicJob
@inject IMechanicService Imechanic
@inject IEventService Ievent
@inject IInventoryRequestService IInvRequestservice
@inject IDialogService DialogService
@inject MudBlazor.ISnackbar snackbar
@attribute [Authorize]
@inject AuthenticationStateProvider auth
@using System.Threading;
@inject IRoleService<RoleModel> Irole
@inject IInsuranceClaimService IClaimservice

<style>
    .InActiveText {
        color: lightgray;
    }

    .ActiveText {
        color: cornflowerblue;
    }
</style>

<div class="admin-page-container">
    <div class="admin-header-tiered mb-6">
        <div class="d-flex align-center justify-space-between">
            <div>
                <MudText Typo="Typo.h4" Class="admin-title">Fleet Maintenance & Job Cards</MudText>
                <MudText Typo="Typo.body2" Class="admin-subtitle">Monitor vehicle repairs, workshop throughput, and spare part utilization.</MudText>
            </div>
        </div>
    </div>

    <div class="admin-glass-card pa-6 mb-8">
        <div class="d-flex align-center mb-4">
            <div class="icon-badge primary-badge-soft mr-3">
                <MudIcon Icon="@Icons.Material.Filled.LocalShipping" Size="Size.Medium" />
            </div>
            <div>
                <MudText Typo="Typo.h6" Class="fw-700 color-navy">Vehicle Selection</MudText>
                <MudText Typo="Typo.caption" Class="opacity-60">Select a truck to view or manage its maintenance lifecycle.</MudText>
            </div>
        </div>
        <TruckSelector Value="SelectedTruck" ValueChanged="TruckSelected" BranchID="BranchID" Filter="All" Class="modern-selector" />
    </div>

    @if (SelectedJobcard?.JobcardID != null)
    {
        <div class="jobcard-dashboard-wrapper fade-in mb-8">
            <MudCard Class="admin-glass-card border-none overflow-hidden dashboard-card-primary" Elevation="0">
                <div class="card-gradient-overlay"></div>
                
                <MudCardContent Class="pa-8 relative-content">
                    <div class="d-flex align-center flex-wrap gap-8">
                        <div class="dashboard-avatar-container">
                            <div class="dashboard-avatar">
                                <MudIcon Icon="@Icons.Material.Filled.Construction" />
                            </div>
                            <div class="avatar-glow"></div>
                        </div>
                        
                        <div class="flex-grow-1">
                            <div class="d-flex justify-space-between align-start flex-wrap gap-4 mb-4">
                                <div>
                                    <div class="d-flex align-center gap-2 mb-1">
                                        <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Filled" Class="fw-800 px-3">ACTIVE JOB CARD</MudChip>
                                        <MudText Typo="Typo.caption" Class="opacity-70 fw-600">ID: @SelectedJobcard.JobcardID</MudText>
                                    </div>
                                    <MudText Typo="Typo.h3" Class="fw-900 admin-title-large mb-1">@SelectedJobcard.JobcardNumber</MudText>
                                    <div class="d-flex align-center gap-2 opacity-80">
                                        <MudIcon Icon="@Icons.Material.Filled.LocationOn" Size="Size.Small" />
                                        <MudText Typo="Typo.body2" Class="fw-600">@SelectedJobcard.BranchName Operations</MudText>
                                    </div>
                                </div>
                                <div class="d-flex gap-3 mt-2 mt-md-0">
                                    @if (SelectedJobcard.UserInfo.RecordStatus == 3)
                                    {
                                        <MudButton StartIcon="@Icons.Material.Filled.BuildCircle" Variant="Variant.Filled" Color="Color.Surface" OnClick="(()=>OpenInventoryRequestDialog(new InventoryRequestModel()))" Class="dashboard-action-btn fw-700">REQUEST SPARES</MudButton>
                                        <MudButton StartIcon="@Icons.Material.Filled.CheckCircle" Variant="Variant.Outlined" Color="Color.Surface" OnClick="CloseJobcard" Class="dashboard-action-btn-outline fw-700">FINALIZE JOB</MudButton>
                                    }
                                </div>
                            </div>

                            <div class="d-flex gap-4 flex-wrap align-center bg-white-translucent pa-2 rounded-lg border-subtle-white">
                                @if (!Breakdown.IsClaimInitiated)
                                {
                                    <MudButton Variant="Variant.Text" Class="text-white-soft fw-600" StartIcon="@Icons.Material.Filled.Security" OnClick="BeginInsuranceClaim">Initiate Claim</MudButton>
                                }
                                else
                                {
                                    <MudButton Variant="Variant.Text" Class="text-white-soft fw-600" StartIcon="@Icons.Material.Filled.VerifiedUser" OnClick="ViewClaimStatus">Claim Status</MudButton>
                                }

                                <div class="v-divider"></div>

                                <MudMenu ActivationEvent="@MouseEvent.MouseOver" AnchorOrigin="Origin.BottomCenter" TransformOrigin="Origin.TopCenter" Class="text-white-soft">
                                    <ActivatorContent>
                                        <MudButton Variant="Variant.Text" Class="text-white-soft fw-600" StartIcon="@Icons.Material.Filled.Payment">
                                            Financial Postings
                                        </MudButton>
                                    </ActivatorContent>
                                    <ChildContent>
                                        <MudMenuItem OnClick="OpenExpenses" Icon="@Icons.Material.Outlined.ShoppingCart">Procurement Purchase</MudMenuItem>
                                        <MudMenuItem OnClick="OpenSundrypayment" Icon="@Icons.Material.Outlined.AccountBalanceWallet">Sundry Payment</MudMenuItem>
                                    </ChildContent>
                                </MudMenu>
                            </div>
                        </div>
                    </div>

                    <div class="metrics-container mt-8 pt-8 border-t-white-translucent">
                        <div class="metric-item">
                            <span class="metric-label">WO ESTIMATES</span>
                            <span class="metric-value">@Breakdown.EstimateList.Count</span>
                        </div>
                        <div class="metric-divider"></div>
                        <div class="metric-item">
                            <span class="metric-label">ACTIVE JOBS</span>
                            <span class="metric-value">@JipList.Count</span>
                        </div>
                        <div class="metric-divider"></div>
                        <div class="metric-item">
                            <span class="metric-label">SPARE REQUESTS</span>
                            <span class="metric-value">@InvRequestList.Count</span>
                        </div>
                        <div class="metric-divider"></div>
                        <div class="metric-item">
                            <span class="metric-label">FINANCIALS</span>
                            <span class="metric-value">@ExpenseList.Count</span>
                        </div>
                    </div>
                </MudCardContent>
            </MudCard>
        </div>
    }

@if (SelectedJobcard?.JobcardID != null)
{
    <MudTabs Elevation="4" Rounded="true" ApplyEffectsToContainer="true" PanelClass="pa-6" Color="Color.Surface" SliderColor="Color.Primary" MinimumTabWidth="160px" Style="border-radius: 16px; margin-top: 16px;">
        <MudTabPanel Text="WORK ORDER INFO" Icon="@Icons.Material.Filled.CarCrash" BadgeData="@Breakdown.EstimateList.Count.ToString()" BadgeColor="Color.Primary" Style="font-weight: 600;">
            <MudPaper Elevation="0" Class="pa-4">
                <div class="sub-panel ma-0 mb-4 pa-4 overflow-y-auto">
                    <BreakdownComponent MainModel="Breakdown" HideControls=true ReadOnly="@(SelectedJobcard.UserInfo.RecordStatus != 3 ? true : false)"></BreakdownComponent>
                </div>
            </MudPaper>
        </MudTabPanel>
        <MudTabPanel Text="WORKSHOP HISTORY" Icon="@Icons.Material.Filled.HomeRepairService" BadgeData="@jwList.Count.ToString()" BadgeColor="Color.Primary" Style="font-weight: 600;">
            <MudPaper Elevation="0" Class="pa-0">
                <MudTable Items="@jwList" Dense="true" Hover="true" Elevation="0" Class="modern-admin-table mb-4">
                    <HeaderContent>
                        <MudTh><span class="admin-header-text">WORKSHOP NAME</span></MudTh>
                        <MudTh><span class="admin-header-text">ENTRY TIME</span></MudTh>
                        <MudTh><span class="admin-header-text">EXIT TIME</span></MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="Workshop">
                            <div class="d-flex align-center gap-2">
                                <MudIcon Icon="@Icons.Material.Outlined.Storefront" Color="Color.Secondary" Size="Size.Small" />
                                <MudText Typo="Typo.body2" Class="admin-td-primary">@context.WorkshopName</MudText>
                            </div>
                        </MudTd>
                        <MudTd DataLabel="Entry Time">
                            <MudChip T="string" Color="Color.Info" Variant="Variant.Outlined" Size="Size.Small" Class="fw-bold">
                                @context.EnteredOn?.ToString("dd/MM/yy HH:mm tt")
                            </MudChip>
                        </MudTd>
                        <MudTd DataLabel="Exit Time">
                            @if (@context.ExitOn == null)
                            {
                                <MudButton Variant="Variant.Filled" Color="Color.Error" Size="Size.Small" OnClick="@(() => ExitWorkshop(context))" Class="fw-bold px-4" Style="border-radius: 6px;">Mark Exit</MudButton>
                            }
                            else
                            {
                                <MudChip T="string" Color="Color.Default" Variant="Variant.Filled" Size="Size.Small" Class="text-muted fw-bold">
                                    @context.ExitOn?.ToString("dd/MM/yy HH:mm tt")
                                </MudChip>
                            }
                        </MudTd>
                    </RowTemplate>
                </MudTable>

                @if (!jwList.Any(x => x.ExitOn == null) && SelectedJobcard?.UserInfo.RecordStatus == 3)
                {
                    <MudCard Elevation="0" Class="sub-panel" Style="border: 1px dashed var(--mud-palette-primary);">
                        <MudCardContent Class="d-flex align-center gap-4">
                            <MudIcon Icon="@Icons.Material.Filled.AddBusiness" Color="Color.Primary" Size="Size.Large" />
                            <MudSelect For="@(() => SelectedWorkshop)" T="WorkshopModel" @bind-Value="SelectedWorkshop" Label="Assign New Workshop" Strict="true" Variant="Variant.Outlined" Margin="Margin.Dense" Class="flex-grow-1 bg-white">
                                @foreach (var workshop in Workshops)
                                {
                                    <MudSelectItem Value="workshop">@workshop.WorkshopName</MudSelectItem>
                                }
                            </MudSelect>
                            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="EnterWorkshop" Size="Size.Large" Class="fw-bold px-6" Style="height: 48px; border-radius: 8px;">Enter</MudButton>
                        </MudCardContent>
                    </MudCard>
                }
            </MudPaper>
        </MudTabPanel>
        <MudTabPanel Text="REPAIR JOBS" Icon="@Icons.Material.Filled.Engineering" BadgeData="@JipList.Count.ToString()" BadgeColor="Color.Primary" Style="font-weight: 600;">
            <MudPaper Elevation="0" Class="pa-4">
                <div style="margin-bottom: 8px;">
                    <MudGrid>
                            @foreach (var item in JipList)
                            {
                                <MudItem xs="12" md="6" lg="4">
                                    <MudCard Elevation="3" Style="border-radius: 12px; height: 100%; display: flex; flex-direction: column; overflow: visible;">
                                        <MudCardHeader Style="padding-bottom: 0;">
                                            <CardHeaderContent>
                                                @if (EditingJob == item)
                                                {
                                                    <div class="d-flex flex-column gap-2 mb-2">
                                                        <MudAutocomplete T="RepairJobModel"
                                                                         Variant="Variant.Outlined"
                                                                         Margin="Margin.Dense"
                                                                         Label="Select Job Group"
                                                                         Value="EditedJobGroup"
                                                                         ValueChanged="GroupChanged"
                                                                         ResetValueOnEmptyText="true"
                                                                         SearchFunc="@(async (string s, CancellationToken t) => await SearchGroup(s, t))"
                                                                         ToStringFunc="@(e => (e?.JobGroup == null || e?.JobSubGroup == null)
                                                                         ? null
                                                                         : $"{e.JobGroup.Title} | {e.JobSubGroup.Title}")" />
                                                        <MudAutocomplete T="RepairJobModel"
                                                                         Variant="Variant.Outlined"
                                                                         Margin="Margin.Dense"
                                                                         Label="Select Job"
                                                                         Value="EditedJob"
                                                                         ValueChanged="JobChanged"
                                                                         ResetValueOnEmptyText="true"
                                                                         SearchFunc="@(async (string s, CancellationToken t) => await SearchJob(s, t))"
                                                                         ToStringFunc="@(e => e == null ? null : e.Title)" />
                                                    </div>
                                                }
                                                else
                                                {
                                                    <MudText Typo="Typo.h6" Class="fw-bold">@item.RepairJobTitle</MudText>
                                                }
                                            </CardHeaderContent>
                                            <CardHeaderActions>
                                                @if (EditingJob == item)
                                                {
                                                    <MudIconButton Icon="@Icons.Material.Filled.Save" Color="Color.Success" OnClick="@(() => SaveEditingJob(item))" Title="Save" Size="Size.Small" />
                                                    <MudIconButton Icon="@Icons.Material.Filled.Cancel" Color="Color.Error" OnClick="CancelEditingJob" Title="Cancel" Size="Size.Small" />
                                                }
                                                else
                                                {
                                                    <MudIconButton Icon="@Icons.Material.Filled.Edit" OnClick="@(() => StartEditingJob(item))" Title="Edit" Size="Size.Small" />
                                                }
                                            </CardHeaderActions>
                                        </MudCardHeader>
                                        
                                        <MudCardContent Class="flex-grow-1" Style="padding-top: 8px;">
                                            <div class="d-flex justify-space-between align-center mb-4">
                                                <MudChip T="string" Size="Size.Small" Color="@(item.JobStatus == 1 ? Color.Warning : Color.Success)" Variant="Variant.Filled" Class="fw-bold">
                                                    @item.JobStatusText
                                                </MudChip>
                                                <MudText Typo="Typo.caption" Color="Color.Secondary">@item.CreatedOn?.ToString("MMM dd, yyyy HH:mm")</MudText>
                                            </div>

                                            @if (item.WarrantyCheck)
                                            {
                                                <MudAlert Severity="Severity.Success" Variant="Variant.Outlined" Class="mb-3 py-1 px-2" Style="font-size: 0.8rem;">
                                                    Under Warranty till @item.WarrantyExpiryDate
                                                </MudAlert>
                                            }

                                            @if (!string.IsNullOrEmpty(item.Remarks))
                                            {
                                                <div class="mb-3 p-2 rounded" style="background-color: var(--mud-palette-background-grey);">
                                                    <MudText Typo="Typo.caption" Color="Color.Error" Class="fw-bold d-block">REMARKS:</MudText>
                                                    <MudText Typo="Typo.body2">@item.Remarks</MudText>
                                                </div>
                                            }
                                            
                                            <div class="d-flex align-center justify-space-between mt-auto pt-3 border-t">
                                                <div class="d-flex align-center flex-grow-1">
                                                    <MudNumericField HideSpinButtons @bind-Value="item.TotalAmount" Label="Amount" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => item.TotalAmount)" Class="mr-2" />
                                                    @if (item.JobStatus == 2)
                                                    {
                                                        <MudButton Variant="Variant.Filled" Size="Size.Small" Color="Color.Success" OnClick="@(() => UpdateJob(item, 2))" Class="px-3" Style="height: fit-content; align-self: center;">Update</MudButton>
                                                    }
                                                </div>
                                                
                                                @if (item.JobStatus == 1 && EditingJob != item)
                                                {
                                                    <div class="d-flex gap-1 ml-2">
                                                        <MudTooltip Text="Finished">
                                                            <MudIconButton Icon="@Icons.Material.Filled.Check" Color="Color.Success" Variant="Variant.Outlined" Size="Size.Small" OnClick="@(() => UpdateJob(item, 2))" />
                                                        </MudTooltip>
                                                        <MudTooltip Text="Cancel">
                                                            <MudIconButton Icon="@Icons.Material.Filled.Cancel" Color="Color.Error" Variant="Variant.Outlined" Size="Size.Small" OnClick="@(() => UpdateJob(item, 0))" />
                                                        </MudTooltip>
                                                    </div>
                                                }
                                            </div>
                                        </MudCardContent>
                                        
                                        <MudDivider />
                                        
                                        <MudCardActions Class="px-4 py-2 flex-wrap gap-2" Style="background-color: rgba(var(--mud-palette-surface-rgb), 0.5);">
                                            <MudText Typo="Typo.caption" Class="fw-bold mr-2">Mechanics:</MudText>
                                            @foreach (var mech in item.Mechanics)
                                            {
                                                bool isActive = mech.EndedOn == null;
                                                <MudChip T="string" Size="Size.Small" Variant="@(isActive ? Variant.Filled : Variant.Outlined)" Color="@(isActive ? Color.Primary : Color.Default)" OnClose="@(isActive ? (() => RemoveMechanic(mech)) : null)">
                                                    @mech.MechanicName
                                                </MudChip>
                                            }
                                            @if (item.JobStatus == 1)
                                            {
                                                <MudTooltip Text="Assign Mechanic">
                                                    <MudIconButton Size="Size.Small" Icon="@Icons.Material.Filled.Add" OnClick="(() => OpenMechanicSelector(item))" Color="Color.Primary" Variant="Variant.Outlined" Class="ml-auto" />
                                                </MudTooltip>
                                            }
                                        </MudCardActions>
                                    </MudCard>
                                </MudItem>
                            }
                        </MudGrid>
                        @if (CurrentWorkshop != null && SelectedJobcard.UserInfo.RecordStatus == 3)
                        {
                            <MudCard Elevation="2" Class="mt-6" Style="border-radius: 12px; border: 1px dashed var(--mud-palette-primary); background-color: rgba(var(--mud-palette-primary-rgb), 0.05);">
                                <MudCardContent Class="d-flex align-end flex-wrap gap-4">
                                    <div class="flex-grow-1">
                                        <MudText Typo="Typo.subtitle2" Color="Color.Primary" Class="mb-3 fw-bold"><MudIcon Icon="@Icons.Material.Filled.AddAlert" Size="Size.Small" Class="mr-1" /> Add New Job in @CurrentWorkshop.WorkshopName:</MudText>
                                        <JobInProgressView workshop="CurrentWorkshop" model="NewJob" @ref="jipView"></JobInProgressView>
                                    </div>
                                    <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" OnClick="AddJob" Size="Size.Large" Class="fw-bold px-6" Style="border-radius: 8px; height: 48px; margin-bottom: 4px;">Create Job</MudButton>
                                </MudCardContent>
                            </MudCard>
                        }
                </div>
            </MudPaper>
        </MudTabPanel>
        <MudTabPanel Text="SPARE PARTS" Icon="@Icons.Material.Filled.Build" BadgeData="@InvRequestList.Count.ToString()" BadgeColor="Color.Primary" Style="font-weight: 600;">
            <MudPaper Elevation="0" Class="pa-4">
                <MudItem xs="12" md="12">
                    @if (InvRequestList.Count != 0)
                    {
                        <div style="margin-bottom: 8px; overflow-y: auto;">
                            <MudTable Items="@InvRequestList" Dense="false" Hover="true" Striped="true" Elevation="2" Style="border-radius: 12px; overflow: hidden;" Outlined="true">
                                    <HeaderContent>
                                        <MudTh><MudTableSortLabel SortBy="new Func<InventoryRequestModel, object>(x=> x.ReleaseSubDetails?.ItemDescription)" InitialDirection="SortDirection.Ascending"><span class="admin-header-text">ITEM</span></MudTableSortLabel></MudTh>
                                        <MudTh><MudTableSortLabel SortBy="new Func<InventoryRequestModel, object>(x=> x.RequestNumber)" InitialDirection="SortDirection.Ascending"><span class="admin-header-text">DOC DATE / REQ NO.</span></MudTableSortLabel></MudTh>
                                        <MudTh><MudTableSortLabel SortBy="new Func<InventoryRequestModel, object>(x=> x.ReleaseSubDetails?.RequestQty)" InitialDirection="SortDirection.Ascending"><span class="admin-header-text">REQ QTY</span></MudTableSortLabel></MudTh>
                                        <MudTh><MudTableSortLabel SortBy="new Func<InventoryRequestModel, object>(x=> x.ReleaseSubDetails?.ItemQty)" InitialDirection="SortDirection.Ascending"><span class="admin-header-text">REL QTY</span></MudTableSortLabel></MudTh>
                                        <MudTh Style="text-align: right;"><span class="admin-header-text">ACTIONS</span></MudTh>
                                    </HeaderContent>
                                        <RowTemplate>
                                            <MudTd DataLabel="Item"><MudText Typo="Typo.body2" Class="admin-td-primary">@context.ReleaseSubDetails?.ItemGroupDescription - @context.ReleaseSubDetails?.ItemDescription</MudText></MudTd>
                                            <MudTd DataLabel="Details">@(context.RequestDate?.ToShortDateString()) / @(context.RequestNumber)</MudTd>
                                            <MudTd DataLabel="Request Qty">@context.ReleaseSubDetails?.RequestQty</MudTd>
                                            <MudTd DataLabel="Release Qty">@context.ReleaseSubDetails?.ItemQty</MudTd>
                                            <MudTd DataLabel="Actions" Style="text-align: right;">
                                                <div class="d-flex justify-end gap-1">
                                                    @if (!context.IsClosed && @context.ReleaseSubDetails?.ItemQty != null)
                                                    {
                                                        <MudTooltip Text="Close Request">
                                                            <MudIconButton OnClick="@(()=> OpenInventoryReleaseClosedDialog(context))" Color="Color.Warning" Icon="@Icons.Material.Filled.Verified" Size="Size.Small" Variant="Variant.Text" />
                                                        </MudTooltip>
                                                    }
                                                    @if (@context.ReleaseSubDetails?.ItemQty == null)
                                                    {
                                                        <MudTooltip Text="Edit">
                                                            <MudIconButton OnClick="@(()=> OpenInventoryRequestDialog(context))" Color="Color.Primary" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Variant="Variant.Text" />
                                                        </MudTooltip>
                                                        <MudTooltip Text="Delete">
                                                            <MudIconButton OnClick="@(()=> DeleteInventoryRequest(context))" Color="Color.Error" Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Variant="Variant.Text" />
                                                        </MudTooltip>
                                                    }
                                                </div>
                                            </MudTd>
                                        </RowTemplate>
                                    <PagerContent>
                                        <MudTablePager PageSizeOptions="new int[] { 10, 20, 50, 100 }" />
                                    </PagerContent>
                                </MudTable>
                            </div>
                        }
                </MudItem>
            </MudPaper>
        </MudTabPanel>
        <MudTabPanel Text="FINANCIALS" Icon="@Icons.Material.Filled.ReceiptLong" BadgeData="@ExpenseList.Count.ToString()" BadgeColor="Color.Primary" Style="font-weight: 600;">
            <MudPaper Elevation="0" Class="pa-4">
                <MudItem xs="12" md="12">
                    @if (ExpenseList.Count != 0)
                    {
                        <div style="margin-bottom: 8px; overflow-y: auto;">
                            <MudTable Items="@ExpenseList" Dense="false" Hover="true" Striped="true" Elevation="2" Style="border-radius: 12px; overflow: hidden;" Outlined="true">
                                    <HeaderContent>
                                        <MudTh><span class="admin-header-text">DOC NO.</span></MudTh>
                                        <MudTh><span class="admin-header-text">DATE</span></MudTh>
                                        <MudTh><span class="admin-header-text">VENDOR</span></MudTh>
                                        <MudTh><span class="admin-header-text">INVOICE</span></MudTh>
                                        <MudTh><span class="admin-header-text">TOTAL AMT</span></MudTh>
                                        <MudTh><span class="admin-header-text">COST CENTER</span></MudTh>
                                        <MudTh Style="text-align: right;"><span class="admin-header-text">DETAILS</span></MudTh>
                                    </HeaderContent>
                                    <RowTemplate>
                                        <MudTd DataLabel="Doc Number"><MudText Typo="Typo.body2" Class="admin-td-primary">@context.DocNumber</MudText></MudTd>
                                        <MudTd DataLabel="Document Date">@context.DocDate</MudTd>
                                        <MudTd DataLabel="Vendor">@context.RegName</MudTd>
                                        <MudTd DataLabel="Invoice">@context.InvoiceNo</MudTd>
                                        <MudTd DataLabel="Total Amt"><MudText Typo="Typo.body2" Class="admin-td-amount">@context.TotalAmount</MudText></MudTd>
                                        <MudTd DataLabel="Cost Center">@context.CostCenter</MudTd>
                                        <MudTd DataLabel="Actions" Style="text-align: right;">
                                            <MudTooltip Text="@context.Narration">
                                                <MudIconButton Icon="@Icons.Material.Filled.Info" Size="Size.Small" Variant="Variant.Text" />
                                            </MudTooltip>
                                        </MudTd>
                                    </RowTemplate>
                                    <PagerContent>
                                        <div class="pa-4">
                                            <MudTablePager PageSizeOptions="new int[] { 10, 20, 50, 100 }" />
                                        </div>
                                    </PagerContent>
                                </MudTable>
                            </div>
                        }
                </MudItem>
            </MudPaper>
        </MudTabPanel>
    </MudTabs>
}
</div>
<MudDialog @bind-IsVisible="visibleMechanicSelector" DisableSidePadding="true">
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.People" Class="mr-3" /> Assign Mechanics
        </MudText>
    </TitleContent>
    <DialogContent>
