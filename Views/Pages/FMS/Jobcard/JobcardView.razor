        var result = await DialogService.Show<InventoryReleaseClosedDialog>("ADD", parms, mediumWidth).Result;

        InvRequestList = IInvRequestservice.SelectRequestReleaseByJobCardID(SelectedJobcard.JobcardID).ToList();
        model = new();
        await Task.Delay(200);
        _busy = false;
    }

    // Method to open inventory request dialog
    private async Task OpenInventoryRequestDialog(InventoryRequestModel model)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        _busy = true;
        var authprov = await auth.GetAuthenticationStateAsync();
        var branchID = int.Parse(authprov.User.Claims.First(x => x.Type == "BranchID").Value);
        model.Jobcard = SelectedJobcard;
        model.BranchID = branchID;
        model.Truck = SelectedTruck;
        DialogOptions mediumWidth = new DialogOptions() { MaxWidth = MaxWidth.Medium, FullWidth = true };
        DialogParameters parms = new DialogParameters();
        parms.Add("model", model.Clone());
        parms.Add("SetIncomingVal", true);
        var dialog = DialogService.Show<InvRequestDialog>("ADD", parms, mediumWidth);
        var result = await dialog.Result;
        if (!result.Canceled)
        {
            InvRequestList = IInvRequestservice.SelectRequestReleaseByJobCardID(SelectedJobcard.JobcardID).ToList();
            model = new();
        }
        await Task.Delay(200);
        _busy = false;
    }

    // Method to delete an inventory request
    private async Task DeleteInventoryRequest(InventoryRequestModel model)
    {
        if (HasPermissionInventoryRequestDelete)
        {
            try
            {
                bool? result = await DialogService.ShowMessageBox(
                    "Warning !",
                    "Are you sure, you want to delete - " + model.ReleaseSubDetails?.ItemDescription + " (" + model.RequestDate?.ToShortDateString() + " / " + model.RequestNumber + ") ?");
                if (result == true)
                {
                    var authprov = await auth.GetAuthenticationStateAsync();
                    var user = authprov.User;
                    var value = IInvRequestservice.Delete(model.RequestID, user.Identity.Name);
                    if (value != -1)
                    {
                        if (InvRequestList.Exists(s => s.RequestID == value))
                        {
                            InvRequestList.Remove(InvRequestList.FirstOrDefault(s => s.RequestID == value));
                        }
                    }
                    snackbar.Add("Deleted Successfully", Severity.Success);
                }
            }
            catch (Exception ex)
            {
                snackbar.Add(ex.Message, Severity.Error);
            }
        }
        else
        {
            bool? result = await DialogService.ShowMessageBox(
                "Permission denied!",
                "You don't have any permission to Delete InventoryRequest.");
        }
    }

