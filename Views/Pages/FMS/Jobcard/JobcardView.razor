@page "/jobcard"
@inject IJobcardService Iservice
@inject ITruckService Itruck
@inject IJobcardWorkshopService Ijw
@inject IJobInProgressService Ijp
@inject IWorkshopService Iworkshop
@inject IMechanicJobService ImechanicJob

@inject MudBlazor.ISnackbar snackbar
@attribute [Authorize]
@inject AuthenticationStateProvider auth

@inject IDialogService DialogService

<MudPaper Class="p-2" Elevation="0">
    <div class="d-flex">

        <h3 class="d-inline-block mt-2 mr-2">SELECT JOBCARD OF </h3>
        <MudAutocomplete Class="d-inline-block" T="TruckModel" Variant="Variant.Outlined" Margin="Margin.Normal" Label="Truck" Value="SelectedTruck" ValueChanged="TruckSelected" ResetValueOnEmptyText="true"
                         SearchFunc="SearchTruck" ToStringFunc="@(e => e == null ? null : $"{e.RegNo}")"></MudAutocomplete>

    </div>
</MudPaper>

@if (SelectedJobcard?.JobcardID != null)
{
    <h5>@SelectedJobcard?.JobcardNumber</h5>
    <h5>@SelectedJobcard?.BranchName</h5>
    <hr />

    <MudGrid>
        <MudItem xs="12" lg="6">
            <h3>Workshop</h3>
            <MudPaper Class="pa-2 ma-2" Elevation="0">
                <MudList>
                    <MudListItem>
                        <MudGrid>
                            <MudItem xs="6">
                                <b>WORKSHOP</b>
                            </MudItem>
                            <MudItem xs="3">
                                <b> ENTRY</b>
                            </MudItem>
                            <MudItem xs="3">
                                <b> EXIT</b>
                            </MudItem>
                        </MudGrid>
                    </MudListItem>
                    @foreach (var item in jwList)
                    {
                        <MudDivider />
                        <MudListItem>
                            <MudGrid>
                                <MudItem xs="6">
                                    @item.WorkshopName
                                </MudItem>
                                <MudItem xs="3">
                                    @item.EnteredOn?.ToString("dd/MM/yy HH:mm tt")
                                </MudItem>
                                <MudItem xs="3">
                                    @if (@item.ExitOn == null)
                                    {
                                        <MudButton Color="Color.Success" OnClick="@(() => ExitWorkshop(item))">Exit</MudButton>}
                                    else
                                    {
                                        @item.ExitOn?.ToString("dd/MM/yy HH:mm tt")
                                    }
                                </MudItem>
                            </MudGrid>
                            </MudListItem>
                            }
                            @if (jwList.Where(x => x.ExitOn == null).Count() == 0)
                            {
                                <MudDivider></MudDivider>
                                <MudListItem>
                                    <MudGrid>
                                        <MudItem xs="8">
                                            <MudSelect T="WorkshopModel" @bind-Value="SelectedWorkshop" Label="Workshop" Strict="true" Variant="Variant.Outlined">
                                                @foreach (var workshop in Workshops)
                                                {
                                                    <MudSelectItem Value="workshop">@workshop.WorkshopName</MudSelectItem>
                                                }
                                            </MudSelect>
                                        </MudItem>
                                        <MudItem xs="4">
                                            <MudButton Color="Color.Primary" OnClick="EnterWorkshop">Enter Workshop</MudButton>
                                        </MudItem>
                                    </MudGrid>
                                </MudListItem>
                            }

                    </MudList>
                 </MudPaper>
                </MudItem>
        
                    <MudItem xs="12" lg="6">
                        <h3>Jobs</h3>
                        @foreach (var item in JipList)
                        {
                            string AppliedColor = ColorInProgress;
                            @switch (item.JobStatus)
                            {
                                case 0:
                                    AppliedColor = ColorCancelled;
                                    break;
                                case 2:
                                    AppliedColor = ColorFinished;
                                    break;
                            }

                            <MudPaper Class="pa-2 ma-2" Style="@($"background:{AppliedColor};")" Elevation="0">
                                <MudGrid>
                                    <MudItem xs="5">
                                        @item.RepairJobTitle
                                    </MudItem>
                                    <MudItem xs="4">
                                        @item.CreatedOn?.ToString("dd/MM/yy HH:mm tt")
                                    </MudItem>
                                    @if (item.JobStatus == 1)
                                    {
                                        <MudItem xs="3">
                                            <MudButtonGroup Color="Color.Primary" Variant="Variant.Outlined">
                                                <MudTooltip Text="Finished">
                                                    <MudIconButton Icon="@Icons.Material.Filled.Check" Color="Color.Success" OnClick="@(()=> UpdateJob(item,2))"></MudIconButton>
                                                </MudTooltip>
                                                <MudTooltip Text="Cancel">
                                                    <MudIconButton Icon="@Icons.Material.Filled.Cancel" Color="Color.Error" OnClick="@(()=> UpdateJob(item,0))"></MudIconButton>
                                                </MudTooltip>
                                            </MudButtonGroup>
                                        </MudItem>
                                    }
                                <MudItem xs="10">
                                    @foreach (var mech in item.Mechanics)
                                    {
                                        @if (mech.EndedOn == null)
                                        {
                                            <MudText Color="Color.Primary" >mech.MechanicName  </MudText>
                                        }
                                        else
                                        {
                                            <MudText Style="text-decoration:line-through;color:gray">mech.MechanicName  </MudText>
                                        }
                                    }
                                </MudItem>
                                </MudGrid>
                            </MudPaper>
                        }
                        @if (CurrentWorkshop != null)
                        {
                            <MudPaper Class="pa-2 ma-2" Elevation="0">
                                <JobInProgressView workshop="CurrentWorkshop" model="NewJob"></JobInProgressView>
                                <MudButton Color="Color.Success" OnClick="AddJob">Add Job</MudButton>
                            </MudPaper>
                        }
                    </MudItem>
                    </MudGrid>
                    }
                    @code {

                        private List<TruckModel> TruckList = new();
                        private TruckModel SelectedTruck = new();
                        private JobcardModel SelectedJobcard = new();
                        private WorkshopModel SelectedWorkshop = new();
                        private WorkshopModel CurrentWorkshop;
                        private List<JobcardWorkshopModel> jwList = new();
                        private List<JobInProgressModel> JipList = new();
                        private List<WorkshopModel> Workshops = new();

                        private JobInProgressModel NewJob = new JobInProgressModel();

                        string ColorInProgress = Colors.Indigo.Lighten5;
                        string ColorFinished = Colors.Green.Lighten5;
                        string ColorCancelled = Colors.Grey.Lighten5;

                        protected override void OnInitialized()
                        {
                            TruckList = Itruck.Select(null).ToList();
                            Workshops = Iworkshop.Select(0).ToList();
                        }


                        private async Task<IEnumerable<TruckModel>> SearchTruck(string searchString)
                        {
                            return await Task.FromResult(TruckList.Where(x => x.RegNo.Contains(searchString == null ? string.Empty : searchString, StringComparison.InvariantCultureIgnoreCase)));
                        }


                        private async Task TruckSelected(TruckModel obj)
                        {
                            SelectedTruck = obj;
                            SelectedJobcard = Iservice.SelectByTruck(SelectedTruck?.TruckID, true).FirstOrDefault();
                            jwList = Ijw.SelectByJobcard(SelectedJobcard?.JobcardID).ToList();
                            setJipList(SelectedJobcard);
                            if (jwList.Count(x => x.ExitOn == null) > 0)
                            {
                                CurrentWorkshop = Workshops.First(y => y.WorkshopID == jwList.First(x => x.ExitOn == null).WorkshopID);
                            }
                            var authProvider = await auth.GetAuthenticationStateAsync();
                            NewJob = new()
                            {
                                CreatedOn = DateTime.Now,
                                JobCardID = SelectedJobcard?.JobcardID,
                                WorkshopID = CurrentWorkshop?.WorkshopID,
                                JobStatus = 1,
                                UserInfo = new() { UserID = authProvider.User.Identity.Name }
                            };
                        }

                        void setJipList(JobcardModel jobcard)
                        {
                            JipList = Ijp.SelectByJobcard(jobcard?.JobcardID).ToList();
                            foreach(JobInProgressModel item in JipList)
                            {
                              item.Mechanics =  ImechanicJob.SelectByJob(item.JipID).ToList();
                            }
                        }

                        private async Task ExitWorkshop(JobcardWorkshopModel jwModel)
                        {
                            jwModel.ExitOn = DateTime.Now;

                            var authProvider = await auth.GetAuthenticationStateAsync();
                            jwModel.UserInfo.UserID = authProvider.User.Identity.Name;
                            Ijw.Update(jwModel);
                            jwList = Ijw.SelectByJobcard(SelectedJobcard?.JobcardID).ToList();
                            CurrentWorkshop = null;
                        }


                        private async Task EnterWorkshop()
                        {
                            JobcardWorkshopModel jwEnter = new();
                            jwEnter.JobCardID = SelectedJobcard.JobcardID;
                            jwEnter.WorkshopID = SelectedWorkshop.WorkshopID;
                            jwEnter.EnteredOn = DateTime.Now;

                            var authProvider = await auth.GetAuthenticationStateAsync();
                            jwEnter.UserInfo.UserID = authProvider.User.Identity.Name;
                            Ijw.Update(jwEnter);
                            jwList = Ijw.SelectByJobcard(SelectedJobcard?.JobcardID).ToList();
                            CurrentWorkshop = Workshops.First(y => y.WorkshopID == jwList.First(x => x.ExitOn == null).WorkshopID);
                        }

                        private async Task UpdateJob(JobInProgressModel Ujip, int status)
                        {
                            var authProvider = await auth.GetAuthenticationStateAsync();
                            Ujip.UserInfo.UserID = authProvider.User.Identity.Name;
                            Ujip.JobStatus = status;
                            Ujip.FinishedOn = DateTime.Now;
                            Ijp.Update(Ujip);
                            setJipList(SelectedJobcard);
                        }
                        private async Task AddJob()
                        {
                            var authProvider = await auth.GetAuthenticationStateAsync();
                            NewJob.CreatedOn = DateTime.Now;
                            Ijp.Update(NewJob);
                            setJipList(SelectedJobcard);
                        }

                    }