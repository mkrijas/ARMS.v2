@page "/jobcards"
@inject IJobcardService Iservice
@inject IBreakdownService Ibreakdownservice
@inject MudBlazor.ISnackbar snackbar
@attribute [Authorize]
@inject AuthenticationStateProvider auth
@inject NavigationManager nav
@inject IDialogService DialogService
@using System.Threading;
@inject IRoleService<RoleModel> Irole

@if (_isLoading)
{
    <div @key="@("loader")" class="d-flex justify-center align-center" style="min-height: 400px;">
        <LoaderComponent IsFullScreen="false" ShowLogo="false" Size="medium" LoadingText="Synchronizing Jobcards" SubText="Retrieving latest workshop activity records..." />
    </div>
}
else
{
    <div class="admin-page-container fade-in" @key="@("content")">
        <div class="admin-header-tiered mb-6">
            <div class="d-flex align-center justify-space-between">
                <div>
                    <MudText Typo="Typo.h4" Class="admin-title">Workshop Jobcards</MudText>
                    <MudText Typo="Typo.body2" Class="admin-subtitle">Monitor and manage vehicle maintenance work orders and workshop throughput.</MudText>
                </div>
                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="@(() => nav.NavigateTo("jobcard"))" Class="admin-register-btn" StartIcon="@Icons.Material.Filled.Add">CREATE JOBCARD</MudButton>
            </div>
        </div>

        <div class="admin-glass-card pa-6 mb-6">
            <MudGrid Spacing="3" Class="align-center">
                <MudItem xs="12" md="6">
                    <MudTextField @bind-Value="searchString" Placeholder="Search by Jobcard Number or Vehicle Registration..." Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" AdornmentColor="Color.Primary" Variant="Variant.Outlined" Margin="Margin.Dense" Clearable="true" Class="modern-input"></MudTextField>
                </MudItem>
                <MudItem xs="12" md="6" Class="d-flex justify-end">
                    <div class="d-flex align-center gap-2">
                        <MudText Typo="Typo.caption" Class="admin-subtitle">TOTAL RECORDS: @(collection?.Count ?? 0)</MudText>
                    </div>
                </MudItem>
            </MudGrid>
        </div>

        <div class="admin-glass-card overflow-hidden">
            <MudTable Items="@collection" Elevation="0" Filter="new Func<JobcardModel, bool>(search)" @bind-model="model" Hover="true" Breakpoint="Breakpoint.Sm" Class="modern-admin-table">
                <HeaderContent>
                    <MudTh><MudTableSortLabel SortBy="new Func<JobcardModel, object>(x=> x.JobcardNumber)" InitialDirection="SortDirection.Ascending"><span class="admin-header-text">JOBCARD NO</span></MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<JobcardModel, object>(x=> x.RegNo)"><span class="admin-header-text">TRUCK</span></MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<JobcardModel, object>(x=> x.CreatedOn)"><span class="admin-header-text">CREATED ON</span></MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<JobcardModel, object>(x=> x.BreakdownType)"><span class="admin-header-text">WORK ORDER TYPE</span></MudTableSortLabel></MudTh>
                    <MudTh Style="text-align: right;"><span class="admin-header-text">ACTIONS</span></MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="JobcardNumber">
                        <span class="admin-td-primary fw-600">
                            <MudHighlighter Text="@context.JobcardNumber" HighlightedText="@searchString" />
                        </span>
                    </MudTd>
                    <MudTd DataLabel="Truck"><span class="fw-500">@context.RegNo</span></MudTd>
                    <MudTd DataLabel="Date">@context.CreatedOn?.ToString("dd MMM yyyy, hh:mm tt")</MudTd>
                    <MudTd DataLabel="BreakdownType">
                        <MudChip T="string" Size="Size.Small" Color="@(context.BreakdownType == "Major" ? Color.Error : Color.Info)" Class="fw-600">@context.BreakdownType</MudChip>
                    </MudTd>
                    <MudTd DataLabel="Actions" Style="text-align: right;">
                        <MudTooltip Text="Edit Jobcard">
                            <MudIconButton OnClick="@(()=> Edit(context))" Color="Color.Primary" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Variant="Variant.Text" />
                        </MudTooltip>
                        @if (HasPermissionJobcardServiceDelete)
                        {
                            <MudTooltip Text="Delete Record">
                                <MudIconButton OnClick="@(()=> Delete(context))" Color="Color.Error" Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Variant="Variant.Text" />
                            </MudTooltip>
                        }
                    </MudTd>
                </RowTemplate>
                <PagerContent>
                    <div class="pa-4">
                        <MudTablePager PageSizeOptions="new int[] { 10, 20, 50, 100 }" />
                    </div>
                </PagerContent>
            </MudTable>
        </div>
    </div>
}



@code {

    private bool _isLoading = true;
    private DateTime _loadStartTime;

    private JobcardModel model;
    private List<JobcardModel> collection = new();
    private string searchString = string.Empty;

    public bool HasPermissionJobcardServiceDelete { get; set; } = false;
    public int JobcardDocTypeID = 82;

    // Lifecycle method that runs when the component is initialized
    protected override async Task OnInitializedAsync()
    {
        _loadStartTime = DateTime.Now;
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionJobcardServiceDelete = await Irole.HasClaim(JobcardDocTypeID.ToString(), "Edit", ctc.Token);

        model = new();
        await GetAll();
        await EnsureMinimumLoadTime();
        _isLoading = false;
    }

    private async Task EnsureMinimumLoadTime()
    {
        var elapsed = (DateTime.Now - _loadStartTime).TotalMilliseconds;
        if (elapsed < 100)
        {
            await Task.Delay(100 - (int)elapsed);
        }
    }

    // Method to fetch job cards based on the user's branch ID
    private async Task GetAll()
    {
        var authState = await auth.GetAuthenticationStateAsync();
        var claim = authState.User.Claims.FirstOrDefault(x => x.Type == "BranchID");
        if (claim != null)
        {
            int branchID = int.Parse(claim.Value);
            collection = Iservice.SelectByBranch(branchID, true).ToList(); 
        } 
    }

    // Method to navigate to the edit page for a specific job card
    private async Task Edit(JobcardModel Jobcard)
    {
        nav.NavigateTo("jobcard/" + Jobcard.TruckID);
    }

    // Method to delete a specific job card
    private async Task Delete(JobcardModel model)
    {
        if (HasPermissionJobcardServiceDelete)
        {
            bool? result = await DialogService.ShowMessageBoxAsync(
                "Warning !",
                "Are you sure, you want to delete - " + model.JobcardNumber + " ?");
            if (result == true)
            {
                var authprov = await auth.GetAuthenticationStateAsync();
                var user = authprov.User;
                Iservice.Delete(model.JobcardID, user.Identity.Name); // Call the service to delete the job card
                snackbar.Add("Deleted Successfully", Severity.Success);
            }
        }
        else
        {
            bool? result = await DialogService.ShowMessageBoxAsync(
                "Permission denied!",
                "You don't have any permission to Delete Jobcard.");
        }
        GetAll();
    }

    // Method to search for job cards
    private bool search(JobcardModel model)
    {
        if (model.JobcardNumber != null 
            && model.JobcardNumber.Contains(searchString, StringComparison.OrdinalIgnoreCase) 
            || model.RegNo.Contains(searchString, StringComparison.OrdinalIgnoreCase))
        {
            return true;
        }
        return false;
    }
}

