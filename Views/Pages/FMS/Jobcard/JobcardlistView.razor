@page "/jobcards"
@inject IJobcardService Iservice
@inject IBreakdownService Ibreakdownservice
@inject MudBlazor.ISnackbar snackbar
@attribute [Authorize]
@inject AuthenticationStateProvider auth
@inject NavigationManager nav
@inject IDialogService DialogService
@using System.Threading;
@inject IRoleService<RoleModel> Irole

<MudTable Items="@collection" Elevation="10" Filter="new Func<JobcardModel, bool>(search)" @bind-model="model">
    <ToolBarContent>
        <MudText Typo="Typo.h6">Jobcards</MudText>
        <MudSpacer></MudSpacer>
        <MudTextField @bind-Value="searchString" Placeholder="Search JobcardNumber or TruckRegNo... " Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0"></MudTextField>
    </ToolBarContent>
    <HeaderContent>
        <MudTh><MudTableSortLabel SortBy="new Func<JobcardModel, object>(x=> x.JobcardNumber)" InitialDirection="SortDirection.Ascending">Jobcard No</MudTableSortLabel></MudTh>
        <MudTh><MudTableSortLabel SortBy="new Func<JobcardModel, object>(x=> x.RegNo)" InitialDirection="SortDirection.Ascending">Truck</MudTableSortLabel></MudTh>
        <MudTh><MudTableSortLabel SortBy="new Func<JobcardModel, object>(x=> x.CreatedOn)" InitialDirection="SortDirection.Ascending">Created on</MudTableSortLabel></MudTh>
        <MudTh>Actions</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd DataLabel="JobcardNumber"> <MudHighlighter Style="background-color:cornflowerblue;font-weight:bold" Text="@context.JobcardNumber" HighlightedText="@searchString" /></MudTd>
        <MudTd DataLabel="Truck">@context.RegNo</MudTd>
        <MudTd DataLabel="Date">@context.CreatedOn</MudTd>
        <MudTd DataLabel="">
            <MudFab @onclick="@(()=> Edit(context))" Color="Color.Primary" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" IconSize="Size.Small" />
            <MudFab @onclick="@(()=> Delete(context))" Color="Color.Primary" Icon="@Icons.Material.Filled.Delete" Size="Size.Small" IconSize="Size.Small" />
        </MudTd>
    </RowTemplate>
    <PagerContent>
        <MudTablePager PageSizeOptions="new int[] { 10, 20, 50, 100 }" />
    </PagerContent>
</MudTable>

@code {

    private JobcardModel model;
    private List<JobcardModel> collection = new();
    private string searchString = string.Empty;

    public bool HasPermissionJobcardServiceDelete { get; set; } = false;
    public int JobcardDocTypeID = 82;

    // Lifecycle method that runs when the component is initialized
    protected override async Task OnInitializedAsync()
    {
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionJobcardServiceDelete = await Irole.HasClaim(JobcardDocTypeID.ToString(), "Edit", ctc.Token);

        model = new();
        await GetAll();
    }

    // Method to fetch job cards based on the user's branch ID
    private async Task GetAll()
    {
        var authState = await auth.GetAuthenticationStateAsync();
        int branchID = int.Parse(authState.User.Claims.First(x => x.Type == "BranchID").Value);
        collection = Iservice.SelectByBranch(branchID, true).ToList(); // Fetch job cards for the branch 
    }

    // Method to navigate to the edit page for a specific job card
    private async Task Edit(JobcardModel Jobcard)
    {
        nav.NavigateTo("jobcard/" + Jobcard.TruckID);
    }

    // Method to delete a specific job card
    private async Task Delete(JobcardModel model)
    {
        if (HasPermissionJobcardServiceDelete)
        {
            bool? result = await DialogService.ShowMessageBox(
                "Warning !",
                "Are you sure, you want to delete - " + model.JobcardNumber + " ?");
            if (result == true)
            {
                var authprov = await auth.GetAuthenticationStateAsync();
                var user = authprov.User;
                Iservice.Delete(model.JobcardID, user.Identity.Name); // Call the service to delete the job card
                snackbar.Add("Deleted Successfully", Severity.Success);
            }
        }
        else
        {
            bool? result = await DialogService.ShowMessageBox(
                "Permission denied!",
                "You don't have any permission to Delete Jobcard.");
        }
        GetAll();
    }

    // Method to search for job cards
    private bool search(JobcardModel model)
    {
        if (model.JobcardNumber != null 
            && model.JobcardNumber.Contains(searchString, StringComparison.OrdinalIgnoreCase) 
            || model.RegNo.Contains(searchString, StringComparison.OrdinalIgnoreCase))
        {
            return true;
        }
        return false;
    }
}