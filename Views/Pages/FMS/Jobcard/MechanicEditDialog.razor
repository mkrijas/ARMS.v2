@attribute [Authorize]
@inject IMechanicService Iservice
@inject IWorkshopService Iworkshop
@inject MudBlazor.ISnackbar snackbar
@inject AuthenticationStateProvider auth
@using System.Threading;
@inject IRoleService<RoleModel> Irole
@inject IDialogService DialogService

<MudDialog>
    <DialogContent>
        <MudContainer Style="min-height:300px;max-height: 800px;">
            <EditForm id="formJobcard" Model="@model" OnValidSubmit="OnValidSubmit">
                <ObjectGraphDataAnnotationsValidator />
                <ValidationSummary />
                <MudGrid Spacing="2">
                    <MudItem xs="12">
                        <MudTextField @bind-Value="@model.MechanicName" Label="Name" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.MechanicName)"></MudTextField>
                    </MudItem>
                    <MudItem xs="12">
                        <MudSelect Label="Select Workshop" Value="SelectedWorkshop" T="WorkshopModel" ValueChanged="@((e)=> WorkshopChanged(e))" ToStringFunc="@((p) => p?.WorkshopName)" Variant="Variant.Outlined" Margin="Margin.Dense" AdornmentColor="Color.Secondary">
                            @foreach (var ditem in Workshops)
                            {
                                <MudSelectItem Value="@ditem">@ditem.WorkshopName</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12">
                        <MudTextField @bind-Value="@model.Remarks" Lines="3" Label="Remarks" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.Remarks)"></MudTextField>
                    </MudItem>
                </MudGrid>
            </EditForm>
        </MudContainer>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Disabled="@_busy" form="formJobcard" Variant="Variant.Filled" Color="Color.Success" ButtonType="ButtonType.Submit">Submit</MudButton>
    </DialogActions>
</MudDialog>

@code {

    [CascadingParameter] MudDialogInstance MudDialog { get; set; }
    [Parameter] public MechanicModel model { get; set; }
    private WorkshopModel SelectedWorkshop = new();
    private List<WorkshopModel> Workshops = new();
    private bool _busy;

    public bool HasPermissionMechanicServiceEdit { get; set; } = false;
    public int MechanicTypeID = 78;

    // Initialization logic for the component
    protected override async Task OnInitializedAsync()
    {
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionMechanicServiceEdit = await Irole.HasClaim(MechanicTypeID.ToString(), "Edit", ctc.Token);

        Workshops = Iworkshop.Select(null).ToList(); // Load the list of workshops
        SelectedWorkshop = Workshops.FirstOrDefault(x => x.WorkshopID == model?.WorkshopID);
    }

    // Method to cancel the dialog and close it 
    private void Cancel()
    {
        MudDialog.Cancel();
    }

    // Method to handle changes in the selected workshop 
    private void WorkshopChanged(WorkshopModel workshop)
    {
        SelectedWorkshop = workshop;
        model.WorkshopID = workshop.WorkshopID;
    }

    // Method to handle form submission when the form is valid
    private async Task OnValidSubmit(EditContext context)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is being submitted!", Severity.Warning);
            return;
        }
        _busy = true;
        var authprov = await auth.GetAuthenticationStateAsync();
        model.UserInfo.UserID = authprov.User.Identity.Name;
        try
        {
            if (HasPermissionMechanicServiceEdit)
            {
                model = Iservice.Update(model); // Update the mechanic model
                snackbar.Add("Saved Successfully", Severity.Success);
                MudDialog.Close(DialogResult.Ok(model));
                model = new();
            }
            else
            {
                bool? result = await DialogService.ShowMessageBox(
                    "Permission denied!",
                    "You don't have any permission to Edit Mechanic.");
            }
        }
        catch (Exception ex)
        {
            snackbar.Add(ex.Message, Severity.Warning);
        }
        await Task.Delay(200);
        _busy = false;
    }
}