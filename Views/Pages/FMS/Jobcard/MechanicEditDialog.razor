@attribute [Authorize]
@inject IMechanicService Iservice
@inject IWorkshopService Iworkshop
@inject MudBlazor.ISnackbar snackbar
@inject AuthenticationStateProvider auth
@using System.Threading;
@inject IRoleService<RoleModel> Irole
@inject IDialogService DialogService

<MudDialog Class="admin-dialog-glass">
    <TitleContent>
        <div class="header-section mb-2 pt-4 px-4">
            <div class="d-flex align-center justify-space-between">
                <div class="d-flex align-center">
                    <div class="icon-badge primary-badge mr-4">
                        <div class="admin-header-icon-badge mb-3">
                            <MudIcon Icon="@Icons.Material.Filled.Badge" Color="Color.Secondary" Style="font-size: 3rem;" />
                        </div>
                    </div>
                    <div>
                        <MudText Typo="Typo.h5" Class="admin-title"><b>Mechanic Personnel Profile</b></MudText>
                        <MudText Typo="Typo.body2" Class="admin-subtitle">
                            Configure technical certifications and primary facility assignments for maintenance staff.
                        </MudText>
                    </div>
                </div>
            </div>
            <div class="title-accent mt-4"></div>
        </div>
    </TitleContent>
    <DialogContent>
        <MudContainer Class="admin-dialog-container">
            <div class="dialog-content-wrapper fade-in">
                <EditForm id="formMechanic" Model="@model" OnValidSubmit="OnValidSubmit">
                    <ObjectGraphDataAnnotationsValidator />
                    
                    <div class="admin-glass-card pa-6">
                        <div class="d-flex align-center mb-6">
                            <div class="icon-badge primary-badge-soft mr-3">
                                <MudIcon Icon="@Icons.Material.Filled.PersonSearch" Size="Size.Small" />
                            </div>
                            <span class="admin-section-label mb-0">Professional Identity</span>
                        </div>

                        <MudGrid Spacing="3">
                            <MudItem xs="12">
                                <MudTextField @bind-Value="@model.MechanicName" Label="Full Name / Personnel ID" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.MechanicName)" Class="modern-input" Placeholder="Enter full name" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.AccountCircle" />
                            </MudItem>
                            <MudItem xs="12">
                                <MudSelect For="@(() => SelectedWorkshop)" Label="Designated Workshop Facility" Value="SelectedWorkshop" T="WorkshopModel" ValueChanged="@((e)=> WorkshopChanged(e))" ToStringFunc="@((p) => p?.WorkshopName)" Variant="Variant.Outlined" Margin="Margin.Dense" Class="modern-input" AdornmentIcon="@Icons.Material.Filled.Warehouse">
                                    @foreach (var ditem in Workshops)
                                    {
                                        <MudSelectItem Value="@ditem">@ditem.WorkshopName</MudSelectItem>
                                    }
                                </MudSelect>
                            </MudItem>
                            <MudItem xs="12">
                                <MudTextField @bind-Value="@model.Remarks" Lines="2" Label="Specializations & Internal Notes" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.Remarks)" Class="modern-input" Placeholder="e.g., Senior Engine Technician, Hydraulic Systems Specialist" />
                            </MudItem>
                        </MudGrid>
                    </div>
                </EditForm>
            </div>
        </MudContainer>
    </DialogContent>
    <DialogActions>
        <div class="d-flex w-100 px-4 pb-4 align-center gap-3">
            <MudSpacer></MudSpacer>
            <MudButton @onclick="Cancel" Variant="Variant.Outlined" Color="Color.Default" Style="border-radius: 12px; font-weight: 700; text-transform: none; border-color: rgba(0,0,0,0.15);">Cancel</MudButton>
            <MudButton Disabled="@_busy" form="formMechanic" Variant="Variant.Filled" ButtonType="ButtonType.Submit" Color="Color.Success" Style="background: var(--mud-palette-success); color: white; font-weight: 800; border-radius: 12px; text-transform: none; white-space: nowrap; padding: 8px 24px;" StartIcon="@Icons.Material.Filled.DoneAll">Submit</MudButton>
        </div>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; }
    [Parameter] public MechanicModel model { get; set; }
    private WorkshopModel SelectedWorkshop = new();
    private List<WorkshopModel> Workshops = new();
    private bool _busy;

    public bool HasPermissionMechanicServiceEdit { get; set; } = false;
    public int MechanicTypeID = 78;

    // Initialization logic for the component
    protected override async Task OnInitializedAsync()
    {
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionMechanicServiceEdit = await Irole.HasClaim(MechanicTypeID.ToString(), "Edit", ctc.Token);

        Workshops = Iworkshop.Select(null).ToList(); // Load the list of workshops
        SelectedWorkshop = Workshops.FirstOrDefault(x => x.WorkshopID == model?.WorkshopID);
    }

    // Method to cancel the dialog and close it 
    private void Cancel()
    {
        MudDialog.Cancel();
    }

    // Method to handle changes in the selected workshop 
    private void WorkshopChanged(WorkshopModel workshop)
    {
        SelectedWorkshop = workshop;
        model.WorkshopID = workshop.WorkshopID;
    }

    // Method to handle form submission when the form is valid
    private async Task OnValidSubmit(EditContext context)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is being submitted!", Severity.Warning);
            return;
        }
        _busy = true;
        var authprov = await auth.GetAuthenticationStateAsync();
        model.UserInfo.UserID = authprov.User.Identity.Name;
        try
        {
            if (HasPermissionMechanicServiceEdit)
            {
                model = Iservice.Update(model); // Update the mechanic model
                snackbar.Add("Saved Successfully", Severity.Success);
                MudDialog.Close(DialogResult.Ok(model));
                model = new();
            }
            else
            {
                bool? result = await DialogService.ShowMessageBoxAsync(
                    "Permission denied!",
                    "You don't have any permission to Edit Mechanic.");
            }
        }
        catch (Exception ex)
        {
            snackbar.Add(ex.Message, Severity.Warning);
        }
        await Task.Delay(200);
        _busy = false;
    }
}
