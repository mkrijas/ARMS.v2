@page "/mechanics"
@using System.Threading;
@inject IMechanicService Iservice
@inject MudBlazor.ISnackbar snackbar
@attribute [Authorize]
@inject AuthenticationStateProvider auth
@inject IRoleService<RoleModel> Irole
@inject IDialogService DialogService

@if (_isLoading)
{
    <div @key="@("loader")" style="display: flex; justify-content: center; align-items: center; min-height: 400px;">
        <LoaderComponent IsFullScreen="true" 
                        ShowLogo="false" 
                        Size="medium" 
                        LoadingText="Loading Mechanics" 
                        SubText="Please wait..." />
    </div>
}
else
{
    <div class="admin-page-container fade-in" @key="@("content")">
        <div class="admin-header-tiered mb-6">
            <div class="d-flex align-center justify-space-between">
                <div>
                    <MudText Typo="Typo.h4" Class="admin-title">Workshop Mechanics</MudText>
                    <MudText Typo="Typo.body2" Class="admin-subtitle">Manage specialized workforce and maintenance personnel assignments across facilities.</MudText>
                </div>
                <MudButton Disabled="@_busy" Variant="Variant.Filled" Color="Color.Primary" OnClick="Add" Class="admin-register-btn" StartIcon="@Icons.Material.Filled.Add">REGISTER MECHANIC</MudButton>
            </div>
        </div>

        <div class="admin-glass-card pa-6 mb-6">
            <MudGrid Spacing="3" Class="align-center">
                <MudItem xs="12" md="6">
                    <MudTextField @bind-Value="searchString" Placeholder="Search by Mechanic Name..." Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" AdornmentColor="Color.Primary" Variant="Variant.Outlined" Margin="Margin.Dense" Clearable="true" Class="modern-input"></MudTextField>
                </MudItem>
                <MudItem xs="12" md="6" Class="d-flex justify-end">
                    <div class="d-flex align-center gap-2">
                        <MudText Typo="Typo.caption" Class="admin-subtitle">ACTIVE PERSONNEL: @(collection?.Count ?? 0)</MudText>
                    </div>
                </MudItem>
            </MudGrid>
        </div>

        <div class="admin-glass-card overflow-hidden">
            <MudTable Items="@collection" Elevation="0" Filter="new Func<MechanicModel, bool>(search)" @bind-model="model" Hover="true" Breakpoint="Breakpoint.Sm" Class="modern-admin-table">
                <HeaderContent>
                    <MudTh><MudTableSortLabel SortBy="new Func<MechanicModel, object>(x=> x.MechanicName)" InitialDirection="SortDirection.Ascending"><span class="admin-header-text">MECHANIC NAME</span></MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<MechanicModel, object>(x=> x.WorkshopName)"><span class="admin-header-text">PRIMARY WORKSHOP</span></MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<MechanicModel, object>(x=> x.Remarks)"><span class="admin-header-text">SPECIFICATIONS</span></MudTableSortLabel></MudTh>
                    <MudTh Style="text-align: right;"><span class="admin-header-text">ACTIONS</span></MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Mechanic">
                        <div class="d-flex align-center">
                            <MudAvatar Color="Color.Primary" Variant="Variant.Filled" Size="Size.Small" Class="mr-3 fw-600">@(context.MechanicName?.Substring(0, 1).ToUpper())</MudAvatar>
                            <span class="admin-td-primary fw-600">@context.MechanicName</span>
                        </div>
                    </MudTd>
                    <MudTd DataLabel="Workshop"><span class="fw-500">@context.WorkshopName</span></MudTd>
                    <MudTd DataLabel="Remarks"><span class="opacity-70">@context.Remarks</span></MudTd>
                    <MudTd DataLabel="Actions" Style="text-align: right;">
                        <MudTooltip Text="Update Profile">
                            <MudIconButton OnClick="@(()=> Edit(context))" Color="Color.Primary" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Variant="Variant.Text" />
                        </MudTooltip>
                        <MudTooltip Text="Facility Transfer">
                            <MudIconButton OnClick="@(()=> Transfer(context))" Color="Color.Info" Icon="@Icons.Material.Filled.MoveUp" Size="Size.Small" Variant="Variant.Text" />
                        </MudTooltip>
                        <MudTooltip Text="Decommission Record">
                            <MudIconButton OnClick="@(()=> Delete(context))" Color="Color.Error" Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Variant="Variant.Text" />
                        </MudTooltip>
                    </MudTd>
                </RowTemplate>
                <PagerContent>
                    <div class="pa-4">
                        <MudTablePager PageSizeOptions="new int[] { 10, 20, 50, 100 }" />
                    </div>
                </PagerContent>
            </MudTable>
        </div>
    </div>
}



@code {

    private bool _isLoading = true;
    private DateTime _loadStartTime;

    private MechanicModel model;
    private List<MechanicModel> collection = new();
    private string searchString = string.Empty;
    private bool _busy;

    public bool HasPermissionMechanicServiceDelete { get; set; } = false;
    public int MechanicTypeID = 78;

    // Initialization logic for the component
    protected override async Task OnInitializedAsync()
    {
        _loadStartTime = DateTime.Now;
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionMechanicServiceDelete = await Irole.HasClaim(MechanicTypeID.ToString(), "Delete", ctc.Token);

        model = new();
        GetAll();
        await EnsureMinimumLoadTime();
        _isLoading = false;
    }

    private async Task EnsureMinimumLoadTime()
    {
        var elapsed = (DateTime.Now - _loadStartTime).TotalMilliseconds;
        if (elapsed < 100)
        {
            await Task.Delay(100 - (int)elapsed);
        }
    }

    // Method to retrieve all mechanics from the service
    private void GetAll()
    {
        collection = Iservice.Select().ToList(); // Load mechanics from the service into the collection
    }

    // Method to add a new mechanic
    private async Task Add()
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        _busy = true;
        var parameters = new DialogParameters();
        parameters.Add("model", new MechanicModel());
        DialogOptions maxWidth = new DialogOptions() { MaxWidth = MaxWidth.Medium, FullWidth = true };
        var result = await DialogService.ShowAsync<MechanicEditDialog>("Add Mechanic", parameters, maxWidth);
        var data = await result.Result;
        GetAll();
        await Task.Delay(200);
        _busy = false;
    }

    // Method to edit an existing mechanic
    private async Task Edit(MechanicModel mechanic)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        _busy = true;
        var parameters = new DialogParameters();
        parameters.Add("model", mechanic.Clone());
        DialogOptions maxWidth = new DialogOptions() { MaxWidth = MaxWidth.Medium, FullWidth = true };
        var result = await DialogService.ShowAsync<MechanicEditDialog>("Edit Mechanic", parameters, maxWidth);
        var data = await result.Result;
        GetAll();
        await Task.Delay(200);
        _busy = false;
    }

    // Method to delete a mechanic
    private async Task Delete(MechanicModel model)
    {
        if(HasPermissionMechanicServiceDelete)
        {
        bool? result = await DialogService.ShowMessageBoxAsync(
            "Warning !",
            "Are you sure, you want to delete - " + model.MechanicName + " (" + model.WorkshopName + ") ?");
        if (result == true)
        {
            var authprov = await auth.GetAuthenticationStateAsync();
            var user = authprov.User;
            Iservice.Delete(model.MechanicID, user.Identity.Name);
            snackbar.Add("Deleted Successfully", Severity.Success);
        }
        }
        else
        {
            bool? result = await DialogService.ShowMessageBoxAsync(
                "Permission denied!",
                "You don't have any permission to Delete Mechanic.");
        }
        GetAll();
    }

    // Delete the mechanic using the service 
    private bool search(MechanicModel model)
    {
        if (model.MechanicName != null && model.MechanicName.Contains(searchString, StringComparison.OrdinalIgnoreCase))
        {
            return true;
        }
        return false;
    }

    private async Task Transfer(MechanicModel mechanic)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        _busy = true;
        var parameters = new DialogParameters();
        parameters.Add("mechanicModel", mechanic.Clone());
        DialogOptions maxWidth = new DialogOptions() { MaxWidth = MaxWidth.Medium, FullWidth = true };
        var result = await DialogService.ShowAsync<MechanicTransferDialog>("Edit Mechanic", parameters, maxWidth);
        var data = await result.Result;
        GetAll();
        await Task.Delay(200);
        _busy = false;
    }
}
