@using System.Threading;
@inject AuthenticationStateProvider auth
@inject IMechanicService Iservice
@inject IWorkshopService Iworkshop
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject IRoleService<RoleModel> Irole

<MudDialog Class="admin-dialog-glass">
    <TitleContent>
        <div class="header-section mb-2 pt-4 px-4">
            <div class="d-flex align-center justify-space-between">
                <div class="d-flex align-center">
                    <div class="icon-badge primary-badge mr-4">
                        <div class="admin-header-icon-badge mb-3">
                            <MudIcon Icon="@Icons.Material.Filled.TransferWithinAStation" Color="Color.Secondary" Style="font-size: 3rem;" />
                        </div>
                    </div>
                    <div>
                        <MudText Typo="Typo.h5" Class="admin-title"><b>Personnel Realignment</b></MudText>
                        <MudText Typo="Typo.body2" Class="admin-subtitle">Authorize and document the inter-workshop transfer of maintenance technical staff.</MudText>
                    </div>
                </div>
            </div>
            <div class="title-accent mt-4"></div>
        </div>
    </TitleContent>
    <DialogContent>
        <MudContainer Class="admin-dialog-container">
            <div class="dialog-content-wrapper fade-in">
                <EditForm id="formMechanicTransfer" Model="@model" OnValidSubmit="Submit">
                    <ObjectGraphDataAnnotationsValidator />
                    
                    <div class="admin-glass-card pa-6 mb-6">
                        <div class="d-flex align-center mb-6">
                            <div class="icon-badge primary-badge-soft mr-3">
                                <MudIcon Icon="@Icons.Material.Filled.Person" Size="Size.Small" />
                            </div>
                            <span class="admin-section-label mb-0">Technical Personnel Identity</span>
                        </div>

                        <MudGrid Spacing="3">
                            <MudItem xs="12" md="6">
                                <MudTextField Value="model.MechanicName" Label="Technician Name" Variant="Variant.Outlined" Margin="Margin.Dense" ReadOnly Class="modern-input" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Badge" />
                            </MudItem>
                            <MudItem xs="12" md="6">
                                <MudDatePicker Label="Realignment Date" Variant="Variant.Outlined" Margin="Margin.Dense" DisableToolbar="true" Editable="true" @bind-Date="model.TransferredDate" DateFormat="dd/MM/yyyy" Class="modern-input" AdornmentIcon="@Icons.Material.Filled.Event" />
                            </MudItem>
                        </MudGrid>
                    </div>

                    <div class="admin-glass-card pa-6 mb-6">
                        <div class="d-flex align-center mb-6">
                            <div class="icon-badge secondary-badge-soft mr-3">
                                <MudIcon Icon="@Icons.Material.Filled.Lan" Size="Size.Small" />
                            </div>
                            <span class="admin-section-label mb-0">Workshop Logistics</span>
                        </div>

                        <MudGrid Spacing="3">
                            <MudItem xs="12" md="6">
                                <MudTextField Value="model.CurrentWorkshopName" Label="Current Origin Workshop" Variant="Variant.Outlined" Margin="Margin.Dense" ReadOnly Class="modern-input" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.HomeRepairService" />
                            </MudItem>
                            <MudItem xs="12" md="6">
                                <MudSelect For="@(() => model.DestinationWorkshopID)" Label="Target Destination Workshop" Variant="Variant.Outlined" Margin="Margin.Dense" @bind-Value="model.DestinationWorkshopID" T="int?" AnchorOrigin="Origin.BottomCenter" Class="modern-input" AdornmentIcon="@Icons.Material.Filled.MoveToInbox" Required>
                                    @foreach (WorkshopModel ditem in DestinationWorkshopList)
                                    {
                                        <MudSelectItem Value="@ditem.WorkshopID">@ditem.WorkshopName</MudSelectItem>
                                    }
                                </MudSelect>
                            </MudItem>
                        </MudGrid>
                    </div>

                    <div class="admin-glass-card pa-6">
                        <div class="d-flex align-center mb-6">
                            <div class="icon-badge info-badge-soft mr-3">
                                <MudIcon Icon="@Icons.Material.Filled.Comment" Size="Size.Small" />
                            </div>
                            <span class="admin-section-label mb-0">Administrative Remarks</span>
                        </div>
                        <MudTextField @bind-Value="model.Remarks" Label="Transfer Rationale & Notes" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.Remarks)" Class="modern-input" Placeholder="Enter detailed transfer justification..." />
                    </div>
                </EditForm>
            </div>
        </MudContainer>
    </DialogContent>
    <DialogActions>
        <div class="d-flex w-100 px-4 pb-4 align-center gap-3">
            <MudSpacer></MudSpacer>
            <MudButton @onclick="Cancel" Variant="Variant.Outlined" Color="Color.Default" Style="border-radius: 12px; font-weight: 700; text-transform: none; border-color: rgba(0,0,0,0.15);">Cancel</MudButton>
            <MudButton Disabled="@_busy" form="formMechanicTransfer" Variant="Variant.Filled" ButtonType="ButtonType.Submit" Color="Color.Success" Style="background: var(--mud-palette-success); color: white; font-weight: 800; border-radius: 12px; text-transform: none; white-space: nowrap; padding: 8px 24px;" StartIcon="@Icons.Material.Filled.DoneAll">Submit</MudButton>
        </div>
    </DialogActions>
</MudDialog>

@code {

    [CascadingParameter] IMudDialogInstance MudDialog { get; set; }
    [Parameter]
    public MechanicModel mechanicModel { get; set; } = new();
    public MechanicTransferModel model { get; set; } = new MechanicTransferModel();
    private List<WorkshopModel> DestinationWorkshopList = new();
    private bool _busy;
    public bool HasPermissionMechanicServiceEdit { get; set; } = false;
    public int MechanicTypeID = 78;

    // Lifecycle method called when the component is initializedc
    protected override async Task OnInitializedAsync()
    {
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionMechanicServiceEdit = await Irole.HasClaim(MechanicTypeID.ToString(), "Edit", ctc.Token);

        model.MechanicID = mechanicModel.MechanicID;
        model.MechanicName = mechanicModel.MechanicName;
        model.CurrentWorkshopID = mechanicModel.WorkshopID;
        model.CurrentWorkshopName = mechanicModel.WorkshopName;

        DestinationWorkshopList = Iworkshop.Select(null).ToList();
    }

    void Cancel()
    {
        MudDialog.Cancel();
    }

    public async Task Submit()
    {
        if (_busy)
        {
            Snackbar.Add("Please wait while form is being submitted!", Severity.Warning);
            return;
        }

        if (model.MechanicID == null)
        {
            bool? result = await DialogService.ShowMessageBoxAsync(
                "Warning",
                "Please, Select Driver.",
                yesText: "OK");
            return;
        }
        if (model.DestinationWorkshopID == null)
        {
            bool? result = await DialogService.ShowMessageBoxAsync(
                "Warning",
                "Select workshop !.",
                yesText: "OK");
            return;
        }

        try
        {
            if (HasPermissionMechanicServiceEdit)
            {
                _busy = true;
                var authprov = await auth.GetAuthenticationStateAsync();
                model.UserInfo.UserID = authprov.User.Identity.Name;
                
                Iservice.Transfer(model);
                Snackbar.Add("Transferred successfully", Severity.Success);
            }
            else
            {
                bool? result = await DialogService.ShowMessageBoxAsync(
                    "Permission denied!",
                    "You don't have any permission to Edit Mechanic.");
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally
        {
            await Task.Delay(200);
            _busy = false;
        }
        MudDialog.Close(model);
    }
}
