@page "/jobs"
@inject IRepairWorkService Iservice
@inject MudBlazor.ISnackbar snackbar
@attribute [Authorize]
@inject AuthenticationStateProvider auth
@using System.Threading;
@inject IRoleService<RoleModel> Irole
@inject IDialogService DialogService

<MudTable Items="@collection" Elevation="10" Filter="new Func<RepairJobModel, bool>(search)" @bind-model="model">
    <ToolBarContent>
        <MudText Typo="Typo.h6">Jobs</MudText>
        <MudIconButton Disabled="@_busy" Icon="@Icons.Material.Filled.Add" Title="Add" @onclick="(()=>Edit(null))" Color="Color.Dark" Size="Size.Small"></MudIconButton>
        <MudSpacer></MudSpacer>
        <MudTextField @bind-Value="searchString" Placeholder="Search... " Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0"></MudTextField>
    </ToolBarContent>
    <HeaderContent>
        <MudTh><MudTableSortLabel SortBy="new Func<RepairJobModel, object>(x=> x.Title)" InitialDirection="SortDirection.Ascending">Job Name</MudTableSortLabel></MudTh>
        <MudTh><MudTableSortLabel SortBy="new Func<RepairJobModel, object>(x=> x.MechanicalHours)" InitialDirection="SortDirection.Ascending">Hours</MudTableSortLabel></MudTh>
        <MudTh><MudTableSortLabel SortBy="new Func<RepairJobModel, object>(x=> x.JobCode)" InitialDirection="SortDirection.Ascending">Code</MudTableSortLabel></MudTh>
        <MudTh>Actions</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd DataLabel="RepairJob">@context.Title</MudTd>
        <MudTd DataLabel="Hours">@context.MechanicalHours</MudTd>
        <MudTd DataLabel="Description">@context.JobCode</MudTd>
        <MudTd DataLabel="">
            <MudFab @onclick="@(()=> Edit(context.RepairJobID))" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Edit" Size="Size.Small" />
            <MudFab @onclick="@(()=> Delete(context))" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Delete" Size="Size.Small" />
        </MudTd>
    </RowTemplate>
    <PagerContent>
        <MudTablePager PageSizeOptions="new int[] { 10, 20, 50, 100 }" />
    </PagerContent>
</MudTable>

@code {

    private RepairJobModel model;
    private List<RepairJobModel> collection = new();
    private string searchString = string.Empty;
    private bool _busy;

    public bool HasPermissionRepairWorkServiceEdit { get; set; } = false;
    public bool HasPermissionRepairWorkServiceDelete { get; set; } = false;
    public int RepairWorkDocTypeID = 76;

    // Initialization logic for the component
    protected override async Task OnInitializedAsync()
    {
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionRepairWorkServiceEdit = await Irole.HasClaim(RepairWorkDocTypeID.ToString(), "Edit", ctc.Token);
        HasPermissionRepairWorkServiceDelete = await Irole.HasClaim(RepairWorkDocTypeID.ToString(), "Delete", ctc.Token);

        GetAll();
    }

    // Method to retrieve all repair jobs from the service
    private void GetAll()
    {
        collection = Iservice.SelectJob(null, null, null).ToList(); // Load repair jobs from the service into the collection
    }

    // Method to handle form submission when the form is valid
    private async Task OnValidSubmit(EditContext context)
    {
        var authprov = await auth.GetAuthenticationStateAsync();
        model.UserInfo.UserID = authprov.User.Identity.Name;
        try
        {
            if (HasPermissionRepairWorkServiceEdit)
            {
                model = Iservice.Update(model); // Update the repair job model
                snackbar.Add("Saved Successfully", Severity.Success);
                collection.Add(model);
                model = new();
            }
            else
            {
                bool? result = await DialogService.ShowMessageBox(
                    "Permission denied!",
                    "You don't have any permission to Edit RepairWork.");
            }
        }
        catch (Exception ex)
        {
            snackbar.Add(ex.Message, Severity.Warning);
        }
    }

    // Method to edit an existing repair job
    private async Task Edit(int? id)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        if (HasPermissionRepairWorkServiceEdit)
        {
            DialogParameters parms = new DialogParameters();
            if (id != null)
            {
                model = collection.FirstOrDefault(x => x.RepairJobID == id);
            }
            else
            {
                model = new();
            }
            _busy = true;
            parms.Add("model", model.Clone());
            var dialog = DialogService.Show<JobMasterDilogue>("Add Jobcard", parms);
            var result = await dialog.Result;
            if (!result.Canceled)
            {
                RepairJobModel editedModel = (RepairJobModel)result.Data;
                if (collection.Exists(x => x.RepairJobID == editedModel.RepairJobID))
                {
                    collection[collection.FindIndex(x => x.RepairJobID == editedModel.RepairJobID)] = editedModel;
                }
                else
                {
                    collection.Add(editedModel);
                }
            }
        }
        else
        {
            bool? result = await DialogService.ShowMessageBox(
                "Permission denied!",
                "You don't have any permission to Edit RepairWork.");
        }
        await Task.Delay(200);
        _busy = false;
    }

    // Method to delete a repair job
    private async Task Delete(RepairJobModel model)
    {
        if (HasPermissionRepairWorkServiceDelete)
        {
            bool? result = await DialogService.ShowMessageBox(
                "Warning !",
                "Are you sure, you want to delete - " + model.Title + " ?");
            if (result == true)
            {
                var authprov = await auth.GetAuthenticationStateAsync();
                var user = authprov.User;
                Iservice.Delete(model.RepairJobID, user.Identity.Name); // Delete the repair job using the service
                snackbar.Add("Deleted Successfully", Severity.Success);
            }
        }
        else
        {
            bool? result = await DialogService.ShowMessageBox(
                "Permission denied!",
                "You don't have any permission to Delete RepairWork.");
        }
        GetAll();
    }

    // Method to search for repair jobs based on the search string
    private bool search(RepairJobModel model)
    {
        if (model.Title != null && 
             (model.Title.Contains(searchString, StringComparison.OrdinalIgnoreCase) || model.JobCode.Contains(searchString, StringComparison.OrdinalIgnoreCase)))
        {
            return true;
        }
        return false;
    }
}

