@inject IJobcardService Iservice
@inject MudBlazor.ISnackbar snackbar

<DialogForm @ref="@dialogForm" Title="Task Completion Audit" Subtitle="Detailed overview of finalized operational tasks and resource allocation." Icon="@Icons.Material.Filled.FactCheck" AdminStyle="true" IsView="true">
    <FormContent>
        <div class="dialog-content-wrapper fade-in">
            <div class="admin-glass-card pa-0 overflow-hidden">
                <MudTable T="JobInProgressModel" Items="@Jobs" Hover="true" Elevation="0" Class="modern-admin-table no-border-radius">
                    <HeaderContent>
                        <MudTh><span class="admin-header-text">TASK IDENTIFIER</span></MudTh>
                        <MudTh><span class="admin-header-text">TEMPORAL WINDOW</span></MudTh>
                        <MudTh Style="text-align: right;"><span class="admin-header-text">ELAPSED TIME</span></MudTh>
                        <MudTh><span class="admin-header-text">ASSIGNED TECHNICIAN</span></MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="RepairJobTitle"><span class="fw-700 color-primary">@context.RepairJobTitle</span></MudTd>
                        <MudTd DataLabel="Timeline">
                            <div class="d-flex flex-column">
                                <span class="small opacity-70">S: @context.CreatedOn?.ToString("dd/MM/yyyy HH:mm")</span>
                                <span class="small opacity-70">F: @context.FinishedOn?.ToString("dd/MM/yyyy HH:mm")</span>
                            </div>
                        </MudTd>
                        <MudTd DataLabel="TimeTaken" Style="text-align: right;">
                            <span class="fw-700">@context.TimeTaken</span>
                            <span class="ml-1 opacity-50 small">HRS</span>
                        </MudTd>
                        <MudTd DataLabel="Mechanic">
                            <div class="d-flex align-center">
                                <MudIcon Icon="@Icons.Material.Filled.Person" Size="Size.Small" Color="Color.Primary" Class="mr-2" />
                                <span class="fw-500">@context.Mechanic</span>
                            </div>
                        </MudTd>
                    </RowTemplate>
                    <NoRecordsContent>
                        <div class="pa-12 text-center color-muted border-dashed m-4 rounded-lg">
                            <MudIcon Icon="@Icons.Material.Filled.Inbox" Size="Size.Large" Class="mb-2 opacity-30" />
                            <MudText Typo="Typo.body2">No task execution history available for this job card.</MudText>
                        </div>
                    </NoRecordsContent>
                </MudTable>
            </div>
        </div>
    </FormContent>
    <Actions>
        <MudButton Variant="Variant.Text" OnClick="@(()=> dialogForm.Cancel())" Class="px-8">Close Audit</MudButton>
    </Actions>
</DialogForm>

@code {
    private DialogForm dialogForm;

    [Parameter]
    public JobcardModel model { get; set; }
    public int BranchID { get; set; }
    public int JobcardID{ get; set; }

    private bool _busy;

    [CascadingParameter] IMudDialogInstance MudDialog { get; set; }
    private HashSet<JobInProgressModel> selectedItems = new();
    private List<JobInProgressModel> Jobs = new();

    private bool Local;

    // Initialization logic for the component
    protected override void OnInitialized()
    {
        Jobs = Iservice.GetJobListByJobCardID(model.JobcardID).ToList();
    }

    void OnRowClick(TableRowClickEventArgs<AssetPOModel> args)
    {
    }
}
