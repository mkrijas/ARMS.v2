@inject IWorkshopService Iservice
@inject MudBlazor.ISnackbar snackbar
@attribute [Authorize]
@inject AuthenticationStateProvider auth

<MudDialog Class="admin-dialog-glass">
    <TitleContent>
        <div class="header-section mb-2 pt-4 px-4">
            <div class="d-flex align-center justify-space-between">
                <div class="d-flex align-center">
                    <div class="icon-badge primary-badge mr-4">
                        <div class="admin-header-icon-badge mb-3">
                            <MudIcon Icon="@Icons.Material.Filled.Warehouse" Color="Color.Secondary" Style="font-size: 3rem;" />
                        </div>
                    </div>
                    <div>
                        <MudText Typo="Typo.h5" Class="admin-title"><b>Workshop Configuration</b></MudText>
                        <MudText Typo="Typo.body2" Class="admin-subtitle">Configure maintenance facility parameters and vendor linkages.</MudText>
                    </div>
                </div>
            </div>
            <div class="title-accent mt-4"></div>
        </div>
    </TitleContent>
    <DialogContent>
        <MudContainer Class="admin-dialog-container">
            <div class="dialog-content-wrapper fade-in">
                <EditForm id="formworkshop" Model="@model" OnValidSubmit="OnValidSubmit">
                    <DataAnnotationsValidator />
                    
                    <div class="admin-glass-card pa-6">
                        <div class="d-flex align-center mb-6">
                            <div class="icon-badge primary-badge-soft mr-3">
                                <MudIcon Icon="@Icons.Material.Filled.Info" Size="Size.Small" />
                            </div>
                            <span class="admin-section-label mb-0">Facility Blueprint</span>
                        </div>

                        <MudGrid Spacing="3">
                            <MudItem xs="12" md="6">
                                <MudTextField @bind-Value="@model.WorkshopName" Label="Workshop Designation" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.WorkshopName)" Class="modern-input" Placeholder="Enter name" />
                            </MudItem>
                            <MudItem xs="12" md="6">
                                <MudSelect For="@(() => model.WorkshopType)" Label="Internal/External Type" @bind-Value="model.WorkshopType" Variant="Variant.Outlined" Margin="Margin.Dense" Class="modern-input" AdornmentIcon="@Icons.Material.Filled.CompareArrows">
                                    <MudSelectItem Value="@("Inhouse")">Inhouse Facility</MudSelectItem>
                                    <MudSelectItem Value="@("Outside")">Third-Party Vendor</MudSelectItem>
                                </MudSelect>
                            </MudItem>
                            <MudItem xs="12" md="6">
                                <PartySelector For="@(() => model.Party)" Value="model.Party" ValueChanged="PartySelected" NatureOfBusiness="Supplier" BranchID="BranchID" Class="modern-selector" />
                            </MudItem>
                            <MudItem xs="12" md="6">
                                <MudNumericField HideSpinButtons="true" @bind-Value="@model.ContactNumber" MaxLength="10" Label="Direct Hotline" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.ContactNumber)" Class="modern-input" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Phone" />
                            </MudItem>
                        </MudGrid>
                    </div>
                </EditForm>
            </div>
        </MudContainer>
    </DialogContent>
    <DialogActions>
        <div class="d-flex w-100 px-4 pb-4 align-center gap-3">
            <MudSpacer></MudSpacer>
            <MudButton @onclick="Cancel" Variant="Variant.Outlined" Color="Color.Default" Style="border-radius: 12px; font-weight: 700; text-transform: none; border-color: rgba(0,0,0,0.15);">Cancel</MudButton>
            <MudButton Disabled="@_busy" form="formworkshop" Variant="Variant.Filled" ButtonType="ButtonType.Submit" Color="Color.Success" Style="background: var(--mud-palette-success); color: white; font-weight: 800; border-radius: 12px; text-transform: none; white-space: nowrap; padding: 8px 24px;" StartIcon="@Icons.Material.Filled.DoneAll">Submit</MudButton>
        </div>
    </DialogActions>
</MudDialog>

@code {

    private void Cancel()
    {
        MudDialog.Cancel();
    }
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; }
    [Parameter]
    public WorkshopModel model { get; set; }
    private List<WorkshopModel> collection = new();
    private string searchString = string.Empty;
    private bool _busy;

    int? BranchID;

    // Lifecycle method that runs when the component is initialized
    protected override async Task OnInitializedAsync()
    {
        var authProv =  await auth.GetAuthenticationStateAsync();
       BranchID =   int.Parse(authProv.User.Claims.First(x => x.Type == "BranchID").Value);

        GetAll();

    }

    // Method to retrieve all workshops from the service
    private void GetAll()
    {
        collection = Iservice.Select(null).ToList();
    }

    // Method to handle the selection of a party
    private void PartySelected(PartyModel party)
    {
        model.Party = party;
        model.PartyID = party?.PartyID;
    }

    // Method to handle form submission when the form is valid
    private async Task OnValidSubmit(EditContext context)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is being submitted!", Severity.Warning);
            return;
        }
        _busy = true;
        MudDialog.Close(model);
        await Task.Delay(200);
        _busy = false;
    }

    // Method to filter workshops based on the search string
    private bool search(WorkshopModel model)
    {
        if (model.WorkshopName != null && model.WorkshopName.Contains(searchString, StringComparison.OrdinalIgnoreCase))
        {
            return true;
        }
        return false;
    }
}
