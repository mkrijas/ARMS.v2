@inject IWorkshopService Iservice
@inject MudBlazor.ISnackbar snackbar
@attribute [Authorize]
@inject AuthenticationStateProvider auth

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            Workshop
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudContainer>
            <EditForm id="formworkshop" Model="@model" OnValidSubmit="OnValidSubmit">
                <DataAnnotationsValidator />
                <ValidationSummary />
                <MudContainer>
                    <MudGrid Spacing="4">
                        <MudItem xs="12" md="6">
                            <MudTextField @bind-Value="@model.WorkshopName" Label="Workshop Name" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.WorkshopName)"></MudTextField>
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <MudSelect Label="Select Type" @bind-Value="model.WorkshopType" Variant="Variant.Outlined" Margin="Margin.Dense"   AdornmentColor="Color.Secondary">
                                <MudSelectItem Value="@("Inhouse")">Inhouse</MudSelectItem>
                                <MudSelectItem Value="@("Outside")">Outside</MudSelectItem>
                            </MudSelect>
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <PartySelector Value="model.Party" ValueChanged="PartySelected" NatureOfBusiness="Supplier" BranchID="BranchID"></PartySelector>
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <MudNumericField HideSpinButtons="true" @bind-Value="@model.ContactNumber" MaxLength="10" Label="Contact" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.ContactNumber)"></MudNumericField>
                        </MudItem>
                    </MudGrid>
                </MudContainer>
            </EditForm>
        </MudContainer>
    </DialogContent>
    <DialogActions>
        <MudButton Disabled="@_busy" form="formworkshop" Variant="Variant.Filled" Color="Color.Success" ButtonType="ButtonType.Submit">Save</MudButton>
    </DialogActions>
</MudDialog>

@code {

    [CascadingParameter] IMudDialogInstance MudDialog { get; set; }
    [Parameter]
    public WorkshopModel model { get; set; }
    private List<WorkshopModel> collection = new();
    private string searchString = string.Empty;
    private bool _busy;

    int? BranchID;

    // Lifecycle method that runs when the component is initialized
    protected override async Task OnInitializedAsync()
    {
        var authProv =  await auth.GetAuthenticationStateAsync();
       BranchID =   int.Parse(authProv.User.Claims.First(x => x.Type == "BranchID").Value);

        GetAll();

    }

    // Method to retrieve all workshops from the service
    private void GetAll()
    {
        collection = Iservice.Select(null).ToList();
    }

    // Method to handle the selection of a party
    private void PartySelected(PartyModel party)
    {
        model.Party = party;
        model.PartyID = party?.PartyID;
    }

    // Method to handle form submission when the form is valid
    private async Task OnValidSubmit(EditContext context)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is being submitted!", Severity.Warning);
            return;
        }
        _busy = true;
        MudDialog.Close(model);
        await Task.Delay(200);
        _busy = false;
    }

    // Method to filter workshops based on the search string
    private bool search(WorkshopModel model)
    {
        if (model.WorkshopName != null && model.WorkshopName.Contains(searchString, StringComparison.OrdinalIgnoreCase))
        {
            return true;
        }
        return false;
    }
}
