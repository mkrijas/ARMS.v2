@inject IWorkshopService Iservice
@inject IPartyService Iparty;
@inject IGstService Igst;
@inject MudBlazor.ISnackbar snackbar
@attribute [Authorize]
@inject AuthenticationStateProvider auth


<MudDialog >
 
    <DialogActions>
            <EditForm Model="@model" OnValidSubmit="OnValidSubmit">
                <DataAnnotationsValidator />
                <ValidationSummary />
               
                <MudCardContent>
                    <MudGrid Spacing="4">
                        <MudItem xs="12" md="6">
                            <MudTextField @bind-Value="@model.WorkshopName" Label="Workshop Name" Variant="Variant.Outlined" Margin="Margin.Normal" For="@(() => model.WorkshopName)"></MudTextField>
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <MudSelect Label="Select Type" @bind-Value="model.WorkshopType" Variant="Variant.Outlined" Margin="Margin.Dense" OffsetY="true" Direction="Direction.Top" AdornmentColor="Color.Secondary">

                                <MudSelectItem Value="@("Inhouse")">Inhouse</MudSelectItem>
                                <MudSelectItem Value="@("Outside")">Outside</MudSelectItem>
                            </MudSelect>
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <MudAutocomplete T="PartyModel" Variant="Variant.Outlined" Label="Party" Value="SelectedParty" ValueChanged="PartyChanged" ResetValueOnEmptyText="true"
                                             SearchFunc="SearchParty" ToStringFunc="@(e => e == null ? null : $"{e.PartyName}")"></MudAutocomplete>
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <MudSelect Label="Gst Number"  @bind-Value="model.GstID" Variant="Variant.Outlined" Margin="Margin.Dense" OffsetY="true" Direction="Direction.Top" AdornmentColor="Color.Secondary">

                                @foreach (var item in Gsts)
                                {
                                    <MudSelectItem Value="@item.GstID">@item.GstID</MudSelectItem>
                                }
                            </MudSelect>
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <MudTextField @bind-Value="@model.ContactNumber" Label="Contact" Variant="Variant.Outlined" Margin="Margin.Normal" For="@(() => model.ContactNumber)"></MudTextField>
                        </MudItem>
                    </MudGrid>

                    <MudButton Variant="Variant.Filled" Color="Color.Success" ButtonType="ButtonType.Submit">Save</MudButton>

                </MudCardContent>
            </EditForm>
           </DialogActions>
           </MudDialog>

@code {
    [Parameter]
    public WorkshopModel model { get; set;}
    private List<WorkshopModel> collection = new();
    private PartyModel SelectedParty = new();
    private List<PartyModel> Parties = new();
    private List<GstModel> Gsts = new();
        private string searchString = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        
        GetAll();

        await foreach (var item in Iparty.Select(null))
        { Parties.Add(item); }
    }

    private void GetAll()
    {
        collection = Iservice.Select(null).ToList();
    }

 private async Task OnValidSubmit(EditContext context)
    {
        var authprov = await auth.GetAuthenticationStateAsync();
        model.UserInfo.UserID = authprov.User.Identity.Name;

        try
        {
            model = Iservice.Update(model);
            snackbar.Add("Saved Successfully", Severity.Success);
            collection.Add(model);

            model = new();
        }
        catch (Exception ex)
        {
            snackbar.Add(ex.Message, Severity.Warning);
        }
    }
     private async Task PartyChanged(PartyModel obj)
    {
        SelectedParty = obj;
        model.PartyID = obj?.PartyID;

        
        model.GstID = null;
        await foreach (var item in Igst.SelectByParty(model.PartyID))
        {
            Gsts.Add(item);
        }

        if (Gsts.Count() == 1)
        {
            model.GstID = Gsts.First().GstID;            
        }
    }


    private bool search(WorkshopModel model)
    {
        if (model.WorkshopName != null && model.WorkshopName.Contains(searchString, StringComparison.OrdinalIgnoreCase))
        {
            return true;
        }
        return false;
    }
    
    private async Task<IEnumerable<PartyModel>> SearchParty(string searchString)
    {
        return await Task.FromResult(Parties.Where(x => x.PartyName.Contains(searchString == null ? string.Empty : searchString, StringComparison.InvariantCultureIgnoreCase)));
    }


}
