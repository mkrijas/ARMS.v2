@inject IWorkshopService Iservice
@inject MudBlazor.ISnackbar snackbar
@attribute [Authorize]
@inject AuthenticationStateProvider auth


<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            Workshop
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudContainer>
            <EditForm id="formworkshop" Model="@model" OnValidSubmit="OnValidSubmit">
                <DataAnnotationsValidator />
                <ValidationSummary />
                <MudContainer>
                    <MudGrid Spacing="4">
                        <MudItem xs="12" md="6">
                            <MudTextField @bind-Value="@model.WorkshopName" Label="Workshop Name" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.WorkshopName)"></MudTextField>
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <MudSelect Label="Select Type" @bind-Value="model.WorkshopType" Variant="Variant.Outlined" Margin="Margin.Dense" OffsetY="true" Direction="Direction.Top" AdornmentColor="Color.Secondary">

                                <MudSelectItem Value="@("Inhouse")">Inhouse</MudSelectItem>
                                <MudSelectItem Value="@("Outside")">Outside</MudSelectItem>
                            </MudSelect>
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <PartySelector Value="model.Party" ValueChanged="PartySelected" NatureOfBusiness="Supplier"></PartySelector>
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <MudNumericField HideSpinButtons="true" @bind-Value="@model.ContactNumber" MaxLength="10" Label="Contact" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.ContactNumber)"></MudNumericField>
                        </MudItem>
                    </MudGrid>
                </MudContainer>
            </EditForm>
        </MudContainer>
    </DialogContent>
    <DialogActions>
        <MudButton Disabled="@_busy" form="formworkshop" Variant="Variant.Filled" Color="Color.Success" ButtonType="ButtonType.Submit">Save</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] MudDialogInstance MudDialog { get; set; }
    [Parameter]
    public WorkshopModel model { get; set;}
    private List<WorkshopModel> collection = new();
    private string searchString = string.Empty;
    private bool _busy;

    protected override void OnInitialized()
    {

        GetAll();        
    }

    private void GetAll()
    {
        collection = Iservice.Select(null).ToList();
    }

    private void PartySelected(PartyModel party)
    {
        model.Party = party;
        model.PartyID = party?.PartyID;
    }

    private async Task OnValidSubmit(EditContext context)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is being submitted!", Severity.Warning);
            return;
        }
        _busy = true;
        //var authprov = await auth.GetAuthenticationStateAsync();
        //model.UserInfo.UserID = authprov.User.Identity.Name;
        //model.PartyID = model.Party.PartyID;        
        //try
        //{
        //    model = Iservice.Update(model);
        //    snackbar.Add("Saved Successfully", Severity.Success);
        //    collection.Add(model);

        //    model = new();
        //}
        //catch (Exception ex)
        //{
        //    snackbar.Add(ex.Message, Severity.Warning);
        //}
        MudDialog.Close(model);

        await Task.Delay(2000);
        _busy = false;
    }  

    private bool search(WorkshopModel model)
    {
        if (model.WorkshopName != null && model.WorkshopName.Contains(searchString, StringComparison.OrdinalIgnoreCase))
        {
            return true;
        }
        return false;
    }

}
