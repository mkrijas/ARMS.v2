@page "/workshop"
@inject IWorkshopService Iservice
@inject IPartyService Iparty;
@inject MudBlazor.ISnackbar snackbar
@attribute [Authorize]
@inject AuthenticationStateProvider auth
@inject IDialogService DialogService
@using System.Threading;
@inject IRoleService<RoleModel> Irole

@if (_isLoading)
{
    <div @key="@("loader")" class="d-flex justify-center align-center" style="min-height: 400px;">
        <LoaderComponent IsFullScreen="false" ShowLogo="false" Size="medium" LoadingText="Synchronizing Workshop Masters" SubText="Retrieving latest workshop entity records..." />
    </div>
}
else
{
    <div class="admin-page-container fade-in" @key="@("content")">
        <div class="admin-header-tiered mb-6">
            <div class="d-flex align-center justify-space-between">
                <div>
                    <MudText Typo="Typo.h4" Class="admin-title">Workshop Master</MudText>
                    <MudText Typo="Typo.body2" Class="admin-subtitle">Maintain workshop database and contact information for maintenance activities.</MudText>
                </div>
                <MudButton Disabled="@_busy" Variant="Variant.Filled" Color="Color.Primary" OnClick="@(()=> OpenDialog(new WorkshopModel()))" Class="admin-register-btn" StartIcon="@Icons.Material.Filled.Add">ADD WORKSHOP</MudButton>
            </div>
        </div>

        <div class="admin-glass-card pa-6 mb-6">
            <MudGrid Spacing="3" Class="align-center">
                <MudItem xs="12" md="6">
                    <MudTextField @bind-Value="searchString" Placeholder="Search by Workshop Name..." Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" AdornmentColor="Color.Primary" Variant="Variant.Outlined" Margin="Margin.Dense" Clearable="true" Class="modern-input"></MudTextField>
                </MudItem>
            </MudGrid>
        </div>

        <div class="admin-glass-card overflow-hidden">
            <MudTable Items="@collection" Elevation="0" Filter="new Func<WorkshopModel, bool>(search)" @bind-model="model" Hover="true" Breakpoint="Breakpoint.Sm" Class="modern-admin-table">
                <HeaderContent>
                    <MudTh><MudTableSortLabel SortBy="new Func<WorkshopModel, object>(x=> x.WorkshopName)" InitialDirection="SortDirection.Ascending"><span class="admin-header-text">WORKSHOP NAME</span></MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<WorkshopModel, object>(x=> x.WorkshopType)"><span class="admin-header-text">TYPE</span></MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<WorkshopModel, object>(x=> x.ContactNumber)"><span class="admin-header-text">CONTACT</span></MudTableSortLabel></MudTh>
                    <MudTh Style="text-align: right;"><span class="admin-header-text">ACTIONS</span></MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Workshop"><span class="admin-td-primary fw-600">@context.WorkshopName</span></MudTd>
                    <MudTd DataLabel="Type">
                        <MudChip T="string" Size="Size.Small" Color="@(context.WorkshopType == "Internal" ? Color.Primary : Color.Secondary)" Variant="Variant.Text" Class="fw-600">@context.WorkshopType</MudChip>
                    </MudTd>
                    <MudTd DataLabel="contact">@context.ContactNumber</MudTd>
                    <MudTd DataLabel="Actions" Style="text-align: right;">
                        <MudTooltip Text="Edit Workshop">
                            <MudIconButton OnClick="@(()=> OpenDialog(context))" Color="Color.Primary" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Variant="Variant.Text" />
                        </MudTooltip>
                        <MudTooltip Text="Delete Record">
                            <MudIconButton OnClick="@(()=> Delete(context))" Color="Color.Error" Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Variant="Variant.Text" />
                        </MudTooltip>
                    </MudTd>
                </RowTemplate>
                <PagerContent>
                    <div class="pa-4">
                        <MudTablePager PageSizeOptions="new int[] { 10, 20, 50, 100 }" />
                    </div>
                </PagerContent>
            </MudTable>
        </div>
    </div>
}



@code {

    private bool _isLoading = true;
    private DateTime _loadStartTime;

    private WorkshopModel model;
    private List<WorkshopModel> collection = new();
    private PartyModel SelectedParty = new();
    private List<PartyModel> Parties = new();
    private string searchString = string.Empty;
    private bool _busy;

    public bool HasPermissionWorkshopServiceEdit { get; set; } = false;
    public bool HasPermissionWorkshopServiceDelete { get; set; } = false;
    public int WorkshopDocTypeID = 74;

    // Lifecycle method that runs when the component is initializedc
    protected override async Task OnInitializedAsync()
    {
        _loadStartTime = DateTime.Now;
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionWorkshopServiceEdit = await Irole.HasClaim(WorkshopDocTypeID.ToString(), "Edit", ctc.Token);
        HasPermissionWorkshopServiceDelete = await Irole.HasClaim(WorkshopDocTypeID.ToString(), "Delete", ctc.Token);

        model = new();
        GetAll();
        await EnsureMinimumLoadTime();
        _isLoading = false;
    }

    private async Task EnsureMinimumLoadTime()
    {
        var elapsed = (DateTime.Now - _loadStartTime).TotalMilliseconds;
        if (elapsed < 100)
        {
            await Task.Delay(100 - (int)elapsed);
        }
    }

    // Method to retrieve all workshops from the service
    private void GetAll()
    {
        collection = new List<WorkshopModel>();

        // fetch new workshop models
        foreach (var item in Iservice.Select(null))
        {
            collection.Add(item);
        }
    }

    // Method to open a dialog for adding or editing a workshop
    private async Task OpenDialog(WorkshopModel ws)
    {
        if (HasPermissionWorkshopServiceEdit)
        {
            if (_busy)
            {
                snackbar.Add("Please wait while form is closing!", Severity.Warning);
                return;
            }
            _busy = true;
            var authprov = await auth.GetAuthenticationStateAsync();
            var user = authprov.User;

            DialogParameters parms = new DialogParameters();
            parms.Add("model", ws.Clone());
            var dialog = await DialogService.ShowAsync<WorkshopDilogue>(ws.WorkshopID == null ? "ADD" : "EDIT", parms);
            var result = await dialog.Result;
            if (!result.Canceled)
            {
                WorkshopModel UpatedModel = (WorkshopModel)result.Data;
                UpatedModel.UserInfo.UserID = authprov.User.Identity.Name;
                try
                {
                    // Update the workshop model in the service
                    var ResultModel = Iservice.Update(UpatedModel);
                    if (ResultModel != null)
                    {
                        if (collection.Exists(x => x.WorkshopID == ResultModel.WorkshopID))
                        {
                            collection[collection.FindIndex(x => x.WorkshopID == ResultModel.WorkshopID)] = ResultModel;
                        }
                        else
                        {
                            collection.Add(ResultModel);
                        }
                        UpatedModel = new();
                        ResultModel = new();
                        model = new();
                        snackbar.Add("Saved Successfully", Severity.Success);
                    }
                }
                catch (Exception ex)
                {
                    snackbar.Add(ex.Message, Severity.Warning);
                }
            }
            await Task.Delay(200);
            _busy = false;
        }
        else
        {
            bool? result = await DialogService.ShowMessageBoxAsync(
                "Permission denied!",
                "You don't have any permission to Edit Workshop.");
        }
    }

    // Method to delete a workshop
    private async Task Delete(WorkshopModel model)
    {
        if (HasPermissionWorkshopServiceDelete)
        {
            bool? result = await DialogService.ShowMessageBoxAsync(
                "Warning !",
                "Are you sure, you want to delete - " + model.WorkshopName + " (" + model.WorkshopType + ") ?");
            if (result == true)
            {
                var authprov = await auth.GetAuthenticationStateAsync();
                var user = authprov.User;

                // Call the service to delete the workshop and get the result
                int value = Iservice.Delete(model.WorkshopID, user.Identity.Name);
                if (value != -1)
                {
                    if (collection != null && collection.Any(s => s.WorkshopID == model.WorkshopID))
                    {
                        collection.Remove(collection.FirstOrDefault(s => s.WorkshopID == model.WorkshopID));
                        snackbar.Add("Deleted Successfully", Severity.Success);
                    }
                }
            }
        }
        else
        {
            bool? result = await DialogService.ShowMessageBoxAsync(
                "Permission denied!",
                "You don't have any permission to Delete Workshop.");
        }
    }

    // Method to filter workshops based on the search string
    private bool search(WorkshopModel model)
    {
        if (model.WorkshopName != null && model.WorkshopName.Contains(searchString, StringComparison.OrdinalIgnoreCase))
        {
            return true;
        }
        return false;
    }
}

