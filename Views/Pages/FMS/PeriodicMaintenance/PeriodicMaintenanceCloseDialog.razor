@inject IPeriodicMaintenanceService Iservice
@inject MudBlazor.ISnackbar snackbar
@inject AuthenticationStateProvider auth
@using System.Threading;
@inject IRoleService<RoleModel> Irole
@inject IDialogService DialogService

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.AlarmAdd" Class="mr-3 mb-n1" />
            Close Maintenance Reminder for @PmiModel.RegNo
        </MudText>
    </TitleContent>
    <DialogContent>
        <EditForm id="formPmi" Model="@model" OnValidSubmit="OnValidSubmit">
            <ObjectGraphDataAnnotationsValidator />
            <ValidationSummary />
            <MudTextField Value="@PmiModel.Title" Label="Title" ReadOnly="true" />
            <MudTextField Value="@PmiModel.NDate" Label="Date for noitifiction" ReadOnly="true" />
            <MudTextField Value="@PmiModel.NAudometer" Label="Audometer for notification" ReadOnly="true" />
            <MudDatePicker @bind-Date="@model.Date" Label="Date of Maintenance" />
            <MudTextField @bind-Value="@model.Audometer" Label="Audometer Reading" />
        </EditForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Disabled="@_busy" form="formPmi" Variant="Variant.Filled" Color="Color.Success" ButtonType="ButtonType.Submit">Submit</MudButton>
    </DialogActions>
</MudDialog>

@code {

    [CascadingParameter] IMudDialogInstance MudDialog { get; set; }
    [Parameter] public PeriodicMaintenanceInitiateModel PmiModel { get; set; }
    public PeriodicMaintenanceConcludeModel model { get; set; } = new();
    private bool _busy;

    public bool HasPermissionPeriodicMaintenanceServiceEdit { get; set; } = false;
    public int PeriodicMaintenanceTypeID = 77;

    // Lifecycle method that runs when the component is initialized
    protected override async Task OnInitializedAsync()
    {
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionPeriodicMaintenanceServiceEdit = await Irole.HasClaim(PeriodicMaintenanceTypeID.ToString(), "Edit", ctc.Token);

        model.PMIID = PmiModel.PMIID;
    }

    // Method to cancel the dialog
    private void Cancel()
    {
        MudDialog.Cancel();
    }

    // Method to handle form submission when the form is valid
    private async Task OnValidSubmit(EditContext context)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is being submitted!", Severity.Warning);
            return;
        }
        _busy = true;
        if (HasPermissionPeriodicMaintenanceServiceEdit)
        {
            var authState = await auth.GetAuthenticationStateAsync();
            model.UserInfo.UserID = authState.User.Identity.Name;

            // Call the service to conclude the periodic maintenance
            model = Iservice.Conclude(model);
            snackbar.Add("Reminder Closed", Severity.Success);
            MudDialog.Close(DialogResult.Ok(model));
        }
        else
        {
            bool? result = await DialogService.ShowMessageBox(
                "Permission denied!",
                "You don't have any permission to Edit PeriodicMaintenance.");
        }
        await Task.Delay(200);
        _busy = false;
    }
}
