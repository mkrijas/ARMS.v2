@inject IPeriodicMaintenanceService Iservice
@inject MudBlazor.ISnackbar snackbar
@inject AuthenticationStateProvider auth
@using System.Threading;
@inject IRoleService<RoleModel> Irole
@inject IDialogService DialogService

<MudDialog Class="admin-dialog-glass">
    <TitleContent>
        <div class="header-section mb-2 pt-4 px-4">
            <div class="d-flex align-center justify-space-between">
                <div class="d-flex align-center">
                    <div class="icon-badge primary-badge mr-4">
                        <div class="admin-header-icon-badge mb-3">
                            <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Secondary" Style="font-size: 3rem;" />
                        </div>
                    </div>
                    <div>
                        <MudText Typo="Typo.h5" Class="admin-title"><b>Maintenance Decommissioning</b></MudText>
                        <MudText Typo="Typo.body2" Class="admin-subtitle">
                            Formalize the completion of periodic maintenance and synchronize asset thresholds.
                        </MudText>
                    </div>
                </div>
            </div>
            <div class="title-accent mt-4"></div>
        </div>
    </TitleContent>
    <DialogContent>
        <MudContainer Class="admin-dialog-container">
            <div class="dialog-content-wrapper fade-in">
                <EditForm id="formPmi" Model="@model" OnValidSubmit="OnValidSubmit">
                    <ObjectGraphDataAnnotationsValidator />
                    
                    <div class="admin-glass-card pa-6 mb-6">
                        <div class="d-flex align-center mb-6">
                            <div class="icon-badge primary-badge-soft mr-3">
                                <MudIcon Icon="@Icons.Material.Filled.History" Size="Size.Small" />
                            </div>
                            <span class="admin-section-label mb-0">Scheduled Reference</span>
                        </div>

                        <MudGrid Spacing="3">
                            <MudItem xs="12" md="12">
                                <MudTextField Value="@PmiModel.Title" Label="Task Identifier" ReadOnly="true" Variant="Variant.Outlined" Margin="Margin.Dense" Class="modern-input" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Label" />
                            </MudItem>
                            <MudItem xs="12" md="6">
                                <MudTextField Value="@PmiModel.NDate" Label="Target Compliance Date" ReadOnly="true" Variant="Variant.Outlined" Margin="Margin.Dense" Class="modern-input" AdornmentIcon="@Icons.Material.Filled.Event" />
                            </MudItem>
                            <MudItem xs="12" md="6">
                                <MudTextField Value="@PmiModel.NAudometer" Label="Target Odometer Threshold" ReadOnly="true" Variant="Variant.Outlined" Margin="Margin.Dense" Class="modern-input" AdornmentIcon="@Icons.Material.Filled.Speed" Adornment="Adornment.End" AdornmentText="KM" />
                            </MudItem>
                        </MudGrid>
                    </div>

                    <div class="admin-glass-card pa-6">
                        <div class="d-flex align-center mb-6">
                            <div class="icon-badge success-badge-soft mr-3">
                                <MudIcon Icon="@Icons.Material.Filled.AddTask" Size="Size.Small" />
                            </div>
                            <span class="admin-section-label mb-0">Completion Calibration</span>
                        </div>

                        <MudGrid Spacing="3">
                            <MudItem xs="12" md="6">
                                <MudDatePicker @bind-Date="@model.Date" Label="Actual Verification Date" Variant="Variant.Outlined" Margin="Margin.Dense" Class="modern-input" AdornmentIcon="@Icons.Material.Filled.Today" />
                            </MudItem>
                            <MudItem xs="12" md="6">
                                <MudTextField @bind-Value="@model.Audometer" Label="Final Odometer Reading" Variant="Variant.Outlined" Margin="Margin.Dense" Class="modern-input" Adornment="Adornment.End" AdornmentText="KM" />
                            </MudItem>
                        </MudGrid>
                    </div>
                </EditForm>
            </div>
        </MudContainer>
    </DialogContent>
    <DialogActions>
        <div class="d-flex w-100 px-4 pb-4 align-center gap-3">
            <MudSpacer></MudSpacer>
            <MudButton @onclick="Cancel" Variant="Variant.Outlined" Color="Color.Default" Style="border-radius: 12px; font-weight: 700; text-transform: none; border-color: rgba(0,0,0,0.15);">Cancel</MudButton>
            <MudButton Disabled="@_busy" form="formPmi" Variant="Variant.Filled" ButtonType="ButtonType.Submit" Color="Color.Success" Style="background: var(--mud-palette-success); color: white; font-weight: 800; border-radius: 12px; text-transform: none; white-space: nowrap; padding: 8px 24px;" StartIcon="@Icons.Material.Filled.DoneAll">Submit</MudButton>
        </div>
    </DialogActions>
</MudDialog>

@code {

    [CascadingParameter] IMudDialogInstance MudDialog { get; set; }
    [Parameter] public PeriodicMaintenanceInitiateModel PmiModel { get; set; }
    public PeriodicMaintenanceConcludeModel model { get; set; } = new();
    private bool _busy;

    public bool HasPermissionPeriodicMaintenanceServiceEdit { get; set; } = false;
    public int PeriodicMaintenanceTypeID = 77;

    // Lifecycle method that runs when the component is initialized
    protected override async Task OnInitializedAsync()
    {
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionPeriodicMaintenanceServiceEdit = await Irole.HasClaim(PeriodicMaintenanceTypeID.ToString(), "Edit", ctc.Token);

        model.PMIID = PmiModel.PMIID;
    }

    // Method to cancel the dialog
    private void Cancel()
    {
        MudDialog.Cancel();
    }

    // Method to handle form submission when the form is valid
    private async Task OnValidSubmit(EditContext context)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is being submitted!", Severity.Warning);
            return;
        }
        _busy = true;
        if (HasPermissionPeriodicMaintenanceServiceEdit)
        {
            var authState = await auth.GetAuthenticationStateAsync();
            model.UserInfo.UserID = authState.User.Identity.Name;

            // Call the service to conclude the periodic maintenance
            model = Iservice.Conclude(model);
            snackbar.Add("Reminder Closed", Severity.Success);
            MudDialog.Close(DialogResult.Ok(model));
        }
        else
        {
            bool? result = await DialogService.ShowMessageBoxAsync(
                "Permission denied!",
                "You don't have any permission to Edit PeriodicMaintenance.");
        }
        await Task.Delay(200);
        _busy = false;
    }
}
