@inject IPeriodicMaintenanceService Iservice
@inject MudBlazor.ISnackbar snackbar

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.AlarmAdd" Class="mr-3 mb-n1" />
            Create Maintenance Reminder for @model.RegNo
        </MudText>
    </TitleContent>
    <DialogContent>
        <EditForm id="formPmi" Model="@model" OnValidSubmit="OnValidSubmit">
            <ObjectGraphDataAnnotationsValidator />
            <ValidationSummary />
            <MudTextField @bind-Value="@model.Title" Label="Title" />
            <MudDatePicker @bind-Date="@model.NDate" Label="Date for noitifiction" />
            <MudTextField InputType="InputType.Number" @bind-Value="@model.NAudometer" Label="Audometer for notification " />
            <MudTextField @bind-Value="@model.Remarks" Label="Remarks" />
        </EditForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Disabled="@_busy" form="formPmi" Variant="Variant.Filled" Color="Color.Success" ButtonType="ButtonType.Submit">Submit</MudButton>
    </DialogActions>
</MudDialog>

@code {

    [CascadingParameter] MudDialogInstance MudDialog { get; set; }
    [Parameter] public PeriodicMaintenanceInitiateModel model { get; set; }
    private bool _busy;

    private void Cancel()
    {
        MudDialog.Cancel();
    }

    private async Task OnValidSubmit()
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is being submitted!", Severity.Warning);
            return;
        }
        _busy = true;

        model = Iservice.Update(model);
        MudDialog.Close(DialogResult.Ok(model));

        await Task.Delay(2000);
        _busy = false;
    }
}