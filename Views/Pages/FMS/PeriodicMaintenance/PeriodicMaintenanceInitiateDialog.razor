@inject IPeriodicMaintenanceService Iservice
@inject MudBlazor.ISnackbar snackbar
@using System.Threading;
@inject IRoleService<RoleModel> Irole
@inject IDialogService DialogService

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.AlarmAdd" Class="mr-3 mb-n1" />
            Create Maintenance Reminder for @model.RegNo
        </MudText>
    </TitleContent>
    <DialogContent>
        <EditForm id="formPmi" Model="@model" OnValidSubmit="OnValidSubmit">
            <ObjectGraphDataAnnotationsValidator />
            <ValidationSummary />
            <MudTextField @bind-Value="@model.Title" Label="Title" />
            <MudDatePicker @bind-Date="@model.NDate" Label="Date for noitifiction" />
            <MudTextField InputType="InputType.Number" @bind-Value="@model.NAudometer" Label="Audometer for notification " />
            <MudTextField @bind-Value="@model.Remarks" Label="Remarks" />
        </EditForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Disabled="@_busy" form="formPmi" Variant="Variant.Filled" Color="Color.Success" ButtonType="ButtonType.Submit">Submit</MudButton>
    </DialogActions>
</MudDialog>

@code {

    [CascadingParameter] MudDialogInstance MudDialog { get; set; }
    [Parameter] public PeriodicMaintenanceInitiateModel model { get; set; }
    private bool _busy;

    public bool HasPermissionPeriodicMaintenanceServiceEdit { get; set; } = false;
    public int PeriodicMaintenanceDocTypeID = 77;

    protected override async Task OnInitializedAsync()
    {
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionPeriodicMaintenanceServiceEdit = await Irole.HasClaim(PeriodicMaintenanceDocTypeID.ToString(), "Edit", ctc.Token);
    }

    private void Cancel()
    {
        MudDialog.Cancel();
    }

    private async Task OnValidSubmit()
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is being submitted!", Severity.Warning);
            return;
        }
        _busy = true;
        if (HasPermissionPeriodicMaintenanceServiceEdit)
        {
            model = Iservice.Update(model);
            MudDialog.Close(DialogResult.Ok(model));
        }
        else
        {
            bool? result = await DialogService.ShowMessageBox(
                "Permission denied!",
                "You dont have any permission to Edit PeriodicMaintenance.");
        }
        await Task.Delay(2000);
        _busy = false;
    }
}