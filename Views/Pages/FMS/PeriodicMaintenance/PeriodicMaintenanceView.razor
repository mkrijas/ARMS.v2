@page "/Reminders/{id:int}"
@page "/Reminders"
@using Views.Pages.FMS.Jobcard;
@attribute [Authorize]
@inject AuthenticationStateProvider auth
@inject NavigationManager navigationManager
@inject IPeriodicMaintenanceService Iservice
@inject ITripService Itrip
@inject IBreakdownService ibreakdownService
@inject ITruckService Itruck
@inject MudBlazor.ISnackbar snackbar
@inject IDialogService DialogService

<div class="admin-page-container">
    @if (_isLoading)
    {
        <div class="d-flex justify-center align-center" style="min-height: 400px;">
            <LoaderComponent IsFullScreen="false" ShowLogo="false" Size="medium" LoadingText="Synchronizing Reminders" SubText="Retrieving latest maintenance schedules..." />
        </div>
    }
    else
    {
        <div class="admin-header-tiered mb-6">
            <div class="d-flex align-center justify-space-between">
                <div>
                    <MudText Typo="Typo.h4" Class="admin-title">Maintenance Reminders</MudText>
                    <MudText Typo="Typo.body2" Class="admin-subtitle">Monitor and initiate periodic vehicle maintenance based on time or odometer thresholds.</MudText>
                </div>
                @if (SelectedTruck != null)
                {
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="CreateNew" Class="admin-register-btn" StartIcon="@Icons.Material.Filled.AddAlarm">NEW REMINDER</MudButton>
                }
            </div>
        </div>

        <div class="admin-glass-card pa-6 mb-8">
            <MudGrid Spacing="3" Class="align-center">
                <MudItem xs="12">
                    <div class="d-flex align-center">
                        <div class="flex-grow-1">
                            <TruckSelector Value="SelectedTruck" ValueChanged="TruckSelected" Filter="All"></TruckSelector>
                        </div>
                    </div>
                </MudItem>
            </MudGrid>
        </div>

        @if (PmList != null && PmList.Any())
        {
            <div class="fade-in">
                <MudGrid Spacing="4">
                    @foreach (var item in PmList)
                    {
                        <MudItem xs="12" md="4">
                            <div class="admin-glass-card h-100 overflow-hidden d-flex flex-column border-top-4" style="border-top: 4px solid var(--mud-palette-primary) !important;">
                                <div class="pa-4 border-bottom-subtle bg-light-primary d-flex align-center justify-space-between">
                                    <div class="d-flex align-center">
                                        <div class="pa-2 rounded-lg mr-3" style="background: rgba(var(--mud-palette-primary-rgb), 0.1);">
                                            <MudIcon Icon="@Icons.Material.Filled.Engineering" Color="Color.Primary" Size="Size.Small" />
                                        </div>
                                        <MudText Typo="Typo.subtitle1" Class="fw-700">@item.Title</MudText>
                                    </div>
                                    <MudTooltip Text="Close Reminder">
                                        <MudIconButton Disabled="@_busy" OnClick="@(() => CloseReminder(item))" Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" Size="Size.Small" Variant="Variant.Text" />
                                    </MudTooltip>
                                </div>
                                <div class="pa-4 flex-grow-1">
                                    <div class="mb-4">
                                        <MudText Typo="Typo.caption" Class="admin-subtitle uppercase">Scheduled Parameters</MudText>
                                        <div class="d-flex align-center mt-1">
                                            <div class="mr-4">
                                                <MudText Typo="Typo.caption" Class="opacity-60">Due Date</MudText>
                                                <MudText Typo="Typo.body2" Class="fw-600">@item.NDate</MudText>
                                            </div>
                                            <div>
                                                <MudText Typo="Typo.caption" Class="opacity-60">Odometer Threshold</MudText>
                                                <MudText Typo="Typo.body2" Class="fw-600">@item.NAudometer <span class="opacity-50 fw-400">km</span></MudText>
                                            </div>
                                        </div>
                                    </div>
                                    @if (!string.IsNullOrEmpty(item.Remarks))
                                    {
                                        <div class="pa-3 rounded-lg bg-light-surface mb-4">
                                            <MudText Typo="Typo.caption" Class="opacity-60">Internal Remarks</MudText>
                                            <MudText Typo="Typo.body2">@item.Remarks</MudText>
                                        </div>
                                    }
                                </div>
                                <div class="pa-4 pt-0">
                                    @if (item.JobCardID == null)
                                    {
                                        <MudButton Color="Color.Primary" Variant="Variant.Filled" FullWidth="true" StartIcon="@Icons.Material.Filled.AddTask" OnClick="@(()=>CreateJobcard(item))" Class="fw-600">ISSUE JOBCARD</MudButton>
                                    }
                                    else
                                    {
                                        <div class="d-flex align-center justify-center pa-2 rounded-lg border-subtle bg-light-success">
                                            <MudIcon Icon="@Icons.Material.Filled.Verified" Color="Color.Success" Size="Size.Small" Class="mr-2" />
                                            <MudText Typo="Typo.caption" Color="Color.Success" Class="fw-700 uppercase">Jobcard Issued</MudText>
                                        </div>
                                    }
                                </div>
                            </div>
                        </MudItem>
                    }
                </MudGrid>
            </div>
        }
        else if (SelectedTruck != null)
        {
            <div class="d-flex flex-column align-center justify-center py-12 fade-in opacity-50">
                <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Size="Size.Large" Color="Color.Success" Class="mb-4" />
                <MudText Typo="Typo.h6">All clear! No pending maintenance for this vehicle.</MudText>
            </div>
        }
        else
        {
            <div class="d-flex flex-column align-center justify-center py-12 fade-in opacity-50">
                <MudIcon Icon="@Icons.Material.Filled.LocalShipping" Size="Size.Large" Color="Color.Primary" Class="mb-4" />
                <MudText Typo="Typo.h6">Select a vehicle to view maintenance schedules.</MudText>
            </div>
        }
    }
</div>



@code {

    private bool _isLoading = true;
    private DateTime _loadStartTime;

    private List<PeriodicMaintenanceInitiateModel> PmList = new();
    private TruckModel SelectedTruck;
    [Parameter]
    public int? id { get; set; } = null;
    private List<TruckModel> TruckList = new();
    public DateTime? BreakdownTime { get; set; } = DateTime.Now;
    public string Detail { get; set; }
    public string ContactNumber { get; set; }
    public int BranchID { get; set; }
    private List<BreakdownModel> BreakdownList = new();
    private bool _busy;

    // Lifecycle method that runs when the component is initialized
    protected override async Task OnInitializedAsync()
    {
        _loadStartTime = DateTime.Now;
        if (id != null)
        {
            var authprov = await auth.GetAuthenticationStateAsync();
            var user = authprov.User;
            var brancIDString = authprov.User.Claims.FirstOrDefault(x => x.Type == "BranchID")?.Value;
            BranchID = int.Parse(brancIDString);

            // Fetch pending breakdowns and trucks for the branch
            BreakdownList = ibreakdownService.SelectPending(BranchID).ToList();
            TruckList = Itruck.SelectByBranch(BranchID, "All").ToList();

            // Fetch periodic maintenance records based on the provided ID
            PmList = Iservice.Select(id).ToList();
            if (PmList != null && PmList.Count() != 0)
            {
                if (TruckList != null && TruckList.Any(s => s.TruckID == PmList.First().TruckID))
                {
                    SelectedTruck = TruckList.FirstOrDefault(s => s.TruckID == PmList.First().TruckID);
                }
            }
            StateHasChanged();
        }
        await EnsureMinimumLoadTime();
        _isLoading = false;
    }

    private async Task EnsureMinimumLoadTime()
    {
        var elapsed = (DateTime.Now - _loadStartTime).TotalMilliseconds;
        if (elapsed < 100)
        {
            await Task.Delay(100 - (int)elapsed);
        }
    }

    // Method to handle truck selection
    private void TruckSelected(TruckModel obj)
    {
        SelectedTruck = obj;
        if (SelectedTruck != null)
        {
            // fetch its periodic maintenance records
            PmList = Iservice.SelectByTruck(SelectedTruck?.TruckID, 3).ToList();
        }
        else
        {
            if (PmList != null)
                PmList.Clear();
        }
        StateHasChanged();
    }

    // Method to create a new periodic maintenance record
    private async Task CreateNew()
    {
        var authState = await auth.GetAuthenticationStateAsync();
        PeriodicMaintenanceInitiateModel pmModel = new PeriodicMaintenanceInitiateModel()
            {
                TruckID = SelectedTruck?.TruckID,
                RegNo = SelectedTruck?.RegNo,
                UserInfo = {
                         UserID = authState.User.Identity.Name
                    }
            };
        var parameters = new DialogParameters();
        parameters.Add("model", pmModel.Clone());
        var dialog = await DialogService.ShowAsync<PeriodicMaintenanceInitiateDialog>("Periodic Maintenance", parameters);
        var result = await dialog.Result;
        if (!result.Canceled)
        {
            PeriodicMaintenanceInitiateModel item = (PeriodicMaintenanceInitiateModel)result.Data;
            PmList.Add(item);
        }
    }

    // Method to create a job card for a periodic maintenance record
    private async Task CreateJobcard(PeriodicMaintenanceInitiateModel item)
    {
        if (SelectedTruck != null)
        {
            // Get the current trip for the selected truck
            var CurrentTrip = Itrip.Select(Itruck.GetCurrentTrip(SelectedTruck.TruckID));
            if (CurrentTrip != null && !Itrip.IsClosed(CurrentTrip.TripID))
            {
                var authState = await auth.GetAuthenticationStateAsync();
                BreakdownModel Breakdown = new();
                Breakdown.BreakdownType = "PeriodicMaintenance";
                Breakdown.TruckID = SelectedTruck?.TruckID ?? 0;
                Breakdown.RegNo = SelectedTruck?.RegNo ?? "";
                Breakdown.BranchID = BranchID;
                Breakdown.BreakdownTime = DateTime.Now;
                Breakdown.Detail = "";
                Breakdown.ContactNumber = "";
                Breakdown.UserInfo = new ArmsModels.SharedModels.UserInfoModel()
                    {
                        UserID = authState.User.Identity.Name
                    };
                var parameters = new DialogParameters();
                parameters.Add("Breakdown", Breakdown.Clone());
                parameters.Add("PeriodicMaintenanceId", item.PMIID);

                DialogOptions maxWidth = new DialogOptions() { MaxWidth = MaxWidth.Medium, FullWidth = true };
                var dialog = await DialogService.ShowAsync<CreateJobcardDialog>("Initiate Jobcard", parameters, maxWidth);
                var result = await dialog.Result;
                if (!result.Canceled)
                {
                    JobcardModel jobcard = (JobcardModel)result.Data;
                    navigationManager.NavigateTo("jobcard/" + jobcard.TruckID);
                }
            }
            else
            {
                bool? ResultModel = await DialogService.ShowMessageBoxAsync(
                    "Can not create job!",
                    "Can not create this job because the Truck is on a trip.");
            }
        }
    }

    // Method to close a periodic maintenance reminder
    private async Task CloseReminder(PeriodicMaintenanceInitiateModel pmModel)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        _busy = true;
        var parameters = new DialogParameters();
        parameters.Add("PmiModel", pmModel);
        var dialog = await DialogService.ShowAsync<PeriodicMaintenanceCloseDialog>("Close Maintenance Reminder", parameters);
        var result = await dialog.Result;
        if (!result.Canceled)
        {
            PeriodicMaintenanceConcludeModel item = (PeriodicMaintenanceConcludeModel)result.Data;
            PmList.Remove(pmModel);
        }
        await Task.Delay(200);
        _busy = false;
    }
}

