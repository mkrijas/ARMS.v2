@page "/InsuranceStatusReport"
@inject ISnackbar Snackbar
@attribute [Authorize]
@inject AuthenticationStateProvider auth
@inject IBranchService IBranchService
@inherits ReportComponentBase

<div class="admin-page-container">
    <div class="admin-header-tiered mb-6">
        <div class="d-flex align-center justify-space-between">
            <div>
                <MudText Typo="Typo.h4" Class="admin-title">Insurance Compliance Registry</MudText>
                <MudText Typo="Typo.body2" Class="admin-subtitle">Institutional oversight of policy statuses, mandatory renewals, and legal coverage across the fleet.</MudText>
            </div>
        </div>
    </div>

    <div class="admin-glass-card pa-6 mb-6">
        <div class="d-flex align-center mb-6">
            <div class="icon-badge primary-badge-soft mr-3">
                <MudIcon Icon="@Icons.Material.Filled.Gavel" Size="Size.Small" />
            </div>
            <MudText Typo="Typo.subtitle1" Class="fw-700">Compliance Scope</MudText>
        </div>

        <MudGrid Spacing="3" Class="align-end">
            <MudItem xs="12" md="4" Class="d-flex">
                <MudButton Variant="Variant.Outlined" Color="Color.Primary" OnClick="SelectBranches" StartIcon="@Icons.Material.Filled.AccountTree" Class="rounded-pill mr-2 px-6">Scope Branches</MudButton>
                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="RenderReportViewer" StartIcon="@Icons.Material.Filled.FactCheck" Class="rounded-pill px-8 shadow-none flex-grow-1">Analyze Compliance</MudButton>
            </MudItem>
            <MudItem xs="12" md="8"></MudItem>
        </MudGrid>
    </div>

    <div class="mt-4" style="@(ShowReport ? "" : "display:none")">
        <div class="admin-glass-card pa-0 overflow-hidden">
            <ReportViewer ReportName="@ReportName" Parameters=@ReportParameters @ref="@report"></ReportViewer>
        </div>
    </div>
</div>

@code {
    ReportViewer report;
    public Dictionary<string, string> ReportParameters { get; set; } = new();
    public bool ShowReport { get; set; } = false;
    public string ReportName { get; set; }
    public BranchModel SelectedBranch { get; set; } = new();
    public BranchModel CurrentBranch { get; set; } = new();

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();
        var authprov = await auth.GetAuthenticationStateAsync();
        var User = authprov.User;
        string BranchIDString = User.Claims.First(x => x.Type == "BranchID").Value;
        CurrentBranch.BranchName = User.Claims.First(x => x.Type == "BranchName").Value;
    }

    // private async Task BranchChanged(BranchModel branch)
    // {
    //     SelectedBranch = branch;
    // }

    public async Task RenderReportViewer()
    {
        if (!SelectedBranches.Any())
        {
            snackbar.Add("Please select branch.", Severity.Error);
            return;
        }
        ShowReport = true;
        ReportName = "InsuranceStatusReport";
        ReportParameters.Clear();
        ReportParameters.Add("BranchIDS", String.Join(',', SelectedBranches));
        ReportParameters.Add("BranchName", CurrentBranch.BranchName);
        await report.RenderReport();
    }
}
