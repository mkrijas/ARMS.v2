@page "/JobMaintenanceReport"
@attribute [Authorize]
@inject AuthenticationStateProvider auth
@inherits ReportComponentBase
@inject IRepairWorkService Iservice
@inject ISnackbar Snackbar

<div class="admin-page-container">
    <div class="admin-header-tiered mb-6">
        <div class="d-flex align-center justify-space-between">
            <div>
                <MudText Typo="Typo.h4" Class="admin-title">Job Progression Dossier</MudText>
                <MudText Typo="Typo.body2" Class="admin-subtitle">Analytical overview of workshop jobcards, maintenance groups, and technical asset status.</MudText>
            </div>
        </div>
    </div>

    <div class="admin-glass-card pa-6 mb-6">
        <div class="d-flex align-center mb-6">
            <div class="icon-badge primary-badge-soft mr-3">
                <MudIcon Icon="@Icons.Material.Filled.Tune" Size="Size.Small" />
            </div>
            <MudText Typo="Typo.subtitle1" Class="fw-700">Dossier Filtration</MudText>
        </div>

        <MudGrid Spacing="3" Class="align-end">
            <MudItem xs="12" md="3">
                <div class="modern-input-wrapper">
                    <TruckSelector Value="SelectedTruck" BranchID="BranchID" ValueChanged="OnTruckSelected" Filter="AvailableForBranch" HomeOrOperation="Operation" />
                </div>
            </MudItem>
             <MudItem xs="12" md="3">
                <MudSelect For="@(() => JobGroup)" T="RepairJobGroup" Value="@JobGroup" ValueChanged="SetGroup" Label="Job Category" ToStringFunc="@((e) => e?.Title)" Variant="Variant.Outlined" Margin="Margin.Dense" Class="modern-input">
                    @foreach (var group in Groups)
                    {
                        <MudSelectItem Value="group">@group?.Title</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" md="2">
                <MudDatePicker Label="From Date" @bind-Date="@(FromDate)" Variant="Variant.Outlined" Margin="Margin.Dense" Class="modern-input" />
            </MudItem>
            <MudItem xs="12" md="2">
                <MudDatePicker Label="To Date" @bind-Date="@(ToDate)" Variant="Variant.Outlined" Margin="Margin.Dense" Class="modern-input" />
            </MudItem>
            <MudItem xs="12" md="2" Class="d-flex">
                <MudIconButton Icon="@Icons.Material.Filled.AccountTree" Variant="Variant.Outlined" Color="Color.Primary" OnClick="SelectBranches" Class="mr-2" />
                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="RenderReportViewer" Class="rounded-pill px-6 shadow-none flex-grow-1">Analyze</MudButton>
            </MudItem>
        </MudGrid>
    </div>

    <div class="mt-4" style="@(ShowReport ? "" : "display:none")">
        <div class="admin-glass-card pa-0 overflow-hidden">
            <ReportViewer ReportName="@ReportName" Parameters=@ReportParameters @ref="@report"></ReportViewer>
        </div>
    </div>
</div>

@code {

    ReportViewer report;
    public Dictionary<string, string> ReportParameters { get; set; } = new();
    public TruckModel SelectedTruck { get; set; }
    public DateTime? FromDate { get; set; } = DateTime.Now;
    public DateTime? ToDate { get; set; } = DateTime.Now;
    public BranchModel CurrentBranch { get; set; } = new();
    private TripModel CurrentTrip { get; set; }
    public RepairJobGroup JobGroup { get; set; }
    private List<RepairJobGroup> Groups = new();

    public bool ShowReport { get; set; } = false;
    public string ReportName { get; set; }

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();
        var authprov = await auth.GetAuthenticationStateAsync();
        var User = authprov.User;
        string BranchIDString = User.Claims.First(x => x.Type == "BranchID").Value;
        CurrentBranch.BranchName = User.Claims.First(x => x.Type == "BranchName").Value;
        Groups = Iservice.SelectGroup().ToList();
    }

    private void OnTruckSelected(TruckModel model)
    {
        SelectedTruck = model;
    }

    void SetGroup(RepairJobGroup Group)
    {
        JobGroup = Group;
    }

    public async Task RenderReportViewer()
    {
        if (!SelectedBranches.Any())
        {
            snackbar.Add("Please select branch.", Severity.Error);
            return;
        }
        if (FromDate == null)
        {
            Snackbar.Add("Please select From Date.", Severity.Error);
            return;
        }
        if (ToDate == null)
        {
            Snackbar.Add("Please select To Date.", Severity.Error);
            return;
        }

        ShowReport = true;
        ReportName = "JobMaintenanceReport";
        ReportParameters.Clear();
        ReportParameters.Add("BranchIDS", String.Join(',', SelectedBranches));
        ReportParameters.Add("BranchName", CurrentBranch.BranchName);
        ReportParameters.Add("TruckID", SelectedTruck?.TruckID.ToString() ?? "0");
        ReportParameters.Add("RepairJobGroupID", JobGroup?.ID.ToString() ?? "0");
        ReportParameters.Add("FromDate", FromDate.Value.ToString("yyyy/MM/dd"));
        ReportParameters.Add("ToDate", ToDate.Value.ToString("yyyy/MM/dd"));
        await report.RenderReport();
    }
}
