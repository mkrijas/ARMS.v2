@page "/MechanicWorkReport"
@inject ISnackbar Snackbar
@attribute [Authorize]
@inject AuthenticationStateProvider auth
@inject IBranchService Ibranchservice
@inherits ReportComponentBase

<div class="admin-page-container">
    <div class="admin-header-tiered mb-6">
        <div class="d-flex align-center justify-space-between">
            <div>
                <MudText Typo="Typo.h4" Class="admin-title">Technical Personnel Audit</MudText>
                <MudText Typo="Typo.body2" Class="admin-subtitle">Comprehensive performance metrics and workload utilization for mechanical engineering staff.</MudText>
            </div>
        </div>
    </div>

    <div class="admin-glass-card pa-6 mb-6">
        <div class="d-flex align-center mb-6">
            <div class="icon-badge primary-badge-soft mr-3">
                <MudIcon Icon="@Icons.Material.Filled.Engineering" Size="Size.Small" />
            </div>
            <MudText Typo="Typo.subtitle1" Class="fw-700">Audit Scope</MudText>
        </div>

        <MudGrid Spacing="3" Class="align-end">
            <MudItem xs="12" md="4">
                <MudDatePicker Label="Audit Origin" @bind-Date="@(StartDate)" Variant="Variant.Outlined" Margin="Margin.Dense" Class="modern-input" />
            </MudItem>
            <MudItem xs="12" md="4">
                <MudDatePicker Label="Audit Conclusion" @bind-Date="@(EndDate)" Variant="Variant.Outlined" Margin="Margin.Dense" Class="modern-input" />
            </MudItem>
            <MudItem xs="12" md="4" Class="d-flex">
                <MudIconButton Icon="@Icons.Material.Filled.AccountTree" Variant="Variant.Outlined" Color="Color.Primary" OnClick="SelectBranches" Class="mr-2" />
                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="RenderReportViewer" StartIcon="@Icons.Material.Filled.Search" Class="rounded-pill px-8 shadow-none flex-grow-1">Perform Audit</MudButton>
            </MudItem>
        </MudGrid>
    </div>

    <div class="mt-4" style="@(ShowReport ? "" : "display:none")">
        <div class="admin-glass-card pa-0 overflow-hidden">
            <ReportViewer ReportName="@ReportName" Parameters=@ReportParameters @ref="@report"></ReportViewer>
        </div>
    </div>
</div>

@code {
    ReportViewer report;
    public Dictionary<string, string> ReportParameters { get; set; } = new();
    public DateTime? StartDate { get; set; } = DateTime.Now;
    public DateTime? EndDate { get; set; } = DateTime.Now;
    public bool ShowReport { get; set; } = false;
    public string ReportName { get; set; }
    public BranchModel CurrentBranch { get; set; } = new();

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();
        var authprov = await auth.GetAuthenticationStateAsync();
        var User = authprov.User;
        string BranchIDString = User.Claims.First(x => x.Type == "BranchID").Value;
        CurrentBranch.BranchName = User.Claims.First(x => x.Type == "BranchName").Value;
    }

    public async Task RenderReportViewer()
    {
        if (!SelectedBranches.Any())
        {
            snackbar.Add("Please select branch.", Severity.Error);
            return;
        }
        if (StartDate == null)
        {
            Snackbar.Add("Please select From Date.", Severity.Error);
            return;
        }
        if (EndDate == null)
        {
            Snackbar.Add("Please select To Date.", Severity.Error);
            return;
        }

        ShowReport = true;
        ReportName = "MechanicWorkDetails";
        ReportParameters.Clear();
        //string branches = String.Join(',', BranchIDS);
        //ReportParameters.Add("BranchIDS", branches);
        ReportParameters.Add("BranchIDs", String.Join(',', SelectedBranches));
        ReportParameters.Add("BranchName", CurrentBranch.BranchName);
        ReportParameters.Add("StartDate", StartDate.Value.ToString("yyyy/MM/dd"));
        ReportParameters.Add("EndDate", EndDate.Value.ToString("yyyy/MM/dd"));
        await report.RenderReport();
    }
}
