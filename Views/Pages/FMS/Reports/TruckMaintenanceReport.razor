@page "/TruckMaintenanceReport"
@inject ISnackbar Snackbar
@attribute [Authorize]
@inject AuthenticationStateProvider auth
@inherits ReportComponentBase

<div class="admin-page-container">
    <div class="admin-header-tiered mb-6">
        <div class="d-flex align-center justify-space-between">
            <div>
                <MudText Typo="Typo.h4" Class="admin-title">Asset Maintenance Analytics</MudText>
                <MudText Typo="Typo.body2" Class="admin-subtitle">Generate high-precision maintenance dossiers for the fleet's technical operational history.</MudText>
            </div>
        </div>
    </div>

    <div class="admin-glass-card pa-6 mb-6">
        <div class="d-flex align-center mb-6">
            <div class="icon-badge primary-badge-soft mr-3">
                <MudIcon Icon="@Icons.Material.Filled.FilterList" Size="Size.Small" />
            </div>
            <MudText Typo="Typo.subtitle1" Class="fw-700">Dossier Parameters</MudText>
        </div>

        <MudGrid Spacing="3" Class="align-end">
            <MudItem xs="12" md="3">
                <MudDatePicker Label="Chronology Start" @bind-Date="@(FromDate)" Variant="Variant.Outlined" Margin="Margin.Dense" Class="modern-input" 
                              Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.DateRange" />
            </MudItem>
            <MudItem xs="12" md="3">
                <MudDatePicker Label="Chronology End" @bind-Date="@(ToDate)" Variant="Variant.Outlined" Margin="Margin.Dense" Class="modern-input"
                              Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.DateRange" />
            </MudItem>
            <MudItem xs="12" md="6" Class="d-flex">
                <MudButton Variant="Variant.Outlined" Color="Color.Primary" OnClick="SelectBranches" StartIcon="@Icons.Material.Filled.AccountTree" Class="rounded-pill mr-2 px-6">Scope Branches</MudButton>
                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="RenderReportViewer" StartIcon="@Icons.Material.Filled.BarChart" Class="rounded-pill px-8 flex-grow-1 shadow-none">Execute Report</MudButton>
            </MudItem>
        </MudGrid>
    </div>

    <div class="mt-4" style="@(ShowReport ? "" : "display:none")">
        <div class="admin-glass-card pa-0 overflow-hidden">
            <ReportViewer ReportName="@ReportName" Parameters=@ReportParameters @ref="@report"></ReportViewer>
        </div>
    </div>
</div>

@code {

    ReportViewer report;
    public Dictionary<string, string> ReportParameters { get; set; } = new();
    public DateTime? FromDate { get; set; } = DateTime.Now;
    public DateTime? ToDate { get; set; } = DateTime.Now;
    public bool ShowReport { get; set; } = false;
    public string ReportName { get; set; }
    public BranchModel CurrentBranch { get; set; } = new();

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();
        var authprov = await auth.GetAuthenticationStateAsync();
        var User = authprov.User;
        string BranchIDString = User.Claims.First(x => x.Type == "BranchID").Value;
        CurrentBranch.BranchName = User.Claims.First(x => x.Type == "BranchName").Value;
        CurrentBranch.BranchID = int.Parse(BranchIDString);
    }

    public async Task RenderReportViewer()
    {
        if (FromDate == null)
        {
            Snackbar.Add("Please select From Date.", Severity.Error);
            return;
        }
        if (ToDate == null)
        {
            Snackbar.Add("Please select To Date.", Severity.Error);
            return;
        }

        ShowReport = true;
        ReportName = "ROI_TruckMaintenanceReport";
        ReportParameters.Clear();
        ReportParameters.Add("BranchName", CurrentBranch.BranchName);
        ReportParameters.Add("BranchIDS", String.Join(',', SelectedBranches));
        ReportParameters.Add("FromDate", FromDate.Value.ToString("yyyy/MM/dd"));
        ReportParameters.Add("ToDate", ToDate.Value.ToString("yyyy/MM/dd"));
        await report.RenderReport();
    }
}
