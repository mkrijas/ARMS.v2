@using ArmsModels.BaseModels.FMS
@using ArmsModels.BaseModels.General
@using ArmsServices.DataServices.FMS
@using ArmsServices.DataServices.Operations
@inject AuthenticationStateProvider auth
@inject MudBlazor.ISnackbar snackbar
@inject IRoutineCheckListService Iservice
@inject ITruckService IserviceTruck
@inject IRoutineCheckListMasterService IserviceRoutineMaster
@inject IAssetDocumentService IDocumentService
@using System.Threading;
@inject IRoleService<RoleModel> Irole
@inject IDialogService DialogService

<DialogForm @ref="@dialogForm" Title="@(model.RoutineCheckListID == 0 ? "Initial Vehicle Inspection" : "Update Routine Assessment")" Subtitle="Document standardized vehicle health parameters and verify technical safety compliance." Icon="@Icons.Material.Filled.FactCheck" AdminStyle="true" formID="formRoutineCheckList" model="@model" _busy="_busy">
    <FormContent>
        <div class="dialog-content-wrapper fade-in">
            <EditForm id="formRoutineCheckList" Model="@model" OnValidSubmit="Submit">
                <ObjectGraphDataAnnotationsValidator />
                
                @if (ValidationMessage != null)
                {
                    <div class="admin-alert error pa-3 mb-4 rounded-lg d-flex align-center">
                        <MudIcon Icon="@Icons.Material.Filled.Error" Class="mr-2" />
                        <span class="fw-500">@ValidationMessage</span>
                    </div>
                }

                <div class="admin-glass-card pa-6 mb-6">
                    <div class="d-flex align-center mb-6">
                        <div class="icon-badge primary-badge-soft mr-3">
                            <MudIcon Icon="@Icons.Material.Filled.LocalShipping" Size="Size.Small" />
                        </div>
                        <span class="admin-section-label mb-0">Asset Identification & Notes</span>
                    </div>

                    <MudGrid Spacing="3">
                        <MudItem xs="12" md="6">
                            <TruckSelector Value="model.Truck" BranchID="branchID" ValueChanged="TruckSelected" Filter="All" Class="modern-selector" />
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <MudTextField @bind-Value="model.Remarks" Label="Operational Remarks" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.Remarks)" Class="modern-input" Placeholder="Enter overview of vehicle status..." />
                        </MudItem>
                    </MudGrid>
                </div>

                <div class="admin-glass-card pa-6 overflow-hidden">
                    <div class="d-flex align-center mb-6 px-2">
                        <div class="icon-badge secondary-badge-soft mr-3">
                            <MudIcon Icon="@Icons.Material.Filled.Rule" Size="Size.Small" />
                        </div>
                        <span class="admin-section-label mb-0">Technical Inspection Matrix</span>
                    </div>

                    <MudTable Items="@ItemList" Dense="true" Hover="true" Elevation="0" Context="context1" Class="modern-admin-table light-header border-subtle">
                        <HeaderContent>
                            <MudTh><span class="admin-header-text">INSPECTION PARAMETER</span></MudTh>
                            <MudTh Style="width: 100px; text-align: center;"><span class="admin-header-text">STATUS</span></MudTh>
                            <MudTh><span class="admin-header-text">TECHNICAL DESCRIPTION</span></MudTh>
                            <MudTh><span class="admin-header-text">COMPLIANCE STATUS</span></MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd DataLabel="Item Name"><span class="fw-600 color-primary">@context1.ItemName</span></MudTd>
                            <MudTd DataLabel="Is Checked" Style="text-align: center;">
                                <MudCheckBox T="bool" @bind-Value="@context1.IsChecked" Disabled="@context1.IsDisabled" Color="Color.Primary" Dense="true" />
                            </MudTd>
                            <MudTd DataLabel="Description">
                                <MudTextField @bind-Value="context1.DetailDescription" Label="Notes" Variant="Variant.Outlined" Margin="Margin.Dense" Class="modern-input" Placeholder="Technical findings..." />
                            </MudTd>
                            <MudTd DataLabel="Status">
                                <div class="d-flex align-center">
                                    <span class="opacity-70 mr-2">@(context1.CurrentTruckLastUpdatedDate?.ToString("dd/MM/yyyy") ?? "N/A")</span>
                                    @if (context1.IsExpired)
                                    {
                                        <MudChip T="string" Size="Size.Small" Color="Color.Error" Variant="Variant.Text" Class="fw-700" Icon="@Icons.Material.Filled.Warning">EXPIRED</MudChip>
                                    }
                                    else if (context1.CurrentTruckLastUpdatedDate != null)
                                    {
                                        <MudChip T="string" Size="Size.Small" Color="Color.Success" Variant="Variant.Text" Class="fw-700" Icon="@Icons.Material.Filled.CheckCircle">COMPLIANT</MudChip>
                                    }
                                </div>
                            </MudTd>
                        </RowTemplate>
                    </MudTable>
                </div>
            </EditForm>
        </div>
    </FormContent>
</DialogForm>

@code {
    private DialogForm dialogForm;

    [CascadingParameter] IMudDialogInstance MudDialog { get; set; }
    [Parameter]
    public RoutineCheckListModel model { get; set; } = new();
    List<TruckModel> TruckList = new();
    List<RoutineCheckListMasterModel> ItemList = new();
    private int branchID { get; set; } = 0;
    public string ValidationMessage = null;
    private bool _busy;
    private IEnumerable<RoutineCheckListMasterModel> RoutineCheckListItem { get; set; } = new HashSet<RoutineCheckListMasterModel>();

    public bool HasPermissionRoutineCheckListServiceEdit { get; set; } = false;
    public int RoutineCheckListDocTypeID = 75;

    // Lifecycle method that runs when the component is initialized
    protected override async void OnInitialized()
    {
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionRoutineCheckListServiceEdit = await Irole.HasClaim(RoutineCheckListDocTypeID.ToString(), "Edit", ctc.Token);

        branchID = model.BranchID ?? 0;
        if (model.BranchID != null)
        {
            // Fetch items and trucks associated with the branch
            ItemList = IserviceRoutineMaster.SelectItemByBranch(model.BranchID).ToList();
            TruckList = IserviceTruck.SelectByBranch(model.BranchID, "All").ToList();
            if (model.TruckID != null && TruckList != null && TruckList.Any(s => s.TruckID == model.TruckID))
            {
                model.Truck = TruckList.First(s => s.TruckID == model.TruckID);
            }
            if (model.RoutineCheckListID != null)
            {
                List<RoutineCheckListModel> TruckListTemp = new();

                // fetch the last checklist details
                var TruckListTempSub = Iservice.GetLastRoutineCheckListDetailsUsingID(model.RoutineCheckListID);
                if (TruckListTempSub != null)
                {

                    TruckListTemp = TruckListTempSub.ToList();
                    foreach (var item in TruckListTemp.OrderBy(s => s.CreatedDate))
                    {
                        if (ItemList != null && ItemList.Count() != 0 && ItemList.Any(s => s.ItemID == item.ItemID))
                        {
                            foreach (RoutineCheckListMasterModel Values in ItemList.Where(s => (int)s.ItemID == item.ItemID))
                            {
                                Values.CurrentTruckLastUpdatedDate = item.CreatedDate;
                                if (item.CreatedDate != null && Values != null)
                                {
                                    Values.IsExpired = ((DateTime.Now - item.CreatedDate.Value).TotalDays > Values.ValidDays);
                                    Values.IsChecked = true;
                                    Values.DetailDescription = item.Description;
                                }
                            }
                        }
                    }
                }
            }
            if(model.TruckID != null && model.RoutineCheckListID == null)
            {
                // fetch the last checklist details using the truck ID
                var TruckListTempSub = Iservice.GetLastRoutineCheckListDetailsUsingTruckId(model.TruckID);
                if (TruckListTempSub != null)
                {
                    List<RoutineCheckListModel> TruckListTemp = new();
                    TruckListTemp = TruckListTempSub.ToList();
                    foreach (var item in TruckListTemp.OrderBy(s => s.CreatedDate))
                    {
                        if (ItemList != null && ItemList.Count() != 0 && ItemList.Any(s => s.ItemID == item.ItemID))
                        {
                            foreach (RoutineCheckListMasterModel Values in ItemList.Where(s => (int)s.ItemID == item.ItemID))
                            {
                                Values.CurrentTruckLastUpdatedDate = item.CreatedDate;
                                if (item.CreatedDate != null && Values != null)
                                {
                                    Values.IsExpired = ((DateTime.Now - item.CreatedDate.Value).TotalDays > Values.ValidDays);
                                    //Values.IsChecked = true;
                                    //Values.DetailDescription = item.Description;
                                }
                            }
                        }
                    }
                }
            }
        }
    }

    protected override void OnParametersSet()
    {

    }

    // Method to cancel the dialog
    void Cancel()
    {
        MudDialog.Cancel();
    }

    // Method to submit the routine checklist
    public async Task Submit()
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is being submitted!", Severity.Warning);
            return;
        }
        if (HasPermissionRoutineCheckListServiceEdit)
        {
            if (ItemList != null && !ItemList.Any(s => s.IsChecked))
            {
                snackbar.Add("Please check at least 1 item before submitting.", Severity.Error);
                return;
            }
            if (ItemList.Any(s => s.IsExpired && (!s.IsChecked)))
            {
                snackbar.Add("Please check the expired item(s).", Severity.Error);
                return;
            }
            _busy = true;
            var authprov = await auth.GetAuthenticationStateAsync();
            var user = authprov.User;
            if (model != null)
            {
                if (model.Truck != null)
                {
                    model.TruckID = model.Truck.TruckID;
                }
                if (ItemList.Any(d => d.IsChecked && d.ItemID != null))
                {
                    if (model.CheckedItemLists == null)
                    {
                        model.CheckedItemLists = new();
                    }
                    model.CheckedItemLists = ItemList.Where(d => d.IsChecked).Select(s => new IntStringValuesModel() { IntVal = s.ItemID, StringVal = s.DetailDescription }).ToList();
                }
                model.UserInfo.UserID = user.Identity.Name;

                // Call the service to update the routine checklist
                Iservice.Update(model);
            }
            MudDialog.Close(DialogResult.Ok(true));
        }
        else
        {
            bool? result = await DialogService.ShowMessageBoxAsync(
                "Permission denied!",
                "You don't have any permission to Edit RoutineCheckList.");
        }
        await Task.Delay(200);
        _busy = false;
    }

    // Method to handle truck selection
    private async Task TruckSelected(TruckModel obj)
    {
        model.Truck = obj;
        if (obj != null)
        {
            model.TruckID = obj.TruckID;
        }
        else
        {
            model.TruckID = null;
        }
        List<RoutineCheckListModel> TruckListTemp = new();
        if (ItemList != null && ItemList.Count() != 0)
        {
            foreach (RoutineCheckListMasterModel Values in ItemList)
            {
                Values.CurrentTruckLastUpdatedDate = null;
            }
        }
        if (obj != null && obj.TruckID != null)
        {
            // fetch the last routine checklist details
            var TruckListTempSub = Iservice.GetLastRoutineCheckListDetailsUsingTruckId(obj.TruckID);
            if (TruckListTempSub != null)
            {

                TruckListTemp = TruckListTempSub.ToList();
                foreach (var item in TruckListTemp.OrderBy(s => s.CreatedDate))
                {
                    if (ItemList != null && ItemList.Count() != 0 && ItemList.Any(s => s.ItemID == item.ItemID))
                    {
                        foreach (RoutineCheckListMasterModel Values in ItemList.Where(s => (int)s.ItemID == item.ItemID))
                        {
                            Values.CurrentTruckLastUpdatedDate = item.CreatedDate;
                            if (item.CreatedDate != null && Values != null)
                            {
                                Values.IsExpired = ((DateTime.Now - item.CreatedDate.Value).TotalDays > Values.ValidDays);
                                //Values.IsChecked = true;
                                //Values.DetailDescription = item.Description;
                            }
                        }
                    }
                }
            }
        }
    }
}
