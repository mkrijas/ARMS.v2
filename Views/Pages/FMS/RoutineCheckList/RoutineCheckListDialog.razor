@using ArmsModels.BaseModels.FMS
@using ArmsModels.BaseModels.General
@using ArmsServices.DataServices.FMS
@using ArmsServices.DataServices.Operations
@inject AuthenticationStateProvider auth
@inject MudBlazor.ISnackbar snackbar
@inject IRoutineCheckListService Iservice
@inject ITruckService IserviceTruck
@inject IRoutineCheckListMasterService IserviceRoutineMaster
@inject IAssetDocumentService IDocumentService

<MudDialog>
    <TitleContent>
        @if (model.RoutineCheckListID == null || model.RoutineCheckListID == 0)
        {
            <MudText Typo="Typo.h6">
                <MudIcon Icon="@Icons.Material.Filled.Edit" Class="mr-3" /> Add Routine Check List
            </MudText>
        }
        else
        {
            <MudText Typo="Typo.h6">
                <MudIcon Icon="@Icons.Material.Filled.Edit" Class="mr-3" /> Edit Routine Check List
            </MudText>
        }
    </TitleContent>
    <DialogContent>
        <MudContainer Style="max-height: 400px; overflow-y: scroll; margin-left:20px">
            <EditForm id="formRoutineCheckList" Model="@model" OnValidSubmit="Submit">
                <ObjectGraphDataAnnotationsValidator />
                <ValidationSummary />
                @if (ValidationMessage != null)
                {
                    <div class="validation-message">@ValidationMessage</div>
                }
                <MudItem xs="11" md="11" Class="mb-6">
                    <TruckSelector Value="model.Truck" BranchID="branchID" ValueChanged="TruckSelected" />
                </MudItem>
                <MudItem xs="11" md="11" Class="mb-6">
                    <MudTextField @bind-Value="model.Remarks" Label="Remarks" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.Remarks)"></MudTextField>
                </MudItem>
                <MudItem xs="11" md="11">
                    <MudGrid>
                        @*@foreach (var item in ItemList)
                        {*@
                        @*<MudItem Style="border:none; height:fit-content; border-radius:4px;" Class="m-2 mr-2 p-0 pl-2 ml-2 mt-1 mb-1">
                        <MudCheckBox @bind-Checked="@item.IsChecked" Disabled="@item.IsDisabled">@(item.ItemName + (item.CurrentTruckLastUpdatedDate != null ? (" (" + @Convert.ToDateTime(item.CurrentTruckLastUpdatedDate).ToString("dd/MM/yyyy hh:mm") + ")") : ""))</MudCheckBox>
                        </MudItem>*@
                        <MudItem xs="12">
                            <MudTable Items="@ItemList" Dense="true" Hover="true" Striped="true" Elevation="0" @bind-place="model" Context="context1">
                                @*<ToolBarContent>
                                <MudSpacer></MudSpacer>
                                </ToolBarContent>*@
                                <HeaderContent>
                                    <MudTh><MudTableSortLabel SortBy="new Func<RoutineCheckListMasterModel, object>(x=> x.ItemName)" InitialDirection="SortDirection.Ascending">Item Name</MudTableSortLabel></MudTh>
                                    <MudTh><MudTableSortLabel SortBy="new Func<RoutineCheckListMasterModel, object>(x=> x.IsChecked)" InitialDirection="SortDirection.Ascending">Is Checked</MudTableSortLabel></MudTh>
                                    <MudTh><MudTableSortLabel SortBy="new Func<RoutineCheckListMasterModel, object>(x=> x.DetailDescription)" InitialDirection="SortDirection.Ascending">Description</MudTableSortLabel></MudTh>
                                    <MudTh><MudTableSortLabel SortBy="new Func<RoutineCheckListMasterModel, object>(x=> x.CurrentTruckLastUpdatedDate)" InitialDirection="SortDirection.Ascending">Last Updated Date / Is Expired</MudTableSortLabel></MudTh>
                                </HeaderContent>
                                <RowTemplate>
                                    <MudTd DataLabel="Item Name">@context1.ItemName</MudTd>
                                    <MudTd DataLabel="Is Checked"> <MudCheckBox @bind-Checked="@context1.IsChecked" Disabled="@context1.IsDisabled"></MudCheckBox> </MudTd>
                                    <MudTd DataLabel="Description">  <MudTextField @bind-Value="context1.DetailDescription" Label="Description" Variant="Variant.Outlined" Margin="Margin.Dense"></MudTextField> </MudTd>
                                    <MudTd DataLabel="Last Updated Date"><div style="display:inline"> @(context1.CurrentTruckLastUpdatedDate) <span style="color:red"> @(context1.IsExpired ? " (Expired)" : "") </span></div></MudTd>
                                    </RowTemplate>
                                    @*                               <PagerContent>
                                <MudTablePager PageSizeOptions="new int[] { 5, 10, 20, 50, 100 }" />
                                </PagerContent>*@
                                </MudTable>
                            </MudItem>
                            @*}*@
                        </MudGrid>
                    </MudItem>
                </EditForm>
            </MudContainer>
        </DialogContent>
        <DialogActions>
            <MudButton Disabled="@_busy" form="formRoutineCheckList" Variant="Variant.Filled" Color="Color.Primary" ButtonType="ButtonType.Submit" Class="px-12">Submit</MudButton>
        </DialogActions>
    </MudDialog>

@code {

    [CascadingParameter] MudDialogInstance MudDialog { get; set; }
    [Parameter]
    public RoutineCheckListModel model { get; set; } = new();
    List<TruckModel> TruckList = new();
    List<RoutineCheckListMasterModel> ItemList = new();
    private int branchID { get; set; } = 0;
    public string ValidationMessage = null;
    private bool _busy;
    private IEnumerable<RoutineCheckListMasterModel> RoutineCheckListItem { get; set; } = new HashSet<RoutineCheckListMasterModel>();

    protected override async void OnInitialized()
    {
        branchID = model.BranchID ?? 0;
        if (model.BranchID != null)
        {
            ItemList = IserviceRoutineMaster.SelectItemByBranch(model.BranchID).ToList();
            TruckList = IserviceTruck.SelectByBranch(model.BranchID).ToList();
            if (model.TruckID != null && TruckList != null && TruckList.Any(s => s.TruckID == model.TruckID))
            {
                model.Truck = TruckList.First(s => s.TruckID == model.TruckID);
            }
            if (model.TruckID != null)
            {
                List<RoutineCheckListModel> TruckListTemp = new();
                var TruckListTempSub = Iservice.GetLastRoutineCheckListDetailsUsingID(model.RoutineCheckListID);
                if (TruckListTempSub != null)
                {

                    TruckListTemp = TruckListTempSub.ToList();
                    foreach (var item in TruckListTemp.OrderBy(s => s.CreatedDate))
                    {
                        if (ItemList != null && ItemList.Count() != 0 && ItemList.Any(s => s.ItemID == item.ItemID))
                        {
                            foreach (RoutineCheckListMasterModel Values in ItemList.Where(s => (int)s.ItemID == item.ItemID))
                            {
                                Values.CurrentTruckLastUpdatedDate = item.CreatedDate;
                                if (item.CreatedDate != null && Values != null)
                                {
                                    var day1 = item.CreatedDate.Value.Day;
                                    var day2 = DateTime.Now.Day;
                                    var day3 = (item.CreatedDate.Value - DateTime.Now).Days;
                                    var day4 = (item.CreatedDate.Value - DateTime.Now).TotalDays;
                                    Values.IsExpired = ((DateTime.Now - item.CreatedDate.Value ).TotalDays > Values.ValidDays);
                                    Values.IsChecked = true;
                                    Values.DetailDescription = item.Description;
                                }
                            }
                        }
                    }
                }
            }
        }
    }

    protected override void OnParametersSet()
    {

    }

    void Cancel()
    {
        MudDialog.Cancel();
    }

    public async Task Submit()
    {
        if (ItemList != null && !ItemList.Any(s => s.IsChecked))
        {
            snackbar.Add("Please check at least 1 item before submitting.", Severity.Error);
            return;

        }
        if (ItemList.Any(s => s.IsExpired && (!s.IsChecked)))
        {
            snackbar.Add("Please check the expired item(s).", Severity.Error);
            return;

        }
        if (_busy)
        {
            snackbar.Add("Please wait while form is being submitted!", Severity.Warning);
            return;
        }
        _busy = true;

        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;
        if (model != null)
        {
            if (model.Truck != null)
            {
                model.TruckID = model.Truck.TruckID;
            }
            if (ItemList.Any(d => d.IsChecked && d.ItemID != null))
            {
                if (model.CheckedItemLists == null)
                {
                    model.CheckedItemLists = new();
                }
                model.CheckedItemLists = ItemList.Where(d => d.IsChecked).Select(s => new IntStringValuesModel() { IntVal = s.ItemID, StringVal = s.DetailDescription }).ToList();

            }
            model.UserInfo.UserID = user.Identity.Name;
            Iservice.Update(model);
        }
        MudDialog.Close(DialogResult.Ok(true));

        await Task.Delay(2000);
        _busy = false;
    }

    private async Task TruckSelected(TruckModel obj)
    {
        model.Truck = obj;
        if (obj != null)
        {
            model.TruckID = obj.TruckID;
        }
        else
        {
            model.TruckID = null;
        }
        List<RoutineCheckListModel> TruckListTemp = new();
        if (ItemList != null && ItemList.Count() != 0)
        {
            foreach (RoutineCheckListMasterModel Values in ItemList)
            {
                Values.CurrentTruckLastUpdatedDate = null;
            }
        }
        if (obj != null && obj.TruckID != null)
        {
            var TruckListTempSub = Iservice.GetLastRoutineCheckListDetailsUsingTruckId(obj.TruckID);
            if (TruckListTempSub != null)
            {

                TruckListTemp = TruckListTempSub.ToList();
                foreach (var item in TruckListTemp.OrderBy(s => s.CreatedDate))
                {
                    if (ItemList != null && ItemList.Count() != 0 && ItemList.Any(s => s.ItemID == item.ItemID))
                    {
                        foreach (RoutineCheckListMasterModel Values in ItemList.Where(s => (int)s.ItemID == item.ItemID))
                        {
                            Values.CurrentTruckLastUpdatedDate = item.CreatedDate;
                            if (item.CreatedDate != null && Values != null)
                            {
                                Values.IsExpired = ((item.CreatedDate.Value.Day - DateTime.Now.Day) > Values.ValidDays);
                                //Values.IsChecked = true;
                                //Values.DetailDescription = item.Description;
                            }
                        }
                    }
                }
            }
        }
    }
}