@page "/RoutineCheckListView"
@using ArmsModels.BaseModels.FMS
@using ArmsModels.BaseModels.General
@using ArmsServices.DataServices.FMS
@using ArmsServices.DataServices.Operations
@inject IRoutineCheckListService Iservice
@inject MudBlazor.ISnackbar snackbar
@inject AuthenticationStateProvider auth
@attribute [Authorize]
@inject IDialogService DialogService
@inject ITruckService IserviceTruck
@inject IRoutineCheckListMasterService IserviceRoutineMaster
@using System.Threading;
@inject IRoleService<RoleModel> Irole

@if (_isLoading)
{
    <div @key="@("loader")" class="d-flex justify-center align-center" style="min-height: 400px;">
        <LoaderComponent IsFullScreen="false" ShowLogo="false" Size="medium" LoadingText="Synchronizing Routine Checks" SubText="Retrieving latest vehicle inspection records..." />
    </div>
}
else
{
    <div class="admin-page-container fade-in" @key="@("content")">
        <div class="admin-header-tiered mb-6">
            <div class="d-flex align-center justify-space-between">
                <div>
                    <MudText Typo="Typo.h4" Class="admin-title">Routine Checklists</MudText>
                    <MudText Typo="Typo.body2" Class="admin-subtitle">Manage and track daily or routine vehicle health inspections and safety checks.</MudText>
                </div>
                <MudButton Disabled="@_busy" Variant="Variant.Filled" Color="Color.Primary" OnClick="@(()=> OpenDialog(new RoutineCheckListModel()))" Class="admin-register-btn" StartIcon="@Icons.Material.Filled.Add">NEW CHECKLIST</MudButton>
            </div>
        </div>

        <div class="admin-glass-card overflow-hidden">
            <MudTable Items="@collection" Elevation="0" Hover="true" Breakpoint="Breakpoint.Sm" Class="modern-admin-table">
                <HeaderContent>
                    <MudTh><MudTableSortLabel SortBy="new Func<RoutineCheckListModel, object>(x=> x.TruckName)" InitialDirection="SortDirection.Ascending"><span class="admin-header-text">TRUCK</span></MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<RoutineCheckListModel, object>(x=> x.Remarks)"><span class="admin-header-text">REMARKS</span></MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<RoutineCheckListModel, object>(x=> x.ItemNames)"><span class="admin-header-text">INSPECTED ITEMS</span></MudTableSortLabel></MudTh>
                    <MudTh Style="text-align: right;"><span class="admin-header-text">ACTIONS</span></MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Truck"><span class="admin-td-primary fw-600">@context.TruckName</span></MudTd>
                    <MudTd DataLabel="Remarks"><span class="opacity-80">@context.Remarks</span></MudTd>
                    <MudTd DataLabel="Inspected Items">
                        @if (!string.IsNullOrEmpty(context.ItemNames))
                        {
                            <div class="d-flex flex-wrap gap-1">
                                @foreach (var item in context.ItemNames.Split(','))
                                {
                                    <MudChip T="string" Size="Size.Small" Variant="Variant.Text" Color="Color.Info" Class="ma-0">@item.Trim()</MudChip>
                                }
                            </div>
                        }
                    </MudTd>
                    <MudTd DataLabel="Actions" Style="text-align: right;">
                        <MudTooltip Text="Edit Checklist">
                            <MudIconButton OnClick="@(()=> OpenDialog(context))" Color="Color.Primary" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Variant="Variant.Text" />
                        </MudTooltip>
                        <MudTooltip Text="Remove Record">
                            <MudIconButton OnClick="@(()=> OpenDialogDelete(context))" Color="Color.Error" Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Variant="Variant.Text" />
                        </MudTooltip>
                    </MudTd>
                </RowTemplate>
                <PagerContent>
                    <div class="pa-4">
                        <MudTablePager PageSizeOptions="new int[] { 10, 20, 50, 100 }" />
                    </div>
                </PagerContent>
            </MudTable>
        </div>
    </div>
}



@code {

    private bool _isLoading = true;
    private DateTime _loadStartTime;

    private RoutineCheckListModel model = new();
    private List<RoutineCheckListModel> collection = new();
    List<TruckModel> TruckList = new();
    List<RoutineCheckListMasterModel> ItemList = new();
    string state = "Message box hasn't been opened yet";
    private bool _busy;

    public bool HasPermissionRoutineCheckListServiceDelete { get; set; } = false;
    public int RoutineCheckListDocTypeID = 75;

    // Lifecycle method that runs when the component is initialized
    protected async override Task OnInitializedAsync()
    {
        _loadStartTime = DateTime.Now;
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionRoutineCheckListServiceDelete = await Irole.HasClaim(RoutineCheckListDocTypeID.ToString(), "Delete", ctc.Token);

        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;
        var brancIDString = authprov.User.Claims.First(x => x.Type == "BranchID").Value;

        // Fetch trucks and items associated with the branch
        TruckList = IserviceTruck.SelectByBranch(int.Parse(brancIDString), "All").ToList();
        ItemList = IserviceRoutineMaster.SelectItemByBranch(int.Parse(brancIDString)).ToList();

        await GetAll();
        await EnsureMinimumLoadTime();
        _isLoading = false;
    }

    private async Task EnsureMinimumLoadTime()
    {
        var elapsed = (DateTime.Now - _loadStartTime).TotalMilliseconds;
        if (elapsed < 100)
        {
            await Task.Delay(100 - (int)elapsed);
        }
    }

    // Method to open a dialog for creating or editing a routine checklist
    private async Task OpenDialog(RoutineCheckListModel model)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        _busy = true;
        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;
        var brancIDString = authprov.User.Claims.First(x => x.Type == "BranchID").Value;

        model.UserInfo.UserID = user.Identity.Name;
        model.BranchID = int.Parse(brancIDString);
        DialogParameters parms = new DialogParameters();
        parms.Add("model", model.Clone());
        var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Large };
        var dialog = await DialogService.ShowAsync<RoutineCheckListDialog>("Simple Dialog", parms, options);
        var result = await dialog.Result;

        // you can check if the modal was cancelled
        var isCancelled = result.Canceled;
        if (!isCancelled)
        {
            await GetAll();
        }
        await Task.Delay(200);
        _busy = false;
    }

    // Method to open a confirmation dialog for deleting a routine checklist
    private async Task OpenDialogDelete(RoutineCheckListModel model)
    {
        if (HasPermissionRoutineCheckListServiceDelete)
        {
            bool? result = await DialogService.ShowMessageBoxAsync(
                "Warning",
                "Are you sure, you want to delete - " + model.TruckName + " ?",
                yesText: "Delete!", cancelText: "Cancel");
            state = result == null ? "Cancelled" : "Deleted!";
            if (state == "Deleted!")
            {
                var authprov = await auth.GetAuthenticationStateAsync();
                var user = authprov.User;
                model.UserInfo = new();
                if (model.UserInfo != null)
                {
                    model.UserInfo.UserID = user.Identity.Name;
                    Iservice.Delete(model.RoutineCheckListID, model.UserInfo.UserID); //delete the checklist
                }
                await GetAll();
            }
        }
        else
        {
            bool? result = await DialogService.ShowMessageBoxAsync(
                "Permission denied!",
                "You don't have any permission to Delete RoutineCheckList.");
        }
    }

    // Method to fetch all routine checklists
    private async Task GetAll()
    {
        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;
        var brancIDString = authprov.User.Claims.First(x => x.Type == "BranchID").Value;

        collection = new();
        model.UserInfo = new();
        if (model.UserInfo != null)
        {
            model.UserInfo.UserID = user.Identity.Name;
        }
        model.BranchID = int.Parse(brancIDString);

        // Fetch routine checklists for the branch
        collection = Iservice.SelectItemByBranch(model.BranchID)?.ToList() ?? null;
        foreach (var item in collection)
        {
            item.TruckName = TruckList?.FirstOrDefault(s => s.TruckID == item.TruckID)?.RegNo ?? "";
            string ItemNames = "";
            List<RoutineCheckListModel> TruckListTemp = new();

            // Fetch the last routine checklist details
            var TruckListTempSub = Iservice.GetLastRoutineCheckListDetailsUsingID(item.RoutineCheckListID);
            if (TruckListTempSub != null)
            {

                TruckListTemp = TruckListTempSub.ToList();
                foreach (var items in TruckListTemp.OrderBy(s => s.CreatedDate))
                {
                    if (items.ItemID != null && ItemList.Any(s => s.ItemID == items.ItemID))
                    {
                        if (ItemNames == string.Empty)
                        {
                            ItemNames = ItemList.First(s => s.ItemID == items.ItemID).ItemName;
                        }
                        else
                        {
                            ItemNames = ItemNames + "," + ItemList.First(s => s.ItemID == items.ItemID).ItemName;
                        }
                    }
                }
            }
            item.ItemNames = ItemNames;
        }
    }
}
