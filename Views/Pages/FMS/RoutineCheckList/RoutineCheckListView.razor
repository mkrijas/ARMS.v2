@page "/RoutineCheckListView"
@using ArmsModels.BaseModels.FMS
@using ArmsModels.BaseModels.General
@using ArmsServices.DataServices.FMS
@using ArmsServices.DataServices.Operations
@inject IRoutineCheckListService Iservice
@inject MudBlazor.ISnackbar snackbar
@inject AuthenticationStateProvider auth
@attribute [Authorize]
@inject IDialogService DialogService
@inject ITruckService IserviceTruck
@inject IRoutineCheckListMasterService IserviceRoutineMaster
@using System.Threading;
@inject IRoleService<RoleModel> Irole

<MudGrid Spacing="4">
    <MudItem xs="12">
        <MudTable Items="@collection" Dense="true" Hover="true" Striped="true" Elevation="10" @bind-place="model">
            <ToolBarContent>
                <MudText Typo="Typo.h6">Routine Check List</MudText>
                <MudTooltip Text="New Routine Check List">
                    <MudIconButton Disabled="@_busy" Icon="@Icons.Material.Filled.Add" Title="Add" @onclick="@(()=> OpenDialog(new RoutineCheckListModel()))" Color="Color.Dark" Size="Size.Small"></MudIconButton>
                </MudTooltip>
                <MudSpacer></MudSpacer>
            </ToolBarContent>
            <HeaderContent>
                <MudTh><MudTableSortLabel SortBy="new Func<RoutineCheckListModel, object>(x=> x.TruckName)" InitialDirection="SortDirection.Ascending">Truck Name</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<RoutineCheckListModel, object>(x=> x.Remarks)" InitialDirection="SortDirection.Ascending">Remarks</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<RoutineCheckListModel, object>(x=> x.ItemNames)" InitialDirection="SortDirection.Ascending">Routine Check List Names</MudTableSortLabel></MudTh>
                <MudTh>Actions</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="DocumentType">@context.TruckName</MudTd>
                <MudTd DataLabel="Description">@context.Remarks</MudTd>
                <MudTd DataLabel="Description">@context.ItemNames</MudTd>
                <MudTd DataLabel="Actions">
                    <MudTooltip Text="Edit">
                        <MudIconButton @onclick="@(()=> OpenDialog(context))" Color="Color.Primary" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" IconSize="Size.Small" />
                    </MudTooltip>
                    <MudTooltip Text="Remove">
                        <MudIconButton @onclick="@(()=> OpenDialogDelete(context))" Color="Color.Primary" Icon="@Icons.Material.Filled.Remove" Size="Size.Small" IconSize="Size.Small" />
                    </MudTooltip>
                </MudTd>
            </RowTemplate>
            <PagerContent>
                <MudTablePager PageSizeOptions="new int[] { 5, 10, 20, 50, 100 }" />
            </PagerContent>
        </MudTable>
    </MudItem>
</MudGrid>

@code {

    private RoutineCheckListModel model = new();
    private List<RoutineCheckListModel> collection = new();
    List<TruckModel> TruckList = new();
    List<RoutineCheckListMasterModel> ItemList = new();
    string state = "Message box hasn't been opened yet";
    private bool _busy;

    public bool HasPermissionRoutineCheckListServiceDelete { get; set; } = false;
    public int RoutineCheckListDocTypeID = 75;

    protected async override Task OnInitializedAsync()
    {
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionRoutineCheckListServiceDelete = await Irole.HasClaim(RoutineCheckListDocTypeID.ToString(), "Delete", ctc.Token);

        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;
        var brancIDString = authprov.User.Claims.First(x => x.Type == "BranchID").Value;
        TruckList = IserviceTruck.SelectByBranch(int.Parse(brancIDString), "All").ToList();
        ItemList = IserviceRoutineMaster.SelectItemByBranch(int.Parse(brancIDString)).ToList();

        await GetAll();
    }

    private async Task OpenDialog(RoutineCheckListModel model)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        _busy = true;
        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;
        var brancIDString = authprov.User.Claims.First(x => x.Type == "BranchID").Value;

        model.UserInfo.UserID = user.Identity.Name;
        model.BranchID = int.Parse(brancIDString);
        DialogParameters parms = new DialogParameters();
        parms.Add("model", model.Clone());
        var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Large };
        var dialog = DialogService.Show<RoutineCheckListDialog>("Simple Dialog", parms, options);
        var result = await dialog.Result;

        // you can check if the modal was cancelled
        var isCancelled = result.Cancelled;
        if (!isCancelled)
        {
            await GetAll();
        }
        await Task.Delay(200);
        _busy = false;
    }

    private async Task OpenDialogDelete(RoutineCheckListModel model)
    {
        if (HasPermissionRoutineCheckListServiceDelete)
        {
            bool? result = await DialogService.ShowMessageBox(
                "Warning",
                "Are you sure, you want to delete - " + model.TruckName + " ?",
                yesText: "Delete!", cancelText: "Cancel");
            state = result == null ? "Cancelled" : "Deleted!";
            if (state == "Deleted!")
            {
                var authprov = await auth.GetAuthenticationStateAsync();
                var user = authprov.User;
                model.UserInfo = new();
                if (model.UserInfo != null)
                {
                    model.UserInfo.UserID = user.Identity.Name;
                    Iservice.Delete(model.RoutineCheckListID, model.UserInfo.UserID);
                }
                await GetAll();
            }
        }
        else
        {
            bool? result = await DialogService.ShowMessageBox(
                "Permission denied!",
                "You dont have any permission to Delete RoutineCheckList.");
        }
    }

    private async Task GetAll()
    {
        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;
        var brancIDString = authprov.User.Claims.First(x => x.Type == "BranchID").Value;

        collection = new();
        model.UserInfo = new();
        if (model.UserInfo != null)
        {
            model.UserInfo.UserID = user.Identity.Name;
        }
        model.BranchID = int.Parse(brancIDString);
        collection = Iservice.SelectItemByBranch(model.BranchID)?.ToList() ?? null;
        foreach (var item in collection)
        {
            item.TruckName = TruckList?.FirstOrDefault(s => s.TruckID == item.TruckID)?.RegNo ?? "";
            string ItemNames = "";
            List<RoutineCheckListModel> TruckListTemp = new();
            var TruckListTempSub = Iservice.GetLastRoutineCheckListDetailsUsingID(item.RoutineCheckListID);
            if (TruckListTempSub != null)
            {

                TruckListTemp = TruckListTempSub.ToList();
                foreach (var items in TruckListTemp.OrderBy(s => s.CreatedDate))
                {
                    if (items.ItemID != null && ItemList.Any(s => s.ItemID == items.ItemID))
                    {
                        if (ItemNames == string.Empty)
                        {
                            ItemNames = ItemList.First(s => s.ItemID == items.ItemID).ItemName;
                        }
                        else
                        {
                            ItemNames = ItemNames + "," + ItemList.First(s => s.ItemID == items.ItemID).ItemName;
                        }
                    }
                }
            }
            item.ItemNames = ItemNames;
        }
    }
}