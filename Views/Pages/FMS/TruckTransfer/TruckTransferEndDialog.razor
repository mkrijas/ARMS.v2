@inject AuthenticationStateProvider auth
@inject ITruckTransferService Iservice
@inject IBranchService Ibranchservice
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<MudDialog>
    <TitleContent>
        @if (model.TruckTransferEndID == null || model.TruckTransferEndID == 0)
        {
            <MudText Typo="Typo.h6">
                <MudIcon Icon="@Icons.Material.Filled.Edit" Class="mr-3" /> Add Truck Transfer End.
            </MudText>
        }
        else
        {
            <MudText Typo="Typo.h6">
                <MudIcon Icon="@Icons.Material.Filled.Edit" Class="mr-3" /> Edit Truck Transfer End.
            </MudText>
        }
    </TitleContent>
    <DialogContent>

        <MudContainer Style="max-height: 400px; overflow-y: scroll; margin-left:20px">
            <EditForm id="formDriver" Model="@model" OnValidSubmit="Submit">
                <ObjectGraphDataAnnotationsValidator />
                <ValidationSummary />

                <MudItem xs="12" md="12">
                      <MudTextField @bind-Value="model.Truck.RegNo" Label="Truck" Variant="Variant.Outlined" Margin="Margin.Normal" For="@(() => model.Truck.RegNo)" Disabled></MudTextField>
                </MudItem>
                <MudItem xs="12" md="12">
                    <MudTextField @bind-Value="model.InitiationBranch.BranchName" Label="Initiation Branch" Variant="Variant.Outlined" Margin="Margin.Normal" For="@(() => model.InitiationBranch.BranchName)" Disabled></MudTextField>
                </MudItem>
                <MudItem xs="12" md="12" Class="mb-6">
                    <MudTextField @bind-Value="model.EndKM" Label="EndKM" Variant="Variant.Outlined" Margin="Margin.Normal" For="@(() => model.EndKM)" Required></MudTextField>
                </MudItem>
                <MudItem xs="12" md="12" Class="mb-6">
                    <MudTextField @bind-Value="model.Remarks" Label="Remarks" Variant="Variant.Outlined" Margin="Margin.Normal" For="@(() => model.Remarks)"></MudTextField>
                </MudItem>

            </EditForm>
        </MudContainer>

    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Submit" Class="px-12">Reached Branch</MudButton>
    </DialogActions>
</MudDialog>

@code {

    [CascadingParameter] MudDialogInstance MudDialog { get; set; }

    [Parameter]
    public TruckTransferEndModel model { get; set; } = new();




    protected override void OnInitialized()
    {
        branchID = model?.DestinationBranchID??0;
    }

    private int branchID { get; set; } = 0;

    protected override void OnParametersSet()
    {
    }
    void Cancel()
    {
        MudDialog.Cancel();
    }
    public async Task Submit()
    {
        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;
        if(model.Truck==null || model.Truck.TruckID == 0)
        {
            bool? result = await DialogService.ShowMessageBox(
            "Warning",
            "Please, Select truck.", yesText: "OK");

            return;
        }
        if (model != null)
        {

            model.UserInfo.UserID = user.Identity.Name;
            try
            {
                Iservice.UpdateEnd(model);
                Snackbar.Add("Transfered succesfully",Severity.Success);

            }
            catch(Exception ex)
            {
                Snackbar.Add(ex.Message,Severity.Error);
            }
        }

        MudDialog.Close(DialogResult.Ok(true));
    }

}


