@page "/TruckTransferEndView"

@inject ITruckTransferService Iservice
@inject MudBlazor.ISnackbar snackbar

@inject AuthenticationStateProvider auth
@attribute [Authorize]
@inject IDialogService DialogService


<MudGrid Spacing="4">
    <MudItem xs="12">
        <MudTable Items="@collection" Dense="true" Hover="true" Striped="true" Elevation="10" @bind-place="model">

            <HeaderContent>
                <MudTh><MudTableSortLabel SortBy="new Func<TruckTransferEndModel, object>(x=> x.Truck.RegNo)" InitialDirection="SortDirection.Ascending">Truck</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<TruckTransferEndModel, object>(x=> x.InitiationBranch.BranchName)" InitialDirection="SortDirection.Ascending">Initiation Branch</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<TruckTransferEndModel, object>(x=> x.TransferStatus)" InitialDirection="SortDirection.Ascending">Transfer Status</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<TruckTransferEndModel, object>(x=> x.StartKM)" InitialDirection="SortDirection.Ascending">Start KM</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<TruckTransferEndModel, object>(x=> x.EndKM)" InitialDirection="SortDirection.Ascending">End KM</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<TruckTransferEndModel, object>(x=> x.Remarks)" InitialDirection="SortDirection.Ascending">Remarks</MudTableSortLabel></MudTh>
                <MudTh>Actions</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Truck">@context.Truck.RegNo</MudTd>
                <MudTd DataLabel="Initiation Branch">@context.InitiationBranch.BranchName</MudTd>
                <MudTd DataLabel="Transfer Status">@context.TransferStatus</MudTd>
                <MudTd DataLabel="Start KM">@context.StartKM</MudTd>
                <MudTd DataLabel="End KM">@context.EndKM</MudTd>
                <MudTd DataLabel="Remarks">@context.Remarks</MudTd>
                <MudTd DataLabel="">
                    <MudTooltip Text="Edit">
                        <MudIconButton @onclick="@(()=> OpenDialogEdit(context))" Color="Color.Primary" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" IconSize="Size.Small" />
                    </MudTooltip>
                    <MudTooltip Text="Remove">
                        <MudIconButton @onclick="@(()=> OpenDialogDelete(context))" Color="Color.Primary" Icon="@Icons.Material.Filled.Remove" Size="Size.Small" IconSize="Size.Small" />
                    </MudTooltip>
                </MudTd>

            </RowTemplate>

            <PagerContent>
                <MudTablePager PageSizeOptions="new int[] { 5, 10, 20, 50, 100 }" />

            </PagerContent>
        </MudTable>
    </MudItem>
</MudGrid>
@code {


    private TruckTransferEndModel model = new();

    private List<TruckTransferEndModel> collection = new();

    string state = "Message box hasn't been opened yet";
    protected override void OnParametersSet()
    {
        //the param will be set now
        GetAll();

    }

    private async Task OpenDialogEdit(TruckTransferEndModel TruckTransferEnd)
    {


        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;
        var brancIDString = authprov.User.Claims.First(x => x.Type == "BranchID").Value;
        TruckTransferEnd.UserInfo = new();
        if (TruckTransferEnd.UserInfo != null)
        {
            TruckTransferEnd.UserInfo.UserID = user.Identity.Name;
        }
        TruckTransferEnd.InitiationBranchID = int.Parse(brancIDString);


        var model = new DialogParameters { ["model"] = TruckTransferEnd };

        var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Medium };
        var dialog = DialogService.Show<TruckTransferEndDialog>("Simple Dialog", model, options);

        var result = await dialog.Result;

        var isCancelled = result.Cancelled;
        if (!isCancelled)
        {
            GetAll();
        }
    }
    private async Task OpenDialogDelete(TruckTransferEndModel TruckTransferEnd)
    {
        if(TruckTransferEnd.TruckTransferEndID == null || TruckTransferEnd.TruckTransferEndID == 0)
        {
            snackbar.Add("Truck Not Received.",Severity.Error);
            return;
        }

        bool? result = await DialogService.ShowMessageBox(
            "Warning",
            "Are you sure you want to delete this entry?",
            yesText: "Delete!", cancelText: "Cancel");
        state = result == null ? "Cancelled" : "Deleted!";
        if (state == "Deleted!")
        {

            var authprov = await auth.GetAuthenticationStateAsync();
            var user = authprov.User;
            TruckTransferEnd.UserInfo = new();
            if (TruckTransferEnd.UserInfo != null)
            {
                TruckTransferEnd.UserInfo.UserID = user.Identity.Name;
                Iservice.DeleteEnd(TruckTransferEnd.TruckTransferEndID, TruckTransferEnd.UserInfo.UserID);
            }
            GetAll();
        }

    }
    protected override async Task OnInitializedAsync()
    {
        GetAll();
    }

    private async Task GetAll()
    {

        collection = new();

        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;
        var brancIDString = authprov.User.Claims.First(x => x.Type == "BranchID").Value;

        model.UserInfo = new();
        if (model.UserInfo != null)
        {
            model.UserInfo.UserID = user.Identity.Name;
        }
        model.DestinationBranchID = int.Parse(brancIDString);

        foreach (var item in Iservice.SelectPendingByBranchEnd(model.DestinationBranchID))
        {
            if(item.TruckTransferEndID == null || item.TruckTransferEndID == 0)
            {
                item.TransferStatus = "Transfer Not Completed";
            }
            else
            {
                item.TransferStatus = "Transfer Completed";
            }
            collection.Add(item);
        }


    }

}

