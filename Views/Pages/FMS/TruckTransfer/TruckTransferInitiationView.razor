@page "/TruckTransferInitiationView"

@inject ITruckTransferService Iservice
@inject MudBlazor.ISnackbar snackbar

@inject AuthenticationStateProvider auth
@attribute [Authorize]
@inject IDialogService DialogService


<MudGrid Spacing="4">
    <MudItem xs="12">
        <MudTable Items="@collection" Dense="true" Hover="true" Striped="true" Elevation="10" @bind-place="model">
            <ToolBarContent>
                <MudText Typo="Typo.h6">Truck Transfer Initiation View.</MudText>
                <MudTooltip Text="New Asset Request">
                    <MudIconButton Icon="@Icons.Material.Filled.Add" Title="Add" @onclick="@(()=> OpenDialogEdit(new TruckTransferInitiationModel()))" Color="Color.Dark" Size="Size.Small"></MudIconButton>
                </MudTooltip>
                <MudSpacer></MudSpacer>

            </ToolBarContent>
            <HeaderContent>
                <MudTh><MudTableSortLabel SortBy="new Func<TruckTransferInitiationModel, object>(x=> x.Truck.RegNo)" InitialDirection="SortDirection.Ascending">Truck</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<TruckTransferInitiationModel, object>(x=> x.DestinationBranch.BranchName)" InitialDirection="SortDirection.Ascending">Destination Branch</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<TruckTransferInitiationModel, object>(x=> x.StartKM)" InitialDirection="SortDirection.Ascending">Start KM</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<TruckTransferInitiationModel, object>(x=> x.Remarks)" InitialDirection="SortDirection.Ascending">Remarks</MudTableSortLabel></MudTh>
                <MudTh>Actions</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="DocumentType">@context.Truck.RegNo</MudTd>
                <MudTd DataLabel="StartDate">@context.DestinationBranch.BranchName</MudTd>
                <MudTd DataLabel="EndDate">@context.StartKM</MudTd>
                <MudTd DataLabel="Remarks">@context.Remarks</MudTd>
                <MudTd DataLabel="">
                    <MudTooltip Text="Edit">
                        <MudIconButton @onclick="@(()=> OpenDialogEdit(context))" Color="Color.Primary" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" IconSize="Size.Small" />
                    </MudTooltip>
                    <MudTooltip Text="Remove">
                        <MudIconButton @onclick="@(()=> OpenDialogDelete(context))" Color="Color.Primary" Icon="@Icons.Material.Filled.Remove" Size="Size.Small" IconSize="Size.Small" />
                    </MudTooltip>
                </MudTd>
                @* <MudTd DataLabel="">

                @if(@context.ApprovedInfo.RecordStatus!=1)
                {
                <MudTooltip Text="Approve">
                <MudFab @onclick="@(()=> Approve(context))" Color="Color.Success" Icon="@Icons.Material.Filled.Check" Size="Size.Small" IconSize="Size.Small" />
                </MudTooltip>
                }
                </MudTd>*@
            </RowTemplate>

            <PagerContent>
                <MudTablePager PageSizeOptions="new int[] { 5, 10, 20, 50, 100 }" />
                @*  <MudButton OnClick="selected" Variant="Variant.Filled" Color="Color.Success" ButtonType="ButtonType.Submit">Submit</MudButton>*@

            </PagerContent>
        </MudTable>
    </MudItem>
</MudGrid>
