    private async Task OpenDialogEdit(TruckTransferInitiationModel TruckTransferInitiation)
    {


        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;
        var brancIDString = authprov.User.Claims.First(x => x.Type == "BranchID").Value;
        TruckTransferInitiation.UserInfo = new();
        if (TruckTransferInitiation.UserInfo != null)
        {
            TruckTransferInitiation.UserInfo.UserID = user.Identity.Name;
        }
        TruckTransferInitiation.InitiationBranchID = int.Parse(brancIDString);


        var model = new DialogParameters { ["model"] = TruckTransferInitiation };

        var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Medium };
        var dialog = DialogService.Show<TruckTransferInitiationDialog>("Simple Dialog", model, options);

        var result = await dialog.Result;

        var isCancelled = result.Cancelled;
        if (!isCancelled)
        {
            GetAll();
        }
    }
    private async Task OpenDialogDelete(TruckTransferInitiationModel TruckTransferInitiation)
    {

        bool? result = await DialogService.ShowMessageBox(
            "Warning",
            "Are you sure you want to delete this entry?",
            yesText: "Delete!", cancelText: "Cancel");
        state = result == null ? "Cancelled" : "Deleted!";
        if (state == "Deleted!")
        {

            var authprov = await auth.GetAuthenticationStateAsync();
            var user = authprov.User;
            TruckTransferInitiation.UserInfo = new();
            if (TruckTransferInitiation.UserInfo != null)
            {
                TruckTransferInitiation.UserInfo.UserID = user.Identity.Name;
                Iservice.Delete(TruckTransferInitiation.TruckTransferInitiationID, TruckTransferInitiation.UserInfo.UserID);
            }
            GetAll();
        }

    }
    protected override async Task OnInitializedAsync()
    {
        GetAll();
    }

    private async Task GetAll()
    {

        collection = new();

        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;
        var brancIDString = authprov.User.Claims.First(x => x.Type == "BranchID").Value;

        model.UserInfo = new();
        if (model.UserInfo != null)
        {
            model.UserInfo.UserID = user.Identity.Name;
        }
        model.InitiationBranchID = int.Parse(brancIDString);

        foreach (var item in Iservice.SelectPendingByBranch(model.InitiationBranchID))
        {
            collection.Add(item);
        }


    }

