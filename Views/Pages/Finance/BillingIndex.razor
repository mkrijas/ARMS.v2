@page "/billing-index"
@using MudBlazor

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-4">
    <MudText Typo="Typo.h5" Class="mb-4" ><b>Billing Hub</b></MudText>
    <MudText Typo="Typo.body2" Class="mb-6" Color="Color.Secondary">Manage your billing, contracts, and financial documents from one central location.</MudText>

    <MudGrid>
        <!-- Contracts -->
        <MudItem xs="12" sm="6" md="4" lg="3">
            <MudCard Class="hover:elevation-10 cursor-pointer d-flex flex-column align-center justify-center py-8" 
                     Style="height: 100%; border-radius: 12px; transition: all 0.3s;" 
                     @onclick='() => NavigateTo("/order")' Elevation="3">
                <MudIcon Icon="@Icons.Material.Filled.Assignment" Color="Color.Primary" Size="Size.Large" Class="mb-3" Style="font-size: 3rem;" />
                <MudText Typo="Typo.h6" Align="Align.Center">Contracts</MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary" Align="Align.Center">Manage Customer Contracts</MudText>
            </MudCard>
        </MudItem>

        <!-- Tariffs -->
        <MudItem xs="12" sm="6" md="4" lg="3">
            <MudCard Class="hover:elevation-10 cursor-pointer d-flex flex-column align-center justify-center py-8" 
                     Style="height: 100%; border-radius: 12px; transition: all 0.3s;" 
                     @onclick='() => NavigateTo("/TariffTypes")' Elevation="3">
                <MudIcon Icon="@Icons.Material.Filled.MonetizationOn" Color="Color.Success" Size="Size.Large" Class="mb-3" Style="font-size: 3rem;" />
                <MudText Typo="Typo.h6" Align="Align.Center">Tariffs</MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary" Align="Align.Center">Manage Tariffs & Rates</MudText>
            </MudCard>
        </MudItem>

        <!-- Freight Booking -->
        <MudItem xs="12" sm="6" md="4" lg="3">
             <MudCard Class="hover:elevation-10 cursor-pointer d-flex flex-column align-center justify-center py-8" 
                     Style="height: 100%; border-radius: 12px; transition: all 0.3s;" 
                     @onclick='() => NavigateTo("/FreightBooking")' Elevation="3">
                <MudIcon Icon="@Icons.Material.Filled.LocalShipping" Color="Color.Info" Size="Size.Large" Class="mb-3" Style="font-size: 3rem;" />
                <MudText Typo="Typo.h6" Align="Align.Center">Freight Booking</MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary" Align="Align.Center">Book Freight & Logistics</MudText>
            </MudCard>
        </MudItem>

          <!-- Draft Bills -->
        <MudItem xs="12" sm="6" md="4" lg="3">
             <MudCard Class="hover:elevation-10 cursor-pointer d-flex flex-column align-center justify-center py-8" 
                     Style="height: 100%; border-radius: 12px; transition: all 0.3s;" 
                     @onclick='() => NavigateTo("/ConsolidateDraftBillView")' Elevation="3">
                <MudIcon Icon="@Icons.Material.Filled.EditNote" Color="Color.Warning" Size="Size.Large" Class="mb-3" Style="font-size: 3rem;" />
                <MudText Typo="Typo.h6" Align="Align.Center">Draft Bills</MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary" Align="Align.Center">Review Consolidated Drafts</MudText>
            </MudCard>
        </MudItem>

        <!-- Sales Invoice -->
        <MudItem xs="12" sm="6" md="4" lg="3">
             <MudCard Class="hover:elevation-10 cursor-pointer d-flex flex-column align-center justify-center py-8" 
                     Style="height: 100%; border-radius: 12px; transition: all 0.3s;" 
                     @onclick='() => NavigateTo("/Sale")' Elevation="3">
                <MudIcon Icon="@Icons.Material.Filled.Receipt" Color="Color.Secondary" Size="Size.Large" Class="mb-3" Style="font-size: 3rem;" />
                <MudText Typo="Typo.h6" Align="Align.Center">Sales Invoice</MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary" Align="Align.Center">Manage Sales Invoices</MudText>
            </MudCard>
        </MudItem>

         <!-- Credit/Debit Sales -->
        <MudItem xs="12" sm="6" md="4" lg="3">
             <MudCard Class="hover:elevation-10 cursor-pointer d-flex flex-column align-center justify-center py-8" 
                     Style="height: 100%; border-radius: 12px; transition: all 0.3s;" 
                     @onclick='() => NavigateTo("/DrCrNoteView")' Elevation="3">
                <MudIcon Icon="@Icons.Material.Filled.Note" Color="Color.Error" Size="Size.Large" Class="mb-3" Style="font-size: 3rem;" />
                <MudText Typo="Typo.h6" Align="Align.Center">Credit/Debit Notes</MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary" Align="Align.Center">Adjustments & Notes</MudText>
            </MudCard>
        </MudItem>

        <!-- Receipts -->
        <MudItem xs="12" sm="6" md="4" lg="3">
             <MudCard Class="hover:elevation-10 cursor-pointer d-flex flex-column align-center justify-center py-8" 
                     Style="height: 100%; border-radius: 12px; transition: all 0.3s;" 
                     @onclick='() => NavigateTo("/Receipt")' Elevation="3">
                <MudIcon Icon="@Icons.Material.Filled.Payment" Color="Color.Success" Size="Size.Large" Class="mb-3" Style="font-size: 3rem;" />
                <MudText Typo="Typo.h6" Align="Align.Center">Receipts</MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary" Align="Align.Center">Manage Incoming Payments</MudText>
            </MudCard>
        </MudItem>

         <!-- Outstanding Bills -->
        <MudItem xs="12" sm="6" md="4" lg="3">
             <MudCard Class="hover:elevation-10 cursor-pointer d-flex flex-column align-center justify-center py-8" 
                     Style="height: 100%; border-radius: 12px; transition: all 0.3s;" 
                     @onclick='() => NavigateTo("/OutstandingBillInfo")' Elevation="3">
                <MudIcon Icon="@Icons.Material.Filled.PendingActions" Color="Color.Tertiary" Size="Size.Large" Class="mb-3" Style="font-size: 3rem;" />
                <MudText Typo="Typo.h6" Align="Align.Center">Outstanding Bills</MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary" Align="Align.Center">Track Pending Settlements</MudText>
            </MudCard>
        </MudItem>

    </MudGrid>
</MudContainer>

@inject NavigationManager navManager

@code {
    private void NavigateTo(string uri)
    {
        navManager.NavigateTo(uri);
    }
}
