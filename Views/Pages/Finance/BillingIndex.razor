@page "/billing-index"
@using MudBlazor

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-8 mb-12">
    <div class="header-section mb-10">
        <MudText Typo="Typo.h4" Class="hub-title mb-2"><b>Financial Transactions Hub</b></MudText>       
    </div>

    <MudTabs Elevation="0" Rounded="true" ApplyEffectsToContents="true" PanelClass="px-0 pt-6" Centered="false" Class="billing-tabs">
        <!-- Billing Tab -->
        <MudTabPanel Text="Billing" Icon="@Icons.Material.Filled.Receipt">          
            <MudText Typo="Typo.body1" Class="hub-subtitle" Style="color: #667085; max-width: 600px;">
                Streamlined financial management. Access contracts, tariffs, and invoices from our centralized billing ecosystem.
            </MudText>
            <MudGrid Spacing="4">
                <!-- Contracts -->
                <MudItem xs="12" sm="6" md="4" lg="3">
                    <div class="billing-card-wrapper" @onclick='() => NavigateTo("/order")'>
                        <MudPaper Class="billing-glass-card p-6" Elevation="0">
                            <div class="icon-badge primary-badge">
                                <MudIcon Icon="@Icons.Material.Filled.Assignment" Size="Size.Large" />
                            </div>
                            <MudText Typo="Typo.h6" Class="card-title mt-4">Contracts</MudText>
                            <MudText Typo="Typo.body2" Class="card-desc">Manage Customer Agreements</MudText>
                            <div class="card-action-indicator">
                                <MudIcon Icon="@Icons.Material.Filled.ArrowForward" Size="Size.Small" />
                            </div>
                        </MudPaper>
                    </div>
                </MudItem>

                <!-- Tariffs -->
                <MudItem xs="12" sm="6" md="4" lg="3">
                    <div class="billing-card-wrapper" @onclick='() => NavigateTo("/TariffTypes")'>
                        <MudPaper Class="billing-glass-card p-6" Elevation="0">
                            <div class="icon-badge success-badge">
                                <MudIcon Icon="@Icons.Material.Filled.MonetizationOn" Size="Size.Large" />
                            </div>
                            <MudText Typo="Typo.h6" Class="card-title mt-4">Tariffs</MudText>
                            <MudText Typo="Typo.body2" Class="card-desc">Rates & Pricing Structures</MudText>
                            <div class="card-action-indicator">
                                <MudIcon Icon="@Icons.Material.Filled.ArrowForward" Size="Size.Small" />
                            </div>
                        </MudPaper>
                    </div>
                </MudItem>

                <!-- Freight Booking -->
                <MudItem xs="12" sm="6" md="4" lg="3">
                    <div class="billing-card-wrapper" @onclick='() => NavigateTo("/FreightBooking")'>
                        <MudPaper Class="billing-glass-card p-6" Elevation="0">
                            <div class="icon-badge info-badge">
                                <MudIcon Icon="@Icons.Material.Filled.LocalShipping" Size="Size.Large" />
                            </div>
                            <MudText Typo="Typo.h6" Class="card-title mt-4">Freight Booking</MudText>
                            <MudText Typo="Typo.body2" Class="card-desc">Logistics & Transportation</MudText>
                            <div class="card-action-indicator">
                                <MudIcon Icon="@Icons.Material.Filled.ArrowForward" Size="Size.Small" />
                            </div>
                        </MudPaper>
                    </div>
                </MudItem>

                <!-- Draft Bills -->
                <MudItem xs="12" sm="6" md="4" lg="3">
                    <div class="billing-card-wrapper" @onclick='() => NavigateTo("/ConsolidateDraftBillView")'>
                        <MudPaper Class="billing-glass-card p-6" Elevation="0">
                            <div class="icon-badge warning-badge">
                                <MudIcon Icon="@Icons.Material.Filled.EditNote" Size="Size.Large" />
                            </div>
                            <MudText Typo="Typo.h6" Class="card-title mt-4">Draft Bills</MudText>
                            <MudText Typo="Typo.body2" Class="card-desc">Review Pending Drafts</MudText>
                            <div class="card-action-indicator">
                                <MudIcon Icon="@Icons.Material.Filled.ArrowForward" Size="Size.Small" />
                            </div>
                        </MudPaper>
                    </div>
                </MudItem>

                <!-- Sales Invoice -->
                <MudItem xs="12" sm="6" md="4" lg="3">
                    <div class="billing-card-wrapper" @onclick='() => NavigateTo("/Sale")'>
                        <MudPaper Class="billing-glass-card p-6" Elevation="0">
                            <div class="icon-badge secondary-badge">
                                <MudIcon Icon="@Icons.Material.Filled.Receipt" Size="Size.Large" />
                            </div>
                            <MudText Typo="Typo.h6" Class="card-title mt-4">Sales Invoice</MudText>
                            <MudText Typo="Typo.body2" Class="card-desc">Issue & Manage Invoices</MudText>
                            <div class="card-action-indicator">
                                <MudIcon Icon="@Icons.Material.Filled.ArrowForward" Size="Size.Small" />
                            </div>
                        </MudPaper>
                    </div>
                </MudItem>

                <!-- Credit/Debit Notes -->
                <MudItem xs="12" sm="6" md="4" lg="3">
                    <div class="billing-card-wrapper" @onclick='() => NavigateTo("/DrCrNoteView")'>
                        <MudPaper Class="billing-glass-card p-6" Elevation="0">
                            <div class="icon-badge error-badge">
                                <MudIcon Icon="@Icons.Material.Filled.Note" Size="Size.Large" />
                            </div>
                            <MudText Typo="Typo.h6" Class="card-title mt-4">Credit/Debit Notes</MudText>
                            <MudText Typo="Typo.body2" Class="card-desc">Financial Adjustments</MudText>
                            <div class="card-action-indicator">
                                <MudIcon Icon="@Icons.Material.Filled.ArrowForward" Size="Size.Small" />
                            </div>
                        </MudPaper>
                    </div>
                </MudItem>
            </MudGrid>
        </MudTabPanel>

        <!-- Purchase Tab -->
        <MudTabPanel Text="Purchase" Icon="@Icons.Material.Filled.ShoppingCart">
            <MudGrid Spacing="4">
                <!-- Purchase Order -->
                <MudItem xs="12" sm="6" md="4" lg="3">
                    <div class="billing-card-wrapper" @onclick='() => NavigateTo("/PurchaseOrderView")'>
                        <MudPaper Class="billing-glass-card p-6" Elevation="0">
                            <div class="icon-badge primary-badge">
                                <MudIcon Icon="@Icons.Material.Filled.ListAlt" Size="Size.Large" />
                            </div>
                            <MudText Typo="Typo.h6" Class="card-title mt-4">Purchase Order</MudText>
                            <MudText Typo="Typo.body2" Class="card-desc">Vendor Orders</MudText>
                            <div class="card-action-indicator">
                                <MudIcon Icon="@Icons.Material.Filled.ArrowForward" Size="Size.Small" />
                            </div>
                        </MudPaper>
                    </div>
                </MudItem>

                <!-- Asset Purchase -->
                <MudItem xs="12" sm="6" md="4" lg="3">
                    <div class="billing-card-wrapper" @onclick='() => NavigateTo("/AssetPurchase")'>
                        <MudPaper Class="billing-glass-card p-6" Elevation="0">
                            <div class="icon-badge info-badge">
                                <MudIcon Icon="@Icons.Material.Filled.Inventory" Size="Size.Large" />
                            </div>
                            <MudText Typo="Typo.h6" Class="card-title mt-4">Asset Purchase</MudText>
                            <MudText Typo="Typo.body2" Class="card-desc">Capital Goods</MudText>
                            <div class="card-action-indicator">
                                <MudIcon Icon="@Icons.Material.Filled.ArrowForward" Size="Size.Small" />
                            </div>
                        </MudPaper>
                    </div>
                </MudItem>

                <!-- Tax Purchase -->
                <MudItem xs="12" sm="6" md="4" lg="3">
                    <div class="billing-card-wrapper" @onclick='() => NavigateTo("/TaxPurchaseView")'>
                        <MudPaper Class="billing-glass-card p-6" Elevation="0">
                            <div class="icon-badge error-badge">
                                <MudIcon Icon="@Icons.Material.Filled.AccountBalance" Size="Size.Large" />
                            </div>
                            <MudText Typo="Typo.h6" Class="card-title mt-4">Tax Purchase</MudText>
                            <MudText Typo="Typo.body2" Class="card-desc">GST & Other Taxes</MudText>
                            <div class="card-action-indicator">
                                <MudIcon Icon="@Icons.Material.Filled.ArrowForward" Size="Size.Small" />
                            </div>
                        </MudPaper>
                    </div>
                </MudItem>

                <!-- Inventory GRN -->
                <MudItem xs="12" sm="6" md="4" lg="3">
                    <div class="billing-card-wrapper" @onclick='() => NavigateTo("/InventoryGrn")'>
                        <MudPaper Class="billing-glass-card p-6" Elevation="0">
                            <div class="icon-badge success-badge">
                                <MudIcon Icon="@Icons.Material.Filled.Inventory" Size="Size.Large" />
                            </div>
                            <MudText Typo="Typo.h6" Class="card-title mt-4">Inventory GRN</MudText>
                            <MudText Typo="Typo.body2" Class="card-desc">Goods Receipt Notes</MudText>
                            <div class="card-action-indicator">
                                <MudIcon Icon="@Icons.Material.Filled.ArrowForward" Size="Size.Small" />
                            </div>
                        </MudPaper>
                    </div>
                </MudItem>
            </MudGrid>
        </MudTabPanel>

        <!-- Payment Tab -->
        <MudTabPanel Text="Payment" Icon="@Icons.Material.Filled.AccountBalanceWallet">
            <MudGrid Spacing="4">
                <!-- Outstanding -->
                <MudItem xs="12" sm="6" md="4" lg="3">
                    <div class="billing-card-wrapper" @onclick='() => NavigateTo("/OutstandingBillInfo")'>
                        <MudPaper Class="billing-glass-card p-6" Elevation="0">
                            <div class="icon-badge tertiary-badge">
                                <MudIcon Icon="@Icons.Material.Filled.PendingActions" Size="Size.Large" />
                            </div>
                            <MudText Typo="Typo.h6" Class="card-title mt-4">Outstanding</MudText>
                            <MudText Typo="Typo.body2" Class="card-desc">Track Pending Balances</MudText>
                            <div class="card-action-indicator">
                                <MudIcon Icon="@Icons.Material.Filled.ArrowForward" Size="Size.Small" />
                            </div>
                        </MudPaper>
                    </div>
                </MudItem>

                <!-- Payment Memo -->
                <MudItem xs="12" sm="6" md="4" lg="3">
                    <div class="billing-card-wrapper" @onclick='() => NavigateTo("/PaymentMemoView")'>
                        <MudPaper Class="billing-glass-card p-6" Elevation="0">
                            <div class="icon-badge info-badge">
                                <MudIcon Icon="@Icons.Material.Filled.Description" Size="Size.Large" />
                            </div>
                            <MudText Typo="Typo.h6" Class="card-title mt-4">Payment Memo</MudText>
                            <MudText Typo="Typo.body2" Class="card-desc">Payment Instructions</MudText>
                            <div class="card-action-indicator">
                                <MudIcon Icon="@Icons.Material.Filled.ArrowForward" Size="Size.Small" />
                            </div>
                        </MudPaper>
                    </div>
                </MudItem>

                <!-- Payment Initiated -->
                <MudItem xs="12" sm="6" md="4" lg="3">
                    <div class="billing-card-wrapper" @onclick='() => NavigateTo("/PaymentInitiatedView")'>
                        <MudPaper Class="billing-glass-card p-6" Elevation="0">
                            <div class="icon-badge success-badge">
                                <MudIcon Icon="@Icons.Material.Filled.Launch" Size="Size.Large" />
                            </div>
                            <MudText Typo="Typo.h6" Class="card-title mt-4">Initiated</MudText>
                            <MudText Typo="Typo.body2" Class="card-desc">Outbound Payments</MudText>
                            <div class="card-action-indicator">
                                <MudIcon Icon="@Icons.Material.Filled.ArrowForward" Size="Size.Small" />
                            </div>
                        </MudPaper>
                    </div>
                </MudItem>

                <!-- Sundry Payment -->
                <MudItem xs="12" sm="6" md="4" lg="3">
                    <div class="billing-card-wrapper" @onclick='() => NavigateTo("/SundryPaymentView")'>
                        <MudPaper Class="billing-glass-card p-6" Elevation="0">
                            <div class="icon-badge warning-badge">
                                <MudIcon Icon="@Icons.Material.Filled.Paid" Size="Size.Large" />
                            </div>
                            <MudText Typo="Typo.h6" Class="card-title mt-4">Sundry Payment</MudText>
                            <MudText Typo="Typo.body2" Class="card-desc">Misc Disbursements</MudText>
                            <div class="card-action-indicator">
                                <MudIcon Icon="@Icons.Material.Filled.ArrowForward" Size="Size.Small" />
                            </div>
                        </MudPaper>
                    </div>
                </MudItem>

                <!-- Auto Settlement -->
                <MudItem xs="12" sm="6" md="4" lg="3">
                    <div class="billing-card-wrapper" @onclick='() => NavigateTo("/AutoSettleView")'>
                        <MudPaper Class="billing-glass-card p-6" Elevation="0">
                            <div class="icon-badge primary-badge">
                                <MudIcon Icon="@Icons.Material.Filled.Autorenew" Size="Size.Large" />
                            </div>
                            <MudText Typo="Typo.h6" Class="card-title mt-4">Auto Settlement</MudText>
                            <MudText Typo="Typo.body2" Class="card-desc">Automatic Settlements</MudText>
                            <div class="card-action-indicator">
                                <MudIcon Icon="@Icons.Material.Filled.ArrowForward" Size="Size.Small" />
                            </div>
                        </MudPaper>
                    </div>
                </MudItem>

                <!-- InterBranch Payment Memo -->
                <MudItem xs="12" sm="6" md="4" lg="3">
                    <div class="billing-card-wrapper" @onclick='() => NavigateTo("/InterBranchPaymentMemoView")'>
                        <MudPaper Class="billing-glass-card p-6" Elevation="0">
                            <div class="icon-badge error-badge">
                                <MudIcon Icon="@Icons.Material.Filled.AccountTree" Size="Size.Large" />
                            </div>
                            <MudText Typo="Typo.h6" Class="card-title mt-4" Style="font-size: 1.1rem;">InterBranch Memo</MudText>
                            <MudText Typo="Typo.body2" Class="card-desc">InterBranch Payments</MudText>
                            <div class="card-action-indicator">
                                <MudIcon Icon="@Icons.Material.Filled.ArrowForward" Size="Size.Small" />
                            </div>
                        </MudPaper>
                    </div>
                </MudItem>
            </MudGrid>
        </MudTabPanel>

        <!-- Receipts Tab -->
        <MudTabPanel Text="Receipts" Icon="@Icons.Material.Filled.Payments">
            <MudGrid Spacing="4">
                <!-- Receipts -->
                <MudItem xs="12" sm="6" md="4" lg="3">
                    <div class="billing-card-wrapper" @onclick='() => NavigateTo("/Receipt")'>
                        <MudPaper Class="billing-glass-card p-6" Elevation="0">
                            <div class="icon-badge success-alt-badge">
                                <MudIcon Icon="@Icons.Material.Filled.Payment" Size="Size.Large" />
                            </div>
                            <MudText Typo="Typo.h6" Class="card-title mt-4">Receipts</MudText>
                            <MudText Typo="Typo.body2" Class="card-desc">Incoming Payments</MudText>
                            <div class="card-action-indicator">
                                <MudIcon Icon="@Icons.Material.Filled.ArrowForward" Size="Size.Small" />
                            </div>
                        </MudPaper>
                    </div>
                </MudItem>

                <!-- Sundry Receipts -->
                <MudItem xs="12" sm="6" md="4" lg="3">
                    <div class="billing-card-wrapper" @onclick='() => NavigateTo("/SundryReceiptView")'>
                        <MudPaper Class="billing-glass-card p-6" Elevation="0">
                            <div class="icon-badge info-badge">
                                <MudIcon Icon="@Icons.Material.Filled.AccountBalanceWallet" Size="Size.Large" />
                            </div>
                            <MudText Typo="Typo.h6" Class="card-title mt-4">Sundry Receipt</MudText>
                            <MudText Typo="Typo.body2" Class="card-desc">Misc Collections</MudText>
                            <div class="card-action-indicator">
                                <MudIcon Icon="@Icons.Material.Filled.ArrowForward" Size="Size.Small" />
                            </div>
                        </MudPaper>
                    </div>
                </MudItem>

                <!-- Mileage Shortage -->
                <MudItem xs="12" sm="6" md="4" lg="3">
                    <div class="billing-card-wrapper" @onclick='() => NavigateTo("/MileageShortageReceiptView")'>
                        <MudPaper Class="billing-glass-card p-6" Elevation="0">
                            <div class="icon-badge error-badge">
                                <MudIcon Icon="@Icons.Material.Filled.Speed" Size="Size.Large" />
                            </div>
                            <MudText Typo="Typo.h6" Class="card-title mt-4">Shortage</MudText>
                            <MudText Typo="Typo.body2" Class="card-desc">Mileage Deductions</MudText>
                            <div class="card-action-indicator">
                                <MudIcon Icon="@Icons.Material.Filled.ArrowForward" Size="Size.Small" />
                            </div>
                        </MudPaper>
                    </div>
                </MudItem>

                <!-- Inter-Branch -->
                <MudItem xs="12" sm="6" md="4" lg="3">
                    <div class="billing-card-wrapper" @onclick='() => NavigateTo("/InterBranchReceiptView")'>
                        <MudPaper Class="billing-glass-card p-6" Elevation="0">
                            <div class="icon-badge secondary-badge">
                                <MudIcon Icon="@Icons.Material.Filled.Shuffle" Size="Size.Large" />
                            </div>
                            <MudText Typo="Typo.h6" Class="card-title mt-4">Inter-Branch</MudText>
                            <MudText Typo="Typo.body2" Class="card-desc">Internal Transfers</MudText>
                            <div class="card-action-indicator">
                                <MudIcon Icon="@Icons.Material.Filled.ArrowForward" Size="Size.Small" />
                            </div>
                        </MudPaper>
                    </div>
                </MudItem>
            </MudGrid>
        </MudTabPanel>
    </MudTabs>
</MudContainer>

<style>
    .hub-title {
        color: #1a202c;
        letter-spacing: -0.5px;
    }

    .title-accent {
        width: 60px;
        height: 5px;
        background: linear-gradient(90deg, #594ae2, #ff4081);
        border-radius: 10px;
    }

    .billing-card-wrapper {
        cursor: pointer;
        height: 100%;
        transition: transform 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    }

    .billing-card-wrapper:hover {
        transform: translateY(-10px) scale(1.02);
    }

    .billing-glass-card {
        height: 100%;
        min-height: 220px;
        background: rgba(255, 255, 255, 0.8) !important;
        backdrop-filter: blur(10px);
        border: 1px solid rgba(255, 255, 255, 0.3);
        border-radius: 20px !important;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        position: relative;
        overflow: hidden;
        box-shadow: 0 10px 30px rgba(0,0,0,0.05) !important;
        transition: box-shadow 0.3s ease;
    }

    .billing-card-wrapper:hover .billing-glass-card {
        box-shadow: 0 20px 40px rgba(89, 74, 226, 0.15) !important;
        background: rgba(255, 255, 255, 0.95) !important;
    }

    .icon-badge {
        width: 70px;
        height: 70px;
        border-radius: 20px;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: transform 0.3s ease;
    }

    .billing-card-wrapper:hover .icon-badge {
        transform: rotate(10deg);
    }

    /* Badge Themes */
    .primary-badge { background: #eef2ff; color: #594ae2; }
    .success-badge { background: #ecfdf5; color: #059669; }
    .info-badge { background: #eff6ff; color: #2563eb; }
    .warning-badge { background: #fffbeb; color: #d97706; }
    .secondary-badge { background: #f8fafc; color: #64748b; }
    .error-badge { background: #fef2f2; color: #dc2626; }
    .success-alt-badge { background: #f0fdf4; color: #16a34a; }
    .tertiary-badge { background: #f0fdfa; color: #0d9488; }

    .card-title {
        font-weight: 700;
        color: #2d3748;
    }

    .card-desc {
        color: #718096;
        text-align: center;
        margin-top: 4px;
    }

    .card-action-indicator {
        position: absolute;
        bottom: 15px;
        right: 15px;
        opacity: 0;
        transform: translateX(-10px);
        transition: all 0.3s ease;
        color: #594ae2;
    }

    .billing-tabs {
        background: transparent;
    }

    ::deep .mud-tabs-tab {
        font-family: 'Outfit', sans-serif;
        font-weight: 600;
        text-transform: none;
        letter-spacing: 0.5px;
        color: #64748b !important;
        padding: 12px 24px;
        transition: all 0.3s ease;
    }

    ::deep .mud-tab-active {
        color: #594ae2 !important;
    }

    ::deep .mud-tabs-toolbar {
        background: rgba(255, 255, 255, 0.4);
        backdrop-filter: blur(10px);
        border-radius: 12px;
        padding: 4px;
        border: 1px solid rgba(255, 255, 255, 0.2);
    }

    ::deep .mud-tab-slider {
        background: #594ae2;
        height: 3px;
        border-radius: 3px;
    }

    .billing-card-wrapper:hover .card-action-indicator {
        opacity: 1;
        transform: translateX(0);
    }
</style>

@inject NavigationManager navManager

@code {
    private void NavigateTo(string uri)
    {
        navManager.NavigateTo(uri);
    }
}
