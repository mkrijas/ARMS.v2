<MudDialog Options="dialogOptions">
    @*<TitleContent>
    <MudText Typo="Typo.h6">
    <MudIcon Icon="@Icons.Material.Filled.Edit" Class="mr-3"/> Add New Ledger Under @Parent
    </MudText>
    </TitleContent>*@
    <DialogContent>
        <MudTextField @bind-Value="@model.AccountName" Label="Ledger Name" Variant="Variant.Outlined" Margin="Margin.Dense" />
        <MudTextField @bind-Value="@model.AccountDescription" Label="Description" Variant="Variant.Outlined" Margin="Margin.Dense" />
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Submit" Class="px-10">Submit</MudButton>
    </DialogActions>
</MudDialog>
@code {
    [CascadingParameter] MudDialogInstance MudDialog { get; set; }

    [Parameter] public ChartOfAccountModel model { get; set; } = new();
    //[Parameter] public string Parent { get; set; }


    void Cancel()
    {
        MudDialog.Cancel();
    }
    void Submit()
    {
        MudDialog.Close(model);
    }

    private DialogOptions dialogOptions = new() { FullWidth = true };
}
