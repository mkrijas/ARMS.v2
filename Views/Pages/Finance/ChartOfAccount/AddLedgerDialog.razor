@inject MudBlazor.ISnackbar snackbar

<MudDialog Options="dialogOptions">
    <DialogContent>
        <MudTextField @bind-Value="@model.AccountName" Label="Ledger Name" Variant="Variant.Outlined" Margin="Margin.Dense" />
        <MudTextField @bind-Value="@model.AccountDescription" Label="Description" Variant="Variant.Outlined" Margin="Margin.Dense" />
    </DialogContent>
    <DialogActions>
        <MudButton Disabled="@_busy" Variant="Variant.Filled" Color="Color.Primary" OnClick="Submit" Class="px-10">Submit</MudButton>
    </DialogActions>
</MudDialog>

@code {

    [CascadingParameter] MudDialogInstance MudDialog { get; set; }
    [Parameter] public ChartOfAccountModel model { get; set; } = new();
    private bool _busy;

    void Cancel()
    {
        MudDialog.Cancel();
    }

    async void Submit()
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is being submitted!", Severity.Warning);
            return;
        }
        _busy = true;

        MudDialog.Close(model);
        await Task.Delay(200);
        _busy = false;
    }

    private DialogOptions dialogOptions = new() { FullWidth = true };
}