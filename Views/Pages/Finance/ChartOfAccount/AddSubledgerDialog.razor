@inject IChartOfAccountService Iservice
@inject MudBlazor.ISnackbar snackbar
@using System.Threading;

<MudDialog Options="dialogOptions">
    <DialogContent>
        <EditForm id="CoaForm" Model="@model" OnValidSubmit="Submit">
            <DataAnnotationsValidator />
            <ValidationSummary></ValidationSummary>
            <MudTextField @bind-Value="@model.AccountCode" Label="Ledger Code" Variant="Variant.Outlined" Margin="Margin.Normal" ReadOnly="@(model.CoaID != null ? true : false)" Disabled />
             <ValidationMessage For="@(()=>model.AccountCode)" />
             <MudTextField @bind-Value="@model.AccountName" Label="Ledger Name" Variant="Variant.Outlined" Margin="Margin.Normal" Required="true" RequiredError="LedgerName is required!" />
             <ValidationMessage For="@(()=>model.AccountName)" />
             @if (EditMode)
            {
                <MudAutocomplete T="ChartOfAccountModel" Value="@SelectedGroup" ValueChanged="GroupSelected" SearchFunc="@(async (string s, CancellationToken t) => await SearchGroups(s, t))" ToStringFunc="@(x => x?.AccountName)" Label="Group Name" Variant="Variant.Outlined" Margin="Margin.Normal" ResetValueOnEmptyText="true" Required="true" RequiredError="Group Name is required!" />
                <ValidationMessage For="@(()=>model.ParentID)" />
            }
            <MudTextField @bind-Value="@model.AccountDescription" Label="Description" Variant="Variant.Outlined" Margin="Margin.Normal" />
            <ValidationMessage For="@(()=>model.AccountDescription)" />
            <MudCheckBox T="bool" @bind-Value="@model.IsCostCenterMandatory"  Label="CostCenter Mandatory" Color="Color.Primary"></MudCheckBox>
            <MudCheckBox T="bool" @bind-Value="@model.IsDimensionMandatory" Label="Dimension Mandatory" Color="Color.Primary"></MudCheckBox>
            <MudGrid>
                <MudItem Style="padding-top:24px; margin-right:-62px" xs="12" md="5">
                    <MudCheckBox T="bool" Value="@model.LimitToPeriod" ValueChanged="CheckChanged" Label="Limit to Period ?" Color="Color.Primary"></MudCheckBox>
                </MudItem>
                @if (@model.LimitToPeriod == true)
                {
                    <MudItem xs="12" md="8" Style="margin-left:14px; padding-top:4px;">
                        <MudDateRangePicker TransformOrigin="Origin.CenterLeft" Editable="true" Label="Custom start month" Variant="Variant.Outlined" Margin="Margin.Normal" StartMonth="@(new DateTime(DateTime.Now.Year - 1,4,1))" DateRange="@_dateRange" DateRangeChanged="DateChanged" Disabled="@(!model.LimitToPeriod)" />
                    </MudItem>
                }
            </MudGrid>
            <ValidationMessage For="@(()=>model.PeriodFrom)" />
            <ValidationMessage For="@(()=>model.PeriodFrom)" />
        </EditForm>
    </DialogContent>
    <DialogActions>
        <MudButton Disabled="@_busy" ButtonType="ButtonType.Submit" form="CoaForm" Variant="Variant.Filled" Color="Color.Primary" Class="px-10" Style="margin-right:18px; margin-bottom:18px;">Submit</MudButton>
    </DialogActions>
</MudDialog>

@code {

    [CascadingParameter] IMudDialogInstance MudDialog { get; set; }
    [Parameter] public ChartOfAccountModel model { get; set; } = new();
    bool EditMode = false;
    private bool _busy;
    public List<ChartOfAccountModel> Groups;
    private ChartOfAccountModel SelectedGroup;
    private DateRange _dateRange { get; set; }

    // Lifecycle method called when the component is initialized
    protected override void OnInitialized()
    {
        if (model.ParentID == null)
        {
            Groups = Iservice.AllGroups().ToList(); // Fetch all groups from the service
            EditMode = true;
        }
        if (model.PeriodFrom != null)
            _dateRange = new DateRange(model.PeriodFrom, model.PeriodTo);
    }

    // Method to handle the selection of a group
    void GroupSelected(ChartOfAccountModel group)
    {
        SelectedGroup = group;
        model.ParentID = group?.CoaID;
        model.AccountType = group?.AccountType;
    }

    // Method to search for groups based on a search string
    private async Task<IEnumerable<ChartOfAccountModel>> SearchGroups(string searchString, CancellationToken token)
    {
        return await Task.FromResult(Groups.Where(x => x.AccountName.Contains(searchString == null ? string.Empty : searchString, StringComparison.InvariantCultureIgnoreCase)));
    }

    // Method to handle date range changes
    void DateChanged(DateRange dates)
    {
        _dateRange = dates;
        if (_dateRange != null)
        {
            model.PeriodFrom = _dateRange.Start;
            model.PeriodTo = _dateRange.End;
        }
        else
        {
            model.PeriodFrom = null;
            model.PeriodTo = null;
        }
    }

    // Method to handle changes to the checkbox for limiting to a period
    void CheckChanged(bool Checked)
    {
        if (!Checked)
        {
            _dateRange = null;
            model.PeriodFrom = null;
            model.PeriodTo = null;
            model.LimitToPeriod = false;
        }
        else
        {
            model.LimitToPeriod = true;
        }
    }

    // Method to cancel the dialog
    void Cancel()
    {
        MudDialog.Cancel();
    }

    // Method to handle form submission
    async void Submit()
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is being submitted!", Severity.Warning);
            return;
        }
        _busy = true;

        if (!model.LimitToPeriod)
        {
            model.PeriodFrom = null;
            model.PeriodTo = null;
        }
        MudDialog.Close(model);

        await Task.Delay(200);
        _busy = false;
    }

    private DialogOptions dialogOptions = new() { FullWidth = true };
}
