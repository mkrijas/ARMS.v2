<MudDialog Options="dialogOptions">
    @*<TitleContent>
    <MudText Typo="Typo.h6">
    <MudIcon Icon="@Icons.Material.Filled.Edit" Class="mr-3"/> Add New Subledger Under @Parent
    </MudText>
    </TitleContent>*@
    <DialogContent>
        <EditForm id="CoaForm" Model="@model" OnValidSubmit="Submit">
            <DataAnnotationsValidator />
            <MudTextField @bind-Value="@model.AccountCode" Label="Ledger Code" Variant="Variant.Outlined" Margin="Margin.Normal" ReadOnly="@(model.CoaID != null ? true : false)" Disabled />
            <ValidationMessage For="@(()=>model.AccountCode)" />
            <MudTextField @bind-Value="@model.AccountName" Label="Ledger Name" Variant="Variant.Outlined" Margin="Margin.Normal" Required="true" RequiredError="LedgerName is required!" />
            <ValidationMessage For="@(()=>model.AccountName)" />
            <MudTextField @bind-Value="@model.AccountDescription" Label="Description" Variant="Variant.Outlined" Margin="Margin.Normal" />
            <MudDateRangePicker TransformOrigin="Origin.CenterLeft" Editable="true" Label="Custom start month" StartMonth="@(new DateTime(DateTime.Now.Year - 1,4,1))" @bind-DateRange="_dateRange" />

        </EditForm>
        @*<MudTextField @bind-Value="@model.AccountCode" Label="Ledger Code" Variant="Variant.Outlined" Margin="Margin.Dense" Required="true" RequiredError="Ledger Code is required!" ReadOnly="@(model.CoaID != null ? true : false)" />
        <MudTextField @bind-Value="@model.AccountName" Label="Ledger Name" Variant="Variant.Outlined" Margin="Margin.Dense" Required="true" RequiredError="Ledger Name is required!" />
        <MudTextField  @bind-Value="@model.AccountDescription" Label="Description" Variant="Variant.Outlined" Margin="Margin.Dense"/>
        <MudDateRangePicker Editable="true" Label="Custom start month" StartMonth="@(new DateTime(DateTime.Now.Year - 1,4,1))" @bind-DateRange="_dateRange" />*@
    </DialogContent>
    <DialogActions>
        <MudButton ButtonType="ButtonType.Submit"  form="CoaForm" Variant="Variant.Filled" Color="Color.Primary" Class="px-10">Submit</MudButton>
    </DialogActions>
</MudDialog>
@code {
    [CascadingParameter] MudDialogInstance MudDialog { get; set; }

    [Parameter] public ChartOfAccountModel model { get; set; } = new();
    //[Parameter] public string Parent { get; set; }

    private DateRange _dateRange { get; set; }


    void Cancel()
    {
        MudDialog.Cancel();
    }
    void Submit()
    {
        MudDialog.Close(model);
    }

    private DialogOptions dialogOptions = new() { FullWidth = true };
}
