@page "/BankReconciliationView"
@using ArmsModels.BaseModels.Finance.Transactions;
@using ArmsServices.DataServices.Finance.Transactions;
@using Microsoft.AspNetCore.Authorization;
@using Microsoft.AspNetCore.Components.Authorization;
@using MudBlazor;
@using Views.Pages.Finance.Transactions;
@using System.Threading;

@attribute [Authorize]
@inject AuthenticationStateProvider auth
@inject IBankAccountOwnService IbankOwnservice
@inject IUnreconciledBankEntryService IunreconciledBankEntryService
@inject MudBlazor.ISnackbar snackbar
@inject IDialogService DialogService
@inject IInventoryReleaseService Iservice


<style>
    .bigcell {
        width: 150px !important;        
    }
</style>

@if (_isLoading)
{
    <div @key="@("loader")" style="display: flex; justify-content: center; align-items: center; min-height: 400px;">
        <LoaderComponent IsFullScreen="true" 
                        ShowLogo="false" 
                        Size="medium" 
                        LoadingText="Loading Bank Reconciliation" 
                        SubText="Please wait..." />
    </div>
}
else
{
    <div class="fade-in">
        <div class="admin-header-tiered mb-6">
            <div class="d-flex align-center justify-space-between">
                <div>
                    <MudText Typo="Typo.h4" Class="admin-title">Bank Reconciliation</MudText>
                    <MudText Typo="Typo.body2" Class="admin-subtitle">Reconcile bank statements with internal ledger entries. Select a bank and period to begin the audit process and verify financial accuracy.</MudText>
                </div>
            </div>
        </div>

        <div class="admin-glass-card mb-6 pa-6">
            <MudGrid Spacing="4" Class="align-center">
                <MudItem xs="12" md="4">
                    <MudAutocomplete Label="Select Bank" @bind-Value="SelectedBank" SearchFunc="SearchBanks" T="OwnBankModel" Variant="Variant.Outlined" Margin="Margin.Dense" AdornmentColor="Color.Primary" AdornmentIcon="@Icons.Material.Filled.AccountBalance" ToStringFunc="@(e => (e == null) ? null :( string.IsNullOrEmpty(e.BankAccountInfo.BankTitle) ? "" : string.Format("{0} | {1}",e.BankCode,e.BankAccountInfo.BankTitle)))" Clearable="true" />
                </MudItem>
                <MudItem xs="12" md="3">
                    <MudDateRangePicker Label="Reconciliation Period" @bind-DateRange="@dateRange" Variant="Variant.Outlined" Margin="Margin.Dense" DisableToolbar="true" Editable="true" DateFormat="dd/MM/yyyy" AdornmentColor="Color.Primary" />
                </MudItem>
                <MudItem xs="12" md="3">
                    <MudCheckBox T="bool" ValueChanged="@SetIsViewReconciledEntry" Value="@IsViewReconciledEntry" Label="Show Reconciled Entries Only" Color="Color.Primary" Class="fw-600" Dense="true" />
                </MudItem>
                <MudItem xs="12" md="2">
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Refresh" OnClick="(()=>FetchDetails())" FullWidth="true" Class="py-2 fw-700">FETCH DATA</MudButton>
                </MudItem>
            </MudGrid>
        </div>

        @if (IsViewReconciledEntry)
        {
            <div class="admin-glass-card pa-0 overflow-hidden mb-6">
                <MudTable Items="@ReconciledEntries" Elevation="0" Class="modern-admin-table" Hover="true">
                    <HeaderContent>
                        <MudTh><MudTableSortLabel SortBy="new Func<ReconciledBankEntryModel, object>(x=> x.DocDate)" InitialDirection="SortDirection.Ascending"><span class="admin-header-text">DOC DATE</span></MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<ReconciledBankEntryModel, object>(x=> x.DocNumber)"><span class="admin-header-text">DOC NUMBER</span></MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<ReconciledBankEntryModel, object>(x=> x.Remarks)"><span class="admin-header-text">DESCRIPTION</span></MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<ReconciledBankEntryModel, object>(x=> x.Amount)"><span class="admin-header-text">AMOUNT</span></MudTableSortLabel></MudTh>
                        <MudTh><span class="admin-header-text">RECONCILED DATE</span></MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="Date"><span class="fw-500">@context.DocDate</span></MudTd>
                        <MudTd DataLabel="DocNumber"><span class="admin-td-primary fw-700">@context.DocNumber</span></MudTd>
                        <MudTd DataLabel="Description">
                            <div class="d-flex flex-column">
                                <span class="fw-600">@context.Remarks</span>
                                <span class="admin-td-secondary text-truncate" style="max-width: 300px;">@context.Narration</span>
                            </div>
                        </MudTd>
                        <MudTd DataLabel="Amount">
                            <MudChip T="string" Size="Size.Small" Color="Color.Success" Variant="Variant.Text" Class="fw-700">@context.Amount?.ToString("N2")</MudChip>
                        </MudTd>
                        <MudTd DataLabel="ReconciledDate">
                            <span class="fw-600 text-primary">@context.ReconciledDate?.ToString("dd MMM yyyy")</span>
                        </MudTd>
                    </RowTemplate>
                    <PagerContent>
                        <div class="pa-4">
                            <MudTablePager PageSizeOptions="new int[] { 10, 20, 50, 100 }" />
                        </div>
                    </PagerContent>
                </MudTable>
            </div>
        }
        else
        {
            <div class="admin-glass-card pa-0 overflow-hidden mb-6">
                <MudTable Items="@UnReconciledEntries" Elevation="0" Class="modern-admin-table" Hover="true">
                    <HeaderContent>
                        <MudTh><MudTableSortLabel SortBy="new Func<ReconciledBankEntryModel, object>(x=> x.DocDate)" InitialDirection="SortDirection.Ascending"><span class="admin-header-text">DOC DATE</span></MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<ReconciledBankEntryModel, object>(x=> x.DocNumber)"><span class="admin-header-text">DOC NUMBER</span></MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<ReconciledBankEntryModel, object>(x=> x.Remarks)"><span class="admin-header-text">DESCRIPTION</span></MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<ReconciledBankEntryModel, object>(x=> x.Amount)"><span class="admin-header-text">AMOUNT</span></MudTableSortLabel></MudTh>
                        <MudTh><span class="admin-header-text">RECONCILE DATE</span></MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="Date"><span class="fw-500">@context.DocDate?.ToString("dd MMM yyyy")</span></MudTd>
                        <MudTd DataLabel="DocNumber"><span class="admin-td-primary fw-700">@context.DocNumber</span></MudTd>
                        <MudTd DataLabel="Description">
                            <div class="d-flex flex-column">
                                <span class="fw-600">@context.Remarks</span>
                                <span class="admin-td-secondary text-truncate" style="max-width: 300px;">@context.Narration</span>
                            </div>
                        </MudTd>
                        <MudTd DataLabel="Amount">
                            <MudChip T="string" Size="Size.Small" Color="Color.Error" Variant="Variant.Text" Class="fw-700">@context.Amount?.ToString("N2")</MudChip>
                        </MudTd>
                        <MudTd DataLabel="Reconcile" style="min-width:200px;">
                            <MudDatePicker Variant="Variant.Outlined" Margin="Margin.Dense" AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.BottomLeft" For="@(() => @context.ReconciledDate)" DisableToolbar="true" Editable="true" DateFormat="dd/MM/yyyy" @bind-Date="@context.ReconciledDate" Class="admin-input-group" />
                        </MudTd>
                    </RowTemplate>
                    <PagerContent>
                        <div class="d-flex align-center justify-space-between pa-4">
                            @if (UnReconciledEntries.Any(x => x.ReconciledDate is not null))
                            {
                                <MudButton Variant="Variant.Filled" Color="Color.Success" StartIcon="@Icons.Material.Filled.CheckCircle" OnClick="SaveRecounsileEntry" Class="fw-700">RECONCILE SELECTED</MudButton>
                            }
                            else
                            {
                                <div></div>
                            }
                            <MudTablePager PageSizeOptions="new int[] { 10, 20, 50, 100 }" />
                        </div>
                    </PagerContent>
                </MudTable>
            </div>
        }

        @if (UnReconciledEntriesSummary != null && UnReconciledEntriesSummary.Count() != 0)
        {
            <div class="admin-header-tiered mb-4 mt-8">
                <MudText Typo="Typo.h5" Class="admin-title">Reconciliation Summary <small class="admin-subtitle ml-2">@UnReconciledEntriesSummaryLabel</small></MudText>
            </div>
            <div class="admin-glass-card pa-0 overflow-hidden">
                <MudTable Items="@UnReconciledEntriesSummary" Elevation="0" Class="modern-admin-table" Hover="true">
                    <HeaderContent>
                        <MudTh><span class="admin-header-text">ENTITY</span></MudTh>
                        <MudTh><span class="admin-header-text">OPENING</span></MudTh>
                        <MudTh><span class="admin-header-text">TRANSACTION</span></MudTh>
                        <MudTh><span class="admin-header-text">CLOSING</span></MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="Entity"><span class="fw-700 admin-td-primary">@context.BankOrCompany</span></MudTd>
                        <MudTd DataLabel="Opening"><span class="fw-600">@context.OpeningAmount?.ToString("N2")</span></MudTd>
                        <MudTd DataLabel="Transaction"><span class="fw-600">@context.TransactionAmount?.ToString("N2")</span></MudTd>
                        <MudTd DataLabel="Closing"><span class="fw-700 text-primary">@context.ClossingAmount?.ToString("N2")</span></MudTd>
                    </RowTemplate>
                </MudTable>
            </div>
        }
    </div>
}

@code {

    private bool _isLoading = true;
    private DateTime _loadStartTime;

    public bool IsApproved { get; set; } = false;
    private List<ReconciledBankEntryModel> UnReconciledEntries = new List<ReconciledBankEntryModel>();
    private List<ReconciledBankEntryModel> CompleteUnReconciledEntries = new List<ReconciledBankEntryModel>();
    private List<ReconciledBankEntryModel> ReconciledEntries = new List<ReconciledBankEntryModel>();
    private List<ReconciledBankEntryModel> CompleteReconciledEntries = new List<ReconciledBankEntryModel>();
    private List<ReconciledBankSummaryModel> UnReconciledEntriesSummary = new List<ReconciledBankSummaryModel>();
    private ReconciledBankEntryModel opening = new();
    private List<OwnBankModel> BankList = new List<OwnBankModel>();
    public OwnBankModel SelectedBank { get; set; } = new OwnBankModel();
    public List<int?> RequestIds { get; set; } = new();
    public int? branchID { get; set; }
    public string userID { get; set; }
    public string UnReconciledEntriesSummaryLabel { get; set; } = "";
    private bool IsViewReconciledEntry { get; set; } = false;
    DateRange dateRange;

    // Lifecycle method called when the component is initialized
    protected override async Task OnInitializedAsync()
    {
        _loadStartTime = DateTime.Now;
        var authprov = await auth.GetAuthenticationStateAsync();
        branchID = int.Parse(authprov.User.Claims.First(x => x.Type == "BranchID").Value);
        var user = authprov.User;
        userID = user.Identity.Name;
        BankList = IbankOwnservice.Select(branchID).ToList();
        await EnsureMinimumLoadTime();
        _isLoading = false;
    }

    private async Task EnsureMinimumLoadTime()
    {
        var elapsed = (DateTime.Now - _loadStartTime).TotalMilliseconds;
        if (elapsed < 100)
        {
            await Task.Delay(100 - (int)elapsed);
        }
    }

    // Method to set the view mode for reconciled entries
    private void SetIsViewReconciledEntry(bool val)
    {
        IsViewReconciledEntry = val;
        if (dateRange is null)
        {
            return;
        }
            dateRange = new DateRange(DateTime.Today, DateTime.Today);
        FetchRecounsileSummary(branchID, SelectedBank.BankCode, dateRange.Start, dateRange.End);       
    }

    // Method to search for banks based on a search string
    private async Task<IEnumerable<OwnBankModel>> SearchBanks(string searchString, CancellationToken token)
    {
        if (string.IsNullOrEmpty(searchString))
            return BankList;

        return await Task.FromResult(BankList.Where(x => x.BankAccountInfo.BankTitle.Contains(searchString, StringComparison.InvariantCultureIgnoreCase) || x.BankCode.Contains(searchString, StringComparison.InvariantCultureIgnoreCase)));
    }

    // Method to fetch details based on the current view mode
    private void FetchDetails()
    {
        if (IsViewReconciledEntry)
        {
            if (dateRange == null)
            {
                snackbar.Add("Please select date.", Severity.Error);
                return;
            }
            getSelectedBankRecoincilEntries();
        }
        else
        {
            getSelectedBankUnRecoincilEntries();
        }
    }

    // Method to fetch the reconciliation summary
    private void FetchRecounsileSummary(int? BranchID, string BankCode, DateTime? StartDate, DateTime? EndDate)
    {
        var UnReconciledSummary = IunreconciledBankEntryService.GetReconcilBankSummary(BranchID, BankCode, StartDate, EndDate);
        if (UnReconciledEntriesSummary != null)
        {
            UnReconciledEntriesSummary.Clear();
        }
        if (UnReconciledEntriesSummary == null)
        {
            UnReconciledEntriesSummary = new();
        }
        if (UnReconciledSummary != null && UnReconciledSummary.Any(s => (s.OpeningAmount != null) || (s.TransactionAmount != null) || (s.ClossingAmount != null)))
        {
            UnReconciledEntriesSummaryLabel = "(" + (StartDate?.ToString("dd/MM/yyyy") ?? "") + " - " + (EndDate?.ToString("dd/MM/yyyy") ?? "") + ")";
            UnReconciledEntriesSummary = UnReconciledSummary;
        }
    }

    // Method to save reconciled entries
    private void SaveRecounsileEntry()
    {
        if (!UnReconciledEntries.Any(x => x.ReconciledDate is not null))
        {
            snackbar.Add("No Entries Reconciled!.", Severity.Error);
            return;
        }
        else
        if (UnReconciledEntries.Any(x => x.ReconciledDate > DateTime.Now))
        {
            snackbar.Add("Future date can not be selected.", Severity.Error);
            return;
        }

        List<ReconcileUpdateModel> recList = new();
        recList = UnReconciledEntries.Where(x => x.ReconciledDate is not null).Select(y => new ReconcileUpdateModel() { ID = y.ID, BankID = y.BankID, AccountEntryID = y.AccountEntryID,ReconciledDate = y.ReconciledDate }).ToList();

        // Update the reconciled entries in the service
        var result = IunreconciledBankEntryService.UpdateUnReconciledBankEntry(recList, userID);
        getSelectedBankUnRecoincilEntries();
        SetIsViewReconciledEntry(false);        
    }

    // Method to get unreconciled entries for the selected bank
    public void getSelectedBankUnRecoincilEntries()
    {
        if (UnReconciledEntries != null)
        {
            UnReconciledEntries.Clear();
        }
        if (CompleteUnReconciledEntries != null)
        {
            CompleteUnReconciledEntries.Clear();
        }
        // Fetch all unreconciled bank entries for the selected bank
        CompleteUnReconciledEntries = IunreconciledBankEntryService.SelectAllUnReconciledBank(branchID, SelectedBank.ID, dateRange?.Start ?? null, dateRange?.End ?? null).ToList();
        UnReconciledEntries = CompleteUnReconciledEntries.Where(s => !(s.IsExisting ?? false)).ToList();
        if (CompleteUnReconciledEntries.Any(s => (s.IsExisting ?? false)))
        {
            opening = CompleteUnReconciledEntries.FirstOrDefault(s => (s.IsExisting ?? false));
        }
        SetIsViewReconciledEntry(false);
    }

    // Method to get reconciled entries for the selected bank
    public void getSelectedBankRecoincilEntries()
    {
        if (ReconciledEntries != null)
        {
            ReconciledEntries.Clear();
        }
        if (CompleteReconciledEntries != null)
        {
            CompleteReconciledEntries.Clear();
        }
        // Fetch all reconciled bank entries for the selected bank within the specified date range
        CompleteReconciledEntries = IunreconciledBankEntryService.SelectAllReconciledBank(branchID, SelectedBank.ID, dateRange?.Start ?? null, dateRange?.End ?? null).ToList();
        ReconciledEntries = CompleteReconciledEntries.Where(s => !(s.IsExisting ?? false)).ToList();
        if (CompleteReconciledEntries.Any(s => (s.IsExisting ?? false)))
        {
            opening = CompleteReconciledEntries.FirstOrDefault(s => (s.IsExisting ?? false));
        }
        SetIsViewReconciledEntry(true);
    }
}
