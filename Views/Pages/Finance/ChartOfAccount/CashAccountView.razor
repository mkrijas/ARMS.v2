@page "/CashAccount"
@inject ICashAccountService Iservice
@inject MudBlazor.ISnackbar snackbar

@inject AuthenticationStateProvider auth
@attribute [Authorize]
@inject IDialogService DialogService


<MudGrid Spacing="4">
   <MudItem xs="12">  
        <MudTable Items="@collection"   Dense="true" Hover="true"  Striped="true" Elevation="10"  @bind-place="model">
             <ToolBarContent>
                <MudText Typo="Typo.h6">Manage Cash Account </MudText>
                <MudTooltip Text="New Cash Account">
                <MudIconButton  Icon="@Icons.Material.Filled.Add" Title="Add" @onclick="@(()=> OpenDialog(model))"  Color="Color.Dark" Size="Size.Small"></MudIconButton>
                </MudTooltip>
               
             
                <MudSpacer></MudSpacer>
             
            </ToolBarContent>
            <HeaderContent>
                <MudTh><MudTableSortLabel SortBy="new Func<CashAccountModel, object>(x=> x.Title)" InitialDirection="SortDirection.Ascending">Tittle</MudTableSortLabel></MudTh>
                 <MudTh><MudTableSortLabel SortBy="new Func<CashAccountModel, object>(x=> x.CashCode)" InitialDirection="SortDirection.Ascending">Cash code</MudTableSortLabel></MudTh>
               <MudTh><MudTableSortLabel SortBy="new Func<CashAccountModel, object>(x=> x.CoaID.CoaID)" InitialDirection="SortDirection.Ascending">CoaID</MudTableSortLabel></MudTh>
              <MudTh><MudTableSortLabel SortBy="new Func<CashAccountModel, object>(x=> x.MinBalance)" InitialDirection="SortDirection.Ascending">Minimum Balance</MudTableSortLabel></MudTh>
              <MudTh><MudTableSortLabel SortBy="new Func<CashAccountModel, object>(x=> x.MaxBalance)" InitialDirection="SortDirection.Ascending">Maximum Balance</MudTableSortLabel></MudTh>
             
              <MudTh>Actions</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Title">@context.Title</MudTd>                  
                <MudTd DataLabel="BeneficiaryName">@context.CashCode</MudTd>
                 <MudTd DataLabel="AccountNumber">@context.CoaID.CoaID</MudTd>
                  <MudTd DataLabel="Place">@context.MinBalance</MudTd>
                  <MudTd DataLabel="BankCode">@context.MaxBalance</MudTd>
               <MudTd DataLabel="">
                    <MudTooltip Text="Edit">
                   <MudFab @onclick="@(()=> OpenDialog(context))" Color="Color.Primary" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" IconSize="Size.Small" />
                    </MudTooltip> 
                     @*
                    @if(@context.ApprovedInfo.RecordStatus!=1)
                    {
                     <MudTooltip Text="Approve">
                   <MudFab @onclick="@(()=> Approve(context))" Color="Color.Success" Icon="@Icons.Material.Filled.Check" Size="Size.Small" IconSize="Size.Small" />
                    </MudTooltip>
                    }*@
               </MudTd>
            </RowTemplate>
          
            <PagerContent>
                <MudTablePager PageSizeOptions="new int[] { 5, 10, 20, 50, 100 }" />
               @*  <MudButton OnClick="selected" Variant="Variant.Filled" Color="Color.Success" ButtonType="ButtonType.Submit">Submit</MudButton>*@
           
            </PagerContent>
        </MudTable>
    </MudItem>
    </MudGrid>


@code {
    private CashAccountModel model = new CashAccountModel();
    
    private List<CashAccountModel> collection = new List<CashAccountModel>();
    DialogOptions mediumWidth = new DialogOptions() { MaxWidth = MaxWidth.Medium, FullWidth = true };
     protected override async Task OnInitializedAsync()
    {
        model = new();
        GetAll();
    }
    private  void GetAll()
    {

        collection = new List<CashAccountModel>();
        foreach (var item in Iservice.Select())
        {
            collection.Add(item);
        }


    }
     public async Task OpenDialog(CashAccountModel Cam)
    {
        //var authprov = await auth.GetAuthenticationStateAsync();
        //var user = authprov.User;
        //var brancIDString = authprov.User.Claims.First(x => x.Type == "BranchID").Value;

        //model.UserInfo.UserID = user.Identity.Name;
        //model.BranchID = int.Parse(brancIDString);
        DialogParameters parms = new DialogParameters();
        parms.Add("model",Cam);
        var dialog =  DialogService.Show<CashaccDialog>(Cam.CashAccountID == null?"ADD":"EDIT",parms);
        var result = await dialog.Result;

        if(!result.Cancelled)
        {   
            CashAccountModel UpatedModel = (CashAccountModel)result.Data;   
            Iservice.Update(UpatedModel);
            GetAll();


        }
        GetAll();
    }
}
