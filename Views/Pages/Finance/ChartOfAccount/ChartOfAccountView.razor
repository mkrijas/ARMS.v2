@page "/ChartOfAccount"
@inject IChartOfAccountService Iservice
@inject MudBlazor.ISnackbar snackbar
@attribute [Authorize]
@inject AuthenticationStateProvider auth
@inject IDialogService DialogService
@using System
@inject IJSRuntime jsRuntime
@using System.Threading;
@inject IRoleService<RoleModel> Irole

<style>
    .subledger {
        color: blue;
    }

    .fixed {
        position: absolute;
    }

</style>
<MudGrid>
    <MudItem xs="12" md="6">
        <MudPaper Class="p-5">
            <MudText Typo="Typo.h5" Style="font-weight:450" Class="mb-5">
                CHART OF ACCOUNTS
                <MudIconButton Style="margin-bottom:4px;" Icon="@Icons.Material.Filled.Add" Disabled="@_busy" Title="Add Ledger" Color="Color.Dark" Size="Size.Small" OnClick="@addledgerbyicon"></MudIconButton>
            </MudText>
            <MudDivider DividerType="DividerType.Middle"></MudDivider>
            <MudTreeView T="CoaTreeItem" Color="Color.Primary" Items="TreeItems" Hover="true" 
                         SelectedValueChanged="@((CoaTreeItem i) => OnSelected(i))">
                <ItemTemplate>
                    <MudTreeViewItem @bind-Expanded="@context.Expanded" Items="@context.Children" Value="@context.Value">
                        <BodyContent Context="item">
                            <ContextMenuTrigger MenuId="@(context.Value.SummaryAccount ? "myMenu" : "myeditMenu")" Data="@context">
                                <MudStack Row="true" AlignItems="AlignItems.Center" @onclick="@(()=> getcoordinates(context.Value.ID))">
                                    <MudIcon Icon="@context.Icon" Color="Color.Default" Size="Size.Small" Class="mr-2"></MudIcon>
                                    <MudText Typo="@(context.Value.SummaryAccount ? Typo.body1 : Typo.body2)" 
                                             Style="@(context.Value.SummaryAccount ? "font-weight: 500;" : "")"
                                             Class="@(context.Value.SummaryAccount?"":"subledger")">
                                        @context.Text
                                    </MudText>
                                </MudStack>
                            </ContextMenuTrigger>
                        </BodyContent>
                    </MudTreeViewItem>
                </ItemTemplate>
            </MudTreeView>

        </MudPaper>
    </MudItem>
</MudGrid>


<div id="targetBox" Class="float-left fixed" style="left: 0; top: 0;">
    @if (AllocatedBranches.Count > 0)
    {
        <h5 style="margin-left:4px;">ALLOCATED BRANCHES</h5>
        <MudPaper Width="350px" MaxHeight="494px" Class="overflow-y-auto" Elevation="1">
            <div>
                <div style="height:30px">
                    <MudCheckBox T="bool" Style="height:60px" Value="allSelected" ValueChanged="((bool a)=>SelectAll(a))"><b>SELECT ALL</b></MudCheckBox>
                </div>
                <hr style="margin-bottom:0px;">
                @foreach (var item in AllocatedBranches)
                {
                    <div style="height:40px; margin-bottom:0px;">
                        <MudCheckBox T="bool" Style="height:60px;" Value="@item.IsSelected" Label="@item.BranchName" ValueChanged="((bool value)=>BranchCheckedChanged(value,item))"></MudCheckBox>
                    </div>
                }
            </div>
        </MudPaper>
    }
</div>
<ContextMenu Id="myMenu" OnAppearing="OnAppearing">
    <Item OnClick="@ContextMenuOnClick" Id="group">Add Group</Item>
    <Item OnClick="@ContextMenuOnClick" Id="account">Add Ledger</Item>
</ContextMenu>
<ContextMenu Id="myeditMenu">
    <Item OnClick="@ContextEditMenuOnClick">Edit Ledger</Item>
</ContextMenu>

@code {

    private List<TreeItemData<CoaTreeItem>> TreeItems { get; set; } = new List<TreeItemData<CoaTreeItem>>();
    TreeItemData<CoaTreeItem> ContextmenuSource = new();
    TreeItemData<CoaTreeItem> SelectedValue;
    protected List<CoaBranchAvailabilityModel> AllocatedBranches = new();
    protected bool visible = true;
    private bool _busy;

    public bool HasPermissionChartOfAccountServiceEdit { get; set; } = false;
    public bool HasPermissionChartOfAccountServiceUpdateSelect { get; set; } = false;
    public int ChartOfAccountDocTypeID = 89;

    List<ChartOfAccountModel> collection;

    // Class representing tree item data
    public class CoaTreeItem
    {
        public string Title { get; set; }
        public string Icon { get; set; }
        public bool SummaryAccount { get; set; } = false;
        public int? ID { get; set; }
        public string AccountCode { get; set; }
    }

    // Class to hold element coordinates
    public class ElementCoordinates
    {
        public double X { get; set; }
        public double Y { get; set; }
    }

    // Method to get coordinates of an element
    public async Task getcoordinates(int? itemID)
    {
        object[] obj = { itemID, "targetBox" };
        ElementCoordinates coordinates = await jsRuntime.InvokeAsync<ElementCoordinates>("getElementCoordinates", obj);
    }

    // Lifecycle method called when the component is initialized
    protected override async Task OnInitializedAsync()
    {
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionChartOfAccountServiceEdit = await Irole.HasClaim(ChartOfAccountDocTypeID.ToString(), "Edit", ctc.Token);
        HasPermissionChartOfAccountServiceUpdateSelect = await Irole.HasClaim(ChartOfAccountDocTypeID.ToString(), "UpdateSelect", ctc.Token);

        // Load all ledgers and populate the tree items
        collection = Iservice.AllLedgers().ToList();
        var baseGroups = collection.Where(x=> x.ParentID == 0).OrderBy(x => x.SummaryAccount).ThenBy(y => y.AccountName).ToList();

        foreach (var item in baseGroups)
        {
            var coaItem = new CoaTreeItem
            {
                    ID = item.CoaID,
                    Title = item.AccountName,
                    SummaryAccount = item.SummaryAccount,
                    Icon = item.SummaryAccount ? null : Icons.Material.Filled.Description
            };
            
            var hasChildren = collection.Any(x => x.ParentID == item.CoaID);
            var treeItem = new TreeItemData<CoaTreeItem>
            {
                Value = coaItem,
                Text = coaItem.Title,
                Icon = coaItem.Icon,
                Expanded = false,
                Expandable = hasChildren,
                Children = hasChildren ? LoadServerData(item.CoaID) : null
            };
            
            TreeItems.Add(treeItem);
        }
    }

    // Method to load server data for tree items (loads one level only)
    public List<TreeItemData<CoaTreeItem>> LoadServerData(int? CoaID)
    {
        var TreeItems = new List<TreeItemData<CoaTreeItem>>();
        var children = collection.Where(z => z.ParentID == CoaID).OrderBy(x => x.SummaryAccount).ThenBy(y => y.AccountName);
        foreach (var item in children)
        {
            var coaItem = new CoaTreeItem
                {
                    ID = item.CoaID,
                    AccountCode = item.AccountCode,
                    Title = item.AccountName + (item.SummaryAccount ? "" : (" (" + item.AccountCode + ")")),
                    SummaryAccount = item.SummaryAccount,
                    Icon = item.SummaryAccount ? null : Icons.Material.Filled.Description
                };

            var hasChildren = collection.Any(x => x.ParentID == item.CoaID);
            var treeItem = new TreeItemData<CoaTreeItem>
            {
                Value = coaItem,
                Text = coaItem.Title,
                Icon = coaItem.Icon,
                Expanded = false,
                Expandable = hasChildren,
                // Load immediate children only (one level) - they will load their children when expanded
                Children = hasChildren ? LoadServerData(item.CoaID) : null
            };

            TreeItems.Add(treeItem);
        }
        return TreeItems;
    }

    //Function to create group / ledger

    // Method to handle context menu clicks
    // Method to handle context menu clicks
    protected async Task ContextMenuOnClick(ItemClickEventArgs e)
    {
        ContextmenuSource = (TreeItemData<CoaTreeItem>)e.Data; // e.Data comes from ContextMenuTrigger which is wrapper
        var authstate = await auth.GetAuthenticationStateAsync();
        var parameters = new DialogParameters
            {
                ["model"] = new ChartOfAccountModel
                {
                    ParentID = ContextmenuSource.Value.ID,
                    SummaryAccount = e.MenuItem.Id == "group",
                    UserInfo = { UserID = authstate.User.Identity.Name }
                },
            };
        IDialogReference dialog = null;

        // Show the appropriate dialog based on the menu item clicked
        switch (e.MenuItem.Id)
        {
            case "group":
                dialog = DialogService.Show<AddLedgerDialog>("Add Group under - " + ContextmenuSource.Value.Title, parameters);
                break;

            case "account":
                dialog = DialogService.Show<AddSubledgerDialog>("Add Ledger under - " + ContextmenuSource.Value.Title, parameters);
                break;
        }

        if (HasPermissionChartOfAccountServiceEdit)
        {
            var result = await dialog.Result;
            ChartOfAccountModel UpdatedModel = (ChartOfAccountModel)result.Data;
            if (!result.Canceled)
            {
                try
                {
                    var newledger = Iservice.Update(UpdatedModel); // Update the ledger
                    // Finding the parent node in TreeItems
                    var parentNode = GetTreeItemData(TreeItems, UpdatedModel.ParentID);
                    if (parentNode != null)
                    {
                          if (parentNode.Children == null) parentNode.Children = new List<TreeItemData<CoaTreeItem>>();
                          
                          var newCoaItem = new CoaTreeItem
                            {
                                ID = newledger.CoaID,
                                Title = newledger.AccountName + (newledger.SummaryAccount ? "" : (" (" + newledger.AccountCode + ")")),
                                SummaryAccount = newledger.SummaryAccount,
                                Icon = newledger.SummaryAccount ? null : Icons.Material.Filled.Description,
                            };
                            
                          var newNode = new TreeItemData<CoaTreeItem> 
                          { 
                              Value = newCoaItem,
                              Text = newCoaItem.Title,
                              Icon = newCoaItem.Icon,
                              Expanded = true
                          };
                          
                          parentNode.Children.Add(newNode);
                          snackbar.Add(newledger.AccountName + " added successfully", Severity.Success);
                    }
                }
                catch (Exception a)
                {
                    snackbar.Add(a.Message, Severity.Error);
                }
            }
        }
        else
        {
            bool? result = await DialogService.ShowMessageBox(
                "Permission denied!",
                "You don't have any permission to Edit ChartOfAccount.");
        }
    }

    // Method to handle context menu edit clicks
    protected async Task ContextEditMenuOnClick(ItemClickEventArgs e)
    {
        var item = (TreeItemData<CoaTreeItem>)e.Data;
        if (!item.Value.SummaryAccount)
        {
            ChartOfAccountModel model = Iservice.SelectByID(item.Value.ID); // Fetch the model for editing
            ContextmenuSource = item;
            var authstate = await auth.GetAuthenticationStateAsync();
            var parameters = new DialogParameters
                {
                    ["model"] = model.Clone(),
                };
            var editledge = DialogService.Show<AddSubledgerDialog>("Edit Ledger - " + item.Value.Title, parameters);

            if (HasPermissionChartOfAccountServiceEdit)
            {
                var result = await editledge.Result;
                ChartOfAccountModel UpdatedModel = (ChartOfAccountModel)result.Data;
                if (!result.Canceled)
                {
                    var newresult = Iservice.Update(UpdatedModel); // Update the ledger
                    item.Value.Title = newresult.AccountName + (newresult.SummaryAccount ? "" : (" (" + newresult.AccountCode + ")"));
                    item.Value.SummaryAccount = newresult.SummaryAccount;
                    item.Value.Icon = Icons.Material.Filled.Description;
                    
                    item.Text = item.Value.Title;
                    item.Icon = item.Value.Icon;
                    
                    snackbar.Add(newresult.AccountName + " Edited successfully", Severity.Success);
                }
            }
            else
            {
                bool? result = await DialogService.ShowMessageBox(
                    "Permission denied!",
                    "You don't have any permission to Edit ChartOfAccount.");
            }
        }
    }

    // Method to add a ledger by icon clickc
    protected async Task addledgerbyicon()
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        _busy = true;

        var authstate = await auth.GetAuthenticationStateAsync();
        var parameters = new DialogParameters
            {
                ["model"] = new ChartOfAccountModel
                {
                    ParentID = null,
                    SummaryAccount = false,
                    UserInfo = { UserID = authstate.User.Identity.Name }
                },
            };
        IDialogReference dialog = DialogService.Show<AddSubledgerDialog>("Add Ledger", parameters);

        if (HasPermissionChartOfAccountServiceEdit)
        {
            var result = await dialog.Result;
            ChartOfAccountModel UpdatedModel = (ChartOfAccountModel)result.Data;
            if (!result.Canceled)
            {
                try
                {
                    var newledger = Iservice.Update(UpdatedModel); // Update the ledger
                   
                    // Finding the parent node in TreeItems
                     var parentNode = GetTreeItemData(TreeItems, UpdatedModel.ParentID);
                     
                     var newCoaItem = new CoaTreeItem
                            {
                                ID = newledger.CoaID,
                                Title = newledger.AccountName + (newledger.SummaryAccount ? "" : (" (" + newledger.AccountCode + ")")),
                                SummaryAccount = newledger.SummaryAccount,
                                Icon = newledger.SummaryAccount ? null : Icons.Material.Filled.Description,
                            };
                            
                      var newNode = new TreeItemData<CoaTreeItem> 
                          { 
                              Value = newCoaItem,
                              Text = newCoaItem.Title,
                              Icon = newCoaItem.Icon,
                              Expanded = true
                          };
                            
                     if (parentNode != null)
                     {
                         if(parentNode.Children == null) parentNode.Children = new List<TreeItemData<CoaTreeItem>>();
                         parentNode.Children.Add(newNode);
                     }
                     else if (UpdatedModel.ParentID == 0 || UpdatedModel.ParentID == null)
                     {
                         TreeItems.Add(newNode);
                     }

                     snackbar.Add(newledger.AccountName + " added successfully", Severity.Success);

                }
                catch (Exception a)
                {
                    snackbar.Add(a.Message, Severity.Error);
                }
            }
        }
        else
        {
            bool? result = await DialogService.ShowMessageBox(
                "Permission denied!",
                "You don't have any permission to Edit ChartOfAccount.");
        }
        await Task.Delay(200);
        _busy = false;
    }

    // Method to check if all branches are selected
    public bool allSelected { get { return AllocatedBranches.All(ab => ab.IsSelected); } }
    public int? AllSelectCoaId;

    public void OnSelected(CoaTreeItem item)
