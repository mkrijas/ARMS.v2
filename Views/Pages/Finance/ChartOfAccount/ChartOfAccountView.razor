    // Method to check if all branches are selected
    public bool allSelected { get { return AllocatedBranches.All(ab => ab.IsSelected); } }
    public int? AllSelectCoaId;

    public void OnSelected(TreeItemData item)
    {
        //if (item != null && !item.SummaryAccount)
        //{
        //    AllocatedBranches = Iservice.GetAllocatedBranches(item.ID).ToList();
        //    AllSelectCoaId = AllocatedBranches.FirstOrDefault()?.CoaID;
        //    //allSelected = AllocatedBranches.All(ab => ab.IsSelected);
        //}
        //else
        //{
        //    AllocatedBranches = new List<CoaBranchAvailabilityModel>();
