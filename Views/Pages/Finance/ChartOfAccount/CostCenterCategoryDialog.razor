@inject ICostCenterService Iservice
@inject MudBlazor.ISnackbar snackbar
@inject AuthenticationStateProvider auth
@attribute [Authorize]
@inject IDialogService DialogService

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.Build" Class="mr-3 mb-n1" />
            Category
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudContainer Style="min-height:100px;max-height: 800px;">
            <EditForm id="formtdsRate" Model="@model" OnValidSubmit="OnValidSubmit">
                <ObjectGraphDataAnnotationsValidator />
                <ValidationSummary />
                <MudGrid Spacing="2">
                    <MudItem xs="12" md="12">
                        <MudTextField @bind-Value="model.CategoryName" Label="Category Name" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.CategoryName)"></MudTextField>
                    </MudItem>
                </MudGrid>
            </EditForm>
        </MudContainer>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Disabled="@_busy" form="formtdsRate" Variant="Variant.Filled" Color="Color.Success" ButtonType="ButtonType.Submit">Submit</MudButton>
    </DialogActions>
</MudDialog>

@code {

    [Parameter]
    public CategoryModel model { get; set; }
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; }
    private bool _busy;

    protected override async Task OnInitializedAsync()
    {

    }

    // Method called when the form is submitted successfully
    private async void OnValidSubmit(EditContext context)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is being submitted!", Severity.Warning);
            return;
        }
        _busy = true;

        MudDialog.Close(model);

        await Task.Delay(200);
        _busy = false;
    }

    // Method to cancel the dialog
    private void Cancel()
    {
        MudDialog.Cancel();
    }
}
