@inject ICostCenterService Iservice
@inject MudBlazor.ISnackbar snackbar
@inject AuthenticationStateProvider auth
@attribute [Authorize]
@inject IDialogService DialogService



<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.Build" Class="mr-3 mb-n1" />
            Category
        </MudText>
    </TitleContent>
    <DialogContent>

        <MudContainer Style="min-height:100px;max-height: 800px;">
            <EditForm id="formtdsRate" Model="@model" OnValidSubmit="OnValidSubmit">
                <ObjectGraphDataAnnotationsValidator />
                <ValidationSummary />
                <MudGrid Spacing="2">
                     
                     <MudItem xs="12" md="12">
                         
                        <MudTextField  @bind-Value="model.CategoryName" Label="Category Name" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.CategoryName)"></MudTextField>
                         
                    </MudItem>
                    
                   
                   
                   
                </MudGrid>
            </EditForm>
        </MudContainer>


   </DialogContent>
    <DialogActions>
     <MudButton OnClick="Cancel">Cancel</MudButton>
      <MudButton form="formtdsRate" Variant="Variant.Filled" Color="Color.Success" ButtonType="ButtonType.Submit">Submit</MudButton>
       

    </DialogActions>
</MudDialog>




@code {
    [Parameter]
    public CategoryModel model { get; set; }
  
    [CascadingParameter] MudDialogInstance MudDialog { get; set; }


    protected override async Task OnInitializedAsync()
    {
       
    }

   
     private void OnValidSubmit(EditContext context)
    {  
       
         MudDialog.Close(model);
    }
    private void Cancel()
    {
        MudDialog.Cancel();
    }
}
