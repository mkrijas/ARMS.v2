@inject ICostCenterService Iservice
@inject MudBlazor.ISnackbar snackbar
@inject AuthenticationStateProvider auth
@attribute [Authorize]
@inject IDialogService DialogService

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.Build" Class="mr-3 mb-n1" />
            Cost Center
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudContainer Style="min-height:100px;max-height: 800px;">
            <EditForm id="formtdsRate" Model="@model" OnValidSubmit="OnValidSubmit">
                <ObjectGraphDataAnnotationsValidator />
                <ValidationSummary />
                <MudGrid Spacing="2">
                    <MudItem xs="12" md="12">
                        <MudTextField @bind-Value="model.CostCenter" Label="Cost Center" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.CostCenter)"></MudTextField>
                    </MudItem>
                    <MudItem xs="12" md="12">
                        <MudSelect Label="Select Category" ReadOnly="true" @bind-Value="model.Category.CategoryID" T="int?" Variant="Variant.Outlined" Margin="Margin.Dense" OffsetY="true" Direction="Direction.Top" AdornmentColor="Color.Secondary">
                            @foreach (var ditem in category)
                            {
                                <MudSelectItem Value="@ditem.CategoryID">@ditem.CategoryName</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                </MudGrid>
            </EditForm>
        </MudContainer>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton form="formtdsRate" Variant="Variant.Filled" Color="Color.Success" ButtonType="ButtonType.Submit">Submit</MudButton>
     <MudButton OnClick="Cancel">Cancel</MudButton>
      <MudButton Disabled="@_busy" form="formtdsRate" Variant="Variant.Filled" Color="Color.Success" ButtonType="ButtonType.Submit">Submit</MudButton>
       

    </DialogActions>
</MudDialog>

@code {

    [Parameter]
    public CostCenterModel model { get; set; }
    private List<CategoryModel> category = new();
    [CascadingParameter] MudDialogInstance MudDialog { get; set; }


    private bool _busy;

    protected override async Task OnInitializedAsync()
    {
        category = Iservice.SelectCategory().ToList();
    }

    private void OnValidSubmit(EditContext context)
    {
        MudDialog.Close(model);
       
    }

    private async void OnValidSubmit(EditContext context)
    {  
        if (_busy)
        {
            snackbar.Add("Please wait while form is being submitted!", Severity.Warning);
            return;
        }
        _busy = true;

        MudDialog.Close(model);

        await Task.Delay(2000);
        _busy = false;
    }

    private void Cancel()
    {
        MudDialog.Cancel();
    }
}