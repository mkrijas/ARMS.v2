@page "/CostCenter"
@inject ICostCenterService Iservice
@inject MudBlazor.ISnackbar snackbar
@inject AuthenticationStateProvider auth
@attribute [Authorize]
@using System.Threading;
@inject IRoleService<RoleModel> Irole
@inject IDialogService DialogService

@if (_isLoading)
{
    <div @key="@("loader")" style="display: flex; justify-content: center; align-items: center; min-height: 400px;">
        <LoaderComponent IsFullScreen="true" 
                        ShowLogo="false" 
                        Size="medium" 
                        LoadingText="Loading Cost Centers" 
                        SubText="Please wait..." />
    </div>
}
else
{
    <div class="fade-in">
        <div class="admin-header-tiered mb-6">
            <div class="d-flex align-center justify-space-between">
                <div>
                    <MudText Typo="Typo.h4" Class="admin-title">Cost Hierarchy & Allocation</MudText>
                    <MudText Typo="Typo.body2" Class="admin-subtitle">Maintain organizational cost centers across functional categories. track budgetary distribution and define analytic dimensions for granular expense reporting.</MudText>
                </div>
            </div>
        </div>

        <div class="d-flex gap-6 align-start">
            <!-- Sidebar for Categories -->
            <div class="admin-glass-card pa-0 overflow-hidden" style="width: 320px; flex-shrink: 0; position: sticky; top: 24px;">
                <div class="pa-4 b-bottom d-flex align-center justify-space-between bg-glass-brighter">
                    <MudText Typo="Typo.subtitle1" Class="fw-700 opa-80">CATEGORIES</MudText>
                    <MudIconButton Icon="@Icons.Material.Filled.Add" Color="Color.Primary" Size="Size.Small" OnClick="@(()=> OpenDialogCategory(new CategoryModel()))" Disabled="@_busy" Class="bg-glass rounded-pill" />
                </div>
                
                <MudList T="CategoryModel" Clickable="true" SelectedItem="SelectedItem" SelectedItemChanged="SelectedItemChanged" Class="pa-2">
                    @if (listOfItems?.Any() == true)
                    {
                        @foreach (var item in listOfItems)
                        {
                            <ContextMenuTrigger MenuId="myMenu" Data="@item">
                                <MudListItem T="CategoryModel" Value="item" Class="rounded-lg mb-1 admin-list-item">
                                    <div class="d-flex align-center gap-3">
                                        <div class="admin-icon-square-vibrant small">
                                            <MudIcon Icon="@Icons.Material.Filled.FolderOpen" Size="Size.Small" />
                                        </div>
                                        <MudText Typo="Typo.body2" Class="fw-600">@item.CategoryName</MudText>
                                    </div>
                                </MudListItem>
                            </ContextMenuTrigger>
                        }
                    }
                </MudList>
            </div>

            <!-- Main Content Area -->
            <div style="flex-grow: 1;">
                @if (SelectedModel != null && SelectedModel.CategoryID != null)
                {
                    <div class="admin-glass-card pa-0 overflow-hidden">
                        <div class="pa-4 b-bottom d-flex align-center justify-space-between bg-glass-brighter">
                            <div>
                                <MudText Typo="Typo.h6" Class="fw-700">@SelectedModel.CategoryName</MudText>
                                <MudText Typo="Typo.caption" Class="opa-60">Cost centers assigned to this category</MudText>
                            </div>
                            <MudButton StartIcon="@Icons.Material.Filled.Add" Variant="Variant.Filled" Color="Color.Primary" OnClick="@(() => OpenDialog(new CostCenterModel { Category = new CategoryModel { CategoryID = SelectedModel.CategoryID.Value } }))" Size="Size.Small" Class="rounded-pill px-4">ADD CENTER</MudButton>
                        </div>
                        
                        <MudTable Items="@collection" Elevation="0" Class="modern-admin-table" Hover="true">
                            <HeaderContent>
                                <MudTh><span class="admin-header-text">COST CENTER NAME</span></MudTh>
                                <MudTh Style="text-align: right;"><span class="admin-header-text">ACTIONS</span></MudTh>
                            </HeaderContent>
                            <RowTemplate>
                                <MudTd DataLabel="CostCenter"><span class="fw-700 admin-td-primary">@context.CostCenter</span></MudTd>
                                <MudTd DataLabel="Actions" Style="text-align: right;">
                                    <div class="d-flex justify-end gap-1">
                                        <MudTooltip Text="Edit Center">
                                            <MudIconButton OnClick="@(()=> OpenDialog(context))" Color="Color.Primary" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Variant="Variant.Text" />
                                        </MudTooltip>
                                        <MudTooltip Text="Delete Center">
                                            <MudIconButton OnClick="@(()=> Delete(context))" Color="Color.Error" Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Variant="Variant.Text" />
                                        </MudTooltip>
                                    </div>
                                </MudTd>
                            </RowTemplate>
                            <PagerContent>
                                <div class="pa-4">
                                    <MudTablePager PageSizeOptions="new int[] { 10, 20, 50, 100 }" />
                                </div>
                            </PagerContent>
                        </MudTable>
                    </div>
                }
                else
                {
                    <div class="admin-glass-card d-flex flex-column align-center justify-center py-16">
                        <div class="admin-icon-square-vibrant mb-4" style="width: 80px; height: 80px;">
                            <MudIcon Icon="@Icons.Material.Filled.Category" Style="font-size: 3rem;" />
                        </div>
                        <MudText Typo="Typo.h5" Class="fw-700 opa-80">Select a Category</MudText>
                        <MudText Typo="Typo.body2" Class="opa-50">Choose a cost category from the sidebar to manage individual centers.</MudText>
                    </div>
                }
            </div>
        </div>
    </div>

    <ContextMenu Id="myMenu" OnAppearing="OnAppearing">
        <Item OnClick="@ContextMenuOnClickadd" Id="addItem">Add Cost Center</Item>
        <Item OnClick="@ContextMenuOnClickedit" Id="editGroup">Edit Category</Item>
    </ContextMenu>
}

@code {

    private bool _isLoading = true;
    private DateTime _loadStartTime;

    CategoryModel model = new CategoryModel();
    private MudListItem<CategoryModel> SelectedItem;
    private List<CategoryModel> listOfItems = new();
    CategoryModel SelectedModel = new();
    private List<CostCenterModel> collection = new List<CostCenterModel>();
    private bool _busy;

    public bool HasPermissionCostCenterServiceEdit { get; set; } = false;
    public bool HasPermissionCostCenterServiceDelete { get; set; } = false;
    public int CostCenterDocTypeID = 88;

    // Lifecycle method called when the component is initialized
    protected override async Task OnInitializedAsync()
    {
        _loadStartTime = DateTime.Now;
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionCostCenterServiceEdit = await Irole.HasClaim(CostCenterDocTypeID.ToString(), "Edit", ctc.Token);
        HasPermissionCostCenterServiceDelete = await Irole.HasClaim(CostCenterDocTypeID.ToString(), "Delete", ctc.Token);

        GetAll();
        await EnsureMinimumLoadTime();
        _isLoading = false;
    }

    private async Task EnsureMinimumLoadTime()
    {
        var elapsed = (DateTime.Now - _loadStartTime).TotalMilliseconds;
        if (elapsed < 100)
        {
            await Task.Delay(100 - (int)elapsed);
        }
    }

    // Method to handle selection changes in the list
    protected async Task SelectedItemChanged(MudListItem<CategoryModel> obj)
    {
        SelectedItem = obj;
        SelectedModel = SelectedItem.Value;
        GetInventoryItem(SelectedModel);
    }

    // Method to fetch all categories
    private void GetAll()
    {
        listOfItems = Iservice.SelectCategory().ToList(); // Load categories from the service
    }

    // Method to fetch inventory items based on the selected category
    private void GetInventoryItem(CategoryModel ig)
    {
        collection = new List<CostCenterModel>();
        foreach (var item in Iservice.SelectByCategory(ig.CategoryID))
        {
            collection.Add(item);
        }
    }

    // Method to open the dialog for adding or editing a cost center
    private async Task OpenDialog(CostCenterModel ii)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        _busy = true;

        if (HasPermissionCostCenterServiceEdit)
        {
            var authprov = await auth.GetAuthenticationStateAsync();
            var user = authprov.User;
            DialogParameters parms = new DialogParameters();
            parms.Add("model", ii.Clone());
            var dialog = await DialogService.ShowAsync<CostCenterDialog>(ii.CostCenterID == null ? "ADD" : "EDIT", parms);
            var result = await dialog.Result;
            if (!result.Canceled)
            {
                CostCenterModel UpatedModel = (CostCenterModel)result.Data;
                UpatedModel.UserInfo.UserID = user.Identity.Name;
                try
                {
                    UpatedModel = Iservice.Update(UpatedModel); // Update the cost center
                    snackbar.Add("Saved Successfully", Severity.Success);
                    CategoryModel igm = new CategoryModel();
                    igm.CategoryID = UpatedModel.Category.CategoryID;
                    GetInventoryItem(igm);

                }
                catch (Exception ex)
                {
                    snackbar.Add(ex.Message, Severity.Warning);
                }
            }
        }
        else
        {
            bool? result = await DialogService.ShowMessageBoxAsync(
                "Permission denied!",
                "You don't have any permission to Edit CostCenter.");
        }
        await Task.Delay(200);
        _busy = false;
    }

    // Method to delete a cost center
    private async Task Delete(CostCenterModel model)
    {
        if (HasPermissionCostCenterServiceDelete)
        {
            bool? result = await DialogService.ShowMessageBoxAsync(
                "Warning !",
                "Are you sure, you want to delete - " + model.CostCenter + " ?");
            if (result == true)
            {
                var authprov = await auth.GetAuthenticationStateAsync();
                var UserID = authprov.User.Identity.Name;
                Iservice.Delete(model.CostCenterID, UserID); // Delete the cost center
                snackbar.Add("Deleted Successfully", Severity.Success);
            }
            GetAll();
            await SelectedItemChanged(SelectedItem);
        }
        else
        {
            bool? result = await DialogService.ShowMessageBoxAsync(
                "Permission denied!",
                    "You don't have any permission to Delete CostCenter.");
        }
    }

    // Method to open the dialog for adding or editing a category
    private async Task OpenDialogCategory(CategoryModel ig)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        _busy = true;

        if (HasPermissionCostCenterServiceEdit)
        {
            var authprov = await auth.GetAuthenticationStateAsync();
            var user = authprov.User;
            DialogParameters parms = new DialogParameters();
            parms.Add("model", ig.Clone());
            var dialog = await DialogService.ShowAsync<CostCenterCategoryDialog>(ig.CategoryID == null ? "ADD" : "EDIT", parms);
            var result = await dialog.Result;
            if (!result.Canceled)
            {
                CategoryModel UpdatedModel = (CategoryModel)result.Data;
                UpdatedModel.UserInfo.UserID = user.Identity.Name;
                try
                {
                    Iservice.UpdateCategory(UpdatedModel); // Update the category
                    snackbar.Add("Saved Successfully", Severity.Success);
                    GetAll();
                }
                catch (Exception ex)
                {
                    snackbar.Add(ex.Message, Severity.Warning);
                }
            }
        }
        else
        {
            bool? result = await DialogService.ShowMessageBoxAsync(
                "Permission denied!",
                "You don't have any permission to Edit CostCenter.");
        }
        await Task.Delay(200);
        _busy = false;
    }

    void OnAppearing(MenuAppearingEventArgs e)
    {
        //TreeItemData item = (TreeItemData)e.Data;
        // e.PreventShow = !item.HasChildren;
    }

    // Method to handle the context menu click for editing a category
    protected async Task ContextMenuOnClickedit(ItemClickEventArgs e)
    {
        CategoryModel ig = (CategoryModel)e.Data;
        await OpenDialogCategory(ig);
    }

    // Method to handle the context menu click for adding a cost center
    protected async Task ContextMenuOnClickadd(ItemClickEventArgs e)
    {
        CategoryModel ig = (CategoryModel)e.Data;
        CostCenterModel ii = new CostCenterModel();
        ii.Category.CategoryID = ig.CategoryID.Value;
        await OpenDialog(ii);
    }
}

