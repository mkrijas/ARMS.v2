@page "/CostCenter"
@inject ICostCenterService Iservice
@inject MudBlazor.ISnackbar snackbar
@inject AuthenticationStateProvider auth
@attribute [Authorize]
@inject IDialogService DialogService

<MudGrid>
    <MudItem xs="4" lg="4">
        <MudPaper Width="100%" Class="p-2">
            <MudList Clickable="true" SelectedItem="SelectedItem" SelectedItemChanged="SelectedItemChanged">
                <MudText Typo="Typo.h6">
                    Category
                    <MudIconButton Disabled="@_busy" Icon="@Icons.Material.Filled.Add" Title="Add" @onclick="@(()=> OpenDialogCategory(new CategoryModel()))" Color="Color.Dark" Size="Size.Small"></MudIconButton>
                </MudText>
                @if (listOfItems?.Any() == true)
                {
                    @foreach (var item in listOfItems)
                    {
                        <ContextMenuTrigger MenuId="myMenu" Data="@item">
                            <MudListItem Value="item">
                                <MudText Typo=Typo.subtitle1> @item.CategoryName.ToString() </MudText>
                            </MudListItem>
                        </ContextMenuTrigger>
                    }
                }
            </MudList>
        </MudPaper>
    </MudItem>
    <MudItem xs="8" lg="8">
        @if (SelectedItem != null)
        {
            <MudTable Items="@collection" Dense="true" Hover="true" Striped="true" Elevation="10">
                <ToolBarContent>
                    <MudText Typo="Typo.h6">Cost Centers</MudText>
                    <MudSpacer></MudSpacer>
                </ToolBarContent>
                <HeaderContent>
                    <MudTh><MudTableSortLabel SortBy="new Func<CostCenterModel, object>(x=> x.CostCenter)" InitialDirection="SortDirection.Ascending">Cost Center</MudTableSortLabel></MudTh>
                    <MudTh>Actions</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="CostCenter">@context.CostCenter</MudTd>
                    <MudTd DataLabel="">
                        <MudFab @onclick="@(()=> OpenDialog(context))" Color="Color.Primary" title="Edit" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" IconSize="Size.Small" />
                        <MudFab @onclick="@(()=> Delete(context))" Color="Color.Error" title="Delete" Icon="@Icons.Material.Filled.Delete" Size="Size.Small" IconSize="Size.Small" />
                    </MudTd>
                </RowTemplate>
                <PagerContent>
                    <MudTablePager PageSizeOptions="new int[] { 5, 10, 20, 50, 100 }" />
                </PagerContent>
            </MudTable>
        }
    </MudItem>
</MudGrid>
<ContextMenu Id="myMenu" OnAppearing="OnAppearing">
    <Item OnClick="@ContextMenuOnClickadd" Id="addItem">Add CostCenter</Item>
    <Item OnClick="@ContextMenuOnClickedit" Id="editGroup">Edit Category</Item>
</ContextMenu>

@code {

    CategoryModel model = new CategoryModel();
    private MudListItem SelectedItem;
    private List<CategoryModel> listOfItems = new();
    CategoryModel SelectedModel = new();
    private List<CostCenterModel> collection = new List<CostCenterModel>();
    private bool _busy;

    protected override async Task OnInitializedAsync()
    {
        GetAll();
    }

    protected async Task SelectedItemChanged(object obj)
    {
        SelectedItem = (MudListItem)obj;
        SelectedModel = (CategoryModel)SelectedItem.Value;
        GetInventoryItem(SelectedModel);
    }

    private void GetAll()
    {
        listOfItems = Iservice.SelectCategory().ToList();
    }

    private void GetInventoryItem(CategoryModel ig)
    {
        collection = new List<CostCenterModel>();
        foreach (var item in Iservice.SelectByCategory(ig.CategoryID))
        {
            collection.Add(item);
        }
    }

    private async Task OpenDialog(CostCenterModel ii)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        _busy = true;

        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;
        DialogParameters parms = new DialogParameters();
        parms.Add("model", ii.Clone());
        var dialog = DialogService.Show<CostCenterDialog>(ii.CostCenterID == null ? "ADD" : "EDIT", parms);
        var result = await dialog.Result;
        if (!result.Cancelled)
        {
            CostCenterModel UpatedModel = (CostCenterModel)result.Data;
            UpatedModel.UserInfo.UserID = user.Identity.Name;
            try
            {
                UpatedModel = Iservice.Update(UpatedModel);
                snackbar.Add("Saved Successfully", Severity.Success);
                CategoryModel igm = new CategoryModel();
                igm.CategoryID = UpatedModel.Category.CategoryID;
                GetInventoryItem(igm);

            }
            catch (Exception ex)
            {
                snackbar.Add(ex.Message, Severity.Warning);
            }
        }
        await Task.Delay(200);
        _busy = false;
    }

    private async Task Delete(CostCenterModel model)
    {
        bool? result = await DialogService.ShowMessageBox(
            "Warning !",
            "Are you sure, you want to delete - " + model.CostCenter + " ?");
        if (result == true)
        {
            var authprov = await auth.GetAuthenticationStateAsync();
            var UserID = authprov.User.Identity.Name;
            Iservice.Delete(model.CostCenterID, UserID);
            snackbar.Add("Deleted Successfully", Severity.Success);
        }
        GetAll();
        await SelectedItemChanged(SelectedItem);
    }

    private async Task OpenDialogCategory(CategoryModel ig)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        _busy = true;

        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;
        DialogParameters parms = new DialogParameters();
        parms.Add("model", ig.Clone());
        var dialog = DialogService.Show<CostCenterCategoryDialog>(ig.CategoryID == null ? "ADD" : "EDIT", parms);
        var result = await dialog.Result;
        if (!result.Cancelled)
        {
            CategoryModel UpdatedModel = (CategoryModel)result.Data;
            UpdatedModel.UserInfo.UserID = user.Identity.Name;
            try
            {
                Iservice.UpdateCategory(UpdatedModel);
                snackbar.Add("Saved Successfully", Severity.Success);
                GetAll();
            }
            catch (Exception ex)
            {
                snackbar.Add(ex.Message, Severity.Warning);
            }
        }
        await Task.Delay(200);
        _busy = false;
    }

    void OnAppearing(MenuAppearingEventArgs e)
    {
        //TreeItemData item = (TreeItemData)e.Data;
        // e.PreventShow = !item.HasChildren;
    }

    protected async Task ContextMenuOnClickedit(ItemClickEventArgs e)
    {
        CategoryModel ig = (CategoryModel)e.Data;
        await OpenDialogCategory(ig);
    }

    protected async Task ContextMenuOnClickadd(ItemClickEventArgs e)
    {
        CategoryModel ig = (CategoryModel)e.Data;
        CostCenterModel ii = new CostCenterModel();
        ii.Category.CategoryID = ig.CategoryID.Value;
        await OpenDialog(ii);
    }
}