@page "/Diamension"
@inject IDimensionService Iservice
@inject MudBlazor.ISnackbar snackbar
@inject AuthenticationStateProvider auth
@attribute [Authorize]
@using System.Threading;
@inject IRoleService<RoleModel> Irole
@inject IDialogService DialogService

@if (_isLoading)
{
    <div @key="@("loader")" style="display: flex; justify-content: center; align-items: center; min-height: 400px;">
        <LoaderComponent IsFullScreen="true" 
                        ShowLogo="false" 
                        Size="medium" 
                        LoadingText="Loading Dimensions" 
                        SubText="Please wait..." />
    </div>
}
else
{
    <div class="fade-in">
        <div class="admin-header-tiered mb-6">
            <div class="d-flex align-center justify-space-between">
                <div>
                    <MudText Typo="Typo.h4" Class="admin-title">Analytic Dimensions & Groups</MudText>
                    <MudText Typo="Typo.body2" Class="admin-subtitle">Maintain multi-level analytic dimensions for cross-functional financial reporting. organize dimensions into logical categories for structured business intelligence and auditing.</MudText>
                </div>
            </div>
        </div>

        <div class="d-flex gap-6 align-start">
            <!-- Sidebar for Categories -->
            <div class="admin-glass-card pa-0 overflow-hidden" style="width: 320px; flex-shrink: 0; position: sticky; top: 24px;">
                <div class="pa-4 b-bottom d-flex align-center justify-space-between bg-glass-brighter">
                    <MudText Typo="Typo.subtitle1" Class="fw-700 opa-80 uppercase">Categories</MudText>
                    <MudIconButton Icon="@Icons.Material.Filled.AddCircle" Color="Color.Primary" Size="Size.Small" OnClick="@(()=> OpenDialogCategory(model))" Disabled="@_busy" Class="bg-glass rounded-pill" />
                </div>
                
                <MudList T="CategoryModel" Clickable="true" SelectedValue="SelectedModel" SelectedValueChanged="HandleCategoryChanged" Class="pa-2">
                    @if (listOfItems?.Any() == true)
                    {
                        @foreach (var item in listOfItems)
                        {
                            <ContextMenuTrigger MenuId="myMenu" Data="@item">
                                <MudListItem T="CategoryModel" Value="item" Class="rounded-lg mb-1 admin-list-item">
                                    <div class="d-flex align-center gap-3">
                                        <div class="admin-icon-square-vibrant small">
                                            <MudIcon Icon="@Icons.Material.Filled.Layers" Size="Size.Small" />
                                        </div>
                                        <MudText Typo="Typo.body2" Class="fw-600">@item.CategoryName</MudText>
                                    </div>
                                </MudListItem>
                            </ContextMenuTrigger>
                        }
                    }
                </MudList>
            </div>

            <!-- Main Content Area -->
            <div style="flex-grow: 1;">
                @if (SelectedModel != null && SelectedModel.CategoryID != null)
                {
                    <div class="admin-glass-card pa-0 overflow-hidden mb-6">
                        <div class="pa-6 d-flex align-center justify-space-between">
                            <div>
                                <div class="d-flex align-center gap-2 mb-1">
                                    <MudIcon Icon="@Icons.Material.Filled.AutoGraph" Color="Color.Primary" />
                                    <MudText Typo="Typo.h5" Class="fw-800">@SelectedModel.CategoryName</MudText>
                                </div>
                                <MudText Typo="Typo.body2" Class="opa-60">Manage specific analytic identifiers for this category</MudText>
                            </div>
                            <MudButton StartIcon="@Icons.Material.Filled.PlaylistAdd" Variant="Variant.Filled" Color="Color.Primary" OnClick="@(() => OpenDialog(new DimensionModel { Category = new CategoryModel { CategoryID = SelectedModel.CategoryID.Value } }))" Class="admin-register-btn px-6">ADD DIMENSION</MudButton>
                        </div>
                    </div>

                    <div class="admin-glass-card pa-0 overflow-hidden">
                        <div class="pa-4 b-bottom bg-glass-brighter">
                             <MudTextField @bind-Value="searchTerm" Placeholder="Search dimensions..." Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" Variant="Variant.Outlined" Margin="Margin.Dense" Class="admin-input-group" Clearable="true" />
                        </div>
                        
                        <MudTable Items="@FilteredDimensions" Elevation="0" Class="modern-admin-table" Hover="true">
                            <HeaderContent>
                                <MudTh><span class="admin-header-text">DIMENSION KEY</span></MudTh>
                                <MudTh Style="text-align: right;"><span class="admin-header-text">ACTIONS</span></MudTh>
                            </HeaderContent>
                            <RowTemplate>
                                <MudTd DataLabel="Dimension">
                                    <div class="d-flex align-center gap-3">
                                        <MudIcon Icon="@Icons.Material.Filled.Tag" Size="Size.Small" Color="Color.Primary" Class="opa-40" />
                                        <span class="fw-700 admin-td-primary">@context.Dimension</span>
                                    </div>
                                </MudTd>
                                <MudTd DataLabel="Actions" Style="text-align: right;">
                                    <div class="d-flex justify-end gap-1">
                                        <MudTooltip Text="Edit Dimension">
                                            <MudIconButton OnClick="@(()=> OpenDialog(context))" Color="Color.Primary" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Variant="Variant.Text" />
                                        </MudTooltip>
                                        <MudTooltip Text="Purge Entry">
                                            <MudIconButton OnClick="@(()=> Delete(context))" Color="Color.Error" Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Variant="Variant.Text" />
                                        </MudTooltip>
                                    </div>
                                </MudTd>
                            </RowTemplate>
                            <NoRecordsContent>
                                <div class="pa-8 d-flex flex-column align-center">
                                    <MudIcon Icon="@Icons.Material.Filled.Inbox" Size="Size.Large" Class="opa-20 mb-2" />
                                    <MudText Typo="Typo.body2" Class="opa-40">No dimensions found for this search or category</MudText>
                                </div>
                            </NoRecordsContent>
                            <PagerContent>
                                <div class="pa-4">
                                    <MudTablePager PageSizeOptions="new int[] { 10, 20, 50 }" />
                                </div>
                            </PagerContent>
                        </MudTable>
                    </div>
                }
                else
                {
                    <div class="admin-glass-card d-flex flex-column align-center justify-center py-16" style="min-height: 400px;">
                        <div class="admin-icon-square-vibrant mb-6" style="width: 80px; height: 80px;">
                            <MudIcon Icon="@Icons.Material.Filled.GridGoldenratio" Style="font-size: 3rem;" />
                        </div>
                        <MudText Typo="Typo.h5" Class="fw-800 opa-80 mb-2">Select Analytic Category</MudText>
                        <MudText Typo="Typo.body2" Class="opa-50 text-center" Style="max-width: 300px;">Choose an analytic structure from the sidebar to manage individual data points.</MudText>
                    </div>
                }
            </div>
        </div>
    </div>

    <ContextMenu Id="myMenu" OnAppearing="OnAppearing">
        <Item OnClick="@ContextMenuOnClickadd" Id="addItem">Add Dimension</Item>
        <Item OnClick="@ContextMenuOnClickedit" Id="editGroup">Edit Category</Item>
    </ContextMenu>
}

@code {

    private bool _isLoading = true;
    private DateTime _loadStartTime;

    CategoryModel model = new CategoryModel();
    private MudListItem<CategoryModel> SelectedItem;
    private string searchTerm = "";
    private List<CategoryModel> listOfItems = new();
    CategoryModel SelectedModel = new();
    private List<DimensionModel> collection = new List<DimensionModel>();
    private bool _busy;

    private IEnumerable<DimensionModel> FilteredDimensions => collection
        .Where(x => string.IsNullOrWhiteSpace(searchTerm) || 
                   x.Dimension.Contains(searchTerm, StringComparison.OrdinalIgnoreCase));

    public bool HasPermissionDimensionServiceEdit { get; set; } = false;
    public bool HasPermissionDimensionServiceDelete { get; set; } = false;
    public int DimensionDocTypeID = 87;

    // Lifecycle method called when the component is initialized
    protected override async Task OnInitializedAsync()
    {
        _loadStartTime = DateTime.Now;
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionDimensionServiceEdit = await Irole.HasClaim(DimensionDocTypeID.ToString(), "Edit", ctc.Token);
        HasPermissionDimensionServiceDelete = await Irole.HasClaim(DimensionDocTypeID.ToString(), "Delete", ctc.Token);

        GetAll();
        await EnsureMinimumLoadTime();
        _isLoading = false;
    }

    private async Task EnsureMinimumLoadTime()
    {
        var elapsed = (DateTime.Now - _loadStartTime).TotalMilliseconds;
        if (elapsed < 100)
        {
            await Task.Delay(100 - (int)elapsed);
        }
    }

    // Method to handle selection changes in the list   
    protected async Task HandleCategoryChanged(CategoryModel model)
    {
        SelectedModel = model;
        if (SelectedModel != null)
        {
            GetInventoryItem(SelectedModel);
        }
    }

    // Method to fetch all categories
    private void GetAll()
    {
        listOfItems = Iservice.SelectCategory().ToList();
    }

    // Method to fetch inventory items based on the selected category
    private void GetInventoryItem(CategoryModel ig)
    {
        collection = new List<DimensionModel>();
        foreach (var item in Iservice.SelectByCategory(ig.CategoryID))
        {
            collection.Add(item);
        }
    }

    // Method to open the dialog for adding or editing a dimension
    private async Task OpenDialog(DimensionModel ii)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        _busy = true;

        if (HasPermissionDimensionServiceEdit)
        {
            var authprov = await auth.GetAuthenticationStateAsync();
            var user = authprov.User;

            DialogParameters parms = new DialogParameters();
            parms.Add("model", ii.Clone());
            var dialog = await DialogService.ShowAsync<DimensionDialog>(ii.DimensionID == null ? "ADD" : "EDIT", parms);
            var result = await dialog.Result;

            if (!result.Canceled)
            {
                DimensionModel UpatedModel = (DimensionModel)result.Data;
                UpatedModel.UserInfo.UserID = user.Identity.Name;
                try
                {
                    Iservice.Update(UpatedModel); // Update the dimension
                    snackbar.Add("Saved Successfully", Severity.Success);
                    CategoryModel igm = new CategoryModel();
                    igm.CategoryID = UpatedModel.Category.CategoryID;
                    GetInventoryItem(igm);
                }
                catch (Exception ex)
                {
                    snackbar.Add(ex.Message, Severity.Warning);
                }
            }
        }
        else
        {
            bool? result = await DialogService.ShowMessageBoxAsync(
                "Permission denied!",
                "You don't have any permission to Edit Dimension.");
        }
        await Task.Delay(200);
        _busy = false;
    }

    // Method to delete a dimension
    private async Task Delete(DimensionModel model)
    {
        if (HasPermissionDimensionServiceDelete)
        {
            bool? result = await DialogService.ShowMessageBoxAsync(
                   "Warning !",
                   "Are you sure, you want to delete - " + model.Dimension + "?");
            if (result == true)
            {
                var authprov = await auth.GetAuthenticationStateAsync();
                var user = authprov.User;
                Iservice.Delete(model.DimensionID, user.Identity.Name); // Delete the dimension
                snackbar.Add("Deleted Successfully", Severity.Success);
            }
            GetAll();
            if (SelectedModel != null)
            {
                GetInventoryItem(SelectedModel);
            }
        }
        else
        {
            bool? result = await DialogService.ShowMessageBoxAsync(
                "Permission denied!",
                "You don't have any permission to Delete Dimension.");
        }
    }

    // Method to open the dialog for adding or editing a category
    private async Task OpenDialogCategory(CategoryModel ig)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        _busy = true;

        if (HasPermissionDimensionServiceEdit)
        {
            var authprov = await auth.GetAuthenticationStateAsync();
            var user = authprov.User;

            DialogParameters parms = new DialogParameters();
            parms.Add("model", ig.Clone());
            var dialog = await DialogService.ShowAsync<CostCenterCategoryDialog>(ig.CategoryID == null ? "ADD" : "EDIT", parms);
            var result = await dialog.Result;

            if (!result.Canceled)
            {
                CategoryModel UpdatedModel = (CategoryModel)result.Data;
                UpdatedModel.UserInfo.UserID = user.Identity.Name;
                try
                {
                    Iservice.UpdateCategory(UpdatedModel); // Update the category
                    snackbar.Add("Saved Successfully", Severity.Success);
                    GetAll();
                }
                catch (Exception ex)
                {
                    snackbar.Add(ex.Message, Severity.Warning);
                }
            }
        }
        else
        {
            bool? result = await DialogService.ShowMessageBoxAsync(
                "Permission denied!",
                "You don't have any permission to Edit Dimension.");
        }
        await Task.Delay(200);
        _busy = false;
    }

    void OnAppearing(MenuAppearingEventArgs e)
    {
        //TreeItemData item = (TreeItemData)e.Data;
        // e.PreventShow = !item.HasChildren;
    }

    // Method to handle the context menu click for editing a category
    protected async Task ContextMenuOnClickedit(ItemClickEventArgs e)
    {
        CategoryModel ig = (CategoryModel)e.Data;
        await OpenDialogCategory(ig);
    }

    // Method to handle the context menu click for adding a dimension
    protected async Task ContextMenuOnClickadd(ItemClickEventArgs e)
    {
        CategoryModel ig = (CategoryModel)e.Data;
        DimensionModel ii = new DimensionModel();
        ii.Category.CategoryID = ig.CategoryID.Value;
        await OpenDialog(ii);
    }
}

