@page "/GstUsageID"
@inject IGstUsageIDService Iservice
@inject MudBlazor.ISnackbar snackbar

@inject AuthenticationStateProvider auth
@attribute [Authorize]
@inject IDialogService DialogService





<MudGrid Spacing="4">
   <MudItem xs="12">
        <MudTable Items="@collection"  Dense="true" Hover="true"  Striped="true" Elevation="10" Filter="new Func<GstUsageIDModel, bool>(search)" @bind-place="model">
           

             <ToolBarContent>
                <MudText Typo="Typo.h6">GstUsageID</MudText>
                <MudIconButton Icon="@Icons.Material.Filled.Add" Title="Add" @onclick="@(()=> OpenDialog(model))"  Color="Color.Dark" Size="Size.Small"></MudIconButton>
                
                <MudSpacer></MudSpacer>
                <MudTextField @bind-Value="searchTds" Placeholder="Search TDS... "
                              Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                              IconSize="Size.Medium" Class="mt-0"></MudTextField>
            </ToolBarContent>
            <HeaderContent>
                <MudTh><MudTableSortLabel SortBy="new Func<GstUsageIDModel, object>(x=> x.UsageID)" InitialDirection="SortDirection.Ascending">UsageID</MudTableSortLabel></MudTh>
             <MudTh><MudTableSortLabel SortBy="new Func<GstUsageIDModel, object>(x=> x.AccountName)" InitialDirection="SortDirection.Ascending">Account</MudTableSortLabel></MudTh>
               <MudTh><MudTableSortLabel SortBy="new Func<GstUsageIDModel, object>(x=> x.PeriodFrom)" InitialDirection="SortDirection.Ascending">PeriodFrom</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<GstUsageIDModel, object>(x=> x.PeriodTo)" InitialDirection="SortDirection.Ascending">PeriodTo</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<GstUsageIDModel, object>(x=> x.TaxRate)" InitialDirection="SortDirection.Ascending">Rate</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<GstUsageIDModel, object>(x=> x.SAC)" InitialDirection="SortDirection.Ascending">SAC</MudTableSortLabel></MudTh>
                
                <MudTh>Actions</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="UsageID">@context.UsageID</MudTd>
                <MudTd DataLabel="AccountID">@context.AccountName</MudTd>
                <MudTd DataLabel="PeriodFrom">@context.PeriodFrom</MudTd>
                 <MudTd DataLabel="PeriodTo">@context.PeriodTo</MudTd>
                  <MudTd DataLabel="TaxRate">@context.TaxRate</MudTd>
                   <MudTd DataLabel="TaxRate">@context.SAC</MudTd>
                <MudTd DataLabel="">
                    <MudFab @onclick="@(()=> OpenDialog(context))" Color="Color.Primary" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" IconSize="Size.Small" />
                    <MudFab @onclick="@(()=> Delete(context))" Color="Color.Primary" Icon="@Icons.Material.Filled.Delete" Size="Size.Small" IconSize="Size.Small" />
                </MudTd>
            </RowTemplate>
            <PagerContent>
                <MudTablePager PageSizeOptions="new int[] { 5, 10, 20, 50, 100 }" />
            </PagerContent>
        </MudTable>
    </MudItem>
    </MudGrid>



@code {


    private GstUsageIDModel model = new GstUsageIDModel();
    private List<GstUsageIDModel> collection = new List<GstUsageIDModel>();


    private string searchTds = "";

    protected override async Task OnInitializedAsync()
    {
        model = new();
        GetAll();
    }

    private  void GetAll()
    {
        collection = new List<GstUsageIDModel>();
        foreach (var item in Iservice.FilterByText(string.Empty,DateTime.Now))
        {
            collection.Add(item);
        }
       

    }   

    private async Task OpenDialog(GstUsageIDModel tds)
    {
        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;

        DialogParameters parms = new DialogParameters();
        parms.Add("model",tds);
        var dialog =  DialogService.Show<GstUsageIDDialog>(tds.UsageID == null?"ADD":"EDIT",parms);
        var result = await dialog.Result;
       
        if(!result.Cancelled)
        {   
            GstUsageIDModel UpatedModel = (GstUsageIDModel)result.Data;            
            model.UserInfo.UserID = user.Identity.Name;
         
            try
            {
               
                Iservice.Update(UpatedModel);
                snackbar.Add("Saved Successfully", Severity.Success);
                GetAll();
            }
            catch (Exception ex)
            {
                snackbar.Add(ex.Message, Severity.Warning);
            }

        }
    }
    
    private void Delete(GstUsageIDModel tds)
    {
        Iservice.Delete(tds.UsageID, "Rijas");
        snackbar.Add("Deleted Successfully", Severity.Success);
        GetAll();
    }

    private bool search(GstUsageIDModel tds)
    {
     //if (tds.TdsNP.NatureOfPayment != null && tds.TdsNP.NatureOfPayment.Contains(searchTds, StringComparison.OrdinalIgnoreCase))
     //   {
     //       return true;
     //   }
     //   else if (tds.TaxRate == null) return true;
        return true;
    }



}
