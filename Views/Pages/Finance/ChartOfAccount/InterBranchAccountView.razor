@page "/InterBranchAccountMapping"
@inject IInterBranchMappingService Iservice

@inject MudBlazor.ISnackbar snackbar
@inject AuthenticationStateProvider auth
@attribute [Authorize]
@inject IDialogService DialogService



<MudGrid Spacing="4">
    <MudItem xs="12">
        <MudText Typo="Typo.h6">Inter Branch Mapping</MudText>
        <MudTable Items="@collection" Dense="true" Hover="true" Striped="true" Elevation="10" Filter="new Func<InterBranchMappingModel, bool>(search)" @bind-place="model">
            <ToolBarContent>
                <MudText Typo="Typo.h6">Inter Branch Mapping</MudText>
                <MudIconButton Icon="@Icons.Material.Filled.Add" Title="Add" @onclick="@(()=> OpenDialog(model))" Color="Color.Dark" Size="Size.Small"></MudIconButton>

                <MudSpacer></MudSpacer>
                <MudTextField @bind-Value="searchTds" Placeholder="Search Inter Branch... "
                              Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                              IconSize="Size.Medium" Class="mt-0"></MudTextField>
            </ToolBarContent>
            <HeaderContent>
                <MudTh><MudTableSortLabel SortBy="new Func<InterBranchMappingModel, object>(x=> x.TransactionType)" InitialDirection="SortDirection.Ascending">Transaction Type</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<InterBranchMappingModel, object>(x=> x.DebitBranchID)" InitialDirection="SortDirection.Ascending">Debit Branch ID</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<InterBranchMappingModel, object>(x=> x.CreditBranchID)" InitialDirection="SortDirection.Ascending">Credit Branch ID</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<InterBranchMappingModel, object>(x=> x.CoaID)" InitialDirection="SortDirection.Ascending">CoaID</MudTableSortLabel></MudTh>
                <MudTh>Actions</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Transaction Type">@context.TransactionType</MudTd>
                <MudTd DataLabel="Debit Branch Id">@context.DebitBranchID</MudTd>
                <MudTd DataLabel="credit Branch Id">@context.CreditBranchID</MudTd>
                <MudTd DataLabel="CoaID">@context.CoaID</MudTd>
                <MudTd DataLabel="">
                    <MudFab @onclick="@(()=> OpenDialog(context))" Color="Color.Primary" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" IconSize="Size.Small" />
                    <MudFab @onclick="@(()=> Delete(context))" Color="Color.Primary" Icon="@Icons.Material.Filled.Delete" Size="Size.Small" IconSize="Size.Small" />
                </MudTd>
            </RowTemplate>
            <PagerContent>
                <MudTablePager PageSizeOptions="new int[] { 5, 10, 20, 50, 100 }" />
            </PagerContent>
        </MudTable>
    </MudItem>
</MudGrid>

@code {
    private InterBranchMappingModel model = new InterBranchMappingModel();
    private List<InterBranchMappingModel> collection = new List<InterBranchMappingModel>();


    private string searchTds = "";
    private async Task OpenDialog(InterBranchMappingModel ibm)
    {
        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;

        DialogParameters parms = new DialogParameters();
        parms.Add("model",ibm);
         var dialog =  DialogService.Show<InterBranchAccountDialog>(ibm.ID == null?"ADD":"EDIT",parms);
        var result = await dialog.Result;
          if(!result.Cancelled)
        {   
            InterBranchMappingModel UpatedModel = (InterBranchMappingModel)result.Data;            
            model.UserInfo.UserID = user.Identity.Name;
         
            try
            {
               
                Iservice.Update(UpatedModel);
                snackbar.Add("Saved Successfully", Severity.Success);
                GetAll();
            }
            catch (Exception ex)
            {
                snackbar.Add(ex.Message, Severity.Warning);
            }

        }
    }
    private void Delete(InterBranchMappingModel ibm)
    {
        Iservice.Delete(ibm.ID, "Rijas");
        snackbar.Add("Deleted Successfully", Severity.Success);
        GetAll();
    }
    private void GetAll()
    {
        collection = new List<InterBranchMappingModel>();
        foreach (var item in Iservice.Select())
        {
            collection.Add(item);
        }

    }
    protected override async Task OnInitializedAsync()
    {
        model = new();
       // GetAll();
    }
    private bool search(InterBranchMappingModel ibm)
    {
        //if (ibm.TransactionType != null && ibm.TransactionType.Contains(searchTds, StringComparison.OrdinalIgnoreCase))
        //{
        //    return true;
        //}
        //else if (ibm.CreditBranchID == null) return true;
        return false;
    }


}
