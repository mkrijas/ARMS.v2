@page "/UnReconciledBankEntryView"


@inject IUnreconciledBankEntryService Iservice
@inject MudBlazor.ISnackbar snackbar

@inject AuthenticationStateProvider auth
@attribute [Authorize]
@inject IDialogService DialogService


<MudIconButton  Icon="@Icons.Material.Filled.Add" @onclick="OpenDialog" Variant="Variant.Filled" Color="Color.Primary">
    Open Simple Dialog
</MudIconButton>

<MudGrid Spacing="4">
   <MudItem xs="12">
        <MudTable Items="@collection"   Dense="true" Hover="true"  Striped="true" Elevation="10"  @bind-place="model">
           

             <ToolBarContent>
                <MudText Typo="Typo.h6">Un Reconciled Bank Entry View </MudText>
                <MudTooltip Text="New UnReconciledBankEntry">
                @*<MudIconButton  Icon="@Icons.Material.Filled.Add" Title="Add" @onclick="@(()=> OpenDialog(model))"  Color="Color.Dark" Size="Size.Small"></MudIconButton>*@
                </MudTooltip>
               
             
                <MudSpacer></MudSpacer>
             
            </ToolBarContent>
            <HeaderContent>
                <MudTh><MudTableSortLabel SortBy="new Func<UnReconciledBankEntryModel, object>(x=> x.Nature)" InitialDirection="SortDirection.Ascending">Nature</MudTableSortLabel></MudTh>
                 <MudTh><MudTableSortLabel SortBy="new Func<UnReconciledBankEntryModel, object>(x=> x.TransactionDate)" InitialDirection="SortDirection.Ascending">TransactionDate</MudTableSortLabel></MudTh>
               <MudTh><MudTableSortLabel SortBy="new Func<UnReconciledBankEntryModel, object>(x=> x.ArdCode)" InitialDirection="SortDirection.Ascending">ArdCode</MudTableSortLabel></MudTh>
              <MudTh><MudTableSortLabel SortBy="new Func<UnReconciledBankEntryModel, object>(x=> x.InstrumentType)" InitialDirection="SortDirection.Ascending">InstrumentType</MudTableSortLabel></MudTh>
              <MudTh><MudTableSortLabel SortBy="new Func<UnReconciledBankEntryModel, object>(x=> x.InstrumentDate)" InitialDirection="SortDirection.Ascending">InstrumentDate</MudTableSortLabel></MudTh>
              <MudTh><MudTableSortLabel SortBy="new Func<UnReconciledBankEntryModel, object>(x=> x.Amount)" InitialDirection="SortDirection.Ascending">Amount</MudTableSortLabel></MudTh>
             
              <MudTh>Actions</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Title">@context.Nature</MudTd>                  
                <MudTd DataLabel="BeneficiaryName">@context.TransactionDate</MudTd>
                 <MudTd DataLabel="AccountNumber">@context.ArdCode</MudTd>
                  <MudTd DataLabel="Place">@context.InstrumentType</MudTd>
                  <MudTd DataLabel="BankCode">@context.InstrumentDate</MudTd>
                  <MudTd DataLabel="BankCode">@context.Amount</MudTd>
               <MudTd DataLabel="">
                    <MudTooltip Text="Edit">
                   <MudFab @onclick="@(()=> OpenDialogEdit(context))" Color="Color.Primary" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" IconSize="Size.Small" />
                    </MudTooltip> 
                    <MudTooltip Text="Delete">
                   <MudFab @onclick="@(()=> OpenDialogDelete(context))" Color="Color.Primary" Icon="@Icons.Material.Filled.Delete" Size="Size.Small" IconSize="Size.Small" />
                    </MudTooltip>
                     @*
                    @if(@context.ApprovedInfo.RecordStatus!=1)
                    {
                     <MudTooltip Text="Approve">
                   <MudFab @onclick="@(()=> Approve(context))" Color="Color.Success" Icon="@Icons.Material.Filled.Check" Size="Size.Small" IconSize="Size.Small" />
                    </MudTooltip>
                    }*@
               </MudTd>
            </RowTemplate>
          
            <PagerContent>
                <MudTablePager PageSizeOptions="new int[] { 5, 10, 20, 50, 100 }" />
               @*  <MudButton OnClick="selected" Variant="Variant.Filled" Color="Color.Success" ButtonType="ButtonType.Submit">Submit</MudButton>*@
           
            </PagerContent>
        </MudTable>
    </MudItem>
    </MudGrid>
@code {


    private UnReconciledBankEntryModel model = new();
    private List<UnReconciledBankEntryModel> collection = new();

    private void OpenDialog()
    {
        UnReconciledBankEntryModel UnReconciledBankEntry = new();
        UnReconciledBankEntry.BankID = 12323213;
        UnReconciledBankEntry.ArdCode= "cksdfjhdshfgs";
        UnReconciledBankEntry.ID= 1;

        var model = new DialogParameters { ["model"]=UnReconciledBankEntry };

        var options = new DialogOptions { CloseOnEscapeKey = true };
        DialogService.Show<UnReconciledBankEntryDialog>("Simple Dialog",model, options);
    }
    private void OpenDialogAddNew()
    {
        UnReconciledBankEntryModel UnReconciledBankEntry = new();
        //UnReconciledBankEntry.BankID = 12323213;
        //UnReconciledBankEntry.ArdCode= "cksdfjhdshfgs";
        //UnReconciledBankEntry.ID= 1;
         UnReconciledBankEntry.BankID = 12323213;
        var model = new DialogParameters { ["model"]=UnReconciledBankEntry };

        var options = new DialogOptions { CloseOnEscapeKey = true };
        DialogService.Show<UnReconciledBankEntryDialog>("Simple Dialog",model, options);
    }
    private void OpenDialogEdit(UnReconciledBankEntryModel UnReconciledBankEntry)
    {

        var model = new DialogParameters { ["model"]=UnReconciledBankEntry };

        var options = new DialogOptions { CloseOnEscapeKey = true };
        DialogService.Show<UnReconciledBankEntryDialog>("Simple Dialog",model, options);

    }
    private async Task OpenDialogDelete(UnReconciledBankEntryModel UnReconciledBankEntry)
    {
          var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;
        UnReconciledBankEntry.UserInfo.UserID = user.Identity.Name;
        Iservice.Delete(UnReconciledBankEntry.ID,UnReconciledBankEntry.UserInfo.UserID);
        
        var options = new DialogOptions { CloseOnEscapeKey = true };
        
        var model = new DialogParameters { ["model"]=UnReconciledBankEntry };
        DialogService.Show<UnReconciledBankEntryDialog>("Simple Dialog",model, options);
          GetAll();
    }
     protected override async Task OnInitializedAsync()
    {
        model = new();
        GetAll();
    }

    private  void GetAll()
    {

        collection = new();
        foreach (var item in Iservice.Select(0,true))
        {
            collection.Add(item);
        }


    }

}