@page "/DayOpenRequestView"
@attribute [Authorize]
@inject AuthenticationStateProvider auth
@inject IRoleService<RoleModel> Irole
@using Newtonsoft.Json;
@using System.Text;
@using System.Threading;
@using Core.BaseModels.Finance
@using Core.IDataServices.Finance.DayOpen
@inject MudBlazor.ISnackbar snackbar
@inject IDialogService DialogService
@inject IDataAuthorizationSettingsService Iservice
@inject IDayOpenService IDayOpenService

@if (_isLoading)
{
    <div @key="@("loader")" style="display: flex; justify-content: center; align-items: center; min-height: 400px;">
        <LoaderComponent IsFullScreen="true" 
                        ShowLogo="false" 
                        Size="medium" 
                        LoadingText="Loading Day-Open Requests" 
                        SubText="Please wait..." />
    </div>
}
else
{
    <div class="fade-in">
        <div class="admin-header-tiered mb-6">
            <div class="d-flex align-center justify-space-between">
                <div>
                    <MudText Typo="Typo.h4" Class="admin-title">Administrative Day-Open Overrides</MudText>
                    <MudText Typo="Typo.body2" Class="admin-subtitle">Manage requests for reopening closed financial periods. review justification, monitor audit trails, and maintain strict control over retroactive accounting entries.</MudText>
                </div>
                <MudButton StartIcon="@Icons.Material.Filled.Add" Variant="Variant.Filled" Color="Color.Primary" Class="admin-register-btn" OnClick="@(()=> Edit())" Disabled="@_busy">NEW OVERRIDE REQUEST</MudButton>
            </div>
        </div>

        <div class="admin-glass-card mb-6 pa-4">
            <div class="d-flex align-center gap-4 flex-wrap">
                <div style="flex-grow: 1; min-width: 300px;">
                    <MudTextField @bind-Value="searchmodel" Placeholder="Search by branch, document or requester..." Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" Variant="Variant.Outlined" Margin="Margin.Dense" Class="admin-input-group" Clearable="true" />
                </div>
                <div class="d-flex align-center gap-4">
                    <div class="d-flex align-center gap-3 bg-glass rounded-pill px-4 py-1">
                        <MudText Typo="Typo.caption" Class="fw-700 opa-50 uppercase">Fetch</MudText>
                        <MudNumericField Value="@NumberOfRecords" ValueChanged="@((int? x)=> RecordNoChanged(x))" Variant="Variant.Text" Margin="Margin.Dense" Style="width: 50px;" Class="fw-700 mt-0" HideSpinButtons="true" />
                    </div>
                    <div class="d-flex align-center gap-2 bg-glass rounded-pill px-4 py-1">
                        <MudCheckBox T="bool" Label="Archive (Completed)" ValueChanged="((bool value)=>Completed(value))" Value="@IsCompleted" Size="Size.Small" Color="Color.Primary" Class="fw-600"></MudCheckBox>
                    </div>
                </div>
            </div>
        </div>

        <div class="admin-glass-card pa-0 overflow-hidden">
            <MudTable Items="@ShowModel" Elevation="0" Class="modern-admin-table" Hover="true" Filter="new Func<DayOpenRequestModel, bool>(search)">
                <HeaderContent>
                    <MudTh><MudTableSortLabel SortBy="new Func<DayOpenRequestModel, object>(x=> x.Branch.BranchName)" InitialDirection="SortDirection.Descending"><span class="admin-header-text">ENTITY / BRANCH</span></MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<DayOpenRequestModel, object>(x=> x.DocType.Description)"><span class="admin-header-text">DOCUMENT TYPE</span></MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<DayOpenRequestModel, object>(x=> x.FromDate)"><span class="admin-header-text">PERIOD</span></MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<DayOpenRequestModel, object>(x=> x.IsOpen)"><span class="admin-header-text">STATUS</span></MudTableSortLabel></MudTh>
                    <MudTh><span class="admin-header-text">AUDIT TRAIL</span></MudTh>
                    <MudTh Style="text-align: right;"><span class="admin-header-text">ACTIONS</span></MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Branch">
                        <div class="d-flex align-center gap-2">
                            <MudIcon Icon="@Icons.Material.Filled.Domain" Size="Size.Small" Class="opa-40" />
                            <span class="fw-700">@context.Branch.BranchName</span>
                        </div>
                    </MudTd>
                    <MudTd DataLabel="Document">
                        <span class="fw-600">@context.DocType.Description</span>
                    </MudTd>
                    <MudTd DataLabel="Period">
                        <div class="d-flex flex-column small">
                            <span class="fw-700 admin-td-primary">@context.FromDate?.ToString("dd MMM yyyy")</span>
                            <span class="opa-50 fw-600">to @context?.ToDate?.ToString("dd MMM yyyy")</span>
                        </div>
                    </MudTd>
                    <MudTd DataLabel="Status">
                        @if (context.RecordStatus == 3)
                        {
                            <MudChip T="string" Color="Color.Warning" Variant="Variant.Text" Size="Size.Small" Class="fw-700 px-3 border-solid border-1">PENDING REVIEW</MudChip>
                        }
                        else if (context.RecordStatus == 4)
                        {
                            <MudChip T="string" Color="Color.Success" Variant="Variant.Text" Size="Size.Small" Class="fw-700 px-3 border-solid border-1">ACTIVE OVERRIDE</MudChip>
                        }
                        else if (context.RecordStatus == 5 && context.OpenByUsedID != null && context.CloseByUsedID != null)
                        {
                            <MudChip T="string" Color="Color.Default" Variant="Variant.Text" Size="Size.Small" Class="fw-700 px-3 border-solid border-1">RE-CLOSED</MudChip>
                        }
                        else if (context.RecordStatus == 5 && context.OpenByUsedID == null && context.CloseByUsedID != null)
                        {
                            <MudChip T="string" Color="Color.Error" Variant="Variant.Text" Size="Size.Small" Class="fw-700 px-3 border-solid border-1">REJECTED</MudChip>
                        }
                    </MudTd>
                    <MudTd DataLabel="Audit">
                        <div class="d-flex flex-column small">
                            <div class="d-flex align-center gap-2 mb-1">
                                <MudIcon Icon="@Icons.Material.Filled.Person" Size="Size.Small" Style="font-size: 0.8rem;" Class="opa-40" />
                                <span class="fw-600">Req: @context.UserInfo.UserID</span>
                            </div>
                            @if (!string.IsNullOrEmpty(context.OpenByUsedID))
                            {
                                <div class="d-flex align-center gap-2">
                                    <MudIcon Icon="@Icons.Material.Filled.VerifiedUser" Size="Size.Small" Style="font-size: 0.8rem;" Class="opa-40" />
                                    <span class="fw-600">Auth: @context.OpenByUsedID</span>
                                </div>
                            }
                        </div>
                    </MudTd>
                    <MudTd DataLabel="Actions" Style="text-align: right;">
                        <div class="d-flex justify-end gap-2">
                            @if (context.RecordStatus == 3)
                            {
                                <MudTooltip Text="Approve Request">
                                    <MudIconButton OnClick="@(e => Approve(context))" Color="Color.Primary" Icon="@Icons.Material.Filled.CheckCircle" Size="Size.Small" Variant="Variant.Filled" Class="rounded-pill shadow" />
                                </MudTooltip>
                                <MudTooltip Text="Reject Request">
                                    <MudIconButton OnClick="@(e => Reject(context))" Color="Color.Error" Icon="@Icons.Material.Filled.Cancel" Size="Size.Small" Variant="Variant.Text" />
                                </MudTooltip>
                            }
                            @if (context.RecordStatus == 4)
                            {
                                <MudTooltip Text="Terminate Override">
                                    <MudButton OnClick="@(e => Close(context))" StartIcon="@Icons.Material.Filled.Lock" Variant="Variant.Filled" Color="Color.Error" Size="Size.Small" Class="rounded-pill fw-700">RE-CLOSE DAY</MudButton>
                                </MudTooltip>
                            }
                        </div>
                    </MudTd>
                </RowTemplate>
                <PagerContent>
                    <div class="pa-4">
                        <MudTablePager PageSizeOptions="new int[] { 10, 20, 50, 100 }" />
                    </div>
                </PagerContent>
            </MudTable>
        </div>
    </div>
}

@code {

    private bool _isLoading = true;
    private DateTime _loadStartTime;
    private bool _busy;

    List<DocTypeModel> doctypelist = new List<DocTypeModel>();
    private List<DayOpenRequestModel> Model = new List<DayOpenRequestModel>();
    private List<DayOpenRequestModel> ShowModel = new List<DayOpenRequestModel>();
    private string searchmodel = "";
    private int? BranchID;
    public int? NumberOfRecords = 100;
    public bool IsCompleted { get; set; } = false;

    int DayOpenDocTypeID = 137;
    public bool HasPermissionIDayOpenServiceEdit { get; set; } = false;
    public bool HasPermissionIDayOpenServiceApprove { get; set; } = false;
    public bool HasPermissionIDayOpenServiceReject { get; set; } = false;
    public bool HasPermissionIDayOpenServiceClose { get; set; } = false;

    // Lifecycle method called when the component is initialized
    protected override async Task OnInitializedAsync()
    {
        _loadStartTime = DateTime.Now;
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionIDayOpenServiceEdit = await Irole.HasClaim(DayOpenDocTypeID.ToString(), "Edit", ctc.Token);
        HasPermissionIDayOpenServiceApprove = await Irole.HasClaim(DayOpenDocTypeID.ToString(), "Approve", ctc.Token);
        HasPermissionIDayOpenServiceReject = await Irole.HasClaim(DayOpenDocTypeID.ToString(), "Reject", ctc.Token);
        HasPermissionIDayOpenServiceClose = await Irole.HasClaim(DayOpenDocTypeID.ToString(), "Close", ctc.Token);

        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;
        BranchID = int.Parse(user.Claims.FirstOrDefault(x => x.Type == "BranchID").Value);
        await GetAll(NumberOfRecords);
        await Completed(IsCompleted);
        await EnsureMinimumLoadTime();
        _isLoading = false;
    }

    private async Task EnsureMinimumLoadTime()
    {
        var elapsed = (DateTime.Now - _loadStartTime).TotalMilliseconds;
        if (elapsed < 100)
        {
            await Task.Delay(100 - (int)elapsed);
        }
    }

    // Method to fetch all day open requests
    private async Task GetAll(int? RowNo)
    {
        Model = IDayOpenService.Select(RowNo, BranchID).ToList(); // Fetch requests from the service
    }

    // Method to filter requests based on completion status
    private async Task Completed(bool value)
    {
        IsCompleted = value;
        if (IsCompleted)
        {
            ShowModel = Model.Where(x => x.RecordStatus == 5).ToList();
        }
        else
        {
            ShowModel = Model.Where(x => x.RecordStatus != 5).ToList();
        }
    }

    // Method to handle changes in the number of records to display
    public async Task RecordNoChanged(int? RowNo)
    {
        NumberOfRecords = RowNo;
        await GetAll(RowNo);
        await Completed(IsCompleted);
    }

    // Method to open the dialog for adding or editing a day open request
    public async Task Edit()
    {
        if (HasPermissionIDayOpenServiceEdit)
        {
            DialogOptions options = new DialogOptions() { MaxWidth = MaxWidth.Small };
            var dialog = await DialogService.ShowAsync<DayOpenDialog>("Add/Edit DayOpen Request", options);
            var result = await dialog.Result;
            if (!result.Canceled)
            {
                try
                {
                    DayOpenRequestModel UpatedModel = (DayOpenRequestModel)result.Data;
                    IDayOpenService.Update(UpatedModel); // Update the request
                                                         // Code for sending HTTP request
                    var httpClient = new HttpClient();

                    var requestContent = new StringContent(
                        JsonConvert.SerializeObject(new
                        {
                            notificationID = 0,
                            userID = "string",
                            token = "string",
                            title = "New Day Open Request",
                            body = "A request to open the day has been made."
                        }),
                        Encoding.UTF8,
                        "application/json"
                    );

                    var response = await httpClient.PostAsync("https://armsapp.teamthai.in:8084/api/Login/SendAllFirebaseNotifications", requestContent);

                    if (response.IsSuccessStatusCode)
                    {
                        snackbar.Add("Request Created Successfully.", Severity.Success);
                    }
                    else
                    {
                        snackbar.Add("Request Created failed.", Severity.Warning);
                    }
                }
                catch (Exception ex)
                {
                    snackbar.Add(ex.Message, Severity.Warning);
                }
            }
            await GetAll(NumberOfRecords);
            await Completed(IsCompleted);
        }
        else
        {
            bool? result = await DialogService.ShowMessageBoxAsync(
                "Permission denied!",
                "You don't have any permission to Edit DayOpen.");
        }
    }

    // Method to approve a day open request
    public async Task Approve(DayOpenRequestModel model)
    {
        if (HasPermissionIDayOpenServiceApprove)
        {
            var authprov = await auth.GetAuthenticationStateAsync();
            model.UserInfo.UserID = authprov.User.Identity.Name;

            bool? result = await DialogService.ShowMessageBoxAsync(
                "Warning !",
                "Are you sure you want to Approve ?");
            if (result == true)
            {
                try
                {
                    IDayOpenService.Approve(model); // Approve the request
                    snackbar.Add("Approved Successfully.", Severity.Success);
                }
                catch (Exception ex)
                {
                    snackbar.Add(ex.Message, Severity.Warning);
                }
            }
            await GetAll(NumberOfRecords);
            await Completed(IsCompleted);
        }
        else
        {
            bool? result = await DialogService.ShowMessageBoxAsync(
                "Permission denied!",
                "You don't have any permission to Approve DayOpen.");
        }
    }

    // Method to reject a day open request
    public async Task Reject(DayOpenRequestModel model)
    {
        if (HasPermissionIDayOpenServiceReject)
        {
            var authprov = await auth.GetAuthenticationStateAsync();
            model.UserInfo.UserID = authprov.User.Identity.Name;

            bool? result = await DialogService.ShowMessageBoxAsync(
                "Warning !",
                "Are you sure you want to Reject ?");
            if (result == true)
            {
                try
                {
                    IDayOpenService.RejectOrClose(model); // Reject the request
                    snackbar.Add("Rejected Successfully.", Severity.Success);
                }
                catch (Exception ex)
                {
                    snackbar.Add(ex.Message, Severity.Warning);
                }
            }
            await GetAll(NumberOfRecords);
            await Completed(IsCompleted);
        }
        else
        {
            bool? result = await DialogService.ShowMessageBoxAsync(
                "Permission denied!",
                "You don't have any permission to Reject DayOpen.");
        }
    }

    // Method to close a day open request
    public async Task Close(DayOpenRequestModel model)
    {
        if (HasPermissionIDayOpenServiceClose)
        {
            var authprov = await auth.GetAuthenticationStateAsync();
            model.UserInfo.UserID = authprov.User.Identity.Name;

            bool? result = await DialogService.ShowMessageBoxAsync(
                "Warning !",
                "Are you sure you want to Close ?");
            if (result == true)
            {
                try
                {
                    IDayOpenService.RejectOrClose(model); // Close the request
                    snackbar.Add("Closed Successfully.", Severity.Success);
                }
                catch (Exception ex)
                {
                    snackbar.Add(ex.Message, Severity.Warning);
                }
            }
            await GetAll(NumberOfRecords);
            await Completed(IsCompleted);
        }
        else
        {
            bool? result = await DialogService.ShowMessageBoxAsync(
                "Permission denied!",
                "You don't have any permission to Close DayOpen.");
        }
    }

    // Method to filter requests based on the search model
    private bool search(DayOpenRequestModel model)
    {
        if (model.ID != null && model.DocType.Description.Contains(searchmodel, StringComparison.OrdinalIgnoreCase) 
            || model.UserInfo.UserID.Contains(searchmodel, StringComparison.InvariantCultureIgnoreCase)
            || model.Branch.BranchName.Contains(searchmodel, StringComparison.InvariantCultureIgnoreCase))
        {
            return true;
        }
        else if (model.ID == null)
        {
            return true;
        }
        return false;
    }
}
