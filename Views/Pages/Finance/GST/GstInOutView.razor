@page "/gst"
@inject IGstItemService Iservice



<MudGrid Spacing="4">
    <MudItem xs="12">
        <MudTable Items="@model">

            <ToolBarContent>
                <MudText Typo="Typo.h6">GST Input-Output View</MudText>
            </ToolBarContent>

            <HeaderContent>
                <MudTh>GstTypeID</MudTh>
                <MudTh>GstType</MudTh>
                <MudTh>InputAccount</MudTh>
                <MudTh>OutputAccount</MudTh>
            </HeaderContent>

            <RowTemplate>
                <MudTd DataLabel="GstTypeID">@context.GstTypeID</MudTd>
                <MudTd DataLabel="GstType">@context.GstType</MudTd>
                <MudTd DataLabel="InputAccount">@context.InputAccount</MudTd>
                <MudTd DataLabel="OutputAccount">@context.OutputAccount</MudTd>
            </RowTemplate>

            <PagerContent>
                <MudTablePager PageSizeOptions="new int[] { 5, 10, 20, 50, 100 }" />
            </PagerContent>

        </MudTable>
    </MudItem>
</MudGrid>


@code {

    private List<GstInOutModel> model = new List<GstInOutModel>();

    protected override async Task OnInitializedAsync()
    {
        {
            model = new List<GstInOutModel>();
            model = await Task.Run(() => Iservice.GetInOut().ToList());
        }
    }

}
