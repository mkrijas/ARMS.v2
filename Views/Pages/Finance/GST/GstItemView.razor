@page "/GstItems"
@inject IGstItemService Iservice
@inject MudBlazor.ISnackbar snackbar

@inject AuthenticationStateProvider auth
@attribute [Authorize]
@inject IDialogService DialogService





<MudGrid Spacing="4">
   <MudItem xs="12">
        <MudTable Items="@collection"  Dense="true" Hover="true"  Striped="true" Elevation="10" Filter="new Func<GstItemModel, bool>(search)" @bind-place="model">
           

             <ToolBarContent>
                <MudText Typo="Typo.h6">Gst Inventory Items</MudText>
                <MudIconButton Icon="@Icons.Material.Filled.Add" Title="Add" @onclick="@(()=> OpenDialog(model))"  Color="Color.Dark" Size="Size.Small"></MudIconButton>
                
                <MudSpacer></MudSpacer>
                <MudTextField @bind-Value="searchItem" Placeholder="Search Items... "
                              Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                              IconSize="Size.Medium" Class="mt-0"></MudTextField>
            </ToolBarContent>
            <HeaderContent>
                <MudTh><MudTableSortLabel SortBy="new Func<GstItemModel, object>(x=> x.ItemCode)" InitialDirection="SortDirection.Ascending">ItemCode</MudTableSortLabel></MudTh>
             <MudTh><MudTableSortLabel SortBy="new Func<GstItemModel, object>(x=> x.TaxRate)" InitialDirection="SortDirection.Ascending">TaxRate</MudTableSortLabel></MudTh>
               <MudTh><MudTableSortLabel SortBy="new Func<GstItemModel, object>(x=> x.PeriodFrom)" InitialDirection="SortDirection.Ascending">PeriodFrom</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<GstItemModel, object>(x=> x.PeriodTo)" InitialDirection="SortDirection.Ascending">PeriodTo</MudTableSortLabel></MudTh>
              
                <MudTh>Actions</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="ItemCode">@context.ItemCode</MudTd>
                <MudTd DataLabel="TaxRate">@context.TaxRate</MudTd>
                <MudTd DataLabel="PeriodFrom">@context.PeriodFrom</MudTd>
                 <MudTd DataLabel="PeriodTo">@context.PeriodTo</MudTd>

                <MudTd DataLabel="">
                    <MudFab @onclick="@(()=> OpenDialog(context))" Color="Color.Primary" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" IconSize="Size.Small" />
                    <MudFab @onclick="@(()=> Delete(context))" Color="Color.Primary" Icon="@Icons.Material.Filled.Delete" Size="Size.Small" IconSize="Size.Small" />
                </MudTd>
            </RowTemplate>
            <PagerContent>
                <MudTablePager PageSizeOptions="new int[] { 5, 10, 20, 50, 100 }" />
            </PagerContent>
        </MudTable>
    </MudItem>
    </MudGrid>



@code {


    private GstItemModel model = new GstItemModel();
    private List<GstItemModel> collection = new List<GstItemModel>();


    private string searchItem = "";

    protected override async Task OnInitializedAsync()
    {
        model = new();
        GetAll();
    }

    private  void GetAll()
    {
        collection = new List<GstItemModel>();
        foreach (var item in Iservice.Select(DateTime.Now))
        {
            collection.Add(item);
        }


    }   

    private async Task OpenDialog(GstItemModel tds)
    {
        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;

        DialogParameters parms = new DialogParameters();
        parms.Add("model",tds);
        var dialog =  DialogService.Show<GstItemDialog>(tds.HsnID == null?"ADD":"EDIT",parms);
        var result = await dialog.Result;

        if(!result.Cancelled)
        {   
            GstItemModel UpatedModel = (GstItemModel)result.Data;            
            model.UserInfo.UserID = user.Identity.Name;

            try
            {

                Iservice.Update(UpatedModel);
                model = new();
                snackbar.Add("Saved Successfully", Severity.Success);
                model = new GstItemModel();
                GetAll();
            }
            catch (Exception ex)
            {
                snackbar.Add(ex.Message, Severity.Warning);
            }

        }
    }
    
    private void Delete(GstItemModel tds)
    {
        Iservice.Delete(tds.HsnID.Value,"Rijas");
        snackbar.Add("Deleted Successfully", Severity.Success);
        GetAll();
    }

    private bool search(GstItemModel tds)
    {
     if (tds.ItemCode != null && tds.ItemCode.Contains(searchItem, StringComparison.OrdinalIgnoreCase))
        {
            return true;
        }
        else if (tds.ItemCode == null)
        return true;
        return false;
    }



}
