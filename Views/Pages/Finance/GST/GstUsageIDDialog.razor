@inject IGstUsageIDService Iservice
@inject IChartOfAccountService accountService
@inject MudBlazor.ISnackbar snackbar
@inject AuthenticationStateProvider auth
@attribute [Authorize]
@inject IDialogService DialogService



<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.Build" Class="mr-3 mb-n1" />
            Create GstUsageID
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudContainer Style="min-height:300px;max-height: 800px;">
            <EditForm id="formtdsRate" Model="@model" OnValidSubmit="OnValidSubmit">
                <ObjectGraphDataAnnotationsValidator />
                <ValidationSummary />
                <MudGrid Spacing="2">
                    
                     <MudItem xs="12" md="12">
                         @if(model.UsageCode != null)
                         {
                        <MudTextField ReadOnly="true" @bind-Value="model.UsageCode" Label="Gst UsageId" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.UsageCode)"></MudTextField>
                         }
                        
                    </MudItem>
                    <MudItem xs="6">
                        <MudTextField @bind-Value="model.Description" Label="Description" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.Description)"></MudTextField>

                    </MudItem>
                    <MudItem xs="6">
                         <MudSelect Label="Area" @bind-Value="model.Area" T="string" Variant="Variant.Outlined" Margin="Margin.Dense" OffsetY="true" Direction="Direction.Top" AdornmentColor="Color.Secondary">
                            @foreach (var ditem in AreaList)
                            {
                                <MudSelectItem Value="@ditem">@ditem</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                     <MudItem xs="6">
                       

                           <MudAutocomplete T="ChartOfAccountModel" Label="Select Accounts" Value="SelectedAccount" ValueChanged="OnSelectAccount" ResetValueOnEmptyText="true" Variant="Variant.Outlined" Margin="Margin.Dense" OffsetY="true" Direction="Direction.Top" AdornmentColor="Color.Secondary"
                                     SearchFunc="SearchAccounts" ToStringFunc="@(e => e == null ? null : $"{e.AccountName}")" Required></MudAutocomplete>
                    </MudItem>
                    <MudItem xs="6">

                        <MudSelect Label="Select RID" @bind-Value="model.RID" T="int?"  Variant="Variant.Outlined" Margin="Margin.Dense" OffsetY="true" Direction="Direction.Top" AdornmentColor="Color.Secondary">
                            @foreach (var ditem in gstRate)
                            {
                                <MudSelectItem Value="@ditem.RID">@ditem.TaxRate</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                   
                    <MudItem xs="12" md="6">
                        <MudDatePicker Label="Period From" Variant="Variant.Outlined" Margin="Margin.Dense" DisableToolbar="true" Editable="true" @bind-Date="model.PeriodFrom" HelperText="Enter Date" DateFormat="dd/MM/yyyy" />
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudDatePicker Label="Period To" Variant="Variant.Outlined" Margin="Margin.Dense" DisableToolbar="true" Editable="true" @bind-Date="model.PeriodTo" HelperText="Enter Date" DateFormat="dd/MM/yyyy" />
                    </MudItem>
                    <MudItem xs="12" md="12">
                        <MudTextField @bind-Value="model.SAC" Label="SAC" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.SAC)"></MudTextField>
                    </MudItem>
                </MudGrid>
            </EditForm>
        </MudContainer>
    </DialogContent>
    <DialogActions>
        @*   <MudButton OnClick="DeleteTaxRate">Delete Tax Rate</MudButton>
            <MudButton OnClick="AddTaxRate">Add More Tax Rate</MudButton>*@
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton form="formtdsRate" Variant="Variant.Filled" Color="Color.Success" ButtonType="ButtonType.Submit">Submit</MudButton>

    </DialogActions>
</MudDialog>



@code {
    [Parameter]
    public GstUsageCodeModel model { get; set; }
    private List<GstUsageCodeModel> collection = new List<GstUsageCodeModel>();
    private List<string> AreaList = new List<string>() { "Operation", "Maintenance","All" };

    private List<GstRateModel> gstRate = new();
    public static int edit = 0;
    private GstUsageCodeModel tds = new();
    [CascadingParameter] MudDialogInstance MudDialog { get; set; }

    private ChartOfAccountModel SelectedAccount = null;

    protected override void OnInitialized()
    {
        if(model.Id!=null)
        { edit = 1; }
        try
        {
            SelectedAccount = new();
            SelectedAccount.CoaID = model.CoaID;
            SelectedAccount.AccountName = model.CoaDescreption;
        }
        catch(Exception ex)
        {}



        gstRate = Iservice.GetGstRates().ToList();


        // asseesse = Iservice.SelectAssesseeTypes().ToList();
    }

    private async Task<IEnumerable<ChartOfAccountModel>> SearchAccounts(string searchString)
    {

        return await Task.FromResult(accountService.FilterSubLedgers(searchString));

    }

    private void OnSelectAccount(ChartOfAccountModel obj)
    {
        SelectedAccount = obj;
        model.CoaID = SelectedAccount.CoaID;
    }

    private void OnValidSubmit(EditContext context)
    {  
        model.CoaID = SelectedAccount.CoaID;
        DateRange dr = new DateRange(model.PeriodFrom, model.PeriodTo);
        List<GstUsageCodeModel> tdsList = Iservice.SelectByTaxRateAccount(model.RID, model.CoaID).Where(x => x.Id != model.Id).ToList();

        List<DateRange> drList = new List<DateRange>();
        tdsList.ForEach(item => drList.Add(new DateRange(item.PeriodFrom, item.PeriodTo)));

        if (CommonMethods.CheckPeriodOverlap(dr, drList))
        {
            snackbar.Add("Periods cannot be overlapped", Severity.Success);
        }
        else
        {
          
            //if(edit==0)
            //{ 
            //    GstUsageIDModel usageList = Iservice.SelectByID(model.UsageCode);
            //    if(usageList.Id!=null)
            //    {
            //         snackbar.Add("User ID already exists", Severity.Success);
            //         return;
            //    }
            //}
           
            if (model.CoaID == null)
            {
                snackbar.Add("Select Account", Severity.Success);
                return;
            }
           
            MudDialog.Close(model);
        }
    }

    private void Cancel()
    {
        MudDialog.Cancel();
    }
}
