@page "/CreditDebitTransfer"
@page "/CreditDebitTransfer/{id:int}"
@inherits ViewComponentBase<CreditDebitTransferModel>
@* @inject ICreditTransferService Iservice *@

@if (_isLoading)
{
    <div @key="@("loader")" style="display: flex; justify-content: center; align-items: center; min-height: 400px;">
        <LoaderComponent IsFullScreen="true" 
                        ShowLogo="false" 
                        Size="medium" 
                        LoadingText="Loading Transmission Protocols" 
                        SubText="Please wait..." />
    </div>
}
else
{
    <div class="fade-in">
        <div class="admin-header-tiered mb-6">
            <div class="d-flex align-center justify-space-between">
                <div>
                    <MudText Typo="Typo.h4" Class="admin-title">Credit/Debit Fund Transmission</MudText>
                    <MudText Typo="Typo.body2" Class="admin-subtitle">Facilitate intra-branch fund movements and party account adjustments. oversee transmission modes, origin entities, and verification statuses for internal financial integrity.</MudText>
                </div>
                <MudButton StartIcon="@Icons.Material.Filled.SwapVert" Variant="Variant.Filled" Color="Color.Primary" Class="admin-register-btn" OnClick="@(()=> OpenForm(new CreditDebitTransferModel(),false))" Disabled="@_busy">INITIATE TRANSFER</MudButton>
            </div>
        </div>

        <div class="admin-glass-card mb-6 pa-4">
            <div class="d-flex align-center gap-4 flex-wrap">
                <div style="flex-grow: 1; min-width: 300px;">
                    <MudTextField @bind-Value="searchTerm" Placeholder="Search by document number or party details..." Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" Variant="Variant.Outlined" Margin="Margin.Dense" Class="admin-input-group" Clearable="true" @onkeyup="HandleSearchKeyUp" />
                </div>
                <div class="d-flex align-center gap-4">
                    <div class="d-flex align-center bg-glass rounded-pill px-4 py-1">
                        <MudText Typo="Typo.caption" Class="fw-700 opa-50 uppercase mr-2">Limit</MudText>
                        <MudNumericField @bind-Value="@NumberOfRecords" Variant="Variant.Text" Margin="Margin.Dense" Style="width: 50px;" Class="fw-700 mt-0" HideSpinButtons="true" />
                    </div>
                    <div class="d-flex align-center bg-glass rounded-pill px-4 py-1">
                        <MudCheckBox T="bool" Label="Approved Only" ValueChanged="((bool value)=>ToggleData(value))" Value="@ShowApproved" Size="Size.Small" Color="Color.Primary" Class="fw-600" />
                    </div>
                </div>
            </div>
        </div>

        <div class="admin-glass-card pa-0 overflow-hidden">
            <MudTable Items="@collection" Elevation="0" Class="modern-admin-table" Hover="true">
                <HeaderContent>
                    <MudTh><MudTableSortLabel SortBy="new Func<CreditDebitTransferModel, object>(x=> x.DocumentDate)"><span class="admin-header-text">DATE</span></MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<CreditDebitTransferModel, object>(x=> x.DocumentNumber)"><span class="admin-header-text">DOC NUMBER</span></MudTableSortLabel></MudTh>
                    <MudTh><span class="admin-header-text">MODE</span></MudTh>
                    <MudTh><span class="admin-header-text">TRANSMISSION ROUTE (FROM → TO)</span></MudTh>
                    <MudTh Style="text-align: right;"><span class="admin-header-text">AMOUNT</span></MudTh>
                    <MudTh Style="text-align: right;"><span class="admin-header-text">ACTIONS</span></MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Date"><span class="fw-500">@context.DocumentDate.Value.ToString("dd MMM yyyy")</span></MudTd>
                    <MudTd DataLabel="DocNum">
                        <div class="d-flex flex-column">
                            <span class="admin-td-primary fw-700">@context.DocumentNumber</span>
                            @if (context.AuthLevelId == 100)
                            {
                                <span class="tiny fw-800 text-error">REJECTED TRANSMISSION</span>
                            }
                        </div>
                    </MudTd>
                    <MudTd DataLabel="Mode">
                        <MudChip T="string" Color="Color.Default" Variant="Variant.Text" Size="Size.Small" Class="fw-700 px-3 border-solid border-1">@context.TransactionModeDisplay</MudChip>
                    </MudTd>
                    <MudTd DataLabel="Route">
                        <div class="d-flex align-center gap-2">
                            <div class="d-flex flex-column">
                                <span class="small fw-700">@context.BranchName</span>
                                <span class="tiny opa-50">@context.OriginParty.TradeName</span>
                            </div>
                            <MudIcon Icon="@Icons.Material.Filled.ArrowForward" Size="Size.Small" Class="opa-20" />
                            <div class="d-flex flex-column text-right">
                                <span class="small fw-700">@context.OtherBranchName</span>
                                <span class="tiny opa-50">@context.TargetParty.TradeName</span>
                            </div>
                        </div>
                    </MudTd>
                    <MudTd DataLabel="Amount" Style="text-align: right;">
                        <span class="fw-800 text-vibrant" style="font-size: 1rem;">@context.TotalAmount?.ToString("N2")</span>
                    </MudTd>
                    <MudTd DataLabel="Actions" Style="text-align: right;">
                        <div class="d-flex justify-end gap-1">
                            @if (@context.AuthLevelId == 99)
                            {
                                <EntryReversedComponent DocTypeID="DocInfo.DocumentTypeID" DocumentID="context.ID" MID="context.MID" DocumentNumber="@context.DocumentNumber"></EntryReversedComponent>
                            }
                            else if (@context.AuthLevelId != 100)
                            {
                                <MudTooltip Text="Verify Transmission">
                                    <MudIconButton OnClick="@(()=> OpenForm(context,true))" Color="Color.Warning" Icon="@Icons.Material.Filled.Verified" Size="Size.Small" Variant="Variant.Text" />
                                </MudTooltip>
                            }

                            <MudTooltip Text="Inspect Details">
                                <MudIconButton OnClick="@(()=> OpenForm(context,true))" Color="Color.Info" Icon="@Icons.Material.Filled.Visibility" Size="Size.Small" Variant="Variant.Text" />
                            </MudTooltip>

                            @if (context.AuthLevelId == null)
                            {
                                <MudTooltip Text="Edit Parameters">
                                    <MudIconButton OnClick="@(()=> OpenForm(context,false))" Color="Color.Primary" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Variant="Variant.Text" />
                                </MudTooltip>
                                <MudTooltip Text="Purge Record">
                                    <MudIconButton OnClick="@(()=> Delete(context.ID))" Color="Color.Error" Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Variant="Variant.Text" />
                                </MudTooltip>
                            }
                        </div>
                    </MudTd>
                </RowTemplate>
                <PagerContent>
                    <div class="pa-4">
                        <MudTablePager PageSizeOptions="new int[] { 10, 20, 50 }" />
                    </div>
                </PagerContent>
            </MudTable>
        </div>
    </div>
}
}

@code {

    private bool _isLoading = true;
    private DateTime _loadStartTime;

    protected override List<CreditDebitTransferModel> collection { get; set; } = new List<CreditDebitTransferModel>();
    protected override DocumentInfoModel DocInfo { get; set; } = new DocumentInfoModel()
        {
            DocumentTypeID = 140,
            DocumentName = "CreditTransfer"
        };

    // Lifecycle method called when the component is initialized
    protected override async Task OnInitializedAsync()
    {
        _loadStartTime = DateTime.Now;
        await base.OnInitializedAsync();
        LoadData(ShowApproved, NumberOfRecords);

        if (id != null && collection != null && collection.Any(g => g.ID == id))
        {
            await OpenForm(collection.FirstOrDefault(s => s.ID == id), true);
        }
        await EnsureMinimumLoadTime();
        _isLoading = false;
    }

    private async Task EnsureMinimumLoadTime()
    {
        var elapsed = (DateTime.Now - _loadStartTime).TotalMilliseconds;
        if (elapsed < 100)
        {
            await Task.Delay(100 - (int)elapsed);
        }
    }

    // Method to open the dialog for adding or editing a credit/debit transfer
    protected override async Task OpenForm(CreditDebitTransferModel rModel, bool ReadOnly, bool DisableAddition = false)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        _busy = true;
        DialogParameters parms = new DialogParameters();
        parms.Add("model", rModel.Clone());
        parms.Add("ReadOnly", ReadOnly);
        parms.Add("OnApproved", new EventCallbackFactory().Create(this, () => LoadData(ShowApproved, NumberOfRecords)));
        var dialog = await dialogService.ShowAsync<CreditDebitTransferDialog>(rModel.ID == null ? "ADD" : "EDIT", parms, new DialogOptions() { MaxWidth = MaxWidth.Large, FullWidth = true });
        var result = await dialog.Result;
        if (!result.Canceled)
        {
            var ReturnData = (CreditDebitTransferModel)result.Data;
        }
        LoadData(ShowApproved, NumberOfRecords);
        await Task.Delay(200);
        _busy = false;
    }
}
