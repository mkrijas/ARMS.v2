@inherits DialogFormComponentBase<CreditTransferModel>
@inject ICreditTransferService Iservice
@inject IChartOfAccountService coaService


<DialogForm @ref="@dialogForm" ReadOnly="@ReadOnly" Title="Credit Transfer" formID="ctForm" DocumentDetails="DocInfo" model="@model" _busy="_busy">
    <FormContent>
        <MudPaper Class="p-3">
            <EditForm id="ctForm" OnValidSubmit="OnValidSubmit" EditContext="editContext">
                <ObjectGraphDataAnnotationsValidator />
                <ValidationSummary />
                <MudGrid>
                    <MudItem xs="12" md="6">
                        <MudSelect Label="Nature Of Transfer" ReadOnly="ReadOnly" @bind-Value="model.TransactionMode" T="Int32?" Variant="Variant.Outlined" Margin="Margin.Dense" AdornmentColor="Color.Secondary">

                            <MudSelectItem Value="@((int?)-1)"> Credit </MudSelectItem>
                            <MudSelectItem Value="@((int?)1)"> Debit </MudSelectItem>
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudDatePicker ReadOnly="ReadOnly" Label="DocumentDate" Variant="Variant.Outlined" Margin="Margin.Dense" DisableToolbar="true" Editable="true" @bind-Date="model.DocumentDate" DateFormat="dd/MM/yyyy" />
                    </MudItem>
                    <MudItem xs="6">
                      <b>  From</b>
                    </MudItem>
                    <MudItem xs="6">
                        <b> To</b>
                    </MudItem>
                    <MudItem xs="6">
                        <MudTextField ReadOnly T="string" Text="@BranchName" Variant="Variant.Outlined" Margin="Margin.Dense"    ></MudTextField>                      
                    </MudItem>
                    <MudItem xs="6">
                        <BranchSelector Value="@OtherBranch" ValueChanged="BranchChanged" LabelName="Target Branch receipt collected for"></BranchSelector>
                    </MudItem>
                    <MudItem xs="6">
                        <PartySelector Value="model.OriginParty" ValueChanged="OriginPartyChanged" BranchID="BranchID" For="(() => model.OriginParty)" />
                    </MudItem>
                    <MudItem xs="6">
                        <PartySelector Value="model.TargetParty" ValueChanged="TargetPartyChanged" BranchID="OtherBranch?.BranchID" For="(() => model.TargetParty)" />
                    </MudItem>
                    <MudItem xs="6">
                        @model.OriginPartyType
                    </MudItem>
                    <MudItem xs="6">
                        @model.TargetPartyType
                    </MudItem>
                    <MudItem xs="6">
                        <MudSelect Label="Nature Of Account" ReadOnly="ReadOnly" Value="model.OriginSubArdCode" ValueChanged="OriginSubArdChanged" T="string" Variant="Variant.Outlined" Margin="Margin.Dense" AdornmentColor="Color.Secondary">
                            @foreach (var item in subards.Where(x => model.OriginParty is not null && x.ArdGroup == model.OriginParty.NatureOfBusiness))
                            {
                                <MudSelectItem Value="@item.SubArdCode">@item.TranType</MudSelectItem>
                            }

                        </MudSelect>
                    </MudItem>
                    <MudItem xs="6">
                        <MudSelect Label="Nature Of Account" ReadOnly="ReadOnly" Value="model.TargetSubArdCode" ValueChanged="TargetSubArdChanged" T="string" Variant="Variant.Outlined" Margin="Margin.Dense" AdornmentColor="Color.Secondary">

                            @foreach (var item in subards.Where(x => model.TargetParty is not null && x.ArdGroup == model.TargetParty.NatureOfBusiness))
                            {
                                <MudSelectItem Value="@item.SubArdCode">@item.TranType</MudSelectItem>
                            }

                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12">
                        <MudTextField ReadOnly="ReadOnly" @bind-Value="model.Narration" Lines="2" Label="Narration" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.Narration)"></MudTextField>
                    </MudItem>
                </MudGrid>
            </EditForm>
        </MudPaper>
    </FormContent>
    <VerificationStatus>
        <AutherizationStatusComponent DocTypeID="DocInfo.DocumentTypeID" DocDate="@DocDate" DocumentID="model.ID" OnApprove="Approve"></AutherizationStatusComponent>
    </VerificationStatus>
</DialogForm>

@code {


    [Parameter]
    public override CreditTransferModel model { get { return _model; } set { _model = value; DocInfo.DocumentID = value.ID; } }
    private CreditTransferModel _model;
    // string[] natureOfBusinessGroup = new string[] { };
