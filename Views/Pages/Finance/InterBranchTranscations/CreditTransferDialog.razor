@inherits DialogFormComponentBase<CreditTransferModel>
@inject ICreditTransferService Iservice


<DialogForm @ref="@dialogForm" ReadOnly="@ReadOnly" Title="Receipt" formID="receiptForm" DocumentDetails="DocInfo" model="@model" _busy="_busy">
    <FormContent>
        <MudPaper Class="p-3">
            <EditForm id="receiptForm" OnValidSubmit="OnValidSubmit" EditContext="editContext">
                <ObjectGraphDataAnnotationsValidator />
                <ValidationSummary />
                <MudGrid>
                    <MudItem xs="12" md="2">
                        <MudSelect Label="Nature Of Transfer" ReadOnly="ReadOnly" @bind-Value="model.TransactionMode" T="Int32?" Variant="Variant.Outlined" Margin="Margin.Dense" AdornmentColor="Color.Secondary">
                            
                                <MudSelectItem Value="@(-1)"> Credit </MudSelectItem>
                                <MudSelectItem Value="@(1)"> Debit </MudSelectItem>
                            
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12" md="4">
                        <MudDatePicker ReadOnly="ReadOnly" Label="DocumentDate" Variant="Variant.Outlined" Margin="Margin.Dense" DisableToolbar="true" Editable="true" @bind-Date="model.DocumentDate" DateFormat="dd/MM/yyyy" />
                    </MudItem>

                    <MudItem xs="6">
                        <MudGrid>
                            <MudItem>
                                <BranchSelector Value="@OtherBranch" ValueChanged="BranchChanged" LabelName="Target Branch receipt collected for"></BranchSelector>
                            </MudItem>
                            <MudItem>
                                <PartySelector Value="model.OriginParty" ValueChanged="OriginPartyChanged" BranchID="BranchID" For="(() => model.OriginParty)" />
                            </MudItem>
                            <MudItem>
                               @model.OriginPartyType
                            </MudItem>
                            <MudItem>
                                <MudSelect Label="Nature Of Account" ReadOnly="ReadOnly" Value="model.OriginSubArdCode" ValueChanged="nTransactionChanged" T="string" Variant="Variant.Outlined" Margin="Margin.Dense" AdornmentColor="Color.Secondary">
                                    @if (model.OriginParty is not null)
                                    {
                                        foreach (var item in natureOfBusinessGroup)
                                        {
                                            <MudSelectItem Value="@(item)" />
                                        }
                                    }
                                </MudSelect>
                            </MudItem>
                        </MudGrid>
                    </MudItem>
                    <MudItem xs="12" md="12">
                        <MudTextField ReadOnly="ReadOnly" @bind-Value="model.Narration" Lines="2" Label="Narration" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.Narration)"></MudTextField>
                    </MudItem>
                </MudGrid>
            </EditForm>
        </MudPaper>
    </FormContent>
    <VerificationStatus>
        <AutherizationStatusComponent DocTypeID="DocInfo.DocumentTypeID" DocDate="@DocDate" DocumentID="model.ID" OnApprove="Approve"></AutherizationStatusComponent>
    </VerificationStatus>
</DialogForm>

@code {


    [Parameter]
    public override CreditTransferModel model { get { return _model; } set { _model = value; DocInfo.DocumentID = value.ReceiptID; } }
    private CreditTransferModel _model;



    string[] natureOfBusinessGroup = new string[] { };
    string[] RentGroup = { "Rent", "Deposit", "Other" };
    string[] SupplierGroup = { "Deposit", "Payable", "Prepayment" };
    string[] CustomerGroup = { "Deposit", "Receivable", "Prepayment" };
    string[] SisterGroup = { "Deposit", "Trade", "Prepayment" };

    protected override DocumentInfoModel DocInfo { get; set; } = new DocumentInfoModel()
        {
            DocumentTypeID = 140,
            DocumentName = "CreditTransfer"
        };
    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();
        if (model.ID is null)      
        {
            model.BranchID = BranchID;            
        }
        //SetNTransaction(model.BusinessNature);
    }

    protected override async Task<int> Update(CreditTransferModel editModel)
    {
        model = Iservice.Update(model);
        return model.ID.Value;
    }

    protected override int UpdateApproval(DataApprovedStatus aprvd)
    {
        int result = Iservice.Approve(model.ID, model.UserInfo.UserID, aprvd.Remarks);
        return result;
    }

    void BranchChanged(BranchModel br)
    {
        OtherBranch = br;
        model.OtherBranchID = br?.BranchID;
    }

    void SetOriginNTransaction(string nBusiness)
    {        
        if (nBusiness == "Renter")
        {
            natureOfBusinessGroup = RentGroup;
        }
        else if (nBusiness == "Customer")
        {
            natureOfBusinessGroup = CustomerGroup;
        }
        else if (nBusiness == "Supplier")
        {
            natureOfBusinessGroup = SupplierGroup;
        }
        else if (nBusiness == "SisterConcern")
        {
            natureOfBusinessGroup = SisterGroup;
        }
        else
        {
            natureOfBusinessGroup = new string[] { };
        }
    }    

    async Task OriginPartyChanged(PartyModel party)
    {
        model.OriginParty = party;
        model.OriginPartyType = party?.NatureOfBusiness;
        SetOriginNTransaction(model.OriginPartyType);
        await nTransactionChanged(null);
    }

    private async Task nTransactionChanged(string nt)
    {
        model.NatureOfTransaction = nt;
        if (model.NatureOfTransaction is not null)
        {
            model.OriginCoaID = partyService.GetPartyCoaID(model.OriginParty.PartyID, model.OriginPartyType, model.NatureOfTransaction);
            if (model.OriginCoaID == null)
            {
                bool? result = await dialogService.ShowMessageBox(
                    "Account Not Mapped!",
                    "Party Account is not mapped for " + model.NatureOfTransaction + "!");
                model.NatureOfTransaction = null;
            }
        }      
    }

   
}