    private async Task TargetSubArdChanged(string subard)
    {
        var trantype = subards.First(x => x.SubArdCode == subard).TranType;
        // if (model.NatureOfTransaction is not null)
        // {
            model.TargetCoaID = partyService.GetPartyCoaID(model.TargetParty.PartyID, model.TargetPartyType, trantype);
            if (model.TargetCoaID == null)
            {
                bool? result = await dialogService.ShowMessageBox(
                    "Account Not Mapped!",
                    "Party Account is not mapped for " + trantype + "!");
                model.NatureOfTransaction = null;
            }
            else
                model.TargetSubArdCode = subard;
        // }
    }


    private async Task OriginSubArdChanged(string subard)
    {
        var trantype = subards.First(x => x.SubArdCode == subard).TranType;
        // if (model.NatureOfTransaction is not null)
        // {
            model.OriginCoaID = partyService.GetPartyCoaID(model.OriginParty.PartyID, model.OriginPartyType, trantype);
