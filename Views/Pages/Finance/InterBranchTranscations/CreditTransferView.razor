@page "/CreditTransfer"
@page "/CreditTransfer/{id:int}"
@inherits ViewComponentBase<CreditTransferModel>
@* @inject ICreditTransferService Iservice *@

<MudGrid Spacing="4">
    <MudItem xs="12">
        <MudTable Items="@collection" Dense="true" Hover="true" Striped="true" Elevation="10">
            <ToolBarContent>
                <MudText Typo="Typo.h6">Credit Transfer</MudText>
                <MudTooltip Text="Add New">
                    <MudIconButton Disabled="@_busy" Icon="@Icons.Material.Filled.Add" Title="Add" @onclick="@(()=> OpenForm(new CreditTransferModel(),false))" Color="Color.Dark" Size="Size.Small"></MudIconButton>
                </MudTooltip>
                <MudSpacer></MudSpacer>
                <MudTextField @bind-Value="searchTerm" Placeholder="Search ..." Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0" @onkeyup="HandleSearchKeyUp">
                </MudTextField>
                <div class="tablefont">
                    <span style="margin-right: 10px;">Maximum Records: </span>
                </div>
                <MudItem xs="1">
                    <MudTextField @bind-Value="@NumberOfRecords" Variant="Variant.Outlined" Margin="Margin.Dense" Class="padding5" Style="width: 80px;"></MudTextField>
                </MudItem>
                <MudCheckBox Label="Approved Entries" ValueChanged="((bool value)=>ToggleData(value))" Value="@ShowApproved" Size="Size.Medium" Color="Color.Primary" Class="tablefont margin0"></MudCheckBox>
            </ToolBarContent>
            <HeaderContent>
                <MudTh><MudTableSortLabel SortBy="new Func<CreditTransferModel, object>(x=> x.DocumentDate)">Document Date</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<CreditTransferModel, object>(x=> x.ID)" InitialDirection="SortDirection.Descending">Document Number</MudTableSortLabel></MudTh>
                @* <MudTh><MudTableSortLabel SortBy="new Func<CreditTransferModel, object>(x=> x.TransactionMode)">Transfer Type</MudTableSortLabel></MudTh> *@
                <MudTh><MudTableSortLabel SortBy="new Func<CreditTransferModel, object>(x=> x.TransactionMode)">Transfer Type</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<CreditTransferModel, object>(x=> x.OriginParty.TradeName)">From</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<CreditTransferModel, object>(x=> x.TargetParty.TradeName)">To</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<CreditTransferModel, object>(x=> x.TotalAmount)">Total Amount</MudTableSortLabel></MudTh>
                <MudTh>Actions</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="DocumentDate">@context.DocumentDate</MudTd>
                <MudTd DataLabel="DocumentNumber">
                    @context.DocumentNumber
                    @if (context.AuthLevelId == 100)
                    {
                        <MudText Color="Color.Error" GutterBottom> Rejected </MudText>
                    }
                </MudTd>
                <MudTd DataLabel="mode">@context.TransactionMode </MudTd>
                <MudTd DataLabel="Party">@context.OriginParty.TradeName </MudTd>
                <MudTd DataLabel="Party">@context.TargetParty.TradeName </MudTd>
                <MudTd DataLabel="TotalAmount">@context.TotalAmount</MudTd>
                <MudTd DataLabel="">
                    <MudIconButton OnClick="@(()=> OpenForm(context,true))" Color="Color.Primary" Icon="@Icons.Material.Filled.GridView" Title="View" Class="ml-2" Size="Size.Small" Variant="Variant.Filled" />
                    <MudIconButton Disabled="@(context.AuthLevelId != null)" OnClick="@(()=> OpenForm(context,false))" Color="Color.Primary" Title="Edit" Class="ml-2" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Variant="Variant.Filled" />
                    <MudIconButton Disabled="@(context.AuthLevelId != null)" OnClick="@(()=> Delete(context.ID))" Color="Color.Error" Title="Delete" Class="ml-2" Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Variant="Variant.Filled" />

                    @if (@context.AuthLevelId == 99)
                    {
                        <EntryReversedComponent DocTypeID="DocInfo.DocumentTypeID" DocumentID="context.ID" MID="context.MID" DocumentNumber="context.DocumentNumber"></EntryReversedComponent>
                    }
                    else if (@context.AuthLevelId != 100)
                    {
                        <MudIconButton OnClick="@(()=> OpenForm(context,true))" Color="Color.Warning" Class="ml-2" Icon="@Icons.Material.Filled.Verified" Title="Verify" Size="Size.Small" Variant="Variant.Filled" />
                    }
                </MudTd>
            </RowTemplate>
            <PagerContent>
                <MudTablePager PageSizeOptions="new int[] { 10, 20, 50, 100 }" />
                <MudItem xs="12" md="9"> </MudItem><MudItem xs="12" md="3">
                </MudItem>
            </PagerContent>
        </MudTable>
    </MudItem>
</MudGrid>

@code {

    protected override List<CreditTransferModel> collection { get; set; } = new List<CreditTransferModel>();
    protected override DocumentInfoModel DocInfo { get; set; } = new DocumentInfoModel()
        {
            DocumentTypeID = 140,
            DocumentName = "CreditTransfer"
        };

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();
        LoadData(ShowApproved, NumberOfRecords);

        if (id != null && collection != null && collection.Any(g => g.ID == id))
        {
            await OpenForm(collection.FirstOrDefault(s => s.ID == id), true);
        }
    }

    protected override async Task OpenForm(CreditTransferModel rModel, bool ReadOnly, bool DisableAddition = false)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        _busy = true;
        DialogParameters parms = new DialogParameters();
        parms.Add("model", rModel.Clone());
        parms.Add("ReadOnly", ReadOnly);
        parms.Add("OnApproved", new EventCallbackFactory().Create(this, () => LoadData(ShowApproved, NumberOfRecords)));
        var dialog = dialogService.Show<CreditTransferDialog>(rModel.ID == null ? "ADD" : "EDIT", parms, new DialogOptions() { MaxWidth = MaxWidth.Large, FullWidth = true });
        var result = await dialog.Result;
        if (!result.Canceled)
        {
            var ReturnData = (CreditTransferModel)result.Data;
        }
        LoadData(ShowApproved, NumberOfRecords);
        await Task.Delay(200);
        _busy = false;
    }
}