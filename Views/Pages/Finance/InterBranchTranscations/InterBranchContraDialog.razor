@using ArmsModels.BaseModels.Finance.Transactions
@using System.Threading;
@attribute [Authorize]
@inject AuthenticationStateProvider auth
@inherits DialogFormComponentBase<ContraModel>
@inject TruckDataArrayModel data
@inject NavigationManager uriHelper;
@inject IContraService Iservice
@inject IOutstandingBillsService OBIservice
@inject ICostCenterService costIservice
@inject IChartOfAccountService accountService
@inject IDimensionService dimensionIservice
@inject IBranchService branchService
@inject IInterBranchMappingService intermappingIservice
@inject MudBlazor.ISnackbar snackbar
@inject IRoleService<RoleModel> Irole
@inject IDialogService DialogService


<DialogForm @ref="@dialogForm" ReadOnly="@ReadOnly" Title="Contra Entry" formID="IContraForm" model="@model" _busy="_busy">
    <FormContent>
        <MudPaper Class="p-3">
            <EditForm id="IContraForm" OnValidSubmit="OnValidSubmit" Model="@model">
                <DataAnnotationsValidator />
                <ValidationSummary />
                <MudGrid Spacing="4">
                    <MudItem xs="12" md="6">
                        <MudDatePicker Label="Document Date" ReadOnly="ReadOnly" Variant="Variant.Outlined" Margin="Margin.Dense" DisableToolbar="true" Editable="true" @bind-Date="model.DocumentDate" DateFormat="dd/MM/yyyy" MaxDate="DateTime.Now" />
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudTextField ReadOnly="ReadOnly" @bind-Value="model.EntryReference" Label="Reference" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.EntryReference)"></MudTextField>
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudCard>
                            <MudCardContent>
                                <MudItem xs="12" md="12">
                                    <MudTextField ReadOnly="true" @bind-Value="hmbarnchName" Label="Home Branch" Variant="Variant.Outlined" Margin="Margin.Dense"></MudTextField>
                                </MudItem>
                                <br />
                                <MudItem xs="12" md="12">
                                    <MudSelect ReadOnly="ReadOnly" Label="Select Mode" Value="@model.IsPayment" ValueChanged="PaymentModeChanged" T="bool" Variant="Variant.Outlined" Margin="Margin.Dense" AnchorOrigin="Origin.BottomCenter" AdornmentColor="Color.Secondary">
                                        <MudSelectItem Value="@(false)"> Payment </MudSelectItem>
                                        <MudSelectItem Value="@(true)"> Receipt </MudSelectItem>
                                    </MudSelect>
                                </MudItem>
                                <br />
                                <MudItem xs="12" md="12">
                                    <MudSelect ReadOnly="ReadOnly" Label="Bank/Cash" Value="@model.ContraModeHome" ValueChanged="BankModeChanged" T="string" Variant="Variant.Outlined" Margin="Margin.Dense" AnchorOrigin="Origin.BottomCenter" AdornmentColor="Color.Secondary">
                                        <MudSelectItem Value="@("Bank")" />
                                        <MudSelectItem Value="@("Cash")" />
                                        <MudSelectItem Value="@("Wallet")" />
                                    </MudSelect>
                                </MudItem>
                                <br />
                                <MudItem xs="12" md="12">
                                    <MudAutocomplete ReadOnly="ReadOnly" T="PaymentCodeModel" Variant="Variant.Outlined" Margin="Margin.Dense" AnchorOrigin="Origin.BottomCenter" Label="Select Account" Value="accountRuleDefinitionH" ValueChanged="SetAccountRuleDefinitionH" ResetValueOnEmptyText="true"
                                                     Clearable="true" SearchFunc="@(async (string s, CancellationToken t) => await SearchAccountsH(s, t))" ToStringFunc="@(e => (e == null || string.IsNullOrEmpty(e.Title)) ? null : string.Format("{0} | {1}",e.ArdCode,e.Title))"></MudAutocomplete>
                                </MudItem>
                                <br />
                            </MudCardContent>
                        </MudCard>
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudCard>
                            <MudCardContent>
                                <MudItem xs="12" md="12">
                                    <MudSelect ReadOnly="ReadOnly" Label="Select Other Branch" Value="model.OtherBranchID" ValueChanged="OtherBranchChanges" T="int?" Variant="Variant.Outlined" AnchorOrigin="Origin.BottomCenter" Margin="Margin.Dense" AdornmentColor="Color.Secondary">
                                        @foreach (var ditem in branches)
                                        {
                                            <MudSelectItem Value="@ditem.BranchID">@ditem.BranchName</MudSelectItem>
                                        }
                                    </MudSelect>
                                </MudItem>
                                <br />
                                <MudItem xs="12" md="12">
                                    <MudSelect ReadOnly="true" Label="Mode" @bind-Value="@model.IsPayment" T="bool" Variant="Variant.Outlined" Margin="Margin.Dense" AnchorOrigin="Origin.BottomCenter" AdornmentColor="Color.Secondary">
                                        <MudSelectItem Value="@(true)">Payment</MudSelectItem>
                                        <MudSelectItem Value="@(false)">Receipt</MudSelectItem>
                                    </MudSelect>
                                </MudItem>
                                <br />
                                <MudItem xs="12" md="12">
                                    <MudSelect ReadOnly="ReadOnly" Label="Bank/Cash" Value="model.ContraModeOther" ValueChanged="ModeChangeOther" T="string" Variant="Variant.Outlined" Margin="Margin.Dense" AnchorOrigin="Origin.BottomCenter" AdornmentColor="Color.Secondary">
                                        <MudSelectItem Value="@("Bank")" />
                                        <MudSelectItem Value="@("Cash")" />
                                        <MudSelectItem Value="@("Wallet")" />
                                    </MudSelect>
                                </MudItem>
                                <br />
                                <MudItem xs="12" md="12">
                                    <MudAutocomplete ReadOnly="ReadOnly" T="PaymentCodeModel" Variant="Variant.Outlined" Margin="Margin.Dense" Label="Select Account" Value="accountRuleDefinitionO" ValueChanged="SetAccountRuleDefinitionO" ResetValueOnEmptyText="true"
                                                     Clearable="true" SearchFunc="@(async (string s, CancellationToken t) => await SearchAccountsO(s, t))" ToStringFunc="@(e => (e == null || string.IsNullOrEmpty(e.Title)) ? null : string.Format("{0} | {1}",e.ArdCode,e.Title))"></MudAutocomplete>
                                </MudItem>
                                <br />
                            </MudCardContent>
                        </MudCard>
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudTextField ReadOnly="ReadOnly" @bind-Value="model.TotalAmount" Label="Amount" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.TotalAmount)"></MudTextField>
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudSelect ReadOnly="ReadOnly" Label="Select Tool of Payment" T="string" @bind-Value="model.PaymentTool" Variant="Variant.Outlined" Margin="Margin.Dense" AnchorOrigin="Origin.BottomCenter" AdornmentColor="Color.Secondary">
                            @foreach (var item in data.BankTools)
                            {
                                <MudSelectItem Value="@item">@item</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                    @if (model.PaymentTool == "CHEQUE")
                    {
                        <MudItem xs="12" md="12">
                            <MudGrid>
                                <MudItem xs="12" md="6">
                                    <MudTextField ReadOnly="ReadOnly" @bind-Value="model.ChequeInfo.ChequeNumber" Label="Cheque Number" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.ChequeInfo.ChequeNumber)"></MudTextField>
                                </MudItem>
                                <MudItem xs="12" md="6">
                                    <MudDatePicker ReadOnly="ReadOnly" Label="Cheque Date" Variant="Variant.Outlined" Margin="Margin.Dense" DisableToolbar="true" Editable="true" @bind-Date="model.ChequeInfo.ChequeDate" DateFormat="dd/MM/yyyy" />
                                </MudItem>
                            </MudGrid>
                        </MudItem>
                    }
                    <MudItem xs="12" md="12"></MudItem>
                    <MudItem xs="12" md="4">
                        <MudSelect Label="Transaction Type" ReadOnly="ReadOnly" @bind-Value="model.InterBranchTranID" T="int?" Variant="Variant.Outlined" Margin="Margin.Dense" AnchorOrigin="Origin.BottomCenter" AdornmentColor="Color.Secondary" For="@(()=> model.InterBranchTranID)">
                            @foreach (var ditem in transactionTypeList)
                            {
                                <MudSelectItem Value="@ditem.ID">@ditem.TransactionTypeName</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12" md="4">
                        <MudSelect ReadOnly="ReadOnly" Label="Select CostCenter" @bind-Value="model.CostCenter" T="int?" Variant="Variant.Outlined" Margin="Margin.Dense" AnchorOrigin="Origin.BottomCenter" AdornmentColor="Color.Secondary">
                            @foreach (var ditem in costCenter)
                            {
                                <MudSelectItem Value="@ditem.CostCenterID">@ditem.CostCenter</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12" md="4">
                        <MudSelect ReadOnly="ReadOnly" Label="Select Dimension" @bind-Value="model.Dimension" T="int?" Variant="Variant.Outlined" Margin="Margin.Dense" AnchorOrigin="Origin.BottomCenter" AdornmentColor="Color.Secondary">
                            @foreach (var ditem in dimension)
                            {
                                <MudSelectItem Value="@ditem.DimensionID">@ditem.Dimension</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12" md="12">
                        <MudTextField ReadOnly="ReadOnly" @bind-Value="model.Narration" Lines="2" Label="Narration" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.Narration)"></MudTextField>
                    </MudItem>
                </MudGrid>
            </EditForm>
        </MudPaper>
    </FormContent>
    <VerificationStatus>
        <AutherizationStatusComponent CreatedBy="@model.UserInfo" DocTypeID="@DocInfo.DocumentTypeID" DocDate="@DocDate" DocType="@DocType" DocNumber="@DocNumber" PageToRedirectLink="@PageToRedirectLink" DocumentID="model.ContraID" OnApprove="Approve"></AutherizationStatusComponent>
    </VerificationStatus>
</DialogForm>


@code {

    [Parameter]
    public string PageToRedirectLink { get; set; }
    public string DocNumber { get; set; }
    public DateTime? DocDate { get; set; }
    public string DocType { get; set; }
    private List<InterBranchTransactionTypeModel> transactionTypeList = new();
    private List<CostCenterModel> costCenter = new();
    private List<DimensionModel> dimension = new();
    private List<BranchModel> branches = new();
    private PaymentCodeModel accountRuleDefinitionH = new();
    private PaymentCodeModel accountRuleDefinitionO = new();
    List<PaymentCodeModel> PcodesHome = new();
    List<PaymentCodeModel> PcodesOther = new();

    private bool _busy;

    //public bool bnktl = true;
    public string value = "invisible";
    private string hmbarnchName;
    private int? BranchID = null;
    private string UserID = null;
    string UserIDTemp;

    [CascadingParameter] IMudDialogInstance MudDialog { get; set; }

    bool HasPermissionContraServiceEdit { get; set; } = false;
    bool HasPermissionContraServiceApprove { get; set; } = false;

    protected override DocumentInfoModel DocInfo { get; set; } = new DocumentInfoModel()
    {
        DocumentTypeID = 3,
        DocumentName = "Contra"
    };

    // Lifecycle method called when the component is initialized
    protected override async Task OnInitializedAsync()
    {
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionContraServiceEdit = await Irole.HasClaim(DocInfo.DocumentTypeID.ToString(), "Edit", ctc.Token);
        HasPermissionContraServiceApprove = await Irole.HasClaim(DocInfo.DocumentTypeID.ToString(), "Approve", ctc.Token);

        var authprov = await auth.GetAuthenticationStateAsync();
        BranchID = int.Parse(authprov.User.Claims.First(x => x.Type == "BranchID").Value);
        var user = authprov.User;
        UserID = user.Identity.Name;
        var brancIDString = authprov.User.Claims.First(x => x.Type == "BranchName").Value;
        hmbarnchName = brancIDString.ToString();

        await base.OnInitializedAsync();

        transactionTypeList = intermappingIservice.GetTypes().ToList(); // Fetch transaction types
        if (model.ContraID == null)
        {
            model.TotalAmount = 0;
            model.IsInterBranch = true;
            model.UserInfo.UserID = UserID;
        }
        else
        {
            UserIDTemp = model.UserInfo.UserID;
            accountRuleDefinitionH.CoaID = model.CoaIDHome;
            accountRuleDefinitionH.ArdCode = model.ArdCodeHome;
            accountRuleDefinitionO.CoaID = model.CoaIDOther;
            accountRuleDefinitionO.ArdCode = model.ArdCodeOther;

            // Fetch payment codes for home branch if the model is not null
            if (model != null && model.CoaIDHome != null)
            {
                accountRuleDefinitionH = accountService.GetPaymentCodes(model.BranchID, model.ContraModeHome).FirstOrDefault(s => s.ArdCode == model.ArdCodeHome); // Get payment code for home branch
            }

            // Fetch payment codes for other branch if the model is not null
            if (model != null && model.CoaIDOther != null)
            {
                accountRuleDefinitionO = accountService.GetPaymentCodes(model.OtherBranchID, model.ContraModeOther).FirstOrDefault(s => s.ArdCode == model.ArdCodeOther); // Get payment code for other branch
            }
        }
        model.BranchID = BranchID;
        model.NatureOfTransaction = "Contra";
        costCenter = costIservice.Select().ToList();// Fetch cost centers
        dimension = dimensionIservice.Select().ToList(); // Fetch dimensions
        branches = branchService.Select().ToList(); // Fetch branches

        DocNumber = model.DocumentNumber;
        DocDate = model.DocumentDate;
        DocType = model.NatureOfTransaction;
    }

    // Lifecycle method called when parameters are set or changed
    protected override void OnParametersSet()
    {
        DocInfo.DocumentTypeID = DocInfo.DocumentTypeID;
        DocInfo.DocumentID = model.ContraID;
    }

    // Method to approve a contra request
    protected override int UpdateApproval(DataApprovedStatus aprvd)
    {
        int result = Iservice.Approve(model.ContraID, model.UserInfo.UserID, aprvd.Remarks); // Approve the request
        model.UserInfo.UserID = UserIDTemp;
        return result;
    }

    // Method to search for payment codes for home branch
    private async Task<IEnumerable<PaymentCodeModel>> SearchAccountsH(string searchString, CancellationToken token)
    {
        await Task.Delay(5, token);
        if (string.IsNullOrEmpty(searchString))
            return PcodesHome;
        return PcodesHome.Where(x => x.Title.Contains(searchString, StringComparison.InvariantCultureIgnoreCase) || x.ArdCode.Contains(searchString, StringComparison.InvariantCultureIgnoreCase));
    }

    // Method to search for payment codes for other branch
    private async Task<IEnumerable<PaymentCodeModel>> SearchAccountsO(string searchString, CancellationToken token)
    {
        await Task.Delay(5, token);
        if (model.OtherBranchID != null)
        {
            if (string.IsNullOrEmpty(searchString))
                return PcodesOther;
            return PcodesOther.Where(x => x.Title.Contains(searchString, StringComparison.InvariantCultureIgnoreCase) || x.ArdCode.Contains(searchString, StringComparison.InvariantCultureIgnoreCase));
        }
        else
        {
            snackbar.Add("Please select other branch.", Severity.Error);
            return null;
        }
    }

    // Method to set the account rule definition for home branch
    private void SetAccountRuleDefinitionH(PaymentCodeModel obj)
    {
        accountRuleDefinitionH = obj;
        model.CoaIDHome = obj?.CoaID ?? null;
        model.ArdCodeHome = obj?.ArdCode ?? null;
    }

    // Method to set the account rule definition for other branch
    private void SetAccountRuleDefinitionO(PaymentCodeModel obj)
    {
        accountRuleDefinitionO = obj;
        model.CoaIDOther = obj?.CoaID ?? null;
        model.ArdCodeOther = obj?.ArdCode ?? null;
    }

    // Method to handle changes in the payment mode for home branch
    public void BankModeChanged(string val)
    {
        model.ContraModeHome = val;
        PcodesHome = accountService.GetPaymentCodes(BranchID, model.ContraModeHome).ToList(); // Fetch payment codes based on the selected mode

        if (model.IsPayment)
        {
            if (model.ContraModeHome == "Bank")
            {
                // bnktl = false;
            }
            else
            {
                value = "invisible";
                model.PaymentTool = null;
                //bnktl = true;
            }
        }
    }

    // Method to handle changes in the payment mode for other branch
    public void ModeChangeOther(string val)
    {
        model.ContraModeOther = val;
        PcodesOther = accountService.GetPaymentCodes(model.OtherBranchID, model.ContraModeOther).ToList(); // Fetch payment codes based on the selected mode
        if (!model.IsPayment)
        {
            if (model.ContraModeOther == "Bank")
            {
                // bnktl = false;
            }
            else
            {
                value = "invisible";
                model.PaymentTool = null;
                // bnktl = true;
            }
        }
    }

    // Method to handle changes in the other branch ID
    public void OtherBranchChanges(int? otherBranchID)
    {
        model.OtherBranchID = otherBranchID;
        model.ContraModeOther = null;
        accountRuleDefinitionO = null;

    }

    // Method to handle changes in the payment mode
    public void PaymentModeChanged(bool val)
    {
        model.IsPayment = val;
    }

    // Method to cancel the dialog
    public void Cancel()
    {
        MudDialog.Cancel();
    }

    // Method to submit the form
    protected override async Task<int> Update(ContraModel editModel)
    {
        if (validate(model) == true)
        {
            model.CoaIDHome = accountRuleDefinitionH.CoaID;
            model.ArdCodeHome = accountRuleDefinitionH.ArdCode;
            model.CoaIDOther = accountRuleDefinitionO.CoaID;
            model.ArdCodeOther = accountRuleDefinitionO.ArdCode;
            model.BranchID = BranchID;
            model.IsInterBranch = true;
            model.NatureOfTransaction = "Contra";
            model.UserInfo.UserID = UserID;
            model = Iservice.Update(model); // Update the model using the service
            return model.ContraID.Value;
        }
        return 0;
    }

    // Method to validate the contra model
    public bool validate(ContraModel editModel)
    {
        if (model.InterBranchTranID is null)
        {
            snackbar.Add("Transaction Type Not selected!", Severity.Error);
            return false;
        }
        return true;
    }
}
