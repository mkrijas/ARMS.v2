@page "/InterBranchContraView"
@using ArmsModels.BaseModels.Finance.Transactions
@inject IContraService Iservice
@inject ICostCenterService costIservice
@inject IDimensionService dimensionIservice
@inject NavigationManager uriHelper;
@inject MudBlazor.ISnackbar snackbar
@inject AuthenticationStateProvider auth
@attribute [Authorize]
@inject IDialogService DialogService

<MudGrid Spacing="4">
   <MudItem xs="12">
        <MudTable Items="@collection"   Dense="true" Hover="true"  Striped="true" Elevation="10"  @bind-place="model">
           

             <ToolBarContent>
                <MudText Typo="Typo.h6">Contra Entry</MudText>
                <MudTooltip Text="New Payment Memos">
                <MudIconButton  Icon="@Icons.Material.Filled.Add" Title="Add" @onclick="@(()=> OpenDialog(model))"  Color="Color.Dark" Size="Size.Small"></MudIconButton>
                </MudTooltip>
               
             <MudCheckBox Label="Approved Entries"  CheckedChanged="((bool value)=>ApprovedChanged(value))" Checked="@IsApproved" Size="Size.Medium" Color="Color.Primary"></MudCheckBox>

                <MudSpacer></MudSpacer>
             
            </ToolBarContent>
            <HeaderContent>
                <MudTh><MudTableSortLabel SortBy="new Func<ContraModel, object>(x=> x.DocumentDate)" InitialDirection="SortDirection.Ascending">DocumentDate</MudTableSortLabel></MudTh>
              <MudTh><MudTableSortLabel SortBy="new Func<ContraModel, object>(x=> x.DocumentNumber)" InitialDirection="SortDirection.Ascending">DocumentNumber</MudTableSortLabel></MudTh>
               <MudTh><MudTableSortLabel SortBy="new Func<ContraModel, object>(x=> x.ContraModeHome)" InitialDirection="SortDirection.Ascending">Payment</MudTableSortLabel></MudTh>
                
              <MudTh><MudTableSortLabel SortBy="new Func<ContraModel, object>(x=> x.TotalAmount)" InitialDirection="SortDirection.Ascending">Amount</MudTableSortLabel></MudTh>
              
               <MudTh>Actions</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="DocumentDate">@context.DocumentDate?.ToShortDateString()</MudTd>
                
               <MudTd DataLabel="DocumentNumber">@context.DocumentNumber</MudTd>
                  <MudTd DataLabel="ContraModeHome">@context.ContraModeHome</MudTd>
               <MudTd DataLabel="Amount">@context.TotalAmount</MudTd>
               <MudTd DataLabel="">
                     <MudTooltip Text="View">
                   <MudFab @onclick="@(()=> OpenDialogView(context))" Color="Color.Primary" Icon="@Icons.Material.Filled.GridView" Size="Size.Small" IconSize="Size.Small" />
                    </MudTooltip> 
                    @if(@context.AuthLevelId==null)
                    {
                    <MudTooltip Text="Edit">
                   <MudFab @onclick="@(()=> OpenDialog(context))" Color="Color.Primary" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" IconSize="Size.Small" />
                    </MudTooltip>
                      <MudFab @onclick="@(()=> Delete(context))" Color="Color.Error" title="Delete" Icon="@Icons.Material.Filled.Delete" Size="Size.Small" IconSize="Size.Small" />
                  
                   @*  <MudTooltip Text="Approve">
                   <MudFab @onclick="@(()=> Approve(context))" Color="Color.Success" Icon="@Icons.Material.Filled.Check" Size="Size.Small" IconSize="Size.Small" />
                    </MudTooltip>*@
                    }
                    @if (@context.AuthLevelId!= 99)
                    {
                    <MudFab @onclick="@(()=> OpenDialogVerify(context))" Color="Color.Warning" Icon="@Icons.Material.Filled.Verified" title="Verify" Size="Size.Small" IconSize="Size.Small" />
                        
                    }
               </MudTd>
            </RowTemplate>
          
            <PagerContent>
                <MudTablePager PageSizeOptions="new int[] { 5, 10, 20, 50, 100 }" />
               @*  <MudButton OnClick="selected" Variant="Variant.Filled" Color="Color.Success" ButtonType="ButtonType.Submit">Submit</MudButton>*@
           
            </PagerContent>
        </MudTable>
    </MudItem>
    </MudGrid>

@code {
    private ContraModel model = new ContraModel();
      public bool IsApproved { get; set; } = false;
    private List<ContraModel> collection = new List<ContraModel>();
    DialogOptions mediumWidth = new DialogOptions() { MaxWidth = MaxWidth.Medium, FullWidth = true };
    protected override async Task OnInitializedAsync()
    {
        model = new();
        await GetAll(IsApproved);
    }
      async Task ApprovedChanged(bool value)
    {

        IsApproved = value;
        await GetAll(IsApproved);

    }
    private  async Task GetAll(bool val)
    {
        var authprov = await auth.GetAuthenticationStateAsync();
        var brancIDString = authprov.User.Claims.First(x => x.Type == "BranchID").Value;
        int brancID = int.Parse(brancIDString);
        collection = new List<ContraModel>();
       
         if (val)
        {
            collection = Iservice.SelectInterBranch(brancID).Where(x => x.AuthLevelId == 99).ToList();
            
        }
        else
        {
             collection = Iservice.SelectInterBranch(brancID).Where(x => x.AuthLevelId != 99).ToList();
       
        }

    }
    private void Delete(ContraModel tx)
    {
        Iservice.Delete(tx.ContraID, "Rijas");
        snackbar.Add("Deleted Successfully", Severity.Success);
        GetAll(IsApproved);
    }
     private async Task Approve(ContraModel tds)
    {
        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;
        model.UserInfo.UserID = user.Identity.Name;
        Iservice.Approve(tds.ContraID, model.UserInfo.UserID,"");
         GetAll(IsApproved);
    }
   
    private async Task OpenDialog(ContraModel tds)
    {
        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;
        
        DialogParameters parms = new DialogParameters();
        parms.Add("model",tds);
         parms.Add("IsReadOnly",false);
        parms.Add("IsView",false);
        var dialog =  DialogService.Show<InterBranchContraDialog>(tds.ContraID == null?"ADD":"EDIT",parms,mediumWidth);
        var result = await dialog.Result;

        
       await GetAll(IsApproved);
    }
      private async Task OpenDialogView(ContraModel tds)
    {
        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;
        
        DialogParameters parms = new DialogParameters();
        parms.Add("model",tds);
        parms.Add("IsReadOnly",true);
        parms.Add("IsView",true);
        var dialog =  DialogService.Show<InterBranchContraDialog>(tds.ContraID == null?"ADD":"EDIT",parms,mediumWidth);
        var result = await dialog.Result;

       
        await GetAll(IsApproved);
    }
      private async Task OpenDialogVerify(ContraModel tds)
    {
        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;
        
        DialogParameters parms = new DialogParameters();
        parms.Add("model",tds);
         parms.Add("IsReadOnly",true);
        parms.Add("IsView",false);
        var dialog =  DialogService.Show<InterBranchContraDialog>(tds.ContraID == null?"ADD":"EDIT",parms,mediumWidth);
        var result = await dialog.Result;

        
       await GetAll(IsApproved);
    }
}
