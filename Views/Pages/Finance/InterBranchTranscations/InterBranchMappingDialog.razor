@inject IInterBranchMappingService Iservice
@inject IBranchService branchIservice
@inject IChartOfAccountService accountService
@inject MudBlazor.ISnackbar snackbar
@inject AuthenticationStateProvider auth
@attribute [Authorize]
@using System.Threading;
@inject IRoleService<RoleModel> Irole
@inject IDialogService DialogService

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.Build" Class="mr-3 mb-n1" />
            InterBranch Mapping - @model.InterBranchArdCode
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudContainer Style="max-height: 450px; overflow-y: scroll">
            <EditForm id="formtdsRate" Model="@model" OnValidSubmit="OnValidSubmit">
                <ObjectGraphDataAnnotationsValidator />
                <ValidationSummary />
                <MudGrid Spacing="2">
                    <MudItem xs="12" md="6">
                        <MudSelect Label="Select Transaction Type" ReadOnly="ReadOnly" @bind-Value="model.TransactionTypeID" T="int?" Variant="Variant.Outlined" Margin="Margin.Dense"   AdornmentColor="Color.Secondary">
                            @foreach (var ditem in transactionTypeList)
                            {
                                <MudSelectItem Value="@ditem.ID">@ditem.TransactionTypeName</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudSelect Label="Select Branch" ReadOnly="ReadOnly" @bind-Value="model.BranchID" T="int?" Variant="Variant.Outlined" Margin="Margin.Dense"   AdornmentColor="Color.Secondary">
                            @foreach (var ditem in branches)
                            {
                                <MudSelectItem Value="@ditem.BranchID">@ditem.BranchName</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12" md="12">
                        <CoaSelector Value="IntermappingCoaID" ValueChanged="OnIntermappingCoaChange" LabelName="Select Account" />
                    </MudItem>
                </MudGrid>
            </EditForm>
        </MudContainer>
    </DialogContent>
    <DialogActions>
        @if (!ReadOnly)
        {
            <MudButton Variant="Variant.Filled" Color="Color.Info" OnClick="Cancel">Cancel</MudButton>
            <MudButton Disabled="@_busy" form="formtdsRate" Variant="Variant.Filled" Color="Color.Success" ButtonType="ButtonType.Submit">Submit</MudButton>
        }
        @if (ReadOnly)
        {
            <MudButton Variant="Variant.Filled" Color="Color.Info" OnClick="Cancel">Close</MudButton>
        }
    </DialogActions>
</MudDialog>

@code {
    [Parameter]
    public InterBranchMappingModel model { get; set; }
    [Parameter]
    public bool ReadOnly { get; set; }
    [Parameter]
    public bool IsView { get; set; }
    private List<InterBranchTransactionTypeModel> transactionTypeList = new();
    private List<BranchModel> branches = new();
    [CascadingParameter] MudDialogInstance MudDialog { get; set; }
    public ChartOfAccountModel IntermappingCoaID = new();
    private bool _busy;

    public bool HasPermissionInterBranchMappingServiceEdit { get; set; } = false;
    public int InterBranchMappingDocTypeID = 86;

    protected override async Task OnInitializedAsync()
    {
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionInterBranchMappingServiceEdit = await Irole.HasClaim(InterBranchMappingDocTypeID.ToString(), "Edit", ctc.Token);

        transactionTypeList = Iservice.GetTypes().ToList();
        branches = branchIservice.Select().ToList();
        if (model.CoaID != null)
        {
            IntermappingCoaID = accountService.SelectByID(model.CoaID);
        }
    }

    private void Cancel()
    {
        MudDialog.Cancel();
    }

    private void OnIntermappingCoaChange(ChartOfAccountModel obj)
    {
        IntermappingCoaID = obj;
        model.CoaID = IntermappingCoaID?.CoaID ?? null;
    }

    private async Task OnValidSubmit(EditContext context)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is being submitted!", Severity.Warning);
            return;
        }
        if (HasPermissionInterBranchMappingServiceEdit)
        {
            var ExistingModel = Iservice.IsEntriesAlreadyExistOrNot(model);
            if (ExistingModel != null)
            {
                snackbar.Add("Mapping already exist. If required please modify it.", Severity.Error);
                return;
            }
            _busy = true;

            model.CoaID = IntermappingCoaID?.CoaID ?? null;
            var authprov = await auth.GetAuthenticationStateAsync();
            var user = authprov.User;
            model.UserInfo.UserID = user.Identity.Name;
            try
            {
                Iservice.Update(model);
                model = new();
                snackbar.Add("Saved Successfully", Severity.Success);
                model = new();
            }
            catch (Exception ex)
            {
                snackbar.Add(ex.Message, Severity.Warning);
            }
        }
        else
        {
            bool? result = await DialogService.ShowMessageBox(
                "Permission denied!",
                "You don't have any permission to Edit InterBranchMapping.");
        }
        MudDialog.Close();

        await Task.Delay(200);
        _busy = false;
    }
}