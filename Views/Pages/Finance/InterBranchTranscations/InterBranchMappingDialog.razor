@inject IInterBranchMappingService Iservice
@inject IBranchService branchIservice
@inject IChartOfAccountService accountService
@inject MudBlazor.ISnackbar snackbar
@inject AuthenticationStateProvider auth
@attribute [Authorize]
@inject IDialogService DialogService


<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.Build" Class="mr-3 mb-n1" />
            Inter Branch Mapping - @model.InterBranchArdCode
        </MudText>

    </TitleContent>
    <DialogContent>
        <MudContainer Style="max-height: 450px; overflow-y: scroll">
            <EditForm id="formtdsRate" Model="@model" OnValidSubmit="OnValidSubmit">
                <ObjectGraphDataAnnotationsValidator />
                <ValidationSummary />
                <MudGrid Spacing="2">







                    <MudItem xs="12" md="6">
                        <MudSelect Label="Select Transaction Type" ReadOnly="ReadOnly" @bind-Value="model.TransactionTypeID" T="int?" Variant="Variant.Outlined" Margin="Margin.Dense" OffsetY="true" Direction="Direction.Top" AdornmentColor="Color.Secondary">
                            @foreach (var ditem in transactionTypeList)
                            {
                                <MudSelectItem Value="@ditem.ID">@ditem.TransactionTypeName</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudSelect Label="Select Branch" ReadOnly="ReadOnly" @bind-Value="model.BranchID" T="int?" Variant="Variant.Outlined" Margin="Margin.Dense" OffsetY="true" Direction="Direction.Top" AdornmentColor="Color.Secondary">
                            @foreach (var ditem in branches)
                            {
                                <MudSelectItem Value="@ditem.BranchID">@ditem.BranchName</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                    @*  <MudItem xs="12" md="6">
                    <MudTextField @bind-Value="model.InterBranchArdCode" ReadOnly="true"  Label="InterBranchArdCode" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.InterBranchArdCode)"></MudTextField>

                    </MudItem>*@
                    <MudItem xs="12" md="12">
                        <CoaSelector Value="IntermappingCoaID" ValueChanged="OnIntermappingCoaChange" LabelName="Select Account" />
                    </MudItem>



                </MudGrid>
            </EditForm>
        </MudContainer>
    </DialogContent>
    <DialogActions>

        @if (!ReadOnly)
        {
            <MudButton Variant="Variant.Filled" Color="Color.Info" OnClick="Cancel">Cancel</MudButton>

            <MudButton form="formtdsRate" Variant="Variant.Filled" Color="Color.Success" ButtonType="ButtonType.Submit">Submit</MudButton>
        }
        @if (ReadOnly)
        {
            <MudButton Variant="Variant.Filled" Color="Color.Info" OnClick="Cancel">Close</MudButton>

        }
    </DialogActions>
</MudDialog>

@code {
    [Parameter]
    public InterBranchMappingModel model { get; set; }
    [Parameter]
    public bool ReadOnly { get; set; }
    [Parameter]
    public bool IsView { get; set; }
    private List<InterBranchTransactionTypeModel> transactionTypeList = new();
    private List<BranchModel> branches = new();
    [CascadingParameter] MudDialogInstance MudDialog { get; set; }
    public ChartOfAccountModel IntermappingCoaID = new();
    protected override void OnInitialized()
    {
        transactionTypeList = Iservice.GetTypes().ToList();
        branches = branchIservice.Select().ToList();
        if (model.CoaID != null)
        {
            IntermappingCoaID = accountService.SelectByID(model.CoaID);
        }

    }
    private void Cancel()
    {
        MudDialog.Cancel();
    }
    private void OnIntermappingCoaChange(ChartOfAccountModel obj)
    {
        IntermappingCoaID = obj;
        model.CoaID = IntermappingCoaID?.CoaID ?? null;
    }
    private async Task OnValidSubmit(EditContext context)
    {

        model.CoaID = IntermappingCoaID?.CoaID?? null;
        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;
        model.UserInfo.UserID = user.Identity.Name;

        try
        {

            Iservice.Update(model);
            model = new();
            snackbar.Add("Saved Successfully", Severity.Success);
            model = new();

        }
        catch (Exception ex)
        {
            snackbar.Add(ex.Message, Severity.Warning);
        }
        MudDialog.Close();
    }
}
