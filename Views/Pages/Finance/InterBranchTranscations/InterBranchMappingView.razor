@page "/InterBranchMapping"
@inject IInterBranchTransactionService Iservice
@inject MudBlazor.ISnackbar snackbar

@inject AuthenticationStateProvider auth
@attribute [Authorize]
@inject IDialogService DialogService
<MudGrid Spacing="4">
    <MudItem xs="12">
        <MudTable Items="@collection" Dense="true" Hover="true" Striped="true" Elevation="10" @bind-place="model">


            <ToolBarContent>
                <MudText Typo="Typo.h6">InterBranchAccountMapping</MudText>
                <MudTooltip Text="New Sales">
                    <MudIconButton Icon="@Icons.Material.Filled.Add" Title="Add" @onclick="@(()=> OpenDialog(model,false,false))" Color="Color.Dark" Size="Size.Small"></MudIconButton>
                </MudTooltip>

                <MudSpacer></MudSpacer>

            </ToolBarContent>
            <HeaderContent>
                <MudTh><MudTableSortLabel SortBy="new Func<InterBranchAccountMappingModel, object>(x=> x.BranchName)" InitialDirection="SortDirection.Ascending">BranchName</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<InterBranchAccountMappingModel, object>(x=> x.InterBranchArdCode)" InitialDirection="SortDirection.Ascending">InterBranchArdCode</MudTableSortLabel></MudTh>


                <MudTh>Actions</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="GrnNO">@context.BranchName</MudTd>
                <MudTd DataLabel="EntryDate">@context.InterBranchArdCode</MudTd>


                <MudTd DataLabel="">


                    <MudFab @onclick="@(()=> OpenDialog(context,false,false))" Color="Color.Primary" title="Edit" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" IconSize="Size.Small" />
                    <MudFab @onclick="@(()=> Delete(context))" Color="Color.Error" title="Delete" Icon="@Icons.Material.Filled.Delete" Size="Size.Small" IconSize="Size.Small" />

                    <MudFab @onclick="@(()=> OpenDialog(context,true,true))" Color="Color.Info" Icon="@Icons.Material.Filled.GridView" title="View" Size="Size.Small" IconSize="Size.Small" />



                </MudTd>
            </RowTemplate>
            <PagerContent>
                <MudTablePager PageSizeOptions="new int[] { 5, 10, 20, 50, 100 }" />
            </PagerContent>
        </MudTable>
    </MudItem>
</MudGrid>

@code {
    private InterBranchAccountMappingModel model = new InterBranchAccountMappingModel();
    private List<InterBranchAccountMappingModel> collection = new List<InterBranchAccountMappingModel>();
    DialogOptions maxWidth = new DialogOptions() { MaxWidth = MaxWidth.Medium, FullWidth = true };
    protected override void OnInitialized()
    {

        GetAll();
    }
    private void GetAll()
    {

        collection = Iservice.Select().ToList();



    }
    private async Task OpenDialog(InterBranchAccountMappingModel tds, bool Readonly, bool View)
    {
        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;

        DialogParameters parms = new DialogParameters();
        parms.Add("model", tds);
        parms.Add("ReadOnly", Readonly);
        parms.Add("IsView", View);
        var dialog = DialogService.Show<InterBranchMappingDialog>(tds.ID == null ? "ADD" : "EDIT", parms, maxWidth);
        var result = await dialog.Result;

        if (!result.Canceled)
        {

            GetAll();


        }
    }

    private void Delete(InterBranchAccountMappingModel tx)
    {
        Iservice.Delete(tx.ID, "Rijas");
        snackbar.Add("Deleted Successfully", Severity.Success);
        GetAll();
    }
}
