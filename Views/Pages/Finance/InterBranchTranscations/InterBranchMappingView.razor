@page "/InterBranchMapping"
@inject IInterBranchMappingService Iservice
@inject MudBlazor.ISnackbar snackbar
@inject AuthenticationStateProvider auth
@attribute [Authorize]
@using System.Threading;
@inject IRoleService<RoleModel> Irole
@inject IDialogService DialogService

@if (_isLoading)
{
    <div @key="@("loader")" style="display: flex; justify-content: center; align-items: center; min-height: 400px;">
        <LoaderComponent IsFullScreen="true" 
                        ShowLogo="false" 
                        Size="medium" 
                        LoadingText="Loading Sync Protocols" 
                        SubText="Please wait..." />
    </div>
}
else
{
    <div class="fade-in">
        <div class="admin-header-tiered mb-6">
            <div class="d-flex align-center justify-space-between">
                <div>
                    <MudText Typo="Typo.h4" Class="admin-title">Inter-Branch Financial Synchronization</MudText>
                    <MudText Typo="Typo.body2" Class="admin-subtitle">Define account mapping protocols for inter-branch transactions. maintain precise audit trails for internal financial transfers and balancing across organizational units.</MudText>
                </div>
                <MudButton StartIcon="@Icons.Material.Filled.Add" Variant="Variant.Filled" Color="Color.Primary" Class="admin-register-btn" OnClick="@(()=> OpenDialog(new InterBranchMappingModel(),false,false))" Disabled="@_busy">REGISTER SYNC PROTOCOL</MudButton>
            </div>
        </div>

        <div class="admin-glass-card mb-6 pa-4">
            <div class="d-flex align-center gap-4 flex-wrap">
                <div style="flex-grow: 1; min-width: 300px;">
                    <MudTextField @bind-Value="searchTerm" Placeholder="Search by branch, type or ARD code..." Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" Variant="Variant.Outlined" Margin="Margin.Dense" Class="admin-input-group" Clearable="true" />
                </div>
                <div class="d-flex align-center gap-3 bg-glass rounded-pill px-4 py-1">
                    <MudText Typo="Typo.caption" Class="fw-700 opa-50 uppercase">Fetch Limit</MudText>
                    <MudNumericField @bind-Value="@NumberOfRecords" Variant="Variant.Text" Margin="Margin.Dense" Style="width: 60px;" Class="fw-700 mt-0" HideSpinButtons="true" />
                </div>
            </div>
        </div>

        <div class="admin-glass-card pa-0 overflow-hidden">
            <MudTable Items="@collection" Elevation="0" Class="modern-admin-table" Hover="true" Filter="new Func<InterBranchMappingModel, bool>(search)">
                <HeaderContent>
                    <MudTh><span class="admin-header-text">SYNC ATTRIBUTES</span></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<InterBranchMappingModel, object>(x=> x.TransactionTypeName)" InitialDirection="SortDirection.Ascending"><span class="admin-header-text">TRANSACTION TYPE</span></MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<InterBranchMappingModel, object>(x=> x.BranchName)"><span class="admin-header-text">TARGET ENTITY</span></MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<InterBranchMappingModel, object>(x=> x.InterBranchArdCode)"><span class="admin-header-text">ARD CODE</span></MudTableSortLabel></MudTh>
                    <MudTh Style="text-align: right;"><span class="admin-header-text">ACTIONS</span></MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd>
                        <div class="admin-icon-square-vibrant small accent-indigo">
                            <MudIcon Icon="@Icons.Material.Filled.SwapHorizontalCircle" Size="Size.Small" />
                        </div>
                    </MudTd>
                    <MudTd DataLabel="Type">
                        <span class="fw-700 admin-td-primary">@context.TransactionTypeName</span>
                    </MudTd>
                    <MudTd DataLabel="Branch">
                        <div class="d-flex align-center gap-2">
                            <MudIcon Icon="@Icons.Material.Filled.Business" Size="Size.Small" Class="opa-40" />
                            <span class="fw-600">@context.BranchName</span>
                        </div>
                    </MudTd>
                    <MudTd DataLabel="ARD Code">
                        <span class="fw-700 font-monospace opa-70">@context.InterBranchArdCode</span>
                    </MudTd>
                    <MudTd DataLabel="Actions" Style="text-align: right;">
                        <div class="d-flex justify-end gap-1">
                            <MudTooltip Text="Modify Mapping">
                                <MudIconButton OnClick="@(()=> OpenDialog(context,false,false))" Color="Color.Primary" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Variant="Variant.Text" />
                            </MudTooltip>
                            <MudTooltip Text="Delete Protocol">
                                <MudIconButton OnClick="@(()=> Delete(context))" Color="Color.Error" Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Variant="Variant.Text" />
                            </MudTooltip>
                            <MudTooltip Text="Inspect Details">
                                <MudIconButton OnClick="@(()=> OpenDialog(context,true,true))" Color="Color.Info" Icon="@Icons.Material.Filled.Visibility" Size="Size.Small" Variant="Variant.Text" />
                            </MudTooltip>
                        </div>
                    </MudTd>
                </RowTemplate>
                <PagerContent>
                    <div class="pa-4 text-center opa-50 fw-500">
                        <MudTablePager PageSizeOptions="new int[] { 10, 20, 50, 100 }" />
                    </div>
                </PagerContent>
            </MudTable>
        </div>
    </div>
}

@code {

    private bool _isLoading = true;
    private DateTime _loadStartTime;

    private InterBranchMappingModel model = new InterBranchMappingModel();
    private List<InterBranchMappingModel> collection = new List<InterBranchMappingModel>();
    DialogOptions maxWidth = new DialogOptions() { MaxWidth = MaxWidth.Medium, FullWidth = true };
    private int numberOfRecords = 100;
    private string searchTerm = "";
    private bool _busy;

    public bool HasPermissionInterBranchMappingServiceDelete { get; set; } = false;
    public int InterBranchMappingDocTypeID = 86;

    private int NumberOfRecords
    {
        get => numberOfRecords;
        set
        {
            if (numberOfRecords != value)
            {
                numberOfRecords = value;
                _ = ReloadTable();
            }
        }
    }

    //private async Task HandleSearchKeyUp(KeyboardEventArgs e)
    //{
    //    if (e.Key == "Enter")
    //    {
    //        await ReloadTable();
    //    }
    //}

    // Method to reload the table with current filters
    private async Task ReloadTable()
    {
        GetAll(NumberOfRecords);
    }
    // private bool FilterFunc1(InterBranchMappingModel element) => FilterFunc(element, searchTerm);

    // private bool FilterFunc(InterBranchMappingModel element, string searchString)
    // {
    //     if (string.IsNullOrWhiteSpace(searchString))
    //         return true;
    //     if (element.BranchName.Contains(searchString, StringComparison.OrdinalIgnoreCase))
    //         return true;
    //     if (element.TransactionTypeName.Contains(searchString, StringComparison.OrdinalIgnoreCase))
    //         return true;       
    //     return false;
    // }

    // Method to filter the collection based on the search term
    private bool search(InterBranchMappingModel model)
    {
        if ((model.ID != null && model.BranchName.Contains(searchTerm, StringComparison.OrdinalIgnoreCase)) ||
        (model.ID != null && model.TransactionTypeName.Contains(searchTerm, StringComparison.OrdinalIgnoreCase)) ||
        (model.ID != null && model.InterBranchArdCode.Contains(searchTerm, StringComparison.OrdinalIgnoreCase)))
        {
            return true;
        }
        return false;
    }

    // Lifecycle method called when the component is initialized
    protected override async Task OnInitializedAsync()
    {
        _loadStartTime = DateTime.Now;
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionInterBranchMappingServiceDelete = await Irole.HasClaim(InterBranchMappingDocTypeID.ToString(), "Delete", ctc.Token);

        GetAll(NumberOfRecords);
        await EnsureMinimumLoadTime();
        _isLoading = false;
    }

    private async Task EnsureMinimumLoadTime()
    {
        var elapsed = (DateTime.Now - _loadStartTime).TotalMilliseconds;
        if (elapsed < 100)
        {
            await Task.Delay(100 - (int)elapsed);
        }
    }

    // Method to fetch all inter-branch mappings
    private void GetAll(int numberOfRecords)
    {
        int NumberOfRecords = numberOfRecords;
        collection = Iservice.Select(NumberOfRecords, string.Empty).ToList();
    }

    // Method to open the dialog for adding or editing an inter-branch mapping
    private async Task OpenDialog(InterBranchMappingModel tds, bool Readonly, bool View)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        _busy = true;

        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;
        DialogParameters parms = new DialogParameters();
        parms.Add("model", tds.Clone());
        parms.Add("ReadOnly", Readonly);
        parms.Add("IsView", View);
        var dialog = await DialogService.ShowAsync<InterBranchMappingDialog>(tds.ID == null ? "ADD" : "EDIT", parms, maxWidth);
        var result = await dialog.Result;
        if (!result.Canceled)
        {
            GetAll(NumberOfRecords);
        }
        await Task.Delay(200);
        _busy = false;
    }

    // Method to delete an inter-branch mapping
    private async Task Delete(InterBranchMappingModel model)
    {
        if (HasPermissionInterBranchMappingServiceDelete)
        {
            bool? result = await DialogService.ShowMessageBoxAsync(
                "Warning !",
                "Are you sure, you want to delete - " + model.BranchName + " (" + model.InterBranchArdCode + ") ?");
            if (result == true)
            {
                var authprov = await auth.GetAuthenticationStateAsync();
                var User = authprov.User;
                var UserID = User.Identity.Name;
                Iservice.Delete(model.ID, UserID); // Delete the inter-branch mapping
                snackbar.Add("Deleted Successfully", Severity.Success);
            }
        }
        else
        {
            bool? result = await DialogService.ShowMessageBoxAsync(
                "Permission denied!",
                "You don't have any permission to Delete InterBranchMapping.");
        }
        GetAll(NumberOfRecords);
    }
}

