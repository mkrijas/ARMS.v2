@page "/NewInterbranchPaymentMemo"
@using Views.Pages.Finance.Transactions.PurchaseAndPayment;
@inherits DialogFormComponentBase<PaymentMemoModel>
@inject IPaymentService Iservice
@inject IBranchService brService
@inject IInterBranchMappingService intermappingIservice

<DialogForm @ref="@dialogForm" ReadOnly="@ReadOnly" Title="InterBranch Payment Memo" Subtitle="Execute cross-branch payments with real-time settlement tracking and invoice mapping." Icon="@Icons.Material.Filled.SwapHorizontalCircle" AdminStyle="true" formID="ibpaymentform" DocumentDetails="DocInfo" model="@_model" TotalAmount="model.TotalAmount" _busy="_busy">
    <FormContent>
        <div class="dialog-content-wrapper">
            <EditForm id="ibpaymentform" OnValidSubmit="OnValidSubmit" EditContext="editContext">
                <ObjectGraphDataAnnotationsValidator />
                
                <div class="admin-glass-card pa-6 mb-6">
                    <span class="admin-section-label">Routing & Timeline</span>
                    <MudGrid Spacing="3">
                        <MudItem xs="12" md="4">
                            <MudSelect For="@(() => _model.InterBranchTranID)" Label="Internal Transaction Type" ReadOnly="ReadOnly" @bind-Value="_model.InterBranchTranID" T="int?" Variant="Variant.Outlined" Margin="Margin.Dense" Class="admin-input-group">
                                @foreach (var ditem in transactionTypeList)
                                {
                                    <MudSelectItem Value="@ditem.ID">@ditem.TransactionTypeName</MudSelectItem>
                                }
                            </MudSelect>
                        </MudItem>
                        <MudItem xs="12" md="4">
                            <BranchSelector LabelName="Billed Branch" Value="@OtherBranch" ValueChanged="@OtherBranchChanged" Except="@_model.BranchID" Class="admin-input-group" />
                        </MudItem>
                        <MudItem xs="12" md="4">
                            <MudDatePicker ReadOnly="ReadOnly" Label="Document Date" Variant="Variant.Outlined" Margin="Margin.Dense" DisableToolbar="true" Editable="true" @bind-Date="_model.DocumentDate" DateFormat="dd/MM/yyyy" MaxDate="DateTime.Now" Class="admin-input-group" />
                        </MudItem>
                    </MudGrid>
                </div>

                <div class="admin-glass-card pa-6 mb-6">
                    <span class="admin-section-label">Stakeholder Engagement</span>
                    <MudGrid Spacing="3">
                        <MudItem xs="12" md="4">
                            <MudSelect For="@(() => _model.BusinessNature)" Label="Nature of Party" ReadOnly="ReadOnly" Value="@_model.BusinessNature" T="string" ValueChanged="nbusinesschanged" Variant="Variant.Outlined" Margin="Margin.Dense" Class="admin-input-group">
                                <MudSelectItem Value="@("Supplier")" />
                                <MudSelectItem Value="@("Customer")" />
                                <MudSelectItem Value="@("Renter")" />
                                <MudSelectItem Value="@("SisterConcern")">Sister-Concern</MudSelectItem>
                            </MudSelect>
                        </MudItem>
                        <MudItem xs="12" md="4">
                            <PartySelector Value="_model.PartyInfo" ValueChanged="PartyChanged" BranchID="@OtherBranch?.BranchID" NatureOfBusiness="@_model.BusinessNature" Class="admin-input-group"></PartySelector>
                        </MudItem>
                        <MudItem xs="12" md="4">
                            <MudSelect For="@(() => _model.NatureOfTransaction)" Label="Payment Purpose" ReadOnly="ReadOnly" Value="_model.NatureOfTransaction" ValueChanged="nTransactionChanged" T="string" Variant="Variant.Outlined" Margin="Margin.Dense" Class="admin-input-group">
                                @if (_model.PartyInfo != null)
                                {
                                    foreach (var item in natureOfBusinessGroup)
                                    {
                                        <MudSelectItem Value="@(item)" />
                                    }
                                }
                            </MudSelect>
                        </MudItem>
                    </MudGrid>
                </div>

                @if (_model.Bills.Any())
                {
                    <div class="admin-glass-card pa-0 overflow-hidden mb-6">
                        <div class="px-6 py-4 border-bottom-subtle" style="background: rgba(255, 159, 67, 0.03); border-bottom: 1px solid rgba(255, 159, 67, 0.3);">
                            <span class="admin-section-label mb-0">Invoice Settlements</span>
                        </div>
                        <div class="modern-admin-table">
                            <MudGrid Class="admin-table-header px-6 py-3">
                                <MudItem xs="4"><span class="admin-header-text">INVOICE INFO</span></MudItem>
                                <MudItem xs="2"><span class="admin-header-text">BRANCH</span></MudItem>
                                <MudItem xs="3"><span class="admin-header-text">OUTSTANDING</span></MudItem>
                                <MudItem xs="3"><span class="admin-header-text">PAY AMOUNT</span></MudItem>
                            </MudGrid>

                            @foreach (var item in _model.Bills)
                            {
                                <MudGrid Class="px-6 py-3 border-bottom-subtle align-center">
                                    <MudItem xs="4">
                                        <MudText Typo="Typo.body2" Style="font-weight: 700;">@item.InvoiceNumber</MudText>
                                        <MudText Typo="Typo.caption" Style="color: #667085;">@item.InvoiceDate?.ToString("dd/MM/yyyy")</MudText>
                                    </MudItem>
                                    <MudItem xs="2">
                                        <MudText Typo="Typo.body2">@item.BranchName</MudText>
                                    </MudItem>
                                    <MudItem xs="3">
                                        <MudText Typo="Typo.body2">@item.OutstandingAmountDisplayText</MudText>
                                    </MudItem>
                                    <MudItem xs="3">
                                        <MudNumericField T="decimal?" @bind-Value="item.PayAmount" TextChanged="SetTotalAmt" Variant="Variant.Outlined" Margin="Margin.Dense" HideSpinButtons Class="admin-input-group" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.CurrencyRupee" AdornmentColor="Color.Primary" />
                                    </MudItem>
                                </MudGrid>
                            }
                        </div>
                    </div>
                }

                <div class="admin-glass-card pa-6">
                    <span class="admin-section-label">Finalization</span>
                    <MudGrid Spacing="3">
                        <MudItem xs="12" md="@(_model.Bills.Any() ? 12 : 6)">
                            <MudTextField ReadOnly="ReadOnly" @bind-Value="_model.Reference" Label="Reference / Purpose" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => _model.Reference)" Class="admin-input-group"></MudTextField>
                        </MudItem>
                        @if (!_model.Bills.Any() && (_model.NatureOfTransaction == "Deposit" || _model.NatureOfTransaction == "Prepayment" || _model.NatureOfTransaction == "Other"))
                        {
                            <MudItem xs="12" md="6">
                                <MudNumericField ReadOnly="ReadOnly" HideSpinButtons @bind-Value="_model.TotalAmount" Label="Deposit Amount" Variant="Variant.Outlined" Margin="Margin.Dense" Class="admin-input-group" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.CurrencyRupee" AdornmentColor="Color.Primary" For="@(() => _model.TotalAmount)"></MudNumericField>
                            </MudItem>
                        }
                        <MudItem xs="12">
                            <MudTextField ReadOnly="ReadOnly" @bind-Value="_model.Narration" Lines="2" Label="Settlement Narration" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => _model.Narration)" Class="admin-input-group"></MudTextField>
                        </MudItem>
                    </MudGrid>
                </div>
            </EditForm>
        </div>
    </FormContent>
    <VerificationStatus>
        <AutherizationStatusComponent CreatedBy="@_model.UserInfo" DocTypeID="@DocInfo.DocumentTypeID" DocumentID="DocInfo.DocumentID" OnApprove="Approve" OnVerified="Verified"></AutherizationStatusComponent>
    </VerificationStatus>
</DialogForm>

@code {

    [Parameter]
    public override PaymentMemoModel model { get { return _model; } set { _model = value; DocInfo.DocumentID = value.PaymentMemoID; } }
    private PaymentMemoModel _model;


    string[] natureOfBusinessGroup = new string[] { };
    string[] RentGroup = { "Rent", "Deposit", "Other" };
    string[] SupplierGroup = { "Deposit", "Payable", "Prepayment" };
    string[] CustomerGroup = { "Deposit", "Receivable", "Prepayment" };
    string[] SisterGroup = { "Deposit", "Trade", "Prepayment" };

    protected override DocumentInfoModel DocInfo { get; set; } = new DocumentInfoModel()
    {
        DocumentTypeID = 7,
        DocumentName = "PaymentMemo"
    };

    private List<OutstandingBillsModel> SelectedItems = new List<OutstandingBillsModel>();   
    private BranchModel OtherBranch;
    private List<InterBranchTransactionTypeModel> transactionTypeList = new();
    private List<BranchModel> BranchList = new();

    // Lifecycle method called when the component is initialized
    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();

        // Load branches and transaction types
        BranchList = brService.Select().ToList();
        transactionTypeList = intermappingIservice.GetTypes().ToList();
        if (BranchList != null && model.OtherBranchID != null && BranchList.Any(s => s.BranchID == model.OtherBranchID))
        {
            OtherBranch = BranchList.FirstOrDefault(s => s.BranchID == model.OtherBranchID);
        }

        // Load bills if the payment memo ID is provided
        if (model.PaymentMemoID != null)
        {
            model.Bills = Iservice.GetBills(model.PaymentMemoID.Value).ToList();
        }
        else
        {
            model.BranchID = BranchID;
            model.IsInterBranch = true;
            model.BusinessNature = "Supplier";
        }
        SetNTransaction(model.BusinessNature);
        GetBills();
    } 

    // Method to open the dialog for outstanding bills
    private async Task OpenOutstandingBills()
    {
        DialogOptions Doptions = new DialogOptions() { MaxWidth = MaxWidth.Large, FullWidth = true };
        DialogParameters parms = new DialogParameters();
        parms.Add("PartyID", model.PartyInfo.PartyID);
        parms.Add("BranchID", model.OtherBranchID);
        var dialog = await dialogService.ShowAsync<OutstandingBillView>("Outstanding Bill", parms, Doptions);
        var result = await dialog.Result;
        if (!result.Canceled)
        {
            List<OutstandingBillsModel> SelectedItems = new List<OutstandingBillsModel>();
            SelectedItems = (List<OutstandingBillsModel>)result.Data;
            model.Bills.Clear();
            foreach (var item in SelectedItems)
            {
                model.Bills.Add(new BillsPaidModel()
                {
                    MID = item.MID,
                    BranchName = item.BranchName,
                    InvoiceDate = item.ReferenceDocDate,
                    InvoiceNumber = item.ReferenceDocNo,
                    OutstandingAmount = item.OutstandingAmount,
                    PayAmount = -(item.OutstandingAmount),
                    IsMemo = item.isMemo,
                    CoaID = item.CoaID,
                    SubArdCode = item.SubArdCode,
                    PartyID = item.PartyInfo .PartyID,
                    BranchID = item.BranchID 
                });
            }
            //model.Reference = string.Join(",", SelectedItems.Select(x => x.ReferenceDocNo));
        }
        if (!model.Bills.Any())
        {
            model.NatureOfTransaction = null;
        }
    }

    // Method to update the payment memo
    protected override async Task<int> Update(PaymentMemoModel editModel)
    {        
        model = Iservice.Update(model); // Update the model
        return model.PaymentMemoID.Value;
    }

    // Method to update the approval status of the payment memo
    protected override int UpdateApproval(DataApprovedStatus aprvd)
    {
        model.IsInterBranch = true;
        int result = Iservice.Approve(model.PaymentMemoID, model.UserInfo.UserID, aprvd.Remarks); // Approve the payment memo
        return result;
    }
     
    // Method to fetch outstanding bills based on the party ID
    private void GetBills()
    {
        List<OutstandingBillsModel> collection = new List<OutstandingBillsModel>();

        if (model?.PartyInfo?.PartyID != null)
        {
            collection = OBIservice.SelectByParty(model.PartyInfo.PartyID, BranchID, 100, null).ToList(); // Fetch bills by party ID
        }
    }

    // Method to set the total amount based on the bills
    private void SetTotalAmt()
    {
        model.TotalAmount = (model.Bills.Sum(x => x.PayAmount) ?? 0);
    }

    // Method to handle changes in the other branch selection
    private async Task OtherBranchChanged(BranchModel branch)
    {
        OtherBranch = branch;
        model.OtherBranchID = branch?.BranchID;
        model.Bills = new();
        await nbusinesschanged(null);
    }

    // Method to handle changes in business nature
    async Task nbusinesschanged(string val)
    {
        model.BusinessNature = val;
        SetNTransaction(val);
        await PartyChanged(null);
    }

    // Method to set the nature of transaction based on business nature
    void SetNTransaction(string nBusiness)
    {
        if (nBusiness == "Renter")
        {
            natureOfBusinessGroup = RentGroup;
        }
        else if (nBusiness == "Customer")
        {
            natureOfBusinessGroup = CustomerGroup;
        }
        else if (nBusiness == "Supplier")
        {
            natureOfBusinessGroup = SupplierGroup;
        }
        else if (nBusiness == "SisterConcern")
        {
            natureOfBusinessGroup = SisterGroup;
        }
        else
        {
            natureOfBusinessGroup = new string[] { };
        }
    }

    // Method to handle changes in the selected party
    async Task PartyChanged(PartyModel party)
    {
        model.PartyInfo = party;        
        await nTransactionChanged(null);
    }

    // Method to handle changes in the transaction nature
    private async Task nTransactionChanged(string nt)
    {
        model.NatureOfTransaction = nt;
        if (model.NatureOfTransaction is not null)
        {
            model.PartyCoaID = partyService.GetPartyCoaID(model.PartyInfo.PartyID, model.BusinessNature, model.NatureOfTransaction); // Get party COA ID
            if (model.PartyCoaID == null)
            {
                bool? result = await dialogService.ShowMessageBoxAsync(
                    "Account Not Mapped!",
                    "Party Account is not mapped for " + model.NatureOfTransaction + "!");
                model.NatureOfTransaction = null;
            }
        }

        if (nt == "Payable" || nt == "Rent" || nt == "Trade")
        {
            await OpenOutstandingBills();
        }
        else
        {
            model.Bills.Clear();
        }
    }
}
