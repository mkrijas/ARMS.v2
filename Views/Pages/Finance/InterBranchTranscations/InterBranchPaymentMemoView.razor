    private async Task OpenDialog(PartyPaymentMemoModel tds)
    {
        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;


        pmnList = new List<BillsPaidModel>();
        foreach (var item in Iservice.GetBills(tds.PaymentMemoID))
        {
            pmnList.Add(item);
        }
        tds.Bills = pmnList;


        // pim.PaymentMemos.Add(tds);
        DialogParameters parms = new DialogParameters();
        parms.Add("model",pim);
        var dialog =  DialogService.Show<PaymentInitiatedDialog>(tds.PaymentMemoID == null?"ADD":"EDIT",parms,maxWidth);
        var result = await dialog.Result;

        if(!result.Cancelled)
        {   
            await GetAll();
        }
    }

    private async Task Delete(PartyPaymentMemoModel tx)
    {
        Iservice.Delete(tx.PaymentMemoID, "Rijas");
        snackbar.Add("Deleted Successfully", Severity.Success);
        await GetAll();
    }

    private async Task selected()
    {

        if(selectedItems1.Count>0)
        {
            foreach (var item in selectedItems1)
            {
                if(item.AuthLevelId!=99)
                {
                    snackbar.Add("Unverified cannot be selected", Severity.Warning);
                    return;
                }
            }
            // value = "visible";
            pim.PaymentMemos = selectedItems1.ToList();
            foreach (var item in pim.PaymentMemos)
            {
                foreach (var item1 in Iservice.GetBills(item.PaymentMemoID))
                {
                    pmnList.Add(item1);
                }

                item.Bills = pmnList;
                item.PaymentStatus = 1;
            }
            pim.DueOn = null;
            DialogParameters parms = new DialogParameters();
            parms.Add("model",pim);
            var dialog =  DialogService.Show<PaymentInitialMemo>("Payment",parms);
            var result = await dialog.Result;

            if(!result.Cancelled)
            {   
                PaymentInitiatedModel UpatedModel = (PaymentInitiatedModel)result.Data; 
                var authprov = await auth.GetAuthenticationStateAsync();
                var brancIDString = authprov.User.Claims.First(x => x.Type == "BranchID").Value;
                int brancID = int.Parse(brancIDString);
                var user = authprov.User;
                UpatedModel.UserInfo.UserID = user.Identity.Name;
                UpatedModel.BranchID = brancID;
                Iservice.InitiatePayment(UpatedModel);
               await GetAll();
            }
        }
        else
        {
            snackbar.Add("Please Select Memo", Severity.Success);
            return;
        }

        
        //MudDialog.Close(selecteditem);
    
    }
