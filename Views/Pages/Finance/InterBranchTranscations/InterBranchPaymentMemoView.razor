@code {

    private PartyPaymentMemoModel model = new PartyPaymentMemoModel();

    private List<PartyPaymentMemoModel> collection = new List<PartyPaymentMemoModel>();
    private List<BillsPaidModel> pmnList = new List<BillsPaidModel>();
    DialogOptions maxWidth = new DialogOptions() { MaxWidth = MaxWidth.Large, FullWidth = true };
    DialogOptions mediumWidth = new DialogOptions() { MaxWidth = MaxWidth.Medium, FullWidth = true };

    PaymentInitiatedModel pim = new PaymentInitiatedModel();
    private HashSet<PartyPaymentMemoModel> selectedItems1= new HashSet<PartyPaymentMemoModel>();
    public string value="invisible";

    protected override async Task OnInitializedAsync()
    {
        model = new();
        await GetAll();
    }
    public void View(PartyPaymentMemoModel ppmm)
    {
        DialogParameters parms = new DialogParameters();
        parms.Add("model",ppmm);
        var dialog =  DialogService.Show<InterBranchPaymentMemoDialog>(ppmm.PaymentMemoID == null?"Payment Memo":"Payment Memo",parms,mediumWidth);

    }
    private  async Task GetAll()
    {
        var authprov = await auth.GetAuthenticationStateAsync();
        var brancIDString = authprov.User.Claims.First(x => x.Type == "BranchID").Value;
        int brancID = int.Parse(brancIDString);
        collection = new List<PartyPaymentMemoModel>();
        foreach (var item in Iservice.SelectInterBranch(brancID))
        {
            collection.Add(item);
        }


    }   
    public async Task OpenDialogpayment(PartyPaymentMemoModel ppm)
    {
        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;

        DialogParameters parms = new DialogParameters();
        parms.Add("model",ppm);
        parms.Add("IsReadOnly",false);
        parms.Add("IsView",false);
        var dialog =  DialogService.Show<InterBranchPaymentMemoDialog>(ppm.PaymentMemoID == null?"ADD":"EDIT",parms,maxWidth);
        var result = await dialog.Result;

        if(!result.Cancelled)
        {   

            GetAll();


        }

        GetAll();
    }
    public async Task OpenDialogpaymentView(PartyPaymentMemoModel ppm)
    {
        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;

        DialogParameters parms = new DialogParameters();
        parms.Add("model",ppm);
        parms.Add("IsReadOnly",true);
        parms.Add("IsView",true);
        var dialog =  DialogService.Show<InterBranchPaymentMemoDialog>(ppm.PaymentMemoID == null?"ADD":"EDIT",parms,maxWidth);
        var result = await dialog.Result;

        if(!result.Cancelled)
        {   

            GetAll();


        }
        GetAll();

    }
    public async Task OpenDialogpaymentVerify(PartyPaymentMemoModel ppm)
    {
        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;

        DialogParameters parms = new DialogParameters();
        parms.Add("model",ppm);
        parms.Add("IsReadOnly",true);
        parms.Add("IsView",false);
        var dialog =  DialogService.Show<InterBranchPaymentMemoDialog>(ppm.PaymentMemoID == null?"ADD":"EDIT",parms,maxWidth);
        var result = await dialog.Result;

        if(!result.Cancelled)
        {   

            GetAll();


        }

        GetAll();
    }

