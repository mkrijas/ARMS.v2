@using Views.Pages.Finance.Transactions.PurchaseAndPayment
@using ArmsServices.DataServices.General
@using System.Threading;
@attribute [Authorize]
@* @inject AuthenticationStateProvider auth *@
@inherits DialogFormComponentBase<ReceiptModel>
@inject TruckDataArrayModel data
@inject NavigationManager uriHelper;
@inject IConfigTable IConfig
@inject IReceiptService Iservice
@inject IPartyService partyIservice
@inject IOutstandingBillsService OutstandingIservice
@inject ICostCenterService costIservice
@inject IBranchService branchIservice
@inject IInterBranchMappingService intermappingIservice
@inject IDimensionService dimensionIservice
@* @inject MudBlazor.ISnackbar snackbar
@inject IRoleService<RoleModel> Irole *@
@inject IDialogService DialogService

<DialogForm @ref="@dialogForm" ReadOnly="@ReadOnly" Title="InterBranch Receipt" Subtitle="Settle invoices across branches with automated Inter-Branch ledger reconciliation." Icon="@Icons.Material.Filled.SwapHoriz" AdminStyle="true" formID="IreceiptForm" DocumentDetails="DocInfo" model="@model" TotalAmount="model.TotalAmount" _busy="_busy">
    <FormContent>
        <div class="dialog-content-wrapper">
            <EditForm id="IreceiptForm" OnValidSubmit="OnValidSubmit" EditContext="editContext">
                <ObjectGraphDataAnnotationsValidator />
                
                <div class="admin-glass-card pa-6 mb-6">
                    <span class="admin-section-label">Inter-Branch Routing</span>
                    <MudGrid Spacing="3">
                        <MudItem xs="12" md="6">
                            <BranchSelector Value="@OtherBranch" ValueChanged="BranchChanged" LabelName="Target Branch (Receipt collected for)" Class="admin-input-group"></BranchSelector>
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <MudSelect For="@(() => model.InterBranchTranID)" Label="Internal Transaction Type" ReadOnly="ReadOnly" @bind-Value="model.InterBranchTranID" SelectedValuesChanged="CheckInterbranchMapping" T="int?" Variant="Variant.Outlined" Margin="Margin.Dense" Class="admin-input-group">
                                @foreach (var ditem in transactionTypeList)
                                {
                                    <MudSelectItem Value="@ditem.ID">@ditem.TransactionTypeName</MudSelectItem>
                                }
                            </MudSelect>
                        </MudItem>
                    </MudGrid>
                </div>

                <div class="admin-glass-card pa-6 mb-6">
                    <span class="admin-section-label">Stakeholder Definition</span>
                    <MudGrid Spacing="3">
                        <MudItem xs="12" md="4">
                            <MudSelect For="@(() => model.BusinessNature)" Label="Nature of Party" Value="@model.BusinessNature" ValueChanged="BusinessNatureChanged" T="string" Variant="Variant.Outlined" Margin="Margin.Dense" Class="admin-input-group">
                                <MudSelectItem Value="@("Supplier")" />
                                <MudSelectItem Value="@("Customer")" />
                                <MudSelectItem Value="@("Renter")" />
                                <MudSelectItem Value="@("SisterConcern")" />
                            </MudSelect>
                        </MudItem>
                        <MudItem xs="12" md="4">
                            <PartySelector Value="model.PartyInfo" ValueChanged="PartyChanged" NatureOfBusiness="@model.BusinessNature" For="(() => model.PartyInfo)" BranchID="@OtherBranch?.BranchID" Class="admin-input-group" />
                        </MudItem>
                        <MudItem xs="12" md="4">
                            <MudSelect For="@(() => model.NatureOfTransaction)" Label="Nature Of Receipt" ReadOnly="ReadOnly" Value="model.NatureOfTransaction" ValueChanged="nTransactionchanged" T="string" Variant="Variant.Outlined" Margin="Margin.Dense" Class="admin-input-group">
                                <MudSelectItem Value="@("Deposit")" />
                                <MudSelectItem Value="@("Receivable")" />
                                <MudSelectItem Value="@("Trade")" />
                                <MudSelectItem Value="@("Prepayment")" />
                            </MudSelect>
                        </MudItem>
                    </MudGrid>
                </div>

                @if (model.Bills.Any())
                {
                    <div class="admin-glass-card pa-0 overflow-hidden mb-6">
                        <div class="px-6 py-4 border-bottom-subtle" style="background: rgba(255, 159, 67, 0.03); border-bottom: 1px solid rgba(255, 159, 67, 0.3);">
                            <span class="admin-section-label mb-0">Cross-Branch Settlements</span>
                        </div>
                        <div class="modern-admin-table">
                            <MudGrid Class="admin-table-header px-6 py-3">
                                <MudItem xs="4"><span class="admin-header-text">INVOICE INFO</span></MudItem>
                                <MudItem xs="4"><span class="admin-header-text">BRANCH</span></MudItem>
                                <MudItem xs="4"><span class="admin-header-text">RECEIPT AMOUNT</span></MudItem>
                            </MudGrid>

                            @* @foreach (var item in model.Bills) *@
                            @foreach (var (item, index) in model.Bills.Select((value, i) => (value, i)))
                            {
                                <MudGrid Class="px-6 py-3 border-bottom-subtle align-center">
                                    <MudItem xs="4">
                                        <MudText Typo="Typo.body2" Style="font-weight: 700;">@item.InvoiceNumber</MudText>
                                        <MudText Typo="Typo.caption" Style="color: #667085;">@item.InvoiceDate?.ToString("dd/MM/yyyy")</MudText>
                                    </MudItem>
                                    <MudItem xs="4">
                                        <MudText Typo="Typo.body2">@item.BranchName</MudText>
                                    </MudItem>
                                    <MudItem xs="4">
                                        <MudNumericField T="decimal?" Value="item.ReceiptAmount" ValueChanged=@((e)=>OnReceiptAmtChange(e, index)) Variant="Variant.Outlined" Margin="Margin.Dense" HideSpinButtons Class="admin-input-group" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.CurrencyRupee" AdornmentColor="Color.Primary" />
                                    </MudItem>
                                </MudGrid>
                            }
                        </div>
                    </div>
                }

                <div class="admin-glass-card pa-6 mb-6">
                    <span class="admin-section-label">Financial Execution</span>
                    <MudGrid Spacing="3">
                        <MudItem xs="12">
                            <PaymentAccountSelector @bind-PaymentMode="@model.ReceiptMode" @bind-ArdCode="@model.ReceiptArdCode" @bind-CoaID="@model.ReceiptCoaID" @bind-BankCharges="@model.BankCharges" @bind-BankTool="@model.ReceiptTool" Class="admin-input-group" />
                        </MudItem>
                        <MudItem xs="12" md="4">
                            <MudDatePicker ReadOnly="ReadOnly" Label="Effective Date" Variant="Variant.Outlined" Margin="Margin.Dense" DisableToolbar="true" Editable="true" @bind-Date="model.EffectiveDate" DateFormat="dd/MM/yyyy" Class="admin-input-group" />
                        </MudItem>
                        <MudItem xs="12" md="4">
                            <MudTextField ReadOnly="ReadOnly" @bind-Value="model.Reference" Label="Reference / Chq No" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.Reference)" Class="admin-input-group"></MudTextField>
                        </MudItem>
                        @if (!model.Bills.Any())
                        {
                            <MudItem xs="12" md="4">
                                <MudNumericField ReadOnly="ReadOnly" HideSpinButtons @bind-Value="model.TotalAmount" Label="Total Collection Amount" Variant="Variant.Outlined" Margin="Margin.Dense" Class="admin-input-group" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.CurrencyRupee" AdornmentColor="Color.Primary" For="@(() => model.TotalAmount)"></MudNumericField>
                            </MudItem>
                        }
                    </MudGrid>
                </div>

                <div class="admin-glass-card pa-6">
                    <span class="admin-section-label">Verification & Status</span>
                    <MudGrid Spacing="3">
                        <MudItem xs="12" md="4">
                            <MudDatePicker ReadOnly="ReadOnly" Label="Document Date" Variant="Variant.Outlined" Margin="Margin.Dense" DisableToolbar="true" Editable="true" @bind-Date="model.DocumentDate" DateFormat="dd/MM/yyyy" MaxDate="DateTime.Now" Class="admin-input-group" />
                        </MudItem>
                        <MudItem xs="12" md="4">
                            <div class="admin-input-group px-4 py-2 border rounded" style="background: rgba(255,159,67,0.03); border: 1px solid rgba(255,159,67,0.3);">
                                <MudCheckBox @bind-Value="model.IsRealized" ReadOnly="@ReadOnly" Label="Payment Realized" Color="Color.Primary"></MudCheckBox>
                            </div>
                        </MudItem>
                        <MudItem xs="12">
                            <MudTextField ReadOnly="ReadOnly" @bind-Value="model.Narration" Lines="2" Label="Inter-Branch Narration" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.Narration)" Class="admin-input-group"></MudTextField>
                        </MudItem>
                    </MudGrid>
                </div>
            </EditForm>
        </div>
    </FormContent>
    <VerificationStatus>
        <AutherizationStatusComponent CreatedBy="@model.UserInfo" DocTypeID="@DocInfo.DocumentTypeID" DocDate="@DocDate" DocType="@DocType" DocNumber="@DocNumber" PageToRedirectLink="@PageToRedirectLink" DocumentID="model.ReceiptID" OnApprove="Approve" OnVerified="Verified"></AutherizationStatusComponent>
    </VerificationStatus>
</DialogForm>

@code {

    //private string UserID = null;
    string UserIDTemp;
    private List<BranchModel> BranchList = new();
    //private bool _busy;
    //private EditContext editContext;

    protected override DocumentInfoModel DocInfo { get; set; } = new();

    public bool HasPermissionReceiptServiceEdit { get; set; } = false;
    public bool HasPermissionReceiptServiceApprove { get; set; } = false;
    public int ReceiptDocTypeID = 14;

    [Parameter]
    public string PageToRedirectLink { get; set; }
    //public string DocNumber { get; set; }
    //public DateTime? DocDate { get; set; }
    public string DocType { get; set; }

    //BranchModel OtherBranch;
    List<InterBranchTransactionTypeModel> transactionTypeList = new();
    List<BranchModel> branches = new();
    InterBranchMappingModel InterBrMappingList { get; set; }

    // Method to check inter-branch mapping
    private void CheckInterbranchMapping()
    {
        InterBrMappingList = intermappingIservice.Select(OtherBranch.BranchID, model.InterBranchTranID);
        if (InterBrMappingList == null)
        {
            snackbar.Add("Crediting branch is not mapped !", Severity.Warning);
            return;
        }
    }

    // Lifecycle method called when the component is initialized
    protected override async Task OnInitializedAsync()
    {
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionReceiptServiceEdit = await Irole.HasClaim(ReceiptDocTypeID.ToString(), "Edit", ctc.Token);
        HasPermissionReceiptServiceApprove = await Irole.HasClaim(ReceiptDocTypeID.ToString(), "Approve", ctc.Token);

        DocInfo.DocumentTypeID = ReceiptDocTypeID;
        DocInfo.DocumentID = model.ReceiptID;

        await base.OnInitializedAsync();

        // Load transaction types and branches
        transactionTypeList = intermappingIservice.GetTypes().ToList();
        BranchList = branchIservice.Select().ToList();
        if (model.OtherBranchID != null && BranchList.Any(s => s.BranchID == model.OtherBranchID))
        {
            OtherBranch = BranchList.FirstOrDefault(s => s.BranchID == model.OtherBranchID);
        }

        // Load bills if the receipt ID is provided
        if (model.ReceiptID != null)
        {
            UserIDTemp = model.UserInfo.UserID;
            model.Bills = Iservice.GetBills(model.ReceiptID).ToList();
            model.PartyInfo = partyIservice.SelectByID(model.PartyInfo.PartyID); // Load party info
        }
        else
        {
            model.BranchID = BranchID;
        }

        DocNumber = model.DocumentNumber;
        DocDate = model.DocumentDate;
        DocType = model.NatureOfTransaction;
        model.IsInterBranch = true;
    }

    // Method called when parameters are set
    protected override void OnParametersSet()
    {
        editContext = new EditContext(model);
        DocInfo.DocumentTypeID = ReceiptDocTypeID;
        DocInfo.DocumentID = model.ReceiptID;
    }

    // Method to handle changes in the selected branch
    async Task BranchChanged(BranchModel branch)
    {
        OtherBranch = branch;
        model.OtherBranchID = branch?.BranchID;
        await nTransactionchanged(null);
    }

    // Method to handle changes in business nature
    async Task BusinessNatureChanged(string bn)
    {
        model.BusinessNature = bn;
        await PartyChanged(null);
    }

    // Method to handle changes in the selected party
    async Task PartyChanged(PartyModel party)
    {
        model.PartyInfo = party;
        await nTransactionchanged(null);
    }

    // Method to handle changes in the transaction nature
    private async Task nTransactionchanged(string nt)
    {
        if (model.PartyInfo?.PartyID != null)
        {
            model.NatureOfTransaction = nt;
        }
        else if (nt != null)
        {
            snackbar.Add("Select Party", Severity.Warning);
            return;
        }
        if (nt != "Receivable" && nt != "Trade")
        {
            model.Bills.Clear();
        }
        else
        {
            await OpenOutstandingBills();
        }
    }

    private void OnReceiptAmtChange(decimal? Amount, int index)
    {
        model.Bills[index].ReceiptAmount = Amount;
        calcTotalAmt();
    }

    // Method to calculate the total amount based on the bills
    private void calcTotalAmt()
    {
        model.TotalAmount = model.Bills.Sum(x => x.ReceiptAmount);
    }

    // Method to open the dialog for outstanding bills
    private async Task OpenOutstandingBills()
    {
        DialogOptions maxWidth = new DialogOptions() { MaxWidth = MaxWidth.Medium, FullWidth = true };
        DialogParameters parms = new DialogParameters();
        parms.Add("PartyID", model.PartyInfo.PartyID);
        parms.Add("BranchID", model.OtherBranchID);
        var dialog = await DialogService.ShowAsync<OutstandingBillView>("Outstanding Bill", parms, maxWidth);
        var result = await dialog.Result;
        List<OutstandingBillsModel> SelectedItems = new List<OutstandingBillsModel>();
        if (!result.Canceled)
        {
            SelectedItems = (List<OutstandingBillsModel>)result.Data;
            if (SelectedItems != null)
            {
                foreach (var item in SelectedItems)
                {
                    model.Bills.Add(new BillsReceiptModel()
                    {
                        MID = item.MID,
                        BranchName = item.BranchName,
                        BranchID = item.BranchID,
                        InvoiceDate = item.ReferenceDocDate,
                        InvoiceNumber = item.ReferenceDocNo,
                        ReceiptAmount = item.OutstandingAmount,
                        CoaID = item.CoaID,
                        IsMemo = item.isMemo,
                        PartyID = item.PartyInfo.PartyID
                    });
                }
            }
            calcTotalAmt();
        }
        else
        {
            await nTransactionchanged(null);
        }
    }

    // Method to handle form submission
    protected override async Task<int> Update(ReceiptModel editModel)
    {
        if (validate(model) == true)
        {
            // Update the receipt model
            model = Iservice.Update(model);
            if (model.ReceiptID != null)
            {
                return model.ReceiptID.Value;
            }
        }
        return 0;
    }

    // Method to validate the receipt model
    public bool validate(ReceiptModel editModel)
    {
        // Get the party COA ID based on the selected party and business nature
        model.PartyCoaID = partyIservice.GetPartyCoaID(model.PartyInfo.PartyID, model.BusinessNature, model.NatureOfTransaction);
        if (model.PartyCoaID == null)
        {
            snackbar.Add("Party Account is not mapped for " + model.NatureOfTransaction + "!", Severity.Warning);
            return false;
        }
        return true;
    }

    // Method to approve the receipt
    protected override int UpdateApproval(DataApprovedStatus aprvd)
    {
        int result = Iservice.Approve(model.ReceiptID, model.UserInfo.UserID, aprvd.Remarks); // Approve the receipt
        model.UserInfo.UserID = UserIDTemp;
        return result;
    }
}
