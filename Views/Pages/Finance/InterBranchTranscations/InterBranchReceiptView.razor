@page "/InterBranchReceiptView"
@page "/InterBranchReceiptView/{id:int}"
@using System.Threading;
@attribute [Authorize]
@inject AuthenticationStateProvider auth
@inherits ViewComponentBase<ReceiptModel>
@inject NavigationManager uriHelper;
@inject SignalRService signalRService
@inject IReceiptService Iservice
@inject IOutstandingBillsService OutstandingIservice
@inject ICostCenterService costIservice
@inject IDimensionService dimensionIservice
@inject MudBlazor.ISnackbar snackbar
@inject IRoleService<RoleModel> Irole
@inject IDialogService DialogService
@inject IPushNotificationService IpushNotificationService

@if (_isLoading)
{
    <div @key="@("loader")" style="display: flex; justify-content: center; align-items: center; min-height: 400px;">
        <LoaderComponent IsFullScreen="true" 
                        ShowLogo="false" 
                        Size="medium" 
                        LoadingText="Loading Reception Protocols" 
                        SubText="Please wait..." />
    </div>
}
else
{
    <div class="fade-in">
        <div class="admin-header-tiered mb-6">
            <div class="d-flex align-center justify-space-between">
                <div>
                    <MudText Typo="Typo.h4" Class="admin-title">Inter-Branch Funds Reception</MudText>
                    <MudText Typo="Typo.body2" Class="admin-subtitle">Acknowledge and record funds received from other branch locations. verify inter-branch transfers and reconcile incoming payments with outgoing memos.</MudText>
                </div>
                <MudButton StartIcon="@Icons.Material.Filled.AssignmentTurnedIn" Variant="Variant.Filled" Color="Color.Primary" Class="admin-register-btn" OnClick="@(()=> OpenForm(new ReceiptModel(),false,false))" Disabled="@_busy">NEW RECEIPT ENTRY</MudButton>
            </div>
        </div>

        <div class="admin-glass-card mb-6 pa-4">
            <div class="d-flex align-center gap-4 flex-wrap">
                <div style="flex-grow: 1; min-width: 300px;">
                    <MudTextField @bind-Value="searchTerm" Placeholder="Search by receipt number or source branch..." Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" Variant="Variant.Outlined" Margin="Margin.Dense" Class="admin-input-group" Clearable="true" OnKeyUp="HandleSearchKeyUp" />
                </div>
                <div class="d-flex align-center gap-4">
                    <div class="d-flex align-center bg-glass rounded-pill px-4 py-1">
                        <MudText Typo="Typo.caption" Class="fw-700 opa-50 uppercase mr-2">Limit</MudText>
                        <MudNumericField @bind-Value="@NumberOfRecords" Variant="Variant.Text" Margin="Margin.Dense" Style="width: 50px;" Class="fw-700 mt-0" HideSpinButtons="true" />
                    </div>
                    <div class="d-flex align-center bg-glass rounded-pill px-4 py-1">
                        <MudCheckBox T="bool" Label="Approved Entries" ValueChanged="((bool value)=>ApprovedChanged(value))" Value="@IsApproved" Size="Size.Small" Color="Color.Primary" Class="fw-600" />
                    </div>
                </div>
            </div>
        </div>

        <div class="admin-glass-card pa-0 overflow-hidden">
            <MudTable Items="@collection" Elevation="0" Class="modern-admin-table" Hover="true">
                <HeaderContent>
                    <MudTh><MudTableSortLabel SortBy="new Func<ReceiptModel, object>(x=> x.DocumentDate)"><span class="admin-header-text">DATE</span></MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<ReceiptModel, object>(x=> x.DocumentNumber)"><span class="admin-header-text">DOC NUMBER</span></MudTableSortLabel></MudTh>
                    <MudTh Style="text-align: right;"><span class="admin-header-text">TOTAL RECEPTION</span></MudTh>
                    <MudTh Style="text-align: right;"><span class="admin-header-text">ACTIONS</span></MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Date"><span class="fw-500">@context.DocumentDate?.ToString("dd MMM yyyy")</span></MudTd>
                    <MudTd DataLabel="DocNumber">
                        <div class="d-flex align-center gap-2">
                            <span class="admin-td-primary fw-700">@context.DocumentNumber</span>
                            @if (context.AuthLevelId == 99)
                            {
                                <MudIcon Icon="@Icons.Material.Filled.Verified" Color="Color.Success" Size="Size.Small" />
                            }
                        </div>
                    </MudTd>
                    <MudTd DataLabel="Amount" Style="text-align: right;">
                        <span class="fw-800 text-success" style="font-size: 1rem;">@context.TotalAmount?.ToString("N2")</span>
                    </MudTd>
                    <MudTd DataLabel="Actions" Style="text-align: right;">
                        <div class="d-flex justify-end gap-1">
                            @if (@context.AuthLevelId == 99)
                            {
                                <EntryReversedComponent DocTypeID="DocInfo.DocumentTypeID" DocumentID="context.ReceiptID" MID="context.MID" DocumentNumber="@context.DocumentNumber"></EntryReversedComponent>
                            }
                            else if (@context.AuthLevelId != 100)
                            {
                                <MudTooltip Text="Verify Protocol">
                                    <MudIconButton OnClick="@(()=> OpenForm(context,true,false))" Color="Color.Warning" Icon="@Icons.Material.Filled.Verified" Size="Size.Small" Variant="Variant.Text" />
                                </MudTooltip>
                            }

                            <MudTooltip Text="Inspect Details">
                                <MudIconButton OnClick="@(()=> OpenForm(context,true,true))" Color="Color.Info" Icon="@Icons.Material.Filled.Visibility" Size="Size.Small" Variant="Variant.Text" />
                            </MudTooltip>

                            <MudTooltip Text="Edit Parameters">
                                <MudIconButton Disabled="@(context.AuthLevelId != null)" OnClick="@(()=> OpenForm(context,false,false))" Color="Color.Primary" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Variant="Variant.Text" />
                            </MudTooltip>

                            <MudTooltip Text="Purge Entry">
                                <MudIconButton Disabled="@(context.AuthLevelId != null)" OnClick="@(()=> Delete(context))" Color="Color.Error" Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Variant="Variant.Text" />
                            </MudTooltip>
                        </div>
                    </MudTd>
                </RowTemplate>
                <PagerContent>
                    <div class="pa-4">
                        <MudTablePager PageSizeOptions="new int[] { 10, 20, 50 }" />
                    </div>
                </PagerContent>
            </MudTable>
        </div>
    </div>
}
}
<br />

}

@code {

    private bool _isLoading = true;
    private DateTime _loadStartTime;

    private ReceiptModel model = new ReceiptModel();
    protected override List<ReceiptModel> collection { get; set; } = new List<ReceiptModel>();
    public bool IsApproved { get; set; } = false;
    private int numberOfRecords = 100;
    private string searchTerm = "";
    private bool _busy;

    public bool HasPermissionReceiptServiceDelete { get; set; } = false;

    protected override DocumentInfoModel DocInfo { get; set; } = new DocumentInfoModel()
        {
            DocumentTypeID = 14,
            DocumentName = "InterBranchReceipt"
        };

    #region SignaIR Notification

    private PushNotificationModel notificationMessage = new PushNotificationModel();
    #endregion

    private int NumberOfRecords
    {
        get => numberOfRecords;
        set
        {
            if (numberOfRecords != value)
            {
                numberOfRecords = value;
                _ = ReloadTable();
            }
        }
    }

    // Method to handle search key up event
    private async Task HandleSearchKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await ReloadTable();
        }
    }

    // Method to reload the table with current filters
    private async Task ReloadTable()
    {
        await GetReceiptBill(IsApproved, NumberOfRecords);
    }

    // Lifecycle method called when the component is initialized
    protected override async Task OnInitializedAsync()
    {        
        _loadStartTime = DateTime.Now;
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionReceiptServiceDelete = await Irole.HasClaim(DocInfo.DocumentTypeID.ToString(), "Edit", ctc.Token);

        await GetReceiptBill(IsApproved, NumberOfRecords);
        await signalRService.StartAsync();
        await Task.Delay(200);
        if (id != null && collection != null && collection.Any(g => g.ReceiptID == id))
        {
            await OpenForm(collection.FirstOrDefault(s => s.ReceiptID == id), true, false);
        }
        await EnsureMinimumLoadTime();
        _isLoading = false;
    }

    private async Task EnsureMinimumLoadTime()
    {
        var elapsed = (DateTime.Now - _loadStartTime).TotalMilliseconds;
        if (elapsed < 100)
        {
            await Task.Delay(100 - (int)elapsed);
        }
    }

    // Method to handle changes in the approval status
    async Task ApprovedChanged(bool value)
    {
        IsApproved = value;
        await GetReceiptBill(IsApproved, NumberOfRecords);
    }

    // Method to fetch receipt bills based on approval status and number of records
    public async Task GetReceiptBill(bool val, int numberOfRecords)
    {
        var authprov = await auth.GetAuthenticationStateAsync();
        var brancIDString = authprov.User.Claims.First(x => x.Type == "BranchID").Value;
        int brancID = int.Parse(brancIDString);
        int NumberOfRecords = numberOfRecords;

        // Fetch approved or unapproved receipts based on the value of 'val'
        if (val)
        {
            collection = Iservice.SelectByApproved(brancID, NumberOfRecords, true, searchTerm).ToList(); // Fetch approved receipts
        }
        else
        {
            collection = Iservice.SelectByUnapproved(brancID, NumberOfRecords, true, searchTerm).ToList(); // Fetch unapproved receipts
        }
    }

    // Method to open the dialog for adding or editing a receipt
    protected override async Task OpenForm(ReceiptModel tds, bool ReadOnly, bool DisableAddition = false)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        _busy = true;

        DialogOptions maxWidth = new DialogOptions() { MaxWidth = MaxWidth.Large, FullWidth = true };
        DialogParameters parms = new DialogParameters();
        parms.Add("model", tds.Clone());
        parms.Add("PageToRedirectLink", "/InterBranchReceiptView");
        parms.Add("ReadOnly", ReadOnly);
        var dialog = await DialogService.ShowAsync<InterBranchReceiptDialog>(tds.ReceiptID == null ? "ADD" : "EDIT", parms, maxWidth);
        var result = await dialog.Result;

        var isCancelled = result.Canceled;
        if (!isCancelled)
        {
            var ReturnData = (ReceiptModel)result.Data;
            notificationMessage.InitiateBranch = new BranchModel() { BranchID = ReturnData.BranchID };
            notificationMessage.ReceivedBranch = new BranchModel() { BranchID = ReturnData.BranchID };
            notificationMessage.MessageTitle = IpushNotificationService.GetMessageTitle(ReturnData.NatureOfTransaction, ReturnData.DocumentNumber, "Level 1 Verification");
            notificationMessage.MessageBody = IpushNotificationService.GetMessageBody(ReturnData.NatureOfTransaction, ReturnData.DocumentNumber, "Level 1 Verification", ReturnData.DocumentDate);
            notificationMessage.RedirectedTo = 0;
            notificationMessage.ExpiredBy = 7;
            notificationMessage.DocumentID = ReturnData.ReceiptID;
            notificationMessage.MessageGroupID = "PendingVerification";
            notificationMessage.PageToRedirectLink = "/InterBranchReceiptView";
            notificationMessage.ClaimValue = "Verify 1";
            notificationMessage.DocumentTypeID = DocInfo.DocumentTypeID;
            notificationMessage.MsgDate = DateTime.Now;
            await signalRService.Send(notificationMessage);
        }
        await GetReceiptBill(IsApproved, NumberOfRecords);

        await Task.Delay(200);
        _busy = false;
    }
    
    // Method to delete a receipt
    private async Task Delete(ReceiptModel model)
    {
        if (HasPermissionReceiptServiceDelete)
        {
            bool? result = await DialogService.ShowMessageBoxAsync(
                "Warning !",
                "Are you sure, you want to delete - " + model.DocumentNumber + " (" + model.DocumentDate + ") ?");
            if (result == true)
            {
                var authprov = await auth.GetAuthenticationStateAsync();
                var User = authprov.User;
                var branchID = int.Parse(User.Claims.First(x => x.Type == "BranchID").Value);
                var UserID = User.Identity.Name;

                // Call the service to delete the receipt
                Iservice.Delete(model.ReceiptID, UserID);
                snackbar.Add("Deleted Successfully", Severity.Success);
            }
            await GetReceiptBill(IsApproved, NumberOfRecords);
        }
        else
        {
            bool? result = await DialogService.ShowMessageBoxAsync(
                "Permission denied!",
                "You don't have any permission to Delete Receipt.");
        }
    }
}

