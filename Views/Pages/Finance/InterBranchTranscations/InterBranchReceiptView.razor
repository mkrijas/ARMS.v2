@page "/InterBranchReceiptView"
@inject IReceiptService Iservice
@inject IOutstandingBillsService OutstandingIservice
@inject ICostCenterService costIservice
@inject IDimensionService dimensionIservice
@inject NavigationManager uriHelper;
@inject MudBlazor.ISnackbar snackbar
@inject AuthenticationStateProvider auth
@attribute [Authorize]
@inject IDialogService DialogService

 <MudGrid Spacing="4">
   <MudItem xs="12">
       
        <MudTable Items="@collection"   Dense="true" Hover="true"  Striped="true" Elevation="10"  @bind-place="model">
             <ToolBarContent>
                <MudText Typo="Typo.h6">InterBranch Receipt</MudText>
                <MudTooltip Text="Add Receipt">
                <MudIconButton  Icon="@Icons.Material.Filled.Add" Title="Add" @onclick="@(()=> OpenDialog(model))"  Color="Color.Dark" Size="Size.Small"></MudIconButton>
                </MudTooltip>
              
                <MudSpacer></MudSpacer>
               
            </ToolBarContent>

            
            <HeaderContent>
                <MudTh><MudTableSortLabel SortBy="new Func<ReceiptModel, object>(x=> x.DocumentDate)" InitialDirection="SortDirection.Ascending">DocumentDate</MudTableSortLabel></MudTh>
             <MudTh><MudTableSortLabel SortBy="new Func<ReceiptModel, object>(x=> x.DocumentNumber)" InitialDirection="SortDirection.Ascending">DocumentNumber</MudTableSortLabel></MudTh>
               <MudTh><MudTableSortLabel SortBy="new Func<ReceiptModel, object>(x=> x.TotalAmount)" InitialDirection="SortDirection.Ascending">TotalAmount</MudTableSortLabel></MudTh>
                
                
                <MudTh>Actions</MudTh> 
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="DocumentDate">@context.DocumentDate</MudTd>
                <MudTd DataLabel="DocumentNumber">@context.DocumentNumber</MudTd>
                <MudTd DataLabel="TotalAmount">@context.TotalAmount</MudTd>
                
                   <MudTd DataLabel="">

                 
                     @if(@context.AuthLevelId==null)
                    {
                    <MudFab @onclick="@(()=> OpenDialog(context))" Color="Color.Primary" title="Edit" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" IconSize="Size.Small" />
                    <MudFab @onclick="@(()=> Delete(context))" Color="Color.Error" title="Delete" Icon="@Icons.Material.Filled.Delete" Size="Size.Small" IconSize="Size.Small" />
                  
                    }
                    @if (@context.AuthLevelId!= 99)
                    {
                    <MudFab @onclick="@(()=> OpenDialogVerify(context))" Color="Color.Warning" Icon="@Icons.Material.Filled.Verified" title="Verify" Size="Size.Small" IconSize="Size.Small" />
                        
                    }
                    <MudFab @onclick="@(()=> OpenDialogView(context))" Color="Color.Info" Icon="@Icons.Material.Filled.GridView" title="View" Size="Size.Small" IconSize="Size.Small" />
                   
                    
              
                    </MudTd>
                 
           
            </RowTemplate>
            <PagerContent>
                <MudTablePager PageSizeOptions="new int[] { 5, 10, 20, 50, 100 }" />
           <MudItem xs="12"md="9"> </MudItem><MudItem xs="12"md="3">
               
        </MudItem>
            </PagerContent>
        </MudTable>
    </MudItem>
    </MudGrid>



     <br />
  
@code {

    private ReceiptModel model = new ReceiptModel();
    private List<ReceiptModel> collection = new List<ReceiptModel>();
    public string value="invisible";
    public string status=null;
    ReceiptModel pmodel=new();
    public bool readvalue = true;
    public bool checkread = false;
    public List<BillsReceiptModel>? bills = new();
    private List<CostCenterModel> costCenter = new();
    private List<DimensionModel> dimension = new();
    DialogOptions maxWidth = new DialogOptions() { MaxWidth = MaxWidth.Large, FullWidth = true };


    protected override async Task OnInitializedAsync()
    {
        costCenter = costIservice.Select().ToList();
        dimension = dimensionIservice.Select().ToList();

        await GetReceiptBill();

    }


    public async Task GetReceiptBill()
    {
        var authprov = await auth.GetAuthenticationStateAsync();
        var brancIDString = authprov.User.Claims.First(x => x.Type == "BranchID").Value;
        int brancID = int.Parse(brancIDString);
        collection = Iservice.SelectInterBranch(brancID).ToList();
    }
   

    private async Task OpenDialog(ReceiptModel tds)
    {
        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;

        DialogParameters parms = new DialogParameters();
        parms.Add("model",tds);
        parms.Add("IsReadOnly",false);
        parms.Add("IsView",false);
        var dialog =  DialogService.Show<InterBranchReceiptDialog>(tds.ReceiptID == null?"ADD":"EDIT",parms,maxWidth);
        var result = await dialog.Result;

        if(!result.Cancelled)
        {   

           await GetReceiptBill();


        }
       await GetReceiptBill();
    }
    private async Task OpenDialogVerify(ReceiptModel tds)
    {
        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;

        DialogParameters parms = new DialogParameters();
        parms.Add("model",tds);
        parms.Add("IsReadOnly",true);
        parms.Add("IsView",false);
        var dialog =  DialogService.Show<InterBranchReceiptDialog>(tds.ReceiptID == null?"ADD":"EDIT",parms,maxWidth);
        var result = await dialog.Result;

        if(!result.Cancelled)
        {   

           await GetReceiptBill();


        }
        await GetReceiptBill();
    }
    private async Task OpenDialogView(ReceiptModel tds)
    {
        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;

        DialogParameters parms = new DialogParameters();
        parms.Add("model",tds);
       parms.Add("IsReadOnly",true);
        parms.Add("IsView",true);
        var dialog =  DialogService.Show<InterBranchReceiptDialog>(tds.ReceiptID == null?"ADD":"EDIT",parms,maxWidth);
        var result = await dialog.Result;

        if(!result.Cancelled)
        {   

           await GetReceiptBill();


        }
        await GetReceiptBill();
    }
    private void Delete(ReceiptModel tx)
    {
        Iservice.Delete(tx.ReceiptID, "Rijas");
        snackbar.Add("Deleted Successfully", Severity.Success);
        GetReceiptBill();
    }
}

