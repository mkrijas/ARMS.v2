                                            </MudItem>
                                            <MudItem xs="1">
                                                @* <MudDivider Style="width:1%; height:100%" Color="Color.Dark" Vertical="true" FlexItem="true" /> *@
                                            </MudItem>
                                            <MudItem xs="1">
                                                <MudNumericField HideSpinButtons
                                                                  Label="Amount" @bind-Value="Model.Amount" Variant="Variant.Outlined" Margin="Margin.Dense"></MudNumericField>
                                             </MudItem>
                                            <MudItem xs="1">
                                                <MudSelect Label="Cr/Dr" @bind-Value="Model.drcrTypeDesc" T="string" Variant="Variant.Outlined" Margin="Margin.Dense" AdornmentColor="Color.Secondary">
                                                    @foreach (var ditem in creditDebitList)
                                                    {
                                                        <MudSelectItem Value="@ditem">@ditem</MudSelectItem>
                                                    }
                                                </MudSelect>
                                            </MudItem>
                                            <MudItem xs="1">
                                            </MudItem>
                                            <MudItem xs="1" Class="d-flex align-center">
                                                <MudIconButton Title="Add" OnClick="ADD" Color="Color.Primary" Icon="@Icons.Material.Filled.Add" Size="Size.Small" />
                                            </MudItem>
                                        }

                                    </MudGrid>
                                </MudItem>


                            </div>
                        </MudItem>
                    }
                </MudGrid>



            </EditForm>
        </MudPaper>
    </FormContent>
    <VerificationStatus>
        <AutherizationStatusComponent DocTypeID="@ContraDocTypeID" DocDate="@DocDate" DocType="@DocType" DocNumber="@DocNumber" PageToRedirectLink="@PageToRedirectLink" DocumentID="model.ID" OnApprove="Approve"></AutherizationStatusComponent>
    </VerificationStatus>
</DialogForm>


