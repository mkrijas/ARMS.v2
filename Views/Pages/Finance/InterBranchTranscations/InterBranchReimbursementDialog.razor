    public void Cancel()
    {
        MudDialog.Cancel();
    }
    public async void Submit()
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is being submitted!", Severity.Warning);
            return;
        }
        _busy = true;

        if (HasPermissionContraServiceEdit)
        {
            try
            {
                decimal? totalCr = 0; 
                decimal? totalDr = 0;
                foreach(var item in model.Particulars)
                {
                    if(item.drcrTypeDesc == "Cr")
                    {
                        totalCr += item.Amount;
                    }
                    else
                    {
                        totalDr += item.Amount;
                    }
                }
                if(totalCr == totalDr)
                {
                    model.BranchID = branchID;
                    model.IsInterBranch = true;
                    model.NatureOfTransaction = "Reimbursement";
                    model.UserInfo.UserID = UserID;
                    var updatedModel = Iservice.Update(model);
                    snackbar.Add("Saved Successfully", Severity.Success);
                    MudDialog.Close(updatedModel);
                }
                else
                {
                    snackbar.Add("Debit and Credit must be equal!", Severity.Error);
                    _busy = false;
                    return;
                }
            }
            catch (Exception ex)
            {
                snackbar.Add(ex.Message, Severity.Error);
            }
        }
        else
        {
            bool? result = await DialogService.ShowMessageBox(
                "Permission denied!",
                "You dont have any permission to Edit Contra.");
        }

        await Task.Delay(200);
        _busy = false;
    }

    public async Task ADD()
    {
        // Model.BranchID = BranchID;
        if (AddTax() && editContext.Validate())
        {
            // if (Model.drcrType == 1)
            //     Model.drcrTypeDesc = "Cr";
            // else
            //     Model.drcrTypeDesc = "Dr";
            
            await OnExpenseAdded.InvokeAsync(Model);
            model.Particulars.Add(Model);
            SetTotalAmt();
            Model = new();
            gstusge = null;
            gstusgeother = null;
        }
        else
        {
            snackbar.Add("Entered particulars are invalid.", Severity.Error);
        }
    }

    private void SetTotalAmt()
    {
        model.TotalAmount = 0;
        foreach(var item in model.Particulars)
        {
            model.TotalAmount = model.TotalAmount + item.Amount + item.CGST + item.SGST + item.IGST;
        }
    }

