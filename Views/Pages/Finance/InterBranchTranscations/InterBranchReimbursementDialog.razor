                                            </MudItem>
                                            <MudItem xs="1">@item.Amount</MudItem>
                                            <MudItem xs="1">@item.drcrTypeDesc</MudItem>
                                            <MudItem xs="1">@(item.CGST + item.SGST + item.IGST)@* /@item.TDS *@</MudItem>
                                            <MudItem xs="1">
                                                @if (!ReadOnly)
                                                {
                                                    <MudIconButton Title="Delete" Color="Color.Error" @onclick="@(()=> DeleteExpenses(@item))" Icon="@Icons.Material.Filled.Delete" Size="Size.Small" />
                                                }
                                                <MudIconButton Title="Show Taxes" Color="Color.Info" @onclick="@(()=> OpenDialogTaxRates(@item))" Icon="@Icons.Material.Filled.CurrencyExchange" Size="Size.Small" />
                                            </MudItem>
                                        }

                                        @if (!ReadOnly && IsView == false)
                                        {
                                            <MudItem xs="1">
                                                <UsageCodeSelector Value=gstusge ValueChanged="UsageCodeSelected"></UsageCodeSelector>
                                            </MudItem>
                                            <MudItem xs="1">
                                                <CostCenterSelector @bind-Value="@Model.CostCenterID" @bind-ValueText="@Model.CostCenterDesc" ReadOnly="@ReadOnly"></CostCenterSelector>
                                            </MudItem>
                                            <MudItem xs="1">
                                                <DimensionSelector @bind-Value="@Model.DimensionID" @bind-ValueText="@Model.DimensionDesc" ReadOnly="@ReadOnly"></DimensionSelector>
                                            </MudItem>
                                            <MudItem xs="1">
                                                @* <MudDivider Style="width:1%; height:100%" Color="Color.Dark" Vertical="true" FlexItem="true" /> *@
                                            </MudItem>

                                            <MudItem xs="1">
                                                <UsageCodeSelector Value=gstusgeother ValueChanged="UsageCodeOtherSelected"></UsageCodeSelector>
                                            </MudItem>
                                            <MudItem xs="1">
                                                <CostCenterSelector @bind-Value="@Model.CostCenterOtherID" @bind-ValueText="@Model.CostCenterOtherDesc" ReadOnly="@ReadOnly"></CostCenterSelector>
                                            </MudItem>
                                            <MudItem xs="1">
