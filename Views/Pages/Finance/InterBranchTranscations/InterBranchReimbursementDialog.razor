                                        {
                                            <MudSelectItem Value="@ditem.BranchID">@ditem.BranchName</MudSelectItem>
                                        }
                                    </MudSelect>
                                </MudItem>
                                <br />
                            </MudGrid>
                        </MudContainer>
                    </MudCard>

                    <MudItem xs="12" md="12">
                        <MudTextField ReadOnly="ReadOnly" @bind-Value="model.Narration" Lines="2" Label="Narration" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.Narration)"></MudTextField>
                    </MudItem>

                    @if (!ReadOnly || IsView == true || ExpenseList.Any())
                    {
