    private async Task OpenDialogTaxRates(ReimbursementSubModel i)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        _busy = true;
        GstModel taxModel = new GstModel();
        taxModel.CGST = i.CGST;
        taxModel.IGST = i.IGST;
        //taxModel.TDS = i.TDS;
        taxModel.SGST = i.SGST;
        taxModel.GstRate = i.GstRate;
        DialogParameters parms = new DialogParameters();
        parms.Add("tax", taxModel);
        parms.Add("ReadOnly", ReadOnly);
        var dialog = DialogService.Show<TaxRatedialog>(i.ReimbursementID == null ? "ADD" : "EDIT", parms, new DialogOptions() { MaxWidth = MaxWidth.Small, FullWidth = true });
        var result = await dialog.Result;
        if (!result.Canceled)
        {
            taxModel = (GstModel)result.Data;
            i.CGST = taxModel.CGST;
            i.IGST = taxModel.IGST;
            //i.TDS = taxModel.TDS;
            i.SGST = taxModel.SGST;
            i.GstRate = taxModel.GstRate;

            await OnAmountChange.InvokeAsync();
        }
        await Task.Delay(200);
        _busy = false;
    }

    private async Task DeleteExpenses(ReimbursementSubModel i)
    {
        int rowIndex = model.Particulars.IndexOf(i);
        model.Particulars.RemoveAt(rowIndex);
        await OnAmountChange.InvokeAsync();
    }

    private bool AddTax()
    {
        if (gstusge != null && Model.Amount != null && gstusgeother != null)
        {
            Model.GstRate = usageIservice.GetGstRate(Model.UsageCode, DateTime.Now) ?? 0;
            Model.GstRate += usageIservice.GetGstRate(Model.UsageCodeOther, DateTime.Now) ?? 0;
            HomeGst = branchservice.GetGstNo(model.BranchID);
            TargetGst = branchservice.GetGstNo(model.OtherBranchID);
            Local = HomeGst.Substring(0, 2) == TargetGst.Substring(0, 2);
            IsTaxable = HomeGst != TargetGst;
            if (!IsTaxable)
            {
                return true;
            }

            decimal taxRate = Model.GstRate.Value;
            
            if (!Local)
            {
                Model.IGST = Math.Round(Model.Amount.Value * taxRate / 100, 2);
            }
            else
            {
                Model.SGST = Model.CGST = Math.Round(Model.Amount.Value * taxRate / 200, 2);
            }
            //decimal tdsRate = tdsService.GetTdsRate(PartyInfo.PartyID, Model.CoaID);
            //Model.TDS = Math.Round((Model.Amount.Value * tdsRate) / 100, 2);
            return true;
        }
        return false;
    }
