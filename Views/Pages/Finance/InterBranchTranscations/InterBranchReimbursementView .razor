@page "/ReimbursementView"
@page "/ReimbursementView/{id:int}"
@using ArmsModels.BaseModels.Finance.Transactions
@using System.Threading;
@attribute [Authorize]
@inject AuthenticationStateProvider auth
@inject NavigationManager uriHelper;
@inject SignalRService signalRService
@inject IReimbursementService Iservice
@inject ICostCenterService costIservice
@inject IDimensionService dimensionIservice
@inject MudBlazor.ISnackbar snackbar
@inject IRoleService<RoleModel> Irole
@inject IDialogService DialogService
@inject IPushNotificationService IpushNotificationService

<MudGrid Spacing="4">
    <MudItem xs="12">
        <MudTable Items="@collection" Dense="true" Hover="true" Striped="true" Elevation="10" @bind-place="model">
            <ToolBarContent>
                <MudText Typo="Typo.h6">Reimbursement / Cross Charge</MudText>
                <MudTooltip Text="New Reimbursement">
                    <MudIconButton Disabled="@_busy" Icon="@Icons.Material.Filled.Add" Title="Add" @onclick="@(()=> OpenDialog(new InterBranchReimbursementModel(),false,false))" Color="Color.Dark" Size="Size.Small"></MudIconButton>
                </MudTooltip>
                <MudSpacer></MudSpacer>
                <MudTextField @bind-Value="searchTerm" Placeholder="Search Contra..." Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0" @onkeyup="HandleSearchKeyUp">
                </MudTextField>
                <div class="tablefont">
                    <span style="margin-right: 10px;">Maximum Records: </span>
                </div>
                <MudItem xs="1">
                    <MudTextField @bind-Value="@NumberOfRecords" Variant="Variant.Outlined" Margin="Margin.Dense" Class="padding5" Style="width: 80px;"></MudTextField>
                </MudItem>
                <MudCheckBox Label="Approved Entries" ValueChanged="((bool value)=>ApprovedChanged(value))" Value="@IsApproved" Size="Size.Medium" Color="Color.Primary" Class="tablefont margin0"></MudCheckBox>
            </ToolBarContent>
            <HeaderContent>
                <MudTh><MudTableSortLabel SortBy="new Func<InterBranchReimbursementModel , object>(x=> x.DocumentDate)" InitialDirection="SortDirection.Ascending">Document Date</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<InterBranchReimbursementModel, object>(x=> x.DocumentNumber)" InitialDirection="SortDirection.Ascending">Document Number</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<InterBranchReimbursementModel, object>(x=> x.NatureOfTransaction)" InitialDirection="SortDirection.Ascending">Nature</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<InterBranchReimbursementModel, object>(x=> x.OtherBranchName)" InitialDirection="SortDirection.Ascending">Target Branch</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<InterBranchReimbursementModel, object>(x=> x.TotalAmount)" InitialDirection="SortDirection.Ascending">Amount</MudTableSortLabel></MudTh>
                <MudTh>Actions</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="DocumentDate">@context.DocumentDate?.ToShortDateString()</MudTd>
                <MudTd DataLabel="DocumentNumber">@context.DocumentNumber</MudTd>
                <MudTd DataLabel="NatureOfTransaction">@context.NatureOfTransaction</MudTd>
                <MudTd DataLabel="OtherBranchName">@context.OtherBranchName</MudTd>
                <MudTd DataLabel="Amount">@context.TotalAmount</MudTd>
                <MudTd DataLabel="">
                    <MudTooltip Text="View">
                        <MudFab @onclick="@(()=> OpenDialog(context,true,true))" Color="Color.Primary" Icon="@Icons.Material.Filled.GridView" Size="Size.Small" IconSize="Size.Small" />
                    </MudTooltip>
                    @if (@context.AuthLevelId == null)
                    {
                        <MudTooltip Text="Edit">
                            <MudFab @onclick="@(()=> OpenDialog(context,false,false))" Color="Color.Primary" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" IconSize="Size.Small" />
                        </MudTooltip>
                        <MudTooltip Text="Verify">
                            <MudFab @onclick="@(()=> OpenDialog(context,true,true))" Color="Color.Warning" Icon="@Icons.Material.Filled.Verified" title="Verify" Size="Size.Small" IconSize="Size.Small" />
                        </MudTooltip>
                        <MudTooltip Text="Delete">
                            <MudFab @onclick="@(()=> Delete(context))" Color="Color.Error" title="Delete" Icon="@Icons.Material.Filled.Delete" Size="Size.Small" IconSize="Size.Small" />
                        </MudTooltip>
                    }
                    @if (@context.AuthLevelId == 99)
                    {
                        <MudTooltip Text="Print">
                            <MudFab @onclick="@(()=> Print(context.ID, context.NatureOfTransaction))" Color="Color.Tertiary" title="Delete" Icon="@Icons.Material.Filled.Print" Size="Size.Small" IconSize="Size.Small" />
                        </MudTooltip>
                    }
                </MudTd>
            </RowTemplate>
            <PagerContent>
                <MudTablePager PageSizeOptions="new int[] { 10, 20, 50, 100 }" />
            </PagerContent>
        </MudTable>
    </MudItem>
</MudGrid>

@code {

    private InterBranchReimbursementModel model = new InterBranchReimbursementModel();
    public bool IsApproved { get; set; } = false;
    private List<InterBranchReimbursementModel> collection = new List<InterBranchReimbursementModel>();
    private int numberOfRecords = 100;
    private string searchTerm = "";
    [Parameter]
    public int? id { get; set; } = null;
    private bool _busy;

    public bool HasPermissionContraServiceDelete { get; set; } = false;
    public bool HasPermissionContraServiceApprove { get; set; } = false;
    public int ContraDocTypeID = 3;

    #region SignaIR Notification

    private PushNotificationModel notificationMessage = new PushNotificationModel();
    #endregion

    private int NumberOfRecords
    {
        get => numberOfRecords;
        set
        {
            if (numberOfRecords != value)
            {
                numberOfRecords = value;
                _ = ReloadTable();
            }
        }
    }

    // Method to handle search key up event
    private async Task HandleSearchKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await ReloadTable();
        }
    }

    // Method to reload the table with current filters
    private async Task ReloadTable()
    {
        await GetAll(IsApproved, NumberOfRecords);
    }

    // Lifecycle method called when the component is initialized
    protected override async Task OnInitializedAsync()
    {
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionContraServiceDelete = await Irole.HasClaim(ContraDocTypeID.ToString(), "Delete", ctc.Token);
        HasPermissionContraServiceApprove = await Irole.HasClaim(ContraDocTypeID.ToString(), "Approve", ctc.Token);

        model = new();
        await GetAll(IsApproved, NumberOfRecords);
        await Task.Delay(200);
        await signalRService.StartAsync();
        if (id != null && collection != null && collection.Any(g => g.ID == id))
        {
            await OpenDialog(collection.FirstOrDefault(s => s.ID == id), false, false);
        }
    }

    // Method to handle changes in the approval status
    async Task ApprovedChanged(bool value)
    {
        IsApproved = value;
        await GetAll(IsApproved, NumberOfRecords);
    }

    // Method to fetch all inter-branch reimbursements based on approval status and number of records
    private async Task GetAll(bool val, int numberOfRecords)
    {
        var authprov = await auth.GetAuthenticationStateAsync();
        var brancIDString = authprov.User.Claims.First(x => x.Type == "BranchID").Value;
        int brancID = int.Parse(brancIDString);
        int NumberOfRecords = numberOfRecords;
        collection = new List<InterBranchReimbursementModel>();

        // Fetch approved or unapproved reimbursements based on the value of 'val'
        if (val)
        {
            collection = Iservice.SelectByApproved(brancID, NumberOfRecords, true, searchTerm).ToList(); // Fetch approved reimbursements
        }
        else
        {
            collection = Iservice.SelectByUnapproved(brancID, NumberOfRecords, true, searchTerm).ToList(); // Fetch unapproved reimbursements
        }
    }

    // Method to delete a reimbursement 
    private async Task Delete(InterBranchReimbursementModel model)
    {
        if (HasPermissionContraServiceDelete)
        {
            bool? result = await DialogService.ShowMessageBox(
                "Warning !",
                "Are you sure, you want to delete - " + model.DocumentNumber + " (" + model.DocumentDate + ") ?");
            if (result == true)
            {
                var authprov = await auth.GetAuthenticationStateAsync();
                var User = authprov.User;
                var UserID = User.Identity.Name;

                // Call the service to delete the reimbursemen
                Iservice.Delete(model.ID, UserID);
                snackbar.Add("Deleted Successfully", Severity.Success);
            }
            await GetAll(IsApproved, NumberOfRecords);
        }
        else
        {
            bool? result = await DialogService.ShowMessageBox(
                "Permission denied!",
                "You don't have any permission to Delete Contra.");
        }
    }

    // Method to approve a reimbursement
    private async Task Approve(InterBranchReimbursementModel tds)
    {
        if (HasPermissionContraServiceApprove)
        {
            var authprov = await auth.GetAuthenticationStateAsync();
            var user = authprov.User;
            model.UserInfo.UserID = user.Identity.Name;
            try
            {
                // Call the service to approve the reimbursement
                Iservice.Approve(tds.ID, model.UserInfo.UserID, "");
                snackbar.Add("Approved Successfully", Severity.Success);
                await GetAll(IsApproved, NumberOfRecords);
            }
            catch (Exception ex)
            {
                snackbar.Add(ex.Message, Severity.Error);
            }
        }
        else
        {
            bool? result = await DialogService.ShowMessageBox(
                "Permission denied!",
                "You don't have any permission to Approve Contra.");
        }
    }

    // Method to open the dialog for adding or editing a reimbursement
    private async Task OpenDialog(InterBranchReimbursementModel tds, bool ReadOnly, bool View)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        _busy = true;

        DialogOptions mediumWidth = new DialogOptions() { MaxWidth = MaxWidth.Large, FullWidth = true };
        DialogParameters parms = new DialogParameters();
        parms.Add("model", tds.Clone());
        parms.Add("ReadOnly", ReadOnly);
        var dialog = DialogService.Show<InterBranchReimbursementDialog>(tds.ID == null ? "ADD" : "EDIT", parms, mediumWidth);
        var result = await dialog.Result;

        var isCancelled = result.Canceled;
        if (!isCancelled)
        {
            var ReturnData = (InterBranchReimbursementModel)result.Data;

        }
        await GetAll(IsApproved, NumberOfRecords);

        await Task.Delay(200);
        _busy = false;
    }

    public string ReportName { get; set; }
    public Dictionary<string, string> ReportParameters { get; set; } = new();

    // Method to print a reimbursement
    private async Task Print(int? ReimbursementID, string NatureOfTransaction)
    {
        ReportParameters.Clear();
        ReportParameters.Add("ReimbursementID", ReimbursementID.ToString());
        var parameters = new DialogParameters();
        parameters.Add("Parameters", ReportParameters); // Add the dictionary as a parameter
        if (NatureOfTransaction == "CROSS CHARGE")
        {
            parameters.Add("ReportName", "PrintCrossChargeInvoice");
        }
        if (NatureOfTransaction == "REIMBURSEMENT" || NatureOfTransaction == "STOCK TRANSFER")
        {
            parameters.Add("ReportName", "PrintReimbursementOrStockTransferInvoice");
        }
        DialogOptions maxWidth = new DialogOptions() { MaxWidth = MaxWidth.Medium, FullWidth = true };
        var result = DialogService.Show<PrintDialog>("PRINT", parameters, maxWidth);
    }
}