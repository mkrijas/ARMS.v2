@page "/ReimbursementView"
@page "/ReimbursementView/{id:int}"
@using System.Threading;
@inject IReimbursementService Iservice
@inherits ViewComponentBase<InterBranchReimbursementModel>


    <div class="fade-in">
        <div class="admin-header-tiered mb-6">
            <div class="d-flex align-center justify-space-between">
                <div>
                    <MudText Typo="Typo.h4" Class="admin-title">Reimbursement & Cross-Charge</MudText>
                    <MudText Typo="Typo.body2" Class="admin-subtitle">Process and manage employee expense reimbursements and cross-branch charges. verify expense claims, assess financial impact, and authorize payouts.</MudText>
                </div>
                <MudButton StartIcon="@Icons.Material.Filled.ReceiptLong" Variant="Variant.Filled" Color="Color.Primary" Class="admin-register-btn" OnClick="@(()=> OpenForm(new InterBranchReimbursementModel(),false,false))" Disabled="@_busy">NEW REIMBURSEMENT</MudButton>
            </div>
        </div>

        <div class="admin-glass-card mb-6 pa-4">
            <div class="d-flex align-center gap-4 flex-wrap">
                <div style="flex-grow: 1; min-width: 300px;">
                    <MudTextField @bind-Value="searchTerm" Placeholder="Search by document number or nature..." Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" Variant="Variant.Outlined" Margin="Margin.Dense" Class="admin-input-group" Clearable="true" OnKeyUp="HandleSearchKeyUp" />
                </div>
                <div class="d-flex align-center gap-4">                 
                    <div class="d-flex align-center bg-glass rounded-pill px-4 py-1">
                        <MudCheckBox T="bool" Label="Approved Entries" ValueChanged="((bool value)=>ToggleData(value))" Value="@ShowApproved" Size="Size.Small" Color="Color.Primary" Class="fw-600" />
                    </div>
                </div>
            </div>
        </div>

        <div class="admin-glass-card pa-0 overflow-hidden">
        <MudTable ServerData="LoadServerData" T="InterBranchReimbursementModel" @ref="_table" Elevation="0" Class="modern-admin-table" Hover="true">
                <LoadingContent>
                <div @key="@("loader")" style="display: flex; justify-content: center; align-items: center; min-height: 400px;">
                    <LoaderComponent IsFullScreen="false"
                                     ShowLogo="false"
                                     Size="large"
                                     LoadingText="Loading...."
                                     SubText="Fetching Data..." />
                </div>
                  </LoadingContent>
                <HeaderContent>
                    <MudTh><MudTableSortLabel SortBy="new Func<InterBranchReimbursementModel , object>(x=> x.DocumentDate)" InitialDirection="SortDirection.Ascending"><span class="admin-header-text">DATE</span></MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<InterBranchReimbursementModel, object>(x=> x.DocumentNumber)"><span class="admin-header-text">DOC NUMBER</span></MudTableSortLabel></MudTh>
                    <MudTh><span class="admin-header-text">NATURE & TARGET</span></MudTh>
                    <MudTh Style="text-align: right;"><span class="admin-header-text">CLAIM AMOUNT</span></MudTh>
                    <MudTh Style="text-align: right;"><span class="admin-header-text">ACTIONS</span></MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Date"><span class="fw-500">@context.DocumentDate?.ToString("dd MMM yyyy")</span></MudTd>
                    <MudTd DataLabel="DocNumber">
                        <div class="d-flex align-center gap-2">
                            <span class="admin-td-primary fw-700">@context.DocumentNumber</span>
                            @if (context.AuthLevelId == 99)
                            {
                                <MudIcon Icon="@Icons.Material.Filled.Verified" Color="Color.Success" Size="Size.Small" />
                            }
                        </div>
                    </MudTd>
                    <MudTd DataLabel="Nature">
                        <div class="d-flex flex-column">
                            <span class="fw-700 small">@context.NatureOfTransaction</span>
                            <div class="d-flex align-center gap-1 opa-60">
                                <MudIcon Icon="@Icons.Material.Filled.Business" Size="Size.Small" />
                                <span class="tiny">@context.OtherBranchName</span>
                            </div>
                        </div>
                    </MudTd>
                    <MudTd DataLabel="Amount" Style="text-align: right;">
                        <span class="fw-800 text-vibrant" style="font-size: 1rem;">@context.TotalAmount?.ToString("N2")</span>
                    </MudTd>
                    <MudTd DataLabel="Actions" Style="text-align: right;">
                        <div class="d-flex justify-end gap-1">
                            @if (@context.AuthLevelId == 99)
                            {
                                <MudTooltip Text="Print Protocol">
                                    <MudIconButton OnClick="@(()=> Print(context.ID, context.NatureOfTransaction))" Color="Color.Tertiary" Icon="@Icons.Material.Filled.Print" Size="Size.Small" Variant="Variant.Text" />
                                </MudTooltip>
                            }
                            else if (@context.AuthLevelId == null)
                            {
                                <MudTooltip Text="Verify Claim">
                                    <MudIconButton OnClick="@(()=> OpenForm(context,true,true))" Color="Color.Warning" Icon="@Icons.Material.Filled.Verified" Size="Size.Small" Variant="Variant.Text" />
                                </MudTooltip>

                                <MudTooltip Text="Edit Parameters">
                                    <MudIconButton OnClick="@(()=> OpenForm(context,false,false))" Color="Color.Primary" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Variant="Variant.Text" />
                                </MudTooltip>

                                <MudTooltip Text="Purge Entry">
                                    <MudIconButton OnClick="@(()=> Delete(context.ID))" Color="Color.Error" Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Variant="Variant.Text" />
                                </MudTooltip>
                            }

                            <MudTooltip Text="Inspect Details">
                                <MudIconButton OnClick="@(()=> OpenForm(context,true,true))" Color="Color.Info" Icon="@Icons.Material.Filled.Visibility" Size="Size.Small" Variant="Variant.Text" />
                            </MudTooltip>
                        </div>
                    </MudTd>
                </RowTemplate>
                <PagerContent>
                    <div class="pa-4">
                        <MudTablePager PageSizeOptions="new int[] { 10, 20, 50 }" />
                    </div>
                </PagerContent>
            </MudTable>
        </div>
    </div>

@code {   
    
     protected override DocumentInfoModel DocInfo { get; set; } = new DocumentInfoModel()
    {
        DocumentTypeID = 3,
        DocumentName = "Reimbersement"
    };
    
    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();
        if (id != null && _collection != null && _collection.Any(g => g.ID == id))
        {
            await OpenForm(_collection.FirstOrDefault(s => s.ID == id), true);
        }
    }
    protected override async Task OpenForm(InterBranchReimbursementModel _model, bool ReadOnly, bool DisableAddition = false)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        _busy = true;

        DialogOptions largeWidth = new DialogOptions() { MaxWidth = MaxWidth.Large, FullWidth = true };
        DialogParameters parms = new DialogParameters();
        parms.Add("model", _model.Clone());        
        parms.Add("ReadOnly", ReadOnly);
        var dialog = await dialogService.ShowAsync<InterBranchReimbursementDialog>(_model.ID == null ? "ADD" : "EDIT", parms, largeWidth);
        var result = await dialog.Result;
        var isCancelled = result.Canceled;
        if (!isCancelled)
        {
            var ReturnData = (InterBranchReimbursementModel)result.Data;
            await _table.ReloadServerData();
        }        
        await Task.Delay(200);
        _busy = false;
    }

    public string ReportName { get; set; }
    public Dictionary<string, string> ReportParameters { get; set; } = new();

    // Method to print a reimbursement
    private async Task Print(int? ReimbursementID, string NatureOfTransaction)
    {
        ReportParameters.Clear();
        ReportParameters.Add("ReimbursementID", ReimbursementID.ToString());
        var parameters = new DialogParameters();
        parameters.Add("Parameters", ReportParameters); // Add the dictionary as a parameter
        if (NatureOfTransaction == "CROSS CHARGE")
        {
            parameters.Add("ReportName", "PrintCrossChargeInvoice");
        }
        if (NatureOfTransaction == "REIMBURSEMENT" || NatureOfTransaction == "STOCK TRANSFER")
        {
            parameters.Add("ReportName", "PrintReimbursementOrStockTransferInvoice");
        }
        DialogOptions maxWidth = new DialogOptions() { MaxWidth = MaxWidth.Medium, FullWidth = true };
        var result = await dialogService.ShowAsync<PrintDialog>("PRINT", parameters, maxWidth);
    }
}

