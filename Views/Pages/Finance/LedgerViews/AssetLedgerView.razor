@page "/AssetLedgerView"
@page "/AssetLedgerView/{AssetID:int}"
@using ArmsModels.BaseModels.Finance.Report;
@using Core.BaseModels.Finance.LedgerViews;
@using Core.IDataServices.Finance.LedgerViews;
@using Microsoft.JSInterop
@using Microsoft.AspNetCore.Components
@using Views.Data;
@using System.Text;
@using System.Net;
@inject AuthenticationStateProvider auth
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject IAssetLedgerViewService AssetLedgerViewService
@inject IAssetService Iasset

<MudGrid Spacing="4">
    <MudItem xs="12">
        <MudPaper Class="mb-5 p-4">
            <MudGrid>
                <MudItem xs="12" md="4" lg="4">
                    <AssetSelector @bind-Value="SelectedAsset" BranchID="BranchID" />
                </MudItem>
                <MudItem xs="12" md="3" lg="3">
                    <MudDatePicker Label="Start Date" @bind-Date="@(StartDate)" />
                </MudItem>
                <MudItem xs="12" md="3" lg="3">
                    <MudDatePicker Label="End Date" @bind-Date="@(EndDate)" />
                </MudItem>
                <MudItem xs="12" md="2" lg="2">
                    <MudButton Size="Size.Large" Variant="Variant.Filled" Color="Color.Success" OnClick="ReloadCollection">Load Data</MudButton>
                </MudItem>
            </MudGrid>
        </MudPaper>
    </MudItem>
</MudGrid>
<MudGrid>
    <MudItem xs="12" md="12" lg="12">
        <MudTable Items="@collection" Dense="true" Hover="true" Striped="true" Elevation="5">
            <ToolBarContent>
                <MudText Typo="Typo.h6">Asset Ledger Collection</MudText>
                <MudSpacer></MudSpacer>
            </ToolBarContent>
            <HeaderContent>
                <MudTh><MudTableSortLabel SortBy="new Func<LedgerViewsModel, object>(x=> x.AccountName)" InitialDirection="SortDirection.Ascending">Account Name</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<LedgerViewsModel, object>(x=> x.Date)" InitialDirection="SortDirection.Ascending">Date</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<LedgerViewsModel, object>(x=> x.Narration)" InitialDirection="SortDirection.Ascending">Remarks</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<LedgerViewsModel, object>(x=> x.Amount)" InitialDirection="SortDirection.Ascending">Amount</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<LedgerViewsModel, object>(x=> x.Refference)" InitialDirection="SortDirection.Ascending">Refference</MudTableSortLabel></MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Account Name">@context.AccountName</MudTd>
                <MudTd DataLabel="Date">@(context.Date?.ToString())</MudTd>
                <MudTd DataLabel="Remarks">@context.Narration</MudTd>
                <MudTd DataLabel="Amount">@(Math.Abs(context.Amount ?? 0)) @(context.DrCrText)</MudTd>
                <MudTd DataLabel="Refference"> @(context.Refference)</MudTd>
            </RowTemplate>
            <PagerContent>
                <MudTablePager PageSizeOptions="new int[] { 10, 20, 50, 100 }" />
            </PagerContent>
        </MudTable>
    </MudItem>
</MudGrid>

@code {

    public DateTime? StartDate { get; set; } = DateTime.Now.AddMonths(-1);
    public DateTime? EndDate { get; set; } = DateTime.Now;
    [Parameter]
    public int? AssetID { get; set; } = null;
    public AssetModel SelectedAsset = new();
    private List<LedgerViewsModel> collection = new List<LedgerViewsModel>();
    private List<AssetModel> AssetList = new();
    public int BranchID { get; set; } = 0;

    // Lifecycle method called when the component is initialized        
    protected override async Task OnInitializedAsync()
    {
        var authprov = await auth.GetAuthenticationStateAsync();
        var brancIDString = authprov.User.Claims.First(x => x.Type == "BranchID").Value;
        BranchID = int.Parse(brancIDString);

        // Load assets based on the branch ID
        AssetList = Iasset.SelectBySubClass(BranchID, null).ToList();
        if (AssetID != null && AssetList.Any(s => s.AssetID == AssetID))
        {
            SelectedAsset = AssetList.FirstOrDefault(s => s.AssetID == AssetID);
        }

        // If a selected asset is available, load its ledger view data
        if (SelectedAsset != null && SelectedAsset.AssetID != null)
        {
            var result = AssetLedgerViewService.SelectByAssetIDAndDate(SelectedAsset.AssetID, StartDate, EndDate);
            if (result != null)
            {
                collection = result.ToList();
            }
        }
    }

    // Method to reload the collection of ledger views based on selected asset and date range
    public void ReloadCollection()
    {
        if (SelectedAsset == null || SelectedAsset.AssetID == 0)
        {
            Snackbar.Add("Please select asset", Severity.Error);
            return;
        }
        if (StartDate == null)
        {
            Snackbar.Add("Please select start date.", Severity.Error);
            return;
        }
        if (EndDate == null)
        {
            Snackbar.Add("Please select end date.", Severity.Error);
            return;
        }

        // Fetch the ledger view data based on the selected asset and date range
        var result = AssetLedgerViewService.SelectByAssetIDAndDate(SelectedAsset.AssetID, StartDate, EndDate);
        if (result != null)
        {
            collection = result.ToList();
        }
    }
}