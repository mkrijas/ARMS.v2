@page "/BankLedgerView"
@page "/BankLedgerView/{BankID:int}"
@using ArmsModels.BaseModels.Finance.Report;
@using Core.BaseModels.Finance.LedgerViews;
@using Core.IDataServices.Finance.LedgerViews;
@using Microsoft.JSInterop
@using Microsoft.AspNetCore.Components
@using Views.Data;
@using System.Text;
@using System.Net;
@inject AuthenticationStateProvider auth
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject IBankLedgerViewService BankLedgerViewService
@inject IBankAccountOwnService IbankOwnservice

<MudGrid Spacing="4">
    <MudItem xs="12">
        <MudPaper Class="mb-5 p-4">
            <MudGrid>

                <MudItem xs="12" lg="4" md="4">
                    <MudSelect Label="Select Bank" @bind-Value="SelectedBank" T="OwnBankModel" Variant="Variant.Outlined" Margin="Margin.Dense" AdornmentColor="Color.Secondary" ToStringFunc="@(e => e == null ? null : $"{e.BankCode}")">
                        @foreach (var item in BankList)
                        {
                            <MudSelectItem Value="@item">@item.BankCode | @item.BankAccountInfo.BankTitle</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" md="3" lg="3">
                    <MudDatePicker Label="Start Date" @bind-Date="@(StartDate)" Variant="Variant.Outlined" Margin="Margin.Dense" />
                </MudItem>
                <MudItem xs="12" md="3" lg="3">
                    <MudDatePicker Label="End Date" @bind-Date="@(EndDate)" Variant="Variant.Outlined" Margin="Margin.Dense" />
                </MudItem>
                <MudItem xs="12" md="2" lg="2">
                    <MudButton Size="Size.Large" Variant="Variant.Filled" Color="Color.Success" OnClick="ReloadCollection">Load Data</MudButton>
                </MudItem>
            </MudGrid>
        </MudPaper>
    </MudItem>
</MudGrid>
<MudGrid>
    <MudItem xs="12" md="12" lg="12">
        <MudTable Items="@collection" Dense="true" Hover="true" Striped="true" Elevation="5">
            <ToolBarContent>
                <MudText Typo="Typo.h6">Bank Ledger Collection</MudText>
                <MudSpacer></MudSpacer>
            </ToolBarContent>
            <HeaderContent>
                <MudTh><MudTableSortLabel SortBy="new Func<LedgerViewsModel, object>(x=> x.AccountName)" InitialDirection="SortDirection.Ascending">Account Name</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<LedgerViewsModel, object>(x=> x.Date)" InitialDirection="SortDirection.Ascending">Date</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<LedgerViewsModel, object>(x=> x.Narration)" InitialDirection="SortDirection.Ascending">Remarks</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<LedgerViewsModel, object>(x=> x.Amount)" InitialDirection="SortDirection.Ascending">Amount</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<LedgerViewsModel, object>(x=> x.Refference)" InitialDirection="SortDirection.Ascending">Refference</MudTableSortLabel></MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Account Name">@context.AccountName</MudTd>
                <MudTd DataLabel="Date">@(context.Date?.ToString())</MudTd>
                    <MudTd DataLabel="Remarks">@context.Narration</MudTd>
                    <MudTd DataLabel="Amount">@(Math.Abs(context.Amount ?? 0)) @(context.DrCrText)</MudTd>
                    <MudTd DataLabel="Refference"> @(context.Refference)</MudTd>
                </RowTemplate>
                <PagerContent>
                    <MudTablePager PageSizeOptions="new int[] { 5, 10, 20, 50, 100 }" />
                </PagerContent>
            </MudTable>
        </MudItem>
    </MudGrid>

    @code {

    public DateTime? StartDate { get; set; } = DateTime.Now.AddMonths(-1);
    public DateTime? EndDate { get; set; } = DateTime.Now;
    [Parameter]
    public int? BankID { get; set; } = null;
    public OwnBankModel SelectedBank = new();
    public LedgerTransactionsReportMoreParameterModel MoreParameter { get; set; } = new();
    private List<LedgerViewsModel> collection = new List<LedgerViewsModel>();
    private List<OwnBankModel> BankList = new List<OwnBankModel>();

    protected override async Task OnInitializedAsync()
    {

        var authprov = await auth.GetAuthenticationStateAsync();
        var branchID = int.Parse(authprov.User.Claims.First(x => x.Type == "BranchID").Value);
        BankList = IbankOwnservice.Select(branchID).ToList();
        if (BankID != null && BankList.Any(s => s.ID == BankID))
        {
            SelectedBank = BankList.FirstOrDefault(s => s.ID == BankID);
        }
        if (SelectedBank != null && SelectedBank.ID != null)
        {
            var result = BankLedgerViewService.SelectByBankIDAndDate(SelectedBank.ID, StartDate, EndDate);
            if (result != null)
            {
                collection = result.ToList();
            }

        }
    }


    public void ReloadCollection()
    {
        if (SelectedBank == null || SelectedBank.ID == 0)
        {
            Snackbar.Add("Please select bank", Severity.Error);
            return;
        }
        if (StartDate == null)
        {
            Snackbar.Add("Please select start date.", Severity.Error);
            return;
        }
        if (EndDate == null)
        {
            Snackbar.Add("Please select end date.", Severity.Error);
            return;
        }

        var result = BankLedgerViewService.SelectByBankIDAndDate(SelectedBank.ID, StartDate, EndDate);
        if (result != null)
        {
            collection = result.ToList();
        }
    }
}

