@page "/BankLedgerView"
@page "/BankLedgerView/{BankID:int}"
@using ArmsModels.BaseModels.Finance.Report;
@using Core.BaseModels.Finance.LedgerViews;
@using Core.IDataServices.Finance.LedgerViews;
@using Microsoft.JSInterop
@using Microsoft.AspNetCore.Components
@using Views.Data;
@using System.Text;
@using System.Net;
@using System.Threading;
@inject AuthenticationStateProvider auth
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject IBankLedgerViewService BankLedgerViewService
@inject IBankAccountOwnService IbankOwnservice

@if (_isLoading)
{
    <LoaderComponent IsFullScreen="true" 
                    ShowLogo="false" 
                    Size="medium" 
                    LoadingText="Loading Bank Ledger" 
                    SubText="Please wait..." />
}
else
{
    <div class="admin-page-container">
        <div class="admin-header-tiered mb-6">
            <div class="d-flex align-center justify-space-between">
                <div>
                    <MudText Typo="Typo.h4" Class="admin-title">Bank Ledger</MudText>
                    <MudText Typo="Typo.body2" Class="admin-subtitle">Monitor transaction histories, bank reconciliations, and cash flows for individual company accounts.</MudText>
                </div>
            </div>
        </div>

        <div class="admin-glass-card mb-6 pa-6">
            <div class="d-flex flex-wrap align-end gap-4">
                <div style="flex: 2; min-width: 300px;">
                    <MudAutocomplete Label="Select Bank" @bind-Value="SelectedBank" SearchFunc="SearchBanks" T="OwnBankModel" Variant="Variant.Outlined" Margin="Margin.Dense" AdornmentColor="Color.Primary" Class="admin-input-group" ToStringFunc="@(e => (e == null) ? null :( string.IsNullOrEmpty(e.BankAccountInfo.BankTitle) ? "" : string.Format("{0} | {1}",e.BankCode,e.BankAccountInfo.BankTitle)))" />
                </div>
                <div style="flex: 1; min-width: 150px;">
                    <MudDatePicker Label="Start Date" @bind-Date="@(StartDate)" Variant="Variant.Outlined" Margin="Margin.Dense" Color="Color.Primary" />
                </div>
                <div style="flex: 1; min-width: 150px;">
                    <MudDatePicker Label="End Date" @bind-Date="@(EndDate)" Variant="Variant.Outlined" Margin="Margin.Dense" Color="Color.Primary" />
                </div>
                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="ReloadCollection" Class="admin-register-btn" Style="height: 40px;">LOAD DATA</MudButton>
            </div>
        </div>
        <div class="admin-glass-card pa-0 overflow-hidden">
            <MudTable Items="@collection" Dense="true" Hover="true" Elevation="0" Class="modern-admin-table">
                <HeaderContent>
                    <MudTh><MudTableSortLabel SortBy="new Func<LedgerViewsModel, object>(x=> x.AccountName)" InitialDirection="SortDirection.Ascending"><span class="admin-header-text">ACCOUNT NAME</span></MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<LedgerViewsModel, object>(x=> x.Date)" InitialDirection="SortDirection.Ascending"><span class="admin-header-text">DATE</span></MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<LedgerViewsModel, object>(x=> x.Narration)" InitialDirection="SortDirection.Ascending"><span class="admin-header-text">REMARKS</span></MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<LedgerViewsModel, object>(x=> x.Amount)" InitialDirection="SortDirection.Ascending"><span class="admin-header-text">AMOUNT</span></MudTableSortLabel></MudTh>
                    <MudTh Style="text-align: right;"><span class="admin-header-text">REFERENCE</span></MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Account Name"><MudText Typo="Typo.body2" Class="admin-td-primary">@context.AccountName</MudText></MudTd>
                    <MudTd DataLabel="Date">@(context.Date?.ToString("dd MMM yyyy"))</MudTd>
                    <MudTd DataLabel="Remarks"><MudText Typo="Typo.body2" Class="admin-td-secondary">@context.Narration</MudText></MudTd>
                    <MudTd DataLabel="Amount"><MudText Typo="Typo.body2" Class="admin-td-amount">@(Math.Abs(context.Amount ?? 0)) @(context.DrCrText)</MudText></MudTd>
                    <MudTd DataLabel="Reference" Style="text-align: right;">@(context.Refference)</MudTd>
                </RowTemplate>
                <PagerContent>
                    <div class="pa-4">
                        <MudTablePager PageSizeOptions="new int[] { 10, 20, 50, 100 }" />
                    </div>
                </PagerContent>
            </MudTable>
        </div>
    </div>
}

@code {

    private bool _isLoading = true;
    private DateTime _loadStartTime;

    public DateTime? StartDate { get; set; } = DateTime.Now.AddMonths(-1);
    public DateTime? EndDate { get; set; } = DateTime.Now;
    [Parameter]
    public int? BankID { get; set; } = null;
    public OwnBankModel SelectedBank = new();
    public LedgerTransactionsReportMoreParameterModel MoreParameter { get; set; } = new();
    private List<LedgerViewsModel> collection = new List<LedgerViewsModel>();
    private List<OwnBankModel> BankList = new List<OwnBankModel>();

    // Lifecycle method called when the component is initialized
    protected override async Task OnInitializedAsync()
    {
        _loadStartTime = DateTime.Now;

        var authprov = await auth.GetAuthenticationStateAsync();
        var branchID = int.Parse(authprov.User.Claims.First(x => x.Type == "BranchID").Value);

        // Load banks based on the branch ID
        BankList = IbankOwnservice.Select(branchID).ToList();
        if (BankID != null && BankList.Any(s => s.ID == BankID))
        {
            SelectedBank = BankList.FirstOrDefault(s => s.ID == BankID);
        }

        // Load ledger view data if a selected bank is available
        if (SelectedBank != null && SelectedBank.ID != null)
        {
            var result = BankLedgerViewService.SelectByBankIDAndDate(SelectedBank.ID, StartDate, EndDate);
            if (result != null)
            {
                collection = result.ToList();
            }

        }
        await EnsureMinimumLoadTime();
        _isLoading = false;
    }

    private async Task EnsureMinimumLoadTime()
    {
        var elapsed = (DateTime.Now - _loadStartTime).TotalMilliseconds;
        if (elapsed < 100)
        {
            await Task.Delay(100 - (int)elapsed);
        }
    }

    // Method to reload the collection of ledger views based on selected bank and date range
    public void ReloadCollection()
    {
        if (SelectedBank == null || SelectedBank.ID == 0)
        {
            Snackbar.Add("Please select bank", Severity.Error);
            return;
        }
        if (StartDate == null)
        {
            Snackbar.Add("Please select start date.", Severity.Error);
            return;
        }
        if (EndDate == null)
        {
            Snackbar.Add("Please select end date.", Severity.Error);
            return;
        }

        // Fetch the ledger view data based on the selected bank and date range
        var result = BankLedgerViewService.SelectByBankIDAndDate(SelectedBank.ID, StartDate, EndDate);
        if (result != null)
        {
            collection = result.ToList();
        }
    }
    
    // Method to search for banks based on a search string
    private async Task<IEnumerable<OwnBankModel>> SearchBanks(string searchString, CancellationToken token)
    {
        if (string.IsNullOrEmpty(searchString))
            return BankList;

        return await Task.FromResult(BankList.Where(x => x.BankAccountInfo.BankTitle.Contains(searchString, StringComparison.InvariantCultureIgnoreCase) || x.BankCode.Contains(searchString, StringComparison.InvariantCultureIgnoreCase)));

    }
}
