@page "/PartyLedgerView"
@using ArmsModels.BaseModels.Finance.Report;
@using Microsoft.JSInterop
@using Microsoft.AspNetCore.Components
@using Views.Data;
@using System.Text;
@using System.Net;
@inject AuthenticationStateProvider auth
@inject IBranchService Ibranchservice
@inject ISnackbar Snackbar
@inject IDialogService DialogService

<MudGrid Spacing="4">
    <MudItem xs="12">
        <MudPaper Class="mb-5 p-4">
            <MudGrid>
                <MudItem xs="6" md="6">
                    <PartySelector @bind-Value="SelectedParty" LabelName="Select Party" IsFetchAll="true" />
                </MudItem>
                <MudItem xs="4" md="4">
                    <MudDatePicker Label="Start Date" @bind-Date="@(StartDate)" />
                </MudItem>
                <MudItem xs="4" md="4">
                    <MudDatePicker Label="End Date" @bind-Date="@(EndDate)" />
                </MudItem>
                <MudItem xs="2" md="2">
                    <MudButton Style="margin-top:9%;" Variant="Variant.Filled" Color="@(IsMoreParameterHasValues ?Color.Success:Color.Primary)" OnClick="OpenDialogAddOrEditReference">
                        Add More @(IsMoreParameterHasValues ? "(Has Value)" : "")
                    </MudButton>
                </MudItem>
                <MudItem xs="2" md="2">
                    <MudButton Style="margin-top:9%;" Variant="Variant.Filled" Color="Color.Success" OnClick="RenderReportViewer">View Report</MudButton>
                </MudItem>
            </MudGrid>
        </MudPaper>
    </MudItem>
</MudGrid>
<MudGrid Style="@(ShowReport?"":"Display:none")">
    <MudItem xs="12">
        <ReportViewer ReportName="@ReportName" Parameters=@ReportParameters></ReportViewer>
    </MudItem>
</MudGrid>

@code {

