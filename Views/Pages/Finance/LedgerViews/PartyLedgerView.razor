@page "/PartyLedgerView"
@page "/PartyLedgerView/{PartyID:int}"
@using ArmsModels.BaseModels.Finance.Report;
@using Core.BaseModels.Finance.LedgerViews;
@using Core.IDataServices.Finance.LedgerViews;
@using Microsoft.JSInterop
@using Microsoft.AspNetCore.Components
@using Views.Data;
@using System.Text;
@using System.Net;
@attribute [Authorize]
@inject AuthenticationStateProvider auth
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject IPartyLedgerViewService PartyLedgerViewService
@inject IPartyService partyIservice
<MudGrid Spacing="4">
    <MudItem xs="12">
        <MudPaper Class="mb-5 p-4">
            <MudGrid>
                <MudItem xs="12" md="4" lg="4">
                    <PartySelector @bind-Value="SelectedParty" />
                </MudItem>
                <MudItem xs="12" md="3" lg="3">
                    <MudDatePicker Variant="Variant.Outlined" Margin="Margin.Dense" Label="Start Date" @bind-Date="@(StartDate)" />
                </MudItem>
                <MudItem xs="12" md="3" lg="3">
                    <MudDatePicker Variant="Variant.Outlined" Margin="Margin.Dense" Label="End Date" @bind-Date="@(EndDate)" />
                </MudItem>
                <MudItem xs="12" md="2" lg="2">
                    <MudButton Size="Size.Large" Variant="Variant.Filled" Color="Color.Success" OnClick="ReloadCollection">Load Data</MudButton>
                </MudItem>
            </MudGrid>
        </MudPaper>
    </MudItem>
</MudGrid>
<MudGrid>
    <MudItem xs="12" md="12" lg="12">
        <MudTable Items="@collection" Dense="true" Hover="true" Striped="true" Elevation="5">
            <ToolBarContent>
                <MudText Typo="Typo.h6">Party Ledger Collection</MudText>
                <MudSpacer></MudSpacer>
            </ToolBarContent>
            <HeaderContent>
                <MudTh><MudTableSortLabel SortBy="new Func<LedgerViewsModel, object>(x=> x.AccountName)" InitialDirection="SortDirection.Ascending">Account Name</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<LedgerViewsModel, object>(x=> x.Date)" InitialDirection="SortDirection.Ascending">Date</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<LedgerViewsModel, object>(x=> x.Narration)" InitialDirection="SortDirection.Ascending">Remarks</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<LedgerViewsModel, object>(x=> x.Amount)" InitialDirection="SortDirection.Ascending">Amount</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<LedgerViewsModel, object>(x=> x.Refference)" InitialDirection="SortDirection.Ascending">Refference</MudTableSortLabel></MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Account Name">@context.AccountName</MudTd>
                <MudTd DataLabel="Date">@(context.Date?.ToString())</MudTd>
                    <MudTd DataLabel="Narration">@context.Narration</MudTd>
                    <MudTd DataLabel="Amount">@(Math.Abs(context.Amount ?? 0)) @(context.DrCrText)</MudTd>
                    <MudTd DataLabel="Refference"> @(context.Refference)</MudTd>
                </RowTemplate>
                <PagerContent>
                    <MudTablePager PageSizeOptions="new int[] { 5, 10, 20, 50, 100 }" />
                </PagerContent>
            </MudTable>
        </MudItem>
    </MudGrid>

    @code {

    public DateTime? StartDate { get; set; } = DateTime.Now.AddMonths(-1);
    public DateTime? EndDate { get; set; } = DateTime.Now;
    [Parameter]
    public int? PartyID { get; set; } = null;
    public PartyModel SelectedParty = new();
    public LedgerTransactionsReportMoreParameterModel MoreParameter { get; set; } = new();
    public bool IsMoreParameterHasValues { get; set; } = false;
    private List<LedgerViewsModel> collection = new List<LedgerViewsModel>();

    private List<PartyModel> partyList = new();

    protected override void OnInitialized()
    {
        partyList = partyIservice.SelectByCode(null, null).ToList();
        if (PartyID != null && partyList.Any(s => s.PartyID == PartyID))
        {
            SelectedParty = partyList.FirstOrDefault(s => s.PartyID == PartyID);
        }
        if (SelectedParty != null && SelectedParty.PartyID != null)
        {
            var result = PartyLedgerViewService.SelectByPartyIDAndDate(SelectedParty.PartyID, StartDate, EndDate);
            if (result != null)
            {
                collection = result.ToList();
            }
        }
    }

    public void ReloadCollection()
    {
        if (SelectedParty == null || SelectedParty.PartyID == 0)
        {
            Snackbar.Add("Please select party", Severity.Error);
            return;
        }
        if (StartDate == null)
        {
            Snackbar.Add("Please select start date.", Severity.Error);
            return;
        }
        if (EndDate == null)
        {
            Snackbar.Add("Please select end date.", Severity.Error);
            return;
        }

        var result = PartyLedgerViewService.SelectByPartyIDAndDate(SelectedParty.PartyID, StartDate, EndDate);
        if (result != null)
        {
            collection = result.ToList();
        }
    }
}