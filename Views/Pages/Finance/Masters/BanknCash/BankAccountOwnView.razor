@page "/BankAccountOwnView"
@inject IBankAccountOwnService Iservice
@inject MudBlazor.ISnackbar snackbar

@inject AuthenticationStateProvider auth
@attribute [Authorize]
@inject IDialogService DialogService

@inject Microsoft.AspNetCore.Components.NavigationManager navigationManager


<style>
    .selected {
        background-color: #1E88E5 !important;
    }

        .selected > td {
            color: white !important;
        }

            .selected > td .mud-input {
                color: white !important;
            }
</style>

<MudGrid Spacing="4">
    <MudItem xs="12">
        <MudTable Items="@collection" Dense="true" Hover="true" Striped="true" Elevation="10" @bind-place="model" @ref="mudTable" RowClassFunc="@SelectedRowClassFunc" T="OwnBankModel">

            <ToolBarContent>
                <MudText Typo="Typo.h6">BankAccount Own </MudText>
                <MudTooltip Text="New Sundry Paymnet">
                    <MudIconButton Icon="@Icons.Material.Filled.Add" Title="Add" @onclick="@(()=> OpenDialog(model))" Color="Color.Dark" Size="Size.Small"></MudIconButton>
                </MudTooltip>


                <MudSpacer></MudSpacer>

            </ToolBarContent>
            <HeaderContent>
                <MudTh><MudTableSortLabel SortBy="new Func<OwnBankModel, object>(x=> x.BankAccountInfo.BankTitle)" InitialDirection="SortDirection.Ascending">Title</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<OwnBankModel, object>(x=> x.BankAccountInfo.BeneficiaryName)" InitialDirection="SortDirection.Ascending">BeneficiaryName</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<OwnBankModel, object>(x=> x.BankAccountInfo.AccountNumber)" InitialDirection="SortDirection.Ascending">AccountNumber</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<OwnBankModel, object>(x=> x.BankAccountInfo.BankBranch)" InitialDirection="SortDirection.Ascending">Branch</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<OwnBankModel, object>(x=> x.BankCode)" InitialDirection="SortDirection.Ascending">BankCode</MudTableSortLabel></MudTh>

                <MudTh>Actions</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Title">@context.BankAccountInfo.BankTitle</MudTd>
                <MudTd DataLabel="BeneficiaryName">@context.BankAccountInfo.BeneficiaryName</MudTd>
                <MudTd DataLabel="AccountNumber">@context.BankAccountInfo.AccountNumber</MudTd>
                <MudTd DataLabel="Branch">@context.BankAccountInfo.BankBranch</MudTd>
                <MudTd DataLabel="BankCode">@context.BankCode</MudTd>
                <MudTd DataLabel="">
                    <MudTooltip Text="Edit">
                        <MudFab @onclick="@(()=> OpenDialog(context))" Color="Color.Primary" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" IconSize="Size.Small" />
                    </MudTooltip>
                    
                    <MudTooltip Text="UnRecounciledBankEntry">
                        <MudFab @onclick="@(()=> RedirectToUnRecounciledBankEntry(context))" Color="Color.Primary" Icon="@Icons.Material.Filled.TableView" Size="Size.Small" IconSize="Size.Small" />
                    </MudTooltip>
                </MudTd>
            </RowTemplate>

            <PagerContent>
                <MudTablePager PageSizeOptions="new int[] { 5, 10, 20, 50, 100 }" />
                @*  <MudButton OnClick="selected" Variant="Variant.Filled" Color="Color.Success" ButtonType="ButtonType.Submit">Submit</MudButton>*@

            </PagerContent>
        </MudTable>

    </MudItem>
</MudGrid>
<MudGrid>
    <MudItem>
        @if (ShowUnReconciledBankEntry)
        {
            <UnReconciledBankEntryView bankModel="unRecounciledBankEntry" @ref="child" />
        }
    </MudItem>
</MudGrid>

@code {
    private OwnBankModel model = new OwnBankModel();

    private List<OwnBankModel> collection = new List<OwnBankModel>();
    DialogOptions mediumWidth = new DialogOptions() { MaxWidth = MaxWidth.Medium, FullWidth = true };
    protected override async Task OnInitializedAsync()
    {
        model = new();
        GetAll();
    }

    private void GetAll()
    {

        collection = new List<OwnBankModel>();
        foreach (var item in Iservice.Select())
        {
            collection.Add(item);
        }


    }
    public async Task OpenDialog(OwnBankModel ownBank)
    {
        //var authprov = await auth.GetAuthenticationStateAsync();
        //var user = authprov.User;
        //var brancIDString = authprov.User.Claims.First(x => x.Type == "BranchID").Value;

        //model.UserInfo.UserID = user.Identity.Name;
        //model.BranchID = int.Parse(brancIDString);
        DialogParameters parms = new DialogParameters();
        parms.Add("model", ownBank);
        var dialog = DialogService.Show<BankAccountOwnDialog>(ownBank.ID == null ? "ADD" : "EDIT", parms, mediumWidth);
        var result = await dialog.Result;

        if (!result.Canceled)
        {
            try
            {
                OwnBankModel UpdatedModel = (OwnBankModel)result.Data;
                Iservice.Update(UpdatedModel);
                snackbar.Add("Saved Successfully", Severity.Success);
                GetAll();
            }
            catch (Exception ex)
            {
                snackbar.Add(ex.Message, Severity.Error);
            }
        }     
    }


    UnReconciledBankEntryView child;
    int PreviousBankId = 0;
    public OwnBankModel unRecounciledBankEntry { get; set; }
    public bool ShowUnReconciledBankEntry { get; set; }
    void ShowModal()
    {
        ShowUnReconciledBankEntry = true;
    }

    void HideModal()
    {
        ShowUnReconciledBankEntry = false;
    }
    public void RedirectToUnRecounciledBankEntry(OwnBankModel bankModel)
    {
        unRecounciledBankEntry = bankModel;
        if (ShowUnReconciledBankEntry)
        {
            ShowUnReconciledBankEntry = false;
        }
        else
        {
            ShowUnReconciledBankEntry = false;
            ShowUnReconciledBankEntry = true;
        }

        if (bankModel != null && bankModel.ID != null)
        {

            if (PreviousBankId != (int)bankModel.ID)
            {
                ShowUnReconciledBankEntry = false;
                ShowUnReconciledBankEntry = true;
            }
            PreviousBankId = (int)bankModel.ID;

        }

        //model = new();
        //GetAll();
    }
    


    private int selectedRowNumber = -1;
    private MudTable<OwnBankModel> mudTable;
    private List<string> clickedEvents = new();
    


    private string SelectedRowClassFunc(OwnBankModel element, int rowNumber)
    {
     if (unRecounciledBankEntry != null && unRecounciledBankEntry.Equals(element))
        {
            selectedRowNumber = rowNumber;
            return "selected";
        }
        else
        {
            return string.Empty;
        }
    }
}
