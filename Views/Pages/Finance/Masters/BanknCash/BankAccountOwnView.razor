@page "/BankAccountOwnView"
@inject IBankAccountOwnService Iservice
@inject MudBlazor.ISnackbar snackbar
@inject AuthenticationStateProvider auth
@attribute [Authorize]
@using System.Threading;
@inject IRoleService<RoleModel> Irole
@inject IDialogService DialogService
@inject NavigationManager NavigationManager
@inject NavigationManager nav
@inject Microsoft.AspNetCore.Components.NavigationManager navigationManager


<style>
    .selected {
        background-color: #1E88E5 !important;
    }

        .selected > td {
            color: white !important;
        }

            .selected > td .mud-input {
                color: white !important;
            }

    .disabled-row {
        background-color: #bec2bf !important;
        color: #828894 !important;
    }
</style>

<MudGrid Spacing="4">
    <MudItem xs="12">
        <MudTable Items="@collection" Dense="true" Hover="true" Striped="true" Elevation="10" @bind-place="model" @ref="mudTable" RowClassFunc="@RowClassFunc" T="OwnBankModel">
            <ToolBarContent>
                <MudText Typo="Typo.h6">Own Bank Accounts</MudText>
                <MudTooltip Text="New Sundry Paymnet">
                    <MudIconButton Disabled="@_busy" Icon="@Icons.Material.Filled.Add" Title="Add" @onclick="@(()=> OpenDialog(model))" Color="Color.Dark" Size="Size.Small"></MudIconButton>
                </MudTooltip>
                <MudSpacer></MudSpacer>
            </ToolBarContent>
            <HeaderContent>
                <MudTh><MudTableSortLabel SortBy="new Func<OwnBankModel, object>(x=> x.BankAccountInfo.BankTitle)" InitialDirection="SortDirection.Ascending">Title</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<OwnBankModel, object>(x=> x.BankAccountInfo.BeneficiaryName)" InitialDirection="SortDirection.Ascending">Beneficiary Name</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<OwnBankModel, object>(x=> x.BankAccountInfo.AccountNumber)" InitialDirection="SortDirection.Ascending">Account Number</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<OwnBankModel, object>(x=> x.BankAccountInfo.BankBranch)" InitialDirection="SortDirection.Ascending">Branch</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<OwnBankModel, object>(x=> x.BankCode)" InitialDirection="SortDirection.Ascending">BankCode</MudTableSortLabel></MudTh>
                <MudTh>Is Disable</MudTh>
                <MudTh>Actions</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Title">@context.BankAccountInfo.BankTitle</MudTd>
                <MudTd DataLabel="BeneficiaryName">@context.BankAccountInfo.BeneficiaryName</MudTd>
                <MudTd DataLabel="AccountNumber">@context.BankAccountInfo.AccountNumber</MudTd>
                <MudTd DataLabel="Branch">@context.BankAccountInfo.BankBranch</MudTd>
                <MudTd DataLabel="BankCode">@context.BankCode</MudTd>
                <MudTd DataLabel="">
                    <MudTooltip Text="Disable">
                        <MudSwitch Checked="@context.IsDisabled" Color="Color.Primary" T="bool?" CheckedChanged="@(async (bool? e) => await DisableAccount(e,context.ID))"></MudSwitch>
                    </MudTooltip>
                </MudTd>
                <MudTd DataLabel="">
                    <MudTooltip Text="Edit">
                        <MudFab @onclick="@(()=> OpenDialog(context))" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Edit" Size="Size.Small" />
                    </MudTooltip>
                    <MudTooltip Text="UnRecounciled Bank Entry">
                        <MudFab @onclick="@(()=> RedirectToUnRecounciledBankEntry(context))" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Grid3x3" Size="Size.Small" />
                    </MudTooltip>
                    <MudTooltip Text="Cheque Books">
                        <MudFab OnClick="@(() => nav.NavigateTo("chequebook/" + context.ID.ToString()))" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Newspaper" Size="Size.Small" />
                    </MudTooltip>
                    @* <MudTooltip Text="Bank Ledger Views">
                        <MudFab @onclick="@(()=> OpenBankLedgerViews(context))" Color="Color.Primary" StartIcon="@Icons.Material.Filled.TableView" Size="Size.Small" />
                    </MudTooltip> *@
                </MudTd>
            </RowTemplate>
            <PagerContent>
                <MudTablePager PageSizeOptions="new int[] { 10, 20, 50, 100 }" />
            </PagerContent>
        </MudTable>
    </MudItem>
</MudGrid>
@if (ShowUnReconciledBankEntry)
{
    <UnReconciledBankEntryView bankModel="unRecounciledBankEntry" @ref="child" />
}

@code {

    private OwnBankModel model = new OwnBankModel();
    private List<OwnBankModel> collection = new List<OwnBankModel>();
    DialogOptions mediumWidth = new DialogOptions() { MaxWidth = MaxWidth.Medium, FullWidth = true };
    private bool _busy;

    public bool HasPermissionBankAccountOwnServiceEdit { get; set; } = false;
    public int BankAccountOwnDocTypeID = 109;

    // Lifecycle method called when the component is initialized
    protected override async Task OnInitializedAsync()
    {
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionBankAccountOwnServiceEdit = await Irole.HasClaim(BankAccountOwnDocTypeID.ToString(), "Edit", ctc.Token);

        model = new();
        await GetAll();
    }

    // Method to fetch all bank accounts
    private async Task GetAll()
    {
        var authprov = await auth.GetAuthenticationStateAsync();
        var branchIDString = authprov.User.Claims.First(x => x.Type == "BranchID").Value;
        int branchID = int.Parse(branchIDString);

        collection = new List<OwnBankModel>();

        // Load bank accounts for the specified branch
        foreach (var item in Iservice.SelectSelectByBranchALL(branchID))
        {
            collection.Add(item);
        }
    }

    // Method to open the dialog for adding or editing a bank account
    public async Task OpenDialog(OwnBankModel ownBank)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        _busy = true;

        if (HasPermissionBankAccountOwnServiceEdit)
        {
            DialogParameters parms = new DialogParameters();
            parms.Add("model", ownBank.Clone());
            var dialog = DialogService.Show<BankAccountOwnDialog>(ownBank.ID == null ? "ADD" : "EDIT", parms, mediumWidth);
            var result = await dialog.Result;
            if (!result.Canceled)
            {
                try
                {
                    OwnBankModel UpdatedModel = (OwnBankModel)result.Data;
                    Iservice.Update(UpdatedModel); // Update the bank account
                    snackbar.Add("Saved Successfully", Severity.Success);
                    await GetAll();
                }
                catch (Exception ex)
                {
                    snackbar.Add(ex.Message, Severity.Error);
                }
            }
        }
        else
        {
            bool? result = await DialogService.ShowMessageBox(
                "Permission denied!",
                "You don't have any permission to Edit BankAccountOwn.");
        }
        await Task.Delay(200);
        _busy = false;
    }

    UnReconciledBankEntryView child;
    int PreviousBankId = 0;
    public OwnBankModel unRecounciledBankEntry { get; set; }
    public bool ShowUnReconciledBankEntry { get; set; }

    // Method to show the modal for un-reconciled bank entries
    void ShowModal()
    {
        ShowUnReconciledBankEntry = true;
    }

    // Method to hide the modal for un-reconciled bank entries
    void HideModal()
    {
        ShowUnReconciledBankEntry = false;
    }

    // Method to redirect to the un-reconciled bank entry view
    public void RedirectToUnRecounciledBankEntry(OwnBankModel bankModel)
    {
        unRecounciledBankEntry = bankModel;
        if (ShowUnReconciledBankEntry)
        {
            ShowUnReconciledBankEntry = false;
        }
        else
        {
            ShowUnReconciledBankEntry = false;
            ShowUnReconciledBankEntry = true;
        }
        if (bankModel != null && bankModel.ID != null)
        {
            if (PreviousBankId != (int)bankModel.ID)
            {
                ShowUnReconciledBankEntry = false;
                ShowUnReconciledBankEntry = true;
            }
            PreviousBankId = (int)bankModel.ID;
        }
    }

    private int selectedRowNumber = -1;
    private MudTable<OwnBankModel> mudTable;
    private List<string> clickedEvents = new();

    // Method to determine the CSS class for the selected row
    private string SelectedRowClassFunc(OwnBankModel element, int rowNumber)
    {
        if (unRecounciledBankEntry != null && unRecounciledBankEntry.Equals(element))
        {
            selectedRowNumber = rowNumber;
            return "selected";
        }
        else
        {
            return string.Empty;
        }
    }

    private string RowClassFunc(OwnBankModel element, int rowNumber)
    {
        if (element.IsDisabled == true)
            return "disabled-row";
        if (unRecounciledBankEntry != null && unRecounciledBankEntry.Equals(element))
        {
            selectedRowNumber = rowNumber;
            return "selected";
        }
        return string.Empty;
    }

    // Method to open the bank ledger views for a specific bank
    private void OpenBankLedgerViews(OwnBankModel Bank)
    {
        if (Bank != null && Bank.ID != null)
        {
            NavigationManager.NavigateTo("/BankLedgerView/" + Bank.ID.ToString());
        }
    }

    // Method to enable or disable a bank account
    public async Task DisableAccount(bool? IsDisabled, int? ID)
    {
        if (HasPermissionBankAccountOwnServiceEdit)
        {
            if (collection.Any(s => s.ID == ID))
            {
                var authprov = await auth.GetAuthenticationStateAsync();
                var user = authprov.User.Identity.Name;
                int result = Iservice.DisableAccount(IsDisabled, ID, user); // Call service to disable/enable account
                if (result != -1)
                {
                    collection.First(s => s.ID == ID).IsDisabled = IsDisabled;
                    if (IsDisabled == true)
                    {
                        snackbar.Add("Disabled " + collection.First(s => s.ID == ID).BankAccountInfo.BankTitle + " Succesfully.", Severity.Success);
                    }
                    else
                    {
                        snackbar.Add("Enabled " + collection.First(s => s.ID == ID).BankAccountInfo.BankTitle + " Succesfully.", Severity.Success);
                    }
                }
                else
                {
                    snackbar.Add("error occurred while disabling.", Severity.Error);
                }
            }
        }
        else
        {
            bool? result = await DialogService.ShowMessageBox(
                "Permission denied!",
                "You don't have any permission to Edit BankAccountOwn.");
        }
    }
}

