@page "/BankAccountOwnView"
@inject IBankAccountOwnService Iservice
@inject MudBlazor.ISnackbar snackbar
@inject AuthenticationStateProvider auth
@attribute [Authorize]
@using System.Threading;
@inject IRoleService<RoleModel> Irole
@inject IDialogService DialogService
@inject NavigationManager NavigationManager
@inject NavigationManager nav
@inject Microsoft.AspNetCore.Components.NavigationManager navigationManager


@if (_isLoading)
{
    <div @key="@("loader")" style="display: flex; justify-content: center; align-items: center; min-height: 400px;">
        <LoaderComponent IsFullScreen="true" 
                        ShowLogo="false" 
                        Size="medium" 
                        LoadingText="Loading Financial Portals" 
                        SubText="Please wait..." />
    </div>
}
else
{
    <div class="fade-in">
        <div class="admin-header-tiered mb-6">
            <div class="d-flex align-center justify-space-between">
                <div>
                    <MudText Typo="Typo.h4" Class="admin-title">Bank Account Portfolio</MudText>
                    <MudText Typo="Typo.body2" Class="admin-subtitle">Maintain institution-level bank accounts across all regional branches. oversee liquidity access points, beneficiary configurations, and audit bank-specific financial tools.</MudText>
                </div>
                <MudButton StartIcon="@Icons.Material.Filled.AccountBalance" Variant="Variant.Filled" Color="Color.Primary" Class="admin-register-btn" OnClick="@(()=> OpenDialog(model))" Disabled="@_busy">REGISTER NEW ACCOUNT</MudButton>
            </div>
        </div>

        <div class="admin-glass-card pa-0 overflow-hidden">
            <MudTable Items="@collection" Elevation="0" Class="modern-admin-table" Hover="true" RowClassFunc="@RowClassFunc" T="OwnBankModel">
                <HeaderContent>
                    <MudTh><MudTableSortLabel SortBy="new Func<OwnBankModel, object>(x=> x.BankAccountInfo.BankTitle)" InitialDirection="SortDirection.Ascending"><span class="admin-header-text">BANK / TITLE</span></MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<OwnBankModel, object>(x=> x.BankAccountInfo.BeneficiaryName)"><span class="admin-header-text">BENEFICIARY</span></MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<OwnBankModel, object>(x=> x.BankAccountInfo.AccountNumber)"><span class="admin-header-text">ACCOUNT NUMBER</span></MudTableSortLabel></MudTh>
                    <MudTh><span class="admin-header-text">BRANCH / CODE</span></MudTh>
                    <MudTh Style="width: 120px;"><span class="admin-header-text">STATUS</span></MudTh>
                    <MudTh Style="text-align: right;"><span class="admin-header-text">ACTIONS</span></MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Title">
                        <div class="d-flex align-center gap-3">
                            <div class="admin-icon-square-vibrant small accent-indigo">
                                <MudIcon Icon="@Icons.Material.Filled.AccountBalance" Size="Size.Small" />
                            </div>
                            <div class="d-flex flex-column">
                                <span class="fw-700 admin-td-primary">@context.BankAccountInfo.BankTitle</span>
                                <span class="small opa-50 fw-600">GL: @(context.PostingGroup?.BankAccount?.AccountName ?? "N/A")</span>
                            </div>
                        </div>
                    </MudTd>
                    <MudTd DataLabel="Beneficiary"><span class="fw-600">@context.BankAccountInfo.BeneficiaryName</span></MudTd>
                    <MudTd DataLabel="Account"><span class="fw-700 text-vibrant font-monospace" style="font-size: 1rem; color: #141A46;">@context.BankAccountInfo.AccountNumber</span></MudTd>
                    <MudTd DataLabel="Branch">
                        <div class="d-flex flex-column">
                            <span class="fw-700 small">@context.BankAccountInfo.BankBranch</span>
                            <span class="small opa-40 fw-800">CODE: @context.BankCode</span>
                        </div>
                    </MudTd>
                    <MudTd DataLabel="Status">
                        <div class="d-flex align-center gap-2">
                            <MudSwitch T="bool?" Value="@context.IsDisabled" Color="Color.Error" UnCheckedColor="Color.Success" ValueChanged="@(async (bool? e) => await DisableAccount(e,context.ID))" Size="Size.Small" />
                            <MudTooltip Text="@(context.IsDisabled == true ? "Inactive Account" : "Active & Operational")">
                                <MudChip T="string" Color="@(context.IsDisabled == true ? Color.Error : Color.Success)" Variant="Variant.Text" Size="Size.Small" Class="fw-800 px-0">@(context.IsDisabled == true ? "INACTIVE" : "ACTIVE")</MudChip>
                            </MudTooltip>
                        </div>
                    </MudTd>
                    <MudTd DataLabel="Actions" Style="text-align: right;">
                        <div class="d-flex justify-end gap-1">
                            <MudTooltip Text="Edit Parameters">
                                <MudIconButton OnClick="@(()=> OpenDialog(context))" Color="Color.Primary" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Variant="Variant.Text" />
                            </MudTooltip>
                            
                            <MudTooltip Text="Opening Reconciliation">
                                <MudIconButton OnClick="@(()=> RedirectToUnRecounciledBankEntry(context))" Color="Color.Warning" Icon="@Icons.Material.Filled.AccountBalanceWallet" Size="Size.Small" Variant="Variant.Text" />
                            </MudTooltip>

                            <MudTooltip Text="Cheque Book Suite">
                                <MudIconButton OnClick="@(() => nav.NavigateTo("chequebook/" + context.ID.ToString()))" Color="Color.Secondary" Icon="@Icons.Material.Filled.FactCheck" Size="Size.Small" Variant="Variant.Text" />
                            </MudTooltip>
                        </div>
                    </MudTd>
                </RowTemplate>
                <PagerContent>
                    <div class="pa-4">
                        <MudTablePager PageSizeOptions="new int[] { 10, 20, 50 }" />
                    </div>
                </PagerContent>
            </MudTable>
        </div>

        @if (ShowUnReconciledBankEntry)
        {
            <div class="mt-8 slide-up">
                <UnReconciledBankEntryView bankModel="unRecounciledBankEntry" @ref="child" />
            </div>
        }
    </div>
}

@code {

    private bool _isLoading = true;
    private DateTime _loadStartTime;

    private OwnBankModel model = new OwnBankModel();
    private List<OwnBankModel> collection = new List<OwnBankModel>();
    DialogOptions mediumWidth = new DialogOptions() { MaxWidth = MaxWidth.ExtraLarge, FullWidth = true };
    private bool _busy;

    public bool HasPermissionBankAccountOwnServiceEdit { get; set; } = false;
    public int BankAccountOwnDocTypeID = 109;

    // Lifecycle method called when the component is initialized
    protected override async Task OnInitializedAsync()
    {
        _loadStartTime = DateTime.Now;
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionBankAccountOwnServiceEdit = await Irole.HasClaim(BankAccountOwnDocTypeID.ToString(), "Edit", ctc.Token);

        model = new();
        await GetAll();
        await EnsureMinimumLoadTime();
        _isLoading = false;
    }

    private async Task EnsureMinimumLoadTime()
    {
        var elapsed = (DateTime.Now - _loadStartTime).TotalMilliseconds;
        if (elapsed < 100)
        {
            await Task.Delay(100 - (int)elapsed);
        }
    }

    // Method to fetch all bank accounts
    private async Task GetAll()
    {
        var authprov = await auth.GetAuthenticationStateAsync();
        var branchIDString = authprov.User.Claims.First(x => x.Type == "BranchID").Value;
        int branchID = int.Parse(branchIDString);

        collection = new List<OwnBankModel>();

        // Load bank accounts for the specified branch
        foreach (var item in Iservice.SelectSelectByBranchALL(branchID))
        {
            collection.Add(item);
        }
    }

    // Method to open the dialog for adding or editing a bank account
    public async Task OpenDialog(OwnBankModel ownBank)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        _busy = true;

        if (HasPermissionBankAccountOwnServiceEdit)
        {
            DialogParameters parms = new DialogParameters();
            parms.Add("model", ownBank.Clone());
            var dialog = await DialogService.ShowAsync<BankAccountOwnDialog>(ownBank.ID == null ? "ADD" : "EDIT", parms, mediumWidth);
            var result = await dialog.Result;
            if (!result.Canceled)
            {
                try
                {
                    OwnBankModel UpdatedModel = (OwnBankModel)result.Data;
                    Iservice.Update(UpdatedModel); // Update the bank account
                    snackbar.Add("Saved Successfully", Severity.Success);
                    await GetAll();
                }
                catch (Exception ex)
                {
                    snackbar.Add(ex.Message, Severity.Error);
                }
            }
        }
        else
        {
            bool? result = await DialogService.ShowMessageBoxAsync(
                "Permission denied!",
                "You don't have any permission to Edit BankAccountOwn.");
        }
        await Task.Delay(200);
        _busy = false;
    }

    UnReconciledBankEntryView child;
    int PreviousBankId = 0;
    public OwnBankModel unRecounciledBankEntry { get; set; }
    public bool ShowUnReconciledBankEntry { get; set; }

    // Method to show the modal for un-reconciled bank entries
    void ShowModal()
    {
        ShowUnReconciledBankEntry = true;
    }

    // Method to hide the modal for un-reconciled bank entries
    void HideModal()
    {
        ShowUnReconciledBankEntry = false;
    }

    // Method to redirect to the un-reconciled bank entry view
    public void RedirectToUnRecounciledBankEntry(OwnBankModel bankModel)
    {
        unRecounciledBankEntry = bankModel;
        if (ShowUnReconciledBankEntry)
        {
            ShowUnReconciledBankEntry = false;
        }
        else
        {
            ShowUnReconciledBankEntry = false;
            ShowUnReconciledBankEntry = true;
        }
        if (bankModel != null && bankModel.ID != null)
        {
            if (PreviousBankId != (int)bankModel.ID)
            {
                ShowUnReconciledBankEntry = false;
                ShowUnReconciledBankEntry = true;
            }
            PreviousBankId = (int)bankModel.ID;
        }
    }

    private int selectedRowNumber = -1;
    private MudTable<OwnBankModel> mudTable;
    private List<string> clickedEvents = new();

    // Method to determine the CSS class for the selected row
    private string SelectedRowClassFunc(OwnBankModel element, int rowNumber)
    {
        if (unRecounciledBankEntry != null && unRecounciledBankEntry.Equals(element))
        {
            selectedRowNumber = rowNumber;
            return "selected";
        }
        else
        {
            return string.Empty;
        }
    }

    private string RowClassFunc(OwnBankModel element, int rowNumber)
    {
        if (element.IsDisabled == true)
            return "disabled-row";
        if (unRecounciledBankEntry != null && unRecounciledBankEntry.Equals(element))
        {
            selectedRowNumber = rowNumber;
            return "selected";
        }
        return string.Empty;
    }

    // Method to open the bank ledger views for a specific bank
    private void OpenBankLedgerViews(OwnBankModel Bank)
    {
        if (Bank != null && Bank.ID != null)
        {
            NavigationManager.NavigateTo("/BankLedgerView/" + Bank.ID.ToString());
        }
    }

    // Method to enable or disable a bank account
    public async Task DisableAccount(bool? IsDisabled, int? ID)
    {
        if (HasPermissionBankAccountOwnServiceEdit)
        {
            if (collection.Any(s => s.ID == ID))
            {
                var authprov = await auth.GetAuthenticationStateAsync();
                var user = authprov.User.Identity.Name;
                int result = Iservice.DisableAccount(IsDisabled, ID, user); // Call service to disable/enable account
                if (result != -1)
                {
                    collection.First(s => s.ID == ID).IsDisabled = IsDisabled;
                    if (IsDisabled == true)
                    {
                        snackbar.Add("Disabled " + collection.First(s => s.ID == ID).BankAccountInfo.BankTitle + " Succesfully.", Severity.Success);
                    }
                    else
                    {
                        snackbar.Add("Enabled " + collection.First(s => s.ID == ID).BankAccountInfo.BankTitle + " Succesfully.", Severity.Success);
                    }
                }
                else
                {
                    snackbar.Add("error occurred while disabling.", Severity.Error);
                }
            }
        }
        else
        {
            bool? result = await DialogService.ShowMessageBoxAsync(
                "Permission denied!",
                "You don't have any permission to Edit BankAccountOwn.");
        }
    }
}

