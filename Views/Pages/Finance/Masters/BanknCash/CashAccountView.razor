@page "/CashAccount"
@inject ICashAccountService Iservice
@inject MudBlazor.ISnackbar snackbar
@inject AuthenticationStateProvider auth
@attribute [Authorize]
@using System.Threading;
@inject IRoleService<RoleModel> Irole
@inject IDialogService DialogService

<MudGrid Spacing="4">
    <MudItem xs="12">
        <MudTable Items="@collection" RowsPerPage="10" Dense="true" Hover="true" Striped="true" Elevation="10" @bind-place="model">
            <ToolBarContent>
                <MudText Typo="Typo.h6">Manage Cash Accounts </MudText>
                <MudTooltip Text="New Cash Account">
                    <MudIconButton Disabled="@_busy" Icon="@Icons.Material.Filled.Add" Title="Add" @onclick="@(()=> OpenDialog(new CashAccountModel()))" Color="Color.Dark" Size="Size.Small"></MudIconButton>
                </MudTooltip>
                <MudSpacer></MudSpacer>
            </ToolBarContent>
            <HeaderContent>
                <MudTh><MudTableSortLabel SortBy="new Func<CashAccountModel, object>(x=> x.AccountType)" InitialDirection="SortDirection.Ascending">Type</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<CashAccountModel, object>(x=> x.Title)" InitialDirection="SortDirection.Ascending">Title</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<CashAccountModel, object>(x=> x.CashCode)" InitialDirection="SortDirection.Ascending">Cash code</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<CashAccountModel, object>(x=> x.Coa.AccountName)" InitialDirection="SortDirection.Ascending">Account Name</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<CashAccountModel, object>(x=> x.MinBalance)" InitialDirection="SortDirection.Ascending">Minimum Balance</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<CashAccountModel, object>(x=> x.MaxBalance)" InitialDirection="SortDirection.Ascending">Maximum Balance</MudTableSortLabel></MudTh>
                <MudTh>Is Disable</MudTh>
                <MudTh>Actions</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Type">@context.AccountType</MudTd>
                <MudTd DataLabel="Title">@context.Title</MudTd>
                <MudTd DataLabel="Code">@context.CashCode</MudTd>
                <MudTd DataLabel="AccountNumber">@context.Coa.AccountName</MudTd>
                <MudTd DataLabel="min">@context.MinBalance</MudTd>
                <MudTd DataLabel="max">@context.MaxBalance</MudTd>
                <MudTd DataLabel="">
                    <MudTooltip Text="Disable">
                        <MudSwitch Checked="@context.IsDisabled" Color="Color.Primary" T="bool?" CheckedChanged="@((e) => DisableAccount(e,context.CashAccountID))"></MudSwitch>
                    </MudTooltip>
                </MudTd>
                <MudTd DataLabel="">
                    <MudTooltip Text="Edit">
                        <MudFab @onclick="@(()=> OpenDialog(context))" Color="Color.Primary" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" IconSize="Size.Small" />
                    </MudTooltip>
                </MudTd>
            </RowTemplate>
            <PagerContent>
                <MudTablePager PageSizeOptions="new int[] { 10, 20, 50, 100 }" />
            </PagerContent>
        </MudTable>
    </MudItem>
</MudGrid>

@code {

    private CashAccountModel model = new CashAccountModel();
    private List<CashAccountModel> collection = new List<CashAccountModel>();
    DialogOptions mediumWidth = new DialogOptions() { MaxWidth = MaxWidth.Medium, FullWidth = true };
    private bool _busy;

    public bool HasPermissionCashAccountServiceEnableDisable { get; set; } = false;
    public int CashAccountDocTypeID = 90;

    protected override async Task OnInitializedAsync()
    {
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionCashAccountServiceEnableDisable = await Irole.HasClaim(CashAccountDocTypeID.ToString(), "Enable/Disable", ctc.Token);

        await GetAll();
    }

    private async Task GetAll()
    {
        var authState = await auth.GetAuthenticationStateAsync();
        var branch = int.Parse(authState.User.Claims.FirstOrDefault(x => x.Type == "BranchID").Value);
        collection = Iservice.SelectByBranchALL(branch).ToList();
    }

    public async Task OpenDialog(CashAccountModel Cam)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        _busy = true;

        DialogParameters parms = new DialogParameters();
        parms.Add("model", Cam.Clone());
        var dialog = DialogService.Show<CashaccDialog>(Cam.CashAccountID == null ? "ADD" : "EDIT", parms);
        var result = await dialog.Result;
        if (!result.Canceled)
        {
            CashAccountModel UpatedModel = (CashAccountModel)result.Data;
            await GetAll();
        }
        await Task.Delay(200);
        _busy = false;
    }

    public async Task DisableAccount(bool? IsDisabled, int? CashAccountID)
    {
        if (HasPermissionCashAccountServiceEnableDisable)
        {
            if (collection.Any(s => s.CashAccountID == CashAccountID))
            {
                var authprov = await auth.GetAuthenticationStateAsync();
                var user = authprov.User.Identity.Name;
                int result = Iservice.DisableAccount(IsDisabled, CashAccountID, user);
                if (result != -1)
                {
                    collection.First(s => s.CashAccountID == CashAccountID).IsDisabled = IsDisabled;
                    if (IsDisabled == true)
                    {
                        snackbar.Add("Disabled " + collection.First(s => s.CashAccountID == CashAccountID).Title + " Succesfully.", Severity.Success);
                    }
                    else
                    {
                        snackbar.Add("Enabled " + collection.First(s => s.CashAccountID == CashAccountID).Title + " Succesfully.", Severity.Success);
                    }
                }
                else
                {
                    snackbar.Add("error occurred while disabling.", Severity.Error);
                }
            }
        }
        else
        {
            bool? result = await DialogService.ShowMessageBox(
                "Permission denied!",
                "You dont have any permission to Enable/Disable CashAccount.");
        }
    }
}