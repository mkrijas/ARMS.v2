@page "/CashAccount"
@inject ICashAccountService Iservice
@inject MudBlazor.ISnackbar snackbar
@inject AuthenticationStateProvider auth
@attribute [Authorize]
@using System.Threading;
@inject IRoleService<RoleModel> Irole
@inject IDialogService DialogService

@if (_isLoading)
{
    <div @key="@("loader")" style="display: flex; justify-content: center; align-items: center; min-height: 400px;">
        <LoaderComponent IsFullScreen="true" 
                        ShowLogo="false" 
                        Size="medium" 
                        LoadingText="Loading Cash Registries" 
                        SubText="Please wait..." />
    </div>
}
else
{
    <div class="fade-in">
        <div class="admin-header-tiered mb-6">
            <div class="d-flex align-center justify-space-between">
                <div>
                    <MudText Typo="Typo.h4" Class="admin-title">Cash Registry Management</MudText>
                    <MudText Typo="Typo.body2" Class="admin-subtitle">Oversee physical cash assets, branch safes, and petty cash holdings. Define operational thresholds and maintain strict control over cash liquidity points.</MudText>
                </div>
                <MudButton StartIcon="@Icons.Material.Filled.Payments" Variant="Variant.Filled" Color="Color.Primary" Class="admin-register-btn" OnClick="@(()=> OpenDialog(new CashAccountModel()))" Disabled="@_busy">REGISTER NEW REGISTRY</MudButton>
            </div>
        </div>

        <div class="admin-glass-card pa-0 overflow-hidden">
            <MudTable Items="@collection" Elevation="0" Class="modern-admin-table" Hover="true">
                <HeaderContent>
                    <MudTh><MudTableSortLabel SortBy="new Func<CashAccountModel, object>(x=> x.Title)" InitialDirection="SortDirection.Ascending"><span class="admin-header-text">REGISTRY / CODE</span></MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<CashAccountModel, object>(x=> x.AccountType)"><span class="admin-header-text">REGISTRY TYPE</span></MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<CashAccountModel, object>(x=> x.Coa.AccountName)"><span class="admin-header-text">LEDGER MAPPING</span></MudTableSortLabel></MudTh>
                    <MudTh><span class="admin-header-text">BALANCE THRESHOLDS</span></MudTh>
                    <MudTh Style="width: 120px;"><span class="admin-header-text">STATUS</span></MudTh>
                    <MudTh Style="text-align: right;"><span class="admin-header-text">ACTIONS</span></MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Registry">
                        <div class="d-flex align-center gap-3">
                            <div class="admin-icon-square-vibrant small accent-amber">
                                <MudIcon Icon="@Icons.Material.Filled.PointOfSale" Size="Size.Small" />
                            </div>
                            <div class="d-flex flex-column">
                                <span class="fw-700 admin-td-primary">@context.Title</span>
                                <span class="small opa-40 fw-800">CODE: @context.CashCode</span>
                            </div>
                        </div>
                    </MudTd>
                    <MudTd DataLabel="Type">
                        <MudChip T="string" Color="Color.Default" Variant="Variant.Text" Size="Size.Small" Class="fw-700 px-3 border-solid border-1">@context.AccountType</MudChip>
                    </MudTd>
                    <MudTd DataLabel="Ledger">
                        <div class="d-flex align-center gap-2">
                            <MudIcon Icon="@Icons.Material.Filled.Link" Size="Size.Small" Class="opa-30" />
                            <span class="fw-600">@context.Coa?.AccountName</span>
                        </div>
                    </MudTd>
                    <MudTd DataLabel="Thresholds">
                        <div class="d-flex align-center gap-4">
                            <div class="d-flex flex-column">
                                <span class="tiny opa-40 fw-800 uppercase">Min Floor</span>
                                <span class="fw-700 text-info font-monospace">₹@context.MinBalance?.ToString("N0")</span>
                            </div>
                            <div class="d-flex flex-column">
                                <span class="tiny opa-40 fw-800 uppercase">Max Ceiling</span>
                                <span class="fw-700 text-error font-monospace">₹@context.MaxBalance?.ToString("N0")</span>
                            </div>
                        </div>
                    </MudTd>
                    <MudTd DataLabel="Status">
                        <div class="d-flex align-center gap-2">
                            <MudSwitch T="bool?" Value="@context.IsDisabled" Color="Color.Error" UnCheckedColor="Color.Success" ValueChanged="@(async (bool? e) => await DisableAccount(e,context.CashAccountID))" Size="Size.Small" />
                            <MudTooltip Text="@(context.IsDisabled == true ? "Inactive Registry" : "Active & Operational")">
                                <MudChip T="string" Color="@(context.IsDisabled == true ? Color.Error : Color.Success)" Variant="Variant.Text" Size="Size.Small" Class="fw-800 px-0">@(context.IsDisabled == true ? "INACTIVE" : "ACTIVE")</MudChip>
                            </MudTooltip>
                        </div>
                    </MudTd>
                    <MudTd DataLabel="Actions" Style="text-align: right;">
                        <div class="d-flex justify-end gap-1">
                            <MudTooltip Text="Modify Configuration">
                                <MudIconButton OnClick="@(()=> OpenDialog(context))" Color="Color.Primary" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Variant="Variant.Text" />
                            </MudTooltip>
                        </div>
                    </MudTd>
                </RowTemplate>
                <PagerContent>
                    <div class="pa-4">
                        <MudTablePager PageSizeOptions="new int[] { 10, 20, 50 }" />
                    </div>
                </PagerContent>
            </MudTable>
        </div>
    </div>
}


@code {

    private bool _isLoading = true;
    private DateTime _loadStartTime;

    private CashAccountModel model = new CashAccountModel();
    private List<CashAccountModel> collection = new List<CashAccountModel>();
    DialogOptions mediumWidth = new DialogOptions() { MaxWidth = MaxWidth.Medium, FullWidth = true };
    private bool _busy;

    public bool HasPermissionCashAccountServiceEnableDisable { get; set; } = false;
    public int CashAccountDocTypeID = 90;

    // Lifecycle method called when the component is initialized
    protected override async Task OnInitializedAsync()
    {
        _loadStartTime = DateTime.Now;
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionCashAccountServiceEnableDisable = await Irole.HasClaim(CashAccountDocTypeID.ToString(), "Enable/Disable", ctc.Token);

        await GetAll();
        await EnsureMinimumLoadTime();
        _isLoading = false;
    }

    private async Task EnsureMinimumLoadTime()
    {
        var elapsed = (DateTime.Now - _loadStartTime).TotalMilliseconds;
        if (elapsed < 100)
        {
            await Task.Delay(100 - (int)elapsed);
        }
    }

    // Method to fetch all cash accounts for the current branch
    private async Task GetAll()
    {
        var authState = await auth.GetAuthenticationStateAsync();
        var branch = int.Parse(authState.User.Claims.FirstOrDefault(x => x.Type == "BranchID").Value);
        collection = Iservice.SelectByBranchALL(branch).ToList(); // Load cash accounts for the specified branch
    }

    // Method to open the dialog for adding or editing a cash account
    public async Task OpenDialog(CashAccountModel Cam)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        _busy = true;

        DialogParameters parms = new DialogParameters();
        parms.Add("model", Cam.Clone());
        var dialog = await DialogService.ShowAsync<CashaccDialog>(Cam.CashAccountID == null ? "ADD" : "EDIT", parms);
        var result = await dialog.Result;
        if (!result.Canceled)
        {
            CashAccountModel UpatedModel = (CashAccountModel)result.Data;
            await GetAll();
        }
        await Task.Delay(200);
        _busy = false;
    }

    // Method to enable or disable a cash account
    public async Task DisableAccount(bool? IsDisabled, int? CashAccountID)
    {
        if (HasPermissionCashAccountServiceEnableDisable)
        {
            if (collection.Any(s => s.CashAccountID == CashAccountID))
            {
                var authprov = await auth.GetAuthenticationStateAsync();
                var user = authprov.User.Identity.Name;
                int result = Iservice.DisableAccount(IsDisabled, CashAccountID, user); // Call service to disable/enable account
                if (result != -1)
                {
                    collection.First(s => s.CashAccountID == CashAccountID).IsDisabled = IsDisabled;
                    if (IsDisabled == true)
                    {
                        snackbar.Add("Disabled " + collection.First(s => s.CashAccountID == CashAccountID).Title + " Succesfully.", Severity.Success);
                    }
                    else
                    {
                        snackbar.Add("Enabled " + collection.First(s => s.CashAccountID == CashAccountID).Title + " Succesfully.", Severity.Success);
                    }
                }
                else
                {
                    snackbar.Add("error occurred while disabling.", Severity.Error);
                }
            }
        }
        else
        {
            bool? result = await DialogService.ShowMessageBoxAsync(
                "Permission denied!",
                "You don't have any permission to Enable/Disable CashAccount.");
        }
    }
}

