@page "/chequebookleaves/{OwnBankAccountID:int}/{ChequeBookID:int}/{Readonly:bool}/{Verify:bool}"
@using System.Threading;
@attribute [Authorize]
@inject AuthenticationStateProvider auth
@inject NavigationManager NavigationManager
@inject IRoleService<RoleModel> Irole
@inject MudBlazor.ISnackbar snackbar
@inject IDialogService DialogService
@inject IChequeBookService Iservice

@@if (_isLoading)
{
    <div @key="@("loader")" style="display: flex; justify-content: center; align-items: center; min-height: 400px;">
        <LoaderComponent IsFullScreen="true" 
                        ShowLogo="false" 
                        Size="medium" 
                        LoadingText="Loading Leaf Audit" 
                        SubText="Please wait..." />
    </div>
}
else
{
    <div class="fade-in">
        <div class="admin-header-tiered mb-6">
            <div class="d-flex align-center justify-space-between">
                <div>
                    <MudText Typo="Typo.h4" Class="admin-title">Cheque Leaf Utilization Audit</MudText>
                    <MudText Typo="Typo.body2" Class="admin-subtitle">Track and audit the lifecycle of individual cheque leaves. monitor issuance amounts, verify cancellations, and maintain a high-integrity registry of financial instruments.</MudText>
                </div>
                <MudButton StartIcon="@Icons.Material.Filled.ArrowBack" Variant="Variant.Text" Color="Color.Default" Class="rounded-pill px-6" OnClick="Cancel">RETURN TO INVENTORY</MudButton>
            </div>
        </div>

        <div class="admin-glass-card pa-6 mb-6">
            <div class="d-flex align-center gap-3 mb-4">
                <div class="admin-icon-square-vibrant small accent-indigo">
                    <MudIcon Icon="@Icons.Material.Filled.MenuBook" Size="Size.Small" />
                </div>
                <MudText Typo="Typo.subtitle1" Class="fw-700 uppercase opa-80">Book Series Configuration</MudText>
            </div>

            <EditForm id="ChequeBookForm" OnValidSubmit="OnValidSubmit" Model="MainModel">
                <ObjectGraphDataAnnotationsValidator />
                <div class="d-flex flex-column gap-6">
                    <div class="admin-grid-layout">
                        <MudTextField @bind-Value="@MainModel.StartingChequeNo" ReadOnly="@Readonly" Label="Beginning Serial" Variant="Variant.Outlined" Margin="Margin.Dense" HelperText="6-digit instrument number" For="@(()=> MainModel.StartingChequeNo)" MaxLength="6" Class="admin-input-group" />
                        <MudTextField @bind-Value="@MainModel.EndingChequeNo" ReadOnly="@Readonly" Label="Ending Serial" Variant="Variant.Outlined" Margin="Margin.Dense" HelperText="6-digit instrument number" For="@(()=> MainModel.EndingChequeNo)" MaxLength="6" Class="admin-input-group" />
                        <MudDatePicker @bind-Date="@MainModel.CreatedDate" ReadOnly="@Readonly" Label="Inventory Date" Variant="Variant.Outlined" Margin="Margin.Dense" DisableToolbar="true" Editable="true" DateFormat="dd MMM yyyy" For="@(()=> MainModel.CreatedDate)" MaxDate="DateTime.Now" Class="admin-input-group" />
                    </div>

                    @if (!Readonly)
                    {
                        <div class="d-flex justify-end mt-2">
                            <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Primary" Class="rounded-pill px-12 fw-700 shadow-lg">UPDATE BOOK ENTIRETY</MudButton>
                        </div>
                    }
                </div>
            </EditForm>
        </div>

        <div class="admin-glass-card mb-6 pa-4 bg-glass-brighter">
            <div class="d-flex align-center gap-4 flex-wrap">
                <div style="flex-grow: 1; min-width: 300px;">
                    <MudTextField @bind-Value="searchchequeno" Placeholder="Search by leaf serial number..." Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" Variant="Variant.Outlined" Margin="Margin.Dense" Class="admin-input-group" Clearable="true" />
                </div>
                <div class="d-flex align-center gap-4">
                    <div class="d-flex align-center gap-2 bg-glass rounded-pill px-4 py-1">
                        <MudRadioGroup Value="@status" T="string" ValueChanged="OnSelectedOptionChanged" Class="admin-radio-group-compact">
                            <MudRadio Value="@("Pending")" Color="Color.Primary" UnCheckedColor="Color.Default" Size="Size.Small"><span class="fw-700 small uppercase">Idle</span></MudRadio>
                            <MudRadio Value="@("Active")" Color="Color.Info" UnCheckedColor="Color.Default" Size="Size.Small"><span class="fw-700 small uppercase">In-Use</span></MudRadio>
                            <MudRadio Value="@("Cashed")" Color="Color.Success" UnCheckedColor="Color.Default" Size="Size.Small"><span class="fw-700 small uppercase">Utilized</span></MudRadio>
                            <MudRadio Value="@("Cancelled")" Color="Color.Error" UnCheckedColor="Color.Default" Size="Size.Small"><span class="fw-700 small uppercase">Void</span></MudRadio>
                        </MudRadioGroup>
                    </div>
                </div>
            </div>
        </div>

        <div class="admin-glass-card pa-0 overflow-hidden mb-8">
            <MudTable Items="@collection" Elevation="0" Class="modern-admin-table" Hover="true" Filter="new Func<ChequeBookLeavesModel, bool>(search)">
                <HeaderContent>
                    <MudTh><MudTableSortLabel SortBy="new Func<ChequeBookLeavesModel, object>(x=> x.ChequeNo)" InitialDirection="SortDirection.Ascending"><span class="admin-header-text">LEAF SERIAL</span></MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<ChequeBookLeavesModel, object>(x=> x.Amount)"><span class="admin-header-text">ISSUED AMOUNT</span></MudTableSortLabel></MudTh>
                    <MudTh Style="text-align: right;"><span class="admin-header-text">ACTIONS</span></MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Serial">
                        <div class="d-flex align-center gap-2">
                            <MudIcon Icon="@Icons.Material.Filled.ConfirmationNumber" Size="Size.Small" Class="opa-40" />
                            <span class="fw-700 font-monospace admin-td-primary">#@context.ChequeNo</span>
                        </div>
                    </MudTd>
                    <MudTd DataLabel="Amount">
                        @if (context.UserInfo.RecordStatus == 1 && MainModel.AuthLevelID != null)
                        {
                            <MudNumericField @bind-Value="@context.Amount" Variant="Variant.Outlined" Margin="Margin.Dense" HideSpinButtons="true" Class="admin-input-group-compact fw-700" T="decimal?" />
                        }
                        else
                        {
                            <span class="fw-700 text-vibrant">@string.Format("{0:N2}", context.Amount ?? 0)</span>
                        }
                    </MudTd>
                    <MudTd DataLabel="Actions" Style="text-align: right;">
                        <div class="d-flex justify-end gap-1">
                            @if (context.UserInfo.RecordStatus == 1)
                            {
                                <MudTooltip Text="Commit Amount">
                                    <MudIconButton Disabled="@(MainModel.AuthLevelID == null)" OnClick="@(() => Submit(context))" Color="Color.Success" Icon="@Icons.Material.Filled.Save" Size="Size.Small" Variant="Variant.Text" />
                                </MudTooltip>
                            }
                            @if (context.UserInfo.RecordStatus != 4 && context.UserInfo.RecordStatus != 3 && context.UserInfo.RecordStatus != 0)
                            {
                                <MudTooltip Text="Void Instrument">
                                    <MudIconButton Disabled="@(MainModel.AuthLevelID == null)" OnClick="@(()=> CancelCheque(context))" Color="Color.Warning" Icon="@Icons.Material.Filled.Block" Size="Size.Small" Variant="Variant.Text" />
                                </MudTooltip>
                                <MudTooltip Text="Purge Record">
                                    <MudIconButton Disabled="@(Readonly && MainModel.AuthLevelID == null)" OnClick="@(()=> DeleteCheque(context))" Color="Color.Error" Icon="@Icons.Material.Filled.LinkOff" Size="Size.Small" Variant="Variant.Text" />
                                </MudTooltip>
                            }
                        </div>
                    </MudTd>
                </RowTemplate>
                <PagerContent>
                    <div class="pa-4">
                        <MudTablePager PageSizeOptions="new int[] { 10, 25, 50, 100 }" />
                    </div>
                </PagerContent>
            </MudTable>
        </div>

        @if (Verify || (MainModel != null && MainModel.AuthLevelID == 99))
        {
            <div class="admin-glass-card pa-6">
                <div class="d-flex align-center gap-3 mb-6">
                    <div class="admin-icon-square-vibrant small accent-amber">
                        <MudIcon Icon="@Icons.Material.Filled.Gavel" Size="Size.Small" />
                    </div>
                    <MudText Typo="Typo.subtitle1" Class="fw-700 uppercase opa-80">Final Authorization</MudText>
                </div>
            <AutherizationStatusComponent CreatedBy="@MainModel.UserInfo" DocTypeID="@DocTypeID" DocDate="@DocDate" DocType="@DocType" DocNumber="@DocNumber" PageToRedirectLink="@PageToRedirectLink" DocumentID="MainModel.ChequeBookID" OnApprove="IsApproveData" ></AutherizationStatusComponent>
            </div>
        }
    </div>
}


@code {

    private bool _isLoading = true;
    private DateTime _loadStartTime;

    private ChequeBookModel MainModel = new ChequeBookModel();
    private List<ChequeBookLeavesModel> collection = new List<ChequeBookLeavesModel>();
    private string searchchequeno = "";
    private string status = "Pending";
    private string UserID = null;

    public bool HasEditPermission { get; set; } = false;
    public bool HasApprovePermission { get; set; } = false;
    [Parameter]
    public string PageToRedirectLink { get; set; }
    public string DocNumber { get; set; }
    public DateTime? DocDate { get; set; }
    public string DocType { get; set; }
    public int DocTypeID = 147;
    [Parameter]
    public int OwnBankAccountID { get; set; }
    [Parameter]
    public int ChequeBookID { get; set; }
    [Parameter]
    public bool Readonly { get; set; }
    [Parameter]
    public bool Verify { get; set; }

    // Lifecycle method called when the component is initialized
    protected override async Task OnInitializedAsync()
    {
        _loadStartTime = DateTime.Now;
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasEditPermission = await Irole.HasClaim(DocTypeID.ToString(), "Edit", ctc.Token);
        HasApprovePermission = await Irole.HasClaim(DocTypeID.ToString(), "Approve", ctc.Token);
        if (ChequeBookID == 0)
        {
            MainModel = new ChequeBookModel();
            collection = new List<ChequeBookLeavesModel>();
            MainModel.OwnBankAccountID = OwnBankAccountID;
        }
        else
        {
            MainModel = Iservice.SelectByID(ChequeBookID);
            LoadData();
        }
        await EnsureMinimumLoadTime();
        _isLoading = false;
    }

    private async Task EnsureMinimumLoadTime()
    {
        var elapsed = (DateTime.Now - _loadStartTime).TotalMilliseconds;
        if (elapsed < 100)
        {
            await Task.Delay(100 - (int)elapsed);
        }
    }  

    // Method to load data based on the current state
    private async Task LoadData()
    {

        if (status == "Pending")
        {
            collection = Iservice.GetPendingLeaves(ChequeBookID).ToList();
        }
        else if (status == "Active")
        {
            collection = Iservice.GetActiveLeaves(ChequeBookID).ToList();
        }
        else if (status == "Cashed")
        {
            collection = Iservice.GetCashedLeaves(ChequeBookID).ToList();
        }
        else if (status == "Cancelled")
        {
            collection = Iservice.GetCancelledLeaves(ChequeBookID).ToList();
        }        
        DocType = "Cheque Book";
    }

    // Method to Approve an entry
    protected async Task IsApproveData(DataApprovedStatus aprvd)
    {
        if (HasApprovePermission)
        {
            if (aprvd.IsApprove)
            {
                try
                {
                    var authprov = await auth.GetAuthenticationStateAsync();
                    var user = authprov.User;
                    MainModel.UserInfo.UserID = user.Identity.Name;
                    Iservice.Approve(MainModel.ChequeBookID.Value, MainModel.UserInfo.UserID, string.Empty);
                    snackbar.Add("Approved Successfully", Severity.Success);
                }
                catch (Exception ex)
                {
                    snackbar.Add(ex.Message, Severity.Error);
                }
            }
        }
        else
        {
            bool? result = await DialogService.ShowMessageBoxAsync(
                "Permission denied!",
                "You don't have any permission to Approve PurchaseOrder.");
        }
    }

    public void OnSelectedOptionChanged(string value)
    {       
        status = value;
        LoadData();        
    }

    void Cancel()
    {
        NavigationManager.NavigateTo("/chequebook/" + OwnBankAccountID.ToString());
    }

    public async Task OnValidSubmit()
    {
        if (HasEditPermission)
        {
            try
            {
                var authprov = await auth.GetAuthenticationStateAsync();
                var user = authprov.User;
                UserID = user.Identity.Name;

                MainModel.UserInfo.UserID = UserID;

                // Call the service to update the process
                Iservice.Update(MainModel);
                snackbar.Add("Saved Successfully", Severity.Success);
                NavigationManager.NavigateTo("/chequebook/" + OwnBankAccountID.ToString());
            }
            catch (Exception ex)
            {
                snackbar.Add(ex.Message, Severity.Error);
            }
        }
        else
        {
            bool? result = await DialogService.ShowMessageBoxAsync(
                "Permission denied!",
                "You don't have any permission to Edit FasTag.");
        }
    }

    // Method to search for items based on the plate number
    private bool search(ChequeBookLeavesModel model)
    {
        if (model.ChequeNo != null && model.ChequeNo.Contains(searchchequeno, StringComparison.OrdinalIgnoreCase))
        {
            return true;
        }
        else if (model.ChequeNo == null)
            return true;
        return false;
    }

    private async Task Submit(ChequeBookLeavesModel model)
    {
        try
        {
            var authprov = await auth.GetAuthenticationStateAsync();
            var user = authprov.User;
            model.UserInfo.RecordStatus = 2;
            model.UserInfo.UserID = user.Identity.Name;

            Iservice.LeafUpdate(model);
            snackbar.Add("Updated Successfully", Severity.Success);
            LoadData();
        }
        catch (Exception ex)
        {
            snackbar.Add(ex.Message, Severity.Error);
        }
    }

    private async Task CancelCheque(ChequeBookLeavesModel model)
    {
        if (HasEditPermission)
        {
            bool? result = await DialogService.ShowMessageBoxAsync(
                "Warning !",
                "Are you sure, you want to Cancel - " + model.ChequeNo + " ?");
            if (result == true)
            {
                var authprov = await auth.GetAuthenticationStateAsync();
                var user = authprov.User;
                model.UserInfo.RecordStatus = 4;
                model.UserInfo.UserID = user.Identity.Name;
                Iservice.LeafUpdate(model);
                snackbar.Add("Cancelled Successfully", Severity.Success);
                LoadData();
            }
        }
        else
        {
            bool? result = await DialogService.ShowMessageBoxAsync(
                "Permission denied!",
                "You don't have any permission to cancel Cheque.");
        }
    }

    private async Task DeleteCheque(ChequeBookLeavesModel model)
    {
        if (HasEditPermission)
        {
            bool? result = await DialogService.ShowMessageBoxAsync(
                "Warning !",
                "Are you sure, you want to Delete - " + model.ChequeNo + " ?");
            if (result == true)
            {
                var authprov = await auth.GetAuthenticationStateAsync();
                var user = authprov.User;
                model.UserInfo.RecordStatus = 0;
                model.UserInfo.UserID = user.Identity.Name;
                Iservice.LeafUpdate(model);
                snackbar.Add("Deleted Successfully", Severity.Success);
                LoadData();
            }
        }
        else
        {
            bool? result = await DialogService.ShowMessageBoxAsync(
                "Permission denied!",
                "You don't have any permission to delete Cheque.");
        }
    }
}
