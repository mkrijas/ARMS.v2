@page "/UnReconciledBankEntryView/{bankModel}"
@page "/UnReconciledBankEntryView"

@inject IUnreconciledBankEntryService Iservice
@inject MudBlazor.ISnackbar snackbar

@inject AuthenticationStateProvider auth
@attribute [Authorize]
@inject IDialogService DialogService



<MudGrid Spacing="4">
    <MudItem xs="12">
        <MudTable Items="@collection" Dense="true" Hover="true" Striped="true" Elevation="10" @bind-place="model">
            <ToolBarContent>
                @if(bankModel != null && bankModel.BankAccountInfo != null)
                {
                    <MudText Typo="Typo.h6">@(bankModel.BankAccountInfo.BankTitle) - List of Opening Unreconciled Entries</MudText>
                }
                else
                {
                     <MudText Typo="Typo.h6">No Bank account selected.</MudText>
                }
                <MudTooltip Text="Add UnReconciled Transaction">
                    <MudIconButton Icon="@Icons.Material.Filled.Add" Title="Add" @onclick="@(()=> AddEditUnreconciled(new UnReconciledBankEntryModel()))" Color="Color.Dark" Size="Size.Small"></MudIconButton>
                </MudTooltip>
                <MudSpacer></MudSpacer>
            </ToolBarContent>
            <HeaderContent>
                <MudTh><MudTableSortLabel SortBy="new Func<UnReconciledBankEntryModel, object>(x=> x.Nature)" InitialDirection="SortDirection.Ascending">Nature</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<UnReconciledBankEntryModel, object>(x=> x.TransactionDate)" InitialDirection="SortDirection.Ascending">Transaction Date</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<UnReconciledBankEntryModel, object>(x=> x.ArdCode)" InitialDirection="SortDirection.Ascending">Ard Code</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<UnReconciledBankEntryModel, object>(x=> x.InstrumentType)" InitialDirection="SortDirection.Ascending">Instrument Type</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<UnReconciledBankEntryModel, object>(x=> x.InstrumentDate)" InitialDirection="SortDirection.Ascending">Instrument Date</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<UnReconciledBankEntryModel, object>(x=> x.Amount)" InitialDirection="SortDirection.Ascending">Amount</MudTableSortLabel></MudTh>
                <MudTh>Actions</MudTh>  
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Title">@context.NatureName</MudTd>
                <MudTd DataLabel="BeneficiaryName">@context.TransactionDate?.ToShortDateString()</MudTd>
                <MudTd DataLabel="AccountNumber">@context.ArdCode</MudTd>
                <MudTd DataLabel="Place">@context.InstrumentType</MudTd>
                <MudTd DataLabel="BankCode">@context.InstrumentDate?.ToShortDateString()</MudTd>
                <MudTd DataLabel="BankCode">@context.Amount</MudTd>
                <MudTd DataLabel="">
                    <MudFab @onclick="@(()=> AddEditUnreconciled(context))" Title="Edit" Color="Color.Primary" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" IconSize="Size.Small" />
                    <MudFab @onclick="@(()=> Delete(context))" Title="Delete" Color="Color.Primary" Icon="@Icons.Material.Filled.Delete" Size="Size.Small" IconSize="Size.Small" />                
                </MudTd>
            </RowTemplate>
            <PagerContent>
                <MudTablePager PageSizeOptions="new int[] { 5, 10, 20, 50, 100 }" />    
            </PagerContent>
        </MudTable>
    </MudItem>
</MudGrid>
@code {

    private UnReconciledBankEntryModel model = new();

    [Parameter]
    public OwnBankModel bankModel { get; set; } = new();
    private List<UnReconciledBankEntryModel> collection = new();

    protected override async Task OnInitializedAsync()
    {        
        if (bankModel != null)
        {
            model.BankID = (bankModel.ID != null ? (int)bankModel?.ID : 0);
            model.ArdCode = bankModel.BankCode;
        }
        GetAll();
    }

    private async Task AddEditUnreconciled(UnReconciledBankEntryModel unrec)
    {        
        if (bankModel != null && unrec.BankID == 0)
        {
            unrec.BankID = (int)bankModel.ID;
            unrec.ArdCode = bankModel.BankCode;
        }
        else
        {
            snackbar.Add("Bank not selected!",Severity.Error);
            return;
        }
        var parameters = new DialogParameters { ["model"] = unrec };        
        var dialog = DialogService.Show<UnReconciledBankEntryDialog>("Add/Edit Unreconciled Entries", parameters);
        var result = await dialog.Result;

        // you can check if the modal was cancelled
        var isCancelled = result.Canceled;
        if (!isCancelled)
        {
            GetAll();
        }
    }
    
    private async Task Delete(UnReconciledBankEntryModel UnReconciledBankEntry)
    {
        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;
        UnReconciledBankEntry.UserInfo.UserID = user.Identity.Name;
        Iservice.Delete(UnReconciledBankEntry.ID, UnReconciledBankEntry.UserInfo.UserID);
        GetAll();
    }    

    private void GetAll()
    {
        collection = new();
        if (bankModel != null)
        {
            model.BankID = (bankModel.ID != null ? (int)bankModel.ID : 0);
            model.ArdCode = bankModel.BankCode;
        }

        foreach (var item in Iservice.Select(model.BankID, true))
        {
            if (item.Nature != null && item.Nature == -1)
            {
                item.NatureName = "Payment";
            }
            else if (item.Nature != null && item.Nature == 1)
            {
                item.NatureName = "Receipt";
            }
            else
            {
                item.NatureName = "";
            }
            collection.Add(item);
        }
    }

}