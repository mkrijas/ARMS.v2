@page "/CancellationReasonCodeView"
@using System.Threading;
@using ArmsAdmin.Pages.User;
@using Core.BaseModels.Finance;
@using Core.IDataServices.Finance;
@using DAL.DataServices.Finance;
@inject ICancellationReasonCodeService Iservice
@inject IPlaceService Iplace
@inject IOrderService Iorder
@inject IChartOfAccountService Icoa
@inject IAddressService Iaddress
@inject MudBlazor.ISnackbar snackbar
@attribute [Authorize]
@inject AuthenticationStateProvider auth
@inject IDialogService DialogService
@inject IRoleService<RoleModel> Irole

@if (!isLoaded)
{
    <div @key="@("loader")" style="display: flex; justify-content: center; align-items: center; min-height: 400px;">
        <LoaderComponent IsFullScreen="true" 
                        ShowLogo="false" 
                        Size="medium" 
                        LoadingText="Loading Reason Codes" 
                        SubText="Please wait..." />
    </div>
}
else
{
    <div class="fade-in">
        <div class="admin-header-tiered mb-6">
            <div class="d-flex align-center justify-space-between">
                <div>
                    <MudText Typo="Typo.h4" Class="admin-title">Document Cancellation Protocols</MudText>
                    <MudText Typo="Typo.body2" Class="admin-subtitle">Maintain standardized reason codes for document cancellations and transaction reversals. track compliance requirements across different business document families.</MudText>
                </div>
                <MudButton StartIcon="@Icons.Material.Filled.Add" Variant="Variant.Filled" Color="Color.Primary" Class="admin-register-btn" OnClick="@(() => Edit(new CancellationReasonCodesByDocumentType()))" Disabled="@_busy">DEFINE REASON CODE</MudButton>
            </div>
        </div>

        <div class="admin-glass-card mb-6 pa-4">
            <div class="d-flex align-center gap-4 flex-wrap">
                <div style="flex-grow: 1; min-width: 300px;">
                    <MudTextField @bind-Value="searchBranch" Placeholder="Search by document type..." Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" Variant="Variant.Outlined" Margin="Margin.Dense" Class="admin-input-group" Clearable="true" />
                </div>
            </div>
        </div>

        <div class="admin-glass-card pa-0 overflow-hidden">
            <MudTable Items="@collection" Elevation="0" Class="modern-admin-table" Hover="true" Filter="new Func<CancellationReasonCodesByDocumentType, bool>(search)">
                <HeaderContent>
                    <MudTh><MudTableSortLabel SortBy="new Func<CancellationReasonCodesByDocumentType, object>(x => x.DocumentTypeName)" InitialDirection="SortDirection.Ascending"><span class="admin-header-text">DOCUMENT TYPE</span></MudTableSortLabel></MudTh>
                    <MudTh Style="text-align: right;"><span class="admin-header-text">ACTIONS</span></MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Document Type">
                        <div class="d-flex align-center gap-3">
                            <div class="admin-icon-square-vibrant small accent">
                                <MudIcon Icon="@Icons.Material.Filled.AssignmentReturn" Size="Size.Small" />
                            </div>
                            <span class="fw-700 admin-td-primary">@context.DocumentTypeName</span>
                        </div>
                    </MudTd>
                    <MudTd DataLabel="Actions" Style="text-align: right;">
                        <div class="d-flex justify-end gap-1">
                            <MudTooltip Text="Edit Protocols">
                                <MudIconButton OnClick="@(() => Edit(context))" Color="Color.Primary" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Variant="Variant.Text" />
                            </MudTooltip>
                            @*<MudTooltip Text="Delete Protocols">
                                <MudIconButton OnClick="@(() => Delete(context))" Color="Color.Error" Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Variant="Variant.Text" />
                            </MudTooltip>*@
                        </div>
                    </MudTd>
                </RowTemplate>
                <PagerContent>
                    <div class="pa-4">
                        <MudTablePager PageSizeOptions="new int[] { 10, 20, 50, 100 }" />
                    </div>
                </PagerContent>
            </MudTable>
        </div>
    </div>
}

@code {

    private CancellationReasonCodesByDocumentType model = new CancellationReasonCodesByDocumentType();
    private List<CancellationReasonCodesByDocumentType> collection = new List<CancellationReasonCodesByDocumentType>();
    private List<OrderModel> AssignedOrders = new List<OrderModel>();
    private List<OrderModel> Orders = new List<OrderModel>();
    private OrderModel OrderAssigned { get; set; }
    DialogOptions maxWidth = new DialogOptions() { MaxWidth = MaxWidth.Medium, FullWidth = true };

    public bool HasPermissionOrderServiceAddRemoveOrder { get; set; } = false;
    public int OrderDocTypeID = 45;
    public bool HasPermissionBranchServiceEdit { get; set; } = false;
    public bool HasPermissionBranchServiceDelete { get; set; } = false;
    public int BranchDocTypeID = 73;

    private bool _busy;
    private string searchBranch = "";
    private bool visibleOrders;
    private int? ClickedBranchID;
    private bool isLoaded = false;

    // Lifecycle method called when the component is initialized
    protected override async Task OnInitializedAsync()
    {
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionOrderServiceAddRemoveOrder = await Irole.HasClaim(OrderDocTypeID.ToString(), "AddRemoveOrder", ctc.Token);
        HasPermissionBranchServiceEdit = await Irole.HasClaim(BranchDocTypeID.ToString(), "Edit", ctc.Token);
        HasPermissionBranchServiceDelete = await Irole.HasClaim(BranchDocTypeID.ToString(), "Delete", ctc.Token);

        await GetAll();
    }

    // Method to fetch all cancellation reason codes by document type
    private async Task GetAll()
    {
        collection = Iservice.Select().ToList(); // Fetch data from the service
        isLoaded = true;
    }

    // Method to open the dialog for adding or editing a cancellation reason code
    private async Task Edit(CancellationReasonCodesByDocumentType model)
    {
        try
        {
            if (HasPermissionBranchServiceEdit)
            {
                if (_busy)
                {
                    snackbar.Add("Please wait while form is closing!", Severity.Warning);
                    return;
                }
                _busy = true;
                DialogParameters parms = new DialogParameters();
                parms.Add("model", model.Clone());
                var dialog = await DialogService.ShowAsync<CancellationReasonCodeDialog>("Add/Edit Branch", parms, new DialogOptions() { MaxWidth = MaxWidth.Medium });
                var result = await dialog.Result;
                if (!result.Canceled)
                {
                    CancellationReasonCodesByDocumentType UpdatedModel = (CancellationReasonCodesByDocumentType)result.Data;
                    if (UpdatedModel != null)
                    {

                        var authState = await auth.GetAuthenticationStateAsync();
                        if (UpdatedModel.UserInfo == null)
                        {
                            UpdatedModel.UserInfo = new();
                        }
                        UpdatedModel.UserInfo.UserID = authState.User.Identity.Name;
                        Iservice.Update(UpdatedModel); // Update the cancellation reason code
                        snackbar.Add("Saved Successfully", Severity.Success);
                    }

                }
            }
            else
            {
                bool? result = await DialogService.ShowMessageBoxAsync(
                    "Permission denied!",
                    "You don't have any permission to Edit Branch.");
            }
            await GetAll();
        }
        catch (Exception a)
        {
            snackbar.Add(a.Message, Severity.Error);
        }
        finally
        {
            await Task.Delay(200);
            _busy = false;
        }
    }

    // Method to delete a cancellation reason code
    private async Task Delete(CancellationReasonCodesByDocumentType model)
    {
        if (HasPermissionBranchServiceDelete)
        {
            bool? result = await DialogService.ShowMessageBoxAsync(
                "Warning !",
                "Are you sure, you want to delete branch - " + model.DocumentTypeName + "?");
            if (result == true)
            {
                var authprov = await auth.GetAuthenticationStateAsync();
                Iservice.Delete(model.ReasonCodeID, authprov.User.Identity.Name); // Delete the cancellation reason code
                snackbar.Add("Deleted Successfully", Severity.Success);
            }
        }
        else
        {
            bool? result = await DialogService.ShowMessageBoxAsync(
                "Permission denied!",
                "You don't have any permission to Delete Branch.");
        }
        await GetAll();
    }

    // Method to search for cancellation reason codes based on a search string
    private bool search(CancellationReasonCodesByDocumentType model)
    {
        if (searchBranch == string.Empty || model.DocumentTypeName != null && model.DocumentTypeName.Contains(searchBranch, StringComparison.OrdinalIgnoreCase))
        {
            return true;
        }
        return false;
    }
}

