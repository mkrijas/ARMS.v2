@page "/gst"
@inject IGstItemService Iservice

<MudItem xs="12">
    <MudTable Items="@model">
        <ToolBarContent>
            <MudText Typo="Typo.h6">GST Input-Output View</MudText>
        </ToolBarContent>
        <HeaderContent>
            <MudTh>Tax Type</MudTh>
            <MudTh>Input Account</MudTh>
            <MudTh>Output Account</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Tax Type">@context.GstType</MudTd>
            <MudTd DataLabel="Input Account">@context.InputAccount</MudTd>
            <MudTd DataLabel="Output Account">@context.OutputAccount</MudTd>
        </RowTemplate>
        <PagerContent>
            <MudTablePager PageSizeOptions="new int[] { 5, 10, 20, 50, 100 }" />
        </PagerContent>
    </MudTable>
</MudItem>

@code {

    private List<GstInOutModel> model = new List<GstInOutModel>();

    protected override async Task OnInitializedAsync()
    {
        {
            model = new List<GstInOutModel>();
            model = await Task.Run(() => Iservice.GetInOut().ToList());
        }
    }
}