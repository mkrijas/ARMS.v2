@page "/gst"
@inject IGstItemService Iservice

@if (_isLoading)
{
    <div @key="@("loader")" style="position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(255,255,255,0.9); z-index: 9999; display: flex; justify-content: center; align-items: center;">
        <LoaderComponent IsFullScreen="true" 
                        ShowLogo="false" 
                        Size="medium" 
                        LoadingText="Loading GST Input-Output" 
                        SubText="Please wait..." />
    </div>
}
else
{
    <div @key="@("content")">

<MudItem xs="12">
    <MudTable Items="@model" >
        <ToolBarContent>
            <MudText Typo="Typo.h6">GST Input-Output View</MudText>
        </ToolBarContent>
        <HeaderContent>
            <MudTh>Tax Type</MudTh>
            <MudTh>Input Account</MudTh>
            <MudTh>Output Account</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Tax Type">@context.GstType</MudTd>
            <MudTd DataLabel="Input Account">@context.InputAccount</MudTd>
            <MudTd DataLabel="Output Account">@context.OutputAccount</MudTd>
        </RowTemplate>
        <PagerContent>
            <MudTablePager PageSizeOptions="new int[] { 10, 20, 50, 100 }" />
        </PagerContent>
    </MudTable>
</MudItem>
</div>
}


@code {

    private bool _isLoading = true;
    private DateTime _loadStartTime;

    private List<GstInOutModel> model = new List<GstInOutModel>();

    // Lifecycle method called when the component is initialized
    protected override async Task OnInitializedAsync()
    {
        _loadStartTime = DateTime.Now;
        {
            model = new List<GstInOutModel>();

            // Fetch GST In/Out data asynchronously and populate the model
            model = await Task.Run(() => Iservice.GetInOut().ToList());
        }
        await EnsureMinimumLoadTime();
        _isLoading = false;
    }

    private async Task EnsureMinimumLoadTime()
    {
        var elapsed = (DateTime.Now - _loadStartTime).TotalMilliseconds;
        if (elapsed < 100)
        {
            await Task.Delay(100 - (int)elapsed);
        }
    }
}
