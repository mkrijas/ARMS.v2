@inject IGstItemService Iservice
@inject IGstUsageIDService gstusageIservice
@inject IInventoryItemService itemService
@inject MudBlazor.ISnackbar snackbar
@inject AuthenticationStateProvider auth
@attribute [Authorize]
@inject IDialogService DialogService
@using System.Threading;

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.Build" Class="mr-3 mb-n1" />
            Item GST
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudContainer Style="min-height:300px;max-height: 800px;">
            <EditForm id="formtdsRate" Model="@model" OnValidSubmit="OnValidSubmit">
                <ObjectGraphDataAnnotationsValidator />
                <ValidationSummary />
                <MudGrid Spacing="2">
                    <MudItem xs="12">
                        <MudAutocomplete Label="Select Item" Value="SelectedInventoryItem" ValueChanged=@((e) => OnchangeInventoryItem(e)) SearchFunc="SearchBanks" T="InventoryItemModel" Variant="Variant.Outlined" Margin="Margin.Dense" AdornmentColor="Color.Secondary"
                                         ToStringFunc="@(e => (e == null) ? null : (e.InventoryItemID == null ? "" : string.Format("{0} | {1} | {2} | {3}",e.InventoryItemCode, e.ItemGroup.ItemGroupDescription, e.ItemDescription, e.PartNumber)))"></MudAutocomplete>
                    </MudItem>
                    <MudItem xs="12">
                        <GstMechanismSelector @bind-Value="model.GstMechanism"></GstMechanismSelector>
                    </MudItem>
                    <MudItem xs="12">
                        <MudSelect Label="Select GST Rate" @bind-Value="model.RID" T="int?" Variant="Variant.Outlined" Margin="Margin.Dense" AdornmentColor="Color.Secondary" AnchorOrigin="Origin.BottomCenter">
                            @foreach (var ditem in gstRate)
                            {
                                <MudSelectItem Value="@ditem.RID">@ditem.TaxRate</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudDatePicker @bind-Date="model.PeriodFrom" Label="Period From" Variant="Variant.Outlined" Margin="Margin.Dense" AnchorOrigin="Origin.BottomLeft" DisableToolbar="true" Editable="true" HelperText="Enter Date" DateFormat="dd/MM/yyyy" />
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudDatePicker @bind-Date="model.PeriodTo" Label="Period To" Variant="Variant.Outlined" Margin="Margin.Dense" AnchorOrigin="Origin.BottomLeft" DisableToolbar="true" Editable="true" HelperText="Enter Date" DateFormat="dd/MM/yyyy" />
                    </MudItem>
                </MudGrid>
            </EditForm>
        </MudContainer>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Disabled="@_busy" form="formtdsRate" Variant="Variant.Filled" Color="Color.Success" ButtonType="ButtonType.Submit">Submit</MudButton>
    </DialogActions>
</MudDialog>

@code {

    [Parameter]
    public GstItemModel model { get; set; }
    private List<GstRateModel> gstRate = new();
    private List<InventoryItemModel> items = new();
    private GstItemModel tds = new();
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; }
    private ChartOfAccountModel SelectedAccount = null;
    public InventoryItemModel SelectedInventoryItem = new();

    private bool _busy;

    // Lifecycle method called when the component is initialized
    protected override void OnInitialized()
    {
        // Load inventory items and GST rates
        items = itemService.SearchByDescription(string.Empty).ToList();
        gstRate = gstusageIservice.GetGstRates().ToList();

        SelectedInventoryItem.InventoryItemID = model.ItemID;
        SelectedInventoryItem.InventoryItemCode = model.ItemCode;
        SelectedInventoryItem.ItemGroup.ItemGroupDescription = model.ItemGroupDescription;
        SelectedInventoryItem.ItemDescription = model.ItemDescription;
    }

    // Method to handle changes in the selected inventory item
    void OnchangeInventoryItem(InventoryItemModel item)
    {
        SelectedInventoryItem = item;
        model.ItemID = SelectedInventoryItem.InventoryItemID;
    }

    // Method to handle form submission when the form is valid
    private async void OnValidSubmit(EditContext context)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is being submitted!", Severity.Warning);
            return;
        }
        _busy = true;

        DateRange dr = new DateRange(model.PeriodFrom, model.PeriodTo);
        // Fetch existing GST items for the selected item ID
        List<GstItemModel> tdsList = Iservice.SelectByItem(model.ItemID.Value).Where(x => x.HsnID != model.HsnID).ToList();
        List<DateRange> drList = new List<DateRange>();
        tdsList.ForEach(item => drList.Add(new DateRange(item.PeriodFrom, item.PeriodTo)));
        if (CommonMethods.CheckPeriodOverlap(dr, drList))
        {
            snackbar.Add("Periods cannot be overlapped", Severity.Warning);
        }
        else
        {
            MudDialog.Close(model);
        }
        await Task.Delay(200);
        _busy = false;
    }

    // Method to search for inventory items based on a search string
    private async Task<IEnumerable<InventoryItemModel>> SearchBanks(string searchString, CancellationToken token)
    {
        if (string.IsNullOrEmpty(searchString))
            return items;

        return await Task.FromResult(items.Where(x => x.InventoryItemCode.Contains(searchString, StringComparison.InvariantCultureIgnoreCase) 
                                                   || x.ItemGroup.ItemGroupDescription.Contains(searchString, StringComparison.InvariantCultureIgnoreCase)
                                                   || x.ItemDescription.Contains(searchString, StringComparison.InvariantCultureIgnoreCase)));

    }

    private void Cancel()
    {
        MudDialog.Cancel();
    }
}
