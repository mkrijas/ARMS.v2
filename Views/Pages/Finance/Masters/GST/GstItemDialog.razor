@inject IGstItemService Iservice
@inject IGstUsageIDService gstusageIservice
@inject IInventoryItemService itemService
@inject MudBlazor.ISnackbar snackbar
@inject AuthenticationStateProvider auth
@attribute [Authorize]
@inject IDialogService DialogService

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.Build" Class="mr-3 mb-n1" />
            Item GST
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudContainer Style="min-height:300px;max-height: 800px;">
            <EditForm id="formtdsRate" Model="@model" OnValidSubmit="OnValidSubmit">
                <ObjectGraphDataAnnotationsValidator />
                <ValidationSummary />
                <MudGrid Spacing="2">
                    <MudItem xs="12">
                        <MudSelect Label="Select Item" @bind-Value="model.ItemID" T="int?" Variant="Variant.Outlined" Margin="Margin.Dense" OffsetY="true" Direction="Direction.Top" AdornmentColor="Color.Secondary">
                            @foreach (var ditem in items)
                            {
                                <MudSelectItem Value="@ditem.InventoryItemID">@(ditem.InventoryItemCode) (@(ditem.ItemDescription))</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12">
                        <MudSelect Label="Select RID" @bind-Value="model.RID" T="int?" Variant="Variant.Outlined" Margin="Margin.Dense" OffsetY="true" Direction="Direction.Top" AdornmentColor="Color.Secondary">
                            @foreach (var ditem in gstRate)
                            {
                                <MudSelectItem Value="@ditem.RID">@ditem.TaxRate</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudDatePicker Label="Period From" Variant="Variant.Outlined" Margin="Margin.Dense" DisableToolbar="true" Editable="true" @bind-Date="model.PeriodFrom" HelperText="Enter Date" DateFormat="dd/MM/yyyy" />
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudDatePicker Label="Period To" Variant="Variant.Outlined" Margin="Margin.Dense" DisableToolbar="true" Editable="true" @bind-Date="model.PeriodTo" HelperText="Enter Date" DateFormat="dd/MM/yyyy" />
                    </MudItem>
                </MudGrid>
            </EditForm>
        </MudContainer>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Disabled="@_busy" form="formtdsRate" Variant="Variant.Filled" Color="Color.Success" ButtonType="ButtonType.Submit">Submit</MudButton>
    </DialogActions>
</MudDialog>

@code {

    [Parameter]
    public GstItemModel model { get; set; }
    private List<GstItemModel> collection = new List<GstItemModel>();
    private List<GstRateModel> gstRate = new();
    private List<InventoryItemModel> items = new();
    private GstItemModel tds = new();
    [CascadingParameter] MudDialogInstance MudDialog { get; set; }
    private ChartOfAccountModel SelectedAccount = null;

    private bool _busy;

    protected override void OnInitialized()
    {
        items = itemService.SearchByDescription(string.Empty).ToList();
        gstRate = gstusageIservice.GetGstRates().ToList();
    }

    private async void OnValidSubmit(EditContext context)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is being submitted!", Severity.Warning);
            return;
        }
        _busy = true;

        DateRange dr = new DateRange(model.PeriodFrom, model.PeriodTo);
        List<GstItemModel> tdsList = Iservice.SelectByItem(model.ItemID.Value).Where(x => x.HsnID != model.HsnID).ToList();
        List<DateRange> drList = new List<DateRange>();
        tdsList.ForEach(item => drList.Add(new DateRange(item.PeriodFrom, item.PeriodTo)));
        if (CommonMethods.CheckPeriodOverlap(dr, drList))
        {
            snackbar.Add("Periods cannot be overlapped", Severity.Success);
        }
        else
        {
            MudDialog.Close(model);
        }
        await Task.Delay(200);
        _busy = false;
    }

    private void Cancel()
    {
        MudDialog.Cancel();
    }
}