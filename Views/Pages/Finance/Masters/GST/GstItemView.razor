@page "/GstItems"
@inject IGstItemService Iservice
@inject MudBlazor.ISnackbar snackbar
@inject AuthenticationStateProvider auth
@attribute [Authorize]
@using System.Threading;
@inject IRoleService<RoleModel> Irole
@inject IDialogService DialogService

<MudGrid Spacing="4">
    <MudItem xs="12">
        <MudTable Items="@collection" Dense="true" Hover="true" Striped="true" Elevation="10" Filter="new Func<GstItemModel, bool>(search)" @bind-place="model">
            <ToolBarContent>
                <MudText Typo="Typo.h6">GST Inventory Items</MudText>
                <MudIconButton Disabled="@_busy" Icon="@Icons.Material.Filled.Add" Title="Add" @onclick="@(()=> OpenDialog(model))" Color="Color.Dark" Size="Size.Small"></MudIconButton>
                <MudSpacer></MudSpacer>
                <MudTextField @bind-Value="searchItem" Placeholder="Search Items... " Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0"></MudTextField>
                <MudCheckBox Label="Show All" T="bool" CheckedChanged="GstItemToggled" Checked="@GstItemToggle" Size="Size.Medium" Color="Color.Primary" Class="tablefont margin0"></MudCheckBox>
            </ToolBarContent>
            <HeaderContent>
                <MudTh><MudTableSortLabel SortBy="new Func<GstItemModel, object>(x=> x.ItemCode)" InitialDirection="SortDirection.Ascending">Item Code</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<GstItemModel, object>(x=> x.TaxRate)" InitialDirection="SortDirection.Ascending">Tax Rate</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<GstItemModel, object>(x=> x.PeriodFrom)" InitialDirection="SortDirection.Ascending">Period From</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<GstItemModel, object>(x=> x.PeriodTo)" InitialDirection="SortDirection.Ascending">Period To</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<GstItemModel, object>(x=> x.HsnCode)" InitialDirection="SortDirection.Ascending">Hsn Code</MudTableSortLabel></MudTh>
                <MudTh>Actions</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="ItemCode">@(context.ItemCode) (@(context.ItemGroupDescription)-@(context.ItemDescription))</MudTd>
                <MudTd DataLabel="TaxRate">@context.TaxRate</MudTd>
                <MudTd DataLabel="PeriodFrom">@context.PeriodFrom?.ToShortDateString()</MudTd>
                <MudTd DataLabel="PeriodTo">@context.PeriodTo?.ToShortDateString()</MudTd>
                <MudTd DataLabel="Hsn Code">@context.HsnCode</MudTd>
                <MudTd DataLabel="">
                    <MudFab @onclick="@(()=> OpenDialog(context))" Color="Color.Primary" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" IconSize="Size.Small" />
                    <MudFab @onclick="@(()=> Delete(context))" Color="Color.Primary" Icon="@Icons.Material.Filled.Delete" Size="Size.Small" IconSize="Size.Small" />
                </MudTd>
            </RowTemplate>
            <PagerContent>
                <MudTablePager PageSizeOptions="new int[] { 10, 20, 50, 100 }" />
            </PagerContent>
        </MudTable>
    </MudItem>
</MudGrid>

@code {

    private GstItemModel model = new GstItemModel();
    private List<GstItemModel> collection = new List<GstItemModel>();
    private string searchItem = "";
    public bool GstItemToggle { get; set; } = false;
    private bool _busy;

    public bool HasPermissionGstItemServiceEdit { get; set; } = false;
    public bool HasPermissionGstItemServiceDelete { get; set; } = false;
    public int GstItemDocTypeID = 102;

    protected override async Task OnInitializedAsync()
    {
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionGstItemServiceEdit = await Irole.HasClaim(GstItemDocTypeID.ToString(), "Edit", ctc.Token);
        HasPermissionGstItemServiceDelete = await Irole.HasClaim(GstItemDocTypeID.ToString(), "Delete", ctc.Token);

        model = new();
        GstItemToggled(false);
    }

    private async Task OpenDialog(GstItemModel tds)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        _busy = true;

        if (HasPermissionGstItemServiceEdit)
        {
            var authprov = await auth.GetAuthenticationStateAsync();
            var user = authprov.User;
            DialogParameters parms = new DialogParameters();
            parms.Add("model", tds.Clone());
            var dialog = DialogService.Show<GstItemDialog>(tds.HsnID == null ? "ADD" : "EDIT", parms);
            var result = await dialog.Result;
            if (!result.Cancelled)
            {
                GstItemModel UpatedModel = (GstItemModel)result.Data;
                UpatedModel.UserInfo.UserID = user.Identity.Name;
                try
                {
                    Iservice.Update(UpatedModel);
                    model = new();
                    snackbar.Add("Saved Successfully", Severity.Success);
                    model = new GstItemModel();
                    GstItemToggled(GstItemToggle);
                }
                catch (Exception ex)
                {
                    snackbar.Add(ex.Message, Severity.Warning);
                }
            }
        }
        else
        {
            bool? result = await DialogService.ShowMessageBox(
                "Permission denied!",
                "You dont have any permission to Edit GstItem.");
        }
        await Task.Delay(200);
        _busy = false;
    }

    private async Task Delete(GstItemModel model)
    {
        if (HasPermissionGstItemServiceDelete)
        {
            bool? result = await DialogService.ShowMessageBox(
                "Warning !",
                "Are you sure, you want to delete - " + model.ItemCode + " (" + model.ItemDescription + ") ?");
            if (result == true)
            {
                var authprov = await auth.GetAuthenticationStateAsync();
                var user = authprov.User;
                var value = Iservice.Delete(model.HsnID.Value, user.Identity.Name);
                if (value != -1)
                {
                    snackbar.Add("Deleted Successfully", Severity.Success);
                    GstItemToggled(GstItemToggle);
                }
            }
        }
        else
        {
            bool? result = await DialogService.ShowMessageBox(
                "Permission denied!",
                "You dont have any permission to Delete GstItem.");
        }
    }

    private bool search(GstItemModel tds)
    {
        if (tds.ItemCode != null && tds.ItemCode.Contains(searchItem, StringComparison.OrdinalIgnoreCase))
        {
            return true;
        }
        else if (tds.ItemCode == null)
            return true;
        return false;
    }

    private void GstItemToggled(bool Toggle)
    {
        if (collection != null)
        {
            collection.Clear();
        }
        GstItemToggle = Toggle;
        DateTime? dtm = Toggle ? null : DateTime.Today;
        collection = Iservice.SelectByDate(dtm).ToList();
    }
}