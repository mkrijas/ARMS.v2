@page "/GstItems"
@inject IGstItemService Iservice
@inject MudBlazor.ISnackbar snackbar
@inject AuthenticationStateProvider auth
@attribute [Authorize]
@using System.Threading;
@inject IRoleService<RoleModel> Irole
@inject IDialogService DialogService

@if (_isLoading)
{
    <div @key="@("loader")" style="display: flex; justify-content: center; align-items: center; min-height: 400px;">
        <LoaderComponent IsFullScreen="true" 
                        ShowLogo="false" 
                        Size="medium" 
                        LoadingText="Loading GST Items" 
                        SubText="Please wait..." />
    </div>
}
else
{
    <div class="fade-in">
        <div class="admin-header-tiered mb-6">
            <div class="d-flex align-center justify-space-between">
                <div>
                    <MudText Typo="Typo.h4" Class="admin-title">Inventory GST Classification</MudText>
                    <MudText Typo="Typo.body2" Class="admin-subtitle">Maintain HSN and tax rate assignments for the entire inventory catalog. monitor tax applicability timelines and ensure accurate fiscal categorization of goods.</MudText>
                </div>
                <MudButton StartIcon="@Icons.Material.Filled.Add" Variant="Variant.Filled" Color="Color.Primary" Class="admin-register-btn" OnClick="@(()=> OpenDialog(model))" Disabled="@_busy">ADD TAX PROFILE</MudButton>
            </div>
        </div>

        <div class="admin-glass-card mb-6 pa-4">
            <div class="d-flex align-center gap-4 flex-wrap">
                <div style="flex-grow: 1; min-width: 300px;">
                    <MudTextField @bind-Value="searchItem" Placeholder="Search by code, group or description..." Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" Variant="Variant.Outlined" Margin="Margin.Dense" Class="admin-input-group" Clearable="true" />
                </div>
                <div class="d-flex align-center gap-4 bg-glass rounded-pill px-4 py-1">
                    <MudCheckBox Label="Show All Records" T="bool" ValueChanged="GstItemToggled" Value="@GstItemToggle" Size="Size.Small" Color="Color.Primary" Class="fw-600"></MudCheckBox>
                </div>
            </div>
        </div>

        <div class="admin-glass-card pa-0 overflow-hidden">
            <MudTable Items="@collection" Elevation="0" Class="modern-admin-table" Hover="true" Filter="new Func<GstItemModel, bool>(search)">
                <HeaderContent>
                    <MudTh><MudTableSortLabel SortBy="new Func<GstItemModel, object>(x=> x.ItemCode)" InitialDirection="SortDirection.Ascending"><span class="admin-header-text">ITEM / DESCRIPTION</span></MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<GstItemModel, object>(x=> x.TaxRate)" InitialDirection="SortDirection.Ascending"><span class="admin-header-text">TAX RATE</span></MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<GstItemModel, object>(x=> x.PeriodFrom)" InitialDirection="SortDirection.Ascending"><span class="admin-header-text">PERIOD FROM</span></MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<GstItemModel, object>(x=> x.PeriodTo)" InitialDirection="SortDirection.Ascending"><span class="admin-header-text">PERIOD TO</span></MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<GstItemModel, object>(x=> x.HsnCode)" InitialDirection="SortDirection.Ascending"><span class="admin-header-text">HSN CODE</span></MudTableSortLabel></MudTh>
                    <MudTh Style="text-align: right;"><span class="admin-header-text">ACTIONS</span></MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Item Detail">
                        <div class="d-flex flex-column">
                            <span class="fw-700 admin-td-primary">@context.ItemCode</span>
                            <span class="small opa-70">@context.ItemGroupDescription - @context.ItemDescription (@context.PartNumber)</span>
                        </div>
                    </MudTd>
                    <MudTd DataLabel="Rate">
                        <MudChip T="string" Color="Color.Info" Variant="Variant.Filled" Size="Size.Small" Class="fw-700 px-3">@context.TaxRate%</MudChip>
                    </MudTd>
                    <MudTd DataLabel="From"><span class="fw-500">@context.PeriodFrom?.ToShortDateString()</span></MudTd>
                    <MudTd DataLabel="To"><span class="fw-500">@context.PeriodTo?.ToShortDateString()</span></MudTd>
                    <MudTd DataLabel="HSN"><span class="fw-600 font-monospace opa-80">@context.HsnCode</span></MudTd>
                    <MudTd DataLabel="Actions" Style="text-align: right;">
                        <div class="d-flex justify-end gap-1">
                            <MudTooltip Text="Edit Profile">
                                <MudIconButton OnClick="@(()=> OpenDialog(context))" Color="Color.Primary" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Variant="Variant.Text" />
                            </MudTooltip>
                            <MudTooltip Text="Delete Profile">
                                <MudIconButton OnClick="@(()=> Delete(context))" Color="Color.Error" Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Variant="Variant.Text" />
                            </MudTooltip>
                        </div>
                    </MudTd>
                </RowTemplate>
                <PagerContent>
                    <div class="pa-4">
                        <MudTablePager PageSizeOptions="new int[] { 10, 20, 50, 100 }" />
                    </div>
                </PagerContent>
            </MudTable>
        </div>
    </div>
}


@code {

    private bool _isLoading = true;
    private DateTime _loadStartTime;

    private GstItemModel model = new GstItemModel();
    private List<GstItemModel> collection = new List<GstItemModel>();
    private string searchItem = "";
    public bool GstItemToggle { get; set; } = false;
    private bool _busy;

    public bool HasPermissionGstItemServiceEdit { get; set; } = false;
    public bool HasPermissionGstItemServiceDelete { get; set; } = false;
    public int GstItemDocTypeID = 102;

    // Lifecycle method called when the component is initialized 
    protected override async Task OnInitializedAsync()
    {
        _loadStartTime = DateTime.Now;
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionGstItemServiceEdit = await Irole.HasClaim(GstItemDocTypeID.ToString(), "Edit", ctc.Token);
        HasPermissionGstItemServiceDelete = await Irole.HasClaim(GstItemDocTypeID.ToString(), "Delete", ctc.Token);

        model = new();
        GstItemToggled(false);
        await EnsureMinimumLoadTime();
        _isLoading = false;
    }

    private async Task EnsureMinimumLoadTime()
    {
        var elapsed = (DateTime.Now - _loadStartTime).TotalMilliseconds;
        if (elapsed < 100)
        {
            await Task.Delay(100 - (int)elapsed);
        }
    }

    // Method to open the dialog for adding or editing a GST item
    private async Task OpenDialog(GstItemModel tds)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        _busy = true;

        if (HasPermissionGstItemServiceEdit)
        {
            var authprov = await auth.GetAuthenticationStateAsync();
            var user = authprov.User;
            DialogParameters parms = new DialogParameters();
            parms.Add("model", tds.Clone());
            var dialog = await DialogService.ShowAsync<GstItemDialog>(tds.HsnID == null ? "ADD" : "EDIT", parms);
            var result = await dialog.Result;
            if (!result.Canceled)
            {
                GstItemModel UpatedModel = (GstItemModel)result.Data;
                UpatedModel.UserInfo.UserID = user.Identity.Name;
                try
                {
                    Iservice.Update(UpatedModel); // Update the GST item
                    model = new();
                    snackbar.Add("Saved Successfully", Severity.Success);
                    model = new GstItemModel();
                    GstItemToggled(GstItemToggle);
                }
                catch (Exception ex)
                {
                    snackbar.Add(ex.Message, Severity.Warning);
                }
            }
        }
        else
        {
            bool? result = await DialogService.ShowMessageBoxAsync(
                "Permission denied!",
                "You don't have any permission to Edit GstItem.");
        }
        await Task.Delay(200);
        _busy = false;
    }

    // Method to delete a GST item
    private async Task Delete(GstItemModel model)
    {
        if (HasPermissionGstItemServiceDelete)
        {
            bool? result = await DialogService.ShowMessageBoxAsync(
                "Warning !",
                "Are you sure, you want to delete - " + model.ItemCode + " (" + model.ItemDescription + ") ?");
            if (result == true)
            {
                var authprov = await auth.GetAuthenticationStateAsync();
                var user = authprov.User;
                var value = Iservice.Delete(model.HsnID.Value, user.Identity.Name); // Call service to delete the item
                if (value != -1)
                {
                    snackbar.Add("Deleted Successfully", Severity.Success);
                    GstItemToggled(GstItemToggle);
                }
            }
        }
        else
        {
            bool? result = await DialogService.ShowMessageBoxAsync(
                "Permission denied!",
                "You don't have any permission to Delete GstItem.");
        }
    }

    // Method to search for GST items based on the search term
    private bool search(GstItemModel tds)
    {
        if (tds.ItemCode != null && tds.ItemCode.Contains(searchItem, StringComparison.OrdinalIgnoreCase) 
                                 || tds.ItemGroupDescription.Contains(searchItem, StringComparison.OrdinalIgnoreCase) 
                                 || tds.ItemDescription.Contains(searchItem, StringComparison.OrdinalIgnoreCase))
        {
            return true;
        }
        else if (tds.ItemCode == null)
            return true;
        return false;
    }

    // Method to toggle the display of GST items
    private void GstItemToggled(bool Toggle)
    {
        if (collection != null)
        {
            collection.Clear();
        }
        GstItemToggle = Toggle;
        DateTime? dtm = Toggle ? null : DateTime.Today;
        collection = Iservice.SelectByDate(dtm).ToList(); // Load GST items based on the date
    }
}

