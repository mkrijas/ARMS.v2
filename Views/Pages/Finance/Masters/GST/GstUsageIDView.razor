@page "/GstUsageID"
@inject IGstUsageIDService Iservice
@inject MudBlazor.ISnackbar snackbar

@inject AuthenticationStateProvider auth
@attribute [Authorize]
@inject IDialogService DialogService





<MudGrid Spacing="4">
    <MudItem xs="12">
        <MudTable Items="@collection" Dense="true" Hover="true" Striped="true" Elevation="10" Filter="new Func<GstUsageCodeModel, bool>(search)" @bind-place="model">
            <ToolBarContent>
                <MudText Typo="Typo.h6">GstUsageID</MudText>
                <MudIconButton Icon="@Icons.Material.Filled.Add" Title="Add" @onclick="@(()=> OpenDialog(model))" Color="Color.Dark" Size="Size.Small"></MudIconButton>

                <MudSpacer></MudSpacer>                
                <MudTextField @bind-Value="searchTds" Placeholder="Search TDS... "
                              Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                              IconSize="Size.Medium" Class="mt-0"></MudTextField>
                <MudCheckBox T="bool" Size="Size.Medium" Checked="SelectAll" CheckedChanged="SelectAllChanged" Label="Select All" Class="tablefont margin0 pr-3"></MudCheckBox>
            </ToolBarContent>
            <HeaderContent>
                <MudTh><MudTableSortLabel SortBy="new Func<GstUsageCodeModel, object>(x=> x.UsageCode)" InitialDirection="SortDirection.Ascending">UsageCode</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<GstUsageCodeModel, object>(x=> x.Description)" InitialDirection="SortDirection.Ascending">Description</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<GstUsageCodeModel, object>(x=> x.SAC)" InitialDirection="SortDirection.Ascending">SAC</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<GstUsageCodeModel, object>(x=> x.CoaDescreption)" InitialDirection="SortDirection.Ascending">Account</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<GstUsageCodeModel, object>(x=> x.TaxRate)" InitialDirection="SortDirection.Ascending">Rate</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<GstUsageCodeModel, object>(x=> x.PeriodFrom)" InitialDirection="SortDirection.Ascending">PeriodFrom</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<GstUsageCodeModel, object>(x=> x.PeriodTo)" InitialDirection="SortDirection.Ascending">PeriodTo</MudTableSortLabel></MudTh>    
                <MudTh>Actions</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="UsageID">@context.UsageCode</MudTd>
                <MudTd DataLabel="AccountID">@context.Description</MudTd>
                <MudTd DataLabel="TaxRate">@context.SAC</MudTd>
                <MudTd DataLabel="AccountID">@context.CoaDescreption</MudTd>
                <MudTd DataLabel="TaxRate">@context.TaxRate</MudTd>
                <MudTd DataLabel="PeriodFrom">@context.PeriodFrom?.ToShortDateString()</MudTd>
                <MudTd DataLabel="PeriodTo">@context.PeriodTo?.ToShortDateString()</MudTd>
                <MudTd DataLabel="">
                    <MudFab @onclick="@(()=> OpenDialog(context))" Color="Color.Primary" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" IconSize="Size.Small" />
                    <MudFab @onclick="@(()=> Delete(context))" Color="Color.Primary" Icon="@Icons.Material.Filled.Delete" Size="Size.Small" IconSize="Size.Small" />
                </MudTd>
            </RowTemplate>
            <PagerContent>
                <MudTablePager PageSizeOptions="new int[] { 5, 10, 20, 50, 100 }" />
            </PagerContent>
        </MudTable>
    </MudItem>
</MudGrid>



@code {


    private GstUsageCodeModel model = new GstUsageCodeModel();
    private List<GstUsageCodeModel> collection = new List<GstUsageCodeModel>();

    public bool SelectAll = false;
    private string searchTds = "";

    protected override void OnInitialized()
    {
        model = new();
        GetAll(SelectAll);
    }



    private async Task OpenDialog(GstUsageCodeModel tds)
    {
        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;

        DialogParameters parms = new DialogParameters();
        parms.Add("model", model.Clone());
        var dialog = DialogService.Show<GstUsageIDDialog>(tds.Id == null ? "ADD" : "EDIT", parms);
        var result = await dialog.Result;

        if (!result.Canceled)
        {
            GstUsageCodeModel UpatedModel = (GstUsageCodeModel)result.Data;
            model.UserInfo.UserID = user.Identity.Name;

            try
            {

                Iservice.Update(UpatedModel);
                model = new();
                snackbar.Add("Saved Successfully", Severity.Success);
                model = new GstUsageCodeModel();
                GetAll(SelectAll);
            }
            catch (Exception ex)
            {
                snackbar.Add(ex.Message, Severity.Warning);
            }

        }
    }

    private async Task Delete(GstUsageCodeModel tds)
    {

        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User.Identity.Name;
        Iservice.Delete(tds.Id, user);
        snackbar.Add("Deleted Successfully", Severity.Success);
        GetAll(SelectAll);
    }

    private bool search(GstUsageCodeModel tds)
    {
        if (tds.UsageCode != null && tds.UsageCode.Contains(searchTds, StringComparison.OrdinalIgnoreCase))
        {
            return true;
        }
        else if (tds.UsageCode == null)
            return true;
        return false;
    }

    void SelectAllChanged(bool val)
    {
        SelectAll = val;
        GetAll(val);
    }

    private void GetAll(bool val)
    {
        DateTime? Today = val ? null : DateTime.Today;
        collection = Iservice.Select(Today).ToList();        
    }
}
