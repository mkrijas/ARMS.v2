@page "/GstUsageID"
@inject IGstUsageIDService Iservice
@inject MudBlazor.ISnackbar snackbar
@inject AuthenticationStateProvider auth
@attribute [Authorize]
@using System.Threading;
@inject IRoleService<RoleModel> Irole
@inject IDialogService DialogService

<MudGrid Spacing="4">
    <MudItem xs="12">
        <MudTable Items="@collection" Dense="true" Hover="true" Striped="true" Elevation="10" Filter="new Func<GstUsageCodeModel, bool>(search)">
            <ToolBarContent>
                <MudText Typo="Typo.h6">Chart of Account Usage Codes</MudText>
                <MudIconButton Disabled="@_busy" Icon="@Icons.Material.Filled.Add" Title="Add" @onclick="@(()=> OpenDialog(model))" Color="Color.Dark" Size="Size.Small"></MudIconButton>
                <MudSpacer></MudSpacer>
                <MudTextField @bind-Value="searchGstUsageID" Placeholder="Search Gst Usage ID... " Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0"></MudTextField>
                <MudCheckBox T="bool" Size="Size.Medium" Checked="SelectAll" CheckedChanged="SelectAllChanged" Label="Show All" Class="tablefont margin0 pr-3"></MudCheckBox>
            </ToolBarContent>
            <HeaderContent>
                <MudTh><MudTableSortLabel SortBy="new Func<GstUsageCodeModel, object>(x=> x.UsageCode)" InitialDirection="SortDirection.Ascending">Usage Code</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<GstUsageCodeModel, object>(x=> x.Description)" InitialDirection="SortDirection.Ascending">Description</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<GstUsageCodeModel, object>(x=> x.SAC)" InitialDirection="SortDirection.Ascending">SAC</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<GstUsageCodeModel, object>(x=> x.CoaDescreption)" InitialDirection="SortDirection.Ascending">Account</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<GstUsageCodeModel, object>(x=> x.TaxRate)" InitialDirection="SortDirection.Ascending">Rate</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<GstUsageCodeModel, object>(x=> x.PeriodFrom)" InitialDirection="SortDirection.Ascending">Period From</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<GstUsageCodeModel, object>(x=> x.PeriodTo)" InitialDirection="SortDirection.Ascending">Period To</MudTableSortLabel></MudTh>
                <MudTh>Actions</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="UsageID">@context.UsageCode</MudTd>
                <MudTd DataLabel="AccountID">@context.Description</MudTd>
                <MudTd DataLabel="TaxRate">@context.SAC</MudTd>
                <MudTd DataLabel="AccountID">@context.CoaDescreption</MudTd>
                <MudTd DataLabel="TaxRate">@context.TaxRate</MudTd>
                <MudTd DataLabel="PeriodFrom">@context.PeriodFrom?.ToShortDateString()</MudTd>
                <MudTd DataLabel="PeriodTo">@context.PeriodTo?.ToShortDateString()</MudTd>
                <MudTd DataLabel="">
                    <MudFab @onclick="@(()=> OpenDialog(context))" Color="Color.Primary" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" IconSize="Size.Small" />
                    <MudFab @onclick="@(()=> Delete(context))" Color="Color.Primary" Icon="@Icons.Material.Filled.Delete" Size="Size.Small" IconSize="Size.Small" />
                </MudTd>
            </RowTemplate>
            <PagerContent>
                <MudTablePager PageSizeOptions="new int[] { 10, 20, 50, 100 }" />
            </PagerContent>
        </MudTable>
    </MudItem>
</MudGrid>

@code {

    private GstUsageCodeModel model = new GstUsageCodeModel();
    private List<GstUsageCodeModel> collection = new List<GstUsageCodeModel>();
    public bool SelectAll = false;
    private string searchGstUsageID = "";
    private bool _busy;

    public bool HasPermissionGstUsageIDServiceEdit { get; set; } = false;
    public bool HasPermissionGstUsageIDServiceDelete { get; set; } = false;
    public int GstUsageIDDocTypeID = 101;

    protected override async Task OnInitializedAsync()
    {
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionGstUsageIDServiceEdit = await Irole.HasClaim(GstUsageIDDocTypeID.ToString(), "Edit", ctc.Token);
        HasPermissionGstUsageIDServiceDelete = await Irole.HasClaim(GstUsageIDDocTypeID.ToString(), "Delete", ctc.Token);

        model = new();
        GetAll(SelectAll);
    }

    private async Task OpenDialog(GstUsageCodeModel tds)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        _busy = true;

        if (HasPermissionGstUsageIDServiceEdit)
        {
            var authprov = await auth.GetAuthenticationStateAsync();
            var user = authprov.User;
            DialogParameters parms = new DialogParameters();
            parms.Add("model", tds.Clone());
            var dialog = DialogService.Show<GstUsageIDDialog>(tds.Id == null ? "ADD" : "EDIT", parms);
            var result = await dialog.Result;
            if (!result.Canceled)
            {
                GstUsageCodeModel UpatedModel = (GstUsageCodeModel)result.Data;
                UpatedModel.UserInfo.UserID = user.Identity.Name;
                try
                {
                    Iservice.Update(UpatedModel);
                    model = new();
                    snackbar.Add("Saved Successfully", Severity.Success);
                    model = new GstUsageCodeModel();
                    GetAll(SelectAll);
                }
                catch (Exception ex)
                {
                    snackbar.Add(ex.Message, Severity.Warning);
                }
            }
        }
        else
        {
            bool? result = await DialogService.ShowMessageBox(
                "Permission denied!",
                "You don't have any permission to Edit GstUsageID.");
        }
        await Task.Delay(200);
        _busy = false;
    }

    private async Task Delete(GstUsageCodeModel model)
    {
        if (HasPermissionGstUsageIDServiceDelete)
        {
            bool? result = await DialogService.ShowMessageBox(
                "Warning !",
                "Are you sure, you want to delete - " + model.UsageCode + " (" + model.Description + ") ?");
            if (result == true)
            {
                var authprov = await auth.GetAuthenticationStateAsync();
                var user = authprov.User.Identity.Name;
                Iservice.Delete(model.Id, user);
                snackbar.Add("Deleted Successfully", Severity.Success);
            }
            GetAll(SelectAll);
        }
        else
        {
            bool? result = await DialogService.ShowMessageBox(
                "Permission denied!",
                "You don't have any permission to Delete GstUsageID.");
        }
    }

    private bool search(GstUsageCodeModel tds)
    {
        if (tds.UsageCode != null && tds.UsageCode.Contains(searchGstUsageID, StringComparison.OrdinalIgnoreCase) || tds.Description != null && tds.Description.Contains(searchGstUsageID, StringComparison.OrdinalIgnoreCase))
        {
            return true;
        }
        else if (tds.UsageCode == null)
            return true;
        return false;
    }

    void SelectAllChanged(bool val)
    {
        SelectAll = val;
        GetAll(val);
    }

    private void GetAll(bool val)
    {
        DateTime? Today = val ? null : DateTime.Today;
        collection = Iservice.Select(null).ToList();
    }
}