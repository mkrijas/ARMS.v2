@page "/GstUsageID"
@inject IGstUsageIDService Iservice
@inject MudBlazor.ISnackbar snackbar
@inject AuthenticationStateProvider auth
@attribute [Authorize]
@using System.Threading;
@inject IRoleService<RoleModel> Irole
@inject IDialogService DialogService

@if (_isLoading)
{
    <div @key="@("loader")" style="display: flex; justify-content: center; align-items: center; min-height: 400px;">
        <LoaderComponent IsFullScreen="true" 
                        ShowLogo="false" 
                        Size="medium" 
                        LoadingText="Loading GST Usage Codes" 
                        SubText="Please wait..." />
    </div>
}
else
{
    <div class="fade-in">
        <div class="admin-header-tiered mb-6">
            <div class="d-flex align-center justify-space-between">
                <div>
                    <MudText Typo="Typo.h4" Class="admin-title">Service Account SAC Classification</MudText>
                    <MudText Typo="Typo.body2" Class="admin-subtitle">Configuration of SAC codes and tax rates for service-oriented usage ID's. maintain precise tax applicability for non-inventory financial transactions.</MudText>
                </div>
                <MudButton StartIcon="@Icons.Material.Filled.Add" Variant="Variant.Filled" Color="Color.Primary" Class="admin-register-btn" OnClick="@(()=> OpenDialog(model))" Disabled="@_busy">REGISTER SAC PROFILE</MudButton>
            </div>
        </div>

        <div class="admin-glass-card mb-6 pa-4">
            <div class="d-flex align-center gap-4 flex-wrap">
                <div style="flex-grow: 1; min-width: 300px;">
                    <MudTextField @bind-Value="searchGstUsageID" Placeholder="Search by code or description..." Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" Variant="Variant.Outlined" Margin="Margin.Dense" Class="admin-input-group" Clearable="true" />
                </div>
                <div class="d-flex align-center gap-4 bg-glass rounded-pill px-4 py-1">
                    <MudCheckBox T="bool" Size="Size.Small" Value="SelectAll" ValueChanged="SelectAllChanged" Label="Show All Records" Color="Color.Primary" Class="fw-600"></MudCheckBox>
                </div>
            </div>
        </div>

        <div class="admin-glass-card pa-0 overflow-hidden">
            <MudTable Items="@collection" Elevation="0" Class="modern-admin-table" Hover="true" Filter="new Func<GstUsageCodeModel, bool>(search)">
                <HeaderContent>
                    <MudTh><MudTableSortLabel SortBy="new Func<GstUsageCodeModel, object>(x=> x.UsageCode)" InitialDirection="SortDirection.Ascending"><span class="admin-header-text">USAGE CODE</span></MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<GstUsageCodeModel, object>(x=> x.Description)" InitialDirection="SortDirection.Ascending"><span class="admin-header-text">DESCRIPTION</span></MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<GstUsageCodeModel, object>(x=> x.SAC)" InitialDirection="SortDirection.Ascending"><span class="admin-header-text">SAC</span></MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<GstUsageCodeModel, object>(x=> x.CoaDescreption)" InitialDirection="SortDirection.Ascending"><span class="admin-header-text">GL ACCOUNT</span></MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<GstUsageCodeModel, object>(x=> x.TaxRate)" InitialDirection="SortDirection.Ascending"><span class="admin-header-text">RATE</span></MudTableSortLabel></MudTh>
                    <MudTh><span class="admin-header-text">VALIDITY</span></MudTh>
                    <MudTh Style="text-align: right;"><span class="admin-header-text">ACTIONS</span></MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Code"><span class="fw-700 admin-td-primary">@context.UsageCode</span></MudTd>
                    <MudTd DataLabel="Description"><span class="fw-500">@context.Description</span></MudTd>
                    <MudTd DataLabel="SAC"><span class="fw-600 font-monospace opa-70">@context.SAC</span></MudTd>
                    <MudTd DataLabel="Account"><span class="fw-500 small">@context.CoaDescreption</span></MudTd>
                    <MudTd DataLabel="Rate">
                        <MudChip T="string" Color="Color.Info" Variant="Variant.Filled" Size="Size.Small" Class="fw-700 px-3">@context.TaxRate%</MudChip>
                    </MudTd>
                    <MudTd DataLabel="Validity">
                        <div class="d-flex flex-column small">
                            <span class="fw-600 opa-60">From: @context.PeriodFrom?.ToShortDateString()</span>
                            <span class="fw-600 opa-60">To: @context.PeriodTo?.ToShortDateString()</span>
                        </div>
                    </MudTd>
                    <MudTd DataLabel="Actions" Style="text-align: right;">
                        <div class="d-flex justify-end gap-1">
                            <MudTooltip Text="Edit Profile">
                                <MudIconButton OnClick="@(()=> OpenDialog(context))" Color="Color.Primary" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Variant="Variant.Text" />
                            </MudTooltip>
                            <MudTooltip Text="Delete Profile">
                                <MudIconButton OnClick="@(()=> Delete(context))" Color="Color.Error" Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Variant="Variant.Text" />
                            </MudTooltip>
                        </div>
                    </MudTd>
                </RowTemplate>
                <PagerContent>
                    <div class="pa-4">
                        <MudTablePager PageSizeOptions="new int[] { 10, 20, 50, 100 }" />
                    </div>
                </PagerContent>
            </MudTable>
        </div>
    </div>
}


@code {

    private bool _isLoading = true;
    private DateTime _loadStartTime;

    private GstUsageCodeModel model = new GstUsageCodeModel();
    private List<GstUsageCodeModel> collection = new List<GstUsageCodeModel>();
    public bool SelectAll = false;
    private string searchGstUsageID = "";
    private bool _busy;

    public bool HasPermissionGstUsageIDServiceEdit { get; set; } = false;
    public bool HasPermissionGstUsageIDServiceDelete { get; set; } = false;
    public int GstUsageIDDocTypeID = 101;

    // Lifecycle method called when the component is initialized
    protected override async Task OnInitializedAsync()
    {
        _loadStartTime = DateTime.Now;
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionGstUsageIDServiceEdit = await Irole.HasClaim(GstUsageIDDocTypeID.ToString(), "Edit", ctc.Token);
        HasPermissionGstUsageIDServiceDelete = await Irole.HasClaim(GstUsageIDDocTypeID.ToString(), "Delete", ctc.Token);

        model = new();
        GetAll(SelectAll);
        await EnsureMinimumLoadTime();
        _isLoading = false;
    }

    private async Task EnsureMinimumLoadTime()
    {
        var elapsed = (DateTime.Now - _loadStartTime).TotalMilliseconds;
        if (elapsed < 100)
        {
            await Task.Delay(100 - (int)elapsed);
        }
    }

    // Method to open the dialog for adding or editing a GST usage code
    private async Task OpenDialog(GstUsageCodeModel tds)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        _busy = true;

        if (HasPermissionGstUsageIDServiceEdit)
        {
            var authprov = await auth.GetAuthenticationStateAsync();
            var user = authprov.User;
            DialogParameters parms = new DialogParameters();
            parms.Add("model", tds.Clone());
            var dialog = await DialogService.ShowAsync<GstUsageIDDialog>(tds.Id == null ? "ADD" : "EDIT", parms);
            var result = await dialog.Result;
            if (!result.Canceled)
            {
                GstUsageCodeModel UpatedModel = (GstUsageCodeModel)result.Data;
                UpatedModel.UserInfo.UserID = user.Identity.Name;
                try
                {
                    Iservice.Update(UpatedModel); // Update the GST usage code
                    model = new();
                    snackbar.Add("Saved Successfully", Severity.Success);
                    model = new GstUsageCodeModel();
                    GetAll(SelectAll);
                }
                catch (Exception ex)
                {
                    snackbar.Add(ex.Message, Severity.Warning);
                }
            }
        }
        else
        {
            bool? result = await DialogService.ShowMessageBoxAsync(
                "Permission denied!",
                "You don't have any permission to Edit GstUsageID.");
        }
        await Task.Delay(200);
        _busy = false;
    }

    // Method to delete a GST usage code
    private async Task Delete(GstUsageCodeModel model)
    {
        if (HasPermissionGstUsageIDServiceDelete)
        {
            bool? result = await DialogService.ShowMessageBoxAsync(
                "Warning !",
                "Are you sure, you want to delete - " + model.UsageCode + " (" + model.Description + ") ?");
            if (result == true)
            {
                var authprov = await auth.GetAuthenticationStateAsync();
                var user = authprov.User.Identity.Name;
                Iservice.Delete(model.Id, user); // Call service to delete the item
                snackbar.Add("Deleted Successfully", Severity.Success);
            }
            GetAll(SelectAll);
        }
        else
        {
            bool? result = await DialogService.ShowMessageBoxAsync(
                "Permission denied!",
                "You don't have any permission to Delete GstUsageID.");
        }
    }

    // Method to search for GST usage codes based on the search term
    private bool search(GstUsageCodeModel tds)
    {
        if (tds.UsageCode != null && tds.UsageCode.Contains(searchGstUsageID, StringComparison.OrdinalIgnoreCase) || tds.Description != null && tds.Description.Contains(searchGstUsageID, StringComparison.OrdinalIgnoreCase))
        {
            return true;
        }
        else if (tds.UsageCode == null)
            return true;
        return false;
    }

    // Method to handle the selection of all items
    void SelectAllChanged(bool val)
    {
        SelectAll = val;
        GetAll(val);
    }

    // Method to fetch all GST usage codes based on the selection state
    private void GetAll(bool val)
    {
        DateTime? Today = val ? null : DateTime.Today;
        collection = Iservice.Select(null).ToList(); // Load GST usage codes
    } 
}

