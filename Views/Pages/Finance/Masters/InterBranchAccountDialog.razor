@inject IInterBranchMappingService Iservice

@inject MudBlazor.ISnackbar snackbar
@inject AuthenticationStateProvider auth
@attribute [Authorize]
@inject IDialogService DialogService
@inject IChartOfAccountService accountService


<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.Build" Class="mr-3 mb-n1" />
            Create Inter Branch Mapping
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudContainer Style="min-height:300px;max-height: 800px;">
            <EditForm id="formtdsRate" Model="@model" OnValidSubmit="OnValidSubmit">
                <ObjectGraphDataAnnotationsValidator />
                <ValidationSummary />
                <MudGrid Spacing="2">
                    <MudItem xs="12">
                       @* <MudSelect Label="Select Nature of payment" @bind-Value="model.TdsNP" T="NatureOfPaymentModel" ToStringFunc="@((p) => p?.NatureOfPayment)" Variant="Variant.Outlined" Margin="Margin.Normal" OffsetY="true" Direction="Direction.Top" AdornmentColor="Color.Secondary">
                            @foreach (var ditem in naturepayment)
                            {
                                <MudSelectItem Value="@ditem">@ditem.NatureOfPayment</MudSelectItem>
                            }
                        </MudSelect>*@
                         <MudTextField  @bind-Value="model.TransactionType" Label="Dimension" Variant="Variant.Outlined" Margin="Margin.Normal" For="@(() => model.TransactionType)"></MudTextField>
                    </MudItem>
                     <MudItem xs="12" md="12">
                        <MudTextField @bind-Value="model.DebitBranchID" Label="debit Branch ID" Variant="Variant.Outlined" Margin="Margin.Normal" For="@(() => model.DebitBranchID)"></MudTextField>
                    </MudItem>
                        <MudItem xs="12" md="12">
                        <MudTextField @bind-Value="model.CreditBranchID" Label="Credit Branch ID" Variant="Variant.Outlined" Margin="Margin.Normal" For="@(() => model.CreditBranchID)"></MudTextField>
                    </MudItem>
           <MudItem xs="12" md="5">
             <MudAutocomplete T="ChartOfAccountModel" Label="Select Accounts" @bind-Value="SelectedAccount" ResetValueOnEmptyText="true" Variant="Variant.Outlined" Margin="Margin.Dense" OffsetY="true" Direction="Direction.Top" AdornmentColor="Color.Secondary"
                                     SearchFunc="SearchAccounts" ToStringFunc="@(e => e == null ? null : $"{e.AccountName}")"></MudAutocomplete>
              
        </MudItem>
              
                </MudGrid>
            </EditForm>
        </MudContainer>
    </DialogContent>
    <DialogActions>
        @*   <MudButton OnClick="DeleteTaxRate">Delete Tax Rate</MudButton>
            <MudButton OnClick="AddTaxRate">Add More Tax Rate</MudButton>*@
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton form="formIbm" Variant="Variant.Filled" Color="Color.Success" ButtonType="ButtonType.Submit">Submit</MudButton>

    </DialogActions>
</MudDialog>

@code {
    [Parameter]
    public InterBranchMappingModel model { get; set; }
    private List<InterBranchMappingModel> collection = new List<InterBranchMappingModel>();
    private ChartOfAccountModel SelectedAccount = null;
    private ChartOfAccountModel SelectedAccounts = null;
        [CascadingParameter] MudDialogInstance MudDialog { get; set; }
        private async Task<IEnumerable<ChartOfAccountModel>> SearchAccounts(string searchString)
    {

        return await Task.FromResult(accountService.FilterSubLedgers(searchString));

    }
    private void OnValidSubmit(EditContext context)
    {
        MudDialog.Close(model);
    }
     private void Cancel()
    {
        MudDialog.Cancel();
    }
    protected override async Task OnInitializedAsync()
    {
        SelectedAccount = new();
            SelectedAccount.CoaID = model.CoaID;
            SelectedAccount.AccountName = model.AccountName;
    }
}
