@page "/BankPostingGroup"
@inject IBankPostingGroupService Iservice
@inject IChartOfAccountService accountService
@inject MudBlazor.ISnackbar snackbar
@inject IChartOfAccountService accountService
@using ArmsServices.DataServices.General
@inject IConfigTable IConfig
@inject AuthenticationStateProvider auth
@attribute [Authorize]
@using System.Threading;
@inject IRoleService<RoleModel> Irole
@inject IDialogService DialogService

@if (_isLoading)
{
    <div @key="@("loader")" style="display: flex; justify-content: center; align-items: center; min-height: 400px;">
        <LoaderComponent IsFullScreen="true" 
                        ShowLogo="false" 
                        Size="medium" 
                        LoadingText="Loading Bank Posting Groups" 
                        SubText="Please wait..." />
    </div>
}
else
{
    <div class="fade-in">
        <div class="admin-header-tiered mb-6">
            <div class="d-flex align-center justify-space-between">
                <div>
                    <MudText Typo="Typo.h4" Class="admin-title">Bank Ledger Mapping Protocols</MudText>
                    <MudText Typo="Typo.body2" Class="admin-subtitle">Assign and manage general ledger linkages for banking institutions. define systematic posting rules for bank charges, processing fees, and main account reconciliations.</MudText>
                </div>
            </div>
        </div>

        <div class="d-flex gap-6 align-start">
            <!-- Sidebar for Posting Groups -->
            <div class="admin-glass-card pa-0 overflow-hidden" style="width: 320px; flex-shrink: 0; position: sticky; top: 24px;">
                <div class="pa-4 b-bottom d-flex align-center justify-space-between bg-glass-brighter">
                    <MudText Typo="Typo.subtitle1" Class="fw-700 opa-80 uppercase">Posting Groups</MudText>
                    <MudIconButton Icon="@Icons.Material.Filled.AddCircle" Color="Color.Primary" Size="Size.Small" OnClick="@(()=> OpenDialogGroup(model))" Disabled="@_busy" Class="bg-glass rounded-pill" />
                </div>
                
                <MudList T="BankPostingGroupModel" Clickable="true" SelectedValue="SelectedModel" SelectedValueChanged="HandleGroupChanged" Class="pa-2">
                    @if (listOfItems?.Any() == true)
                    {
                        @foreach (var item in listOfItems)
                        {
                            <ContextMenuTrigger MenuId="myMenu" Data="@item">
                                <MudListItem T="BankPostingGroupModel" Value="item" Class="rounded-lg mb-1 admin-list-item">
                                    <div class="d-flex align-center gap-3">
                                        <div class="admin-icon-square-vibrant small">
                                            <MudIcon Icon="@Icons.Material.Filled.AccountBalance" Size="Size.Small" />
                                        </div>
                                        <MudText Typo="Typo.body2" Class="fw-600">@item.Title</MudText>
                                    </div>
                                </MudListItem>
                            </ContextMenuTrigger>
                        }
                    }
                </MudList>
            </div>

            <!-- Main Content Area: Form -->
            <div style="flex-grow: 1;">
                @if (value == true)
                {
                    <div class="admin-glass-card pa-6">
                        <div class="d-flex align-center justify-space-between mb-6">
                            <div>
                                <div class="d-flex align-center gap-2 mb-1">
                                    <MudIcon Icon="@Icons.Material.Filled.AccountBalanceWallet" Color="Color.Primary" />
                                    <MudText Typo="Typo.h5" Class="fw-800">@titleValue</MudText>
                                </div>
                                <MudText Typo="Typo.body2" Class="opa-60">Define GL linkages for this bank posting profile</MudText>
                            </div>
                            @if (IsOnlyView)
                            {
                                <MudChip T="string" Color="Color.Info" Variant="Variant.Text" Icon="@Icons.Material.Filled.Info" Size="Size.Small" Class="fw-700">READ-ONLY PROTOCOL</MudChip>
                            }
                        </div>

                        <EditForm Model="model" OnValidSubmit="CreateBankPostingGroup">
                            <ObjectGraphDataAnnotationsValidator />
                            <div class="d-flex flex-column gap-6">
                                <MudTextField @bind-Value="model.Title" Label="Group Profile Identifier" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.Title)" Disabled="IsOnlyView" Class="admin-input-group" />
                                
                                <div class="admin-form-section">
                                    <div class="d-flex align-center gap-2 mb-3">
                                        <MudIcon Icon="@Icons.Material.Filled.AccountTree" Size="Size.Small" Class="opa-40" />
                                        <MudText Typo="Typo.subtitle2" Class="fw-800 opa-50 uppercase">Ledger Synchronization</MudText>
                                    </div>
                                    <div class="d-flex flex-column gap-4">
                                        <div class="pa-4 bg-glass rounded-lg border-2 border-dashed border-opa-10">
                                            <MudAutocomplete T="ChartOfAccountModel" Label="Primary Bank GL Account" @bind-Value="model.BankAccount" ResetValueOnEmptyText="true" Variant="Variant.Outlined" Margin="Margin.Dense" AdornmentColor="Color.Secondary" Class="admin-input-group"
                                                SearchFunc="SearchAccountsBankAccount" ToStringFunc="@(e => e == null ? null : $"{e.AccountName}")" Disabled="IsOnlyView"></MudAutocomplete>
                                        </div>

                                        <div class="pa-4 bg-glass rounded-lg border-2 border-dashed border-opa-10">
                                            <MudAutocomplete T="ChartOfAccountModel" Label="Bank Service Charges Account" @bind-Value="model.BankCharges" ResetValueOnEmptyText="true" Variant="Variant.Outlined" Margin="Margin.Dense" AdornmentColor="Color.Secondary" Class="admin-input-group"
                                                SearchFunc="SearchAccountsExpenceAccount" ToStringFunc="@(e => e == null ? null : $"{e.AccountName}")" Disabled="IsOnlyView"></MudAutocomplete>
                                        </div>

                                        <div class="pa-4 bg-glass rounded-lg border-2 border-dashed border-opa-10">
                                            <MudAutocomplete T="ChartOfAccountModel" Label="Transaction Processing Fee Account" @bind-Value="model.ProcessingFee" ResetValueOnEmptyText="true" Variant="Variant.Outlined" Margin="Margin.Dense" AdornmentColor="Color.Secondary" Class="admin-input-group"
                                                SearchFunc="SearchAccountsExpenceAccount" ToStringFunc="@(e => e == null ? null : $"{e.AccountName}")" Disabled="IsOnlyView"></MudAutocomplete>
                                        </div>
                                    </div>
                                </div>

                                <div class="d-flex align-center justify-end gap-3 mt-4">
                                    <MudButton OnClick="CancelBankPostingGroup" Variant="Variant.Text" Color="Color.Default" Class="rounded-pill px-6 fw-600">DISMISS</MudButton>
                                    @if (!IsOnlyView)
                                    {
                                        <MudButton Disabled="@_busy" ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Primary" Class="admin-register-btn px-8 shadow-lg">COMMIT CONFIGURATION</MudButton>
                                    }
                                    else if (HasPermissionBankPostingGroupServiceEdit)
                                    {
                                         <MudButton OnClick="@(() => { IsOnlyView = false; titleValue = "Edit Bank Posting Group"; })" Variant="Variant.Filled" Color="Color.Warning" Class="admin-register-btn px-8 shadow-lg">UNLOCK TO EDIT</MudButton>
                                    }
                                </div>
                            </div>
                        </EditForm>
                    </div>
                }
                else
                {
                    <div class="admin-glass-card d-flex flex-column align-center justify-center py-16" style="min-height: 480px;">
                        <div class="admin-icon-square-vibrant mb-6 shadow-glow" style="width: 80px; height: 80px;">
                            <MudIcon Icon="@Icons.Material.Filled.AccountBalanceWallet" Style="font-size: 3rem;" />
                        </div>
                        <MudText Typo="Typo.h5" Class="fw-800 opa-80 mb-2">Select Posting Group</MudText>
                        <MudText Typo="Typo.body2" Class="opa-50 text-center" Style="max-width: 300px;">Choose a bank account profile from the sidebar to configure its audit linkages and synchronization accounts.</MudText>
                    </div>
                }
            </div>
        </div>
    </div>

    <ContextMenu Id="myMenu" OnAppearing="OnAppearing">
        <Item OnClick="@ContextMenuOnClickedit" Id="editGroup">Edit Group Configuration</Item>
    </ContextMenu>
}

@code {

    private bool _isLoading = true;
    private DateTime _loadStartTime;

    BankPostingGroupModel model = new BankPostingGroupModel();
    private MudListItem<BankPostingGroupModel> SelectedItem;
    private List<BankPostingGroupModel> listOfItems = new();
    BankPostingGroupModel SelectedModel = new();
    private List<BankPostingGroupModel> collection = new List<BankPostingGroupModel>();
    private ChartOfAccountModel SelectedAccountBankAccount = null;
    private ChartOfAccountModel SelectedAccountBankCharges = null;
    private ChartOfAccountModel SelectedAccountBankProcessingFee = null;
    public string titleValue = null;
    public bool value = false;
    private bool _busy;

    public bool HasPermissionBankPostingGroupServiceEdit { get; set; } = false;
    public int BankPostingGroupDocTypeID = 106;

    // Method to search for bank accounts based on a search string
    private async Task<IEnumerable<ChartOfAccountModel>> SearchAccountsBankAccount(string searchString, CancellationToken token)
    {
        await Task.Delay(5);
        string[] bankGrps = IConfig.GetByFinanceBankGroupID().ValueString.Split(",");
        List<ChartOfAccountModel> Coas = new();
        foreach(var item in bankGrps)
        {
            int coID = Convert.ToInt32(item);
            var Result = await Task.FromResult(accountService.SelectAllChildrenAndItsSub(coID, searchString)); // Fetch accounts
            Coas.AddRange(Result);
        }       
        
        return await Task.FromResult(Coas);
    }

    // Method to search for expense accounts based on a search string
    private async Task<IEnumerable<ChartOfAccountModel>> SearchAccountsExpenceAccount(string searchString, CancellationToken token)
    {
        await Task.Delay(5);
        int ExpenseGroupID = 3;
        return await Task.FromResult(accountService.SelectAllChildrenAndItsSub(ExpenseGroupID, searchString)); // Return filtered accounts
    }

    private bool IsOnlyView { get; set; } = false;

    // Lifecycle method called when the component is initialized
    protected override async Task OnInitializedAsync()
    {
        _loadStartTime = DateTime.Now;
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionBankPostingGroupServiceEdit = await Irole.HasClaim(BankPostingGroupDocTypeID.ToString(), "Edit", ctc.Token);

        GetAll();
        await EnsureMinimumLoadTime();
        _isLoading = false;
    }

    private async Task EnsureMinimumLoadTime()
    {
        var elapsed = (DateTime.Now - _loadStartTime).TotalMilliseconds;
        if (elapsed < 100)
        {
            await Task.Delay(100 - (int)elapsed);
        }
    }

    // Method to fetch all bank posting groups
    private void GetAll()
    {
        listOfItems = Iservice.Select().ToList(); // Load bank posting groups from the service
    }

    // Method to handle selection changes in the list   
    protected async Task HandleGroupChanged(BankPostingGroupModel model)
    {
        SelectedModel = model;
        if (SelectedModel != null)
        {
            ViewDetails(null, SelectedModel);
        }
    }

    private void GetBankPostingGroup()
    {
        collection = new List<BankPostingGroupModel>();
        foreach (var item in Iservice.Select())
        {
            collection.Add(item);
        }
    }

    // Method to cancel the bank posting group operation
    public async Task CancelBankPostingGroup()
    {
        IsOnlyView = false;
        value = false;
        model = new();
        SelectedAccountBankAccount = new();
        SelectedAccountBankCharges = new();
        SelectedAccountBankProcessingFee = new();
    }

    // Method to create or update a bank posting group
    public async Task CreateBankPostingGroup()
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is being submitted!", Severity.Warning);
            return;
        }
        _busy = true;

        if (HasPermissionBankPostingGroupServiceEdit)
        {
            var authprov = await auth.GetAuthenticationStateAsync();
            var user = authprov.User;
            model.UserInfo.UserID = user.Identity.Name;
            try
            {
                Iservice.Update(model); // Update the bank posting group
                snackbar.Add("Successfully Submitted", Severity.Success);
                GetAll();
                value = false;
            }
            catch (Exception a)
            {
                snackbar.Add(a.Message, Severity.Error);
            }
        }
        else
        {
            bool? result = await DialogService.ShowMessageBoxAsync(
                "Permission denied!",
                "You don't have any permission to Edit BankPostingGroup.");
        }
        await Task.Delay(200);
        _busy = false;
    }

    private async Task OpenDialog(BankPostingGroupModel ii)
    {

    }

    private void Delete(InventoryItemModel ii)
    {

    }

    // Method to prepare for adding a new bank posting group
    private void OpenDialogGroup(BankPostingGroupModel ig)
    {
        value = true;
        IsOnlyView = false;
        model = new();
        SelectedAccountBankAccount = new();
        SelectedAccountBankCharges = new();
        SelectedAccountBankProcessingFee = new();
        titleValue = "Add Bank Posting Group";
    }

    void OnAppearing(MenuAppearingEventArgs e)
    {

    }
    
    // Method to handle editing a bank posting group from the context menu
    protected void ContextMenuOnClickedit(ItemClickEventArgs e)
    {
        IsOnlyView = false;
        model = (BankPostingGroupModel)((BankPostingGroupModel)e.Data).Clone();
        SelectedAccountBankAccount = model.BankAccount;
        SelectedAccountBankCharges = model.BankCharges;
        SelectedAccountBankProcessingFee = model.ProcessingFee;
        value = true;
        titleValue = "Edit Bank Posting Group";
    }

    // Method to view details of a bank posting group
    protected void ViewDetails(MouseEventArgs e, BankPostingGroupModel Data)
    {
        IsOnlyView = true;
        model = Data;
        SelectedAccountBankAccount = model.BankAccount;
        SelectedAccountBankCharges = model.BankCharges;
        SelectedAccountBankProcessingFee = model.ProcessingFee;
        value = true;
        titleValue = "Bank Posting Group | " + Data.Title;
    }
}
