@page "/CustomerPostingGroup"
@inject ICustomerPostingGroupService Iservice
@inject IChartOfAccountService accountService
@inject MudBlazor.ISnackbar snackbar
@inject IChartOfAccountService accountService
@using ArmsServices.DataServices.General
@inject IConfigTable IConfig
@inject AuthenticationStateProvider auth
@attribute [Authorize]
@using System.Threading;
@inject IRoleService<RoleModel> Irole
@inject IDialogService DialogService

@if (_isLoading)
{
    <div @key="@("loader")" style="display: flex; justify-content: center; align-items: center; min-height: 400px;">
        <LoaderComponent IsFullScreen="true" 
                        ShowLogo="false" 
                        Size="medium" 
                        LoadingText="Loading Customer Posting Groups" 
                        SubText="Please wait..." />
    </div>
}
else
{
    <div class="fade-in">
        <div class="admin-header-tiered mb-6">
            <div class="d-flex align-center justify-space-between">
                <div>
                    <MudText Typo="Typo.h4" Class="admin-title">Customer Accounts Receivable Protocols</MudText>
                    <MudText Typo="Typo.body2" Class="admin-subtitle">Assign and manage general ledger linkages for customer entities and debt control. define systematic posting rules for primary receivables, pre-payments, and security deposits.</MudText>
                </div>
            </div>
        </div>

        <div class="d-flex gap-6 align-start">
            <!-- Sidebar for Posting Groups -->
            <div class="admin-glass-card pa-0 overflow-hidden" style="width: 320px; flex-shrink: 0; position: sticky; top: 24px;">
                <div class="pa-4 b-bottom d-flex align-center justify-space-between bg-glass-brighter">
                    <MudText Typo="Typo.subtitle1" Class="fw-700 opa-80 uppercase">Posting Groups</MudText>
                    <MudIconButton Icon="@Icons.Material.Filled.AddCircle" Color="Color.Primary" Size="Size.Small" OnClick="@(()=> OpenDialogGroup(model))" Disabled="@_busy" Class="bg-glass rounded-pill" />
                </div>
                
                <MudList T="CustomerPostingGroupModel" Clickable="true" SelectedValue="SelectedModel" SelectedValueChanged="HandleGroupChanged" Class="pa-2">
                    @if (listOfItems?.Any() == true)
                    {
                        @foreach (var item in listOfItems)
                        {
                            <ContextMenuTrigger MenuId="myMenu" Data="@item">
                                <MudListItem T="CustomerPostingGroupModel" Value="item" Class="rounded-lg mb-1 admin-list-item">
                                    <div class="d-flex align-center gap-3">
                                        <div class="admin-icon-square-vibrant small accent-indigo">
                                            <MudIcon Icon="@Icons.Material.Filled.PeopleAlt" Size="Size.Small" />
                                        </div>
                                        <MudText Typo="Typo.body2" Class="fw-600">@item.Title</MudText>
                                    </div>
                                </MudListItem>
                            </ContextMenuTrigger>
                        }
                    }
                </MudList>
            </div>

            <!-- Main Content Area: Form -->
            <div style="flex-grow: 1;">
                @if (value == true)
                {
                    <div class="admin-glass-card pa-6">
                        <div class="d-flex align-center justify-space-between mb-6">
                            <div>
                                <div class="d-flex align-center gap-2 mb-1">
                                    <MudIcon Icon="@Icons.Material.Filled.Shield" Color="Color.Primary" />
                                    <MudText Typo="Typo.h5" Class="fw-800">@titleValue</MudText>
                                </div>
                                <MudText Typo="Typo.body2" Class="opa-60">Define AR linkages for this customer posting profile</MudText>
                            </div>
                            @if (IsOnlyView)
                            {
                                <MudChip T="string" Color="Color.Info" Variant="Variant.Text" Icon="@Icons.Material.Filled.Info" Size="Size.Small" Class="fw-700">READ-ONLY PROTOCOL</MudChip>
                            }
                        </div>

                        <EditForm Model="model" OnValidSubmit="CreateCustomerPostingGroup">
                            <ObjectGraphDataAnnotationsValidator />
                            <div class="d-flex flex-column gap-6">
                                <MudTextField @bind-Value="model.Title" Label="Posting Group Identifier" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.Title)" Disabled="IsOnlyView" Class="admin-input-group" />
                                
                                <div class="admin-form-section">
                                    <div class="d-flex align-center gap-2 mb-3">
                                        <MudIcon Icon="@Icons.Material.Filled.AccountTree" Size="Size.Small" Class="opa-40" />
                                        <MudText Typo="Typo.subtitle2" Class="fw-800 opa-50 uppercase">Ledger Synchronization</MudText>
                                    </div>
                                    <div class="d-flex flex-column gap-4">
                                        <div class="pa-4 bg-glass rounded-lg border-2 border-dashed border-opa-10">
                                            <CoaSelector @bind-Value="model.Receivable" LabelName="Control Account (Primary Receivables)" IsDisable="IsOnlyView" />
                                        </div>
                                        <div class="pa-4 bg-glass rounded-lg border-2 border-dashed border-opa-10">
                                            <CoaSelector @bind-Value="model.PrePayment" LabelName="Liability Account (Advance Receipts)" IsDisable="IsOnlyView" />
                                        </div>
                                        <div class="pa-4 bg-glass rounded-lg border-2 border-dashed border-opa-10">
                                            <CoaSelector @bind-Value="model.Deposit" LabelName="Liability Account (Security Deposits)" IsDisable="IsOnlyView" />
                                        </div>
                                    </div>
                                </div>

                                <div class="d-flex align-center justify-end gap-3 mt-4">
                                    <MudButton OnClick="CancelCustomerPostingGroup" Variant="Variant.Text" Color="Color.Default" Class="rounded-pill px-6 fw-600">DISMISS</MudButton>
                                    @if (!IsOnlyView)
                                    {
                                        <MudButton Disabled="@_busy" ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Primary" Class="admin-register-btn px-8 shadow-lg">COMMIT CONFIGURATION</MudButton>
                                    }
                                    else if (HasPermissionCustomerPostingGroupServiceEdit)
                                    {
                                         <MudButton OnClick="@(() => { IsOnlyView = false; titleValue = "Edit Customer Posting Group"; })" Variant="Variant.Filled" Color="Color.Warning" Class="admin-register-btn px-8 shadow-lg">UNLOCK TO EDIT</MudButton>
                                    }
                                </div>
                            </div>
                        </EditForm>
                    </div>
                }
                else
                {
                    <div class="admin-glass-card d-flex flex-column align-center justify-center py-16" style="min-height: 400px;">
                        <div class="admin-icon-square-vibrant mb-6 accent-indigo" style="width: 80px; height: 80px;">
                            <MudIcon Icon="@Icons.Material.Filled.Group" Style="font-size: 3rem;" />
                        </div>
                        <MudText Typo="Typo.h5" Class="fw-800 opa-80 mb-2">Select Posting Group</MudText>
                        <MudText Typo="Typo.body2" Class="opa-50 text-center" Style="max-width: 300px;">Choose a customer profile from the sidebar to configure its audit linkages and control accounts.</MudText>
                    </div>
                }
            </div>
        </div>
    </div>

    <ContextMenu Id="myMenu" OnAppearing="OnAppearing">
        <Item OnClick="@ContextMenuOnClickedit" Id="editGroup">Edit Group Configuration</Item>
    </ContextMenu>
}

@code {

    private bool _isLoading = true;
    private DateTime _loadStartTime;

    CustomerPostingGroupModel model = new CustomerPostingGroupModel();
    private MudListItem<CustomerPostingGroupModel> SelectedItem;
    private List<CustomerPostingGroupModel> listOfItems = new();
    CustomerPostingGroupModel SelectedModel = new();
    public bool value = false;
    public string titleValue = null;
    private List<CustomerPostingGroupModel> collection = new List<CustomerPostingGroupModel>();
    private bool IsOnlyView { get; set; } = false;
    private bool _busy;

    public bool HasPermissionCustomerPostingGroupServiceEdit { get; set; } = false;
    public int CustomerPostingGroupDocTypeID = 105;

    // Lifecycle method called when the component is initialized
    protected override async Task OnInitializedAsync()
    {
        _loadStartTime = DateTime.Now;
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionCustomerPostingGroupServiceEdit = await Irole.HasClaim(CustomerPostingGroupDocTypeID.ToString(), "Edit", ctc.Token);

        GetAll();
        await EnsureMinimumLoadTime();
        _isLoading = false;
    }

    private async Task EnsureMinimumLoadTime()
    {
        var elapsed = (DateTime.Now - _loadStartTime).TotalMilliseconds;
        if (elapsed < 100)
        {
            await Task.Delay(100 - (int)elapsed);
        }
    }

    // Method to fetch all customer posting groups
    private void GetAll()
    {
        listOfItems = Iservice.Select().ToList(); // Load customer posting groups from the service
    }

    // Method to handle selection changes in the list   
    protected async Task HandleGroupChanged(CustomerPostingGroupModel model)
    {
        SelectedModel = model;
        if (SelectedModel != null)
        {
            ViewDetails(null, SelectedModel);
        }
    }

    // Method to cancel the customer posting group operation
    public async Task CancelCustomerPostingGroup()
    {
        IsOnlyView = false;
        value = false;
        model = new();
    }

    // Method to create or update a customer posting group
    public async Task CreateCustomerPostingGroup()
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is being submitted!", Severity.Warning);
            return;
        }
        _busy = true;

        if (HasPermissionCustomerPostingGroupServiceEdit)
        {
            var authprov = await auth.GetAuthenticationStateAsync();
            var user = authprov.User;
            model.UserInfo.UserID = user.Identity.Name;
            try
            {
                Iservice.Update(model); // Update the customer posting group
                snackbar.Add("Successfully Submitted", Severity.Success);
                GetAll();
                value = false;
            }
            catch (Exception a)
            {
                snackbar.Add(a.Message, Severity.Error);
            }
        }
        else
        {
            bool? result = await DialogService.ShowMessageBoxAsync(
                "Permission denied!",
                "You don't have any permission to Edit CustomerPostingGroup.");
        }
        await Task.Delay(200);
        _busy = false;
    }

    private async Task OpenDialog(CustomerPostingGroupModel ii)
    {

    }

    void OnAppearing(MenuAppearingEventArgs e)
    {

    }

    // Method to prepare for adding a new customer posting group
    private void OpenDialogGroup(CustomerPostingGroupModel ig)
    {
        IsOnlyView = false;
        value = true;
        model = new();
        titleValue = "Add Customer Posting Group";
    }

    // Method to handle editing a customer posting group from the context menu
    protected void ContextMenuOnClickedit(ItemClickEventArgs e)
    {
        IsOnlyView = false;
        model = (CustomerPostingGroupModel)((CustomerPostingGroupModel)e.Data).Clone();
        value = true;
        titleValue = "Edit Customer Posting Group";
    }

    // Method to view details of a customer posting group
    protected void ViewDetails(MouseEventArgs e, CustomerPostingGroupModel Data)
    {
        IsOnlyView = true;
        model = Data;
        value = true;
        titleValue = "Customer Posting Group | " + Data.Title;
    }
}
