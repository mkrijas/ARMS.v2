@page "/OperationPostingGroup"
@attribute [Authorize]
@inject AuthenticationStateProvider auth
@using System.Threading;
@inject IRoleService<RoleModel> Irole
@inject IDialogService DialogService
@inject IOperationPostingGroupService IOperationPostingGroupService
@inject MudBlazor.ISnackbar snackbar

@if (_isLoading)
{
    <div @key="@("loader")" style="display: flex; justify-content: center; align-items: center; min-height: 400px;">
        <LoaderComponent IsFullScreen="true" 
                        ShowLogo="false" 
                        Size="medium" 
                        LoadingText="Loading Operation Protocols" 
                        SubText="Please wait..." />
    </div>
}
else
{
    <div class="fade-in">
        <div class="admin-header-tiered mb-6">
            <div class="d-flex align-center justify-space-between">
                <div>
                    <MudText Typo="Typo.h4" Class="admin-title">Operational Ledger Configurations</MudText>
                    <MudText Typo="Typo.body2" Class="admin-subtitle">Assign and manage general ledger linkages for daily operational activities. define systematic posting rules for service usages and revenue-to-cost distributions.</MudText>
                </div>
            </div>
        </div>

        <div class="admin-glass-card mb-6 pa-4">
            <div class="d-flex align-center gap-4 flex-wrap">
                <div style="flex-grow: 1; min-width: 300px;">
                    <MudTextField @bind-Value="searchTerm" Placeholder="Search by protocol title or ARD code..." Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" Variant="Variant.Outlined" Margin="Margin.Dense" Class="admin-input-group" Clearable="true" />
                </div>
            </div>
        </div>

        <MudForm @bind-IsValid="@formValid" @ref="form" Class="admin-glass-card pa-0 overflow-hidden">
            <MudTable Items="@FilteredOperationPostingList" Elevation="0" Class="modern-admin-table" Hover="true" CanCancelEdit="true" RowEditPreview="BackupItem" RowEditCancel="ResetItemToOriginalValues" RowEditCommit="ItemHasBeenCommitted">
                <HeaderContent>
                    <MudTh Style="width: 60px;"></MudTh>
                    <MudTh><span class="admin-header-text">PROTOCOL / ARD</span></MudTh>
                    <MudTh><span class="admin-header-text">USAGE PROTOCOL</span></MudTh>
                    <MudTh Style="width: 120px; text-align: right;"><span class="admin-header-text">ACTIONS</span></MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd>
                        <div class="admin-icon-square-vibrant small accent-cyan">
                            <MudIcon Icon="@Icons.Material.Filled.Settings" Size="Size.Small" />
                        </div>
                    </MudTd>
                    <MudTd DataLabel="Protocol">
                        <div class="d-flex flex-column">
                            <span class="fw-700 admin-td-primary">@context.Title</span>
                            <div class="d-flex align-center gap-1 mt-1">
                                <span class="tiny-badge accent-indigo">@context.ADCode</span>
                                <span class="tiny opa-50 uppercase fw-600">ARD Code</span>
                            </div>
                        </div>
                    </MudTd>
                    <MudTd DataLabel="Usage Protocol">
                        <div class="d-flex flex-column">
                            <span class="fw-700">@context.UsageCode.UsageCode</span>
                            <span class="tiny opa-60">@context.UsageCode.Description</span>
                        </div>
                    </MudTd>
                    <MudTd Style="text-align: right;">
                        <MudTooltip Text="Modify Configuration">
                            <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Color="Color.Primary" Variant="Variant.Text" />
                        </MudTooltip>
                    </MudTd>
                </RowTemplate>
                <RowEditingTemplate>
                    <MudTd></MudTd>
                    <MudTd DataLabel="Protocol">
                         <div class="d-flex flex-column gap-2">
                            <MudTextField @bind-Value="@context.Title" Label="Protocol Title" Variant="Variant.Outlined" Margin="Margin.Dense" Required Class="admin-input-group" />
                            <MudTextField @bind-Value="@context.ADCode" Label="ARD Code (Auto)" Variant="Variant.Outlined" Margin="Margin.Dense" Disabled Class="admin-input-group opa-50" />
                         </div>
                    </MudTd>
                    <MudTd DataLabel="Usage Protocol">
                        <div class="pa-2 bg-glass rounded border-2 border-dashed border-opa-10 mt-1">
                            <UsageCodeSelector @bind-Value="@context.UsageCode" LabelName="Select Protocol" Required />
                        </div>
                    </MudTd>
                    <MudTd></MudTd>
                </RowEditingTemplate>
                <FooterContent>
                    <MudTFootRow Class="bg-glass-brighter">
                        <MudTd>
                            <div class="admin-icon-square-vibrant small shadow-glow">
                                <MudIcon Icon="@Icons.Material.Filled.PostAdd" Size="Size.Small" />
                            </div>
                        </MudTd>
                        <MudTd>
                            <div class="d-flex flex-column gap-1">
                                <MudText Typo="Typo.overline" Class="fw-800 opa-50">Initialize New Protocol</MudText>
                                <MudTextField @bind-Value="@InsertElement.Title" Placeholder="Enter protocol name..." Variant="Variant.Outlined" Margin="Margin.Dense" Required Class="admin-input-group" />
                            </div>
                        </MudTd>
                        <MudTd>
                             <div class="pa-2 bg-glass rounded border-2 border-dashed border-opa-10 mt-5">
                                <UsageCodeSelector @bind-Value="@InsertElement.UsageCode" LabelName="Select Usage Rule" Required />
                            </div>
                        </MudTd>
                        <MudTd Style="text-align: right;">
                            <MudButton Disabled="@(!formValid || _busy)" OnClick="(()=>ItemHasBeenCommitted(InsertElement))" Variant="Variant.Filled" Color="Color.Primary" Class="admin-register-btn px-6 shadow-lg mt-5">DEPLOY</MudButton>
                        </MudTd>
                    </MudTFootRow>
                </FooterContent>
            </MudTable>
        </MudForm>
    </div>
}

 @code {

    private bool _isLoading = true;
    private DateTime _loadStartTime;

    private bool formValid;
    MudForm form;
    private string searchTerm = "";
    private bool _busy;
    private List<OperationPostingGroupModel> OperationPostingList = new();
    private OperationPostingGroupModel elementBeforeEdit;
    private OperationPostingGroupModel InsertElement = new();

    private IEnumerable<OperationPostingGroupModel> FilteredOperationPostingList => OperationPostingList
        .Where(x => string.IsNullOrWhiteSpace(searchTerm) || 
                   x.Title.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) || 
                   x.ADCode.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ||
                   (x.UsageCode?.UsageCode.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ?? false));

    // Lifecycle method called when the component is initialized
    protected override async Task OnInitializedAsync()
    {
        _loadStartTime = DateTime.Now;
        // Load all operation posting groups from the service
        OperationPostingList = IOperationPostingGroupService.Select().ToList();
        await EnsureMinimumLoadTime();
        _isLoading = false;
    }

    private async Task EnsureMinimumLoadTime()
    {
        var elapsed = (DateTime.Now - _loadStartTime).TotalMilliseconds;
        if (elapsed < 100)
        {
            await Task.Delay(100 - (int)elapsed);
        }
    }

    // Method to backup the original values of an item before editing
    private void BackupItem(object element)
    {
        var item = (OperationPostingGroupModel)element;
        elementBeforeEdit = new()
            {
                ID = item.ID,
                Title = item.Title,
                UsageCode = item.UsageCode,
            };
    }

    // Method to reset an item to its original values
    private void ResetItemToOriginalValues(object element)
    {
        var item = (OperationPostingGroupModel)element;
        item.ID = elementBeforeEdit.ID;
        item.Title = elementBeforeEdit.Title;
        item.UsageCode = elementBeforeEdit.UsageCode;
    }

    // Method to commit changes to an item
    private async void ItemHasBeenCommitted(object element)
    {
        if (_busy) return;
        _busy = true;
        OperationPostingGroupModel item = (OperationPostingGroupModel)element;
        item.Title = item.Title.ToUpper();
        try
        {
            var authprov = await auth.GetAuthenticationStateAsync();
            item.UserInfo.UserID = authprov.User.Identity.Name;
            item.Title = FontStyle.ConvertToCamelCase(item.Title);
            IOperationPostingGroupService.Update(item); // Update the item in the service
            item = new();
            OperationPostingList = IOperationPostingGroupService.Select().ToList(); // Refresh the list of operation posting groups
            await form.ResetAsync();
            snackbar.Add("Successfully Submitted", Severity.Success);
        }
        catch (Exception ex)
        {
            snackbar.Add(ex.Message, Severity.Error);
        }
        await Task.Delay(200);
        _busy = false;
    }
}
