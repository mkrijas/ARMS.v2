@page "/OperationPostingGroup"
@attribute [Authorize]
@inject AuthenticationStateProvider auth
@using System.Threading;
@inject IRoleService<RoleModel> Irole
@inject IDialogService DialogService
@inject IOperationPostingGroupService IOperationPostingGroupService
@inject MudBlazor.ISnackbar snackbar

<MudForm @bind-IsValid="@formValid" @ref="form">
    <MudTable Items="@OperationPostingList" Hover="true" CanCancelEdit="true" RowEditPreview="BackupItem" RowEditCancel="ResetItemToOriginalValues" RowEditCommit="ItemHasBeenCommitted">
        <ToolBarContent>
            <MudText Typo="Typo.h6">Operation Posting Group</MudText>
        </ToolBarContent>
        <HeaderContent>
            <MudTh Style="width:16%"></MudTh>
            <MudTh><MudTableSortLabel SortBy="new Func<OperationPostingGroupModel, object>(x=>x.ADCode)">ARD Code</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel SortBy="new Func<OperationPostingGroupModel, object>(x=>x.Title)">TITLE</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel SortBy="new Func<OperationPostingGroupModel, object>(x=>x.UsageCode.UsageCode)">USAGECODE</MudTableSortLabel></MudTh>
            <MudTh></MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd></MudTd>
            <MudTd DataLabel="ADCode">@context.ADCode</MudTd>
            <MudTd DataLabel="Title">@context.Title</MudTd>
            <MudTd DataLabel="UsageCode">@context.UsageCode.UsageCode | @context.UsageCode.Description</MudTd>
            <MudTd></MudTd>
        </RowTemplate>
        <RowEditingTemplate>
            <MudTd></MudTd>
            <MudTd>
                <MudTextField @bind-Value="@context.ADCode" Variant="Variant.Outlined" Margin="Margin.Dense" Disabled/>
            </MudTd>
            <MudTd DataLabel="Title">
                <MudTextField @bind-Value="@context.Title" Variant="Variant.Outlined" Margin="Margin.Dense" Required />
            </MudTd>
            <MudTd DataLabel="UsageCode">
                <UsageCodeSelector @bind-Value="@context.UsageCode" LabelName="Select Usage Code" Required />
            </MudTd>
            <MudTd></MudTd>
        </RowEditingTemplate>
        <FooterContent>
            <MudTd></MudTd>
            <MudTd Style="padding-left:2%" DataLabel="New">
                New
            </MudTd>
            <MudTd DataLabel="Title">
                <MudTextField @bind-Value="@InsertElement.Title" Label="Title" Variant="Variant.Outlined" Margin="Margin.Dense" Required />
            </MudTd>
            <MudTd DataLabel="UsageCode">
                <UsageCodeSelector @bind-Value="@InsertElement.UsageCode" LabelName="Select Usage Code" Required />
            </MudTd>
            <MudTd DataLabel="Create">
                <MudButton Disabled="@(!formValid)" OnClick="(()=>ItemHasBeenCommitted(InsertElement))">Create</MudButton>
            </MudTd>
        </FooterContent>
    </MudTable>
</MudForm>

 @code {

    MudForm form;
    bool formValid;
    private List<OperationPostingGroupModel> OperationPostingList = new();
    private OperationPostingGroupModel elementBeforeEdit;
    private OperationPostingGroupModel InsertElement = new();

    // Lifecycle method called when the component is initialized
    protected override async Task OnInitializedAsync()
    {
        // Load all operation posting groups from the service
        OperationPostingList = IOperationPostingGroupService.Select().ToList();
    }

    // Method to backup the original values of an item before editing
    private void BackupItem(object element)
    {
        var item = (OperationPostingGroupModel)element;
        elementBeforeEdit = new()
            {
                ID = item.ID,
                Title = item.Title,
                UsageCode = item.UsageCode,
            };
    }

    // Method to reset an item to its original values
    private void ResetItemToOriginalValues(object element)
    {
        var item = (OperationPostingGroupModel)element;
        item.ID = elementBeforeEdit.ID;
        item.Title = elementBeforeEdit.Title;
        item.UsageCode = elementBeforeEdit.UsageCode;
    }

    // Method to commit changes to an item
    private async void ItemHasBeenCommitted(object element)
    {
        OperationPostingGroupModel item = (OperationPostingGroupModel)element;
        item.Title = item.Title.ToUpper();
        try
        {
            var authprov = await auth.GetAuthenticationStateAsync();
            item.UserInfo.UserID = authprov.User.Identity.Name;
            item.Title = FontStyle.ConvertToCamelCase(item.Title);
            IOperationPostingGroupService.Update(item); // Update the item in the service
            item = new();
            OperationPostingList = IOperationPostingGroupService.Select().ToList(); // Refresh the list of operation posting groups
            await form.ResetAsync();
            snackbar.Add("Successfully Submitted", Severity.Success);
        }
        catch (Exception ex)
        {
            snackbar.Add(ex.Message, Severity.Error);
        }
    }
}
