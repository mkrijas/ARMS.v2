@page "/VendorPostingGroup"
@inject IVendorPostingGroupService Iservice
@inject IChartOfAccountService accountService
@inject MudBlazor.ISnackbar snackbar
@inject IChartOfAccountService accountService
@using ArmsServices.DataServices.General
@inject IConfigTable IConfig
@inject AuthenticationStateProvider auth
@attribute [Authorize]
@inject IDialogService DialogService

<MudGrid>
    <MudItem xs="4" lg="4">
        <MudPaper Width="100%" Class="p-2">
            <MudList Clickable="true" SelectedItem="SelectedItem" SelectedItemChanged="SelectedItemChanged">
                <MudText Typo="Typo.h6" style="padding: 4px; margin-top: -8px; margin-bottom: -22px; margin-left: 8px;">
                    Vendor Posting Group
                    <MudIconButton Icon="@Icons.Material.Filled.Add" Title="Add" @onclick="@(()=> OpenDialogGroup(model))" Color="Color.Dark" Size="Size.Small"></MudIconButton>
                </MudText>
                <br />
                @if (listOfItems?.Any() == true)
                {
                    @foreach (var item in listOfItems)
                    {
                        <ContextMenuTrigger MenuId="myMenu" Data="@item">
                            <MudListItem OnClick="((e) => ViewDetails(e,item))" Class="border-solid border-2 pa-4 mb-2 mt-2" Style="border-color:#ccc; border-radius:3%" Value="item">
                                <MudText Typo=Typo.subtitle1> @item.Title.ToString() </MudText>
                            </MudListItem>
                        </ContextMenuTrigger>
                    }
                }
            </MudList>
        </MudPaper>
    </MudItem>
    @if (@value == true)
    {
        <MudItem xs="8" lg="8">
            <MudPaper>
                <MudContainer>
                    <h4 style="padding-top:18px;">@titleValue</h4>
                    <br />
                    <EditForm Model="model" OnValidSubmit="CreateVendorPostingGroup">
                        <ObjectGraphDataAnnotationsValidator />
                        <MudGrid Spacing="4">
                            <MudItem xs="12" lg="12">
                                <MudTextField @bind-Value="model.Title" Label="Title" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.Title)" Disabled="IsOnlyView"></MudTextField>
                            </MudItem>
                            <MudItem xs="12" md="12">
                                <CoaSelector @bind-Value="model.Payable" LabelName="Account For Vendor Payable" IsDisable="IsOnlyView" />
                            </MudItem>
                            <MudItem xs="12" md="12">
                                <CoaSelector @bind-Value="model.PrePayment" LabelName="Account For Vendor PrePayment" IsDisable="IsOnlyView" />
                            </MudItem>
                            <MudItem xs="12" md="12">
                                <CoaSelector @bind-Value="model.Deposit" LabelName="Account For Vendor Deposit" IsDisable="IsOnlyView" />
                            </MudItem>
                            <MudItem xs="12" md="6">
                                <ValidationSummary />
                            </MudItem>
                            <MudItem xs="12" md="6">
                                <MudButton @onclick="CancelVendorPostingGroup" Class="ml-2 mr-2" Variant="Variant.Filled" Color="Color.Warning">Cancel</MudButton>
                                @if (!IsOnlyView)
                                {
                                    <MudButton ButtonType="ButtonType.Submit" Class="ml-2 mr-2" Variant="Variant.Filled" Color="Color.Success">Submit</MudButton>
                                }
                            </MudItem>
                        </MudGrid>
                    </EditForm>
                </MudContainer>
            </MudPaper>
        </MudItem>
    }
</MudGrid>
<ContextMenu Id="myMenu" OnAppearing="OnAppearing">
    <Item OnClick="@ContextMenuOnClickedit" Id="editGroup">Edit Group</Item>
</ContextMenu>

@code {

    VendorPostingGroupModel model = new VendorPostingGroupModel();
    private MudListItem SelectedItem;
    private List<VendorPostingGroupModel> listOfItems = new();
    VendorPostingGroupModel SelectedModel = new();
    public bool value = false;
    public string titleValue = null;
    private List<VendorPostingGroupModel> collection = new List<VendorPostingGroupModel>();

    private bool IsOnlyView { get; set; } = false;

    protected override async Task OnInitializedAsync()
    {
        GetAll();
    }

    protected async Task SelectedItemChanged(object obj)
    {
        SelectedItem = (MudListItem)obj;
        SelectedModel = (VendorPostingGroupModel)SelectedItem.Value;
    }

    private void GetAll()
    {
        listOfItems = Iservice.Select().ToList();
    }

    public void CancelVendorPostingGroup()
    {
        IsOnlyView = false;
        value = false;
        model = new();
    }

    public async Task CreateVendorPostingGroup()
    {
        IsOnlyView = false;
        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;
        model.UserInfo.UserID = user.Identity.Name;
        try
        {
            Iservice.Update(model);
            snackbar.Add("Successfully Submitted", Severity.Success);
            GetAll();
            value = false;
        }
        catch (Exception a)
        {
            snackbar.Add(a.Message, Severity.Error);
        }
    }

    private async Task OpenDialog(VendorPostingGroupModel ii)
    {

    }

    private void OpenDialogGroup(VendorPostingGroupModel ig)
    {
        IsOnlyView = false;
        value = true;
        model = new();
        titleValue = "Add Vendor Posting Group";
    }

    void OnAppearing(MenuAppearingEventArgs e)
    {

    }

    protected void ContextMenuOnClickedit(ItemClickEventArgs e)
    {
        IsOnlyView = false;
        model = (VendorPostingGroupModel)((VendorPostingGroupModel)e.Data).Clone();
        value = true;
        titleValue = "Edit Vendor Posting Group";
    }

    protected void ViewDetails(MouseEventArgs e, VendorPostingGroupModel Data)
    {
        IsOnlyView = true;
        model = Data;
        value = true;
        titleValue = "Vendor Posting Group | " + Data.Title;
    }
}