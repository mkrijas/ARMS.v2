@inject ITdsRateService tdsRate
@inject ITdsAccountMappingService Iservice
@inject IChartOfAccountService accountService
@inject MudBlazor.ISnackbar snackbar
@inject AuthenticationStateProvider auth
@attribute [Authorize]
@inject IDialogService DialogService
@using System.Threading;

<MudDialog Class="admin-dialog-glass">
    <TitleContent>
        <div class="admin-header-tiered px-8 pt-8 pb-4 text-center">
            <div class="admin-header-icon-badge mb-3 mx-auto">
                <MudIcon Icon="@Icons.Material.Filled.AccountTree" Color="Color.Primary" Style="font-size: 3rem; color: #FF9F43 !important;" />
            </div>
            <MudText Typo="Typo.h5" Style="font-weight: 800; color: #141A46; letter-spacing: -0.5px;">TDS Account Mapping</MudText>
            <MudText Typo="Typo.body2" Style="color: #667085; font-weight: 500;" Class="mt-1">Link specific General Ledger accounts to TDS nature of payment categories for automated tax calculation.</MudText>
            <div class="header-accent-divider mx-auto mt-4" style="background: linear-gradient(90deg, transparent, #FF9F43, transparent); width: 100%; height: 1px;"></div>
        </div>
    </TitleContent>
    <DialogContent>
        <div class="dialog-content-wrapper pa-4">
            <EditForm id="formtdsRate" Model="@model" OnValidSubmit="OnValidSubmit">
                <ObjectGraphDataAnnotationsValidator />
                
                <div class="admin-glass-card pa-6">
                    <MudGrid Spacing="4">
                        <MudItem xs="12">
                            <MudSelect For="@(() => model.TdsNPID)" Label="Nature of Payment" @bind-Value="model.TdsNPID" T="int?" Variant="Variant.Outlined" Margin="Margin.Dense" Class="admin-input-group" Disabled="true">
                                @foreach (var ditem in naturepayment)
                                {
                                    <MudSelectItem Value="@ditem.TdsNPID">@ditem.NatureOfPayment</MudSelectItem>
                                }
                            </MudSelect>
                        </MudItem>
                        <MudItem xs="12">
                            <MudAutocomplete T="ChartOfAccountModel" ValueChanged="OnChangeAccount" Label="Select Ledger Account" Value="SelectedAccount" ResetValueOnEmptyText="true" Variant="Variant.Outlined" Margin="Margin.Dense" Class="admin-input-group"
                                             SearchFunc="SearchAccounts" ToStringFunc="@(e => e == null ? null : $"{e.AccountName}")" Required />
                        </MudItem>
                    </MudGrid>
                </div>
            </EditForm>
        </div>
    </DialogContent>
    <DialogActions>
        <div class="px-8 pb-8 d-flex gap-4 w-100">
            <MudButton OnClick="Cancel" Variant="Variant.Outlined" FullWidth="true" Style="border-radius: 12px; height: 50px; font-weight: 700; color: #141A46; border: 2px solid #E2E8F0;">CANCEL</MudButton>
            <MudButton Disabled="@_busy" form="formtdsRate" Variant="Variant.Filled" Color="Color.Primary" FullWidth="true" ButtonType="ButtonType.Submit" Style="background: #FF9F43; border-radius: 12px; height: 50px; font-weight: 700;">SAVE MAPPING</MudButton>
        </div>
    </DialogActions>
</MudDialog>

 @code {

    [Parameter]
    public TdsAccountMappingModel model { get; set; }
    private List<TdsAccountMappingModel> collection = new List<TdsAccountMappingModel>();
    public bool IsDisablePayment { get; set; } = false;
    private List<ChartOfAccountModel> account = new();
    private TdsAccountMappingModel tds = new();
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; }
    private List<NatureOfPaymentModel> naturepayment = new();
    private ChartOfAccountModel SelectedAccount = null;

    private bool _busy;

    // Method to search for accounts based on a search string
    private async Task<IEnumerable<ChartOfAccountModel>> SearchAccounts(string searchString, CancellationToken token)
    {
        return await Task.FromResult(accountService.FilterSubLedgers(searchString));
    }

    // Lifecycle method called when the component is initialized
    protected override void OnInitialized()
    {
        // Load nature of payment options
        naturepayment = tdsRate.SelectTdsNP().ToList();
        try
        {
            SelectedAccount = new();
            SelectedAccount.CoaID = model.CoaID;
            SelectedAccount.AccountName = model.AccountName;
        }
        catch (Exception ex)
        {

        }
    }

    // Method to handle changes in the selected account
    private void OnChangeAccount(ChartOfAccountModel obj)
    {
        SelectedAccount = obj;
        model.CoaID = obj?.CoaID ?? null;
    }

    // Method to handle form submission when the form is valid
    private async void OnValidSubmit(EditContext context)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is being submitted!", Severity.Warning);
            return;
        }
        _busy = true;

        model.CoaID = SelectedAccount.CoaID;
        if (model.CoaID == null)
        {
            snackbar.Add("Select Account", Severity.Success);
        }
        else if (model.TdsNPID == null)
        {
            snackbar.Add("Select Nature of payment", Severity.Success);
        }
        else
        {
            MudDialog.Close(model);
        }
        await Task.Delay(200);
        _busy = false;
    }

    private void Cancel()
    {
        MudDialog.Cancel();
    }
}
