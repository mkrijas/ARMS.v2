@inject ITdsRateService tdsRate
@inject ITdsAccountMappingService Iservice
@inject IChartOfAccountService accountService
@inject MudBlazor.ISnackbar snackbar
@inject AuthenticationStateProvider auth
@attribute [Authorize]
@inject IDialogService DialogService

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.Build" Class="mr-3 mb-n1" />
            TDS Account Mapping
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudContainer Style="min-height:300px;max-height: 800px;">
            <EditForm id="formtdsRate" Model="@model" OnValidSubmit="OnValidSubmit">
                <ObjectGraphDataAnnotationsValidator />
                <ValidationSummary />
                <MudGrid Spacing="2">
                    <MudItem xs="12">
                        <MudSelect Label="Select Nature of payment" @bind-Value="model.TdsNPID" T="int?" Variant="Variant.Outlined" Margin="Margin.Dense"   AdornmentColor="Color.Secondary" Disabled>
                            @foreach (var ditem in naturepayment)
                            {
                                <MudSelectItem Value="@ditem.TdsNPID">@ditem.NatureOfPayment</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12">
                        <MudAutocomplete T="ChartOfAccountModel" ValueChanged="OnChangeAccount" Label="Select Accounts" Value="SelectedAccount" ResetValueOnEmptyText="true" Variant="Variant.Outlined" Margin="Margin.Dense"   AdornmentColor="Color.Secondary"
                                         SearchFunc="SearchAccounts" ToStringFunc="@(e => e == null ? null : $"{e.AccountName}")" Required></MudAutocomplete>
                     </MudItem>
                 </MudGrid>
             </EditForm>
         </MudContainer>
     </DialogContent>
     <DialogActions>
         <MudButton OnClick="Cancel">Cancel</MudButton>
         <MudButton Disabled="@_busy" form="formtdsRate" Variant="Variant.Filled" Color="Color.Success" ButtonType="ButtonType.Submit">Submit</MudButton>
     </DialogActions>
 </MudDialog>

 @code {

    [Parameter]
    public TdsAccountMappingModel model { get; set; }
    private List<TdsAccountMappingModel> collection = new List<TdsAccountMappingModel>();
    public bool IsDisablePayment { get; set; } = false;
    private List<ChartOfAccountModel> account = new();
    private TdsAccountMappingModel tds = new();
    [CascadingParameter] MudDialogInstance MudDialog { get; set; }
    private List<NatureOfPaymentModel> naturepayment = new();
    private ChartOfAccountModel SelectedAccount = null;

    private bool _busy;

    // Method to search for accounts based on a search string
    private async Task<IEnumerable<ChartOfAccountModel>> SearchAccounts(string searchString)
    {
        return await Task.FromResult(accountService.FilterSubLedgers(searchString));
    }

    // Lifecycle method called when the component is initialized
    protected override void OnInitialized()
    {
        // Load nature of payment options
        naturepayment = tdsRate.SelectTdsNP().ToList();
        try
        {
            SelectedAccount = new();
            SelectedAccount.CoaID = model.CoaID;
            SelectedAccount.AccountName = model.AccountName;
        }
        catch (Exception ex)
        {

        }
    }

    // Method to handle changes in the selected account
    private void OnChangeAccount(ChartOfAccountModel obj)
    {
        SelectedAccount = obj;
        model.CoaID = obj?.CoaID ?? null;
    }

    // Method to handle form submission when the form is valid
    private async void OnValidSubmit(EditContext context)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is being submitted!", Severity.Warning);
            return;
        }
        _busy = true;

        model.CoaID = SelectedAccount.CoaID;
        if (model.CoaID == null)
        {
            snackbar.Add("Select Account", Severity.Success);
        }
        else if (model.TdsNPID == null)
        {
            snackbar.Add("Select Nature of payment", Severity.Success);
        }
        else
        {
            MudDialog.Close(model);
        }
        await Task.Delay(200);
        _busy = false;
    }

    private void Cancel()
    {
        MudDialog.Cancel();
    }
}