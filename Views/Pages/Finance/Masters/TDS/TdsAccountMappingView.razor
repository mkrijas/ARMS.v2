<ContextMenu Id="myMenu" OnAppearing="OnAppearing">
    <Item OnClick="@ContextMenuOnClickadd" Id="addItem">Add Tds Account</Item>
</ContextMenu>*@

@code {

    private List<TdsAccountMappingModel> collection = new List<TdsAccountMappingModel>();
    private List<TdsRateModel> collectionTdsRate = new List<TdsRateModel>();
    private List<TdsThresholdLimitModel> collectionThresholdLimit = new List<TdsThresholdLimitModel>();

    public bool TdsRateToggle { get; set; } = false;
    public bool ThresholdLimitToggle { get; set; } = false;

    private List<NatureOfPaymentModel> listOfItems = new();
    NatureOfPaymentModel SelectedNP = new();
    MudListItem SelectedItem = new();
    //private MudListItem SelectedItem;

    private string searchTds = "";

    protected override void OnInitialized()
    {
        GetAll();
    }

    protected void SelectedItemChanged(object obj)
    {
        if (obj != null)
        {
            SelectedItem = (MudListItem)obj;
            SelectedNP = (NatureOfPaymentModel)SelectedItem.Value;
            ShowMappedAccounts(SelectedNP);
            TdsrateToggled(false);
            ThresholdLimitToggled(false);

        }
    }

    protected void SelectedItemChangedInitial(object obj)
    {
        if (obj != null)
        {


            ShowMappedAccounts(SelectedNP);
            TdsrateToggled(false);
            ThresholdLimitToggled(false);

        }
    }
    private void GetAll()
    {
        listOfItems = ITdsRateservice.SelectTdsNP().ToList();
        if (listOfItems != null && listOfItems.Count() != 0)
        {
            SelectedNP = (listOfItems.FirstOrDefault());
            SelectedItemChanged(SelectedNP);

        }
    }
    private void ShowMappedAccounts(NatureOfPaymentModel ig)
    {
        collection = Iservice.SelectByNP(ig.TdsNPID.Value).ToList();
    }

    private void TdsrateToggled(bool Toggle)
    {
        TdsRateToggle = Toggle;
        DateTime? dtm = Toggle ? null : DateTime.Today;
        collectionTdsRate = ITdsRateservice.Select(null, SelectedNP?.TdsNPID, dtm).ToList();
    }

    private void ThresholdLimitToggled(bool Toggle)
    {
        ThresholdLimitToggle = Toggle;
        DateTime? dtm = Toggle ? null : DateTime.Today;
        collectionThresholdLimit = IThresholdLimitservice.SelectByNP(SelectedNP.TdsNPID ?? 0, dtm).ToList();
    }


    private async Task Delete(TdsAccountMappingModel tds)
    {
        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;
        var result = Iservice.Delete(tds.TdsAccountMappedID, user.Identity.Name);
        if (result != -1)
        {
            snackbar.Add("Deleted Successfully", Severity.Success);
            NatureOfPaymentModel igm = new NatureOfPaymentModel();
            igm.TdsNPID = tds.TdsNPID;
            ShowMappedAccounts(igm);
        }
    }

    private async Task DeleteTdsRate(TdsRateModel tds)
    {
        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;
        var result = ITdsRateservice.Delete(tds.TdsRateID, user.Identity.Name);

        if (result != -1)
        {
            snackbar.Add("Deleted Successfully", Severity.Success);
            TdsrateToggled(TdsRateToggle);
        }
    }

    private async Task DeleteThresholdLimit(TdsThresholdLimitModel tds)
    {

        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;
        var result = IThresholdLimitservice.Delete(tds.TdsTLID, user.Identity.Name);

        if (result != -1)
        {
            snackbar.Add("Deleted Successfully", Severity.Success);
            ThresholdLimitToggled(ThresholdLimitToggle);

        }
    }

    private bool search(TdsAccountMappingModel tds)
    {
        if (tds.NatureOfPayment != null && tds.AccountName.Contains(searchTds, StringComparison.OrdinalIgnoreCase))
        {
            return true;
        }
        else if (tds.NatureOfPayment == null) return true;
        return false;
    }


    private async Task AddEditAccountMapping(TdsAccountMappingModel ii)
    {
        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;
        ii.NatureOfPayment = SelectedNP.NatureOfPayment;
        ii.TdsNPID = SelectedNP.TdsNPID;
        DialogParameters parms = new DialogParameters();
        parms.Add("model", ii);
        var dialog = DialogService.Show<TdsAccountMappingDialig>(ii.TdsAccountMappedID == null ? "ADD" : "EDIT", parms);
        var result = await dialog.Result;

        if (!result.Canceled)
        {
            TdsAccountMappingModel UpatedModel = (TdsAccountMappingModel)result.Data;
            ii.UserInfo.UserID = user.Identity.Name;
            try
            {
                Iservice.Update(UpatedModel);
                snackbar.Add("Saved Successfully", Severity.Success);
                NatureOfPaymentModel igm = new NatureOfPaymentModel();
                igm.TdsNPID = UpatedModel.TdsNPID;
                ShowMappedAccounts(igm);
            }
            catch (Exception ex)
            {
                snackbar.Add(ex.Message, Severity.Warning);
            }

        }
    }

    private async Task OpenDialogTdsRate(TdsRateModel tds)
    {
        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;

        tds.TdsNP = SelectedNP;

        DialogParameters parms = new DialogParameters();
        parms.Add("model", tds);
        var dialog = DialogService.Show<TdsRateDialog>(tds.TdsRateID == null ? "ADD" : "EDIT", parms);
        var result = await dialog.Result;

        if (!result.Canceled)
        {
            TdsRateModel UpatedModel = (TdsRateModel)result.Data;
            UpatedModel.UserInfo.UserID = user.Identity.Name;
            try
            {
                ITdsRateservice.Update(UpatedModel);
                snackbar.Add("Saved Successfully", Severity.Success);
                NatureOfPaymentModel igm = new NatureOfPaymentModel();
                igm.TdsNPID = UpatedModel.TdsNP.TdsNPID;
                TdsrateToggled(TdsRateToggle);
            }
            catch (Exception ex)
            {
                snackbar.Add(ex.Message, Severity.Warning);
            }

        }
    }

    private async Task OpenDialogThresholdLimit(TdsThresholdLimitModel tds)
    {
        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;
        tds.NatureOfPayment = SelectedNP;
        DialogParameters parms = new DialogParameters();
        parms.Add("model", tds);
        var dialog = DialogService.Show<TdsThresholdLimitDialog>(tds.TdsTLID == null ? "ADD" : "EDIT", parms);
        var result = await dialog.Result;
        if (!result.Canceled)
        {
            TdsThresholdLimitModel UpatedModel = (TdsThresholdLimitModel)result.Data;
            UpatedModel.UserInfo.UserID = user.Identity.Name;
            try
            {
                IThresholdLimitservice.Update(UpatedModel);
                snackbar.Add("Saved Successfully", Severity.Success);
                NatureOfPaymentModel igm = new NatureOfPaymentModel();
                igm.TdsNPID = UpatedModel.TdsTLID;
                ThresholdLimitToggled(ThresholdLimitToggle);
            }
            catch (Exception ex)
            {
                snackbar.Add(ex.Message, Severity.Warning);
            }

        }
    }

    void OnAppearing(MenuAppearingEventArgs e)
    {
        //TreeItemData item = (TreeItemData)e.Data;
        // e.PreventShow = !item.HasChildren;
    }
    //protected async Task ContextMenuOnClickadd(ItemClickEventArgs e)
    //{
    //    NatureOfPaymentModel ig = (NatureOfPaymentModel)e.Data;
    //    TdsAccountMappingModel ii = new TdsAccountMappingModel();
    //    ii.TdsNPID = ig.TdsNPID;
    //    await AddEditAccountMapping(ii);
    //}
}

