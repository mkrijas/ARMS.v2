@page "/TDSSetting"
@inject ITdsRateService tdsRate
@inject ITdsAccountMappingService Iservice
@inject ITdsRateService ITdsRateservice
@inject ITdsThresholdLimitService IThresholdLimitservice
@inject IChartOfAccountService account
@inject MudBlazor.ISnackbar snackbar
@inject AuthenticationStateProvider auth
@attribute [Authorize]
@using System.Threading;
@inject IRoleService<RoleModel> Irole
@inject IDialogService DialogService

@if (_isLoading)
{
    <div @key="@("loader")" style="position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(255,255,255,0.9); z-index: 9999; display: flex; justify-content: center; align-items: center;">
        <LoaderComponent IsFullScreen="true" 
                        ShowLogo="false" 
                        Size="medium" 
                        LoadingText="Loading TDS Account Mapping" 
                        SubText="Please wait..." />
    </div>
}
else
{
    <div @key="@("content")">
    <div class="admin-page-container pa-6">
        <div class="admin-header-tiered mb-6">
            <div class="d-flex align-center justify-space-between">
                <div>
                    <MudText Typo="Typo.h4" Style="font-weight: 800; color: #141A46; letter-spacing: -1px;">TDS Configuration</MudText>
                    <MudText Typo="Typo.body2" Style="color: #667085; font-weight: 500;">Manage tax deduction rates, thresholds, and ledger account mappings for compliance.</MudText>
                </div>
            </div>
        </div>

        <MudGrid Spacing="4">
            <MudItem xs="12" md="4" lg="3">
                <div class="admin-glass-card pa-0 overflow-hidden sticky-top" style="top: 24px;">
                    <div class="px-6 py-4 border-bottom-subtle" style="background: rgba(255, 159, 67, 0.02);">
                        <span class="admin-section-label mb-0">Nature of Payment</span>
                    </div>
                    <div class="pa-2">
                        @if (listOfItems?.Any() == true)
                        {
                           @foreach (var item in listOfItems)
                           {
                               <div class="admin-nav-item @(SelectedNP == item ? "active" : "") pa-3 rounded-lg mb-1 cursor-pointer transition-all" 
                                    style="@(SelectedNP == item ? "background: rgba(255, 159, 67, 0.1); border-left: 4px solid #FF9F43; color: #141A46; font-weight: 700;" : "color: #667085;")" 
                                    @onclick="@(()=> SelectItem(item))">
                                   <MudText Typo="Typo.body2" Style="font-weight: inherit;">@(item?.NatureOfPayment?.ToString())</MudText>
                               </div>
                           }
                        }
                    </div>
                </div>
            </MudItem>

            @if (SelectedNP != null)
            {
                <MudItem xs="12" md="8" lg="9">
                    <div class="d-flex flex-column gap-6">
                        @* Account Mapping Table *@
                        <div class="admin-glass-card pa-0 overflow-hidden">
                            <div class="px-6 py-4 border-bottom-subtle d-flex align-center justify-space-between" style="background: rgba(255, 159, 67, 0.02);">
                                <span class="admin-section-label mb-0">GL Account Mappings</span>
                                <MudButton StartIcon="@Icons.Material.Filled.Add" Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small" Style="background: #FF9F43; border-radius: 8px; font-weight: 700;" OnClick="@(()=> AddEditAccountMapping(new TdsAccountMappingModel()))" Disabled="@_busy">ADD MAPPING</MudButton>
                            </div>
                            <div class="modern-admin-table">
                                <MudTable Items="@collection" Dense="true" Hover="true" Elevation="0">
                                    <HeaderContent>
                                        <MudTh><span class="admin-header-text">ACCOUNT NAME</span></MudTh>
                                        <MudTh Style="text-align: right;"><span class="admin-header-text">ACTIONS</span></MudTh>
                                    </HeaderContent>
                                    <RowTemplate>
                                        <MudTd DataLabel="AccountName">
                                            <MudText Typo="Typo.body2" Style="font-weight: 700; color: #141A46;">@context.AccountName</MudText>
                                        </MudTd>
                                        <MudTd Style="text-align: right;">
                                            <div class="d-flex justify-end gap-1">
                                                <MudIconButton OnClick="@(()=> AddEditAccountMapping(context))" Color="Color.Primary" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Variant="Variant.Text" />
                                                <MudIconButton OnClick="@(()=> Delete(context))" Color="Color.Error" Icon="@Icons.Material.Filled.DeleteOutline" Size="Size.Small" Variant="Variant.Text" />
                                            </div>
                                        </MudTd>
                                    </RowTemplate>
                                </MudTable>
                            </div>
                        </div>

                        @* TDS Rates Table *@
                        <div class="admin-glass-card pa-0 overflow-hidden">
                            <div class="px-6 py-4 border-bottom-subtle d-flex align-center justify-space-between" style="background: rgba(255, 159, 67, 0.02);">
                                <div class="d-flex align-center gap-4">
                                    <span class="admin-section-label mb-0">TDS Rates</span>
                                    <div class="d-flex align-center px-3 py-1 rounded-lg" style="background: rgba(255, 159, 67, 0.05); border: 1px solid rgba(255, 159, 67, 0.1);">
                                        <MudCheckBox Label="Show All" T="bool" ValueChanged="TdsrateToggled" Value="@TdsRateToggle" Size="Size.Small" Color="Color.Primary" />
                                    </div>
                                </div>
                                <MudButton StartIcon="@Icons.Material.Filled.Add" Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small" Style="background: #FF9F43; border-radius: 8px; font-weight: 700;" OnClick="@(()=> OpenDialogTdsRate(new TdsRateModel()))" Disabled="@_busy">ADD RATE</MudButton>
                            </div>
                            <div class="modern-admin-table">
                                <MudTable Items="@collectionTdsRate" Dense="true" Hover="true" Elevation="0">
                                    <HeaderContent>
                                        <MudTh><span class="admin-header-text">ASSESSEE TYPE</span></MudTh>
                                        <MudTh><span class="admin-header-text">PERIOD FROM</span></MudTh>
                                        <MudTh><span class="admin-header-text">PERIOD TO</span></MudTh>
                                        <MudTh><span class="admin-header-text">TAX RATE %</span></MudTh>
                                        <MudTh Style="text-align: right;"><span class="admin-header-text">ACTIONS</span></MudTh>
                                    </HeaderContent>
                                    <RowTemplate>
                                        <MudTd DataLabel="AssesseeType">@context.AssesseeType?.AssesseeTypeName</MudTd>
                                        <MudTd DataLabel="PeriodFrom">@context.PeriodFrom?.ToString("dd/MM/yyyy")</MudTd>
                                        <MudTd DataLabel="PeriodTo">@context.PeriodTo?.ToString("dd/MM/yyyy")</MudTd>
                                        <MudTd DataLabel="TaxRate">
                                            <MudText Typo="Typo.body2" Style="font-weight: 800; color: #FF9F43;">@context.TaxRate%</MudText>
                                        </MudTd>
                                        <MudTd Style="text-align: right;">
                                            <div class="d-flex justify-end gap-1">
                                                <MudIconButton OnClick="@(()=> OpenDialogTdsRate(context))" Color="Color.Primary" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Variant="Variant.Text" />
                                                <MudIconButton OnClick="@(()=> DeleteTdsRate(context))" Color="Color.Error" Icon="@Icons.Material.Filled.DeleteOutline" Size="Size.Small" Variant="Variant.Text" />
                                            </div>
                                        </MudTd>
                                    </RowTemplate>
                                </MudTable>
                            </div>
                        </div>

                        @* Threshold Limits Table *@
                        <div class="admin-glass-card pa-0 overflow-hidden">
                            <div class="px-6 py-4 border-bottom-subtle d-flex align-center justify-space-between" style="background: rgba(255, 159, 67, 0.02);">
                                <div class="d-flex align-center gap-4">
                                    <span class="admin-section-label mb-0">Threshold Limits</span>
                                    <div class="d-flex align-center px-3 py-1 rounded-lg" style="background: rgba(255, 159, 67, 0.05); border: 1px solid rgba(255, 159, 67, 0.1);">
                                        <MudCheckBox Label="Show All" T="bool" ValueChanged="ThresholdLimitToggled" Value="@ThresholdLimitToggle" Size="Size.Small" Color="Color.Primary" />
                                    </div>
                                </div>
                                <MudButton StartIcon="@Icons.Material.Filled.Add" Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small" Style="background: #FF9F43; border-radius: 8px; font-weight: 700;" OnClick="@(()=> OpenDialogThresholdLimit(new TdsThresholdLimitModel()))" Disabled="@_busy">ADD LIMIT</MudButton>
                            </div>
                            <div class="modern-admin-table">
                                <MudTable Items="@collectionThresholdLimit" Dense="true" Hover="true" Elevation="0">
                                    <HeaderContent>
                                        <MudTh><span class="admin-header-text">PERIOD FROM</span></MudTh>
                                        <MudTh><span class="admin-header-text">PERIOD TO</span></MudTh>
                                        <MudTh><span class="admin-header-text">SINGLE BILL</span></MudTh>
                                        <MudTh><span class="admin-header-text">ANNUAL PER.</span></MudTh>
                                        <MudTh Style="text-align: right;"><span class="admin-header-text">ACTIONS</span></MudTh>
                                    </HeaderContent>
                                    <RowTemplate>
                                        <MudTd DataLabel="PeriodFrom">@context.PeriodFrom?.ToString("dd/MM/yyyy")</MudTd>
                                        <MudTd DataLabel="PeriodTo">@context.PeriodTo?.ToString("dd/MM/yyyy")</MudTd>
                                        <MudTd DataLabel="ThresholdLimitSingle">
                                            <MudText Typo="Typo.body2" Style="font-weight: 700;">₹ @context.ThresholdLimitSingle?.ToString("N2")</MudText>
                                        </MudTd>
                                        <MudTd DataLabel="ThresholdLimitPeriod">
                                            <MudText Typo="Typo.body2" Style="font-weight: 700;">₹ @context.ThresholdLimitPeriod?.ToString("N2")</MudText>
                                        </MudTd>
                                        <MudTd Style="text-align: right;">
                                            <div class="d-flex justify-end gap-1">
                                                <MudIconButton OnClick="@(()=> OpenDialogThresholdLimit(context))" Color="Color.Primary" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Variant="Variant.Text" />
                                                <MudIconButton OnClick="@(()=> DeleteThresholdLimit(context))" Color="Color.Error" Icon="@Icons.Material.Filled.DeleteOutline" Size="Size.Small" Variant="Variant.Text" />
                                            </div>
                                        </MudTd>
                                    </RowTemplate>
                                </MudTable>
                            </div>
                        </div>
                    </div>
                </MudItem>
            }
        </MudGrid>
    </div>
    </div>
}
}

@code {

    private bool _isLoading = true;
    private DateTime _loadStartTime;

    private List<TdsAccountMappingModel> collection = new List<TdsAccountMappingModel>();
    private List<TdsRateModel> collectionTdsRate = new List<TdsRateModel>();
    private List<TdsThresholdLimitModel> collectionThresholdLimit = new List<TdsThresholdLimitModel>();
    public bool TdsRateToggle { get; set; } = false;
    public bool ThresholdLimitToggle { get; set; } = false;
    private List<NatureOfPaymentModel> listOfItems = new();
    NatureOfPaymentModel SelectedNP = new();
    
    private string searchTds = "";
    private bool _busy;

    public bool HasPermissionTdsThresholdLimitServiceEdit { get; set; } = false;
    public bool HasPermissionTdsThresholdLimitServiceDelete { get; set; } = false;
    public int TdsThresholdLimitDocTypeID = 76;

    public bool HasPermissionTdsRateServiceEdit { get; set; } = false;
    public bool HasPermissionTdsRateServiceDelete { get; set; } = false;
    public int TdsRateDocTypeID = 75;

    public bool HasPermissionTdsAccountMappingServiceEdit { get; set; } = false;
    public bool HasPermissionTdsAccountMappingServiceDelete { get; set; } = false;
    public int TdsAccountMappingDocTypeID = 45;

    // Lifecycle method called when the component is initialized
    protected override async Task OnInitializedAsync()
    {
        _loadStartTime = DateTime.Now;
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionTdsThresholdLimitServiceEdit = await Irole.HasClaim(TdsThresholdLimitDocTypeID.ToString(), "Edit", ctc.Token);
        HasPermissionTdsThresholdLimitServiceDelete = await Irole.HasClaim(TdsThresholdLimitDocTypeID.ToString(), "Delete", ctc.Token);
        HasPermissionTdsRateServiceEdit = await Irole.HasClaim(TdsRateDocTypeID.ToString(), "Edit", ctc.Token);
        HasPermissionTdsRateServiceDelete = await Irole.HasClaim(TdsRateDocTypeID.ToString(), "Delete", ctc.Token);
        HasPermissionTdsAccountMappingServiceEdit = await Irole.HasClaim(TdsAccountMappingDocTypeID.ToString(), "Edit", ctc.Token);
        HasPermissionTdsAccountMappingServiceDelete = await Irole.HasClaim(TdsAccountMappingDocTypeID.ToString(), "Delete", ctc.Token);

        GetAll();
        await EnsureMinimumLoadTime();
        _isLoading = false;
    }

    private async Task EnsureMinimumLoadTime()
    {
        var elapsed = (DateTime.Now - _loadStartTime).TotalMilliseconds;
        if (elapsed < 100)
        {
            await Task.Delay(100 - (int)elapsed);
        }
    }

    // Method to handle changes in the selected item
    protected void SelectItem(NatureOfPaymentModel item)
    {
        if (item != null)
        {
            SelectedNP = item;
            ShowMappedAccounts(SelectedNP);
            TdsrateToggled(false);
            ThresholdLimitToggled(false);
        }
    }

    // Method to fetch all nature of payment items
    private void GetAll()
    {
        listOfItems = ITdsRateservice.SelectTdsNP().ToList(); // Load nature of payment items from the service
    }

    // Method to show mapped accounts for a selected nature of payment
    private void ShowMappedAccounts(NatureOfPaymentModel ig)
    {
        collection = Iservice.SelectByNP(ig.TdsNPID.Value).ToList(); // Load mapped accounts based on the selected nature of payment
    }

    // Method to toggle the visibility of TDS rates
    private void TdsrateToggled(bool Toggle)
    {
        TdsRateToggle = Toggle;
        DateTime? dtm = Toggle ? null : DateTime.Today;
        collectionTdsRate = ITdsRateservice.Select(null, SelectedNP?.TdsNPID, dtm).ToList(); // Load TDS rates
    }

    // Method to toggle the visibility of threshold limits
    private void ThresholdLimitToggled(bool Toggle)
    {
        ThresholdLimitToggle = Toggle;
        DateTime? dtm = Toggle ? null : DateTime.Today;
        collectionThresholdLimit = IThresholdLimitservice.SelectByNP(SelectedNP.TdsNPID ?? 0, dtm).ToList(); // Load threshold limits
    }

    // Method to delete a TDS account mapping
    private async Task Delete(TdsAccountMappingModel model)
    {
        if (HasPermissionTdsAccountMappingServiceDelete)
        {
            bool? result = await DialogService.ShowMessageBox(
                "Warning !",
                "Are you sure, you want to delete - " + model.AccountName + " ?");
            if (result == true)
            {
                var authprov = await auth.GetAuthenticationStateAsync();
                var user = authprov.User;
                var value = Iservice.Delete(model.TdsAccountMappedID, user.Identity.Name); // Delete the account mapping
                if (value != -1)
                {
                    snackbar.Add("Deleted Successfully", Severity.Success);
                    NatureOfPaymentModel igm = new NatureOfPaymentModel();
                    igm.TdsNPID = model.TdsNPID;
                    ShowMappedAccounts(igm);
                }
            }
        }
        else
        {
            bool? result = await DialogService.ShowMessageBox(
                "Permission denied!",
                "You don't have any permission to Delete TdsAccountMapping.");
        }
    }

    // Method to delete a TDS rate
    private async Task DeleteTdsRate(TdsRateModel model)
    {
        if (HasPermissionTdsRateServiceDelete)
        {
            bool? result = await DialogService.ShowMessageBox(
                "Warning !",
                "Are you sure, you want to delete - " + model.AssesseeType.AssesseeTypeName + " (" + model.PeriodFrom + " - " + model.PeriodTo + ") ?");
            if (result == true)
            {
                var authprov = await auth.GetAuthenticationStateAsync();
                var user = authprov.User;
                var value = ITdsRateservice.Delete(model.TdsRateID, user.Identity.Name); // Delete the TDS rate
                if (value != -1)
                {
                    snackbar.Add("Deleted Successfully", Severity.Success);
                    TdsrateToggled(TdsRateToggle);
                }
            }
        }
        else
        {
            bool? result = await DialogService.ShowMessageBox(
                "Permission denied!",
                "You don't have any permission to Delete TdsRate.");
        }
    }

    // Method to delete a TDS threshold limit
    private async Task DeleteThresholdLimit(TdsThresholdLimitModel model)
    {
        if (HasPermissionTdsThresholdLimitServiceDelete)
        {
            bool? result = await DialogService.ShowMessageBox(
                "Warning !",
                "Are you sure, you want to delete - " + model.NatureOfPayment.NatureOfPayment + " (" + model.PeriodFrom + " - " + model.PeriodTo + ") ?");
            if (result == true)
            {
                var authprov = await auth.GetAuthenticationStateAsync();
                var user = authprov.User;
                var value = IThresholdLimitservice.Delete(model.TdsTLID, user.Identity.Name); // Delete the threshold limit
                if (value != -1)
                {
                    snackbar.Add("Deleted Successfully", Severity.Success);
                    ThresholdLimitToggled(ThresholdLimitToggle);
                }
            }
        }
        else
        {
            bool? result = await DialogService.ShowMessageBox(
                "Permission denied!",
                "You don't have any permission to Delete TdsThresholdLimit.");
        }
    }

    // Method to search for TDS account mappings based on a search string
    private bool search(TdsAccountMappingModel tds)
    {
        if (tds.NatureOfPayment != null && tds.AccountName.Contains(searchTds, StringComparison.OrdinalIgnoreCase))
        {
            return true;
        }
        else if (tds.NatureOfPayment == null) return true;
        return false;
    }

    // Method to add or edit an account mapping
    private async Task AddEditAccountMapping(TdsAccountMappingModel model)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        _busy = true;

        if (HasPermissionTdsAccountMappingServiceEdit)
        {
            var authprov = await auth.GetAuthenticationStateAsync();
            var user = authprov.User;
            model.NatureOfPayment = SelectedNP.NatureOfPayment;
            model.TdsNPID = SelectedNP.TdsNPID;
            DialogParameters parms = new DialogParameters();
            parms.Add("model", model.Clone());
            var dialog = DialogService.Show<TdsAccountMappingDialig>(model.TdsAccountMappedID == null ? "ADD" : "EDIT", parms);
            var result = await dialog.Result;
            if (!result.Canceled)
            {
                TdsAccountMappingModel UpatedModel = (TdsAccountMappingModel)result.Data;
                UpatedModel.UserInfo.UserID = user.Identity.Name;
                try
                {
                    // Check if the account already exists
                    TdsAccountMappingModel checkexist = Iservice.CheckExist(UpatedModel.CoaID);
                    @if (checkexist.NatureOfPayment != null)
                    {
                        bool? exist = await DialogService.ShowMessageBox(
                            "Warning !",
                            "Account Name : " + checkexist.AccountName + " already exist under NatureOfPayment : " + checkexist.NatureOfPayment + " ?");
                    }
                    else
                    {
                        Iservice.Update(UpatedModel); // Update the account mapping
                        snackbar.Add("Saved Successfully", Severity.Success);
                        NatureOfPaymentModel igm = new NatureOfPaymentModel();
                        igm.TdsNPID = UpatedModel.TdsNPID;
                        ShowMappedAccounts(igm);
                    }
                }
                catch (Exception ex)
                {
                    snackbar.Add(ex.Message, Severity.Warning);
                }
            }
        }
        else
        {
            bool? result = await DialogService.ShowMessageBox(
                "Permission denied!",
                "You don't have any permission to Edit TdsAccountMapping.");
        }
        await Task.Delay(200);
        _busy = false;
    }

    // Method to open the dialog for adding or editing a TDS rate
    private async Task OpenDialogTdsRate(TdsRateModel tds)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        _busy = true;

        if (HasPermissionTdsRateServiceEdit)
        {
            var authprov = await auth.GetAuthenticationStateAsync();
            var user = authprov.User;
            tds.TdsNP = SelectedNP;
            DialogParameters parms = new DialogParameters();
            parms.Add("model", tds.Clone());
            var dialog = DialogService.Show<TdsRateDialog>(tds.TdsRateID == null ? "ADD" : "EDIT", parms);
            var result = await dialog.Result;
            if (!result.Canceled)
            {
                TdsRateModel UpatedModel = (TdsRateModel)result.Data;
                UpatedModel.UserInfo.UserID = user.Identity.Name;
                try
                {
                    ITdsRateservice.Update(UpatedModel); // Update the TDS rate
                    snackbar.Add("Saved Successfully", Severity.Success);
                    NatureOfPaymentModel igm = new NatureOfPaymentModel();
                    igm.TdsNPID = UpatedModel.TdsNP.TdsNPID;
                    TdsrateToggled(TdsRateToggle);
                }
                catch (Exception ex)
                {
                    snackbar.Add(ex.Message, Severity.Warning);
                }
            }
        }
        else
        {
            bool? result = await DialogService.ShowMessageBox(
                "Permission denied!",
                "You don't have any permission to Edit TdsRate.");
        }
        await Task.Delay(200);
        _busy = false;
    }

    // Method to open the dialog for adding or editing a TDS threshold limit
    private async Task OpenDialogThresholdLimit(TdsThresholdLimitModel tds)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        _busy = true;

        if (HasPermissionTdsThresholdLimitServiceEdit)
        {
            var authprov = await auth.GetAuthenticationStateAsync();
            var user = authprov.User;
            tds.NatureOfPayment = SelectedNP;
            DialogParameters parms = new DialogParameters();
            parms.Add("model", tds.Clone());
            var dialog = DialogService.Show<TdsThresholdLimitDialog>(tds.TdsTLID == null ? "ADD" : "EDIT", parms);
            var result = await dialog.Result;
            if (!result.Canceled)
            {
                TdsThresholdLimitModel UpatedModel = (TdsThresholdLimitModel)result.Data;
                UpatedModel.UserInfo.UserID = user.Identity.Name;
                try
                {
                    IThresholdLimitservice.Update(UpatedModel); // Update the TDS threshold limit
                    snackbar.Add("Saved Successfully", Severity.Success);
                    NatureOfPaymentModel igm = new NatureOfPaymentModel();
                    igm.TdsNPID = UpatedModel.TdsTLID;
                    ThresholdLimitToggled(ThresholdLimitToggle);
                }
                catch (Exception ex)
                {
                    snackbar.Add(ex.Message, Severity.Warning);
                }
            }
        }
        else
        {
            bool? result = await DialogService.ShowMessageBox(
                "Permission denied!",
                "You don't have any permission to Edit TdsThresholdLimit.");
        }
        await Task.Delay(200);
        _busy = false;
    }

    void OnAppearing(MenuAppearingEventArgs e)
    {

    }
}

