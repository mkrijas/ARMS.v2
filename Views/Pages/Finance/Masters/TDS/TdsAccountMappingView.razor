@page "/TDSSetting"
@inject ITdsRateService tdsRate
@inject ITdsAccountMappingService Iservice
@inject ITdsRateService ITdsRateservice
@inject ITdsThresholdLimitService IThresholdLimitservice
@inject IChartOfAccountService account
@inject MudBlazor.ISnackbar snackbar
@inject AuthenticationStateProvider auth
@attribute [Authorize]
@using System.Threading;
@inject IRoleService<RoleModel> Irole
@inject IDialogService DialogService

@if (_isLoading)
{
    <div @key="@("loader")" style="display: flex; justify-content: center; align-items: center; min-height: 400px;">
        <LoaderComponent IsFullScreen="true" 
                        ShowLogo="false" 
                        Size="medium" 
                        LoadingText="Loading TDS Configuration Hub" 
                        SubText="Please wait..." />
    </div>
}
else
{
    <div class="fade-in tds-settings-page">
        <div class="admin-header-tiered mb-6">
            <div class="d-flex align-center justify-space-between">
                <div>
                    <MudText Typo="Typo.h4" Class="admin-title">TDS Central Configuration Hub</MudText>
                    <MudText Typo="Typo.body2" Class="admin-subtitle">Consolidated orchestrator for Tax Deducted at Source. map ledger accounts, define tax matrices, and configure applicability thresholds for systematic compliance.</MudText>
                </div>
            </div>
        </div>

        <div class="admin-grid-layout-split">
            @* Sidebar Navigation *@
            <div class="admin-glass-card pa-0 overflow-hidden sticky-top" style="top: 24px; height: fit-content;">
                <div class="px-6 py-4 bg-glass border-bottom-subtle">
                    <div class="d-flex align-center gap-2">
                        <MudIcon Icon="@Icons.Material.Filled.AccountTree" Size="Size.Small" Class="opa-50" />
                        <span class="admin-section-label mb-0">Payment Natures</span>
                    </div>
                </div>
                <div class="pa-2 max-h-500 overflow-y-auto">
                    @if (listOfItems?.Any() == true)
                    {
                        @foreach (var item in listOfItems)
                        {
                            <div class="admin-nav-item @(SelectedNP == item ? "active" : "") pa-3 rounded-lg mb-1 cursor-pointer transition-all" 
                                 @onclick="@(()=> SelectItem(item))">
                                <div class="d-flex align-center gap-3">
                                    <div class="admin-nav-indicator"></div>
                                    <MudText Typo="Typo.body2" Class="fw-600">@(item?.NatureOfPayment?.ToString())</MudText>
                                </div>
                            </div>
                        }
                    }
                </div>
            </div>

            @* Main Content *@
            @if (SelectedNP != null)
            {
                <div class="d-flex flex-column gap-6 tds-settings-main">
                    @* GL Account Mapping Section *@
                    <div class="admin-glass-card pa-0 overflow-hidden shadow-sm">
                        <div class="px-6 py-4 bg-glass border-bottom-subtle d-flex align-center justify-space-between">
                            <div class="d-flex align-center gap-3">
                                <div class="admin-icon-square-vibrant small accent-indigo">
                                    <MudIcon Icon="@Icons.Material.Filled.Link" Size="Size.Small" />
                                </div>
                                <span class="admin-section-label mb-0">GL Account Mappings</span>
                            </div>
                            <MudButton StartIcon="@Icons.Material.Filled.Add" Variant="Variant.Filled" Color="Color.Primary" Class="admin-register-btn" OnClick="@(()=> AddEditAccountMapping(new TdsAccountMappingModel()))" Disabled="@_busy">ADD MAPPING</MudButton>
                        </div>
                        <MudTable Items="@collection" Elevation="0" Class="modern-admin-table" Hover="true">
                            <HeaderContent>
                                <MudTh><span class="admin-header-text">CHART OF ACCOUNT / LEDGER</span></MudTh>
                                <MudTh Style="text-align: right;"><span class="admin-header-text">ACTIONS</span></MudTh>
                            </HeaderContent>
                            <RowTemplate>
                                <MudTd DataLabel="Account">
                                    <div class="d-flex align-center gap-2">
                                        <MudIcon Icon="@Icons.Material.Filled.AccountBalance" Size="Size.Small" Class="opa-40" />
                                        <span class="fw-700 admin-td-primary">@context.AccountName</span>
                                    </div>
                                </MudTd>
                                <MudTd DataLabel="Actions" Style="text-align: right;">
                                    <div class="d-flex justify-end gap-1">
                                        <MudTooltip Text="Edit Mapping">
                                            <MudIconButton OnClick="@(()=> AddEditAccountMapping(context))" Color="Color.Primary" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Variant="Variant.Text" />
                                        </MudTooltip>
                                        <MudTooltip Text="Purge Mapping">
                                            <MudIconButton OnClick="@(()=> Delete(context))" Color="Color.Error" Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Variant="Variant.Text" />
                                        </MudTooltip>
                                    </div>
                                </MudTd>
                            </RowTemplate>
                        </MudTable>
                    </div>

                    @* TDS Rates Section *@
                    <div class="admin-glass-card pa-0 overflow-hidden shadow-sm">
                        <div class="px-6 py-4 bg-glass border-bottom-subtle d-flex align-center justify-space-between">
                            <div class="d-flex align-center gap-4">
                                <div class="d-flex align-center gap-3">
                                    <div class="admin-icon-square-vibrant small accent-amber">
                                        <MudIcon Icon="@Icons.Material.Filled.Percent" Size="Size.Small" />
                                    </div>
                                    <span class="admin-section-label mb-0">Deduction Matrix</span>
                                </div>
                                <div class="d-flex align-center bg-glass rounded-pill px-4 py-1">
                                    <MudCheckBox Label="Audit Legacy (Show All)" T="bool" ValueChanged="TdsrateToggled" Value="@TdsRateToggle" Size="Size.Small" Color="Color.Primary" Class="fw-600" />
                                </div>
                            </div>
                            <MudButton StartIcon="@Icons.Material.Filled.Add" Variant="Variant.Filled" Color="Color.Primary" Class="admin-register-btn" OnClick="@(()=> OpenDialogTdsRate(new TdsRateModel()))" Disabled="@_busy">ADD RATE</MudButton>
                        </div>
                        <MudTable Items="@collectionTdsRate" Elevation="0" Class="modern-admin-table" Hover="true">
                            <HeaderContent>
                                <MudTh><span class="admin-header-text">ASSESSEE TYPE</span></MudTh>
                                <MudTh><span class="admin-header-text">VALIDITY</span></MudTh>
                                <MudTh Style="text-align: right;"><span class="admin-header-text">TAX RATE</span></MudTh>
                                <MudTh Style="text-align: right;"><span class="admin-header-text">ACTIONS</span></MudTh>
                            </HeaderContent>
                            <RowTemplate>
                                <MudTd DataLabel="Assessee">
                                    <MudChip T="string" Color="Color.Default" Variant="Variant.Text" Size="Size.Small" Class="fw-700 px-3 border-solid border-1">@context.AssesseeType?.AssesseeTypeName</MudChip>
                                </MudTd>
                                <MudTd DataLabel="Validity">
                                    <div class="d-flex align-center gap-2">
                                        <span class="fw-600">@context.PeriodFrom?.ToString("dd MMM yyyy")</span>
                                        <MudIcon Icon="@Icons.Material.Filled.ArrowForward" Size="Size.Small" Class="opa-20" />
                                        <span class="fw-600">@context.PeriodTo?.ToString("dd MMM yyyy")</span>
                                    </div>
                                </MudTd>
                                <MudTd DataLabel="Rate" Style="text-align: right;">
                                    <span class="fw-800 text-vibrant" style="font-size: 1.1rem;">@context.TaxRate%</span>
                                </MudTd>
                                <MudTd DataLabel="Actions" Style="text-align: right;">
                                    <div class="d-flex justify-end gap-1">
                                        <MudIconButton OnClick="@(()=> OpenDialogTdsRate(context))" Color="Color.Primary" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Variant="Variant.Text" />
                                        <MudIconButton OnClick="@(()=> DeleteTdsRate(context))" Color="Color.Error" Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Variant="Variant.Text" />
                                    </div>
                                </MudTd>
                            </RowTemplate>
                        </MudTable>
                    </div>

                    @* Threshold Limits Section *@
                    <div class="admin-glass-card pa-0 overflow-hidden shadow-sm mb-8">
                        <div class="px-6 py-4 bg-glass border-bottom-subtle d-flex align-center justify-space-between">
                            <div class="d-flex align-center gap-4">
                                <div class="d-flex align-center gap-3">
                                    <div class="admin-icon-square-vibrant small accent-success">
                                        <MudIcon Icon="@Icons.Material.Filled.VerticalAlignTop" Size="Size.Small" />
                                    </div>
                                    <span class="admin-section-label mb-0">Applicability Thresholds</span>
                                </div>
                                <div class="d-flex align-center bg-glass rounded-pill px-4 py-1">
                                    <MudCheckBox Label="Historical (Show All)" T="bool" ValueChanged="ThresholdLimitToggled" Value="@ThresholdLimitToggle" Size="Size.Small" Color="Color.Primary" Class="fw-600" />
                                </div>
                            </div>
                            <MudButton StartIcon="@Icons.Material.Filled.Add" Variant="Variant.Filled" Color="Color.Primary" Class="admin-register-btn" OnClick="@(()=> OpenDialogThresholdLimit(new TdsThresholdLimitModel()))" Disabled="@_busy">ADD LIMIT</MudButton>
                        </div>
                        <MudTable Items="@collectionThresholdLimit" Elevation="0" Class="modern-admin-table" Hover="true">
                            <HeaderContent>
                                <MudTh><span class="admin-header-text">PERIOD</span></MudTh>
                                <MudTh Style="text-align: right;"><span class="admin-header-text">SINGLE BILL CAP</span></MudTh>
                                <MudTh Style="text-align: right;"><span class="admin-header-text">ANNUAL AGGREGATE</span></MudTh>
                                <MudTh Style="text-align: right;"><span class="admin-header-text">ACTIONS</span></MudTh>
                            </HeaderContent>
                            <RowTemplate>
                                <MudTd DataLabel="Period">
                                    <div class="d-flex align-center gap-2">
                                        <span class="fw-600">@context.PeriodFrom?.ToString("dd MMM yyyy")</span>
                                        <MudIcon Icon="@Icons.Material.Filled.ArrowForward" Size="Size.Small" Class="opa-20" />
                                        <span class="fw-600">@context.PeriodTo?.ToString("dd MMM yyyy")</span>
                                    </div>
                                </MudTd>
                                <MudTd DataLabel="Single" Style="text-align: right;">
                                    <span class="fw-700 font-monospace">@string.Format("{0:N2}", context.ThresholdLimitSingle)</span>
                                </MudTd>
                                <MudTd DataLabel="Aggregate" Style="text-align: right;">
                                    <span class="fw-700 text-vibrant font-monospace">@string.Format("{0:N2}", context.ThresholdLimitPeriod)</span>
                                </MudTd>
                                <MudTd DataLabel="Actions" Style="text-align: right;">
                                    <div class="d-flex justify-end gap-1">
                                        <MudIconButton OnClick="@(()=> OpenDialogThresholdLimit(context))" Color="Color.Primary" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Variant="Variant.Text" />
                                        <MudIconButton OnClick="@(()=> DeleteThresholdLimit(context))" Color="Color.Error" Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Variant="Variant.Text" />
                                    </div>
                                </MudTd>
                            </RowTemplate>
                        </MudTable>
                    </div>
                </div>
            }
            else
            {
                <div class="d-flex flex-column align-center justify-center pa-12 opa-30" style="min-height: 400px;">
                    <MudIcon Icon="@Icons.Material.Filled.AdsClick" Size="Size.Large" Class="mb-4" Style="font-size: 4rem;" />
                    <MudText Typo="Typo.h5" Class="fw-700">Select Payment Nature</MudText>
                    <MudText Typo="Typo.body2">Choose a category from the sidebar to configure its TDS parameters.</MudText>
                </div>
            }
        </div>
    </div>
}

@code {

    private bool _isLoading = true;
    private DateTime _loadStartTime;

    private List<TdsAccountMappingModel> collection = new List<TdsAccountMappingModel>();
    private List<TdsRateModel> collectionTdsRate = new List<TdsRateModel>();
    private List<TdsThresholdLimitModel> collectionThresholdLimit = new List<TdsThresholdLimitModel>();
    public bool TdsRateToggle { get; set; } = false;
    public bool ThresholdLimitToggle { get; set; } = false;
    private List<NatureOfPaymentModel> listOfItems = new();
    NatureOfPaymentModel SelectedNP = null;
    
    private string searchTds = "";
    private bool _busy;

    public bool HasPermissionTdsThresholdLimitServiceEdit { get; set; } = false;
    public bool HasPermissionTdsThresholdLimitServiceDelete { get; set; } = false;
    public int TdsThresholdLimitDocTypeID = 76;

    public bool HasPermissionTdsRateServiceEdit { get; set; } = false;
    public bool HasPermissionTdsRateServiceDelete { get; set; } = false;
    public int TdsRateDocTypeID = 75;

    public bool HasPermissionTdsAccountMappingServiceEdit { get; set; } = false;
    public bool HasPermissionTdsAccountMappingServiceDelete { get; set; } = false;
    public int TdsAccountMappingDocTypeID = 45;

    // Lifecycle method called when the component is initialized
    protected override async Task OnInitializedAsync()
    {
        _loadStartTime = DateTime.Now;
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionTdsThresholdLimitServiceEdit = await Irole.HasClaim(TdsThresholdLimitDocTypeID.ToString(), "Edit", ctc.Token);
        HasPermissionTdsThresholdLimitServiceDelete = await Irole.HasClaim(TdsThresholdLimitDocTypeID.ToString(), "Delete", ctc.Token);
        HasPermissionTdsRateServiceEdit = await Irole.HasClaim(TdsRateDocTypeID.ToString(), "Edit", ctc.Token);
        HasPermissionTdsRateServiceDelete = await Irole.HasClaim(TdsRateDocTypeID.ToString(), "Delete", ctc.Token);
        HasPermissionTdsAccountMappingServiceEdit = await Irole.HasClaim(TdsAccountMappingDocTypeID.ToString(), "Edit", ctc.Token);
        HasPermissionTdsAccountMappingServiceDelete = await Irole.HasClaim(TdsAccountMappingDocTypeID.ToString(), "Delete", ctc.Token);

        GetAll();
        await EnsureMinimumLoadTime();
        _isLoading = false;
    }

    private async Task EnsureMinimumLoadTime()
    {
        var elapsed = (DateTime.Now - _loadStartTime).TotalMilliseconds;
        if (elapsed < 100)
        {
            await Task.Delay(100 - (int)elapsed);
        }
    }

    // Method to handle changes in the selected item
    protected void SelectItem(NatureOfPaymentModel item)
    {
        if (item != null)
        {
            SelectedNP = item;
            ShowMappedAccounts(SelectedNP);
            TdsrateToggled(false);
            ThresholdLimitToggled(false);
        }
    }

    // Method to fetch all nature of payment items
    private void GetAll()
    {
        listOfItems = ITdsRateservice.SelectTdsNP().ToList(); // Load nature of payment items from the service
        if (listOfItems.Any())
        {
            SelectItem(listOfItems.First());
        }
    }

    // Method to show mapped accounts for a selected nature of payment
    private void ShowMappedAccounts(NatureOfPaymentModel ig)
    {
        collection = Iservice.SelectByNP(ig.TdsNPID.Value).ToList(); // Load mapped accounts based on the selected nature of payment
    }

    // Method to toggle the visibility of TDS rates
    private void TdsrateToggled(bool Toggle)
    {
        TdsRateToggle = Toggle;
        if (SelectedNP?.TdsNPID == null)
        {
            collectionTdsRate = new List<TdsRateModel>();
            return;
        }

        DateTime? dtm = Toggle ? null : DateTime.Today;
        collectionTdsRate = ITdsRateservice.Select(null, SelectedNP?.TdsNPID, dtm).ToList(); // Load TDS rates
    }

    // Method to toggle the visibility of threshold limits
    private void ThresholdLimitToggled(bool Toggle)
    {
        ThresholdLimitToggle = Toggle;
        if (SelectedNP?.TdsNPID == null)
        {
            collectionThresholdLimit = new List<TdsThresholdLimitModel>();
            return;
        }

        DateTime? dtm = Toggle ? null : DateTime.Today;
        collectionThresholdLimit = IThresholdLimitservice.SelectByNP(SelectedNP.TdsNPID ?? 0, dtm).ToList(); // Load threshold limits
    }

    // Method to delete a TDS account mapping
    private async Task Delete(TdsAccountMappingModel model)
    {
        if (HasPermissionTdsAccountMappingServiceDelete)
        {
            bool? result = await DialogService.ShowMessageBoxAsync(
                "Warning !",
                "Are you sure, you want to delete - " + model.AccountName + " ?");
            if (result == true)
            {
                var authprov = await auth.GetAuthenticationStateAsync();
                var user = authprov.User;
                var value = Iservice.Delete(model.TdsAccountMappedID, user.Identity.Name); // Delete the account mapping
                if (value != -1)
                {
                    snackbar.Add("Deleted Successfully", Severity.Success);
                    NatureOfPaymentModel igm = new NatureOfPaymentModel();
                    igm.TdsNPID = model.TdsNPID;
                    ShowMappedAccounts(igm);
                }
            }
        }
        else
        {
            bool? result = await DialogService.ShowMessageBoxAsync(
                "Permission denied!",
                "You don't have any permission to Delete TdsAccountMapping.");
        }
    }

    // Method to delete a TDS rate
    private async Task DeleteTdsRate(TdsRateModel model)
    {
        if (HasPermissionTdsRateServiceDelete)
        {
            bool? result = await DialogService.ShowMessageBoxAsync(
                "Warning !",
                "Are you sure, you want to delete - " + model.AssesseeType.AssesseeTypeName + " (" + model.PeriodFrom + " - " + model.PeriodTo + ") ?");
            if (result == true)
            {
                var authprov = await auth.GetAuthenticationStateAsync();
                var user = authprov.User;
                var value = ITdsRateservice.Delete(model.TdsRateID, user.Identity.Name); // Delete the TDS rate
                if (value != -1)
                {
                    snackbar.Add("Deleted Successfully", Severity.Success);
                    TdsrateToggled(TdsRateToggle);
                }
            }
        }
        else
        {
            bool? result = await DialogService.ShowMessageBoxAsync(
                "Permission denied!",
                "You don't have any permission to Delete TdsRate.");
        }
    }

    // Method to delete a TDS threshold limit
    private async Task DeleteThresholdLimit(TdsThresholdLimitModel model)
    {
        if (HasPermissionTdsThresholdLimitServiceDelete)
        {
            bool? result = await DialogService.ShowMessageBoxAsync(
                "Warning !",
                "Are you sure, you want to delete - " + model.NatureOfPayment.NatureOfPayment + " (" + model.PeriodFrom + " - " + model.PeriodTo + ") ?");
            if (result == true)
            {
                var authprov = await auth.GetAuthenticationStateAsync();
                var user = authprov.User;
                var value = IThresholdLimitservice.Delete(model.TdsTLID, user.Identity.Name); // Delete the threshold limit
                if (value != -1)
                {
                    snackbar.Add("Deleted Successfully", Severity.Success);
                    ThresholdLimitToggled(ThresholdLimitToggle);
                }
            }
        }
        else
        {
            bool? result = await DialogService.ShowMessageBoxAsync(
                "Permission denied!",
                "You don't have any permission to Delete TdsThresholdLimit.");
        }
    }

    // Method to search for TDS account mappings based on a search string
    private bool search(TdsAccountMappingModel tds)
    {
        if (tds.NatureOfPayment != null && tds.AccountName.Contains(searchTds, StringComparison.OrdinalIgnoreCase))
        {
            return true;
        }
        else if (tds.NatureOfPayment == null) return true;
        return false;
    }

    // Method to add or edit an account mapping
    private async Task AddEditAccountMapping(TdsAccountMappingModel model)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        _busy = true;

        if (HasPermissionTdsAccountMappingServiceEdit)
        {
            var authprov = await auth.GetAuthenticationStateAsync();
            var user = authprov.User;
            model.NatureOfPayment = SelectedNP.NatureOfPayment;
            model.TdsNPID = SelectedNP.TdsNPID;
            DialogParameters parms = new DialogParameters();
            parms.Add("model", model.Clone());
            var dialog = await DialogService.ShowAsync<TdsAccountMappingDialig>(model.TdsAccountMappedID == null ? "ADD" : "EDIT", parms);
            var result = await dialog.Result;
            if (!result.Canceled)
            {
                TdsAccountMappingModel UpatedModel = (TdsAccountMappingModel)result.Data;
                UpatedModel.UserInfo.UserID = user.Identity.Name;
                try
                {
                    // Check if the account already exists
                    TdsAccountMappingModel checkexist = Iservice.CheckExist(UpatedModel.CoaID);
                    @if (checkexist.NatureOfPayment != null)
                    {
                        bool? exist = await DialogService.ShowMessageBoxAsync(
                            "Warning !",
                            "Account Name : " + checkexist.AccountName + " already exist under NatureOfPayment : " + checkexist.NatureOfPayment + " ?");
                    }
                    else
                    {
                        Iservice.Update(UpatedModel); // Update the account mapping
                        snackbar.Add("Saved Successfully", Severity.Success);
                        NatureOfPaymentModel igm = new NatureOfPaymentModel();
                        igm.TdsNPID = UpatedModel.TdsNPID;
                        ShowMappedAccounts(igm);
                    }
                }
                catch (Exception ex)
                {
                    snackbar.Add(ex.Message, Severity.Warning);
                }
            }
        }
        else
        {
            bool? result = await DialogService.ShowMessageBoxAsync(
                "Permission denied!",
                "You don't have any permission to Edit TdsAccountMapping.");
        }
        await Task.Delay(200);
        _busy = false;
    }

    // Method to open the dialog for adding or editing a TDS rate
    private async Task OpenDialogTdsRate(TdsRateModel tds)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        _busy = true;

        if (HasPermissionTdsRateServiceEdit)
        {
            var authprov = await auth.GetAuthenticationStateAsync();
            var user = authprov.User;
            tds.TdsNP = SelectedNP;
            DialogParameters parms = new DialogParameters();
            parms.Add("model", tds.Clone());
            var dialog = await DialogService.ShowAsync<TdsRateDialog>(tds.TdsRateID == null ? "ADD" : "EDIT", parms);
            var result = await dialog.Result;
            if (!result.Canceled)
            {
                TdsRateModel UpatedModel = (TdsRateModel)result.Data;
                UpatedModel.UserInfo.UserID = user.Identity.Name;
                try
                {
                    ITdsRateservice.Update(UpatedModel); // Update the TDS rate
                    snackbar.Add("Saved Successfully", Severity.Success);
                    NatureOfPaymentModel igm = new NatureOfPaymentModel();
                    igm.TdsNPID = UpatedModel.TdsNP.TdsNPID;
                    TdsrateToggled(TdsRateToggle);
                }
                catch (Exception ex)
                {
                    snackbar.Add(ex.Message, Severity.Warning);
                }
            }
        }
        else
        {
            bool? result = await DialogService.ShowMessageBoxAsync(
                "Permission denied!",
                "You don't have any permission to Edit TdsRate.");
        }
        await Task.Delay(200);
        _busy = false;
    }

    // Method to open the dialog for adding or editing a TDS threshold limit
    private async Task OpenDialogThresholdLimit(TdsThresholdLimitModel tds)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        _busy = true;

        if (HasPermissionTdsThresholdLimitServiceEdit)
        {
            var authprov = await auth.GetAuthenticationStateAsync();
            var user = authprov.User;
            tds.NatureOfPayment = SelectedNP;
            DialogParameters parms = new DialogParameters();
            parms.Add("model", tds.Clone());
            var dialog = await DialogService.ShowAsync<TdsThresholdLimitDialog>(tds.TdsTLID == null ? "ADD" : "EDIT", parms);
            var result = await dialog.Result;
            if (!result.Canceled)
            {
                TdsThresholdLimitModel UpatedModel = (TdsThresholdLimitModel)result.Data;
                UpatedModel.UserInfo.UserID = user.Identity.Name;
                try
                {
                    IThresholdLimitservice.Update(UpatedModel); // Update the TDS threshold limit
                    snackbar.Add("Saved Successfully", Severity.Success);
                    NatureOfPaymentModel igm = new NatureOfPaymentModel();
                    igm.TdsNPID = UpatedModel.TdsTLID;
                    ThresholdLimitToggled(ThresholdLimitToggle);
                }
                catch (Exception ex)
                {
                    snackbar.Add(ex.Message, Severity.Warning);
                }
            }
        }
        else
        {
            bool? result = await DialogService.ShowMessageBoxAsync(
                "Permission denied!",
                "You don't have any permission to Edit TdsThresholdLimit.");
        }
        await Task.Delay(200);
        _busy = false;
    }

    void OnAppearing(MenuAppearingEventArgs e)
    {

    }
}

