@page "/TDSSetting"
@inject ITdsRateService tdsRate
@inject ITdsAccountMappingService Iservice
@inject ITdsRateService ITdsRateservice
@inject ITdsThresholdLimitService IThresholdLimitservice
@inject IChartOfAccountService account
@inject MudBlazor.ISnackbar snackbar
@inject AuthenticationStateProvider auth
@attribute [Authorize]
@inject IDialogService DialogService

<MudGrid>
    <MudItem xs="4" lg="4">
        <MudPaper Width="100%" Class="p-2">
            <MudList Clickable="true" SelectedItem="SelectedItem" SelectedItemChanged="SelectedItemChanged">

                @if (listOfItems?.Any() == true)
                {
                    @foreach (var item in listOfItems)
                    {
                        @*<ContextMenuTrigger MenuId="myMenu" Data="@item">*@

                        <MudListItem Value="item">
                            <MudText Typo=Typo.subtitle1> @(item?.NatureOfPayment?.ToString()) </MudText>
                            @* <MudText Typo="Typo.overline">Since : @item.UserInfo.TimeStampField?.ToString("dd/MM/yy")</MudText>
                    <MudText Typo="Typo.overline">Since : @item.InventoryGroupName.ToString()</MudText>*@

                        </MudListItem>
                        @*</ContextMenuTrigger>*@
                    }
                }
            </MudList>
        </MudPaper>
    </MudItem>



    <MudItem xs="8" lg="8">

        @if (SelectedNP != null)
        {
            <MudItem xs="12" lg="12">

                <MudTable Items="@collection" Dense="true" Hover="true" Striped="true" Elevation="10">


                    <ToolBarContent>
                        <MudText Typo="Typo.h6">@(SelectedNP.NatureOfPayment) Chart of Account Mapping</MudText>
                        <MudIconButton Icon="@Icons.Material.Filled.Add" Title="Add" @onclick="@(()=> AddEditAccountMapping(new TdsAccountMappingModel()))" Color="Color.Dark" Size="Size.Small"></MudIconButton>

                        <MudSpacer></MudSpacer>

                    </ToolBarContent>
                    <HeaderContent>
                        <MudTh><MudTableSortLabel SortBy="new Func<TdsAccountMappingModel, object>(x=> x.AccountName)" InitialDirection="SortDirection.Ascending">Account Name</MudTableSortLabel></MudTh>


                        <MudTh>Actions</MudTh>
                    </HeaderContent>
                    <RowTemplate>

                        <MudTd DataLabel="TdsAccountMapping">@context.AccountName</MudTd>


                        <MudTd DataLabel="">
                            <MudFab @onclick="@(()=> AddEditAccountMapping(context))" Color="Color.Primary" title="Edit" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" IconSize="Size.Small" />
                            <MudFab @onclick="@(()=> Delete(context))" Color="Color.Error" title="Delete" Icon="@Icons.Material.Filled.Delete" Size="Size.Small" IconSize="Size.Small" />
                        </MudTd>
                    </RowTemplate>
                    <PagerContent>
                        <MudTablePager PageSizeOptions="new int[] { 5, 10, 20, 50, 100 }" />
                    </PagerContent>
                </MudTable>
            </MudItem>
            <br />
            <MudItem xs="12" lg="12">
                <MudTable Items="@collectionTdsRate" Dense="true" Hover="true" Striped="true" Elevation="10">

                    <ToolBarContent>
                        <MudText Typo="Typo.h6">@(SelectedNP.NatureOfPayment) Tds Rates</MudText>
                        <MudIconButton Icon="@Icons.Material.Filled.Add" Title="Add" @onclick="@(()=> OpenDialogTdsRate(new TdsRateModel()))" Color="Color.Dark" Size="Size.Small"></MudIconButton>

                        <MudSpacer></MudSpacer>
                        <MudCheckBox Label="Show All" T="bool" CheckedChanged="TdsrateToggled" Checked="@TdsRateToggle" Size="Size.Medium" Color="Color.Primary" Class="tablefont margin0"></MudCheckBox>
                    </ToolBarContent>
                    <HeaderContent>
                        <MudTh><MudTableSortLabel SortBy="new Func<TdsRateModel, object>(x=> x.TdsNP.NatureOfPayment)" InitialDirection="SortDirection.Ascending">Nature of Payment</MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<TdsRateModel, object>(x=> x.AssesseeType.AssesseeTypeName)" InitialDirection="SortDirection.Ascending">Assessee Type</MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<TdsRateModel, object>(x=> x.PeriodFrom)" InitialDirection="SortDirection.Ascending">PeriodFrom</MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<TdsRateModel, object>(x=> x.PeriodTo)" InitialDirection="SortDirection.Ascending">PeriodTo</MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<TdsRateModel, object>(x=> x.TaxRate)" InitialDirection="SortDirection.Ascending">TaxRate</MudTableSortLabel></MudTh>

                        <MudTh>Actions</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="NatureOfPayment">@context.TdsNP.NatureOfPayment</MudTd>
                        <MudTd DataLabel="AssesseeTypeName">@context.AssesseeType.AssesseeTypeName</MudTd>
                        <MudTd DataLabel="PeriodFrom">@context.PeriodFrom?.ToShortDateString()</MudTd>
                        <MudTd DataLabel="PeriodTo">@context.PeriodTo?.ToShortDateString()</MudTd>
                        <MudTd DataLabel="TaxRate">@context.TaxRate</MudTd>
                        <MudTd DataLabel="">
                            <MudFab @onclick="@(()=> OpenDialogTdsRate(context))" Color="Color.Primary" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" IconSize="Size.Small" />
                            <MudFab @onclick="@(()=> DeleteTdsRate(context))" Color="Color.Primary" Icon="@Icons.Material.Filled.Delete" Size="Size.Small" IconSize="Size.Small" />
                        </MudTd>
                    </RowTemplate>
                    <PagerContent>
                        <MudTablePager PageSizeOptions="new int[] { 5, 10, 20, 50, 100 }" />
                    </PagerContent>
                </MudTable>
            </MudItem>
            <br />
            <MudItem xs="12" lg="12">
                <MudTable Items="@collectionThresholdLimit" Dense="true" Hover="true" Striped="true" Elevation="10">

                    <ToolBarContent>
                        <MudText Typo="Typo.h6">@(SelectedNP.NatureOfPayment)  Tds Threshold Limits</MudText>
                        <MudIconButton Icon="@Icons.Material.Filled.Add" Title="Add" @onclick="@(()=> OpenDialogThresholdLimit(new TdsThresholdLimitModel()))" Color="Color.Dark" Size="Size.Small"></MudIconButton>

                        <MudSpacer></MudSpacer>
                        <MudCheckBox Label="Show All" T="bool" CheckedChanged="ThresholdLimitToggled" Checked="@ThresholdLimitToggle" Size="Size.Medium" Color="Color.Primary" Class="tablefont margin0"></MudCheckBox>
                    </ToolBarContent>

                    <HeaderContent>
                        <MudTh><MudTableSortLabel SortBy="new Func<TdsThresholdLimitModel, object>(x=> x.NatureOfPayment.NatureOfPayment)" InitialDirection="SortDirection.Ascending">Nature of Payment</MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<TdsThresholdLimitModel, object>(x=> x.PeriodFrom)" InitialDirection="SortDirection.Ascending">PeriodFrom</MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<TdsThresholdLimitModel, object>(x=> x.PeriodTo)" InitialDirection="SortDirection.Ascending">PeriodTo</MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<TdsThresholdLimitModel, object>(x=> x.ThresholdLimitSingle)" InitialDirection="SortDirection.Ascending">Single</MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<TdsThresholdLimitModel, object>(x=> x.ThresholdLimitPeriod)" InitialDirection="SortDirection.Ascending">Period</MudTableSortLabel></MudTh>

                        <MudTh>Actions</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="NatureOfPayment">@context.NatureOfPayment.NatureOfPayment</MudTd>
                        <MudTd DataLabel="PeriodFrom">@context.PeriodFrom?.ToShortDateString()</MudTd>
                        <MudTd DataLabel="PeriodTo">@context.PeriodTo?.ToShortDateString()</MudTd>
                        <MudTd DataLabel="ThresholdLimitSingle">@context.ThresholdLimitSingle</MudTd>
                        <MudTd DataLabel="ThresholdLimitPeriod">@context.ThresholdLimitPeriod</MudTd>

                        <MudTd DataLabel="">
                            <MudFab @onclick="@(()=> OpenDialogThresholdLimit(context))" Color="Color.Primary" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" IconSize="Size.Small" />
                            <MudFab @onclick="@(()=> DeleteThresholdLimit(context))" Color="Color.Primary" Icon="@Icons.Material.Filled.Delete" Size="Size.Small" IconSize="Size.Small" />
                        </MudTd>
                    </RowTemplate>
                    <PagerContent>
                        <MudTablePager PageSizeOptions="new int[] { 5, 10, 20, 50, 100 }" />
                    </PagerContent>
                </MudTable>
            </MudItem>
        }

    </MudItem>

</MudGrid>
