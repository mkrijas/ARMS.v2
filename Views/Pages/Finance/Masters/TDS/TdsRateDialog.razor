@inject ITdsRateService Iservice
@inject MudBlazor.ISnackbar snackbar
@inject AuthenticationStateProvider auth
@attribute [Authorize]
@inject IDialogService DialogService

<MudDialog Class="admin-dialog-glass">
    <TitleContent>
        <div class="admin-header-tiered px-8 pt-8 pb-4 text-center">
            <div class="admin-header-icon-badge mb-3 mx-auto">
                <MudIcon Icon="@Icons.Material.Filled.AccountBalance" Color="Color.Primary" Style="font-size: 3rem; color: #FF9F43 !important;" />
            </div>
            <MudText Typo="Typo.h5" Style="font-weight: 800; color: #141A46; letter-spacing: -0.5px;">TDS Rate Configuration</MudText>
            <MudText Typo="Typo.body2" Style="color: #667085; font-weight: 500;" Class="mt-1">Define and manage withholding tax rates based on nature of payment and assessee types.</MudText>
            <div class="header-accent-divider mx-auto mt-4" style="background: linear-gradient(90deg, transparent, #FF9F43, transparent); width: 100%; height: 1px;"></div>
        </div>
    </TitleContent>
    <DialogContent>
        <div class="dialog-content-wrapper pa-4">
            <EditForm id="formtdsRate" Model="@model" OnValidSubmit="OnValidSubmit">
                <ObjectGraphDataAnnotationsValidator />
                
                <div class="admin-glass-card pa-6 mb-6">
                    <span class="admin-section-label">Scope & Classification</span>
                    <MudGrid Spacing="3">
                        <MudItem xs="12">
                            <MudSelect For="@(() => model.TdsNP)" Label="Nature of Payment" @bind-Value="model.TdsNP" T="NatureOfPaymentModel" ToStringFunc="@((p) => p?.NatureOfPayment)" Variant="Variant.Outlined" Margin="Margin.Dense" Disabled Class="admin-input-group">
                                @foreach (var ditem in naturepayment)
                                {
                                    <MudSelectItem Value="@ditem">@ditem.NatureOfPayment</MudSelectItem>
                                }
                            </MudSelect>
                        </MudItem>
                        <MudItem xs="12">
                            <MudSelect For="@(() => model.AssesseeType)" Label="Assessee Category" @bind-Value="model.AssesseeType" T="AssesseeTypeModel" ToStringFunc="@((p) => p?.AssesseeTypeName)" Variant="Variant.Outlined" Margin="Margin.Dense" Class="admin-input-group">
                                @foreach (var ditem in asseesse)
                                {
                                    <MudSelectItem Value="@ditem">@ditem.AssesseeTypeName</MudSelectItem>
                                }
                            </MudSelect>
                        </MudItem>
                    </MudGrid>
                </div>

                <div class="admin-glass-card pa-6 mb-6">
                    <span class="admin-section-label">Validity & Rate Details</span>
                    <MudGrid Spacing="3">
                        <MudItem xs="12" md="6">
                            <MudDatePicker Label="Effective From" Variant="Variant.Outlined" Margin="Margin.Dense" DisableToolbar="true" Editable="true" @bind-Date="model.PeriodFrom" DateFormat="dd/MM/yyyy" Class="admin-input-group" />
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <MudDatePicker Label="Effective To" Variant="Variant.Outlined" Margin="Margin.Dense" DisableToolbar="true" Editable="true" @bind-Date="model.PeriodTo" DateFormat="dd/MM/yyyy" Class="admin-input-group" />
                        </MudItem>
                        <MudItem xs="12">
                            <MudNumericField HideSpinButtons @bind-Value="model.TaxRate" Label="Applicable Tax Rate" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.TaxRate)" Adornment="Adornment.End" AdornmentText="%" Class="admin-input-group" />
                        </MudItem>
                    </MudGrid>
                </div>
            </EditForm>
        </div>
    </DialogContent>
    <DialogActions>
        <div class="px-8 pb-8 d-flex gap-4 w-100">
            <MudButton OnClick="Cancel" Variant="Variant.Outlined" FullWidth="true" Style="border-radius: 12px; height: 50px; font-weight: 700; color: #141A46; border: 2px solid #E2E8F0;">CANCEL</MudButton>
            <MudButton Disabled="@_busy" form="formtdsRate" Variant="Variant.Filled" Color="Color.Primary" FullWidth="true" ButtonType="ButtonType.Submit" Style="background: #FF9F43; border-radius: 12px; height: 50px; font-weight: 700;">SUBMIT RATE</MudButton>
        </div>
    </DialogActions>
</MudDialog>

@code {

    [Parameter]
    public TdsRateModel model { get; set; }
    private List<TdsRateModel> collection = new List<TdsRateModel>();
    private List<NatureOfPaymentModel> naturepayment = new();
    private List<AssesseeTypeModel> asseesse = new();
    private TdsRateModel tds = new();
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; }

    private bool _busy;

    // Lifecycle method called when the component is initialized
    protected override void OnInitialized()
    {
        // Load nature of payment and assessee types from the service
        naturepayment = Iservice.SelectTdsNP().ToList();
        asseesse = Iservice.SelectAssesseeTypes().ToList();
    }

    // Method to handle form submission when the form is valid
    private async void OnValidSubmit(EditContext context)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is being submitted!", Severity.Warning);
            return;
        }
        _busy = true;

        DateRange dr = new DateRange(model.PeriodFrom, model.PeriodTo);

        // Fetch existing TDS rates that overlap with the current one
        List<TdsRateModel> tdsList = Iservice.Select(model.AssesseeType.AssesseeTypeID, model.TdsNP.TdsNPID, null).Where(x => x.TdsRateID != model.TdsRateID).ToList();
        List<DateRange> drList = new List<DateRange>();
        tdsList.ForEach(item => drList.Add(new DateRange(item.PeriodFrom, item.PeriodTo)));
        if (CommonMethods.CheckPeriodOverlap(dr, drList))
        {
            snackbar.Add("Periods cannot be overlapped", Severity.Success);
        }
        else
        {
            MudDialog.Close(model);
        }
        await Task.Delay(200);
        _busy = false;
    }

    private void Cancel()
    {
        MudDialog.Cancel();
    }
}
