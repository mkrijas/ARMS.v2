@page "/tdsRate"
@inject ITdsRateService Iservice
@inject MudBlazor.ISnackbar snackbar
@inject AuthenticationStateProvider auth
@attribute [Authorize]
@inject IDialogService DialogService

<MudGrid Spacing="4">
    <MudItem xs="12">
        <MudTable Items="@collection" Dense="true" Hover="true" Striped="true" Elevation="10" Filter="new Func<TdsRateModel, bool>(search)" @bind-place="model">
            <ToolBarContent>
                <MudText Typo="Typo.h6">TdsRateView</MudText>
                <MudIconButton Icon="@Icons.Material.Filled.Add" Title="Add" @onclick="@(()=> OpenDialog(model))" Color="Color.Dark" Size="Size.Small"></MudIconButton>
                <MudSpacer></MudSpacer>
                <MudTextField @bind-Value="searchTds" Placeholder="Search TDS... " Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0"></MudTextField>
            </ToolBarContent>
            <HeaderContent>
                <MudTh><MudTableSortLabel SortBy="new Func<TdsRateModel, object>(x=> x.TdsNP.NatureOfPayment)" InitialDirection="SortDirection.Ascending">Nature of Payment</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<TdsRateModel, object>(x=> x.AssesseeType.AssesseeTypeName)" InitialDirection="SortDirection.Ascending">Assessee Type</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<TdsRateModel, object>(x=> x.PeriodFrom)" InitialDirection="SortDirection.Ascending">Period From</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<TdsRateModel, object>(x=> x.PeriodTo)" InitialDirection="SortDirection.Ascending">Period To</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<TdsRateModel, object>(x=> x.TaxRate)" InitialDirection="SortDirection.Ascending">Tax Rate</MudTableSortLabel></MudTh>
                <MudTh>Actions</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="NatureOfPayment">@context.TdsNP.NatureOfPayment</MudTd>
                <MudTd DataLabel="AssesseeTypeName">@context.AssesseeType.AssesseeTypeName</MudTd>
                <MudTd DataLabel="PeriodFrom">@(context.PeriodFrom?.ToShortDateString())</MudTd>
                    <MudTd DataLabel="PeriodTo">@(context.PeriodTo?.ToShortDateString())</MudTd>
                    <MudTd DataLabel="TaxRate">@context.TaxRate</MudTd>
                    <MudTd DataLabel="">
                        <MudFab @onclick="@(()=> OpenDialog(context))" Color="Color.Primary" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" IconSize="Size.Small" />
                        <MudFab @onclick="@(()=> Delete(context))" Color="Color.Primary" Icon="@Icons.Material.Filled.Delete" Size="Size.Small" IconSize="Size.Small" />
                    </MudTd>
                </RowTemplate>
                <PagerContent>
                    <MudTablePager PageSizeOptions="new int[] { 5, 10, 20, 50, 100 }" />
                </PagerContent>
            </MudTable>
        </MudItem>
    </MudGrid>

    @code {

    private TdsRateModel model = new TdsRateModel();
    private List<TdsRateModel> collection = new List<TdsRateModel>();

    private string searchTds = "";

    protected override void OnInitialized()
    {
        model = new();
        GetAll();
    }

    private void GetAll()
    {
        collection = new List<TdsRateModel>();
        foreach (var item in Iservice.SelectByIDT(0))
        {
            collection.Add(item);
        }
    }

    private async Task OpenDialog(TdsRateModel tds)
    {
        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;
        DialogParameters parms = new DialogParameters();
        parms.Add("model", tds);
        var dialog = DialogService.Show<TdsRateDialog>(tds.TdsRateID == null ? "ADD" : "EDIT", parms);
        var result = await dialog.Result;
        if (!result.Canceled)
        {
            TdsRateModel UpatedModel = (TdsRateModel)result.Data;
            model.UserInfo.UserID = user.Identity.Name;
            try
            {
                Iservice.Update(UpatedModel);
                snackbar.Add("Saved Successfully", Severity.Success);
                GetAll();
            }
            catch (Exception ex)
            {
                snackbar.Add(ex.Message, Severity.Warning);
            }
        }
    }

    private async Task Delete(TdsRateModel model)
    {
        bool? result = await DialogService.ShowMessageBox(
            "Warning !",
            "Are you sure, you want to delete - " + model.AssesseeType.AssesseeTypeName + " (" + model.PeriodFrom + " - " + model.PeriodTo + ") ?");
        if (result == true)
        {
            var authprov = await auth.GetAuthenticationStateAsync();
            var user = authprov.User;
            Iservice.Delete(model.TdsRateID, user.Identity.Name);
            snackbar.Add("Deleted Successfully", Severity.Success);
        }
        GetAll();
    }

    private bool search(TdsRateModel tds)
    {
        if (tds.TdsNP.NatureOfPayment != null && tds.TdsNP.NatureOfPayment.Contains(searchTds, StringComparison.OrdinalIgnoreCase))
        {
            return true;
        }
        else if (tds.TaxRate == null) return true;
        return false;
    }
}