@page "/tdsRate"
@inject ITdsRateService Iservice
@inject MudBlazor.ISnackbar snackbar
@inject AuthenticationStateProvider auth
@attribute [Authorize]
@using System.Threading;
@inject IRoleService<RoleModel> Irole
@inject IDialogService DialogService

@if (_isLoading)
{
    <div @key="@("loader")" style="display: flex; justify-content: center; align-items: center; min-height: 400px;">
        <LoaderComponent IsFullScreen="true" 
                        ShowLogo="false" 
                        Size="medium" 
                        LoadingText="Loading Tax Matrices" 
                        SubText="Please wait..." />
    </div>
}
else
{
    <div class="fade-in">
        <div class="admin-header-tiered mb-6">
            <div class="d-flex align-center justify-space-between">
                <div>
                    <MudText Typo="Typo.h4" Class="admin-title">TDS Rate Master Configuration</MudText>
                    <MudText Typo="Typo.body2" Class="admin-subtitle">Define and maintain Tax Deducted at Source (TDS) rates. configure thresholds based on nature of payment and assessee categories to ensure accurate tax compliance and reporting.</MudText>
                </div>
                <MudButton StartIcon="@Icons.Material.Filled.PostAdd" Variant="Variant.Filled" Color="Color.Primary" Class="admin-register-btn" OnClick="@(()=> OpenDialog(model))" Disabled="@_busy">REGISTER NEW RATE</MudButton>
            </div>
        </div>

        <div class="admin-glass-card mb-6 pa-4">
            <div class="d-flex align-center gap-4">
                <div style="flex-grow: 1;">
                    <MudTextField @bind-Value="searchTds" Placeholder="Search by nature of payment or assessee type..." Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" Variant="Variant.Outlined" Margin="Margin.Dense" Class="admin-input-group" Clearable="true" />
                </div>
            </div>
        </div>

        <div class="admin-glass-card pa-0 overflow-hidden">
            <MudTable Items="@collection" Elevation="0" Class="modern-admin-table" Hover="true" Filter="new Func<TdsRateModel, bool>(search)">
                <HeaderContent>
                    <MudTh><MudTableSortLabel SortBy="new Func<TdsRateModel, object>(x=> x.TdsNP.NatureOfPayment)" InitialDirection="SortDirection.Ascending"><span class="admin-header-text">PAYMENT NATURE</span></MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<TdsRateModel, object>(x=> x.AssesseeType.AssesseeTypeName)"><span class="admin-header-text">ASSESSEE CATEGORY</span></MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<TdsRateModel, object>(x=> x.PeriodFrom)"><span class="admin-header-text">VALIDITY PERIOD</span></MudTableSortLabel></MudTh>
                    <MudTh Style="text-align: right;"><MudTableSortLabel SortBy="new Func<TdsRateModel, object>(x=> x.TaxRate)"><span class="admin-header-text">TAX RATE</span></MudTableSortLabel></MudTh>
                    <MudTh Style="text-align: right;"><span class="admin-header-text">ACTIONS</span></MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Nature">
                        <div class="d-flex align-center gap-3">
                            <div class="admin-icon-square-vibrant small accent-indigo">
                                <MudIcon Icon="@Icons.Material.Filled.AccountTree" Size="Size.Small" />
                            </div>
                            <span class="fw-700 admin-td-primary">@context.TdsNP.NatureOfPayment</span>
                        </div>
                    </MudTd>
                    <MudTd DataLabel="Assessee">
                        <MudChip T="string" Color="Color.Default" Variant="Variant.Text" Size="Size.Small" Class="fw-700 px-3 border-solid border-1">@context.AssesseeType.AssesseeTypeName</MudChip>
                    </MudTd>
                    <MudTd DataLabel="Validity">
                        <div class="d-flex align-center gap-2">
                            <span class="fw-600">@context.PeriodFrom?.ToString("dd MMM yyyy")</span>
                            <MudIcon Icon="@Icons.Material.Filled.ArrowForward" Size="Size.Small" Class="opa-20" />
                            <span class="fw-600">@context.PeriodTo?.ToString("dd MMM yyyy")</span>
                        </div>
                    </MudTd>
                    <MudTd DataLabel="Rate" Style="text-align: right;">
                        <span class="fw-700 text-vibrant" style="font-size: 1.1rem;">@context.TaxRate%</span>
                    </MudTd>
                    <MudTd DataLabel="Actions" Style="text-align: right;">
                        <div class="d-flex justify-end gap-1">
                            <MudTooltip Text="Edit Parameters">
                                <MudIconButton OnClick="@(()=> OpenDialog(context))" Color="Color.Primary" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Variant="Variant.Text" />
                            </MudTooltip>
                            <MudTooltip Text="Purge Configuration">
                                <MudIconButton OnClick="@(()=> Delete(context))" Color="Color.Error" Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Variant="Variant.Text" />
                            </MudTooltip>
                        </div>
                    </MudTd>
                </RowTemplate>
                <PagerContent>
                    <div class="pa-4">
                        <MudTablePager PageSizeOptions="new int[] { 10, 20, 50, 100 }" />
                    </div>
                </PagerContent>
            </MudTable>
        </div>
    </div>
}
}

@code {

    private bool _isLoading = true;
    private DateTime _loadStartTime;

    private TdsRateModel model = new TdsRateModel();
    private List<TdsRateModel> collection = new List<TdsRateModel>();
    private string searchTds = "";
    private bool _busy;

    public bool HasPermissionTdsRateServiceEdit { get; set; } = false;
    public bool HasPermissionTdsRateServiceDelete { get; set; } = false;
    public int TdsRateDocTypeID = 99;

    // Lifecycle method called when the component is initialized
    protected override async Task OnInitializedAsync()
    {
        _loadStartTime = DateTime.Now;
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionTdsRateServiceEdit = await Irole.HasClaim(TdsRateDocTypeID.ToString(), "Edit", ctc.Token);
        HasPermissionTdsRateServiceDelete = await Irole.HasClaim(TdsRateDocTypeID.ToString(), "Delete", ctc.Token);

        model = new();
        GetAll();
        await EnsureMinimumLoadTime();
        _isLoading = false;
    }

    private async Task EnsureMinimumLoadTime()
    {
        var elapsed = (DateTime.Now - _loadStartTime).TotalMilliseconds;
        if (elapsed < 100)
        {
            await Task.Delay(100 - (int)elapsed);
        }
    }

    // Method to fetch all TDS rates
    private void GetAll()
    {
        collection = new List<TdsRateModel>();
        foreach (var item in Iservice.SelectByIDT(0)) // Fetch TDS rates from the service
        {
            collection.Add(item);
        }
    }

    // Method to open the dialog for adding or editing a TDS rate
    private async Task OpenDialog(TdsRateModel tds)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        _busy = true;

        if (HasPermissionTdsRateServiceEdit)
        {
            var authprov = await auth.GetAuthenticationStateAsync();
            var user = authprov.User;
            DialogParameters parms = new DialogParameters();
            parms.Add("model", tds.Clone());
            var dialog = await DialogService.ShowAsync<TdsRateDialog>(tds.TdsRateID == null ? "ADD" : "EDIT", parms);
            var result = await dialog.Result;
            if (!result.Canceled)
            {
                TdsRateModel UpatedModel = (TdsRateModel)result.Data;
                UpatedModel.UserInfo.UserID = user.Identity.Name;
                try
                {
                    Iservice.Update(UpatedModel); // Update the TDS rateS
                    snackbar.Add("Saved Successfully", Severity.Success);
                    GetAll();
                }
                catch (Exception ex)
                {
                    snackbar.Add(ex.Message, Severity.Warning);
                }
            }
        }
        else
        {
            bool? result = await DialogService.ShowMessageBoxAsync(
                "Permission denied!",
                "You don't have any permission to Edit TdsRate.");
        }
        await Task.Delay(200);
        _busy = false;
    }

    // Method to delete a TDS rate
    private async Task Delete(TdsRateModel model)
    {
        if (HasPermissionTdsRateServiceDelete)
        {
            bool? result = await DialogService.ShowMessageBoxAsync(
                "Warning !",
                "Are you sure, you want to delete - " + model.AssesseeType.AssesseeTypeName + " (" + model.PeriodFrom + " - " + model.PeriodTo + ") ?");
            if (result == true)
            {
                var authprov = await auth.GetAuthenticationStateAsync();
                var user = authprov.User;
                Iservice.Delete(model.TdsRateID, user.Identity.Name); // Delete the TDS rate
                snackbar.Add("Deleted Successfully", Severity.Success);
            }
            GetAll();
        }
        else
        {
            bool? result = await DialogService.ShowMessageBoxAsync(
                "Permission denied!",
                "You don't have any permission to Delete TdsRate.");
        }
    }

    // Method to search for TDS rates based on a search string
    private bool search(TdsRateModel tds)
    {
        if (tds.TdsNP.NatureOfPayment != null && tds.TdsNP.NatureOfPayment.Contains(searchTds, StringComparison.OrdinalIgnoreCase))
        {
            return true;
        }
        else if (tds.TaxRate == null) return true;
        return false;
    }
}

