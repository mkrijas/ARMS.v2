@inject ITdsRateService tdsRate
@inject ITdsThresholdLimitService Iservice
@inject MudBlazor.ISnackbar snackbar
@inject AuthenticationStateProvider auth
@attribute [Authorize]
@inject IDialogService DialogService

<MudDialog Class="admin-dialog-glass">
    <TitleContent>
        <div class="admin-header-tiered px-8 pt-8 pb-4 text-center">
            <div class="admin-header-icon-badge mb-3 mx-auto">
                <MudIcon Icon="@Icons.Material.Filled.Security" Color="Color.Primary" Style="font-size: 3rem; color: #FF9F43 !important;" />
            </div>
            <MudText Typo="Typo.h5" Style="font-weight: 800; color: #141A46; letter-spacing: -0.5px;">TDS Threshold Limit</MudText>
            <MudText Typo="Typo.body2" Style="color: #667085; font-weight: 500;" Class="mt-1">Configure transaction and cumulative threshold limits for automated TDS deduction triggers.</MudText>
            <div class="header-accent-divider mx-auto mt-4" style="background: linear-gradient(90deg, transparent, #FF9F43, transparent); width: 100%; height: 1px;"></div>
        </div>
    </TitleContent>
    <DialogContent>
        <div class="dialog-content-wrapper pa-4">
            <EditForm id="formtdsThreshold" Model="@model" OnValidSubmit="OnValidSubmit">
                <ObjectGraphDataAnnotationsValidator />
                
                <div class="admin-glass-card pa-6 mb-6">
                    <span class="admin-section-label">Nature of Payment</span>
                    <MudGrid Spacing="3">
                        <MudItem xs="12">
                            <MudSelect For="@(() => model.NatureOfPayment)" Label="Payment Category" @bind-Value="model.NatureOfPayment" T="NatureOfPaymentModel" ToStringFunc="@((p) => p?.NatureOfPayment)" Variant="Variant.Outlined" Margin="Margin.Dense" Disabled Class="admin-input-group">
                                @foreach (var ditem in naturepayment)
                                {
                                    <MudSelectItem Value="@ditem">@ditem.NatureOfPayment</MudSelectItem>
                                }
                            </MudSelect>
                        </MudItem>
                    </MudGrid>
                </div>

                <div class="admin-glass-card pa-6 mb-6">
                    <span class="admin-section-label">Limit Configuration & Validity</span>
                    <MudGrid Spacing="3">
                        <MudItem xs="12" md="6">
                            <MudDatePicker Label="Period From" Variant="Variant.Outlined" Margin="Margin.Dense" DisableToolbar="true" Editable="true" @bind-Date="model.PeriodFrom" DateFormat="dd/MM/yyyy" Class="admin-input-group" />
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <MudDatePicker Label="Period To" Variant="Variant.Outlined" Margin="Margin.Dense" DisableToolbar="true" Editable="true" @bind-Date="model.PeriodTo" DateFormat="dd/MM/yyyy" Class="admin-input-group" />
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <MudNumericField HideSpinButtons @bind-Value="model.ThresholdLimitSingle" Label="Single Transaction Limit" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.ThresholdLimitSingle)" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.AccountBalance" Class="admin-input-group" />
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <MudNumericField HideSpinButtons @bind-Value="model.ThresholdLimitPeriod" Label="Period Cumulative Limit" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.ThresholdLimitPeriod)" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.History" Class="admin-input-group" />
                        </MudItem>
                    </MudGrid>
                </div>
            </EditForm>
        </div>
    </DialogContent>
    <DialogActions>
        <div class="px-8 pb-8 d-flex gap-4 w-100">
            <MudButton OnClick="Cancel" Variant="Variant.Outlined" FullWidth="true" Style="border-radius: 12px; height: 50px; font-weight: 700; color: #141A46; border: 2px solid #E2E8F0;">CANCEL</MudButton>
            <MudButton Disabled="@_busy" form="formtdsThreshold" Variant="Variant.Filled" Color="Color.Primary" FullWidth="true" ButtonType="ButtonType.Submit" Style="background: #FF9F43; border-radius: 12px; height: 50px; font-weight: 700;">SAVE LIMITS</MudButton>
        </div>
    </DialogActions>
</MudDialog>

@code {

    [Parameter]
    public TdsThresholdLimitModel model { get; set; }
    private List<TdsThresholdLimitModel> collection = new List<TdsThresholdLimitModel>();
    private TdsThresholdLimitModel tds = new();
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; }
    private List<NatureOfPaymentModel> naturepayment = new();

    private bool _busy;

    // Lifecycle method called when the component is initialized
    protected override void OnInitialized()
    {
        // Load nature of payment options from the service
        naturepayment = tdsRate.SelectTdsNP().ToList();
    }

    // Method to handle form submission when the form is valid
    private async void OnValidSubmit(EditContext context)
    {
        if (model.NatureOfPayment == null)
        {
            snackbar.Add("Select Nature of payment", Severity.Success);
        }
        else
        {
            if (_busy)
            {
                snackbar.Add("Please wait while form is being submitted!", Severity.Warning);
                return;
            }
            _busy = true;

            DateRange dr = new DateRange(model.PeriodFrom, model.PeriodTo);
            // Fetch existing threshold limits based on the selected nature of payment
            List<TdsThresholdLimitModel> tdsList = Iservice.SelectByNP(model.NatureOfPayment?.TdsNPID ?? 0, null).ToList();
            List<DateRange> drList = new List<DateRange>();
            tdsList.Where(s => s.TdsTLID != model.TdsTLID).ToList().ForEach(item => drList.Add(new DateRange(item.PeriodFrom, item.PeriodTo)));
            if (CommonMethods.CheckPeriodOverlap(dr, drList))
            {
                snackbar.Add("Periods cannot be overlapped", Severity.Success);
            }
            else
            {
                MudDialog.Close(model);
            }
            await Task.Delay(200);
            _busy = false;
        }
    }

    private void Cancel()
    {
        MudDialog.Cancel();
    }
}
