@page "/tdsTdsThresholdLimit"
@inject ITdsRateService tdsRate
@inject ITdsThresholdLimitService Iservice
@inject MudBlazor.ISnackbar snackbar
@inject AuthenticationStateProvider auth
@attribute [Authorize]
@using System.Threading;
@inject IRoleService<RoleModel> Irole
@inject IDialogService DialogService

@@if (_isLoading)
{
    <div @key="@("loader")" style="display: flex; justify-content: center; align-items: center; min-height: 400px;">
        <LoaderComponent IsFullScreen="true" 
                        ShowLogo="false" 
                        Size="medium" 
                        LoadingText="Loading Limit Matrices" 
                        SubText="Please wait..." />
    </div>
}
else
{
    <div class="fade-in">
        <div class="admin-header-tiered mb-6">
            <div class="d-flex align-center justify-space-between">
                <div>
                    <MudText Typo="Typo.h4" Class="admin-title">TDS Applicability Thresholds</MudText>
                    <MudText Typo="Typo.body2" Class="admin-subtitle">Configure monetary ceilings for TDS deduction. bridge legal requirements with operational reality by defining single-transaction and aggregate-period limits across different payment categories.</MudText>
                </div>
                <MudButton StartIcon="@Icons.Material.Filled.VerticalAlignTop" Variant="Variant.Filled" Color="Color.Primary" Class="admin-register-btn" OnClick="@(()=> OpenDialog(model))" Disabled="@_busy">DEFINE NEW THRESHOLD</MudButton>
            </div>
        </div>

        <div class="admin-glass-card mb-6 pa-4">
            <div class="d-flex align-center gap-4">
                <div style="flex-grow: 1;">
                    <MudTextField @bind-Value="searchTds" Placeholder="Search by payment nature..." Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" Variant="Variant.Outlined" Margin="Margin.Dense" Class="admin-input-group" Clearable="true" />
                </div>
            </div>
        </div>

        <div class="admin-glass-card pa-0 overflow-hidden">
            <MudTable Items="@collection" Elevation="0" Class="modern-admin-table" Hover="true" Filter="new Func<TdsThresholdLimitModel, bool>(search)">
                <HeaderContent>
                    <MudTh><MudTableSortLabel SortBy="new Func<TdsThresholdLimitModel, object>(x=> x.NatureOfPayment.NatureOfPayment)" InitialDirection="SortDirection.Ascending"><span class="admin-header-text">PAYMENT NATURE</span></MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<TdsThresholdLimitModel, object>(x=> x.PeriodFrom)"><span class="admin-header-text">EFFECTIVE PERIOD</span></MudTableSortLabel></MudTh>
                    <MudTh Style="text-align: right;"><MudTableSortLabel SortBy="new Func<TdsThresholdLimitModel, object>(x=> x.ThresholdLimitSingle)"><span class="admin-header-text">SINGLE LIMIT</span></MudTableSortLabel></MudTh>
                    <MudTh Style="text-align: right;"><MudTableSortLabel SortBy="new Func<TdsThresholdLimitModel, object>(x=> x.ThresholdLimitPeriod)"><span class="admin-header-text">AGGREGATE LIMIT</span></MudTableSortLabel></MudTh>
                    <MudTh Style="text-align: right;"><span class="admin-header-text">ACTIONS</span></MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Nature">
                        <div class="d-flex align-center gap-3">
                            <div class="admin-icon-square-vibrant small accent-indigo">
                                <MudIcon Icon="@Icons.Material.Filled.Payments" Size="Size.Small" />
                            </div>
                            <span class="fw-700 admin-td-primary">@context.NatureOfPayment.NatureOfPayment</span>
                        </div>
                    </MudTd>
                    <MudTd DataLabel="Period">
                        <div class="d-flex align-center gap-2">
                            <span class="fw-600">@context.PeriodFrom?.ToString("dd MMM yyyy")</span>
                            <MudIcon Icon="@Icons.Material.Filled.ArrowForward" Size="Size.Small" Class="opa-20" />
                            <span class="fw-600">@context.PeriodTo?.ToString("dd MMM yyyy")</span>
                        </div>
                    </MudTd>
                    <MudTd DataLabel="Single" Style="text-align: right;">
                        <span class="fw-700 font-monospace">@string.Format("{0:N2}", context.ThresholdLimitSingle)</span>
                    </MudTd>
                    <MudTd DataLabel="Aggregate" Style="text-align: right;">
                        <span class="fw-700 text-vibrant font-monospace">@string.Format("{0:N2}", context.ThresholdLimitPeriod)</span>
                    </MudTd>
                    <MudTd DataLabel="Actions" Style="text-align: right;">
                        <div class="d-flex justify-end gap-1">
                            <MudTooltip Text="Modify Thresholds">
                                <MudIconButton OnClick="@(()=> OpenDialog(context))" Color="Color.Primary" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Variant="Variant.Text" />
                            </MudTooltip>
                            <MudTooltip Text="Delete Matrix">
                                <MudIconButton OnClick="@(()=> Delete(context))" Color="Color.Error" Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Variant="Variant.Text" />
                            </MudTooltip>
                        </div>
                    </MudTd>
                </RowTemplate>
                <PagerContent>
                    <div class="pa-4">
                        <MudTablePager PageSizeOptions="new int[] { 10, 20, 50, 100 }" />
                    </div>
                </PagerContent>
            </MudTable>
        </div>
    </div>
}

@code {

    private bool _isLoading = true;
    private DateTime _loadStartTime;

    private TdsThresholdLimitModel model = new TdsThresholdLimitModel();
    private List<TdsThresholdLimitModel> collection = new List<TdsThresholdLimitModel>();
    private string searchTds = "";
    private bool _busy;

    public bool HasPermissionTdsThresholdLimitServiceEdit { get; set; } = false;
    public bool HasPermissionTdsThresholdLimitServiceDelete { get; set; } = false;
    public int TdsThresholdLimitDocTypeID = 98;

    // Lifecycle method called when the component is initialized
    protected override async Task OnInitializedAsync()
    {
        _loadStartTime = DateTime.Now;
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionTdsThresholdLimitServiceEdit = await Irole.HasClaim(TdsThresholdLimitDocTypeID.ToString(), "Edit", ctc.Token);
        HasPermissionTdsThresholdLimitServiceDelete = await Irole.HasClaim(TdsThresholdLimitDocTypeID.ToString(), "Delete", ctc.Token);

        model = new();
        GetAll();
        await EnsureMinimumLoadTime();
        _isLoading = false;
    }

    private async Task EnsureMinimumLoadTime()
    {
        var elapsed = (DateTime.Now - _loadStartTime).TotalMilliseconds;
        if (elapsed < 100)
        {
            await Task.Delay(100 - (int)elapsed);
        }
    }

    // Method to fetch all TDS threshold limits
    private void GetAll()
    {
        collection = new List<TdsThresholdLimitModel>();
        foreach (var item in Iservice.Select()) // Fetch TDS threshold limits from the service
        {
            collection.Add(item);
        }
    }

    // Method to open the dialog for adding or editing a TDS threshold limit
    private async Task OpenDialog(TdsThresholdLimitModel tds)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        _busy = true;

        if (HasPermissionTdsThresholdLimitServiceEdit)
        {
            var authprov = await auth.GetAuthenticationStateAsync();
            var user = authprov.User;

            DialogParameters parms = new DialogParameters();
            parms.Add("model", tds.Clone());
            var dialog = await DialogService.ShowAsync<TdsThresholdLimitDialog>(tds.TdsTLID == null ? "ADD" : "EDIT", parms);
            var result = await dialog.Result;
            if (!result.Canceled)
            {
                TdsThresholdLimitModel UpatedModel = (TdsThresholdLimitModel)result.Data;
                UpatedModel.UserInfo.UserID = user.Identity.Name;
                try
                {
                    Iservice.Update(UpatedModel); // Update the TDS threshold limit
                    snackbar.Add("Saved Successfully", Severity.Success);
                    GetAll();
                }
                catch (Exception ex)
                {
                    snackbar.Add(ex.Message, Severity.Warning);
                }
            }
        }
        else
        {
            bool? result = await DialogService.ShowMessageBoxAsync(
                "Permission denied!",
                "You don't have any permission to Edit TdsThresholdLimit.");
        }
        await Task.Delay(200);
        _busy = false;
    }

    // Method to delete a TDS threshold limit
    private async Task Delete(TdsThresholdLimitModel model)
    {
        if (HasPermissionTdsThresholdLimitServiceDelete)
        {
            bool? result = await DialogService.ShowMessageBoxAsync(
                  "Warning !",
                  "Are you sure, you want to delete - " + model.NatureOfPayment.NatureOfPayment + " (" + model.PeriodFrom + " - " + model.PeriodTo + ") ?");
            if (result == true)
            {
                var authprov = await auth.GetAuthenticationStateAsync();
                var user = authprov.User;
                Iservice.Delete(model.TdsTLID, user.Identity.Name); // Delete the TDS threshold limit
                snackbar.Add("Deleted Successfully", Severity.Success);
            }
            GetAll();
        }
        else
        {
            bool? result = await DialogService.ShowMessageBoxAsync(
                "Permission denied!",
                "You don't have any permission to Delete TdsThresholdLimit.");
        }
    }

    // Method to search for TDS threshold limits based on a search string
    private bool search(TdsThresholdLimitModel ts)
    {
        if (ts.NatureOfPayment != null && ts.NatureOfPayment.NatureOfPayment != null && ts.NatureOfPayment.NatureOfPayment.Contains(searchTds, StringComparison.OrdinalIgnoreCase))
        {
            return true;
        }
        else if (ts.NatureOfPayment == null) return true;
        return false;
    }
}

