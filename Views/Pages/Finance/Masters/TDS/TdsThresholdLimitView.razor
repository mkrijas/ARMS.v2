@page "/tdsTdsThresholdLimit"
@inject ITdsRateService tdsRate
@inject ITdsThresholdLimitService Iservice
@inject MudBlazor.ISnackbar snackbar
@inject AuthenticationStateProvider auth
@attribute [Authorize]
@using System.Threading;
@inject IRoleService<RoleModel> Irole
@inject IDialogService DialogService

<MudItem xs="12">
    <MudTable Items="@collection" Dense="true" Hover="true" Striped="true" Elevation="10" Filter="new Func<TdsThresholdLimitModel, bool>(search)" @bind-place="model">
        <ToolBarContent>
            <MudText Typo="Typo.h6">Tds Threshold Limit</MudText>
            <MudIconButton Disabled="@_busy" Icon="@Icons.Material.Filled.Add" Title="Add" @onclick="@(()=> OpenDialog(model))" Color="Color.Dark" Size="Size.Small"></MudIconButton>
            <MudSpacer></MudSpacer>
            <MudTextField @bind-Value="searchTds" Placeholder="Search TDS... " Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0"></MudTextField>
        </ToolBarContent>
        <HeaderContent>
            <MudTh><MudTableSortLabel SortBy="new Func<TdsThresholdLimitModel, object>(x=> x.NatureOfPayment.NatureOfPayment)" InitialDirection="SortDirection.Ascending">Nature of Payment</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel SortBy="new Func<TdsThresholdLimitModel, object>(x=> x.PeriodFrom)" InitialDirection="SortDirection.Ascending">Period From</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel SortBy="new Func<TdsThresholdLimitModel, object>(x=> x.PeriodTo)" InitialDirection="SortDirection.Ascending">Period To</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel SortBy="new Func<TdsThresholdLimitModel, object>(x=> x.ThresholdLimitSingle)" InitialDirection="SortDirection.Ascending">Single</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel SortBy="new Func<TdsThresholdLimitModel, object>(x=> x.ThresholdLimitPeriod)" InitialDirection="SortDirection.Ascending">Period</MudTableSortLabel></MudTh>
            <MudTh>Actions</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="NatureOfPayment">@context.NatureOfPayment.NatureOfPayment</MudTd>
            <MudTd DataLabel="AssesseeTypeName">@context.PeriodFrom</MudTd>
            <MudTd DataLabel="AssesseeTypeName">@context.PeriodTo</MudTd>
            <MudTd DataLabel="AssesseeTypeName">@context.ThresholdLimitSingle</MudTd>
            <MudTd DataLabel="AssesseeTypeName">@context.ThresholdLimitPeriod</MudTd>
            <MudTd DataLabel="">
                <MudFab @onclick="@(()=> OpenDialog(context))" Color="Color.Primary" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" IconSize="Size.Small" />
                <MudFab @onclick="@(()=> Delete(context))" Color="Color.Primary" Icon="@Icons.Material.Filled.Delete" Size="Size.Small" IconSize="Size.Small" />
            </MudTd>
        </RowTemplate>
        <PagerContent>
            <MudTablePager PageSizeOptions="new int[] { 10, 20, 50, 100 }" />
        </PagerContent>
    </MudTable>
</MudItem>

@code {

    private TdsThresholdLimitModel model = new TdsThresholdLimitModel();
    private List<TdsThresholdLimitModel> collection = new List<TdsThresholdLimitModel>();
    private string searchTds = "";
    private bool _busy;

    public bool HasPermissionTdsThresholdLimitServiceEdit { get; set; } = false;
    public bool HasPermissionTdsThresholdLimitServiceDelete { get; set; } = false;
    public int TdsThresholdLimitDocTypeID = 98;

    // Lifecycle method called when the component is initialized
    protected override async Task OnInitializedAsync()
    {
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionTdsThresholdLimitServiceEdit = await Irole.HasClaim(TdsThresholdLimitDocTypeID.ToString(), "Edit", ctc.Token);
        HasPermissionTdsThresholdLimitServiceDelete = await Irole.HasClaim(TdsThresholdLimitDocTypeID.ToString(), "Delete", ctc.Token);

        model = new();
        GetAll();
    }

    // Method to fetch all TDS threshold limits
    private void GetAll()
    {
        collection = new List<TdsThresholdLimitModel>();
        foreach (var item in Iservice.Select()) // Fetch TDS threshold limits from the service
        {
            collection.Add(item);
        }
    }

    // Method to open the dialog for adding or editing a TDS threshold limit
    private async Task OpenDialog(TdsThresholdLimitModel tds)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        _busy = true;

        if (HasPermissionTdsThresholdLimitServiceEdit)
        {
            var authprov = await auth.GetAuthenticationStateAsync();
            var user = authprov.User;

            DialogParameters parms = new DialogParameters();
            parms.Add("model", tds.Clone());
            var dialog = DialogService.Show<TdsThresholdLimitDialog>(tds.TdsTLID == null ? "ADD" : "EDIT", parms);
            var result = await dialog.Result;
            if (!result.Cancelled)
            {
                TdsThresholdLimitModel UpatedModel = (TdsThresholdLimitModel)result.Data;
                UpatedModel.UserInfo.UserID = user.Identity.Name;
                try
                {
                    Iservice.Update(UpatedModel); // Update the TDS threshold limit
                    snackbar.Add("Saved Successfully", Severity.Success);
                    GetAll();
                }
                catch (Exception ex)
                {
                    snackbar.Add(ex.Message, Severity.Warning);
                }
            }
        }
        else
        {
            bool? result = await DialogService.ShowMessageBox(
                "Permission denied!",
                "You don't have any permission to Edit TdsThresholdLimit.");
        }
        await Task.Delay(200);
        _busy = false;
    }

    // Method to delete a TDS threshold limit
    private async Task Delete(TdsThresholdLimitModel model)
    {
        if (HasPermissionTdsThresholdLimitServiceDelete)
        {
            bool? result = await DialogService.ShowMessageBox(
                  "Warning !",
                  "Are you sure, you want to delete - " + model.NatureOfPayment.NatureOfPayment + " (" + model.PeriodFrom + " - " + model.PeriodTo + ") ?");
            if (result == true)
            {
                var authprov = await auth.GetAuthenticationStateAsync();
                var user = authprov.User;
                Iservice.Delete(model.TdsTLID, user.Identity.Name); // Delete the TDS threshold limit
                snackbar.Add("Deleted Successfully", Severity.Success);
            }
            GetAll();
        }
        else
        {
            bool? result = await DialogService.ShowMessageBox(
                "Permission denied!",
                "You don't have any permission to Delete TdsThresholdLimit.");
        }
    }

    // Method to search for TDS threshold limits based on a search string
    private bool search(TdsThresholdLimitModel ts)
    {
        if (ts.NatureOfPayment != null && ts.NatureOfPayment.NatureOfPayment != null && ts.NatureOfPayment.NatureOfPayment.Contains(searchTds, StringComparison.OrdinalIgnoreCase))
        {
            return true;
        }
        else if (ts.NatureOfPayment == null) return true;
        return false;
    }
}