@page "/OpeningBalance"
@attribute [Authorize]
@inject AuthenticationStateProvider auth
@using Core.IDataServices.Finance
@using System.Threading
@inject IOpeningBalanceService Iservice
@inject MudBlazor.ISnackbar snackbar
@inject IRoleService<RoleModel> Irole
@inject IDialogService DialogService
@inject NavigationManager Navigation
@inject IRoleService<RoleModel> Irole

@if (_isLoading)
{
    <div @key="@("loader")" style="display: flex; justify-content: center; align-items: center; min-height: 400px;">
        <LoaderComponent IsFullScreen="true" 
                        ShowLogo="false" 
                        Size="medium" 
                        LoadingText="Loading Opening Balance" 
                        SubText="Please wait..." />
    </div>
}
else
{
    <div class="fade-in">
        <div class="admin-header-tiered mb-6">
            <div class="d-flex align-center justify-space-between">
                <div>
                    <MudText Typo="Typo.h4" Class="admin-title">Fiscal Position Initialization</MudText>
                    <MudText Typo="Typo.body2" Class="admin-subtitle">Establish opening ledger balances for the current financial period. maintain accurate starting points for all chart of account dimensions and sub-ledgers.</MudText>
                </div>
            </div>
        </div>

        <div class="admin-glass-card mb-6 pa-4">
            <div class="d-flex align-center gap-6 flex-wrap">
                <div style="flex-grow: 1; min-width: 300px;">
                    <MudSelect Label="Financial Period" @bind-Value="PeriodID" T="int?" Variant="Variant.Outlined" Margin="Margin.Dense" Class="admin-input-group" AnchorOrigin="Origin.BottomCenter">
                        @foreach (var ditem in Periods)
                        {
                            <MudSelectItem Value="@ditem.PeriodID">@ditem.PeriodDescription</MudSelectItem>
                        }
                    </MudSelect>
                </div>
                <div class="d-flex align-center gap-3">
                    <MudButton OnClick="fetch" Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Refresh" Class="rounded-pill px-6">FETCH BALANCES</MudButton>
                    <MudButton OnClick="ResetOpeningBalance" Variant="Variant.Outlined" Color="Color.Secondary" StartIcon="@Icons.Material.Filled.History" Class="rounded-pill px-6">ROLL OVER PREVIOUS</MudButton>
                </div>
            </div>
        </div>

        @if (collection.Any())
        {
            <div class="admin-glass-card pa-0 overflow-hidden">
                <MudTable Items="@collection" Elevation="0" Class="modern-admin-table" Hover="true">
                    <HeaderContent>
                        <MudTh><span class="admin-header-text">ACCOUNT DETAIL</span></MudTh>
                        <MudTh><span class="admin-header-text">ARD CODE</span></MudTh>
                        <MudTh><span class="admin-header-text">SUB-ARD</span></MudTh>
                        <MudTh><span class="admin-header-text">OPENING AMOUNT</span></MudTh>
                        <MudTh Style="text-align: right;"><span class="admin-header-text">ACTIONS</span></MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="Account">
                            <span class="fw-700 admin-td-primary">@context.AccountName</span>
                        </MudTd>
                        <MudTd DataLabel="ARD">
                            <span class="fw-600 font-monospace opa-70">@context.ArdCode</span>
                        </MudTd>
                        <MudTd DataLabel="Sub-ARD">
                            <span class="fw-600 font-monospace opa-70">@context.SubArdCode</span>
                        </MudTd>
                        <MudTd DataLabel="Amount">
                            @if (!context.hideTextField)
                            {
                                <span class="fw-700 @(context.Amount < 0 ? "text-error" : "text-primary")">@context.Amount?.ToString("N2")</span>
                            }
                            else
                            {
                                <MudNumericField HideSpinButtons Label="Enter Amount" @bind-Value="@context.Amount" Variant="Variant.Outlined" Margin="Margin.Dense" Class="admin-input-group max-w-200" AutoFocus="true" />
                            }
                        </MudTd>
                        <MudTd DataLabel="Actions" Style="text-align: right;">
                            <div class="d-flex justify-end gap-1">
                                @if (!context.hideTextField)
                                {
                                    <MudTooltip Text="Adjust Balance">
                                        <MudIconButton OnClick="@(()=> Edit(context))" Color="Color.Primary" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Variant="Variant.Text" />
                                    </MudTooltip>
                                }
                                else
                                {
                                    <MudTooltip Text="Commit Changes">
                                        <MudIconButton OnClick="@(value => Submit(context.Amount, context))" Color="Color.Success" Icon="@Icons.Material.Filled.CheckCircle" Size="Size.Small" Variant="Variant.Filled" Class="mr-1" />
                                    </MudTooltip>
                                    <MudTooltip Text="Revert">
                                        <MudIconButton OnClick="@(()=> Cancel(context))" Color="Color.Error" Icon="@Icons.Material.Filled.Cancel" Size="Size.Small" Variant="Variant.Text" />
                                    </MudTooltip>
                                }
                            </div>
                        </MudTd>
                    </RowTemplate>
                    <PagerContent>
                        <div class="pa-4">
                            <MudTablePager PageSizeOptions="new int[] { 10, 20, 50, 100 }" />
                        </div>
                    </PagerContent>
                </MudTable>
            </div>
        }
        else
        {
            <div class="admin-glass-card d-flex flex-column align-center justify-center py-16">
                <div class="admin-icon-square-vibrant mb-4 accent" style="width: 80px; height: 80px;">
                    <MudIcon Icon="@Icons.Material.Filled.AccountBalance" Style="font-size: 3rem;" />
                </div>
                <MudText Typo="Typo.h5" Class="fw-700 opa-80">Fiscal Period Initialization</MudText>
                <MudText Typo="Typo.body2" Class="opa-50">Select a financial period and fetch to start initializing opening balances.</MudText>
            </div>
        }
    </div>
}

@code {
    private bool _isLoading = true;
    private DateTime _loadStartTime;
    private List<OpeningBalanceModel> collection = new();
    private List<PeriodModel> Periods = new();
    private int? PeriodID;
    private int? BranchID;

    private bool resetValueOnEmptyText;
    private bool coerceText;
    private bool coerceValue;
    public bool HasPermissionOpeningBalanceSeriviceEdit { get; set; } = false;
    private Dictionary<string, string> options = new Dictionary<string, string>();
    public int DocTypeID = 136;

    // Lifecycle method that runs when the component is initialized
    protected override async Task OnInitializedAsync()
    {
        _loadStartTime = DateTime.Now;
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionOpeningBalanceSeriviceEdit = await Irole.HasClaim(DocTypeID.ToString(), "Edit", ctc.Token);

        var authprov = await auth.GetAuthenticationStateAsync();
        var UserID = authprov.User.Identity.Name;
        BranchID = int.Parse(authprov.User.Claims.FirstOrDefault(x => x.Type == "BranchID").Value);

        // Fetch the list of periods
        Periods = Iservice.GetPeriods().ToList();
        await EnsureMinimumLoadTime();
        _isLoading = false;
    }

    private async Task EnsureMinimumLoadTime()
    {
        var elapsed = (DateTime.Now - _loadStartTime).TotalMilliseconds;
        if (elapsed < 100)
        {
            await Task.Delay(100 - (int)elapsed);
        }
    }

    // Method to fetch balances based on the selected period
    public async Task fetch()
    {
        if (PeriodID != null)
        {
            // Fetch the balance for the selected period and branch
            collection = Iservice.GetBalance(PeriodID, BranchID).ToList();
        }
        else
        {
            snackbar.Add("Select a period", Severity.Error);
            return;
        }
    }

    // Method to Reset Opening Balance based on the selected period
    public async Task ResetOpeningBalance()
    {
        if (PeriodID != null)
       
        {
            bool? result = await DialogService.ShowMessageBoxAsync(
                "Warning !",
                "Do you want to carry over the opening balance from the previous year ");
            if (result == true)
            try
            {
                var authprov = await auth.GetAuthenticationStateAsync();
                var user = authprov.User;
               
                Iservice.Reset(PeriodID, user.Identity.Name); 
                snackbar.Add("Opening Balance Updated Successfully", Severity.Success);
                
            }
                catch (Exception ex)
                {
                    snackbar.Add(ex.Message, Severity.Error);
                }
        }
        
        else
        {
            snackbar.Add("Select a period", Severity.Error);
            return;
        }
    }

    // Method to edit an opening balance model
    private void Edit(OpeningBalanceModel context)
    {
        context.hideTextField = true;
    }

    // Method to cancel editing of an opening balance model
    private void Cancel(OpeningBalanceModel context)
    {
        context.hideTextField = false;
        StateHasChanged();
        //Navigation.NavigateTo(Navigation.Uri, true);

    }

    // Method to submit the updated amount for an opening balance model
    private async Task Submit(decimal? newAmount,OpeningBalanceModel model)
    {
        if (HasPermissionOpeningBalanceSeriviceEdit)
        {
            try
            {
                var authprov = await auth.GetAuthenticationStateAsync();
                var user = authprov.User;

                model.UserInfo.UserID = user.Identity.Name;
                model.Amount = newAmount;

                // Update the model in the service
                Iservice.Update(model);
                snackbar.Add("Updated Successfully", Severity.Success);
                model.hideTextField = false;
                StateHasChanged();
            }
            catch (Exception ex)
            {
                snackbar.Add(ex.Message, Severity.Error);
            }
        }
        else
        {
            bool? ResultModel = await DialogService.ShowMessageBoxAsync(
                "Permission denied!",
                "You don't have any permission to Add or Edit Driver.");
        }

    }

}
