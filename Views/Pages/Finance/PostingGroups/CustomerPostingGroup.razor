@page "/CustomerPostingGroup"
@inject ICustomerPostingGroupService Iservice
@inject IChartOfAccountService accountService
@inject MudBlazor.ISnackbar snackbar
@inject IChartOfAccountService accountService
@inject IConfiguration configuration
@using Microsoft.Extensions.Configuration
@inject AuthenticationStateProvider auth
@attribute [Authorize]
@inject IDialogService DialogService


<MudGrid>
    <MudItem xs="4" lg="4">
        <MudPaper Width="100%" Class="p-2" >
            <MudList Clickable="true" SelectedItem="SelectedItem" SelectedItemChanged="SelectedItemChanged">
                <MudText Typo="Typo.h6">Customer Posting Group
                <MudIconButton Icon="@Icons.Material.Filled.Add" Title="Add" @onclick="@(()=> OpenDialogGroup(model))"  Color="Color.Dark" Size="Size.Small"></MudIconButton>

                </MudText>
             
               
               
                @if (listOfItems?.Any() == true)
                {
                    @foreach (var item in listOfItems)
                    {
                         <ContextMenuTrigger MenuId="myMenu"  Data="@item" >
                        
                        <MudListItem Value="item">
                            <MudText Typo=Typo.subtitle1> @item.Title.ToString() </MudText>
                           @* <MudText Typo="Typo.overline">Since : @item.UserInfo.TimeStampField?.ToString("dd/MM/yy")</MudText>
                            <MudText Typo="Typo.overline">Since : @item.InventoryGroupName.ToString()</MudText>*@
                        
                        </MudListItem>
                        </ContextMenuTrigger>
                    }
                }
            </MudList>
        </MudPaper>
    </MudItem>


    @if (@value==true)
    {
        <MudItem xs="8" lg="8">
            
           <MudPaper >
              <MudContainer>
                    <h4>@titleValue</h4>
                    <br/>
               <MudGrid Spacing="4">
                   
                   <MudItem xs="12" lg="12">
                        <MudTextField @bind-Value="model.Title" Label="Title" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.Title)"></MudTextField>
                       
                   </MudItem>
                    <MudItem xs="12"md="12">
                         <CoalDSelect   @bind-Value="model.Receivable" LabelName="SelectedAccountReceivable" />
                      </MudItem>
                       <MudItem xs="12"md="12">
                        <CoalDSelect   @bind-Value="model.PrePayment" LabelName="SelectedAccountPrePayment"  />
                      </MudItem>
                       <MudItem xs="12"md="12">
                      <CoalDSelect   @bind-Value="model.Deposit" LabelName="SelectedAccountPrePayment" />
                      </MudItem>
                       <MudItem xs="12"md="6">
                       </MudItem> <MudItem xs="12"md="6">
                        <MudButton @onclick="CancelCustomerPostingGroup" Variant="Variant.Filled" Color="Color.Warning" >Cancel</MudButton>

                        <MudButton @onclick="CreateCustomerPostingGroup" Variant="Variant.Filled" Color="Color.Success" >Submit</MudButton>

                       </MudItem>
                </MudGrid>
                </MudContainer>
               
           </MudPaper>
      </MudItem>
    }
      


</MudGrid>
<ContextMenu Id="myMenu" OnAppearing="OnAppearing">
 @*   <Item OnClick="@ContextMenuOnClickadd"  Id="addItem" >Add Items</Item>*@
    <Item OnClick="@ContextMenuOnClickedit"  Id="editGroup">Edit Group</Item>  
</ContextMenu>

@code {


    CustomerPostingGroupModel model = new CustomerPostingGroupModel();
    private MudListItem SelectedItem;
    private List<CustomerPostingGroupModel> listOfItems = new();
    CustomerPostingGroupModel SelectedModel = new();
    public bool value = false;
    public string titleValue = null;
    private List<CustomerPostingGroupModel> collection = new List<CustomerPostingGroupModel>();
   

    protected override async Task OnInitializedAsync()
    {
        GetAll();

    }
    protected async Task SelectedItemChanged(object obj)
    {
        SelectedItem = (MudListItem)obj;
        SelectedModel = (CustomerPostingGroupModel)SelectedItem.Value;
       
    }
    private  void GetAll()
    {
        listOfItems = Iservice.Select().ToList();
    } 
    
    public async Task CancelCustomerPostingGroup()
    {
        value = false;
        model = new();
       
      
    }
    public async Task CreateCustomerPostingGroup()
    {
        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;
        model.UserInfo.UserID = user.Identity.Name;
      
        Iservice.Update(model);
        snackbar.Add("Successfully Submitted", Severity.Success);
        GetAll();
        value = false;
    }
    private async Task OpenDialog(CustomerPostingGroupModel ii)
    {





    }
     void OnAppearing(MenuAppearingEventArgs e)
    {
        //TreeItemData item = (TreeItemData)e.Data;
        // e.PreventShow = !item.HasChildren;      
    }
  
    private void OpenDialogGroup(CustomerPostingGroupModel ig)
    {
        value = true;
        model = new();
        
        titleValue = "Add Customer Posting Group";
    }
   
    protected void ContextMenuOnClickedit(ItemClickEventArgs e)
    {
        model = (CustomerPostingGroupModel)e.Data;
      
        value = true;
        titleValue = "Edit Customer Posting Group";
       
       
    }

}
