@page "/AssetRegisterReport"
@inherits ReportComponentBase

<div class="fade-in">
    <div class="admin-header-tiered mb-6">
        <div class="d-flex align-center justify-space-between">
            <div>
                <MudText Typo="Typo.h4" Class="admin-title">Asset Audit Center | Register Report</MudText>
                <MudText Typo="Typo.body2" Class="admin-subtitle">Systematic index of organizational capital assets. Filter by specific branch clusters and temporal ranges to generate comprehensive audit trails for financial compliance and valuation tracking.</MudText>
            </div>
        </div>
    </div>

    <div class="admin-glass-card mb-6 pa-6">
        <MudGrid Spacing="4" Class="align-center">
            <MudItem xs="12" sm="3">
                <MudDatePicker Label="Report Start Date" @bind-Date="@FromDate" Variant="Variant.Outlined" Margin="Margin.Dense" Class="admin-input-group" />
            </MudItem>
            <MudItem xs="12" sm="3">
                <MudDatePicker Label="Report End Date" @bind-Date="@ToDate" Variant="Variant.Outlined" Margin="Margin.Dense" Class="admin-input-group" />
            </MudItem>
            <MudItem xs="12" sm="6" Class="d-flex align-center gap-2">
                <MudTooltip Text="Select Branches">
                    <MudIconButton Icon="@Icons.Material.Filled.AccountTree" Variant="Variant.Filled" Color="Color.Success" OnClick="SelectBranches" Class="rounded-lg" />
                </MudTooltip>
                <MudButton FullWidth="true" Variant="Variant.Filled" Color="Color.Primary" OnClick="RenderReportViewer" Class="admin-register-btn">GENERATE REGISTER</MudButton>
            </MudItem>
        </MudGrid>
    </div>

    <div class="admin-glass-card pa-0 overflow-hidden shadow-sm @(ShowReport ? "" : "d-none")">
        <div class="pa-4 border-b">
            <div class="d-flex align-center gap-2">
                <MudIcon Icon="@Icons.Material.Filled.Description" Size="Size.Small" Color="Color.Primary" />
                <MudText Typo="Typo.subtitle2" Class="fw-700 uppercase">Interactive Report Preview</MudText>
            </div>
        </div>
        <div class="pa-0">
            <ReportViewer ReportName="@ReportName" Parameters=@ReportParameters @ref="@report"></ReportViewer>
        </div>
    </div>

    @if (!ShowReport)
    {
        <div class="admin-glass-card pa-12 d-flex flex-column align-center justify-center border-dashed">
            <MudIcon Icon="@Icons.Material.Filled.AutoGraph" Size="Size.Large" Color="Color.Default" Class="opa-10 mb-4" />
            <MudText Typo="Typo.h6" Class="fw-700 opa-20 uppercase tracking-widest">Awaiting Parameter Selection</MudText>
            <MudText Typo="Typo.body2" Class="opa-30 mt-1">Configure date ranges and branch filters to initialize the asset register.</MudText>
        </div>
    }
</div>

@code {

    ReportViewer report;
    public DateTime? FromDate { get; set; } = DateTime.Now;
    public DateTime? ToDate { get; set; } = DateTime.Now;

    public bool ShowReport { get; set; } = false;
    public string ReportName { get; set; }
    // public BranchModel CurrentBranch { get; set; } = new();


    protected bool Validate()
    {
        if (!SelectedBranches.Any())
        {
            snackbar.Add("Please select branch.", Severity.Error);
            return false;
        }
        if (FromDate == null)
        {
            snackbar.Add("Please select From Date.", Severity.Error);
            return false;
        }
        if (ToDate == null)
        {
            snackbar.Add("Please select To Date.", Severity.Error);
            return false;
        }
        return true;
    }

    public async Task RenderReportViewer()
    {        
        try
        {
            if (Validate())
            {
                ReportName = "AssetRegister";
                ReportParameters.Clear();                
                ReportParameters.Add("BranchIDS", String.Join(',', SelectedBranches));
                ReportParameters.Add("FromDate", FromDate.Value.ToString("yyyy-MM-dd"));
                ReportParameters.Add("ToDate", ToDate.Value.ToString("yyyy-MM-dd"));
                ShowReport = true;
                await report.RenderReport(ReportName);
            }
        }
        catch (Exception ex)
        {
            snackbar.Add(ex.Message, Severity.Error);
        }
    }
}
