@page "/ReceiptsandPaymentsReport"
@inherits ReportComponentBase
@using ArmsModels.BaseModels.Finance.Report;
@inject IDialogService DialogService

<div class="fade-in">
    <div class="admin-header-tiered mb-6">
        <div class="d-flex align-center justify-space-between">
            <div>
                <MudText Typo="Typo.h4" Class="admin-title">Receipts and Payments Audit</MudText>
                <MudText Typo="Typo.body2" Class="admin-subtitle">Comprehensive audit of cash and bank movements. Analyze liquidity flows, operational receipts, and disbursement patterns across the fiscal period.</MudText>
            </div>
            <MudRadioGroup T="string" @bind-Value="@Operation" Class="admin-glass-card pa-2 d-flex gap-4">
                <MudRadio Value="@("Bank")" Color="Color.Secondary" UnCheckedColor="Color.Default" Size="Size.Small">Bank Audit</MudRadio>
                <MudRadio Value="@("Cash")" Color="Color.Primary" UnCheckedColor="Color.Default" Size="Size.Small">Cash Audit</MudRadio>
            </MudRadioGroup>
        </div>
    </div>

    <div class="admin-glass-card mb-6 pa-6">
        <MudGrid Spacing="4" Class="align-center">
            <MudItem xs="12" sm="4">
                <MudDatePicker Label="From Date" @bind-Date="@StartDate" Variant="Variant.Outlined" Margin="Margin.Dense" Class="admin-input-group" />
            </MudItem>
            <MudItem xs="12" sm="4">
                <MudDatePicker Label="To Date" @bind-Date="@EndDate" Variant="Variant.Outlined" Margin="Margin.Dense" Class="admin-input-group" />
            </MudItem>
            <MudItem xs="12" sm="4" Class="d-flex align-center gap-2">
                <MudTooltip Text="Select Branches">
                    <MudIconButton Icon="@Icons.Material.Filled.List" Variant="Variant.Filled" Color="Color.Success" OnClick="SelectBranches" Class="rounded-lg" />
                </MudTooltip>
                <MudButton FullWidth="true" Variant="Variant.Filled" Color="Color.Primary" OnClick="RenderReportViewer" Class="admin-register-btn">VIEW REPORT</MudButton>
            </MudItem>
        </MudGrid>
    </div>

    <div class="admin-glass-card pa-0 overflow-hidden shadow-sm @(ShowReport ? "" : "d-none")">
        <ReportViewer ReportName="@ReportName" Parameters=@ReportParameters @ref="@report"></ReportViewer>
    </div>
</div>

@code {

    ReportViewer report;
    DateTime? StartDate { get; set; } = DateTime.Now;
    DateTime? EndDate { get; set; } = DateTime.Now;
    public BranchModel Branch { get; set; } = null;
    bool ShowReport { get; set; } = false;
    string Operation { get; set; }
    string ReportName { get; set; }
    public BranchModel CurrentBranch { get; set; } = new();
    bool IsBrachDiasbled = true;

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();
        var authprov = await auth.GetAuthenticationStateAsync();
        var User = authprov.User;
        string BranchIDString = User.Claims.First(x => x.Type == "BranchID").Value;
        CurrentBranch.BranchName = User.Claims.First(x => x.Type == "BranchName").Value;
        CurrentBranch.BranchID = int.Parse(BranchIDString);
        //CurrentBranch.BranchID = int.Parse(BranchIDString);
        //BranchList = Ibranchservice.Select().ToList();
    }

    async Task BranchChanged(BranchModel branch)
    {
        Branch = branch;
    }

    public async Task RenderReportViewer()
    {
        if (!SelectedBranches.Any())
        {
            snackbar.Add("Please select branch.", Severity.Error);
            return;
        }
        if (Operation == null)
        {
            snackbar.Add("Please select cash/bank!.", Severity.Warning);
            return;
        }
        if (StartDate == null)
        {
            snackbar.Add("Please select start date.", Severity.Error);
            return;
        }
        if (EndDate == null)
        {
            snackbar.Add("Please select end date.", Severity.Error);
            return;
        }

        ShowReport = true;
        ReportName = "CashBankAuditReport";
        ReportParameters.Clear();
        ReportParameters.Add("Operation", Operation);
        ReportParameters.Add("FromDate", StartDate.Value.ToString("yyyy-MM-dd"));
        ReportParameters.Add("ToDate", EndDate.Value.ToString("yyyy-MM-dd"));
        ReportParameters.Add("BranchID", CurrentBranch.BranchID.Value.ToString());
        await report.RenderReport(ReportName);
    }

}
