@page "/BankLedgerReport"
@inherits ReportComponentBase
@inject IBankAccountOwnService IbankService
@using System.Threading;

<div class="fade-in">
    <div class="admin-header-tiered mb-6">
        <div class="d-flex align-center justify-space-between">
            <div>
                <MudText Typo="Typo.h4" Class="admin-title">Bank Ledger Report</MudText>
                <MudText Typo="Typo.body2" Class="admin-subtitle">Comprehensive audit trail of bank account transactions. Reconcile statements, track deposits, and monitor outflows across institutional accounts.</MudText>
            </div>
        </div>
    </div>

    <div class="admin-glass-card mb-6 pa-6">
        <MudGrid Spacing="4" Class="align-center">
            <MudItem xs="12" sm="4">
                <MudAutocomplete Label="Select Bank" @bind-Value="SelectedBank" SearchFunc="SearchBanks" T="OwnBankModel" Variant="Variant.Outlined" Margin="Margin.Dense" Class="admin-input-group" AdornmentColor="Color.Secondary" ToStringFunc="@(e => (e == null) ? null :( string.IsNullOrEmpty(e.BankAccountInfo.BankTitle) ? "" : string.Format("{0} | {1}",e.BankCode,e.BankAccountInfo.BankTitle)))" />
            </MudItem>
            <MudItem xs="12" sm="3">
                <MudDatePicker Label="From Date" @bind-Date="@FromDate" Variant="Variant.Outlined" Margin="Margin.Dense" Class="admin-input-group" />
            </MudItem>
            <MudItem xs="12" sm="3">
                <MudDatePicker Label="To Date" @bind-Date="@ToDate" Variant="Variant.Outlined" Margin="Margin.Dense" Class="admin-input-group" />
            </MudItem>
            <MudItem xs="12" sm="2" Class="d-flex align-center gap-2">
                <MudCheckBox @bind-Value="@detailed" Label="Detailed" Color="Color.Primary" Dense="true" />
                <MudTooltip Text="Select Branches">
                    <MudIconButton Icon="@Icons.Material.Filled.List" Variant="Variant.Filled" Color="Color.Success" OnClick="SelectBranches" Class="rounded-lg" />
                </MudTooltip>
                <MudButton FullWidth="true" Variant="Variant.Filled" Color="Color.Primary" OnClick="RenderReportViewer" Class="admin-register-btn">VIEW REPORT</MudButton>
            </MudItem>
        </MudGrid>
    </div>

    <div class="admin-glass-card pa-0 overflow-hidden shadow-sm @(ShowReport ? "" : "d-none")">
        <ReportViewer ReportName="@ReportName" Parameters=@ReportParameters  @ref="@report"></ReportViewer>
    </div>
</div>

@code {
    bool detailed = false;
    ReportViewer report;
    public DateTime? FromDate { get; set; } = DateTime.Now;
    public DateTime? ToDate { get; set; } = DateTime.Now;

    public OwnBankModel SelectedBank { get; set; }
    public bool ShowReport { get; set; } = false;
    public string ReportName { get; set; }

    private List<OwnBankModel> BankList = new List<OwnBankModel>(); 

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();
        BankList = IbankService.Select(BranchID).ToList();        
    }

    protected bool Validate()
    {
        if (!SelectedBranches.Any())
        {
            snackbar.Add("Please select branch.", Severity.Error);
            return false;
        }
        if (SelectedBank.BankCode == null)
        {
            snackbar.Add("Please select Bank.", Severity.Error);
            return false;
        }
        if (FromDate == null)
        {
            snackbar.Add("Please select From Date.", Severity.Error);
            return false;
        }
        if (ToDate == null)
        {
            snackbar.Add("Please select To Date.", Severity.Error);
            return false;
        }
        return true;
    }

    private async Task<IEnumerable<OwnBankModel>> SearchBanks(string searchString, CancellationToken token)
    {
        if (string.IsNullOrEmpty(searchString))
            return BankList;

        return await Task.FromResult(BankList.Where(x => x.BankAccountInfo.BankTitle.Contains(searchString, StringComparison.InvariantCultureIgnoreCase) || x.BankCode.Contains(searchString, StringComparison.InvariantCultureIgnoreCase)));
    }

    public async Task RenderReportViewer()
    {
        try
        {
           await  Task.Delay(5);
            if(Validate())
            {                
                ReportName = detailed ? "BankLedgerReportDetailed" : "BankLedgerReport";               
                ReportParameters.Clear();        
                ReportParameters.Add("ArdCode", SelectedBank.BankCode);
                ReportParameters.Add("BranchIDS", String.Join(',', SelectedBranches));
                ReportParameters.Add("FromDate", FromDate.Value.ToString("yyyy-MM-dd"));
                ReportParameters.Add("ToDate", ToDate.Value.ToString("yyyy-MM-dd"));
                ShowReport = true;
                await report.RenderReport(ReportName);
                
            }
        }
        catch(Exception ex)
        {
            snackbar.Add(ex.Message, Severity.Error);
        }
    }
}
