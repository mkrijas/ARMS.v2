@page "/CashLedgerReport"
@inherits ReportComponentBase
@inject ICashAccountService ICashAccountService

<div class="fade-in">
    <div class="admin-header-tiered mb-6">
        <div class="d-flex align-center justify-space-between">
            <div>
                <MudText Typo="Typo.h4" Class="admin-title">Cash Ledger Report</MudText>
                <MudText Typo="Typo.body2" Class="admin-subtitle">Audit of liquid cash account movements. Track petty cash flows, branch-level disbursements, and daily settlement history.</MudText>
            </div>
        </div>
    </div>

    <div class="admin-glass-card mb-6 pa-6">
        <MudGrid Spacing="4" Class="align-center">
            <MudItem xs="12" sm="4">
                <MudSelect For="@(() => SelectedCashAccount)" Label="Select CashAccount" @bind-Value="SelectedCashAccount" T="CashAccountModel" Variant="Variant.Outlined" Margin="Margin.Dense" Class="admin-input-group" AdornmentColor="Color.Secondary" ToStringFunc="@(e => e == null ? null : $"{e.CashCode}")">
                    @foreach (var item in collection)
                    {
                        <MudSelectItem Value="@item">@item.CashCode | @item.Title</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" sm="3">
                <MudDatePicker Label="From Date" @bind-Date="@FromDate" Variant="Variant.Outlined" Margin="Margin.Dense" Class="admin-input-group" />
            </MudItem>
            <MudItem xs="12" sm="3">
                <MudDatePicker Label="To Date" @bind-Date="@ToDate" Variant="Variant.Outlined" Margin="Margin.Dense" Class="admin-input-group" />
            </MudItem>
            <MudItem xs="12" sm="2" Class="d-flex align-center gap-2">
                <MudCheckBox @bind-Value="@detailed" Label="Detailed" Color="Color.Primary" Dense="true" />
                <MudTooltip Text="Select Branches">
                    <MudIconButton Icon="@Icons.Material.Filled.List" Variant="Variant.Filled" Color="Color.Success" OnClick="SelectBranches" Class="rounded-lg" />
                </MudTooltip>
                <MudButton FullWidth="true" Variant="Variant.Filled" Color="Color.Primary" OnClick="RenderReportViewer" Class="admin-register-btn">VIEW REPORT</MudButton>
            </MudItem>
        </MudGrid>
    </div>

    <div class="admin-glass-card pa-0 overflow-hidden shadow-sm @(ShowReport ? "" : "d-none")">
        <ReportViewer ReportName="@ReportName" Parameters=@ReportParameters @ref="@report"></ReportViewer>
    </div>
</div>

@code {

    bool detailed = false;
    ReportViewer report;
    public bool ShowReport { get; set; } = false;
    public string ReportName { get; set; }
    int branch;
    public DateTime? FromDate { get; set; } = DateTime.Now;
    public DateTime? ToDate { get; set; } = DateTime.Now;
    public CashAccountModel SelectedCashAccount { get; set; }
    private List<CashAccountModel> collection = new List<CashAccountModel>();

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();
        var authState = await auth.GetAuthenticationStateAsync();
        branch = int.Parse(authState.User.Claims.FirstOrDefault(x => x.Type == "BranchID").Value);
        collection = ICashAccountService.SelectByBranchALL(branch).ToList();
    }

    protected bool Validate()
    {
        if (!SelectedBranches.Any())
        {
            snackbar.Add("Please select branch.", Severity.Error);
            return false;
        }
        if (SelectedCashAccount.CashCode == null)
        {
            snackbar.Add("Please select CashAccount.", Severity.Error);
            return false;
        }
        if (FromDate == null)
        {
            snackbar.Add("Please select From Date.", Severity.Error);
            return false;
        }
        if (ToDate == null)
        {
            snackbar.Add("Please select To Date.", Severity.Error);
            return false;
        }
        return true;
    }

    public async Task RenderReportViewer()
    {
        try
        {
            if (Validate())
            {                
                
                ReportName = detailed ? "CashLedgerReportDetailed" : "CashLedgerReport";
                ReportParameters.Clear();
                ReportParameters.Add("ArdCode", SelectedCashAccount.CashCode);
                ReportParameters.Add("BranchIDS", String.Join(',', SelectedBranches));
                ReportParameters.Add("FromDate", FromDate.Value.ToString("yyyy-MM-dd"));
                ReportParameters.Add("ToDate", ToDate.Value.ToString("yyyy-MM-dd"));
                ShowReport = true;
                await report.RenderReport(ReportName);
            }
        }
        catch (Exception ex)
        {
            snackbar.Add(ex.Message, Severity.Error);
        }
    }
}
