@page "/FinanceAccountLedgerReport"
@inherits ReportComponentBase
@using ArmsModels.BaseModels.Finance.Report;
@inject IDialogService DialogService

<div class="fade-in">
    <div class="admin-header-tiered mb-6">
        <div class="d-flex align-center justify-space-between">
            <div>
                <MudText Typo="Typo.h4" Class="admin-title">Account Ledger Report</MudText>
                <MudText Typo="Typo.body2" Class="admin-subtitle">Master ledger showing consolidated account transactions. Track general ledger movements, reference-based audits, and detailed transaction history.</MudText>
            </div>
        </div>
    </div>

    <div class="admin-glass-card mb-6 pa-6">
        <MudGrid Spacing="4" Class="align-center">
            <MudItem xs="12" sm="3">
                <CoaSelector @bind-Value="SelectedAccount" LabelName="Select Account" IsFetchAll="true" Class="admin-input-group" />
            </MudItem>
            <MudItem xs="12" sm="2">
                <MudDatePicker Label="Start Date" @bind-Date="@StartDate" Variant="Variant.Outlined" Margin="Margin.Dense" Class="admin-input-group" />
            </MudItem>
            <MudItem xs="12" sm="2">
                <MudDatePicker Label="End Date" @bind-Date="@EndDate" Variant="Variant.Outlined" Margin="Margin.Dense" Class="admin-input-group" />
            </MudItem>
            <MudItem xs="12" sm="5" Class="d-flex align-center gap-2">
                <MudTooltip Text="More Filters">
                    <MudIconButton Icon="@Icons.Material.Filled.FilterAlt" Variant="Variant.Filled" Color="@(IsMoreParameterHasValues ? Color.Success : Color.Primary)" OnClick="OpenDialogAddOrEditReference" Class="rounded-lg" />
                </MudTooltip>
                <MudCheckBox @bind-Value="@detailed" Label="Detailed" Color="Color.Primary" Dense="true" />
                <MudTooltip Text="Select Branches">
                    <MudIconButton Icon="@Icons.Material.Filled.List" Variant="Variant.Filled" Color="Color.Success" OnClick="SelectBranches" Class="rounded-lg" />
                </MudTooltip>
                <MudButton FullWidth="true" Variant="Variant.Filled" Color="Color.Primary" OnClick="RenderReportViewer" Class="admin-register-btn">VIEW REPORT</MudButton>
            </MudItem>
        </MudGrid>
    </div>

    <div class="admin-glass-card pa-0 overflow-hidden shadow-sm @(ShowReport ? "" : "d-none")">
        <ReportViewer ReportName="@ReportName" Parameters=@ReportParameters @ref="@report"></ReportViewer>
    </div>
</div>

@code {

    ReportViewer report;
    DateTime? StartDate { get; set; } = DateTime.Now;
    DateTime? EndDate { get; set; } = DateTime.Now;
    ChartOfAccountModel SelectedAccount = new();
    bool ShowReport { get; set; } = false;
    string ReportName { get; set; }
    LedgerTransactionsReportMoreParameterModel MoreParameter { get; set; } = new();
    bool IsMoreParameterHasValues { get; set; } = false;

    bool detailed = false;


    private async Task OpenDialogAddOrEditReference()
    {
        var model = new DialogParameters { ["model"] = MoreParameter };
        var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Medium };
        var dialog = await DialogService.ShowAsync<LedgerTransactionsReportMoreParameterDialog>("More parameters", model, options);
        var result = await dialog.Result;
        var isCancelled = result.Canceled;
        if (!isCancelled)
        {
            MoreParameter = (LedgerTransactionsReportMoreParameterModel)result.Data;
            if (MoreParameter.Reference != null && MoreParameter.Reference != "")
            {
                IsMoreParameterHasValues = true;
            }
            else
            {
                IsMoreParameterHasValues = false;
            }
        }
    }

    protected bool Validate()
    {
        if (SelectedBranches == null || !SelectedBranches.Any())
        {
            snackbar.Add("Please select branch.", Severity.Error);
            return false;
        }
        if (StartDate == null)
        {
            snackbar.Add("Please select Start-Date.", Severity.Error);
            return false;
        }
        if (EndDate == null)
        {
            snackbar.Add("Please select End-Date.", Severity.Error);
            return false;
        }
        if (SelectedAccount == null || SelectedAccount.CoaID == null)
        {
            snackbar.Add("Please select Account", Severity.Error);
            return false;
        }
        return true;
    }

    public async Task RenderReportViewer()
    {
        try 
        {
            ShowReport = false;
            StateHasChanged();

            if (Validate())
            {            
                ReportName = detailed ? "FinanceAccountLedgerDetailed" : "FinanceAccountLedger";
                ReportParameters.Clear();
                ReportParameters.Add("BranchIDS", String.Join(',', SelectedBranches));
                ReportParameters.Add("CoaID", SelectedAccount.CoaID.Value.ToString());
                ReportParameters.Add("StartDate", StartDate.Value.ToString("yyyy-MM-dd"));
                ReportParameters.Add("EndDate", EndDate.Value.ToString("yyyy-MM-dd"));
                ReportParameters.Add("Reference", MoreParameter?.Reference ?? "");
                
                ShowReport = true;
                StateHasChanged();
                
                if (report == null)
                {
                    snackbar.Add("Report Viewer not initialized. Please try again.", Severity.Warning);
                    return;
                }

                await report.RenderReport(ReportName);
            }
        }
        catch (Exception ex)
        {
            snackbar.Add("Error loading report: " + ex.Message, Severity.Error);
        }
    }
}
