@page "/FinanceAccountLedgerTransactionReport"
@using ArmsModels.BaseModels.Finance.Report;
@using Microsoft.JSInterop
@using Microsoft.AspNetCore.Components
@using Views.Data;
@using System.Text;
@using System.Net;
@inject AuthenticationStateProvider auth
@inject IBranchService Ibranchservice
@inject ISnackbar Snackbar
@inject IDialogService DialogService

<MudGrid Spacing="4">
    <MudItem xs="12">
        <MudPaper Class="mb-5 p-4">
            <MudGrid>
                <MudItem xs="6" md="6">
                    <CoaSelector @bind-Value="SelectedAccount" LabelName="Select Account" IsFetchAll="true" />
                </MudItem>
                <MudItem xs="6" md="6">
                    <MudSelect Label="Select Branch" Variant="Variant.Outlined" Margin="Margin.Dense" @bind-Value="SelectedBranch" ToStringFunc="@((e)=>e==null?null:e.BranchName)" T="BranchModel" OffsetY="true" Direction="Direction.Top" AdornmentColor="Color.Secondary" Required>
                        @foreach (BranchModel ditem in DestinationBranchList)
                        {
                            <MudSelectItem Value="@ditem">@ditem.BranchName</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="4" md="4">
                    <MudDatePicker Label="Start Date" @bind-Date="@(StartDate)" />
                </MudItem>
                <MudItem xs="4" md="4">
                    <MudDatePicker Label="End Date" @bind-Date="@(EndDate)" />
                </MudItem>
                <MudItem xs="2" md="2">
                    <MudButton Style="margin-top:9%;" Variant="Variant.Filled" Color="@(IsMoreParameterHasValues ?Color.Success:Color.Primary)" OnClick="OpenDialogAddOrEditReference">
                        Add More @(IsMoreParameterHasValues ? "(Has Value)" : "")
                    </MudButton>
                </MudItem>
                <MudItem xs="2" md="2">
                    <MudButton Style="margin-top:9%;" Variant="Variant.Filled" Color="Color.Success" OnClick="RenderReportViewer">View Report</MudButton>
                </MudItem>
            </MudGrid>
        </MudPaper>
    </MudItem>
</MudGrid>
<MudGrid Style="@(ShowReport?"":"Display:none")">
    <MudItem xs="12">
        <ReportViewer ReportName="@ReportName" Parameters=@ReportParameters></ReportViewer>
    </MudItem>
</MudGrid>

@code {

    public Dictionary<string, string> ReportParameters { get; set; } = new();
    public DateTime? StartDate { get; set; } = DateTime.Now;
    public DateTime? EndDate { get; set; } = DateTime.Now;
    public int? BranchID { get; set; } = 0;
    public BranchModel SelectedBranch { get; set; } = new();
    public ChartOfAccountModel SelectedAccount = new();
    public bool ShowReport { get; set; } = false;
    public string ReportName { get; set; }
    public LedgerTransactionsReportMoreParameterModel MoreParameter { get; set; } = new();
    private List<BranchModel> DestinationBranchList = new();
    public bool IsMoreParameterHasValues { get; set; } = false;

    protected override void OnInitialized()
    {
        DestinationBranchList = Ibranchservice.Select().ToList();
    }

    private async Task OpenDialogAddOrEditReference()
    {
        var model = new DialogParameters { ["model"] = MoreParameter };
        var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Medium };
        var dialog = DialogService.Show<LedgerTransactionsReportMoreParameterDialog>("More parameters", model, options);
        var result = await dialog.Result;
        var isCancelled = result.Cancelled;
        if (!isCancelled)
        {
            MoreParameter = (LedgerTransactionsReportMoreParameterModel)result.Data;
            if (MoreParameter.Reference != null && MoreParameter.Reference != "")
            {
                IsMoreParameterHasValues = true;
            }
            else
            {
                IsMoreParameterHasValues = false;
            }
        }
    }

    public void RenderReportViewer()
    {
        if (SelectedAccount == null || SelectedAccount.CoaID == 0)
        {
            Snackbar.Add("Please select account", Severity.Error);
            return;
        }
        if (SelectedAccount == null || SelectedAccount.CoaID == 0)
        {
            Snackbar.Add("Please select account.", Severity.Error);
            return;
        }
        if (SelectedBranch == null || SelectedBranch.BranchID == null)
        {
            Snackbar.Add("Please select branch.", Severity.Error);
            return;
        }
        if (StartDate == null)
        {
            Snackbar.Add("Please select start date.", Severity.Error);
            return;
        }
        if (EndDate == null)
        {
            Snackbar.Add("Please select end date.", Severity.Error);
            return;
        }
        ShowReport = true;
        ReportName = "rpt.Finance.AccountLedgerTransactions";
        ReportParameters.Clear();
        ReportParameters.Add("AccountID", SelectedAccount.CoaID.ToString());
        ReportParameters.Add("BranchID", SelectedBranch.BranchID.ToString());
        ReportParameters.Add("StartDate", StartDate.Value.ToString("yyyy/MM/dd"));
        ReportParameters.Add("EndDate", EndDate.Value.ToString("yyyy/MM/dd"));
        ReportParameters.Add("Reference", MoreParameter != null ? MoreParameter.Reference : "");
    }
}