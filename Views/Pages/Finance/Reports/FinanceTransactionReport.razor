@page "/Daybook"
@inherits ReportComponentBase


<MudGrid>
    <MudItem xs="4" md="2">
        <MudDatePicker Label="Start Date" @bind-Date="@(StartDate)" Variant="Variant.Outlined" Margin="Margin.Dense" />
    </MudItem>
    <MudItem xs="4" md="2">
        <MudDatePicker Label="End Date" @bind-Date="@(EndDate)" Variant="Variant.Outlined" Margin="Margin.Dense" />
    </MudItem>
    <MudItem xs="2" md="2">
        <MudIconButton Title="Select Branch" Icon="@Icons.Material.Filled.List" Variant="Variant.Filled" Color="Color.Success" OnClick="SelectBranches"></MudIconButton>
        <MudIconButton Title="Render Report" Icon="@Icons.Material.Filled.DocumentScanner" Variant="Variant.Filled" Color="Color.Success" OnClick="RenderReportViewer"></MudIconButton>
    </MudItem>
</MudGrid>
<MudGrid Style="@(ShowReport?"":"Display:none")">
    <MudItem xs="12">
        <ReportViewer ReportName="@ReportName" Parameters=@ReportParameters @ref="@report"></ReportViewer>
    </MudItem>
</MudGrid>

@code {
    ReportViewer report;

    public DateTime? StartDate { get; set; } = DateTime.Now;
    public DateTime? EndDate { get; set; } = DateTime.Now;
    public bool ShowReport { get; set; } = false;
    public string ReportName { get; set; }



    public async Task RenderReportViewer()
    {
        ReportName = "FinanceDaybook";
        if (!SelectedBranches.Any() || SelectedBranches.Count > 1)
        {
            snackbar.Add("Please select One Branch!.", Severity.Warning);
            return;
        }
        if (StartDate == null)
        {
            snackbar.Add("Please select start date.", Severity.Error);
            return;
        }
        if (EndDate == null)
        {
            snackbar.Add("Please select end date.", Severity.Error);
            return;
        }

        ShowReport = true;
        ReportParameters.Clear();
        ReportParameters.Add("BranchID", SelectedBranches.First().ToString());
        ReportParameters.Add("StartDate", StartDate.Value.ToString("yyyy/MM/dd"));
        ReportParameters.Add("EndDate", EndDate.Value.ToString("yyyy/MM/dd"));
        await report.RenderReport();
    }
}
