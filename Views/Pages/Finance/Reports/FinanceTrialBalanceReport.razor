@page "/FinanceTrialBalanceReport"
@inherits ReportComponentBase

<div class="fade-in">
    <div class="admin-header-tiered mb-6">
        <div class="d-flex align-center justify-space-between">
            <div>
                <MudText Typo="Typo.h4" Class="admin-title">Trial Balance Report</MudText>
                <MudText Typo="Typo.body2" Class="admin-subtitle">Verification of accounting equality across all ledger heads. Ensure debit and credit balances are in parity for accurate financial reporting.</MudText>
            </div>
        </div>
    </div>

    <div class="admin-glass-card mb-6 pa-6">
        <MudGrid Spacing="4" Class="align-center">
            <MudItem xs="12" sm="3">
                <MudDatePicker Label="From Date" @bind-Date="@StartDate" Variant="Variant.Outlined" Margin="Margin.Dense" Class="admin-input-group" />
            </MudItem>
            <MudItem xs="12" sm="3">
                <MudDatePicker Label="To Date" @bind-Date="@EndDate" Variant="Variant.Outlined" Margin="Margin.Dense" Class="admin-input-group" />
            </MudItem>
            <MudItem xs="12" sm="3">
                <div class="d-flex flex-column gap-1">
                    <MudCheckBox T="bool" @bind-Value="@ShowAllHeads" Color="Color.Primary" Dense="true" Label="Show All Heads" />
                    <MudCheckBox T="bool" @bind-Value="@Columnar" Color="Color.Secondary" Dense="true" Label="Columnar Format" />
                </div>
            </MudItem>
            <MudItem xs="12" sm="3" Class="d-flex align-center gap-2">
                <MudTooltip Text="Select Branches">
                    <MudIconButton Icon="@Icons.Material.Filled.List" Variant="Variant.Filled" Color="Color.Success" OnClick="SelectBranches" Class="rounded-lg" />
                </MudTooltip>
                <MudButton FullWidth="true" Variant="Variant.Filled" Color="Color.Primary" OnClick="RenderReportViewer" Class="admin-register-btn">VIEW REPORT</MudButton>
            </MudItem>
        </MudGrid>
    </div>

    <div class="admin-glass-card pa-0 overflow-hidden shadow-sm @(ShowReport ? "" : "d-none")">
        <ReportViewer ReportName="@ReportName" Parameters=@ReportParameters @ref="@report"></ReportViewer>
    </div>
</div>

@code {
    
    ReportViewer report;
    public DateTime? StartDate { get; set; } = DateTime.Now;
    public DateTime? EndDate { get; set; } = DateTime.Now;
    public BranchModel CurrentBranch { get; set; } = new();
    public bool ShowReport { get; set; } = false;
    public string ReportName { get; set; } = "FinanceTrialBalance";
    bool ShowAllHeads;
    bool Columnar;

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();
        var authprov = await auth.GetAuthenticationStateAsync();
        var User = authprov.User;
        CurrentBranch.BranchName = User.Claims.First(x => x.Type == "BranchName").Value;
    }

    protected bool Validate()
    {
        if (!SelectedBranches.Any())
        {
            snackbar.Add("Please select branch.", Severity.Error);
            return false;
        }
        if (StartDate == null)
        {
            snackbar.Add("Please select Start-Date.", Severity.Error);
            return false;
        }
        if (EndDate == null)
        {
            snackbar.Add("Please select End-Date.", Severity.Error);
            return false;
        }
        return true;
    }

    public async Task RenderReportViewer()
    {
        if (Validate())
        {           
            ReportName = Columnar ? "FinanceTrialBalanceColumnar" : "FinanceTrialBalance";
            ReportParameters.Clear();
            ReportParameters.Add("ShowAllHeads", ShowAllHeads.ToString());
            ReportParameters.Add("BranchIDS", String.Join(',', SelectedBranches));
            ReportParameters.Add("BranchName", CurrentBranch.BranchName);
            ReportParameters.Add("StartDate", StartDate.Value.ToString("yyyy-MM-dd"));
            ReportParameters.Add("EndDate", EndDate.Value.ToString("yyyy-MM-dd"));
            ShowReport = true;
            await report.RenderReport(ReportName);           
        }
    }
}
