@page "/FinanceTrialBalanceReport"
@inherits ReportComponentBase

<MudText Typo="Typo.h4"> Trial Balance </MudText>
<MudGrid Spacing="4">
    <MudItem xs="12">
        <MudPaper Class="mb-5 p-4">
            <MudGrid>
                <MudItem xs="3">
                    <MudDatePicker Label="From Date" @bind-Date="@(StartDate)" Variant="Variant.Outlined" Margin="Margin.Dense" />
                </MudItem>
                <MudItem xs="3">
                    <MudDatePicker Label="To Date" @bind-Date="@(EndDate)" Variant="Variant.Outlined" Margin="Margin.Dense" />
                </MudItem>
                <MudItem xs="3">
                    <MudCheckBox @bind-Checked="@(ShowAllHeads)" Dense  Label="Show All Heads" />
                </MudItem>
                <MudItem xs="2">
                    <MudIconButton Title="Select Branches" Icon="@Icons.Material.Filled.List" Variant="Variant.Filled" Color="Color.Success" OnClick="SelectBranches"></MudIconButton>
                    <MudIconButton Title="Render Report" Icon="@Icons.Material.Filled.DocumentScanner" Variant="Variant.Filled" Color="Color.Success" OnClick="RenderReportViewer"></MudIconButton>
                </MudItem>
            </MudGrid>
        </MudPaper>
    </MudItem>
</MudGrid>

<MudGrid Style="@(ShowReport?"":"Display:none")">
    <MudItem xs="12">
        <ReportViewer ReportName="@ReportName" Parameters=@ReportParameters></ReportViewer>
    </MudItem>
</MudGrid>

@code {

    public DateTime? StartDate { get; set; } = DateTime.Now;
    public DateTime? EndDate { get; set; } = DateTime.Now;      
    public BranchModel CurrentBranch { get; set; } = new();
    public bool ShowReport { get; set; } = false;
    public string ReportName { get; set; }
    bool ShowAllHeads;

    protected override void OnInitialized()
    {

    }

    protected bool Validate()
    {
        if (!SelectedBranches.Any())
        {
            snackbar.Add("Please select branch.", Severity.Error);
            return false;
        }
        if (StartDate == null)
        {
            snackbar.Add("Please select Start-Date.", Severity.Error);
            return false;
        }
        if (EndDate == null)
        {
            snackbar.Add("Please select End-Date.", Severity.Error);
            return false;
        }
        return true;
    }

    public void RenderReportViewer()
    {
        if (Validate())
        {
            ShowReport = true;
            ReportName = "FinanceTrialBalance";
            ReportParameters.Clear();
            ReportParameters.Add("ShowAllHeads", ShowAllHeads.ToString());
            ReportParameters.Add("BranchIDS", String.Join(',', SelectedBranches));
            ReportParameters.Add("StartDate", StartDate.Value.ToString("yyyy/MM/dd"));
            ReportParameters.Add("EndDate", EndDate.Value.ToString("yyyy/MM/dd"));
        }
    }
}