@page "/FinanceTrialBalanceReport"
@using Microsoft.JSInterop
@using Microsoft.AspNetCore.Components
@using Views.Data;
@using System.Text;
@using System.Net;
@attribute [Authorize]
@inject AuthenticationStateProvider auth
@inject IBranchService Ibranchservice
@inject ISnackbar Snackbar

<MudGrid Spacing="4">
    <MudItem xs="12">
        <MudPaper Class="mb-5 p-4">
            <MudGrid>
                <MudItem xs="12">
                    <MudSelect T="string" Label="Select Branch" MultiSelection="true" MultiSelectionTextFunc="@(new Func<List<string>, string>(GetMultiSelectionText))"
                               Variant="Variant.Outlined" Margin="Margin.Dense" @bind-Value="BranchID" @bind-SelectedValues="BranchIDS" OffsetY="true" AnchorOrigin="Origin.BottomCenter"
                               AdornmentColor="Color.Secondary" Required>
                        @foreach (BranchModel ditem in BranchList)
                        {
                            <MudSelectItem T="string" Value="@(ditem.BranchID.Value.ToString())">@ditem.BranchName</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="5">
                    <MudDatePicker Label="Start Date" @bind-Date="@(StartDate)" Variant="Variant.Outlined" Margin="Margin.Dense" />
                </MudItem>
                <MudItem xs="5">
                    <MudDatePicker Label="End Date" @bind-Date="@(EndDate)" Variant="Variant.Outlined" Margin="Margin.Dense" />
                </MudItem>
                <MudItem xs="2">
                    <MudButton Style="margin-top: 4px; width:-webkit-fill-available" Variant="Variant.Filled" Color="Color.Success" OnClick="RenderReportViewer">View Report</MudButton>
                </MudItem>
            </MudGrid>
        </MudPaper>
    </MudItem>
</MudGrid>
<MudGrid Style="@(ShowReport?"":"Display:none")">
    <MudItem xs="12">
        <ReportViewer ReportName="@ReportName" Parameters=@ReportParameters></ReportViewer>
    </MudItem>
</MudGrid>

@code {

    public Dictionary<string, string> ReportParameters { get; set; } = new();
    public DateTime? StartDate { get; set; } = DateTime.Now;
    public DateTime? EndDate { get; set; } = DateTime.Now;
    public string BranchID { get; set; } = "";
    public bool ShowReport { get; set; } = false;
    public string ReportName { get; set; }
    private IEnumerable<string> BranchIDS { get; set; } = new HashSet<string>() { };

    private List<BranchModel> BranchList = new();

    protected override void OnInitialized()
    {
        BranchList = Ibranchservice.Select().ToList();
    }

    private string GetMultiSelectionText(List<string> selectedValues)
    {
        string Result = "";
        foreach (var item in selectedValues)
        {
            if (BranchList.Any(s => s.BranchID.Value.ToString() == item))
            {
                if (Result == "")
                {
                    Result = BranchList.FirstOrDefault(s => s.BranchID.Value.ToString() == item).BranchName;
                }
                else
                {
                    Result = Result + ", " + BranchList.FirstOrDefault(s => s.BranchID.Value.ToString() == item).BranchName;
                }
            }
        }
        return Result;
    }

    public void RenderReportViewer()
    {
        ShowReport = true;
        string branches = String.Join(',', BranchIDS);
        ReportName = "TrialBalanceReport";
        ReportParameters.Clear();
        ReportParameters.Add("BranchIDS", branches);
        ReportParameters.Add("StartDate", StartDate.Value.ToString("yyyy/MM/dd"));
        ReportParameters.Add("EndDate", EndDate.Value.ToString("yyyy/MM/dd"));
    }
}