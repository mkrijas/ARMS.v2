@page "/financialstatements"
@inherits ReportComponentBase
@using ArmsModels.BaseModels.Finance.Report;
@inject IDialogService DialogService

<div class="fade-in">
    <div class="admin-header-tiered mb-6">
        <div class="d-flex align-center justify-space-between">
            <div>
                <MudText Typo="Typo.h4" Class="admin-title">Financial Statements</MudText>
                <MudText Typo="Typo.body2" Class="admin-subtitle">Core accounting declarations for the organization. Generate Profit & Loss statements and Balance Sheets for fiscal health assessment.</MudText>
            </div>
            <MudRadioGroup T="string" Value="ReportName" ValueChanged="ReportNameChanged" Class="admin-glass-card pa-2 d-flex gap-4">
                <MudRadio Value="@("ProfitnLoss")" Color="Color.Primary" UnCheckedColor="Color.Default" Size="Size.Small">P&L State</MudRadio>
                <MudRadio Value="@("BalanceSheet")" Color="Color.Secondary" UnCheckedColor="Color.Default" Size="Size.Small">Balance Sheet</MudRadio>
                @* <MudRadio Value="@("FundFlow")" Color="Color.Tertiary" UnCheckedColor="Color.Default" Size="Size.Small">Fund Flow</MudRadio> *@
            </MudRadioGroup>
        </div>
    </div>

    <div class="admin-glass-card mb-6 pa-6">
        <MudGrid Spacing="4" Class="align-center">
            <MudItem xs="12" sm="4">
                <MudDatePicker Disabled="@StartDateDisabled" Label="Start Date" @bind-Date="@StartDate" Variant="Variant.Outlined" Margin="Margin.Dense" Class="admin-input-group" />
            </MudItem>
            <MudItem xs="12" sm="4">
                <MudDatePicker Label="End Date" @bind-Date="@EndDate" Variant="Variant.Outlined" Margin="Margin.Dense" Class="admin-input-group" />
            </MudItem>
            <MudItem xs="12" sm="4" Class="d-flex align-center gap-2">
                <MudTooltip Text="Select Branches">
                    <MudIconButton Icon="@Icons.Material.Filled.List" Variant="Variant.Filled" Color="Color.Success" OnClick="SelectBranches" Class="rounded-lg" />
                </MudTooltip>
                <MudButton FullWidth="true" Variant="Variant.Filled" Color="Color.Primary" OnClick="RenderReportViewer" Class="admin-register-btn">VIEW REPORT</MudButton>
            </MudItem>
        </MudGrid>
    </div>

    <div class="admin-glass-card pa-0 overflow-hidden shadow-sm @(ShowReport ? "" : "d-none")">
        <ReportViewer ReportName="@ReportName" Parameters=@ReportParameters @ref="@report"></ReportViewer>
    </div>
</div>

@code {

    ReportViewer report;
    DateTime? StartDate { get; set; } = DateTime.Now;
    DateTime? EndDate { get; set; } = DateTime.Now;    
    bool ShowReport { get; set; } = false;
    string ReportName { get; set; }

    bool StartDateDisabled = false;


    protected bool Validate()
    {
        if (!SelectedBranches.Any())
        {
            snackbar.Add("Please select branch.", Severity.Error);
            return false;
        }
        if (StartDate == null)
        {
            snackbar.Add("Please select Start-Date.", Severity.Error);
            return false;
        }
        if (EndDate == null)
        {
            snackbar.Add("Please select End-Date.", Severity.Error);
            return false;
        }

        return true;
    }

    void ReportNameChanged(string name)
    {
        ReportName = name;
        StartDateDisabled = name == "BalanceSheet";
        ShowReport = false;
    }
    public async Task RenderReportViewer()
    {
        ShowReport = false;
        if (Validate())
        {   
            ReportParameters.Clear();
            ReportParameters.Add("BranchIDS", String.Join(',', SelectedBranches));
            if (ReportName != "BalanceSheet")
            {
                ReportParameters.Add("FromDate", StartDate.Value.ToString("yyyy-MM-dd"));
            }
            ReportParameters.Add("ToDate", EndDate.Value.ToString("yyyy-MM-dd"));
            ShowReport = true;
            await report.RenderReport(ReportName);
        }
    }
}
