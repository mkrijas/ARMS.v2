@page "/GstrReports"
@inherits ReportComponentBase

<div class="fade-in">
    <div class="admin-header-tiered mb-6">
        <div class="d-flex align-center justify-space-between">
            <div>
                <MudText Typo="Typo.h4" Class="admin-title">GSTR Compliance Reports</MudText>
                <MudText Typo="Typo.body2" Class="admin-subtitle">Taxation audits for GST filing. Generate Nature, Rate, or Invoice-wise reports for GSTR-1 and GSTR-2 compliance.</MudText>
            </div>
            <MudRadioGroup Value="@ReportGroup" T="string" ValueChanged="@ReportGroupChanged" Class="admin-glass-card pa-2 d-flex gap-4">
                <MudRadio Value="@("GstrOne")" Color="Color.Primary" UnCheckedColor="Color.Default" Size="Size.Small">GSTR-1</MudRadio>
                <MudRadio Value="@("GstrTwo")" Color="Color.Secondary" UnCheckedColor="Color.Default" Size="Size.Small">GSTR-2</MudRadio>
            </MudRadioGroup>
        </div>
    </div>

    <div class="admin-glass-card mb-6 pa-6">
        <MudGrid Spacing="4" Class="align-center">
            <MudItem xs="12" sm="4">
                <MudRadioGroup Value="@ReportType" T="string" ValueChanged="@ReportTypeChanged" Class="d-flex gap-4">
                    <MudRadio Value="@("Nature")" Color="Color.Primary" Dense="true">Nature-wise</MudRadio>
                    <MudRadio Value="@("Rate")" Color="Color.Secondary" Dense="true">Rate-wise</MudRadio>
                    <MudRadio Value="@("Invoice")" Color="Color.Tertiary" Dense="true">Invoice-wise</MudRadio>
                </MudRadioGroup>
            </MudItem>
            <MudItem xs="12" sm="2">
                <MudDatePicker Label="From Date" @bind-Date="@FromDate" Variant="Variant.Outlined" Margin="Margin.Dense" Class="admin-input-group" />
            </MudItem>
            <MudItem xs="12" sm="2">
                <MudDatePicker Label="To Date" @bind-Date="@ToDate" Variant="Variant.Outlined" Margin="Margin.Dense" Class="admin-input-group" />
            </MudItem>
            <MudItem xs="12" sm="4" Class="d-flex align-center gap-2">
                <MudTooltip Text="Select Branches">
                    <MudIconButton Icon="@Icons.Material.Filled.List" Variant="Variant.Filled" Color="Color.Success" OnClick="SelectBranches" Class="rounded-lg" />
                </MudTooltip>
                <MudButton FullWidth="true" Variant="Variant.Filled" Color="Color.Primary" OnClick="RenderReportViewer" Class="admin-register-btn">VIEW REPORT</MudButton>
            </MudItem>
        </MudGrid>
    </div>

    <div class="admin-glass-card pa-0 overflow-hidden shadow-sm @(ShowReport ? "" : "d-none")">
        <ReportViewer ReportName="@ReportName" Parameters=@ReportParameters @ref="@report"></ReportViewer>
    </div>
</div>

@code {

    ReportViewer report;
    public bool ShowReport { get; set; } = false;
    public string ReportName { get; set; } = "GstrOne_Nature";
    private string ReportGroup = "GstrOne";
    private string ReportType  = "Nature";
    public BranchModel CurrentBranch { get; set; } = new();
    public DateTime? FromDate { get; set; } = DateTime.Now;
    public DateTime? ToDate { get; set; } = DateTime.Now;

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();
        var authState = await auth.GetAuthenticationStateAsync();
        var User = authState.User;
        CurrentBranch.BranchName = User.Claims.First(x => x.Type == "BranchName").Value;
    }

    protected void ReportGroupChanged(string val)
    {
        ReportGroup = val;
        ReportName = ReportGroup + "_" + ReportType;
    }

     protected void ReportTypeChanged(string val)
    {
        ReportType = val;
        ReportName = ReportGroup + "_" + ReportType;
    }

    protected bool Validate()
    {
        if (!SelectedBranches.Any())
        {
            snackbar.Add("Please select branch.", Severity.Error);
            return false;
        }

        if (FromDate == null)
        {
            snackbar.Add("Please select From Date.", Severity.Error);
            return false;
        }
        if (ToDate == null)
        {
            snackbar.Add("Please select To Date.", Severity.Error);
            return false;
        }
        return true;
    }

    public async Task RenderReportViewer()
    {
        try
        {
            if (Validate())
            {                
                      
                ReportParameters.Clear();
                ReportParameters.Add("BranchIDS", String.Join(',', SelectedBranches));
                ReportParameters.Add("BranchName", CurrentBranch.BranchName);
                ReportParameters.Add("From", FromDate.Value.ToString("yyyy-MM-dd"));
                ReportParameters.Add("To", ToDate.Value.ToString("yyyy-MM-dd"));
                StateHasChanged();
                await report.RenderReport(ReportName);
                ShowReport = true;
                
            }
        }
        catch (Exception ex)
        {
            snackbar.Add(ex.Message, Severity.Error);
        }
    }
}
