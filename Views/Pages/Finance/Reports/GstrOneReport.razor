@page "/GstrReports"
@inherits ReportComponentBase

<MudGrid Spacing="4">
    <MudItem xs="12">
        <MudPaper Class="mb-5 p-4">
            <MudToolBar Style="padding-left: 0px; margin-top: -22px;">
                <MudText Typo="Typo.h5" Style="font-weight:500;">GSTR Reports</MudText>                
            </MudToolBar>
            <MudRadioGroup Value="@ReportGroup" T="string" ValueChanged="@ReportGroupChanged" Style="text-align: center;">
                <MudRadio Value="@("GstrOne")" Color="Color.Primary" Dense="true">Gstr1</MudRadio>
                <MudRadio Value="@("GstrTwo")" Color="Color.Secondary" Dense="true">Gstr2</MudRadio>
            </MudRadioGroup>
            <MudDivider />
            <MudGrid Style="padding-top: 22px;">
                <MudItem xs="4">
                    <MudRadioGroup Value="@ReportType" T="string" ValueChanged="@ReportTypeChanged" Style="text-align: center;">
                        <MudRadio Value="@("Nature")" Color="Color.Primary" Dense="true">Nature</MudRadio>
                        <MudRadio Value="@("Rate")" Color="Color.Secondary" Dense="true">Rate</MudRadio>
                        <MudRadio Value="@("Invoice")" Color="Color.Tertiary" Dense="true">Invoice</MudRadio>
                    </MudRadioGroup>
                </MudItem>
                <MudItem xs="3">
                    <MudDatePicker Label="From Date" @bind-Date="@(FromDate)" Variant="Variant.Outlined" Margin="Margin.Dense" />
                </MudItem>
                <MudItem xs="3">
                    <MudDatePicker Label="To Date" @bind-Date="@(ToDate)" Variant="Variant.Outlined" Margin="Margin.Dense" />
                </MudItem>
                <MudItem xs="2" Style="display: flex; align-items: center;">
                    <MudIconButton Style="margin-right: 8px;" Title="Select Branches" Icon="@Icons.Material.Filled.List" Variant="Variant.Filled" Color="Color.Success" OnClick="SelectBranches"></MudIconButton>
                    <MudButton Style="width: -webkit-fill-available;" Variant="Variant.Filled" Color="Color.Success" OnClick="RenderReportViewer">View Report</MudButton>
                </MudItem>
            </MudGrid>
        </MudPaper>
    </MudItem>
</MudGrid>
<MudGrid Style="@(ShowReport?"":"Display:none")">
    <MudItem xs="12">
        <ReportViewer ReportName="@ReportName" Parameters=@ReportParameters @ref="@report"></ReportViewer>
    </MudItem>
</MudGrid>

@code {

    ReportViewer report;
    public bool ShowReport { get; set; } = false;
    public string ReportName { get; set; } = "GstrOne_Nature";
    private string ReportGroup = "GstrOne";
    private string ReportType  = "Nature";
    public BranchModel CurrentBranch { get; set; } = new();
    public DateTime? FromDate { get; set; } = DateTime.Now;
    public DateTime? ToDate { get; set; } = DateTime.Now;

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();
        var authState = await auth.GetAuthenticationStateAsync();
        var User = authState.User;
        CurrentBranch.BranchName = User.Claims.First(x => x.Type == "BranchName").Value;
    }

    protected void ReportGroupChanged(string val)
    {
        ReportGroup = val;
        ReportName = ReportGroup + "_" + ReportType;
    }

     protected void ReportTypeChanged(string val)
    {
        ReportType = val;
        ReportName = ReportGroup + "_" + ReportType;
    }

    protected bool Validate()
    {
        if (!SelectedBranches.Any())
        {
            snackbar.Add("Please select branch.", Severity.Error);
            return false;
        }

        if (FromDate == null)
        {
            snackbar.Add("Please select From Date.", Severity.Error);
            return false;
        }
        if (ToDate == null)
        {
            snackbar.Add("Please select To Date.", Severity.Error);
            return false;
        }
        return true;
    }

    public async Task RenderReportViewer()
    {
        try
        {
            if (Validate())
            {                
                      
                ReportParameters.Clear();
                ReportParameters.Add("BranchIDS", String.Join(',', SelectedBranches));
                ReportParameters.Add("BranchName", CurrentBranch.BranchName);
                ReportParameters.Add("From", FromDate.Value.ToString("yyyy/MM/dd"));
                ReportParameters.Add("To", ToDate.Value.ToString("yyyy/MM/dd"));      
                StateHasChanged();
                await report.RenderReport();
                ShowReport = true;
                
            }
        }
        catch (Exception ex)
        {
            snackbar.Add(ex.Message, Severity.Error);
        }
    }
}
