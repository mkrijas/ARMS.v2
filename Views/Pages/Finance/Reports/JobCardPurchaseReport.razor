@page "/JobCardPurchaseReport"
@inject ISnackbar Snackbar
@attribute [Authorize]
@inherits ReportComponentBase

<div class="fade-in">
    <div class="admin-header-tiered mb-6">
        <div class="d-flex align-center justify-space-between">
            <div>
                <MudText Typo="Typo.h4" Class="admin-title">Job Card Purchase Report</MudText>
                <MudText Typo="Typo.body2" Class="admin-subtitle">Inventory and service audit for vehicle maintenance. Track parts purchase, repairs consumption, and work order types across the fleet.</MudText>
            </div>
        </div>
    </div>

    <div class="admin-glass-card mb-6 pa-6">
        <MudGrid Spacing="4" Class="align-center">
            <MudItem xs="12" sm="3">
                <MudSelect For="@(() => coaGroup)" @bind-Value="@coaGroup" Label="Select Type" Variant="Variant.Outlined" Margin="Margin.Dense" AnchorOrigin="Origin.BottomCenter" Class="admin-input-group">
                    <MudSelectItem Value="@("All")">All Types</MudSelectItem>
                    <MudSelectItem Value="@("Repairs")">Repairs</MudSelectItem>
                    <MudSelectItem Value="@("Purchase")">Purchase</MudSelectItem>
                    <MudSelectItem Value="@("Consumption")">Consumption</MudSelectItem>
                </MudSelect>
            </MudItem>
            <MudItem xs="12" sm="3">
                <MudSelect For="@(() => breakdownType)" @bind-Value="@breakdownType" Label="Work Order Type" Variant="Variant.Outlined" Margin="Margin.Dense" AnchorOrigin="Origin.BottomCenter" Class="admin-input-group">
                    <MudSelectItem Value="@("All")">All Work Orders</MudSelectItem>
                    <MudSelectItem Value="@("Accident Claim")">Accident Claim</MudSelectItem>
                    <MudSelectItem Value="@("Accident Non Claim")">Accident Non Claim</MudSelectItem>
                    <MudSelectItem Value="@("Work Order")">Work Order</MudSelectItem>
                    <MudSelectItem Value="@("General Service")">General Service</MudSelectItem>
                    <MudSelectItem Value="@("FC Work")">FC Work</MudSelectItem>
                    <MudSelectItem Value="@("Periodic Service")">Periodic Service</MudSelectItem>
                    <MudSelectItem Value="@("Special Work")">Special Work</MudSelectItem>
                    <MudSelectItem Value="@("Tyre Work")">Tyre Work</MudSelectItem>
                    <MudSelectItem Value="@("Engine Work")">Engine Work</MudSelectItem>
                    <MudSelectItem Value="@("Body Work")">Body Work</MudSelectItem>
                    <MudSelectItem Value="@("Gear Box Work")">Gear Box Work</MudSelectItem>
                    <MudSelectItem Value="@("Differential Work")">Differential Work</MudSelectItem>
                    <MudSelectItem Value="@("Clutch Work")">Clutch Work</MudSelectItem>
                    <MudSelectItem Value="@("Battery")">Battery</MudSelectItem>
                </MudSelect>
            </MudItem>
            <MudItem xs="12" sm="2">
                <MudDatePicker Label="From Date" @bind-Date="@FromDate" Variant="Variant.Outlined" Margin="Margin.Dense" Class="admin-input-group" />
            </MudItem>
            <MudItem xs="12" sm="2">
                <MudDatePicker Label="To Date" @bind-Date="@ToDate" Variant="Variant.Outlined" Margin="Margin.Dense" Class="admin-input-group" />
            </MudItem>
            <MudItem xs="12" sm="2" Class="d-flex align-center gap-2">
                <MudTooltip Text="Select Branches">
                    <MudIconButton Icon="@Icons.Material.Filled.List" Variant="Variant.Filled" Color="Color.Success" OnClick="SelectBranches" Class="rounded-lg" />
                </MudTooltip>
                <MudButton FullWidth="true" Variant="Variant.Filled" Color="Color.Primary" OnClick="RenderReportViewer" Class="admin-register-btn">VIEW REPORT</MudButton>
            </MudItem>
        </MudGrid>
    </div>

    <div class="admin-glass-card pa-0 overflow-hidden shadow-sm @(ShowReport ? "" : "d-none")">
        <ReportViewer ReportName="@ReportName" Parameters=@ReportParameters @ref="@report"></ReportViewer>
    </div>
</div>

@code {
    ReportViewer report;   
    public DateTime? FromDate { get; set; } = DateTime.Now;
    public DateTime? ToDate { get; set; } = DateTime.Now;
    public bool ShowReport { get; set; } = false;
    public string ReportName { get; set; }   
    private ChartOfAccountModel Coa = new();
    string coaGroup = "All";
    string breakdownType = "All";

    // protected override async Task OnInitializedAsync()
    // {
    //     await base.OnInitializedAsync();
    //     var authState = await auth.GetAuthenticationStateAsync();
    //     branch = int.Parse(authState.User.Claims.FirstOrDefault(x => x.Type == "BranchID").Value);
    // }

    public async Task RenderReportViewer()
    {
        if (FromDate == null)
        {
            Snackbar.Add("Please select From Date.", Severity.Error);
            return;
        }
        if (ToDate == null)
        {
            Snackbar.Add("Please select To Date.", Severity.Error);
            return;
        }

        ShowReport = true;
        ReportName = "JobCardPurchaseReport";
        ReportParameters.Clear();        
        ReportParameters.Add("BranchIDS", String.Join(',', SelectedBranches));
        ReportParameters.Add("FromDate", FromDate.Value.ToString("yyyy-MM-dd"));
        ReportParameters.Add("ToDate", ToDate.Value.ToString("yyyy-MM-dd"));
        ReportParameters.Add("CoaGroup", coaGroup);
        ReportParameters.Add("BreakdownType", breakdownType);
        await report.RenderReport(ReportName);
    }
}
