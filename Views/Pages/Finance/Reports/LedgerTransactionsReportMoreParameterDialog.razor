@using ArmsModels.BaseModels.Finance.Report;
@inject MudBlazor.ISnackbar snackbar
@inject AuthenticationStateProvider auth
@attribute [Authorize]
@inject IDialogService DialogService

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.Build" Class="mr-3 mb-n1" />
            More Parameters
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudContainer Style="min-height:300px;max-height: 800px;">
            <EditForm id="formMoreValuesSubmit" Model="@model" OnValidSubmit="OnValidSubmit">
                <MudGrid Spacing="2">
                    <MudItem xs="6" md="6">
                        <MudTextField @bind-Value="model.Reference" Label="Reference" Variant="Variant.Outlined" Margin="Margin.Normal" For="@(() => model.Reference)"> Reference</MudTextField>
                    </MudItem>
                </MudGrid>
            </EditForm>
        </MudContainer>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton form="formMoreValuesSubmit" Variant="Variant.Filled" Color="Color.Success" ButtonType="ButtonType.Submit">Submit</MudButton>
    </DialogActions>
</MudDialog>

@code {

    [Parameter]
    public LedgerTransactionsReportMoreParameterModel model { get; set; }
    [CascadingParameter] MudDialogInstance MudDialog { get; set; }

    protected override void OnInitialized()
    {

    }

    private void OnValidSubmit(EditContext context)
    {
        MudDialog.Close(model);
    }

    private void Cancel()
    {
        MudDialog.Cancel();
    }
}