@page "/OutstandingBills"
@attribute [Authorize]
@inherits ReportComponentBase

<MudGrid Spacing="4">
    <MudItem xs="12">
        <MudPaper Class="mb-5 p-4">
            <MudToolBar Style="padding-left: 0px; margin-top: -22px;">
                <MudText Typo="Typo.h5" Style="font-weight:500;">Outstanding Bills Ageing Report</MudText>
            </MudToolBar>
            <MudDivider />
            <MudGrid Style="padding-top: 22px;">     
                <MudItem xs="2" Style="display: flex; align-items: center;">
                    <MudRadioGroup T="string" @bind-Value="@drcr">
                        <MudRadio Value="@("Credit")" Color="Color.Primary">Credit </MudRadio>
                        <MudRadio Value="@("Debit")" Color="Color.Primary">Debit</MudRadio>                       
                    </MudRadioGroup>                    
               </MudItem>
                <MudItem xs="2" Style="display: flex; align-items: center;"> 
                        <MudNumericField HideSpinButtons @bind-Value="Interval" Label="Interval(Days)" Variant="Variant.Outlined" Margin="Margin.Dense"></MudNumericField>
                </MudItem>
                <MudItem xs="2" Style="display: flex; align-items: center;"> 
                    <PartySelector @bind-Value="party"></PartySelector>
                    </MudItem>
                <MudItem xs="2" Style="display: flex; align-items: center;">
                    <MudDatePicker Label="As On" Variant="Variant.Outlined" Margin="Margin.Dense" DisableToolbar="true" Editable="true" @bind-Date="DateVar" DateFormat="dd/MM/yyyy" />
                </MudItem>
                <MudItem xs="4" Style="display: flex; align-items: center;">
                    <MudCheckBox @bind-Value="@IncludeMemos" Label="Include Memos"></MudCheckBox>
                    <MudCheckBox @bind-Value = "@summary" Label="Summarized"></MudCheckBox>
                    <MudIconButton Style="margin-right: 8px;" Title="Select Branches" Icon="@Icons.Material.Filled.List" Variant="Variant.Filled" Color="Color.Success" OnClick="SelectBranches"></MudIconButton>
                    <MudButton Style="width: -webkit-fill-available;" Variant="Variant.Filled" Color="Color.Success" OnClick="RenderReportViewer">View Report</MudButton>
                </MudItem>
            </MudGrid>
        </MudPaper>
    </MudItem>
</MudGrid>
<MudGrid Style="@(ShowReport?"":"Display:none")">
    <MudItem xs="12">
        <ReportViewer ReportName="@ReportName" Parameters=@ReportParameters @ref="@report"></ReportViewer>
    </MudItem>
</MudGrid>

@code {

    ReportViewer report;
    public bool ShowReport { get; set; } = false;
    public string ReportName { get; set; }  

    string drcr = "Credit";
    int Interval = 30;
    PartyModel party = new PartyModel();
    DateTime? DateVar = DateTime.Today;
    bool summary = true;
    bool IncludeMemos = false; 

    protected bool Validate()
    {
        if (!SelectedBranches.Any())
        {
            snackbar.Add("Please select branch.", Severity.Error);
            return false;
        }      

        if(Interval == 0 )
        {
            snackbar.Add("Please Type a valid integer for Interval!.", Severity.Error);
            return false;
        }
        return true;
    }

    public async Task RenderReportViewer()
    {
        try
        {
            if (Validate())
            {
                ReportParameters.Clear();

                if(summary)
                {
                    ReportName = "OutstandingBillsAgeSummary";
                }
                else
                {
                    ReportName = "OutstandingBillsAge";                    
                }
                ReportParameters.Add("BranchIDS", String.Join(',', SelectedBranches));
                ReportParameters.Add("DrCr", drcr);
                ReportParameters.Add("Interval", Interval.ToString());
                ReportParameters.Add("Date", DateVar.Value.ToString("yyyy/MM/dd"));
                ReportParameters.Add("PartyID", (party?.PartyID??0).ToString());
                ReportParameters.Add("IncludeMemos", IncludeMemos.ToString());
                ShowReport = true; 
              
                await report.RenderReport();
            }
        }
        catch (Exception ex)
        {
            snackbar.Add(ex.Message, Severity.Error);
        }
    }
}
