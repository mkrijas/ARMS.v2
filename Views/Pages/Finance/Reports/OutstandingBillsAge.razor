@page "/OutstandingBills"
@attribute [Authorize]
@inherits ReportComponentBase

<div class="fade-in">
    <div class="admin-header-tiered mb-6">
        <div class="d-flex align-center justify-space-between">
            <div>
                <MudText Typo="Typo.h4" Class="admin-title">Outstanding Bills Ageing Report</MudText>
                <MudText Typo="Typo.body2" Class="admin-subtitle">Analysis of pending receivables and payables by duration. Track credit/debit ageing to manage cash flow and collection efficiency.</MudText>
            </div>
        </div>
    </div>

    <div class="admin-glass-card mb-6 pa-6">
        <MudGrid Spacing="4" Class="align-center">
            <MudItem xs="12" sm="2">
                <MudRadioGroup T="string" @bind-Value="@drcr" Class="d-flex flex-column gap-1">
                    <MudRadio Value="@("Credit")" Color="Color.Primary" Dense="true">Credit-Age</MudRadio>
                    <MudRadio Value="@("Debit")" Color="Color.Secondary" Dense="true">Debit-Age</MudRadio>
                </MudRadioGroup>
            </MudItem>
            <MudItem xs="12" sm="2">
                <MudNumericField HideSpinButtons @bind-Value="Interval" Label="Interval (Days)" Variant="Variant.Outlined" Margin="Margin.Dense" Class="admin-input-group" />
            </MudItem>
            <MudItem xs="12" sm="3">
                <PartySelector label="Select Party" @bind-Value="party" Class="admin-input-group" />
            </MudItem>
            <MudItem xs="12" sm="2">
                <MudDatePicker Label="As On" Variant="Variant.Outlined" Margin="Margin.Dense" DisableToolbar="true" Editable="true" @bind-Date="DateVar" DateFormat="dd/MM/yyyy" Class="admin-input-group" />
            </MudItem>
            <MudItem xs="12" sm="3" Class="d-flex align-center gap-2">
                <div class="d-flex flex-column gap-1">
                    <MudCheckBox @bind-Value="@IncludeMemos" Label="Memos" Color="Color.Primary" Dense="true" />
                    <MudCheckBox @bind-Value="@summary" Label="Summary" Color="Color.Secondary" Dense="true" />
                </div>
                <MudTooltip Text="Select Branches">
                    <MudIconButton Icon="@Icons.Material.Filled.List" Variant="Variant.Filled" Color="Color.Success" OnClick="SelectBranches" Class="rounded-lg" />
                </MudTooltip>
                <MudButton FullWidth="true" Variant="Variant.Filled" Color="Color.Primary" OnClick="RenderReportViewer" Class="admin-register-btn">VIEW REPORT</MudButton>
            </MudItem>
        </MudGrid>
    </div>

    <div class="admin-glass-card pa-0 overflow-hidden shadow-sm @(ShowReport ? "" : "d-none")">
        <ReportViewer ReportName="@ReportName" Parameters=@ReportParameters @ref="@report"></ReportViewer>
    </div>
</div>

@code {

    ReportViewer report;
    public bool ShowReport { get; set; } = false;
    public string ReportName { get; set; }  

    string drcr = "Credit";
    int Interval = 30;
    PartyModel party = new PartyModel();
    DateTime? DateVar = DateTime.Today;
    bool summary = true;
    bool IncludeMemos = false; 

    protected bool Validate()
    {
        if (!SelectedBranches.Any())
        {
            snackbar.Add("Please select branch.", Severity.Error);
            return false;
        }      

        if(Interval == 0 )
        {
            snackbar.Add("Please Type a valid integer for Interval!.", Severity.Error);
            return false;
        }
        return true;
    }

    public async Task RenderReportViewer()
    {
        try
        {
            if (Validate())
            {
                ReportParameters.Clear();

                if(summary)
                {
                    ReportName = "OutstandingBillsAgeSummary";
                }
                else
                {
                    ReportName = "OutstandingBillsAge";                    
                }
                ReportParameters.Add("BranchIDS", String.Join(',', SelectedBranches));
                ReportParameters.Add("DrCr", drcr);
                ReportParameters.Add("Interval", Interval.ToString());
                ReportParameters.Add("Date", DateVar.Value.ToString("yyyy-MM-dd"));
                ReportParameters.Add("PartyID", (party?.PartyID??0).ToString());
                ReportParameters.Add("IncludeMemos", IncludeMemos.ToString());
                ShowReport = true;
                await report.RenderReport(ReportName);
            }
        }
        catch (Exception ex)
        {
            snackbar.Add(ex.Message, Severity.Error);
        }
    }
}
