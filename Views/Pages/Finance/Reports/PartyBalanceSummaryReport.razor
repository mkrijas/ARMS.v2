@page "/PartyBalanceSummaryReport"
@inherits ReportComponentBase
@inject IPartyService partyService

<MudGrid Spacing="4">
    <MudItem xs="12">
        <MudPaper Class="mb-5 p-4">
            <MudToolBar Style="padding-left: 0px; margin-top: -22px;">
                <MudText Typo="Typo.h5" Style="font-weight:500;">Party Balance Summary Report</MudText>
            </MudToolBar>
            <MudDivider />
            <MudGrid Style="padding-top: 22px;">
                <MudItem xs="4">
                    <MudAutocomplete SelectValueOnTab T="string" @bind-Value="@SelectedPG" Variant="Variant.Outlined" Margin="Margin.Dense"
                                     Label="Account Rule Defenition" ResetValueOnEmptyText="true" SearchFunc="@SearchPGs">
                    </MudAutocomplete>
                </MudItem>
                <MudItem xs="2">
                    <MudDatePicker Label="From Date" @bind-Date="@(FromDate)" Variant="Variant.Outlined" Margin="Margin.Dense" />
                </MudItem>
                <MudItem xs="2">
                    <MudDatePicker Label="To Date" @bind-Date="@(ToDate)" Variant="Variant.Outlined" Margin="Margin.Dense" />
                </MudItem>
                <MudItem xs="4" Style="display: flex; align-items: center;">
                    <MudCheckBox @bind-Value="@ClosingOnly" Label="Closing Only"></MudCheckBox>
                    <MudIconButton Style="margin-right: 8px;" Title="Select Branches" Icon="@Icons.Material.Filled.List" Variant="Variant.Filled" Color="Color.Success" OnClick="SelectBranches"></MudIconButton>
                    <MudButton Style="width: -webkit-fill-available;" Variant="Variant.Filled" Color="Color.Success" OnClick="RenderReportViewer">View Report</MudButton>
                </MudItem>
            </MudGrid>
        </MudPaper>
    </MudItem>
</MudGrid>
<MudGrid Style="@(ShowReport?"":"Display:none")">
    <MudItem xs="12">
        <ReportViewer ReportName="@ReportName" Parameters=@ReportParameters @ref="@report"></ReportViewer>
    </MudItem>
</MudGrid>

@code {

    ReportViewer report;
    public DateTime? FromDate { get; set; } = DateTime.Now;
    public DateTime? ToDate { get; set; } = DateTime.Now;

    bool ClosingOnly = false;

    public PartyModel SelectedParty { get; set; } = new();
    public string PartyCode { get; set; }
    public bool ShowReport { get; set; } = false;
    public string ReportName { get; set; }
    public BranchModel CurrentBranch { get; set; } = new();

    string SelectedPG;
    List<string> PGs = new();

    protected bool Validate()
    {
        if (!SelectedBranches.Any())
        {
            snackbar.Add("Please select branch.", Severity.Error);
            return false;
        }
        if (FromDate == null)
        {
            snackbar.Add("Please select From Date.", Severity.Error);
            return false;
        }
        if (ToDate == null)
        {
            snackbar.Add("Please select To Date.", Severity.Error);
            return false;
        }
        return true;
    }

    protected override void OnInitialized()
    {
        PGs = partyService.GetPostingGroupNames().ToList();
    }

    private async Task<IEnumerable<string>> SearchPGs(string searchString)
    {
        await Task.Delay(5);
        if (searchString is null)
            return PGs;
        return await Task.FromResult(PGs.Where(x => (x.Contains(searchString, StringComparison.InvariantCultureIgnoreCase))));
    }

    public async Task RenderReportViewer()
    {
        
        try
        {
            if (Validate())
            {                
                ReportName = ClosingOnly ? "FinancePartyBalanceClosingSummary" : "FinancePartyBalanceSummary";
                ReportParameters.Clear();
                ReportParameters.Add("PostingGroupName", SelectedPG);
                ReportParameters.Add("BranchIDS", String.Join(',', SelectedBranches));
                ReportParameters.Add("FromDate", FromDate.Value.ToString("yyyy/MM/dd"));
                ReportParameters.Add("ToDate", ToDate.Value.ToString("yyyy/MM/dd"));
                ShowReport = true;
                await report.RenderReport();
            }
        }
        catch (Exception ex)
        {
            snackbar.Add(ex.Message, Severity.Error);
        }
    }
}