@page "/PartyBalanceSummaryReport"
@using System.Threading
@inherits ReportComponentBase
@inject IPartyService partyService


<div class="fade-in">
    <div class="admin-header-tiered mb-6">
        <div class="d-flex align-center justify-space-between">
            <div>
                <MudText Typo="Typo.h4" Class="admin-title">Party Balance Summary Report</MudText>
                <MudText Typo="Typo.body2" Class="admin-subtitle">Consolidated view of all party ledger balances. Monitor financial obligations and credit standing across vendors and customers.</MudText>
            </div>
            <MudRadioGroup T="string" Value="@ReportName" ValueChanged="@((e)=> OnSelectionChanged(e))" Class="admin-glass-card pa-2 d-flex gap-4">
                <MudRadio Value="@("FinancePartyBalanceSummary")" Color="Color.Primary" UnCheckedColor="Color.Default" Size="Size.Small">Summary</MudRadio>
                <MudRadio Value="@("FinancePartyBalanceClosingSummary")" Color="Color.Secondary" UnCheckedColor="Color.Default" Size="Size.Small">Closing Only</MudRadio>
                <MudRadio Value="@("FinancePartyBalanceSummarySubArdCode")" Color="Color.Tertiary" UnCheckedColor="Color.Default" Size="Size.Small">By Nature</MudRadio>
            </MudRadioGroup>
        </div>
    </div>

    <div class="admin-glass-card mb-6 pa-6">
        <MudGrid Spacing="4" Class="align-center">
            <MudItem xs="12" sm="4">
                @if (ReportName == "FinancePartyBalanceSummarySubArdCode")
                {
                    <MudSelect For="@(() => SelectedArdSubGroup)" T="string" @bind-Value="@SelectedArdSubGroup" Label="Transaction Type" Variant="Variant.Outlined" Margin="Margin.Dense" Class="admin-input-group">
                        <MudSelectItem Value="@("Security Deposit")">Security Deposit</MudSelectItem>
                        <MudSelectItem Value="@("Prepayment")">Prepayment</MudSelectItem>
                        <MudSelectItem Value="@("Purchase n Sales")">Purchase & Sales</MudSelectItem>
                        <MudSelectItem Value="@("All")">All Types</MudSelectItem>
                    </MudSelect>
                }
                else
                {
                    <MudAutocomplete SelectValueOnTab T="string" @bind-Value="@SelectedPG" Variant="Variant.Outlined" Margin="Margin.Dense"
                                     Label="Rule Definition" ResetValueOnEmptyText="true" SearchFunc="@SearchPGs" Class="admin-input-group">
                    </MudAutocomplete>
                }
            </MudItem>
            <MudItem xs="12" sm="2">
                <MudDatePicker Label="From Date" @bind-Date="@FromDate" Variant="Variant.Outlined" Margin="Margin.Dense" Class="admin-input-group" />
            </MudItem>
            <MudItem xs="12" sm="2">
                <MudDatePicker Label="To Date" @bind-Date="@ToDate" Variant="Variant.Outlined" Margin="Margin.Dense" Class="admin-input-group" />
            </MudItem>
            <MudItem xs="12" sm="4" Class="d-flex align-center gap-2">
                @if (ReportName != "FinancePartyBalanceSummarySubArdCode")
                {
                    <MudCheckBox @bind-Value="@ClosingOnly" Label="Closing Only" Color="Color.Primary" Dense="true" />
                }
                <MudTooltip Text="Select Branches">
                    <MudIconButton Icon="@Icons.Material.Filled.List" Variant="Variant.Filled" Color="Color.Success" OnClick="SelectBranches" Class="rounded-lg" />
                </MudTooltip>
                <MudButton FullWidth="true" Variant="Variant.Filled" Color="Color.Primary" OnClick="RenderReportViewer" Class="admin-register-btn">VIEW REPORT</MudButton>
            </MudItem>
        </MudGrid>
    </div>

    <div class="admin-glass-card pa-0 overflow-hidden shadow-sm @(ShowReport ? "" : "d-none")">
        <ReportViewer ReportName="@ReportName" Parameters=@ReportParameters @ref="@report"></ReportViewer>
    </div>
</div>

@code {

    ReportViewer report;
    public DateTime? FromDate { get; set; } = DateTime.Now;
    public DateTime? ToDate { get; set; } = DateTime.Now;

    bool ClosingOnly = false;

    public PartyModel SelectedParty { get; set; } = new();
    public string PartyCode { get; set; }
    public bool ShowReport { get; set; } = false;
    public string ReportName { get; set; } = "FinancePartyBalanceSummary";
    public BranchModel CurrentBranch { get; set; } = new();

    SubArdCodeModel SelectedSubArdCode;
    string SelectedArdSubGroup;
    List<SubArdCodeModel> SubArds = new();
    string SelectedPG;
    List<string> PGs = new();

    protected bool Validate()
    {
        if (!SelectedBranches.Any())
        {
            snackbar.Add("Please select branch.", Severity.Error);
            return false;
        }
        if (FromDate == null)
        {
            snackbar.Add("Please select From Date.", Severity.Error);
            return false;
        }
        if (ToDate == null)
        {
            snackbar.Add("Please select To Date.", Severity.Error);
            return false;
        }
        return true;
    }

    protected override void OnInitialized()
    {
        PGs = partyService.GetPostingGroupNames().ToList();
        //SubArds = partyService.getSubArdCodes().ToList();
    }

    private async Task<IEnumerable<string>> SearchPGs(string searchString, CancellationToken token)
    {
        await Task.Delay(5);
        if (searchString is null)
            return PGs;
        return await Task.FromResult(PGs.Where(x => (x.Contains(searchString, StringComparison.InvariantCultureIgnoreCase))));
    }

    private async Task<IEnumerable<SubArdCodeModel>> SearchSubArds(string searchString, CancellationToken token)
    {
        await Task.Delay(5);
        if (searchString is null)
            return SubArds;
        return await Task.FromResult(SubArds.Where(x => (x.TranType.Contains(searchString, StringComparison.InvariantCultureIgnoreCase))));
    }


    void OnSelectionChanged(string val)
    {

        ReportName = val;       
    }

    public async Task RenderReportViewer()
    {

        try
        {
            if (Validate())
            {                
                ReportParameters.Clear();
                if (ReportName == "FinancePartyBalanceSummarySubArdCode")
                {
                    ReportParameters.Add("ArdSubGroup", string.IsNullOrWhiteSpace(SelectedArdSubGroup) ? null : SelectedArdSubGroup);
                }
                else
                {
                    ReportParameters.Add("PostingGroupName", string.IsNullOrWhiteSpace(SelectedPG) ? null : SelectedPG);
                }
                ReportParameters.Add("BranchIDS", String.Join(',', SelectedBranches));
                ReportParameters.Add("FromDate", FromDate.Value.ToString("yyyy-MM-dd"));
                ReportParameters.Add("ToDate", ToDate.Value.ToString("yyyy-MM-dd"));
                ShowReport = true;
                await report.RenderReport(ReportName);
            }
        }
        catch (Exception ex)
        {
            snackbar.Add(ex.Message, Severity.Error);
        }
    }
}
