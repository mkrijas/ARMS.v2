@page "/StockistFreightCollected"
@using ArmsModels.BaseModels.Finance.Report;
@using Microsoft.JSInterop
@using Microsoft.AspNetCore.Components
@using Views.Data;
@using System.Text;
@using System.Net;
@inject AuthenticationStateProvider auth
@inject IBranchService Ibranchservice
@inject ISnackbar Snackbar
@inject IDialogService DialogService

<MudGrid Spacing="4">
    <MudItem xs="12">
        <MudPaper Class="mb-5 p-4">
            <MudGrid>
                <MudItem xs="4">
                    <BranchSelector LabelName="Select Branch" Value="SelectedBranch" ValueChanged="@OtherBranchChanged"></BranchSelector>
                </MudItem>
                <MudItem xs="3">
                    <MudDatePicker Label="From" @bind-Date="@(StartDate)" Variant="Variant.Outlined" Margin="Margin.Dense" />
                </MudItem>
                <MudItem xs="3">
                    <MudDatePicker Label="To" @bind-Date="@(EndDate)" Variant="Variant.Outlined" Margin="Margin.Dense" />
                </MudItem>
                <MudItem xs="2">
                    <MudButton Variant="Variant.Outlined" Color="Color.Success" OnClick="RenderReportViewer">View Report</MudButton>
                </MudItem>
            </MudGrid>
        </MudPaper>
    </MudItem>
</MudGrid>
<MudGrid Style="@(ShowReport?"":"Display:none")">
    <MudItem xs="12">
        @if (ShowReport)
        {
            <ReportViewer ReportName="@ReportName" Parameters=@ReportParameters  @ref="@report"></ReportViewer>
        }
    </MudItem>
</MudGrid>

@code {
    ReportViewer report;
    public Dictionary<string, string> ReportParameters { get; set; } = new();
    public DateTime? StartDate { get; set; } = DateTime.Now;
    public DateTime? EndDate { get; set; } = DateTime.Now;
    public int? BranchID { get; set; } = 0;
    public BranchModel SelectedBranch { get; set; } = new();
    public string ReportName { get; set; }
    bool ShowReport;

    private async Task OtherBranchChanged(BranchModel branch)
    {
        SelectedBranch = branch;
    }

    public async Task RenderReportViewer()
    {
        ReportName = "StocklistFreightCollectedReport";
        ReportParameters.Clear();
        ReportParameters.Add("BranchID", SelectedBranch?.BranchID.ToString());
        ReportParameters.Add("BranchName", SelectedBranch?.BranchName.ToString());
        ReportParameters.Add("PeriodFrom", StartDate.Value.ToString("yyyy/MM/dd"));
        ReportParameters.Add("PeriodTo", EndDate.Value.ToString("yyyy/MM/dd"));
        ShowReport = true;
        await report.RenderReport();
    }
}