@page "/StockistFreightCollectedReport"
@using ArmsModels.BaseModels.Finance.Report;
@using Microsoft.JSInterop
@using Microsoft.AspNetCore.Components
@using Views.Data;
@using System.Text;
@using System.Net;
@inject AuthenticationStateProvider auth
@inherits ReportComponentBase
@inject IBranchService Ibranchservice
@inject ISnackbar Snackbar
@inject IDialogService DialogService

<MudGrid Spacing="4">
    <MudItem xs="12">
        <MudPaper Class="mb-5 p-4">
            <MudToolBar Style="padding-left: 0px; margin-top: -22px;">
                <MudText Typo="Typo.h5" Style="font-weight:500;">Stockist Freight Collected Report</MudText>
            </MudToolBar>
            <MudDivider />
            <MudGrid Style="padding-top: 22px;">
                <MudItem xs="5">
                    <MudDatePicker Label="From" @bind-Date="@(StartDate)" Variant="Variant.Outlined" Margin="Margin.Dense" />
                </MudItem>
                <MudItem xs="5">
                    <MudDatePicker Label="To" @bind-Date="@(EndDate)" Variant="Variant.Outlined" Margin="Margin.Dense" />
                </MudItem>
                <MudItem xs="2" Style="display: flex; align-items: center;">
                    <MudIconButton Style="margin-right: 8px;" Title="Select Branches" Icon="@Icons.Material.Filled.List" Variant="Variant.Filled" Color="Color.Success" OnClick="SelectBranches"></MudIconButton>
                    <MudButton Style="width: -webkit-fill-available;" Variant="Variant.Filled" Color="Color.Success" OnClick="RenderReportViewer">View Report</MudButton>
                </MudItem>
            </MudGrid>
        </MudPaper>
    </MudItem>
</MudGrid>
<MudGrid Style="@(ShowReport?"":"Display:none")">
    <MudItem xs="12">
        <ReportViewer ReportName="@ReportName" Parameters=@ReportParameters @ref="@report"></ReportViewer>
    </MudItem>
</MudGrid>

@code {
    ReportViewer report;
    public Dictionary<string, string> ReportParameters { get; set; } = new();
    public DateTime? StartDate { get; set; } = DateTime.Now;
    public DateTime? EndDate { get; set; } = DateTime.Now;
    public int? BranchID { get; set; } = 0;
    public BranchModel CurrentBranch { get; set; } = new();
    public string ReportName { get; set; }
    bool ShowReport;

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();
        var authprov = await auth.GetAuthenticationStateAsync();
        var User = authprov.User;
        string BranchIDString = User.Claims.First(x => x.Type == "BranchID").Value;
        CurrentBranch.BranchName = User.Claims.First(x => x.Type == "BranchName").Value;
        CurrentBranch.BranchID = int.Parse(BranchIDString);
    }

    private async Task OtherBranchChanged(BranchModel branch)
    {
        CurrentBranch = branch;
    }

    public async Task RenderReportViewer()
    {
        if (CurrentBranch?.BranchID == null)
        {
            Snackbar.Add("Please select Branch", Severity.Error);
            return;
        }

        ShowReport = true;
        ReportName = "StocklistFreightCollectedReport";
        ReportParameters.Clear();
        ReportParameters.Add("BranchIDs", String.Join(',', SelectedBranches));
        ReportParameters.Add("BranchName", CurrentBranch?.BranchName.ToString());
        ReportParameters.Add("PeriodFrom", StartDate.Value.ToString("yyyy/MM/dd"));
        ReportParameters.Add("PeriodTo", EndDate.Value.ToString("yyyy/MM/dd"));   
        if(report is null)
        {
            await Task.Delay(100);
        }
        await report.RenderReport();
    }
}