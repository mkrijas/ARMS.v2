@page "/TripExpenseByPostingGroupReport"
@inherits ReportComponentBase
@using ArmsModels.BaseModels.Finance.Report;
@using System.Threading;
@inject IDialogService DialogService
@inject IOperationPostingGroupService Iservice

<div class="fade-in">
    <div class="admin-header-tiered mb-6">
        <div class="d-flex align-center justify-space-between">
            <div>
                <MudText Typo="Typo.h4" Class="admin-title">Trip Expense Report</MudText>
                <MudText Typo="Typo.body2" Class="admin-subtitle">Consolidated view of operational expenditures by posting group. Track fuel, tolls, and recoveries across trips for cost control and auditing.</MudText>
            </div>
        </div>
    </div>

    <div class="admin-glass-card mb-6 pa-6">
        <MudGrid Spacing="4" Class="align-center">
            <MudItem xs="12" sm="4">
                <MudAutocomplete T="OperationPostingGroupModel" Variant="Variant.Outlined" Margin="Margin.Dense" Label="Select Posting Group" Value="Selected" ValueChanged="SetPostingGroup" Clearable="true" SearchFunc="SearchPostingGroup" ToStringFunc="@(e => (e == null || string.IsNullOrEmpty(e.Title)) ? null : string.Format("{0}",e.Title))" Class="admin-input-group" />
            </MudItem>
            <MudItem xs="12" sm="2">
                <MudDatePicker Label="Start Date" @bind-Date="@StartDate" Variant="Variant.Outlined" Margin="Margin.Dense" Class="admin-input-group" />
            </MudItem>
            <MudItem xs="12" sm="2">
                <MudDatePicker Label="End Date" @bind-Date="@EndDate" Variant="Variant.Outlined" Margin="Margin.Dense" Class="admin-input-group" />
            </MudItem>
            <MudItem xs="12" sm="4" Class="d-flex align-center gap-2">
                <MudTooltip Text="Select Branches">
                    <MudIconButton Icon="@Icons.Material.Filled.List" Variant="Variant.Filled" Color="Color.Success" OnClick="SelectBranches" Class="rounded-lg" />
                </MudTooltip>
                <MudButton FullWidth="true" Variant="Variant.Filled" Color="Color.Primary" OnClick="RenderReportViewer" Class="admin-register-btn">VIEW REPORT</MudButton>
            </MudItem>
        </MudGrid>
    </div>

    <div class="admin-glass-card pa-0 overflow-hidden shadow-sm @(ShowReport ? "" : "d-none")">
        <ReportViewer ReportName="@ReportName" Parameters=@ReportParameters @ref="@report"></ReportViewer>
    </div>
</div>

@code {

    ReportViewer report;
    DateTime? StartDate { get; set; } = DateTime.Now;
    DateTime? EndDate { get; set; } = DateTime.Now;
    private List<OperationPostingGroupModel> postingGroups = new();
    string SelectedpostingGroup { get; set; }
    private OperationPostingGroupModel Selected = new();
    public BranchModel CurrentBranch { get; set; } = new();

    bool ShowReport { get; set; } = false;
    string ReportName { get; set; }
    LedgerTransactionsReportMoreParameterModel MoreParameter { get; set; } = new();
    bool IsMoreParameterHasValues { get; set; } = false;

    bool detailed = false;

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();
        var authprov = await auth.GetAuthenticationStateAsync();
        var User = authprov.User;
        CurrentBranch.BranchID = int.Parse(User.Claims.First(x => x.Type == "BranchID").Value);
        CurrentBranch.BranchName = User.Claims.First(x => x.Type == "BranchName").Value;

        postingGroups = Iservice.Select().ToList();
        postingGroups.Add(new OperationPostingGroupModel { Title = "Toll Expense Fastag" });
        postingGroups.Add(new OperationPostingGroupModel { Title = "Fuel Expense" });
        postingGroups.Add(new OperationPostingGroupModel { Title = "Mileage Short Recovery" });
    }

    private async Task<IEnumerable<OperationPostingGroupModel>> SearchPostingGroup(string searchString, CancellationToken token)
    {
        await Task.Delay(5);
        if (string.IsNullOrEmpty(searchString))
            return postingGroups;
        return postingGroups.Where(x => x.Title.Contains(searchString, StringComparison.InvariantCultureIgnoreCase));
    }

    private void SetPostingGroup(OperationPostingGroupModel obj)
    {
        Selected = obj;
        SelectedpostingGroup = obj.Title;
    }

    protected bool Validate()
    {
        if (!SelectedBranches.Any())
        {
            snackbar.Add("Please select branch.", Severity.Error);
            return false;
        }
        if (StartDate == null)
        {
            snackbar.Add("Please select Start-Date.", Severity.Error);
            return false;
        }
        if (EndDate == null)
        {
            snackbar.Add("Please select End-Date.", Severity.Error);
            return false;
        }
        if (SelectedpostingGroup is null)
        {
            snackbar.Add("Please select Posting Group", Severity.Error);
            return false;
        }
        return true;
    }

    public async Task RenderReportViewer()
    {
        ShowReport = false;
        if (Validate())
        {
            ShowReport = true;
            ReportName = "TripExpenseByPostingGroupReport";
            ReportParameters.Clear();
            ReportParameters.Add("BranchIDS", String.Join(',', SelectedBranches));
            ReportParameters.Add("BranchName", CurrentBranch.BranchName);
            ReportParameters.Add("PostingGroup", SelectedpostingGroup);
            ReportParameters.Add("FromDate", StartDate.Value.ToString("yyyy-MM-dd"));
            ReportParameters.Add("ToDate", EndDate.Value.ToString("yyyy-MM-dd"));
            await report.RenderReport(ReportName);
        }
    }
}
