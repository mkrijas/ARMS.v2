@page "/TripExpenseByPostingGroupReport"
@inherits ReportComponentBase
@using ArmsModels.BaseModels.Finance.Report;
@inject IDialogService DialogService
@inject IOperationPostingGroupService Iservice

<MudGrid Spacing="4">
    <MudItem xs="12">
        <MudPaper Class="mb-5 p-4">
            <MudToolBar Style="padding-left: 0px; margin-top: -22px;">
                <MudText Typo="Typo.h5" Style="font-weight:500;">Trip Expense Report</MudText>
            </MudToolBar>
            <MudDivider />
            <MudGrid Style="padding-top: 22px;">
                <MudItem xs="4">
                    <MudAutocomplete T="OperationPostingGroupModel" Variant="Variant.Outlined" Margin="Margin.Dense" Label="Select Posting Group" Value="Selected" ValueChanged="SetPostingGroup" Clearable="true" SearchFunc="SearchPostingGroup" ToStringFunc="@(e => (e == null || string.IsNullOrEmpty(e.Title)) ? null : string.Format("{0}",e.Title))"></MudAutocomplete>
                    @* <MudSelect Label="Select Posting Group" @bind-Value="@(SelectedpostingGroup)" T="string" Variant="Variant.Outlined" Margin="Margin.Dense"   AdornmentColor="Color.Secondary">
                        @foreach (var ditem in postingGroups)
                        {
                            <MudSelectItem Value="@ditem.Title">@ditem.Title</MudSelectItem>
                        }
                    </MudSelect> *@
                </MudItem>
                <MudItem xs="3">
                    <MudDatePicker Label="Start Date" @bind-Date="@(StartDate)" Variant="Variant.Outlined" Margin="Margin.Dense" />
                </MudItem>
                <MudItem xs="3">
                    <MudDatePicker Label="End Date" @bind-Date="@(EndDate)" Variant="Variant.Outlined" Margin="Margin.Dense" />
                </MudItem>
                <MudItem xs="2" Style="display: flex; align-items: center;">
                    <MudIconButton Style="margin-right: 8px;" Title="Select Branches" Icon="@Icons.Material.Filled.List" Variant="Variant.Filled" Color="Color.Success" OnClick="SelectBranches"></MudIconButton>
                    <MudButton Style="width: -webkit-fill-available;" Variant="Variant.Filled" Color="Color.Success" OnClick="RenderReportViewer">View Report</MudButton>
                </MudItem>
            </MudGrid>
        </MudPaper>
    </MudItem>
</MudGrid>
<MudGrid Style="@(ShowReport?"":"Display:none")">
    <MudItem xs="12">
        <ReportViewer ReportName="@ReportName" Parameters=@ReportParameters @ref="@report"></ReportViewer>
    </MudItem>
</MudGrid>

@code {

    ReportViewer report;
    DateTime? StartDate { get; set; } = DateTime.Now;
    DateTime? EndDate { get; set; } = DateTime.Now;
    private List<OperationPostingGroupModel> postingGroups = new();
    string SelectedpostingGroup { get; set; }
    private OperationPostingGroupModel Selected = new();
    public BranchModel CurrentBranch { get; set; } = new();

    bool ShowReport { get; set; } = false;
    string ReportName { get; set; }
    LedgerTransactionsReportMoreParameterModel MoreParameter { get; set; } = new();
    bool IsMoreParameterHasValues { get; set; } = false;

    bool detailed = false;

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();
        var authprov = await auth.GetAuthenticationStateAsync();
        var User = authprov.User;
        CurrentBranch.BranchID = int.Parse(User.Claims.First(x => x.Type == "BranchID").Value);
        CurrentBranch.BranchName = User.Claims.First(x => x.Type == "BranchName").Value;

        postingGroups = Iservice.Select().ToList();
        postingGroups.Add(new OperationPostingGroupModel { Title = "Toll Expense Fastag" });
        postingGroups.Add(new OperationPostingGroupModel { Title = "Fuel Expense" });
        postingGroups.Add(new OperationPostingGroupModel { Title = "Mileage Short Recovery" });
    }

    private async Task<IEnumerable<OperationPostingGroupModel>> SearchPostingGroup(string searchString)
    {
        await Task.Delay(5);
        if (string.IsNullOrEmpty(searchString))
            return postingGroups;
        return postingGroups.Where(x => x.Title.Contains(searchString, StringComparison.InvariantCultureIgnoreCase));
    }

    private void SetPostingGroup(OperationPostingGroupModel obj)
    {
        Selected = obj;
        SelectedpostingGroup = obj.Title;
    }

    protected bool Validate()
    {
        if (!SelectedBranches.Any())
        {
            snackbar.Add("Please select branch.", Severity.Error);
            return false;
        }
        if (StartDate == null)
        {
            snackbar.Add("Please select Start-Date.", Severity.Error);
            return false;
        }
        if (EndDate == null)
        {
            snackbar.Add("Please select End-Date.", Severity.Error);
            return false;
        }
        if (SelectedpostingGroup is null)
        {
            snackbar.Add("Please select Posting Group", Severity.Error);
            return false;
        }
        return true;
    }

    public async Task RenderReportViewer()
    {
        ShowReport = false;
        if (Validate())
        {
            ShowReport = true;
            ReportName = "TripExpenseByPostingGroupReport";
            ReportParameters.Clear();
            ReportParameters.Add("BranchIDS", String.Join(',', SelectedBranches));
            ReportParameters.Add("BranchName", CurrentBranch.BranchName);
            ReportParameters.Add("PostingGroup", SelectedpostingGroup);
            ReportParameters.Add("FromDate", StartDate.Value.ToString("yyyy/MM/dd"));
            ReportParameters.Add("ToDate", EndDate.Value.ToString("yyyy/MM/dd"));
            await report.RenderReport();
        }
    }
}