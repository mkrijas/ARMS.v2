@inject ITdsRateService tdsRate
@inject ITdsThresholdLimitService Iservice

@inject MudBlazor.ISnackbar snackbar
@inject AuthenticationStateProvider auth
@attribute [Authorize]
@inject IDialogService DialogService



<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.Build" Class="mr-3 mb-n1" />
             TDS Threshold Limit
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudContainer Style="min-height:300px;max-height: 800px;">
            <EditForm id="formtdsThreshold" Model="@model" OnValidSubmit="OnValidSubmit">
                <ObjectGraphDataAnnotationsValidator />
                <ValidationSummary />
                <MudGrid Spacing="2">
                    <MudItem xs="12">
                        <MudSelect Label="Select Nature of payment" @bind-Value="model.NatureOfPayment" T="NatureOfPaymentModel" ToStringFunc="@((p) => p?.NatureOfPayment)" Variant="Variant.Outlined" Margin="Margin.Dense" OffsetY="true" Direction="Direction.Top" AdornmentColor="Color.Secondary">
                            @foreach (var ditem in naturepayment)
                            {
                                <MudSelectItem Value="@ditem">@ditem.NatureOfPayment</MudSelectItem>
                            }
                        </MudSelect>


                    </MudItem>
                     <MudItem xs="12" md="6">
                  <MudDatePicker Label="Period From" Variant="Variant.Outlined" Margin="Margin.Dense" DisableToolbar="true" Editable="true" @bind-Date="model.PeriodFrom" HelperText="Enter Date" DateFormat="dd/MM/yyyy" />
                 </MudItem>
                  <MudItem xs="12" md="6">
                  <MudDatePicker Label="Period To" Variant="Variant.Outlined" Margin="Margin.Dense" DisableToolbar="true" Editable="true" @bind-Date="model.PeriodTo" HelperText="Enter Date" DateFormat="dd/MM/yyyy" />
                   </MudItem>
                  <MudItem xs="12" md="6">
                   <MudTextField  @bind-Value="model.ThresholdLimitSingle" Label="Threshold Limit Single" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.ThresholdLimitSingle)"></MudTextField>
                 </MudItem>
                  <MudItem xs="12" md="6">
                 <MudTextField  @bind-Value="model.ThresholdLimitPeriod" Label="Threshold Limit Period" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.ThresholdLimitPeriod)"></MudTextField>
                   </MudItem>
                   
                    
                </MudGrid>
            </EditForm>
        </MudContainer>
    </DialogContent>
    <DialogActions>
    @*   <MudButton OnClick="DeleteTaxRate">Delete Tax Rate</MudButton>
        <MudButton OnClick="AddTaxRate">Add More Tax Rate</MudButton>*@
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton form="formtdsThreshold" Variant="Variant.Filled" Color="Color.Success" ButtonType="ButtonType.Submit">Submit</MudButton>

    </DialogActions>
</MudDialog>



@code {
    [Parameter]
    public TdsThresholdLimitModel model { get; set; }
    private List<TdsThresholdLimitModel> collection = new List<TdsThresholdLimitModel>();    

   
    private TdsThresholdLimitModel tds = new();
    [CascadingParameter] MudDialogInstance MudDialog { get; set; }

    private List<NatureOfPaymentModel> naturepayment = new();

  

   

    protected override void OnInitialized()
    {


        naturepayment =  tdsRate.SelectTdsNP().ToList();
     


    }
    private void OnValidSubmit(EditContext context)
    {
      
       
        if (model.NatureOfPayment == null)
        {
              snackbar.Add("Select Nature of payment", Severity.Success);
        }
        else
        {
        DateRange dr = new DateRange(model.PeriodFrom, model.PeriodTo);
        List<TdsThresholdLimitModel> tdsList = Iservice.Select().ToList();

        List<DateRange> drList = new List<DateRange>();
        tdsList.ForEach(item => drList.Add(new DateRange(item.PeriodFrom, item.PeriodTo)));

        if (CommonMethods.CheckPeriodOverlap(dr, drList))
        {
            snackbar.Add("Periods cannot be overlapped", Severity.Success);
        }
        else
        {
            MudDialog.Close(model);
        }


           
        }
    }

    private void Cancel()
    {
        MudDialog.Cancel();
    }   
}
