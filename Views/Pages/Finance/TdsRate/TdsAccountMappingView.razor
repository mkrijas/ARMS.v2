@page "/tdsAccountMapping"
@inject ITdsRateService tdsRate
@inject ITdsAccountMappingService Iservice
@inject IChartOfAccountService account
@inject MudBlazor.ISnackbar snackbar
@inject AuthenticationStateProvider auth
@attribute [Authorize]
@inject IDialogService DialogService





<div style="background-color:#1469c0;padding:1%;padding-top:1%;  color:#fff;"><div style="float:left;padding-top:1%"><h6>TDS Account</h6></div><div style="float:right;">
    <MudButton @onclick="@(()=> OpenDialog(model))" StartIcon="@Icons.Outlined.Add" Variant="Variant.Filled" Style="background:none;color:#fff;">
  Add new TDS Mapping
</MudButton></div>
<br />
<br />
</div>

   <MudItem xs="12">
        <MudTable Items="@collection"  Dense="true" Hover="true"  Striped="true" Elevation="10" Filter="new Func<TdsAccountMappingModel, bool>(search)" @bind-place="model">
            <ToolBarContent>
                <MudText Typo="Typo.h6">Tds Account Mapping</MudText>
               <MudSpacer></MudSpacer>
                <MudTextField @bind-Value="searchTds" Placeholder="Search TDS... "
                              Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                              IconSize="Size.Medium" Class="mt-0"></MudTextField>
            </ToolBarContent>
            <HeaderContent>
                <MudTh><MudTableSortLabel SortBy="new Func<TdsAccountMappingModel, object>(x=> x.NatureOfPayment)" InitialDirection="SortDirection.Ascending">Nature of Payment</MudTableSortLabel></MudTh>
             <MudTh><MudTableSortLabel SortBy="new Func<TdsAccountMappingModel, object>(x=> x.AccountName)" InitialDirection="SortDirection.Ascending">AccountName</MudTableSortLabel></MudTh>
               
                <MudTh>Actions</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="NatureOfPayment">@context.NatureOfPayment</MudTd>
                <MudTd DataLabel="AssesseeTypeName">@context.AccountName</MudTd>
             
                <MudTd DataLabel="">
                    <MudFab @onclick="@(()=> OpenDialog(context))" Color="Color.Primary" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" IconSize="Size.Small" />
                    <MudFab @onclick="@(()=> Delete(context))" Color="Color.Primary" Icon="@Icons.Material.Filled.Delete" Size="Size.Small" IconSize="Size.Small" />
                </MudTd>
            </RowTemplate>
            <PagerContent>
                <MudTablePager PageSizeOptions="new int[] { 5, 10, 20, 50, 100 }" />
            </PagerContent>
        </MudTable>
    </MudItem>


@code {

    private TdsAccountMappingModel model = new TdsAccountMappingModel();
    private List<TdsAccountMappingModel> collection = new List<TdsAccountMappingModel>();


    private string searchTds = "";

    protected override async Task OnInitializedAsync()
    {
        model = new();
        GetAll();
    }

    private  void GetAll()
    {
        collection = new List<TdsAccountMappingModel>();
        foreach (var item in Iservice.Select())
        {
            collection.Add(item);
        }


    }   

    private async Task OpenDialog(TdsAccountMappingModel tds)
    {
        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;

        DialogParameters parms = new DialogParameters();
        parms.Add("model",tds);
        var dialog =  DialogService.Show<TdsAccountMappingDialig>(tds.TdsAccountMappedID == null?"ADD":"EDIT",parms);
        var result = await dialog.Result;
        if(!result.Cancelled)
        {   
            TdsAccountMappingModel UpatedModel = (TdsAccountMappingModel)result.Data;            
            model.UserInfo.UserID = user.Identity.Name;

            
            try
            {
                Iservice.Update(UpatedModel);
                snackbar.Add("Saved Successfully", Severity.Success);
                GetAll();
            }
            catch (Exception ex)
            {
                snackbar.Add(ex.Message, Severity.Warning);
            }

        }
    }
    
    private void Delete(TdsAccountMappingModel tds)
    {
        Iservice.Delete(tds.TdsAccountMappedID, "Rijas");
        snackbar.Add("Deleted Successfully", Severity.Success);
        GetAll();
    }

    private bool search(TdsAccountMappingModel tds)
    {
     if (tds.NatureOfPayment != null && tds.AccountName.Contains(searchTds, StringComparison.OrdinalIgnoreCase))
        {
            return true;
        }
        else if (tds.NatureOfPayment == null) return true;
       return false;
    }


   
}
