@inject ITdsRateService Iservice

@inject MudBlazor.ISnackbar snackbar
@inject AuthenticationStateProvider auth
@attribute [Authorize]
@inject IDialogService DialogService



<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.Build" Class="mr-3 mb-n1" />
            Create TDS Rate
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudContainer Style="min-height:300px;max-height: 800px;">
            <EditForm id="formtdsRate" Model="@model" OnValidSubmit="OnValidSubmit">
                <ObjectGraphDataAnnotationsValidator />
                <ValidationSummary />
                <MudGrid Spacing="2">
                    <MudItem xs="12">
                        <MudSelect Label="Select Nature of payment" @bind-Value="model.TdsNP" T="NatureOfPaymentModel" ToStringFunc="@((p) => p?.NatureOfPayment)" Variant="Variant.Outlined" Margin="Margin.Normal" OffsetY="true" Direction="Direction.Top" AdornmentColor="Color.Secondary">
                            @foreach (var ditem in naturepayment)
                            {
                                <MudSelectItem Value="@ditem">@ditem.NatureOfPayment</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                     <MudItem xs="12">
                        <MudSelect Label="Select Assessee Type" @bind-Value="model.AssesseeType" T="AssesseeTypeModel" ToStringFunc="@((p) => p?.AssesseeTypeName)" Variant="Variant.Outlined" Margin="Margin.Normal" OffsetY="true" Direction="Direction.Top" AdornmentColor="Color.Secondary">
                            @foreach (var ditem in asseesse)
                            {
                                <MudSelectItem Value="@ditem">@ditem.AssesseeTypeName</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                     <MudItem xs="12" md="6">
                  <MudDatePicker Label="Period From" Variant="Variant.Outlined" Margin="Margin.Dense" DisableToolbar="true" Editable="true" @bind-Date="model.PeriodFrom" HelperText="Enter Date" DateFormat="dd/MM/yyyy" />
                 </MudItem>
                  <MudItem xs="12" md="6">
                  <MudDatePicker Label="Period To" Variant="Variant.Outlined" Margin="Margin.Dense" DisableToolbar="true" Editable="true" @bind-Date="model.PeriodTo" HelperText="Enter Date" DateFormat="dd/MM/yyyy" />
                   </MudItem>
                   <MudItem xs="12" md="12">
                        <MudTextField @bind-Value="model.TaxRate" Label="Tax Rate%" Variant="Variant.Outlined" Margin="Margin.Normal" For="@(() => model.TaxRate)"></MudTextField>
                   </MudItem>
                </MudGrid>
            </EditForm>
        </MudContainer>
    </DialogContent>
    <DialogActions>
    @*   <MudButton OnClick="DeleteTaxRate">Delete Tax Rate</MudButton>
        <MudButton OnClick="AddTaxRate">Add More Tax Rate</MudButton>*@
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton form="formtdsRate" Variant="Variant.Filled" Color="Color.Success" ButtonType="ButtonType.Submit">Submit</MudButton>

    </DialogActions>
</MudDialog>



@code {
    [Parameter]
    public TdsRateModel model { get; set; }
    private List<TdsRateModel> collection = new List<TdsRateModel>();
    private List<TdsRateModel> tdsList = new List<TdsRateModel>();
    private List<NatureOfPaymentModel> naturepayment = new();
    private List<AssesseeTypeModel> asseesse = new();
    private TdsRateModel tds = new();
    [CascadingParameter] MudDialogInstance MudDialog { get; set; }

    private List<DateRange> drList = new List<DateRange>();

    protected override void OnInitialized()
    {
        naturepayment =  Iservice.SelectTdsNP().ToList();
        asseesse =  Iservice.SelectAssesseeTypes().ToList();
    }
    private void OnValidSubmit(EditContext context)
    {    
        Boolean bl;
        DateRange dr = new DateRange();
        dr.Start = model.PeriodFrom;
        dr.End = model.PeriodTo;
        tdsList = new List<TdsRateModel>();
        foreach (var item in Iservice.Select(model.TdsNP.TdsNPID,model.AssesseeType.AssesseeTypeID))
        {
            tdsList.Add(item);
        }


        if(model.TdsRateID==null)
        {
            
            drList = new List<DateRange>();
            foreach (var item in tdsList)
            {

                DateRange ddr = new DateRange();
                ddr.Start=item.PeriodFrom;
                ddr.End = item.PeriodTo;
                drList.Add(ddr);
            }
            bl = CommonMethods.CheckPeriodOverlap(dr, drList);
            if (bl == true)
            {
                snackbar.Add("Duplicate Date", Severity.Success);
            }
            else
            {
                MudDialog.Close(model);  
            }

        }
        else
        {

            drList = new List<DateRange>();
            var query=tdsList.Where(c=>c.TdsRateID != model.TdsRateID);
           
            drList = new List<DateRange>();
                     foreach (var item in query)
                     {
         
                     DateRange ddr = new DateRange();
                     ddr.Start=item.PeriodFrom;
                     ddr.End = item.PeriodTo;
                     drList.Add(ddr);
                     }
                    bl = CommonMethods.CheckPeriodOverlap(dr, drList);
                    if (bl == true)
                    {
                    snackbar.Add("Duplicate Date", Severity.Success);
                    }
                    else
                    {
                       // snackbar.Add("Done", Severity.Success);
                      MudDialog.Close(model);  
                    }

                }

      
    }

    private void Cancel()
    {
        MudDialog.Cancel();
    }   
}
