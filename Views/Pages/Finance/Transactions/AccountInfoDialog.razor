@inject IAccountInfoService Iservice
@inject MudBlazor.ISnackbar snackbar

@inject AuthenticationStateProvider auth
@attribute [Authorize]
@inject IDialogService DialogService



<MudDialog>
        <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.Build" Class="mr-3 mb-n1" />
           Accounting Info
        </MudText>
    </TitleContent>
     <DialogContent>
          <MudContainer Style="max-height: 500px; overflow-y: scroll">
         <MudGrid Spacing="4">
            <MudItem xs="12" md="3">
                        <MudTextField @bind-Value="model.DocumentDate" Label="DocumentDate" Variant="Variant.Outlined" Margin="Margin.Dense" ></MudTextField>

                    </MudItem>
                <MudItem xs="12" md="3">
                        <MudTextField @bind-Value="model.DocumentNumber" Label="DocumentNumber" Variant="Variant.Outlined" Margin="Margin.Dense" ></MudTextField>

                    </MudItem>
                     <MudItem xs="12" md="3">
                        <MudTextField @bind-Value="model.Dimension" Label="Dimension" Variant="Variant.Outlined" Margin="Margin.Dense" ></MudTextField>

                    </MudItem>
                     <MudItem xs="12" md="3">
                        <MudTextField @bind-Value="model.CostCenter" Label="CostCenter" Variant="Variant.Outlined" Margin="Margin.Dense" ></MudTextField>

                    </MudItem>
                     <MudItem xs="12" md="12">
                        <MudTextField @bind-Value="model.Narration" Lines="2" Label="Narration" Variant="Variant.Outlined" Margin="Margin.Dense" ></MudTextField>

                    </MudItem>

   <MudItem xs="12">
        <MudTable Items="@collection"  Dense="true" Hover="true"  Striped="true" Elevation="10"  @bind-place="model1">
           

            
            <HeaderContent>
                <MudTh><MudTableSortLabel SortBy="new Func<AccountInfoViewSubModel, object>(x=> x.AccountName)" InitialDirection="SortDirection.Ascending">AccountName</MudTableSortLabel></MudTh>
             <MudTh><MudTableSortLabel SortBy="new Func<AccountInfoViewSubModel, object>(x=> x.Amount)" InitialDirection="SortDirection.Ascending">Amount</MudTableSortLabel></MudTh>
               <MudTh><MudTableSortLabel SortBy="new Func<AccountInfoViewSubModel, object>(x=> x.BranchName)" InitialDirection="SortDirection.Ascending">Branch</MudTableSortLabel></MudTh>
                 <MudTh><MudTableSortLabel SortBy="new Func<AccountInfoViewSubModel, object>(x=> x.Reference)" InitialDirection="SortDirection.Ascending">Reference</MudTableSortLabel></MudTh>
               
                
                <MudTh>Actions</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="AccountName">@context.AccountName</MudTd>
                <MudTd DataLabel="Amount">@context.Amount+" "+@context.drcr</MudTd>
                <MudTd DataLabel="Branch">@context.BranchName</MudTd>
                <MudTd DataLabel="Reference">@context.Reference</MudTd>
                
             
            </RowTemplate>
            <PagerContent>
                <MudTablePager PageSizeOptions="new int[] { 5, 10, 20, 50, 100 }" />
            </PagerContent>
        </MudTable>
    </MudItem>
    </MudGrid>
     </MudContainer>
         </DialogContent>
    </MudDialog>

@code {
    [Parameter]
    public int MID  { get; set; }
    private AccountInfoViewModel model = new AccountInfoViewModel();
    private AccountInfoViewSubModel model1 =new AccountInfoViewSubModel();
    private List<AccountInfoViewSubModel> collection = new List<AccountInfoViewSubModel>();
    //private AccountInfoViewModel collection;
    protected override async Task OnInitializedAsync()
    {
        model = new();
        GetAll();
    }
    private  void  GetAll()
    {
        model = Iservice.SelectByID(MID);
        collection = model.Entries.ToList();



    }   

}
