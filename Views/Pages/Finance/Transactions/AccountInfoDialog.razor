@code {
    [Parameter]
    public int? MID { get; set; }

    private AccountInfoViewModel model = new AccountInfoViewModel();
    private AccountInfoViewSubModel model1 = new AccountInfoViewSubModel();
    private List<AccountInfoViewSubModel> collection = new List<AccountInfoViewSubModel>();

    protected override void OnInitialized()
    {
        GetAll();
    }
    private void GetAll()
    {
        if (MID != null)
        {
            model = Iservice.SelectByID(MID);
            collection = Iservice.Entries(MID).ToList();
        }
    }

}
