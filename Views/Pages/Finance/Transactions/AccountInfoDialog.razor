@inject IAccountInfoService Iservice
@inject MudBlazor.ISnackbar snackbar
@inject AuthenticationStateProvider auth
@attribute [Authorize]
@inject IDialogService DialogService

<MudPaper Elevation="0" Class="pa-6 mt-6 border-solid border-1 mud-border-lines-default rounded-lg" Outlined="true" Style="background: var(--mud-palette-background-grey);">
    <MudTable Items="@collection" Hover="true" Striped="true" Elevation="0" Class="rounded-lg shadow-sm p-4" Breakpoint="Breakpoint.Sm">
        <ToolBarContent>
            <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-4">
                <MudIcon Icon="@Icons.Material.Filled.AccountBalance" Color="Color.Primary" Size="Size.Large" Class="mr-2" />
                <MudText Typo="Typo.h6" Class="fw-bold">Financial Accounts Entries</MudText>
            </MudStack>
            <MudSpacer />
        </ToolBarContent>
        <HeaderContent>
            <MudTh><MudTableSortLabel SortBy="@(new Func<AccountInfoViewSubModel, object>(x=> x.BranchName))" InitialDirection="SortDirection.Ascending"><MudText Typo="Typo.subtitle2" Class="fw-bold">Branch</MudText></MudTableSortLabel></MudTh>
            <MudTh><MudText Typo="Typo.subtitle2" Class="fw-bold">Document Date</MudText></MudTh>
            <MudTh><MudTableSortLabel SortBy="@(new Func<AccountInfoViewSubModel, object>(x=> x.AccountName))" InitialDirection="SortDirection.Ascending"><MudText Typo="Typo.subtitle2" Class="fw-bold">Account Name</MudText></MudTableSortLabel></MudTh>
            <MudTh Style="text-align: right;"><MudTableSortLabel SortBy="@(new Func<AccountInfoViewSubModel, object>(x=> x.Amount))" InitialDirection="SortDirection.Ascending"><MudText Typo="Typo.subtitle2" Class="fw-bold">Amount</MudText></MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel SortBy="@(new Func<AccountInfoViewSubModel, object>(x=> x.Reference))" InitialDirection="SortDirection.Ascending"><MudText Typo="Typo.subtitle2" Class="fw-bold">Reference</MudText></MudTableSortLabel></MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Branch">
                <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Text" Class="fw-bold">@context.BranchName</MudChip>
            </MudTd>
            <MudTd DataLabel="Date">
                <MudText Typo="Typo.body2">@model.DocumentDate?.ToString("dd-MM-yyyy")</MudText>
            </MudTd>
            <MudTd DataLabel="Account Name">
                <MudText Typo="Typo.body2" Class="fw-bold">@context.AccountName</MudText>
            </MudTd>
            <MudTd DataLabel="Amount" Style="text-align:right">
                <MudStack Row="true" Justify="Justify.FlexEnd" AlignItems="AlignItems.Center">
                    <MudText Typo="Typo.body2" Class="fw-bold">@Math.Abs(context.Amount ?? 0).ToString("N2")</MudText>
                    <MudChip T="string" Size="Size.Small" Color="@(context.drcr?.ToUpper() == "DR" ? Color.Error : Color.Success)" Variant="Variant.Filled" Style="min-width: 32px; height: 20px; font-size: 0.7rem;">@context.drcr</MudChip>
                </MudStack>
            </MudTd>
            <MudTd DataLabel="Reference" Style="white-space: inherit; word-break: break-word; min-width: 250px;">
                <MudText Typo="Typo.body2" Class="mud-text-secondary">@context.Reference</MudText>
            </MudTd>
        </RowTemplate>
    </MudTable>
</MudPaper>

@code {

    [Parameter]
    public int? MID { get; set; }
    private AccountInfoViewModel model = new AccountInfoViewModel();
    private AccountInfoViewSubModel model1 = new AccountInfoViewSubModel();
    private List<AccountInfoViewSubModel> collection = new List<AccountInfoViewSubModel>();

    // Lifecycle method called when the component is initialized
    protected override void OnInitialized()
    {
        GetAll();
    }

    // Method to retrieve account information and related entries
    private void GetAll()
    {
        if (MID != null)
        {
            // Fetch the account information based on the provided ID
            model = Iservice.SelectByID(MID);

            // Fetch the entries related to the account and store them in the collection
            collection = Iservice.Entries(MID).ToList();
        }
    }
}
