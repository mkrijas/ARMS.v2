@inject IAccountInfoService Iservice
@inject MudBlazor.ISnackbar snackbar
@inject AuthenticationStateProvider auth
@attribute [Authorize]
@inject IDialogService DialogService

<MudPaper Elevation="1" Style="margin-top:30px; text-align-last: center;">
    <MudTable Items="@collection" Dense="true" Hover="true" Striped="true" Elevation="0">
        <ToolBarContent>
            <MudSpacer></MudSpacer>
            <MudText Align="Align.Center" Typo="Typo.h6">Financial Accounts Entries</MudText>
            <MudSpacer></MudSpacer>
        </ToolBarContent>
        <HeaderContent>
            <MudTh><MudTableSortLabel SortBy="new Func<AccountInfoViewSubModel, object>(x=> x.BranchName)" InitialDirection="SortDirection.Ascending">Branch</MudTableSortLabel></MudTh>
            <MudTh> Document Date</MudTh>
            <MudTh><MudTableSortLabel SortBy="new Func<AccountInfoViewSubModel, object>(x=> x.AccountName)" InitialDirection="SortDirection.Ascending">Account Name</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel SortBy="new Func<AccountInfoViewSubModel, object>(x=> x.Amount)" InitialDirection="SortDirection.Ascending">Amount</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel SortBy="new Func<AccountInfoViewSubModel, object>(x=> x.Reference)" InitialDirection="SortDirection.Ascending">Reference</MudTableSortLabel></MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Branch">@context.BranchName</MudTd>
            <MudTd DataLabel="Date">@model.DocumentDate?.ToShortDateString()</MudTd>
            <MudTd DataLabel="AccountName">@context.AccountName</MudTd>
            <MudTd DataLabel="Amount" Style="text-align:right"> @Math.Abs(context.Amount ?? 0) @context.drcr</MudTd>
            <MudTd DataLabel="Reference"> @context.Reference</MudTd>
        </RowTemplate>
    </MudTable>
</MudPaper>

@code {

    [Parameter]
    public int? MID { get; set; }
    private AccountInfoViewModel model = new AccountInfoViewModel();
    private AccountInfoViewSubModel model1 = new AccountInfoViewSubModel();
    private List<AccountInfoViewSubModel> collection = new List<AccountInfoViewSubModel>();

    protected override void OnInitialized()
    {
        GetAll();
    }

    private void GetAll()
    {
        if (MID != null)
        {
            model = Iservice.SelectByID(MID);
            collection = Iservice.Entries(MID).ToList();
        }
    }
}