@inject IDialogService DialogService
@inject MudBlazor.ISnackbar snackbar
@inject ITdsRateService tdsService
@inject IGstItemService gstIservice
@inject IAssetService assetIservice
@inject AuthenticationStateProvider auth

@if (AssetList != null)
{
    @if (!ReadOnly || AssetList.Any())
    {
        @*  <MudItem xs="12" Style="overflow-x:auto; overflow-y:hidden;"> *@
        <h6> <u>Assets</u></h6>
        @*  <div style="width: 1600px;" class="pb-3"> *@
        <MudGrid Justify="Justify.Center">
            <MudItem xs="3"><span class="HeadText">Asset Info</span></MudItem>
            <MudItem xs="2"><span class="HeadText">Serial Number</span></MudItem>
            <MudItem xs="1"><span class="HeadText">Asset Value</span></MudItem>
            <MudItem xs="2"><span class="HeadText">Sale Value</span></MudItem>
            <MudItem xs="2"><span class="HeadText">Taxable Value</span></MudItem>
            <MudItem xs="1"><span class="HeadText">Tax</span></MudItem>
            <MudItem xs="1">Actions</MudItem>
            @foreach (var item in AssetList)
            {
                <MudItem xs="3">@(string.Format("{0} : {1} ", item.AssetCode, item.AssetName))</MudItem>
                <MudItem xs="2">@item.SerialNumber</MudItem>
                <MudItem xs="1">@item.CurrentValue</MudItem>
                <MudItem xs="2">@item.SaleValue</MudItem>
                <MudItem xs="2">@item.TaxableValue</MudItem>
                <MudItem xs="1">@(string.Format("{0}", item.GSTValue))</MudItem>
                <MudItem xs="1" Class="d-flex">
                    @if (!ReadOnly)
                    {
                        <MudIconButton Title="Delete" Color="Color.Error" @onclick="@(()=> Delete(@item))" Icon="@Icons.Material.Filled.Delete" Size="Size.Small" />
                    }
                    <MudIconButton Title="Show Taxes" Color="Color.Info" @onclick="@(()=> OpenDialogTaxRates(@item))" Icon="@Icons.Material.Filled.CurrencyExchange" Size="Size.Small" />
                </MudItem>
            }
            @if (!ReadOnly && !NonInventoryItems)
            {
                <MudItem xs="3">
                    <MudAutocomplete T="AssetModel" Label="Select Parent Asset" Value="Asset" ValueChanged="AssetSelected" ResetValueOnEmptyText="true" Variant="Variant.Outlined" Margin="Margin.Dense" AdornmentColor="Color.Secondary"
                                     SearchFunc="SearchAsset" ToStringFunc="@(e => (e == null || string.IsNullOrWhiteSpace(e.AssetCode) && string.IsNullOrWhiteSpace(e.Description)) ? null : string.Format("{0} | {1}",e.AssetCode,e.Description))"></MudAutocomplete>
                </MudItem>
                <MudItem xs="2">
                    @Model.SerialNumber
                </MudItem>
                <MudItem xs="1">
                    @Model.CurrentValue
                </MudItem>
                <MudItem xs="2">
                    <MudTextField @bind-Value="@Model.SaleValue" Variant="Variant.Outlined" Margin="Margin.Dense" />
                </MudItem>
                <MudItem xs="2">
                    <MudTextField @bind-Value="@Model.TaxableValue" Variant="Variant.Outlined" Margin="Margin.Dense" />
                </MudItem>
                <MudItem xs="1">
                    <MudTextField @bind-Value="@Model.TaxRate" Variant="Variant.Outlined" Margin="Margin.Dense" AdornmentText="%" Adornment="Adornment.End" />
                </MudItem>
                <MudItem xs="1" Class="d-flex align-center">
                    <MudIconButton Title="Add" OnClick="AddItems" Color="Color.Primary" Icon="@Icons.Material.Filled.Add" Size="Size.Small" />
                </MudItem>
            }
        </MudGrid>
        @*  </div>

           </MudItem> *@
    }
}

@code {

    [Parameter]
    public List<AssetSaleModel> AssetList { get; set; }
    [Parameter]
    public bool ReadOnly { get; set; }
    [Parameter]
    public bool NonInventoryItems { get; set; }
    [Parameter]
    public int? BranchID { get; set; }
    [Parameter]
    public PartyModel PartyInfo { get; set; }
    [Parameter]
    public bool Local { get; set; } = true;
    [Parameter]
    public bool IsTaxable { get; set; } = true;
    [Parameter]
    public bool NonInventory { get; set; } = true;
    [Parameter]
    public EventCallback<AssetSaleModel> OnAssetAdded { get; set; }
    [Parameter]
    public EventCallback OnAmountChange { get; set; }
    [Parameter]
    public bool EditMode { get; set; } = true;
    // InventoryItemModel InventoryItem = new();
    AssetSaleModel Model = new AssetSaleModel();
    EditContext editContext;
    public AssetModel Asset { get; set; } = new();
    private bool _busy;
    string UserID;
    int branchID;

    // Lifecycle method called when parameters are set or changed
    protected override void OnParametersSet()
    {
        if (editContext == null)
        {
            editContext = new EditContext(Model);
            editContext.EnableDataAnnotationsValidation();
        }
    }

    // Lifecycle method called when the component is initialized
    protected override void OnInitialized()
    {
        branchID = BranchID.Value;

        if (AssetList != null)
        {
            if (AssetList.Count == 0)
            {
                NonInventoryItems = false;
            }
            else
            {
                NonInventoryItems = true;
            }
            if (!EditMode)
            {
                foreach (var item in AssetList)
                {
                    AddTax(item);
                }
            }
        }
    }

    // Method to search for assets based on a search string
    private async Task<IEnumerable<AssetModel>> SearchAsset(string searchString)
    {
        await Task.Delay(5);
        var authprov = await auth.GetAuthenticationStateAsync();
        var brancIDString = authprov.User.Claims.First(x => x.Type == "BranchID").Value;
        int brancID = int.Parse(brancIDString);
        return await Task.FromResult((assetIservice.SelectByBranch(brancID, false, null, searchString).Where(x => !x.IsComplex 
                                                                                                               && !x.IsSold 
                                                                                                               && (string.IsNullOrEmpty(searchString)
                                                                                                                   || x.AssetCode.Contains(searchString, StringComparison.OrdinalIgnoreCase)
                                                                                                                   || x.Description.Contains(searchString, StringComparison.OrdinalIgnoreCase)
                                                                                                                  ))));
    }

    // Method to add items to the asset sale model
    public async Task AddItems()
    {
        if (Asset is null)
        {
            snackbar.Add("Please select a asset!!", Severity.Warning);
            Asset = null;
            return;
        }
        if (AddTax(Model))
        {

            await OnAssetAdded.InvokeAsync(Model);
            Asset = null;
            Model = new();
        }
        else
        {
            snackbar.Add("Entered Asset are invalid", Severity.Error);
        }
    }

    // Method to handle selection of an asset
    public async Task AssetSelected(AssetModel selectedAsset)
    {
        Asset = (selectedAsset != null ? selectedAsset : new());
        if (Asset.IsSold == true)
        {
            snackbar.Add("Entered Asset are already sold!!", Severity.Warning);
            Asset = null;
            return;
        }
        if (selectedAsset is not null)
        {
            // assetIservice.SelectPOByID(Asset.AssetID);
            Model = new AssetSaleModel()
                {
                    AssetCode = Asset.AssetCode,
                    AssetID = Asset.AssetID,
                    AssetName = Asset.Description,
                    CurrentValue = Asset.CurrentValue,
                    SerialNumber = Asset.SerialNumber,
                    TaxRate = Asset.TaxRate,
                    //GstMechanism = Asset.GstMechanism,

                };
            if (Model?.AssetCode is null)
            {
                snackbar.Add("Entered Asset are invalid!!", Severity.Warning);
                Asset = null;
                return;
            }
        }
    }

    // Method to delete an asset sale entry
    private async Task Delete(AssetSaleModel i)
    {
        int rowIndex = AssetList.IndexOf(i);
        AssetList.RemoveAt(rowIndex);
        await OnAmountChange.InvokeAsync();
    }

    // Method to add tax to the asset sale model
    private bool AddTax(AssetSaleModel asset)
    {

        if (PartyInfo == null)
        {
            snackbar.Add("select party", Severity.Error);
            return false;
        }
        //decimal tdsRate = tdsService.GetTdsRate(PartyInfo.PartyID, asset.CoaID);
        asset.TDS = 0; //Math.Round((asset.SaleValue.Value * tdsRate) / 100, MidpointRounding.AwayFromZero);
        if (!IsTaxable)
        {
            return true;
        }
        //Model.GstRateID = usageIservice.GetGstRate(Model.UsageCode, DateTime.Now);
        decimal taxRate = asset.TaxRate ?? 0;
        if (!Local)
        {
            asset.IGSTValue = Math.Round(asset.TaxableValue.Value * taxRate / 100, 2);
        }
        else
        {
            asset.SGSTValue = asset.CGSTValue = Math.Round(asset.TaxableValue.Value * taxRate / 200, 2);
        }
        asset.GSTValue = (asset.IGSTValue ?? 0) + (asset.CGSTValue ?? 0) + (asset.SGSTValue ?? 0);

        return true;
    }

    // Method to open the tax rates dialog for an asset sale entry
    private async Task OpenDialogTaxRates(AssetSaleModel i)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        _busy = true;
        GstModel taxModel = new GstModel();
        taxModel.CGST = i.CGSTValue;
        taxModel.IGST = i.IGSTValue;
        taxModel.TDS = i.TDS;
        taxModel.SGST = i.SGSTValue;
        taxModel.GstRate = i.TaxRate;
        DialogParameters parms = new DialogParameters();
        parms.Add("tax", taxModel);
        parms.Add("ReadOnly", ReadOnly);
        var dialog = DialogService.Show<TaxRatedialog>(i.PID == null ? "ADD" : "EDIT", parms, new DialogOptions() { MaxWidth = MaxWidth.Small, FullWidth = true });
        var result = await dialog.Result;
        if (!result.Canceled)
        {
            taxModel = (GstModel)result.Data;
            i.CGSTValue = taxModel.CGST;
            i.IGSTValue = taxModel.IGST;
            i.TDS = taxModel.TDS;
            i.SGSTValue = taxModel.SGST;
            i.GSTValue = taxModel.CGST + taxModel.IGST + taxModel.SGST;
            //i.TaxRate = Convert.ToInt32(taxModel.GstRate);

            await OnAmountChange.InvokeAsync();
        }
        await Task.Delay(200);
        _busy = false;
    }
}