@using System.Threading;
@inject IDialogService DialogService
@inject MudBlazor.ISnackbar snackbar
@inject ITdsRateService tdsService
@inject IGstItemService gstIservice
@inject IAssetService assetIservice
@inject AuthenticationStateProvider auth

@if (AssetList != null)
{
    @if (!ReadOnly || AssetList.Any())
    {
    <div class="admin-glass-card pa-0 overflow-hidden mb-6">
        <div class="px-6 py-4 border-bottom-subtle" style="background: rgba(255, 159, 67, 0.02);">
            <span class="admin-section-label mb-0">Assets for Disposal</span>
        </div>
        
        <div class="modern-admin-table">
            <MudGrid Class="admin-table-header px-6 py-3">
                <MudItem xs="3"><span class="admin-header-text">ASSET INFO</span></MudItem>
                <MudItem xs="2"><span class="admin-header-text">SERIAL NUMBER</span></MudItem>
                <MudItem xs="2" Class="text-right"><span class="admin-header-text">CURRENT VAL.</span></MudItem>
                <MudItem xs="2" Class="text-right"><span class="admin-header-text">SALE VAL.</span></MudItem>
                <MudItem xs="2" Class="text-right"><span class="admin-header-text">TAXABLE VAL.</span></MudItem>
                <MudItem xs="1" Class="text-right"></MudItem>
            </MudGrid>

            @foreach (var item in AssetList)
            {
                <MudGrid Class="px-6 py-3 border-bottom-subtle align-center">
                    <MudItem xs="3">
                        <MudText Typo="Typo.body2" Style="font-weight: 700;">@item.AssetCode</MudText>
                        <MudText Typo="Typo.caption" Style="color: #667085;">@item.AssetName</MudText>
                    </MudItem>
                    <MudItem xs="2">
                        <MudText Typo="Typo.body2">@item.SerialNumber</MudText>
                    </MudItem>
                    <MudItem xs="2" Class="text-right">
                        <MudText Typo="Typo.body2" Style="color: #667085;">₹ @item.CurrentValue</MudText>
                    </MudItem>
                    <MudItem xs="2" Class="text-right">
                        <MudText Typo="Typo.body1" Style="font-weight: 800; color: #FF9F43;">₹ @item.SaleValue</MudText>
                    </MudItem>
                    <MudItem xs="2" Class="text-right">
                        <MudText Typo="Typo.body2">₹ @item.TaxableValue</MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">GST: @item.GSTValue</MudText>
                    </MudItem>
                    <MudItem xs="1" Class="d-flex justify-end align-center">
                         @if (!ReadOnly)
                        {
                            <MudIconButton Title="Delete" Color="Color.Error" @onclick="@(()=> Delete(item))" Icon="@Icons.Material.Filled.DeleteOutline" Size="Size.Small" />
                        }
                        <MudIconButton Title="Tax Info" Color="Color.Info" @onclick="@(()=> OpenDialogTaxRates(item))" Icon="@Icons.Material.Filled.Percent" Size="Size.Small" />
                    </MudItem>
                </MudGrid>
            }

            @if (!ReadOnly && !NonInventoryItems)
            {
                <div class="pa-6" style="background: rgba(255, 159, 67, 0.03); border-top: 1px dashed rgba(255,159,67,0.3);">
                    <MudGrid Spacing="2" AlignItems="AlignItems.Center">
                        <MudItem xs="12" md="4">
                            <MudAutocomplete T="AssetModel" Label="Search & Select Parent Asset" Value="Asset" ValueChanged="AssetSelected" ResetValueOnEmptyText="true" Variant="Variant.Outlined" Margin="Margin.Dense" Class="admin-input-group mb-2"
                                             SearchFunc="@(async (string s, CancellationToken t) => await SearchAsset(s, t))" ToStringFunc="@(e => (e == null || string.IsNullOrWhiteSpace(e.AssetCode) && string.IsNullOrWhiteSpace(e.Description)) ? null : string.Format("{0} | {1}",e.AssetCode,e.Description))"></MudAutocomplete>
                             <div class="d-flex gap-4 px-2">
                                <MudText Typo="Typo.caption">S/N: <b>@Model.SerialNumber</b></MudText>
                                <MudText Typo="Typo.caption">Cur. Val: <b>₹ @Model.CurrentValue</b></MudText>
                             </div>
                        </MudItem>
                        <MudItem xs="12" md="2">
                             <MudNumericField HideSpinButtons Label="Sale Value" @bind-Value="@Model.SaleValue" Variant="Variant.Outlined" Margin="Margin.Dense" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.CurrencyRupee" Class="admin-input-group" />
                        </MudItem>
                        <MudItem xs="12" md="2">
                             <MudNumericField HideSpinButtons Label="Taxable Value" @bind-Value="@Model.TaxableValue" Variant="Variant.Outlined" Margin="Margin.Dense" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Calculate" Class="admin-input-group" />
                        </MudItem>
                        <MudItem xs="12" md="2">
                             <MudNumericField HideSpinButtons Label="GST Rate %" @bind-Value="@Model.TaxRate" Variant="Variant.Outlined" Margin="Margin.Dense" Adornment="Adornment.End" AdornmentText="%" Class="admin-input-group" />
                        </MudItem>
                        <MudItem xs="12" md="2" Class="d-flex justify-center">
                            <MudIconButton OnClick="AddItems" Color="Color.Primary" Variant="Variant.Filled" Style="background: #FF9F43; border-radius: 10px; min-width: 50px; height: 40px;" Icon="@Icons.Material.Filled.Add" Size="Size.Medium" Title="ADD ASSET" />
                        </MudItem>
                    </MudGrid>
                </div>
            }
        </div>
    </div>
    }
}

@code {

    [Parameter]
    public List<AssetSaleModel> AssetList { get; set; }
    [Parameter]
    public bool ReadOnly { get; set; }
    [Parameter]
    public bool NonInventoryItems { get; set; }
    [Parameter]
    public int? BranchID { get; set; }
    [Parameter]
    public PartyModel PartyInfo { get; set; }
    [Parameter]
    public bool Local { get; set; } = true;
    [Parameter]
    public bool IsTaxable { get; set; } = true;
    [Parameter]
    public bool NonInventory { get; set; } = true;
    [Parameter]
    public EventCallback<AssetSaleModel> OnAssetAdded { get; set; }
    [Parameter]
    public EventCallback OnAmountChange { get; set; }
    [Parameter]
    public bool EditMode { get; set; } = true;
    // InventoryItemModel InventoryItem = new();
    AssetSaleModel Model = new AssetSaleModel();
    EditContext editContext;
    public AssetModel Asset { get; set; } = new();
    private bool _busy;
    string UserID;
    int branchID;

    // Lifecycle method called when parameters are set or changed
    protected override void OnParametersSet()
    {
        if (editContext == null)
        {
            editContext = new EditContext(Model);
            editContext.EnableDataAnnotationsValidation();
        }
    }

    // Lifecycle method called when the component is initialized
    protected override void OnInitialized()
    {
        branchID = BranchID ?? 0;

        if (AssetList != null)
        {
            if (AssetList.Count == 0)
            {
                NonInventoryItems = false;
            }
            else
            {
                NonInventoryItems = true;
            }
            if (!EditMode)
            {
                foreach (var item in AssetList)
                {
                    AddTax(item);
                }
            }
        }
    }

    // Method to search for assets based on a search string
    private async Task<IEnumerable<AssetModel>> SearchAsset(string searchString, CancellationToken token)
    {
        await Task.Delay(5);
        var authprov = await auth.GetAuthenticationStateAsync();
        var brancIDString = authprov.User.Claims.First(x => x.Type == "BranchID").Value;
        int brancID = int.Parse(brancIDString);
        return await Task.FromResult((assetIservice.SelectByBranch(brancID, false, null, searchString).Where(x => !x.IsComplex 
                                                                                                               && !x.IsSold 
                                                                                                              // && (string.IsNullOrEmpty(searchString)
                                                                                                                   // || x.AssetCode.Contains(searchString, StringComparison.OrdinalIgnoreCase)
                                                                                                                   // || x.Description.Contains(searchString, StringComparison.OrdinalIgnoreCase)
                                                                                                                //  )
                                                                                                                  )));
    }

    // Method to add items to the asset sale model
    public async Task AddItems()
    {
        if (Asset is null)
        {
            snackbar.Add("Please select a asset!!", Severity.Warning);
            Asset = null;
            return;
        }
        if (AddTax(Model))
        {

            await OnAssetAdded.InvokeAsync(Model);
            Asset = null;
            Model = new();
        }
        else
        {
            snackbar.Add("Entered Asset are invalid", Severity.Error);
        }
    }

    // Method to handle selection of an asset
    public async Task AssetSelected(AssetModel selectedAsset)
    {
        Asset = (selectedAsset != null ? selectedAsset : new());
        if (Asset.IsSold == true)
        {
            snackbar.Add("Entered Asset are already sold!!", Severity.Warning);
            Asset = null;
            return;
        }
        if (selectedAsset is not null)
        {
            // assetIservice.SelectPOByID(Asset.AssetID);
            Model = new AssetSaleModel()
                {
                    AssetCode = Asset.AssetCode,
                    AssetID = Asset.AssetID,
                    AssetName = Asset.Description,
                    CurrentValue = Asset.CurrentValue,
                    SerialNumber = Asset.SerialNumber,
                    TaxRate = Asset.TaxRate,
                    //GstMechanism = Asset.GstMechanism,

                };
            if (Model?.AssetCode is null)
            {
                snackbar.Add("Entered Asset are invalid!!", Severity.Warning);
                Asset = null;
                return;
            }
        }
    }

    // Method to delete an asset sale entry
    private async Task Delete(AssetSaleModel i)
    {
        int rowIndex = AssetList.IndexOf(i);
        AssetList.RemoveAt(rowIndex);
        await OnAmountChange.InvokeAsync();
    }

    // Method to add tax to the asset sale model
    private bool AddTax(AssetSaleModel asset)
    {

        if (PartyInfo == null)
        {
            snackbar.Add("select party", Severity.Error);
            return false;
        }
        //decimal tdsRate = tdsService.GetTdsRate(PartyInfo.PartyID, asset.CoaID);
        asset.TDS = 0; //Math.Round((asset.SaleValue.Value * tdsRate) / 100, MidpointRounding.AwayFromZero);
        if (!IsTaxable)
        {
            return true;
        }
        //Model.GstRateID = usageIservice.GetGstRate(Model.UsageCode, DateTime.Now);
        decimal taxRate = asset.TaxRate ?? 0;
        decimal taxableValue = asset.TaxableValue ?? 0;
        if (!Local)
        {
            asset.IGSTValue = Math.Round(taxableValue * taxRate / 100, 2);
        }
        else
        {
            asset.SGSTValue = asset.CGSTValue = Math.Round(taxableValue * taxRate / 200, 2);
        }
        asset.GSTValue = (asset.IGSTValue ?? 0) + (asset.CGSTValue ?? 0) + (asset.SGSTValue ?? 0);

        return true;
    }

    // Method to open the tax rates dialog for an asset sale entry
    private async Task OpenDialogTaxRates(AssetSaleModel i)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        _busy = true;
        GstModel taxModel = new GstModel();
        taxModel.CGST = i.CGSTValue;
        taxModel.IGST = i.IGSTValue;
        taxModel.TDS = i.TDS;
        taxModel.SGST = i.SGSTValue;
        taxModel.GstRate = i.TaxRate;
        DialogParameters parms = new DialogParameters();
        parms.Add("tax", taxModel);
        parms.Add("ReadOnly", ReadOnly);
        var dialog = DialogService.Show<TaxRatedialog>(i.PID == null ? "ADD" : "EDIT", parms, new DialogOptions() { MaxWidth = MaxWidth.Small, FullWidth = true });
        var result = await dialog.Result;
        if (!result.Canceled)
        {
            taxModel = (GstModel)result.Data;
            i.CGSTValue = taxModel.CGST;
            i.IGSTValue = taxModel.IGST;
            i.TDS = taxModel.TDS;
            i.SGSTValue = taxModel.SGST;
            i.GSTValue = taxModel.CGST + taxModel.IGST + taxModel.SGST;
            //i.TaxRate = Convert.ToInt32(taxModel.GstRate);

            await OnAmountChange.InvokeAsync();
        }
        await Task.Delay(200);
        _busy = false;
    }
}
