@using System.Threading;
@inject IDialogService DialogService
@inject MudBlazor.ISnackbar snackbar
@inject ITdsRateService tdsService
@inject IGstItemService gstIservice
@inject IAssetService assetIservice
@inject AuthenticationStateProvider auth

@if (AssetList != null)
{
    @if (!ReadOnly || AssetList.Any())
    {
        <div class="modern-admin-table">
            <MudGrid Class="admin-table-header px-6 py-3">
                <MudItem xs="3"><span class="admin-header-text">ASSET NAME</span></MudItem>
                <MudItem xs="2"><span class="admin-header-text">ACCOUNT HEAD</span></MudItem>
                <MudItem xs="1"><span class="admin-header-text">VALUE</span></MudItem>
                <MudItem xs="1"><span class="admin-header-text">GST RATE</span></MudItem>
                <MudItem xs="1"><span class="admin-header-text">GST MECHANISM</span></MudItem>
                <MudItem xs="1"><span class="admin-header-text">CGST</span></MudItem>
                <MudItem xs="1"><span class="admin-header-text">SGST</span></MudItem>
                <MudItem xs="1"><span class="admin-header-text">IGST</span></MudItem>
                <MudItem xs="1"><span class="admin-header-text">TDS</span></MudItem>
                <MudItem xs="1"><span class="admin-header-text">ACTION</span></MudItem>
            </MudGrid>

            @foreach (var item in AssetList)
            {
                <MudGrid Class="px-6 py-2 border-bottom-subtle align-center">
                    <MudItem xs="3">
                        <MudText Typo="Typo.body2" Style="font-weight: 700; color: #141A46;">@item.Description</MudText>
                    </MudItem>
                    <MudItem xs="2">
                        <MudText Typo="Typo.body2">@item.AccountName</MudText>
                    </MudItem>
                    <MudItem xs="1">
                        <MudText Typo="Typo.body2" Style="font-weight: 700; color: #FF9F43;">₹ @item.BookValue</MudText>
                    </MudItem>
                    <MudItem xs="1">
                        <MudText Typo="Typo.body2">@item.TaxRate %</MudText>
                    </MudItem>
                    <MudItem xs="1">
                        <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Text" Style="font-weight: 700;">@item.GstMechanism</MudChip>
                    </MudItem>
                    <MudItem xs="1"><MudText Typo="Typo.caption">@item.CGSTValue</MudText></MudItem>
                    <MudItem xs="1"><MudText Typo="Typo.caption">@item.SGSTValue</MudText></MudItem>
                    <MudItem xs="1"><MudText Typo="Typo.caption">@item.IGSTValue</MudText></MudItem>
                    <MudItem xs="1"><MudText Typo="Typo.caption">@item.TDS</MudText></MudItem>
                    <MudItem xs="1" Class="d-flex">
                        @if (!ReadOnly)
                        {
                            <MudIconButton Color="Color.Error" OnClick="@(()=> Delete(@item))" Icon="@Icons.Material.Filled.Delete" Size="Size.Small" />
                        }
                        <MudTooltip Text="Tax Info">
                            <MudIconButton Color="Color.Info" OnClick="@(()=> OpenDialogTaxRates(@item))" Icon="@Icons.Material.Filled.CurrencyExchange" Size="Size.Small" />
                        </MudTooltip>
                    </MudItem>
                </MudGrid>
            }

            @if (!ReadOnly && !NonInventoryItems)
            {
                <div class="pa-4" style="background: rgba(255, 159, 67, 0.03); border-top: 1px solid rgba(255, 159, 67, 0.1);">
                    <MudGrid Spacing="2" AlignItems="AlignItems.Center">
                        <MudItem xs="12" md="4">
                            <MudAutocomplete T="AssetModel" Label="Asset" Value="Asset" ValueChanged="AssetSelected" ResetValueOnEmptyText="true" Variant="Variant.Outlined" Margin="Margin.Dense" AdornmentColor="Color.Secondary"
                                             SearchFunc="@(async (string s, CancellationToken t) => await SearchAsset(s, t))" ToStringFunc="@(e => (e == null || string.IsNullOrWhiteSpace(e.AssetCode) && string.IsNullOrWhiteSpace(e.Description)) ? null : string.Format("{0} | {1}",e.AssetCode,e.Description))" Class="admin-input-group"></MudAutocomplete>
                        </MudItem>
                        <MudItem xs="6" md="3">
                            <MudNumericField HideSpinButtons @bind-Value="@Model.BookValue" Label="Amount" Variant="Variant.Outlined" Margin="Margin.Dense" Class="admin-input-group"></MudNumericField>
                        </MudItem>
                        <MudItem xs="4" md="1">
                            <MudTextField @bind-Value="@Model.TaxRate" Label="GST %" Variant="Variant.Outlined" Margin="Margin.Dense" Class="admin-input-group" ReadOnly />
                        </MudItem>
                        <MudItem xs="4" md="2">
                             <GstMechanismSelector page="Asset" @bind-Value="@Model.GstMechanism"></GstMechanismSelector>
                        </MudItem>
                        <MudItem xs="4" md="1" Class="d-flex align-center">
                            <MudSpacer />
                            <MudIconButton OnClick="AddItems" Color="Color.Primary" Variant="Variant.Filled" Style="background: #FF9F43; border-radius: 10px; height: 40px; width: 45px;" Icon="@Icons.Material.Filled.Add" Size="Size.Medium" />
                        </MudItem>
                    </MudGrid>
                </div>
            }
        </div>
    }
}

@code {

    [Parameter]
    public List<AssetPOModel> AssetList { get; set; }
    [Parameter]
    public bool ReadOnly { get; set; }
    [Parameter]
    public bool NonInventoryItems { get; set; }
    [Parameter]
    public int? BranchID { get; set; }
    [Parameter]
    public PartyModel PartyInfo { get; set; }
    [Parameter]
    public bool Local { get; set; } = true;
    [Parameter]
    public bool IsTaxable { get; set; } = true;
    [Parameter]
    public bool NonInventory { get; set; } = true;
    [Parameter]
    public EventCallback<AssetPOModel> OnAssetAdded { get; set; }
    [Parameter]
    public EventCallback OnAmountChange { get; set; }
    [Parameter]
    public bool EditMode { get; set; } = true;
    InventoryItemModel InventoryItem = new();
    AssetPOModel Model = new AssetPOModel();
    EditContext editContext;
    public AssetModel Asset { get; set; }
    private bool _busy;
    string UserID;
    int branchID;

    // Lifecycle method called when parameters are set or changed
    protected override void OnParametersSet()
    {
        if (editContext == null)
        {
            editContext = new EditContext(Model);
            editContext.EnableDataAnnotationsValidation();
        }
    }

    // Lifecycle method called when the component is initialized
    protected override void OnInitialized()
    {
        branchID = BranchID ?? 0;

        if (AssetList != null)
        {
            if (AssetList.Count == 0)
            {
                NonInventoryItems = false;
            }
            else
            {
                NonInventoryItems = true;
            }
            if (!EditMode)
            {
                foreach (var item in AssetList)
                {
                    AddTax(item);
                }
            }
        }
    }

    // Method to search for assets based on a search string
    private async Task<IEnumerable<AssetModel>> SearchAsset(string searchString, CancellationToken token)
    {
        await Task.Delay(5);
        var authprov = await auth.GetAuthenticationStateAsync();
        var brancIDString = authprov.User.Claims.First(x => x.Type == "BranchID").Value;
        int brancID = int.Parse(brancIDString);

        // Return the filtered list of assets based on the search string
        return await Task.FromResult((assetIservice.SelectByBranch(brancID, false, null, searchString).Where(x => !x.IsComplex && !x.IsSold)));
    }

    // Method to add items to the asset sale model
    public async Task AddItems()
    {
        if (Asset is null)
        {
            snackbar.Add("Please select a asset!!", Severity.Warning);
            Asset = null;
            return;
        }
        if (AddTax(Model))
        {
            await OnAssetAdded.InvokeAsync(Model);
            Model = new();
            editContext = new EditContext(Model);
            editContext.EnableDataAnnotationsValidation();
            Asset = null;
            StateHasChanged();
        }
        else
        {
            snackbar.Add("Entered Asset are invalid", Severity.Error);
        }
    }

    // Method to handle selection of an asset
    void AssetSelected(AssetModel selectedAsset)
    {
        Asset = selectedAsset;
        if (Asset.IsSold == true)
        {
            snackbar.Add("Entered Asset are already sold!!", Severity.Warning);
            Asset = null;
            return;
        }
        if (selectedAsset is not null)
        {
            // Populate the model with the selected asset's details
            Model = assetIservice.SelectPOByID(Asset.AssetID);
            if (Model is null)
            {
                snackbar.Add("Entered Asset are invalid!!", Severity.Warning);
                Asset = null;
                return;
            }
        }
    }

    // Method to delete an asset sale entry
    private async Task Delete(AssetPOModel i)
    {
        int rowIndex = AssetList.IndexOf(i);
        AssetList.RemoveAt(rowIndex);
        await OnAmountChange.InvokeAsync();
    }

    // Method to add tax to the asset sale model
    private bool AddTax(AssetPOModel asset)
    {

        if (PartyInfo == null)
        {
            snackbar.Add("select party", Severity.Error);
            return false;
        }

        // Calculate TDS (Tax Deducted at Source) based on the asset's book value
        decimal tdsRate = tdsService.GetTdsRate(PartyInfo.PartyID, asset.CoaID);
        Model.TDS = Math.Round((asset.BookValue.Value * tdsRate) / 100, MidpointRounding.AwayFromZero);
        if (!IsTaxable)
        {
            return true;
        }
        //Model.GstRateID = usageIservice.GetGstRate(Model.UsageCode, DateTime.Now);
        decimal taxRate = asset.GSTValue ?? 0;
        if (!Local)
        {
            Model.IGSTValue = Math.Round(asset.BookValue.Value * asset.TaxRate.Value / 100, 2);
        }
        else
        {
            Model.SGSTValue = Model.CGSTValue = Math.Round(asset.BookValue.Value * asset.TaxRate.Value / 200, 2);
        }

        return true;
    }

    // Method to open the tax rates dialog for an asset sale entry
    private async Task OpenDialogTaxRates(AssetPOModel i)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        _busy = true;
        GstModel taxModel = new GstModel();
        taxModel.CGST = i.CGSTValue;
        taxModel.IGST = i.IGSTValue;
        taxModel.TDS = i.TDS;
        taxModel.SGST = i.SGSTValue;
        taxModel.GstRate = i.TaxRate;
        DialogParameters parms = new DialogParameters();
        parms.Add("tax", taxModel);
        parms.Add("ReadOnly", ReadOnly);
        var dialog = await DialogService.ShowAsync<TaxRatedialog>(i.PID == null ? "ADD" : "EDIT", parms, new DialogOptions() { MaxWidth = MaxWidth.Small, FullWidth = true });
        var result = await dialog.Result;
        if (!result.Canceled)
        {
            taxModel = (GstModel)result.Data;
            i.CGSTValue = taxModel.CGST;
            i.IGSTValue = taxModel.IGST;
            i.TDS = taxModel.TDS;
            i.SGSTValue = taxModel.SGST;
            i.TaxRate = Convert.ToInt32(taxModel.GstRate);

            await OnAmountChange.InvokeAsync();
        }
        await Task.Delay(200);
        _busy = false;
    }
}
