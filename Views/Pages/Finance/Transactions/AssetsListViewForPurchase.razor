@inject IDialogService DialogService
@inject MudBlazor.ISnackbar snackbar
@inject ITdsRateService tdsService
@inject IGstItemService gstIservice
@inject IAssetService assetIservice
@inject AuthenticationStateProvider auth

@if (AssetList != null)
{
    @if (!ReadOnly || AssetList.Any())
    {
        <MudItem xs="12" Style="overflow-x:auto; overflow-y:hidden;">
            <h6> <u>Assets</u></h6>
            <div style="width: 1600px;" class="pb-3">
                <MudGrid Justify="Justify.Center">
                    @* <MudItem xs="1"><span class="HeadText">Asset Code</span></MudItem> *@
                    <MudItem xs="2"><span class="HeadText">Asset Name</span></MudItem>
                    @* <MudItem xs="1"><span class="HeadText">Nature Of Asset</span></MudItem> *@
                    <MudItem xs="2"><span class="HeadText">Account Name</span></MudItem>
                    <MudItem xs="1"><span class="HeadText">Book Value</span></MudItem>
                    <MudItem xs="1"><span class="HeadText">GST Rate</span></MudItem>
                    <MudItem xs="1"><span class="HeadText">GST Mechanism</span></MudItem>
                    <MudItem xs="1"><span class="HeadText">CGST</span></MudItem>
                    <MudItem xs="1"><span class="HeadText">SGST</span></MudItem>
                    <MudItem xs="1"><span class="HeadText">IGST</span></MudItem>
                    <MudItem xs="1"><span class="HeadText">TDS</span></MudItem>
                    <MudItem xs="1">Actions</MudItem>
                    @foreach (var item in AssetList)
                    {
                        @* <MudItem xs="1">@item.AssetCode</MudItem> *@
                        <MudItem xs="2">@item.Description</MudItem>
                        @* <MudItem xs="1">@item.NatureOfAsset</MudItem> *@
                        <MudItem xs="2">@item.AccountName</MudItem>
                        <MudItem xs="1">@item.BookValue</MudItem>
                        <MudItem xs="1">@item.TaxRate</MudItem>
                        <MudItem xs="1">@item.GstMechanism</MudItem>
                        <MudItem xs="1">@item.CGSTValue</MudItem>
                        <MudItem xs="1">@item.SGSTValue</MudItem>
                        <MudItem xs="1">@item.IGSTValue</MudItem>
                        <MudItem xs="1">@item.TDS</MudItem>
                        <MudItem xs="1" Class="d-flex">
                            @if (!ReadOnly)
                            {
                                <MudIconButton Title="Delete" Color="Color.Error" @onclick="@(()=> Delete(@item))" Icon="@Icons.Material.Filled.Delete" Size="Size.Small" />
                            }
                            <MudIconButton Title="Show Taxes" Color="Color.Info" @onclick="@(()=> OpenDialogTaxRates(@item))" Icon="@Icons.Material.Filled.CurrencyExchange" Size="Size.Small" />
                        </MudItem>
                    }
                    @if (!ReadOnly && !NonInventoryItems)
                    {
                        <MudItem xs="2">
                            <MudAutocomplete T="AssetModel" Label="Select Parent Asset" Value="Asset" ValueChanged="AssetSelected" ResetValueOnEmptyText="true" Variant="Variant.Outlined" Margin="Margin.Dense" OffsetY="true" Direction="Direction.Top" AdornmentColor="Color.Secondary"
                                             SearchFunc="SearchAsset" ToStringFunc="@(e => (e == null || string.IsNullOrWhiteSpace(e.AssetCode) && string.IsNullOrWhiteSpace(e.Description)) ? null : string.Format("{0} | {1}",e.AssetCode,e.Description))"></MudAutocomplete>
                        </MudItem>
                        <MudItem xs="1">
                            <MudTd DataLabel="Description">@Model.Description</MudTd>
                        </MudItem>
                        <MudItem xs="1">
                            <MudTd DataLabel="NatureOfAsset">@Model.AccountName</MudTd>
                        </MudItem>
                        <MudItem xs="1">
                            <MudTd DataLabel="BookValue"><MudTextField @bind-Value="@Model.BookValue" /></MudTd>
                        </MudItem>
                        <MudItem xs="1">
                            <MudTd DataLabel="TaxRate"><MudTextField @bind-Value="@Model.TaxRate" /></MudTd>
                        </MudItem>
                        <MudItem xs="1">
                            <MudTd DataLabel="GstMechanism"><GstMechanismSelector page="Asset" @bind-Value="@Model.GstMechanism"></GstMechanismSelector></MudTd>
                        </MudItem>
                        <MudItem xs="1">
                            <MudTd DataLabel="CGSTValue">@Model.CGSTValue</MudTd>
                        </MudItem>
                        <MudItem xs="1">
                            <MudTd DataLabel="SGSTValue">@Model.SGSTValue</MudTd>
                        </MudItem>
                        <MudItem xs="1">
                            <MudTd DataLabel="IGSTValue">@Model.IGSTValue</MudTd>
                        </MudItem>
                        <MudItem xs="1">
                            <MudTd DataLabel="TDS"><MudTextField @bind-Value="@Model.BookValue" /></MudTd>
                        </MudItem>
                        <MudItem xs="1" Class="d-flex align-center">
                            <MudIconButton Title="Add" OnClick="AddItems" Color="Color.Primary" Icon="@Icons.Material.Filled.Add" Size="Size.Small" />
                        </MudItem>
                    }
                </MudGrid>
            </div>
        </MudItem>
    }
}

@code {

    [Parameter]
    public List<AssetPOModel> AssetList { get; set; }
    [Parameter]
    public bool ReadOnly { get; set; }
    [Parameter]
    public bool NonInventoryItems { get; set; }
    [Parameter]
    public int? BranchID { get; set; }
    [Parameter]
    public PartyModel PartyInfo { get; set; }
    [Parameter]
    public bool Local { get; set; } = true;
    [Parameter]
    public bool IsTaxable { get; set; } = true;
    [Parameter]
    public bool NonInventory { get; set; } = true;
    [Parameter]
    public EventCallback<AssetPOModel> OnAssetAdded { get; set; }
    [Parameter]
    public EventCallback OnAmountChange { get; set; }
    [Parameter]
    public bool EditMode { get; set; } = true;
    InventoryItemModel InventoryItem = new();
    AssetPOModel Model = new AssetPOModel();
    EditContext editContext;
    public AssetModel Asset { get; set; }
    private bool _busy;
    string UserID;
    int branchID;

    protected override void OnParametersSet()
    {
        if (editContext == null)
        {
            editContext = new EditContext(Model);
            editContext.EnableDataAnnotationsValidation();
        }
    }

    protected override void OnInitialized()
    {
        branchID = BranchID.Value;

        if (AssetList != null)
        {
            if (AssetList.Count == 0)
            {
                NonInventoryItems = false;
            }
            else
            {
                NonInventoryItems = true;
            }
            if (!EditMode)
            {
                foreach (var item in AssetList)
                {
                    AddTax(item);
                }
            }
        }
    }

    private async Task<IEnumerable<AssetModel>> SearchAsset(string searchString)
    {
        await Task.Delay(5);
        var authprov = await auth.GetAuthenticationStateAsync();
        var brancIDString = authprov.User.Claims.First(x => x.Type == "BranchID").Value;
        int brancID = int.Parse(brancIDString);
        return await Task.FromResult((assetIservice.SelectByBranch(brancID, false, null, searchString).Where(x => !x.IsComplex && !x.IsSold)));
    }

    public async Task AddItems()
    {
        if (Asset is null)
        {
            snackbar.Add("Please select a asset!!", Severity.Warning);
            Asset = null;
            return;
        }
        if (AddTax(Model))
        {
            await OnAssetAdded.InvokeAsync(Model);
            Model = new();
            Asset = null;
        }
        else
        {
            snackbar.Add("Entered Asset are invalid", Severity.Error);
        }
    }

    void AssetSelected(AssetModel selectedAsset)
    {
        Asset = selectedAsset;
        if (Asset.IsSold == true)
        {
            snackbar.Add("Entered Asset are already sold!!", Severity.Warning);
            Asset = null;
            return;
        }
        if (selectedAsset is not null)
        {
            Model = assetIservice.SelectPOByID(Asset.AssetID);
            if (Model is null)
            {
                snackbar.Add("Entered Asset are invalid!!", Severity.Warning);
                Asset = null;
                return;
            }
        }
    }

    private async Task Delete(AssetPOModel i)
    {
        int rowIndex = AssetList.IndexOf(i);
        AssetList.RemoveAt(rowIndex);
        await OnAmountChange.InvokeAsync();
    }

    private bool AddTax(AssetPOModel asset)
    {

        if (PartyInfo == null)
        {
            snackbar.Add("select party", Severity.Error);
            return false;
        }
        decimal tdsRate = tdsService.GetTdsRate(PartyInfo.PartyID, asset.CoaID);
        Model.TDS = Math.Round((asset.BookValue.Value * tdsRate) / 100, MidpointRounding.AwayFromZero);
        if (!IsTaxable)
        {
            return true;
        }
        //Model.GstRateID = usageIservice.GetGstRate(Model.UsageCode, DateTime.Now);
        decimal taxRate = asset.GSTValue ?? 0;
        if (!Local)
        {
            Model.IGSTValue = Math.Round(asset.BookValue.Value * asset.TaxRate.Value / 100, 2);
        }
        else
        {
            Model.SGSTValue = Model.CGSTValue = Math.Round(asset.BookValue.Value * asset.TaxRate.Value / 200, 2);
        }

        return true;
    }

    private async Task OpenDialogTaxRates(AssetPOModel i)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        _busy = true;
        GstModel taxModel = new GstModel();
        taxModel.CGST = i.CGSTValue;
        taxModel.IGST = i.IGSTValue;
        taxModel.TDS = i.TDS;
        taxModel.SGST = i.SGSTValue;
        taxModel.GstRate = i.TaxRate;
        DialogParameters parms = new DialogParameters();
        parms.Add("tax", taxModel);
        parms.Add("ReadOnly", ReadOnly);
        var dialog = DialogService.Show<TaxRatedialog>(i.PID == null ? "ADD" : "EDIT", parms, new DialogOptions() { MaxWidth = MaxWidth.Small, FullWidth = true });
        var result = await dialog.Result;
        if (!result.Canceled)
        {
            taxModel = (GstModel)result.Data;
            i.CGSTValue = taxModel.CGST;
            i.IGSTValue = taxModel.IGST;
            i.TDS = taxModel.TDS;
            i.SGSTValue = taxModel.SGST;
            i.TaxRate = Convert.ToInt32(taxModel.GstRate);

            await OnAmountChange.InvokeAsync();
        }
        await Task.Delay(200);
        _busy = false;
    }
}