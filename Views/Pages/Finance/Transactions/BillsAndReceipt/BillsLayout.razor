@page "/Billing"
@attribute [Authorize]
@inherits LayoutComponentBase
@layout MainLayout

@inject NavigationManager NavManager

<MudContainer MaxWidth="MaxWidth.False" Class="pa-4">
    <!-- Custom Segmented Tab Navigation -->
    <div class="d-flex justify-center mb-6">
        <MudPaper Elevation="0" Outlined="true" Class="d-flex align-center gap-2 pa-1 rounded-pill" Style="background-color: #ffffff; border-color: #e0e0e0;">
             <MudButton Variant="@(IsActive("/FreightBooking") ? Variant.Filled : Variant.Text)" 
                        Color="@(IsActive("/FreightBooking") ? Color.Primary : Color.Default)"
                        OnClick="@(() => Navigate("/FreightBooking"))"
                        Class="rounded-pill px-6"
                        Style="@(IsActive("/FreightBooking") ? "box-shadow: 0 4px 14px 0 rgba(var(--mud-palette-primary-rgb), 0.39);" : "color: #6E6B7B;")"
                        StartIcon="@Icons.Material.Filled.LocalShipping">
                 Book Freight
             </MudButton>

             <MudButton Variant="@(IsActive("/ConsolidatedBills") ? Variant.Filled : Variant.Text)" 
                        Color="@(IsActive("/ConsolidatedBills") ? Color.Primary : Color.Default)"
                        OnClick="@(() => Navigate("/ConsolidatedBills"))"
                        Class="rounded-pill px-6"
                        Style="@(IsActive("/ConsolidatedBills") ? "box-shadow: 0 4px 14px 0 rgba(var(--mud-palette-primary-rgb), 0.39);" : "color: #6E6B7B;")"
                        StartIcon="@Icons.Material.Filled.Assignment">
                 Consolidate Draft Bill
             </MudButton>

             <MudButton Variant="@(IsActive("/ProformaInvoiceView") ? Variant.Filled : Variant.Text)" 
                        Color="@(IsActive("/ProformaInvoiceView") ? Color.Primary : Color.Default)"
                        OnClick="@(() => Navigate("/ProformaInvoiceView"))"
                        Class="rounded-pill px-6"
                        Style="@(IsActive("/ProformaInvoiceView") ? "box-shadow: 0 4px 14px 0 rgba(var(--mud-palette-primary-rgb), 0.39);" : "color: #6E6B7B;")"
                        StartIcon="@Icons.Material.Filled.ReceiptLong">
                 Proforma Invoice
             </MudButton>
        </MudPaper>
    </div>
    
    <div class="mt-4">
         @Body
    </div>
</MudContainer>


@code {
    protected override void OnParametersSet()
    {
       StateHasChanged();
    }

    bool IsActive(string path)
    {
        return NavManager.Uri.Contains(path, StringComparison.OrdinalIgnoreCase);
    }

    void Navigate(string url)
    {
        NavManager.NavigateTo(url);
    }

    MudTheme MuudstrapTheme = new MudTheme()
    {
        PaletteLight = new PaletteLight()
        {
            AppbarBackground = "#f8f9fa",
            AppbarText = "#181819"
        },
        Typography = new Typography()
        {
            H6 = new H6Typography()
            {
                FontFamily = new[] { "system-ui", "-apple-system", "Segoe UI", "Roboto ", "Helvetica Neue", "Arial", "Noto Sans", "Liberation Sans", "sans-serif", "Apple Color Emoji", "Segoe UI Emoji", "Segoe UI Symbol", "Noto Color Emoji" },
                FontSize = "1.25rem",
                FontWeight = "400",
                LineHeight = "1.7",
                LetterSpacing = "normal"
            },
            Button = new ButtonTypography()
            {
                FontFamily = new[] { "system-ui", "-apple-system", "Segoe UI", "Roboto ", "Helvetica Neue", "Arial", "Noto Sans", "Liberation Sans", "sans-serif", "Apple Color Emoji", "Segoe UI Emoji", "Segoe UI Symbol", "Noto Color Emoji" },
                FontSize = "1rem",
                FontWeight = "400",
                LineHeight = "1.5",
                LetterSpacing = "normal"
            }
        }
    };
}
