@using System.Threading;
@inject IRoleService<RoleModel> Irole
@inject IFreightBillingService Iservice
@inject IOrderService orderIservice
@inject ITariffService tariffIservice
@inject MudBlazor.ISnackbar snackbar
@inject AuthenticationStateProvider auth
@attribute [Authorize]
@inject IDialogService DialogService

<DialogForm @ref="@dialogForm" ReadOnly="@ReadOnly" Title="Consolidate Bill" formID="ConsolidateBill" model="@model" _busy="_busy">
    <FormContent>
        <MudPaper Class="p-3">
            <EditForm id="ConsolidateBill" Model="@model" OnValidSubmit="OnValidSubmit">
                <ObjectGraphDataAnnotationsValidator />
                <ValidationSummary />
                <MudGrid Spacing="2">
                    <MudItem xs="12" md="4">
                        <MudTextField ReadOnly="true" Disabled="true" Label="Order" @bind-Value="model.Order.OrderName" Variant="Variant.Outlined" Margin="Margin.Dense" />
                    </MudItem>
                    <MudItem xs="12" md="4">
                        <MudTextField ReadOnly="true" Disabled="true" Label="Tariff Type" @bind-Value="model.TariffType.TariffTypeName" Variant="Variant.Outlined" Margin="Margin.Dense" />
                    </MudItem>
                    <MudItem xs="12" md="4">
                        <MudDatePicker ReadOnly="ReadOnly" Label="DocumentDate" Variant="Variant.Outlined" Margin="Margin.Dense" DisableToolbar="true" Editable="true" @bind-Date="model.DocumentDate" DateFormat="dd/MM/yyyy" For="@(()=> model.DocumentDate)" />
                    </MudItem>
                    <MudItem xs="12">
                        <MudTable Items="@collection" Dense Hover Striped Outlined Elevation="0" @bind-place="gctariffmodel">
                             <HeaderContent>
                                 <MudTh><MudTableSortLabel SortBy="new Func<GcTariffModel, object>(x=> x.BillNumber)" InitialDirection="SortDirection.Ascending">BillNumber</MudTableSortLabel></MudTh>
                                 <MudTh><MudTableSortLabel SortBy="new Func<GcTariffModel, object>(x=> x.BillDate)" InitialDirection="SortDirection.Ascending">BillDate</MudTableSortLabel></MudTh>
                                 <MudTh><MudTableSortLabel SortBy="new Func<GcTariffModel, object>(x=> x.InvoiceDate)" InitialDirection="SortDirection.Ascending">InvoiceDate</MudTableSortLabel></MudTh>
                                 <MudTh><MudTableSortLabel SortBy="new Func<GcTariffModel, object>(x=> x.ConsigneeName)" InitialDirection="SortDirection.Ascending">ConsigneeName</MudTableSortLabel></MudTh>
                                 <MudTh><MudTableSortLabel SortBy="new Func<GcTariffModel, object>(x=> x.BillQuantity)" InitialDirection="SortDirection.Ascending">BillQuantity</MudTableSortLabel></MudTh>
                                 <MudTh><MudTableSortLabel SortBy="new Func<GcTariffModel, object>(x=> x.Amount)" InitialDirection="SortDirection.Ascending">Freight</MudTableSortLabel></MudTh>
                             </HeaderContent>
                             <RowTemplate Context="cntxt">
                                 <MudTd DataLabel="BillNumber">@cntxt.BillNumber</MudTd>
                                 <MudTd DataLabel="BillDate">@cntxt.BillDate?.ToShortDateString()</MudTd>
                                 <MudTd DataLabel="InvoiceDate">@cntxt.InvoiceDate?.ToShortDateString()</MudTd>
                                 <MudTd DataLabel="ConsigneeName">@cntxt.ConsigneeName</MudTd>
                                 <MudTd DataLabel="BillQuantity">@cntxt.BillQuantity</MudTd>
                                 <MudTd DataLabel="Amount">@cntxt.Amount</MudTd>
                             </RowTemplate>
                         </MudTable>
                     </MudItem>
                     <MudItem xs="12" md="12">
                         <MudTextField ReadOnly="ReadOnly" @bind-Value="model.Narration" Lines="3" Label="Narration" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(()=> model.Narration)"></MudTextField>
                     </MudItem>
                     <MudItem xs="12">
                         @if (ReadOnly)
                        {
                            <AutherizationStatusComponent DocTypeID="@DocTypeID" DocDate="@DocDate" DocType="@DocType" DocNumber="@DocNumber" PageToRedirectLink="@PageToRedirectLink" DocumentID="model.DraftBillID" OnApprove="Approve" ApproveWithin></AutherizationStatusComponent>
                        }
                    </MudItem>
                </MudGrid>
            </EditForm>
        </MudPaper>
    </FormContent>
</DialogForm>

@code {

    [Parameter]
    public ConsolidatedDraftBillModel model { get; set; }
    [Parameter]
    public bool ReadOnly { get; set; }
    [Parameter]
    public string PageToRedirectLink { get; set; }
    public string DocNumber { get; set; }
    public DateTime? DocDate { get; set; }
    public string DocType { get; set; }

    private int? branchID = null;
    private string UserID = null;
    DialogForm dialogForm;

    public bool HasAuthoriseEdit { get; set; } = false;
    int DocTypeID = 1;
    private bool _busy;

    private GcTariffModel gctariffmodel = new GcTariffModel();
    private List<GcTariffModel> collection = new List<GcTariffModel>();

    protected override async Task OnInitializedAsync()
    {
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasAuthoriseEdit = await Irole.HasClaim(DocTypeID.ToString(), "Edit", ctc.Token);

        var authprov = await auth.GetAuthenticationStateAsync();
        var User = authprov.User;
        branchID = int.Parse(User.Claims.First(x => x.Type == "BranchID").Value);
        UserID = User.Identity.Name;
        if (ReadOnly)
        {
            collection = Iservice.GetBilled(model.DraftBillID).ToList();
        }
        else
        {
            collection = model.BookedGCs.ToList();
        }
        DocNumber = model.DocumentNumber;
        DocDate = model.DocumentDate;
        DocType = model.NatureOfTransaction;
    }

    private async Task OnValidSubmit(EditContext context)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is being submitted!", Severity.Warning);
            return;
        }
        _busy = true;

        if (HasAuthoriseEdit)
        {
            dialogForm.Close(model);
        }
        else
        {
            bool? result = await DialogService.ShowMessageBox(
                "Permission denied!",
                "You dont have any permission to submit.");
        }
        await Task.Delay(2000);
        _busy = false;
    }

    protected void Approve(DataApprovedStatus aprvd)
    {
        if (aprvd.IsApprove)
        {

        }
    }
}