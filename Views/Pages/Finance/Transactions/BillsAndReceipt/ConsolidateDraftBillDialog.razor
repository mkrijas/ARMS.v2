@using System.Threading;
@inject IRoleService<RoleModel> Irole
@inject IFreightBillingService Iservice
@inject IOrderService orderIservice
@inject ITariffService tariffIservice
@inject MudBlazor.ISnackbar snackbar
@inject AuthenticationStateProvider auth
@attribute [Authorize]
@inject IDialogService DialogService

<DialogForm @ref="@dialogForm" ReadOnly="@ReadOnly" Title="Consolidate Bill" formID="ConsolidateBill" model="@model" _busy="_busy">
    <FormContent>
        <MudPaper Class="p-3">
            <EditForm id="ConsolidateBill" Model="@model" OnValidSubmit="OnValidSubmit">
                <ObjectGraphDataAnnotationsValidator />
                <ValidationSummary />
                <MudGrid Spacing="2">
                    <MudItem xs="12" md="4">
                        <MudDatePicker ReadOnly="ReadOnly" Label="DocumentDate" Variant="Variant.Outlined" Margin="Margin.Dense" DisableToolbar="true" Editable="true" @bind-Date="model.DocumentDate" DateFormat="dd/MM/yyyy" For="@(()=> model.DocumentDate)" />
                    </MudItem>
                    <MudItem xs="12" md="4">
                        <MudDateRangePicker ReadOnly Label="Document Period" @bind-DateRange="dateRange" Variant="Variant.Outlined" Margin="Margin.Dense" DateFormat="dd/MM/yyyy"></MudDateRangePicker>
                    </MudItem>
                    <MudItem xs="12" md="4">
                        <TruckSelector IsDisabled Class="bg-white" Value="model.Truck" Filter="AvailableForBranch" HomeOrOperation="Operation" />
                    </MudItem>
                    <MudItem xs="12" md="4">
                        <MudTextField ReadOnly Label="Party" Value="model.Party?.TradeName" Variant="Variant.Outlined" Margin="Margin.Dense" />
                    </MudItem>
                    <MudItem xs="12" md="4">
                        <MudTextField ReadOnly Label="Order" Value="model.Order?.OrderName" Variant="Variant.Outlined" Margin="Margin.Dense" />
                    </MudItem>
                    <MudItem xs="12" md="4">
                        <MudTextField ReadOnly Label="Tariff Type" @bind-Value="model.TariffType.TariffTypeName" Variant="Variant.Outlined" Margin="Margin.Dense" />
                    </MudItem>
                    <MudItem xs="12">
                        <MudTable Items="@collection" Dense Hover Striped Outlined Elevation="0" @bind-place="gctariffmodel">
                            <HeaderContent>
                                <MudTh><MudTableSortLabel SortBy="new Func<GcTariffModel, object>(x=> x.BillDate)" InitialDirection="SortDirection.Ascending">BillDate</MudTableSortLabel></MudTh>
                                <MudTh><MudTableSortLabel SortBy="new Func<GcTariffModel, object>(x=> x.PassNumber)">PassNumber</MudTableSortLabel></MudTh>
                                <MudTh><MudTableSortLabel SortBy="new Func<GcTariffModel, object>(x=> x.BillNumber)">BillNumber</MudTableSortLabel></MudTh>
                                <MudTh><MudTableSortLabel SortBy="new Func<GcTariffModel, object>(x=> x.ConsigneeName)">ConsigneeName</MudTableSortLabel></MudTh>
                                <MudTh><MudTableSortLabel SortBy="new Func<GcTariffModel, object>(x=> x.BillQuantity)">BillQuantity</MudTableSortLabel></MudTh>
                                <MudTh><MudTableSortLabel SortBy="new Func<GcTariffModel, object>(x=> x.Amount)">Freight</MudTableSortLabel></MudTh>
                                <MudTh><MudTableSortLabel SortBy="new Func<GcTariffModel, object>(x=> x.Deduction)">Deducted</MudTableSortLabel></MudTh>
                            </HeaderContent>
                            <RowTemplate Context="cntxt">
                                <MudTd DataLabel="BillDate">@cntxt.BillDate?.ToShortDateString()</MudTd>
                                <MudTd DataLabel="InvoiceDate">@cntxt.PassNumber</MudTd>
                                <MudTd DataLabel="BillNumber">@cntxt.BillNumber</MudTd>
                                <MudTd DataLabel="ConsigneeName">@cntxt.ConsigneeName</MudTd>
                                <MudTd DataLabel="BillQuantity">@cntxt.BillQuantity</MudTd>
                                <MudTd DataLabel="Amount">
                                    <MudTextField ReadOnly="@ReadOnly" InputMode="InputMode.numeric" Placeholder="Amount" Variant="Variant.Outlined" Margin="Margin.Dense" Value="@cntxt.Amount" ValueChanged="(newValue) => OnAmountChanged(cntxt, newValue)" T="decimal?"></MudTextField>
                                </MudTd>
                                <MudTd DataLabel="Deduction">
                                    <MudTextField ReadOnly="@ReadOnly" InputMode="InputMode.numeric" Placeholder="Deducted" Variant="Variant.Outlined" Margin="Margin.Dense" Value="@cntxt.Deduction" ValueChanged="(newValue) => OnDeductionChanged(cntxt, newValue)" T="decimal?"></MudTextField>
                                </MudTd>
                            </RowTemplate>
                        </MudTable>
                    </MudItem>
                    <MudItem xs="12" md="12">
                        <MudTextField ReadOnly="ReadOnly" @bind-Value="model.Narration" Lines="3" Label="Narration" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(()=> model.Narration)"></MudTextField>
                    </MudItem>
                </MudGrid>
            </EditForm>
        </MudPaper>
    </FormContent>
    <VerificationStatus>
        <AutherizationStatusComponent CreatedBy="@model.UserInfo" DocTypeID="@FreightBillingDocTypeID" DocDate="@DocDate" DocType="@DocType" DocNumber="@DocNumber" PageToRedirectLink="@PageToRedirectLink" DocumentID="model.DraftBillID" OnApprove="Approve" ApproveWithin></AutherizationStatusComponent>
    </VerificationStatus>
</DialogForm>

 @code {

    [Parameter]
    public ConsolidatedDraftBillModel model { get; set; }
    private DateRange dateRange;
    [Parameter]
    public bool ReadOnly { get; set; }
    [Parameter]
    public string PageToRedirectLink { get; set; }
    public string DocNumber { get; set; }
    public DateTime? DocDate { get; set; }
    public string DocType { get; set; }

    private int? BranchID = null;
    private string UserID = null;
    DialogForm dialogForm;

    public int FreightBillingDocTypeID = 2;
    private bool _busy;

    private GcTariffModel gctariffmodel = new GcTariffModel();
    private List<GcTariffModel> collection = new List<GcTariffModel>();

    public ConsolidateDraftBillDialog()
    {
    }

    public decimal? TotalAmount { get; set; }

    protected override void OnParametersSet()
    {
        if (model != null)
        {
            dateRange = new DateRange
                {
                    Start = model.DocFromDate,
                    End = model.DocToDate
                };
        }
    }

    private void OnAmountChanged(GcTariffModel models, decimal? newAmount)
    {
        models.Amount = newAmount;
        model.TotalAmount = collection.Sum(x => x.Amount) - (collection.Sum(y => y.Deduction) ?? 0);
    }

    private void OnDeductionChanged(GcTariffModel models, decimal? newAmount)
    {
        models.Deduction = newAmount;
        model.TotalAmount = collection.Sum(x => x.Amount) - (collection.Sum(y => y.Deduction) ?? 0);
    }

    protected override async Task OnInitializedAsync()
    {
        var authprov = await auth.GetAuthenticationStateAsync();
        var User = authprov.User;
        BranchID = int.Parse(User.Claims.First(x => x.Type == "BranchID").Value);
        UserID = User.Identity.Name;
        if (ReadOnly)
        {
            collection = Iservice.GetBilled(model.DraftBillID).ToList();
        }
        else
        {
            collection = model.BookedGCs.ToList();
        }
        DocNumber = model.DocumentNumber;
        DocDate = model.DocumentDate;
        DocType = model.NatureOfTransaction;
    }

    private async Task OnValidSubmit(EditContext context)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is being submitted!", Severity.Warning);
            return;
        }
        _busy = true;
        model.UserInfo.UserID = UserID;
        dialogForm.Close(model);

        await Task.Delay(200);
        _busy = false;
    }

    protected void Approve(DataApprovedStatus aprvd)
    {
        if (aprvd.IsApprove)
        {

        }
    }
}