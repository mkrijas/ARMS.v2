@page "/ConsolidatedBills"
@page "/ConsolidatedBills/{id:int}"
@using System.Threading;
@inject IFreightBillingService Iservice
@inject MudBlazor.ISnackbar snackbar
@inject AuthenticationStateProvider auth
@inject IRoleService<RoleModel> Irole
@attribute [Authorize]
@inject IDialogService DialogService
@inject SignalRService signalRService
@inject IPushNotificationService IpushNotificationService
@layout BillsLayout

@if (_isLoading)
{
    <div @key="@("loader")" style="display: flex; justify-content: center; align-items: center; min-height: 400px;">
        <LoaderComponent IsFullScreen="true" 
                        ShowLogo="false" 
                        Size="medium" 
                        LoadingText="Loading Consolidated Bills" 
                        SubText="Please wait..." />
    </div>
}
else
{
    <div @key="@("content")">
@if (_isLoading)
{
    <div @key="@("loader")" style="display: flex; justify-content: center; align-items: center; min-height: 400px;">
        <LoaderComponent IsFullScreen="true" 
                        ShowLogo="false" 
                        Size="medium" 
                        LoadingText="Aggregating Drafts" 
                        SubText="Consolidating logistics data..." />
    </div>
}
else
{
    <div class="fade-in">
        <div class="admin-header-tiered mb-6">
            <div class="d-flex align-center justify-space-between">
                <div>
                    <MudText Typo="Typo.h4" Class="admin-title">Consolidated Draft Billing</MudText>
                    <MudText Typo="Typo.body2" Class="admin-subtitle">Unified terminal for reviewing and verifying aggregated logistics drafts. Manage multi-consignee consolidations and prepare verified datasets for proforma invoice generation.</MudText>
                </div>
            </div>
        </div>

        <div class="admin-glass-card mb-6 pa-4">
            <div class="d-flex align-center gap-4 flex-wrap">
                <div style="flex-grow: 1; min-width: 300px;">
                    <MudTextField @bind-Value="searchConsolidatedBill" Placeholder="Search by draft number or client name..." Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" Variant="Variant.Outlined" Margin="Margin.Dense" Class="admin-input-group" Clearable="true" />
                </div>
                <div class="d-flex align-center gap-4">
                     <div class="admin-icon-square-vibrant small accent-indigo">
                        <MudIcon Icon="@Icons.Material.Filled.FilterList" Size="Size.Small" />
                    </div>
                    <span class="admin-section-label mb-0">Filtered Results: <span class="text-indigo fw-800">@collection.Count(search)</span></span>
                </div>
            </div>
        </div>

        <div class="admin-glass-card pa-0 overflow-hidden shadow-sm">
            <MudTable Items="@collection" Elevation="0" Class="modern-admin-table" Hover="true" T="ConsolidatedDraftBillModel" Filter="new Func<ConsolidatedDraftBillModel, bool>(search)">
                <HeaderContent>
                    <MudTh><MudTableSortLabel SortBy="new Func<ConsolidatedDraftBillModel, object>(x=> x.DocumentDate)"><span class="admin-header-text">DATE</span></MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<ConsolidatedDraftBillModel, object>(x=> x.DocumentNumber)"><span class="admin-header-text">DRAFT NUMBER</span></MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<ConsolidatedDraftBillModel, object>(x=> x.Party)"><span class="admin-header-text">PARTY / CLIENT</span></MudTableSortLabel></MudTh>
                    <MudTh Style="text-align: right;"><MudTableSortLabel SortBy="new Func<ConsolidatedDraftBillModel, object>(x=> x.TotalAmount)"><span class="admin-header-text">TOTAL VALUE</span></MudTableSortLabel></MudTh>
                    <MudTh Style="text-align: right;"><span class="admin-header-text">ACTIONS</span></MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Date"><span class="fw-700 admin-td-primary">@context.DocumentDate?.ToString("dd MMM yyyy")</span></MudTd>
                    <MudTd DataLabel="Draft">
                        <div class="d-flex align-center gap-2">
                             <span class="fw-700">@context.DocumentNumber</span>
                             @if (context.AuthLevelId == 100)
                             {
                                 <MudChip T="string" Color="Color.Error" Size="Size.Small" Variant="Variant.Text" Class="fw-900 tiny uppercase">REJECTED</MudChip>
                             }
                        </div>
                    </MudTd>
                    <MudTd DataLabel="Party">
                         <div class="d-flex align-center gap-2">
                             <div class="admin-icon-square-vibrant tiny accent-indigo">
                                <MudIcon Icon="@Icons.Material.Filled.Person" Size="Size.Small" />
                            </div>
                            <span class="fw-600">@context.Party.TradeName</span>
                        </div>
                    </MudTd>
                    <MudTd DataLabel="Amount" Style="text-align: right;">
                        <span class="fw-800 text-vibrant" style="font-size: 1.1rem;">@context.TotalAmount?.ToString("N2")</span>
                    </MudTd>
                    <MudTd DataLabel="Actions" Style="text-align: right;">
                        <div class="d-flex justify-end gap-1">
                                <MudTooltip Text="Inspect Aggregates">
                                    <MudIconButton OnClick="@(()=> OpenConsolidatedBill(context))" Color="Color.Info" Icon="@Icons.Material.Filled.Visibility" Size="Size.Small" Variant="Variant.Text" />
                                </MudTooltip>

                                <MudTooltip Text="Reverse Consolidation">
                                    <MudIconButton OnClick="@(()=> Reverse(context))" Color="Color.Error" Icon="@Icons.Material.Filled.SettingsBackupRestore" Size="Size.Small" Variant="Variant.Text" />
                                </MudTooltip>

                                @if (@context.AuthLevelId == 99)
                                {
                                    <MudTooltip Text="Generate Proforma Invoice">
                                        <MudButton OnClick="@(()=> CreateProformaInvoice(context))" Variant="Variant.Filled" Color="Color.Success" Size="Size.Small" Class="admin-register-btn ml-2" StartIcon="@Icons.Material.Filled.PostAdd">GENERATE PFI</MudButton>
                                    </MudTooltip>
                                }
                        </div>
                    </MudTd>
                </RowTemplate>
                <PagerContent>
                    <div class="pa-4">
                        <MudTablePager PageSizeOptions="new int[] { 10, 20, 50, 100 }" />
                    </div>
                </PagerContent>
            </MudTable>
        </div>
    </div>
}
</div>

}

@code {

    private bool _isLoading = true;
    private DateTime _loadStartTime;

    private ConsolidatedDraftBillModel model = new ConsolidatedDraftBillModel();
    private List<ConsolidatedDraftBillModel> collection = new List<ConsolidatedDraftBillModel>();
    private int? branchID = null;
    private string UserID = null;
    private string searchConsolidatedBill = "";

    [Parameter]
    public int? id { get; set; } = null;
    public bool HasPermissionFreightBillingServiceEditProformaInvoice { get; set; } = false;
    public bool HasPermissionFreightBillingServiceReverseConsolidatedDraftBill { get; set; } = false;
    public int FreightBillingDocTypeID = 2;

    DialogOptions maxWidth = new DialogOptions() { MaxWidth = MaxWidth.Large };


    #region SignaIR Notification

    private PushNotificationModel notificationMessage = new PushNotificationModel();
    #endregion

    // Method to open a consolidated bill for editing
    private async Task OpenConsolidatedBill(ConsolidatedDraftBillModel obj)
    {
        DialogParameters parms = new DialogParameters();
        parms.Add("model", obj.Clone());
        parms.Add("ReadOnly", true);
        var dialog = await DialogService.ShowAsync<ConsolidateDraftBillDialog>(obj.DraftBillID == null ? "ADD" : "EDIT", parms, maxWidth);
        var result = await dialog.Result;
        GetConsolidatedDraftBill();
    }

    // Lifecycle method called when the component is initialized
    protected override async Task OnInitializedAsync()
    {
        _loadStartTime = DateTime.Now;
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionFreightBillingServiceEditProformaInvoice = await Irole.HasClaim(FreightBillingDocTypeID.ToString(), "EditProformaInvoice", ctc.Token);
        HasPermissionFreightBillingServiceReverseConsolidatedDraftBill = await Irole.HasClaim(FreightBillingDocTypeID.ToString(), "ReverseConsolidatedDraftBill", ctc.Token);

        var authprov = await auth.GetAuthenticationStateAsync();
        branchID = int.Parse(authprov.User.Claims.First(x => x.Type == "BranchID").Value);
        var user = authprov.User;
        UserID = user.Identity.Name;
        GetConsolidatedDraftBill();

        await signalRService.StartAsync();
        if (id != null && collection != null && collection.Any(g => g.DraftBillID == id))
        {
            await CreateProformaInvoice(collection.FirstOrDefault(s => s.DraftBillID == id));
        }
        await EnsureMinimumLoadTime();
        _isLoading = false;
    }

    private async Task EnsureMinimumLoadTime()
    {
        var elapsed = (DateTime.Now - _loadStartTime).TotalMilliseconds;
        if (elapsed < 100)
        {
            await Task.Delay(100 - (int)elapsed);
        }
    }

    // Method to fetch consolidated draft bills
    public void GetConsolidatedDraftBill()
    {
        collection = Iservice.SelectPendingConsolidatedDraftBillList(0, branchID).ToList(); // Fetch data from the service
    }

    // Method to reverse a consolidated draft bill
    async Task Reverse(ConsolidatedDraftBillModel model)
    {
        if (HasPermissionFreightBillingServiceReverseConsolidatedDraftBill)
        {
            bool? result = await DialogService.ShowMessageBoxAsync(
                "Warning !",
                "Are you sure, you want to reverse document - " + model.DocumentNumber + " (" + model.DocumentDate + ") ?");
            if (result == true)
            {
                Iservice.ReverseConsolidatedDraftBill(model.DraftBillID, UserID); // Reverse the draft bill
                GetConsolidatedDraftBill();
            }
        }
        else
        {
            bool? result = await DialogService.ShowMessageBoxAsync(
                "Permission denied!",
                "You don't have any permission to ReverseConsolidatedDraftBill FreightBilling.");
        }
    }

    // Method to create a proforma invoice from a consolidated draft bill
    public async Task CreateProformaInvoice(ConsolidatedDraftBillModel cdm)
    {
        if (HasPermissionFreightBillingServiceEditProformaInvoice)
        {
            var gst = Iservice.GetGstRate(cdm.DraftBillID); // Get GST rate for the draft bill

            ProformaInvoiceModel pfm = new ProformaInvoiceModel()
                {
                    BranchID = branchID,
                    FreightAmount = cdm.TotalAmount,
                    DraftBillID = cdm.DraftBillID,
                    Party = new PartyModel()
                    {
                        PartyID = cdm.Party?.PartyID,
                        TradeName = cdm.Party?.TradeName
                    },
                    OrderID = cdm.Order?.OrderID,
                    TariffType = cdm.TariffType,
                    Gst = gst,
                    TotalAmount = cdm.TotalAmount + gst.TotalGst,
                    UserInfo = new() { UserID = UserID },
                };

            DialogParameters parms = new DialogParameters();
            parms.Add("model", pfm);
            parms.Add("PageToRedirectLink", "/ConsolidatedBills");
            parms.Add("ReadOnly", false);
            var dialog = await DialogService.ShowAsync<ProformaInvoiceDialog>("Proforma Invoice", parms, maxWidth);
            var result = await dialog.Result;
            if (!result.Canceled)
            {
                ProformaInvoiceModel UpatedModel = (ProformaInvoiceModel)result.Data;
                int? ReturnVal = Iservice.UpdateProformaInvoice(UpatedModel); // Update the proforma invoice
                if (ReturnVal != -1)
                {
                    var ReturnData = (ProformaInvoiceModel)result.Data;
                    notificationMessage.InitiateBranch = new BranchModel() { BranchID = ReturnData.BranchID };
                    notificationMessage.ReceivedBranch = new BranchModel() { BranchID = ReturnData.BranchID };
                    notificationMessage.MessageTitle = IpushNotificationService.GetMessageTitle(ReturnData.NatureOfTransaction, ReturnData.DocumentNumber, "Level 1 Verification");
                    notificationMessage.MessageBody = IpushNotificationService.GetMessageBody(ReturnData.NatureOfTransaction, ReturnData.DocumentNumber, "Level 1 Verification", ReturnData.DocumentDate);
                    notificationMessage.RedirectedTo = 0;
                    notificationMessage.ExpiredBy = 7;
                    notificationMessage.DocumentID = ReturnVal;
                    notificationMessage.MessageGroupID = "PendingVerification";
                    notificationMessage.PageToRedirectLink = "/ConsolidatedBills";
                    notificationMessage.ClaimValue = "Verify 1";
                    notificationMessage.DocumentTypeID = FreightBillingDocTypeID;
                    notificationMessage.MsgDate = DateTime.Now;
                    await signalRService.Send(notificationMessage);
                    snackbar.Add("Saved Successfully ", Severity.Success);//value = "visible";
                    GetConsolidatedDraftBill();

                }
                else
                {
                    snackbar.Add("Error occured while saving. ", Severity.Error);//value = "visible";
                }
            }
        }
        else
        {
            bool? result = await DialogService.ShowMessageBoxAsync(
                "Permission denied!",
                "You don't have any permission to EditProformaInvoice FreightBilling.");
        }
    }

    // Method to search for consolidated draft bills based on a search string
    private bool search(ConsolidatedDraftBillModel consolidatedDraft)
    {
        if ((consolidatedDraft.DocumentNumber != null && consolidatedDraft.DocumentNumber.Contains(searchConsolidatedBill, StringComparison.OrdinalIgnoreCase)) ||
        (consolidatedDraft.Party.TradeName != null && consolidatedDraft.Party.TradeName.Contains(searchConsolidatedBill, StringComparison.OrdinalIgnoreCase)))
        {

            return true;
        }
        return false;
    }
}
