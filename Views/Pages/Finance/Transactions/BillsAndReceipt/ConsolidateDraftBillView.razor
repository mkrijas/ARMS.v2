@page "/ConsolidatedBills"
@page "/ConsolidatedBills/{id:int}"
@using System.Threading;
@inject IFreightBillingService Iservice
@inject MudBlazor.ISnackbar snackbar
@inject AuthenticationStateProvider auth
@inject IRoleService<RoleModel> Irole
@attribute [Authorize]
@inject IDialogService DialogService
@inject SignalRService signalRService
@inject IPushNotificationService IpushNotificationService
@layout BillsLayout

<style>
    .selected {
        background-color: #1E88E5 !important;
    }

        .selected > td {
            color: white !important;
        }

            .selected > td .mud-input {
                color: white !important;
            }
</style>

<MudGrid Spacing="4">
    <MudItem xs="12">
        <MudTable Items="@collection" Dense="true" Hover="true" Striped="true" Elevation="10" @bind-place="model" T="ConsolidatedDraftBillModel">
            <ToolBarContent>
                <MudText Typo="Typo.h6">Consolidated Bills</MudText>
                <MudSpacer></MudSpacer>
            </ToolBarContent>
            <HeaderContent>
                <MudTh><MudTableSortLabel SortBy="new Func<ConsolidatedDraftBillModel, object>(x=> x.DocumentDate)" InitialDirection="SortDirection.Ascending">Document Date</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<ConsolidatedDraftBillModel, object>(x=> x.DocumentNumber)" InitialDirection="SortDirection.Ascending">Document Number</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<ConsolidatedDraftBillModel, object>(x=> x.TotalAmount)" InitialDirection="SortDirection.Ascending">Total Amount</MudTableSortLabel></MudTh>
                <MudTh>Actions</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="DocumentDate">@context.DocumentDate?.ToShortDateString()</MudTd>
                <MudTd DataLabel="DocumentNumber">@context.DocumentNumber</MudTd>
                <MudTd DataLabel="TotalAmount">@context.TotalAmount</MudTd>
                <MudTd DataLabel="">
                    ReverseConsolidatedDraftBill
                    <MudFab @onclick="@(()=> Reverse(context))" Color="Color.Error" title="Reverse" Icon="@Icons.Material.Filled.ArrowBack" Size="Size.Small" IconSize="Size.Small" />
                    <MudFab @onclick="@(()=> OpenConsolidatedBill(context))" Color="Color.Info" Icon="@Icons.Material.Filled.GridView" title="View" Size="Size.Small" IconSize="Size.Small" />
                    @if (context.AuthLevelId == 99)
                    {
                        <MudTooltip Text="Create Proforma Invoice">
                            <MudFab @onclick="@(()=> CreateProformaInvoice(context))" Color="Color.Success" Icon="@Icons.Material.Filled.CreditCard" Size="Size.Small" IconSize="Size.Small" />
                        </MudTooltip>
                    }
                </MudTd>
            </RowTemplate>
            <PagerContent>
                <MudTablePager PageSizeOptions="new int[] { 5, 10, 20, 50, 100 }" />
            </PagerContent>
        </MudTable>
    </MudItem>
</MudGrid>

@code {

    private ConsolidatedDraftBillModel model = new ConsolidatedDraftBillModel();
    private List<ConsolidatedDraftBillModel> collection = new List<ConsolidatedDraftBillModel>();
    private int? branchID = null;
    private string UserID = null;
    [Parameter]
    public int? id { get; set; } = null;

    int DocTypeID = 1;

    public bool ConsolidatedBillsHasAuthoriseEdit { get; set; } = false;
    public bool ConsolidatedBillsHasAuthoriseDelete { get; set; } = false;
    public bool ConsolidatedBillsHasAuthoriseView { get; set; } = false;
    public bool ProformaInvoiceHasAuthoriseEdit { get; set; } = false;

    public int ConsolidatedBillsDocTypeID { get; set; } = 1;
    public int ProformaInvoiceHasDocTypeID { get; set; } = 2;

    DialogOptions maxWidth = new DialogOptions() { MaxWidth = MaxWidth.Medium, FullWidth = true };


    #region SignaIR Notification

    private PushNotificationModel notificationMessage = new PushNotificationModel();
    #endregion


    private async Task OpenConsolidatedBill(ConsolidatedDraftBillModel obj)
    {
        DialogParameters parms = new DialogParameters();
        parms.Add("model", obj.Clone());
        parms.Add("ReadOnly", true);
        var dialog = DialogService.Show<ConsolidateDraftBillDialog>(obj.DraftBillID == null ? "ADD" : "EDIT", parms, maxWidth);
        var result = await dialog.Result;
        GetConsolidatedDraftBill();
    }

    protected override async Task OnInitializedAsync()
    {
        CancellationTokenSource ctc = new CancellationTokenSource();
        ConsolidatedBillsHasAuthoriseEdit = await Irole.HasClaim(ConsolidatedBillsDocTypeID.ToString(), "Edit", ctc.Token);
        ConsolidatedBillsHasAuthoriseDelete = await Irole.HasClaim(ConsolidatedBillsDocTypeID.ToString(), "Delete", ctc.Token);
        ConsolidatedBillsHasAuthoriseView = await Irole.HasClaim(ConsolidatedBillsDocTypeID.ToString(), "View", ctc.Token);
        ProformaInvoiceHasAuthoriseEdit = await Irole.HasClaim(ProformaInvoiceHasDocTypeID.ToString(), "Edit", ctc.Token);

        var authprov = await auth.GetAuthenticationStateAsync();
        branchID = int.Parse(authprov.User.Claims.First(x => x.Type == "BranchID").Value);
        var user = authprov.User;
        UserID = user.Identity.Name;
        GetConsolidatedDraftBill();

        await signalRService.StartAsync();
        if (id != null && collection != null && collection.Any(g => g.DraftBillID == id))
        {
            await CreateProformaInvoice(collection.FirstOrDefault(s => s.DraftBillID == id));
        }
    }

    public void GetConsolidatedDraftBill()
    {
        collection = Iservice.SelectPendingConsolidatedDraftBillList(0, branchID).ToList();
    }

    async Task Reverse(ConsolidatedDraftBillModel model)
    {
        if (ConsolidatedBillsHasAuthoriseDelete)
        {
            bool? result = await DialogService.ShowMessageBox(
                "Warning !",
                "Are you sure, you want to reverse document - " + model.DocumentNumber + " (" + model.DocumentDate + ") ?");
            if (result == true)
            {
                Iservice.ReverseConsolidatedDraftBill(model.DraftBillID, UserID);
                GetConsolidatedDraftBill();
            }
        }
        else
        {
            bool? result = await DialogService.ShowMessageBox(
                "Permission denied!",
                "You dont have any permission to reverse.");
        }
    }

    public async Task CreateProformaInvoice(ConsolidatedDraftBillModel cdm)
    {
        var gst = Iservice.GetGstRate(cdm.DraftBillID);

        ProformaInvoiceModel pfm = new ProformaInvoiceModel()
            {
                BranchID = branchID,
                FreightAmount = cdm.TotalAmount,
                DraftBillID = cdm.DraftBillID,
                OrderID = cdm.Order.OrderID,
                TariffType = cdm.TariffType,
                Gst = gst,
                TotalAmount = cdm.TotalAmount + gst.TotalGst,
                UserInfo = new() { UserID = UserID },
            };

        DialogParameters parms = new DialogParameters();
        parms.Add("model", pfm);
        parms.Add("PageToRedirectLink", "/ConsolidatedBills");
        parms.Add("ReadOnly", false);
        var dialog = DialogService.Show<ProformaInvoceDialog>("Proforma Invoce", parms, maxWidth);
        var result = await dialog.Result;
        if (!result.Canceled)
        {
            ProformaInvoiceModel UpatedModel = (ProformaInvoiceModel)result.Data;
            int? ReturnVal = Iservice.UpdateProformaInvoice(UpatedModel);
            if(ReturnVal != -1)
            {
                var ReturnData = (ProformaInvoiceModel)result.Data;
                notificationMessage.InitiateBranch = new BranchModel() { BranchID = ReturnData.BranchID };
                notificationMessage.ReceivedBranch = new BranchModel() { BranchID = ReturnData.BranchID };
                notificationMessage.MessageTitle = IpushNotificationService.GetMessageTitle(ReturnData.NatureOfTransaction, ReturnData.DocumentNumber, "Level 1 Verification");
                notificationMessage.MessageBody = IpushNotificationService.GetMessageBody(ReturnData.NatureOfTransaction, ReturnData.DocumentNumber, "Level 1 Verification", ReturnData.DocumentDate);
                notificationMessage.RedirectedTo = 0;
                notificationMessage.ExpiredBy = 7;
                notificationMessage.DocumentID = ReturnData.ProformaInvoiceID;
                notificationMessage.MessageGroupID = "PendingVerification";
                notificationMessage.PageToRedirectLink = "/ConsolidatedBills";
                notificationMessage.ClaimValue = "Verify 1";
                notificationMessage.DocumentTypeID = DocTypeID;
                notificationMessage.MsgDate = DateTime.Now;
                await signalRService.Send(notificationMessage);
                snackbar.Add("Saved Successfully ", Severity.Success);//value = "visible";
                GetConsolidatedDraftBill();

            }
            else
            {
                snackbar.Add("Error occured while saving. ", Severity.Error);//value = "visible";
            }
        }
    }
}