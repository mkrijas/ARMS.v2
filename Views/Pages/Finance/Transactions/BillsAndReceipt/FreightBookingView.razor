@page "/FreightBooking"
@using System.Threading;
@inject IFreightBillingService Iservice
@inject IOrderService orderIservice
@inject ITariffService tariffIservice
@inject NavigationManager uriHelper;
@inject MudBlazor.ISnackbar snackbar
@inject AuthenticationStateProvider auth
@attribute [Authorize]
@inject IDialogService DialogService
@inject IRoleService<RoleModel> Irole
@layout BillsLayout
@inject IGcService IGcService
@using OfficeOpenXml;
@using System.IO;
@using System.Collections.Generic;
@using OfficeOpenXml.Style;
@inject IJSRuntime JSRuntime

<MudPaper Class="p-4">
    <MudGrid>
        <MudItem xs="12" md="4">
            <PartySelector BranchID="@BranchID" NatureOfBusiness="Customer"  @bind-Value="@SelectedClient" IncludeSisterConcern></PartySelector>
        </MudItem>
        <MudItem xs="12" md="4">
            <MudAutocomplete Label="Select Contract" @bind-Value="@SelectedOrder" T="OrderModel" SearchFunc="SearchOrders" ToStringFunc="@((p) => p?.OrderName)" Variant="Variant.Outlined" AnchorOrigin="Origin.BottomCenter" Margin="Margin.Dense" AdornmentColor="Color.Secondary">
            </MudAutocomplete>
        </MudItem>
        <MudItem xs="12" md="4">
            <MudSelect Label="Select Tariff" @bind-Value="SelectedTariffType" T="TariffTypeModel" ToStringFunc="@((p) => p?.TariffTypeName)" Variant="Variant.Outlined" AnchorOrigin="Origin.BottomCenter" Margin="Margin.Dense" AdornmentColor="Color.Secondary">
                @foreach (var item in TariffTypes)
                {
                    <MudSelectItem Value="@item">@item.TariffTypeName</MudSelectItem>
                }
            </MudSelect>
        </MudItem>
        <MudItem xs="12" md="4">
            <MudSelect Label="Select GC Type" @bind-Value="GcType" T="GcTypeModel" ToStringFunc="@((p) => p?.GcTypeName)" Variant="Variant.Outlined" AnchorOrigin="Origin.BottomCenter" Margin="Margin.Dense" AdornmentColor="Color.Secondary">
                @foreach (var item in GcTypes)
                {
                    <MudSelectItem Value="@item">@item.GcTypeName</MudSelectItem>
                }
    
            </MudSelect>
        </MudItem>
        <MudItem xs="12" md="4">
            <MudDateRangePicker Label="Select Period" @bind-DateRange="@dateRange" Variant="Variant.Outlined" Margin="Margin.Dense" DisableToolbar="true" Editable="true" DateFormat="dd/MM/yyyy" Required></MudDateRangePicker>
        </MudItem>
        <MudItem xs="12" md="4" Class="d-flex align-left">
            <MudButton OnClick="fetch" Variant="Variant.Filled" Color="Color.Primary" ButtonType="ButtonType.Submit">Fetch</MudButton>
            <MudButton OnClick="Generate" Style="margin-left: 20px;" Variant="Variant.Filled" Color="Color.Secondary" ButtonType="ButtonType.Button">Generate</MudButton>
        </MudItem>
        @if (collection.Any())
        {
            <MudSpacer></MudSpacer>
            <MudItem Class="">
                <MudButton OnClick="ExcelDownload" StartIcon="@Icons.Material.Outlined.Article" Variant="Variant.Filled" Color="Color.Primary" ButtonType="ButtonType.Button">Export to Excel</MudButton>
                <MudButton Style="margin-left: 14px;" OnClick="Create" Variant="Variant.Filled" Color="Color.Primary" ButtonType="ButtonType.Button">Create Consolidate Draft Bill</MudButton>
            </MudItem>
        }
    </MudGrid>
</MudPaper>
<br />
<MudGrid Spacing="4">
    <MudItem xs="12">
        <MudTable Items="@collection" Dense="true" Hover="true" Striped="true" Elevation="1" Filter="new Func<GcTariffModel, bool>(search)">
            <ToolBarContent>
                <MudSpacer></MudSpacer>
                <MudTextField @bind-Value="searchBookFreight" Placeholder="Search" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0"></MudTextField>
            </ToolBarContent>
            <HeaderContent>
                <MudTh><MudCheckBox ValueChanged="(bool isChecked) => SelectAll(isChecked)"></MudCheckBox></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<GcTariffModel, object>(x=> x.BillNumber)" InitialDirection="SortDirection.Ascending">Bill Number</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<GcTariffModel, object>(x=> x.BillDate)" InitialDirection="SortDirection.Ascending">Bill Date</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<GcTariffModel, object>(x=> x.PassNumber)" InitialDirection="SortDirection.Ascending">Pass Number</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<GcTariffModel, object>(x=> x.ConsigneeName)" InitialDirection="SortDirection.Ascending">Consignee Name</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<GcTariffModel, object>(x=> x.BillQuantity)" InitialDirection="SortDirection.Ascending">Bill Quantity</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<GcTariffModel, object>(x=> x.Amount)" InitialDirection="SortDirection.Ascending">Freight</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<GcTariffModel, object>(x=> x.PaymentMode)" InitialDirection="SortDirection.Ascending">Payment Mode</MudTableSortLabel></MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd><MudCheckBox @bind-Value="@context.IsChecked"></MudCheckBox></MudTd>
                <MudTd DataLabel="BillNumber">@context.BillNumber</MudTd>
                <MudTd DataLabel="BillDate">@context.BillDate?.ToShortDateString()</MudTd>
                <MudTd DataLabel="PassNumber">@context.PassNumber</MudTd>
                <MudTd DataLabel="ConsigneeName">@context.ConsigneeName</MudTd>
                <MudTd DataLabel="BillQuantity">@context.BillQuantity</MudTd>
                <MudTd DataLabel="Amount">@context.Amount</MudTd>
                <MudTd DataLabel="PaymentMode">@context.PaymentMode</MudTd>
            </RowTemplate>
            <PagerContent>
                <MudTablePager PageSizeOptions="new int[] { 5, 10, 20, 50, 100 }" />
            </PagerContent>
        </MudTable>
    </MudItem>
</MudGrid>
<br />

@code {

    private List<GcTariffModel> collection = new List<GcTariffModel>();
    private List<OrderModel> Orders = new();
    private OrderModel SelectedOrder = new();
    private List<GcTypeModel> GcTypes = new();
    private GcTypeModel GcType = new();
    private List<TariffTypeModel> TariffTypes = new();
    private TariffTypeModel SelectedTariffType = new();
    private HashSet<GcTariffModel> selectedItems1 = new HashSet<GcTariffModel>();
    DateRange dateRange;
    private string searchBookFreight = "";

    private PartyModel SelectedClient;

    public bool HasPermissionFreightBillingServiceEditConsolidatedDraftBill { get; set; } = false;
    public int FreightBillingDocTypeID = 2;
    int? BranchID;
    string UserID;


    IEnumerable<GcTariffModel> FilteredCollection { get; set; }

    void UpdateFilteredCollection(string searchString)
    {
        // Apply your filter to the collection
        FilteredCollection = collection.Where(item => item.ConsigneeName.Contains(searchString, StringComparison.InvariantCultureIgnoreCase));
    }

    void SelectAll(bool isChecked)
    {
        FilteredCollection = collection.Where(item => search(item));
        foreach (var item in FilteredCollection)
        {
            item.IsChecked = isChecked;
        }
    }

    protected override async Task OnInitializedAsync()
    {
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionFreightBillingServiceEditConsolidatedDraftBill = await Irole.HasClaim(FreightBillingDocTypeID.ToString(), "EditConsolidatedDraftBill", ctc.Token);
        var authprov = await auth.GetAuthenticationStateAsync();
        var brancIDString = authprov.User.Claims.First(x => x.Type == "BranchID").Value;
        BranchID = int.Parse(brancIDString);
        string UserID = authprov.User.Identity.Name;
        Orders = await orderIservice.SelectByBranch(BranchID).ToListAsync();
        TariffTypes = tariffIservice.SelectTariffTypes("All").ToList();
        GcTypes = IGcService.SelectGcTypes().ToList();
        GcTypeModel GcTypeAll = new GcTypeModel
            {
                GcTypeID = -1,
                GcTypeName = "All"
            };
        GcTypes.Add(GcTypeAll);
    }

    public async Task fetch()
    {
        await  LoadData("Fetch");
    }

    async Task Generate()
    {
        await  LoadData("Generate");
    }

    private async Task<IEnumerable<OrderModel>> SearchOrders(string searchString)
    {
        if (string.IsNullOrEmpty(searchString))
            return Orders.Where(x => x.ClientID == SelectedClient?.PartyID);

        UpdateFilteredCollection(searchString);
        return await Task.FromResult(Orders.Where(x => x.ClientID == SelectedClient?.PartyID && x.OrderName.Contains(searchString, StringComparison.InvariantCultureIgnoreCase)));
    }

    public async Task LoadData(string a)
    {
        if (SelectedOrder?.OrderID is null  && SelectedClient?.PartyID is null )
        {
            snackbar.Add("Party/Contract not selected ! ", Severity.Error);
            return;
        }
        if (SelectedTariffType.TariffTypeID == null)
        {
            snackbar.Add("TafiffType not selected ! ", Severity.Error);
            return;
        }
        if (GcType.GcTypeID == null)
        {
            snackbar.Add("GcType not selected ! ", Severity.Error);
            return;
        }
        if (dateRange?.Start == null || dateRange?.End == null)
        {
            snackbar.Add("Period Date not selected ! ", Severity.Error);
            return;
        }
        if (a == "Fetch")
        {
            collection = Iservice.GetPending(SelectedClient?.PartyID,SelectedOrder?.OrderID, SelectedTariffType.TariffTypeID, GcType.GcTypeID, dateRange?.Start, dateRange?.End).ToList();
        }
        if (a == "Generate")
        {
            if (SelectedOrder?.OrderID is null)
            {
                snackbar.Add("Contract not selected ! ", Severity.Error);
                return;
            }
            collection = Iservice.GenerateTariffs(SelectedOrder.OrderID, SelectedTariffType.TariffTypeID, GcType.GcTypeID, dateRange?.Start, dateRange?.End ).ToList();
        }
        if (collection.Count == 0)
        {
            bool? result = await DialogService.ShowMessageBox(
                "Oops !",
                "No collection found!!");            
        }
    }

    private async Task ExcelDownload()
    {
        var fileName = "Pending Consignments.xlsx";
        var sheetName = "Sheet1"; // Change the sheet name as needed
        var fileBytes = GenerateExcelBytes(sheetName);

        await JSRuntime.InvokeVoidAsync("triggerFileDownload", fileName, Convert.ToBase64String(fileBytes));
    }

    private byte[] GenerateExcelBytes(string sheetName)
    {
        // Generate your Excel data and file here, specifying the sheet name
        // You can use libraries like EPPlus or ClosedXML to generate Excel files
        // Below is just a placeholder method, implement according to your requirements

        using (var package = new ExcelPackage())
        {
            var worksheet = package.Workbook.Worksheets.Add(sheetName);

            // Add column headers
            worksheet.Cells[1, 1].Value = "BillNumber";
            worksheet.Cells[1, 2].Value = "BillDate";
            worksheet.Cells[1, 3].Value = "PassNumber";
            worksheet.Cells[1, 4].Value = "ConsigneeName";
            worksheet.Cells[1, 5].Value = "BillQuantity";
            worksheet.Cells[1, 6].Value = "Amount";
            for (int i = 1; i <= 6; i++)
            {
                worksheet.Cells[1, i].Style.Font.Bold = true;
            }

            worksheet.Column(2).Style.Numberformat.Format = "dd-MM-yyyy"; // Date format
            worksheet.Column(5).Style.Numberformat.Format = "0.00"; // Integer format
            worksheet.Column(6).Style.Numberformat.Format = "0.00";

            // Add data rows
            int row = 2;
            foreach (var item in collection)
            {
                worksheet.Cells[row, 1].Value = item.BillNumber;
                worksheet.Cells[row, 2].Value = item.BillDate;
                worksheet.Cells[row, 3].Value = item.PassNumber;
                worksheet.Cells[row, 4].Value = item.ConsigneeName;
                worksheet.Cells[row, 5].Value = item.BillQuantity;
                worksheet.Cells[row, 6].Value = item.Amount;

                row++;
            }

            worksheet.Cells[worksheet.Dimension.Address].Style.Border.Top.Style = ExcelBorderStyle.Thin;
            worksheet.Cells[worksheet.Dimension.Address].Style.Border.Left.Style = ExcelBorderStyle.Thin;
            worksheet.Cells[worksheet.Dimension.Address].Style.Border.Right.Style = ExcelBorderStyle.Thin;
            worksheet.Cells[worksheet.Dimension.Address].Style.Border.Bottom.Style = ExcelBorderStyle.Thin;

            // Save the Excel package to a memory stream
            using (var stream = new MemoryStream())
            {
                package.SaveAs(stream);
                return stream.ToArray();
            }
        }
    }

    private async Task Create()
    {
        if (HasPermissionFreightBillingServiceEditConsolidatedDraftBill)
        {
            DialogOptions maxWidth = new DialogOptions() { MaxWidth = MaxWidth.Large, FullWidth = true };
            if (collection.Where(x => x.IsChecked).ToList().Count > 0)
            {
                ConsolidatedDraftBillModel cdm = new()
                    {
                        UserInfo = new() { UserID = UserID },
                        BranchID = BranchID,
                        NatureOfTransaction = "Billing",
                        BookedGCs = collection.Where(x => x.IsChecked).ToList(),//selectedItems1.ToList(),
                        Order = SelectedOrder,
                        Party = new PartyModel(){
                         PartyID =   SelectedClient.PartyID,
                            TradeName = SelectedClient.TradeName,
                        },
                        TariffType = SelectedTariffType,
                        DocumentDate = System.DateTime.Now,
                        DocFromDate = dateRange?.Start ?? null,
                        DocToDate = dateRange?.End ?? null,
                        TotalAmount = collection.Where(x => x.IsChecked).Sum(x => x.Amount)
                    };
                DialogParameters parms = new DialogParameters();
                parms.Add("model", cdm);
                parms.Add("ReadOnly", false);
                var dialog = DialogService.Show<ConsolidateDraftBillDialog>("ConsolidateDraftBill", parms, maxWidth);
                var result = await dialog.Result;

                if (!result.Canceled)
                {
                    ConsolidatedDraftBillModel UpatedModel = (ConsolidatedDraftBillModel)result.Data;
                    Iservice.UpdateConsolidatedDraftBill(UpatedModel);
                    snackbar.Add("Created Successfully ", Severity.Success);//value = "visible";
                    await LoadData("Fetch");
                }                
            }
            else
            {
                snackbar.Add("Please select consignments to bill!", Severity.Error);
            }
        }
        else
        {
            bool? result = await DialogService.ShowMessageBox(
                "Permission denied!",
                "You dont have any permission to EditConsolidatedDraftBill FreightBilling.");
        }
    }
    private bool search(GcTariffModel gcTariff)
    {
        if ((gcTariff.BillNumber != null && gcTariff.BillNumber.Contains(searchBookFreight, StringComparison.OrdinalIgnoreCase)) ||
        (gcTariff.PassNumber != null && gcTariff.PassNumber.Contains(searchBookFreight, StringComparison.OrdinalIgnoreCase)))
        {
            
            return true;
        }
        return false;
    }
}