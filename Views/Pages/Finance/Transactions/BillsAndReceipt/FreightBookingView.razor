@page "/FreightBooking"
@using System.Threading;
@inject IFreightBillingService Iservice
@inject IOrderService orderIservice
@inject ITariffService tariffIservice
@inject NavigationManager uriHelper;
@inject MudBlazor.ISnackbar snackbar
@inject AuthenticationStateProvider auth
@attribute [Authorize]
@inject IDialogService DialogService
@inject IRoleService<RoleModel> Irole
@layout BillsLayout
@inject IGcService IGcService
@using OfficeOpenXml;
@using System.IO;
@using System.Collections.Generic;
@using OfficeOpenXml.Style;
@inject IJSRuntime JSRuntime

@if (_isLoading)
{
    <div @key="@("loader")" style="display: flex; justify-content: center; align-items: center; min-height: 400px;">
        <LoaderComponent IsFullScreen="true" 
                        ShowLogo="false" 
                        Size="medium" 
                        LoadingText="Syncing Freight Logistics" 
                        SubText="Optimizing haulage routes..." />
    </div>
}
else
{
    <div class="fade-in">
        <div class="admin-header-tiered mb-6">
            <div class="d-flex align-center justify-space-between">
                <div>
                    <MudText Typo="Typo.h4" Class="admin-title">Freight Booking & Allocation</MudText>
                    <MudText Typo="Typo.body2" Class="admin-subtitle">Strategize haulage operations and orchestrate client consignments. define contracts, allocate resources, and consolidate pending logistics into systematic draft billing protocols.</MudText>
                </div>
            </div>
        </div>

        <div class="admin-glass-card pa-6 mb-6">
            <MudGrid Spacing="3">
                <MudItem xs="12" md="4">
                    <PartySelector BranchID="@BranchID" NatureOfBusiness="Customer" @bind-Value="@SelectedClient" IncludeSisterConcern Label="Client Entity"></PartySelector>
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudAutocomplete Label="Service Contract" @bind-Value="@SelectedOrder" T="OrderModel" SearchFunc="@(async (string s, CancellationToken t) => await SearchOrders(s, t))" ToStringFunc="@((p) => p?.OrderName)" Variant="Variant.Outlined" AnchorOrigin="Origin.BottomCenter" Margin="Margin.Dense" AdornmentColor="Color.Secondary" Class="admin-input-group" />
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudSelect For="@(() => SelectedTariffType)" Label="Logistics Tariff" @bind-Value="SelectedTariffType" T="TariffTypeModel" ToStringFunc="@((p) => p?.TariffTypeName)" Variant="Variant.Outlined" AnchorOrigin="Origin.BottomCenter" Margin="Margin.Dense" AdornmentColor="Color.Secondary" Class="admin-input-group">
                        @foreach (var item in TariffTypes)
                        {
                            <MudSelectItem Value="@item">@item.TariffTypeName</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" md="3">
                    <MudSelect For="@(() => GcType)" Label="Consignment Type" @bind-Value="GcType" T="GcTypeModel" ToStringFunc="@((p) => p?.GcTypeName)" Variant="Variant.Outlined" AnchorOrigin="Origin.BottomCenter" Margin="Margin.Dense" AdornmentColor="Color.Secondary" Class="admin-input-group">
                        @foreach (var item in GcTypes)
                        {
                            <MudSelectItem Value="@item">@item.GcTypeName</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" md="3">
                    <TruckSelector Class="bg-white admin-input-group" Value="SelectedTruck" ValueChanged="OnTruckSelected" Filter="AvailableForBranch" HomeOrOperation="Operation" Label="Assigned Asset" />
                </MudItem>
                <MudItem xs="12" md="3">
                    <MudDateRangePicker Label="Operational Window" @bind-DateRange="@dateRange" Variant="Variant.Outlined" Margin="Margin.Dense" DisableToolbar="true" Editable="true" DateFormat="dd/MM/yyyy" Required Class="admin-input-group" />
                </MudItem>
                <MudItem xs="12" md="3" Class="d-flex align-center gap-2" Style="align-self: flex-end;">
                    <MudButton OnClick="fetch" Variant="Variant.Filled" Color="Color.Primary" Class="admin-register-btn flex-grow-1" StartIcon="@Icons.Material.Filled.Refresh">FETCH</MudButton>
                    <MudButton OnClick="Generate" Variant="Variant.Outlined" Color="Color.Secondary" Class="admin-register-btn flex-grow-1" StartIcon="@Icons.Material.Filled.Autorenew">PROCESS</MudButton>
                </MudItem>
            </MudGrid>
        </div>

        @if (collection?.Any() == true)
        {
            <div class="d-flex align-center justify-space-between mb-4">
                <div class="d-flex align-center gap-3">
                    <div class="admin-icon-square-vibrant small accent-indigo">
                        <MudIcon Icon="@Icons.Material.Filled.FormatListBulleted" Size="Size.Small" />
                    </div>
                    <span class="admin-section-label mb-0">Analyzed Consignments</span>
                </div>
                <div class="d-flex gap-2">
                    <MudButton OnClick="ExcelDownload" StartIcon="@Icons.Material.Filled.FileDownload" Variant="Variant.Outlined" Color="Color.Info" Class="admin-register-btn">EXPORT EXCEL</MudButton>
                    <MudButton OnClick="Create" Variant="Variant.Filled" Color="Color.Success" Class="admin-register-btn" StartIcon="@Icons.Material.Filled.FactCheck">GENERATE DRAFT BILL</MudButton>
                </div>
            </div>
        }

        <div class="admin-glass-card pa-0 overflow-hidden shadow-sm">
            <MudTable Items="@collection" Elevation="0" Class="modern-admin-table" Hover="true" Filter="new Func<GcTariffModel, bool>(search)">
                <ToolBarContent>
                    <div class="d-flex align-center gap-4 w-100 px-4 py-2">
                        <MudTextField @bind-Value="searchBookFreight" Placeholder="Search by Bill No, Pass No, Entity, Location..." Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Variant="Variant.Outlined" Margin="Margin.Dense" Class="admin-input-group flex-grow-1" Clearable="true" />
                    </div>
                </ToolBarContent>
                <HeaderContent>
                    <MudTh Style="width: 50px;"><MudCheckBox T="bool" ValueChanged="(bool isChecked) => SelectAll(isChecked)" Color="Color.Primary"></MudCheckBox></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<GcTariffModel, object>(x=> x.BillDate)"><span class="admin-header-text">DATE</span></MudTableSortLabel></MudTh>
                    <MudTh><span class="admin-header-text">LOGISTICS INFO</span></MudTh>
                    <MudTh><span class="admin-header-text">DESTINATION & ENTITY</span></MudTh>
                    <MudTh Style="text-align: right;"><MudTableSortLabel SortBy="new Func<GcTariffModel, object>(x=> x.Amount)"><span class="admin-header-text">FREIGHT</span></MudTableSortLabel></MudTh>
                    <MudTh Style="text-align: right;"><span class="admin-header-text">STATUS</span></MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd><MudCheckBox T="bool" @bind-Value="@context.IsChecked" Color="Color.Primary"></MudCheckBox></MudTd>
                    <MudTd DataLabel="Date">
                        <div class="d-flex flex-column">
                            <span class="fw-700 admin-td-primary">@context.BillDate?.ToString("dd MMM yyyy")</span>
                            <span class="tiny opa-50">@context.PaymentMode</span>
                        </div>
                    </MudTd>
                    <MudTd DataLabel="Logistics">
                        <div class="d-flex flex-column">
                            <span class="fw-700">Bill: @context.BillNumber</span>
                            <div class="d-flex align-center gap-2">
                                <span class="tiny fw-800 text-indigo uppercase">Pass: @context.PassNumber</span>
                                <span class="tiny fw-700 text-vibrant">Truck: @context.TruckRegNo</span>
                            </div>
                        </div>
                    </MudTd>
                    <MudTd DataLabel="Entity">
                        <div class="d-flex flex-column">
                            <span class="small fw-700">@context.ConsigneeName</span>
                            <span class="tiny opa-50 uppercase">@context.Destination, @context.DistrictName, @context.StateName</span>
                        </div>
                    </MudTd>
                    <MudTd DataLabel="Freight" Style="text-align: right;">
                        <div class="d-flex flex-column align-end">
                            <span class="fw-800 text-vibrant" style="font-size: 1rem;">@context.Amount?.ToString("N2")</span>
                            <span class="tiny opa-40 fw-700">QTY: @context.BillQuantity?.ToString("N2")</span>
                        </div>
                    </MudTd>
                    <MudTd DataLabel="Actions" Style="text-align: right;">
                         <MudChip T="string" Size="Size.Small" Color="Color.Default" Variant="Variant.Text" Class="fw-700 px-3 border-solid border-1">PENDING</MudChip>
                    </MudTd>
                </RowTemplate>
                <PagerContent>
                    <div class="pa-4">
                        <MudTablePager PageSizeOptions="new int[] { 10, 20, 50, 100 }" />
                    </div>
                </PagerContent>
            </MudTable>
        </div>
    </div>
}

@code {

    private bool _isLoading = true;
    private DateTime _loadStartTime;

    private List<GcTariffModel> collection = new List<GcTariffModel>();
    private List<OrderModel> Orders = new();
    private OrderModel SelectedOrder = new();
    private List<GcTypeModel> GcTypes = new();
    private GcTypeModel GcType = new();
    private List<TariffTypeModel> TariffTypes = new();
    private TariffTypeModel SelectedTariffType = new();
    private HashSet<GcTariffModel> selectedItems1 = new HashSet<GcTariffModel>();
    DateRange dateRange;
    private string searchBookFreight = "";

    private PartyModel SelectedClient;

    public bool HasPermissionFreightBillingServiceEditConsolidatedDraftBill { get; set; } = false;
    public int FreightBillingDocTypeID = 2;
    int? BranchID;
    string UserID;

    public TruckModel SelectedTruck { get; set; }

    IEnumerable<GcTariffModel> FilteredCollection { get; set; }

    // Method to handle truck selection
    private void OnTruckSelected(TruckModel model)
    {
        SelectedTruck = model;
    }

    // Method to update the filtered collection based on the search string
    void UpdateFilteredCollection(string searchString)
    {
        // Apply your filter to the collection
        FilteredCollection = collection.Where(item => item.ConsigneeName.Contains(searchString, StringComparison.InvariantCultureIgnoreCase));
    }

    // Method to select or deselect all items in the filtered collection
    void SelectAll(bool isChecked)
    {
        FilteredCollection = collection.Where(item => search(item));
        foreach (var item in FilteredCollection)
        {
            item.IsChecked = isChecked;
        }
    }

    // Lifecycle method called when the component is initialized
    protected override async Task OnInitializedAsync()
    {
        _loadStartTime = DateTime.Now;
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionFreightBillingServiceEditConsolidatedDraftBill = await Irole.HasClaim(FreightBillingDocTypeID.ToString(), "EditConsolidatedDraftBill", ctc.Token);
        var authprov = await auth.GetAuthenticationStateAsync();
        var brancIDString = authprov.User.Claims.First(x => x.Type == "BranchID").Value;
        BranchID = int.Parse(brancIDString);
        string UserID = authprov.User.Identity.Name;

        // Load orders, tariff types, and GC types
        Orders = await orderIservice.SelectByBranch(BranchID).ToListAsync();
        TariffTypes = tariffIservice.SelectTariffTypes("All").ToList();
        GcTypes = IGcService.SelectGcTypes().ToList();
        GcTypeModel GcTypeAll = new GcTypeModel
            {
                GcTypeID = -1,
                GcTypeName = "All"
            };
        GcTypes.Add(GcTypeAll);
        await EnsureMinimumLoadTime();
        _isLoading = false;
    }

    private async Task EnsureMinimumLoadTime()
    {
        var elapsed = (DateTime.Now - _loadStartTime).TotalMilliseconds;
        if (elapsed < 100)
        {
            await Task.Delay(100 - (int)elapsed);
        }
    }

    // Method to fetch data based on the action type
    public async Task fetch()
    {
        await LoadData("Fetch");
    }

    // Method to generate data based on the action type
    async Task Generate()
    {
        await LoadData("Generate");
    }

    // Method to search for orders based on a search string
    private async Task<IEnumerable<OrderModel>> SearchOrders(string searchString, CancellationToken token)
    {
        if (string.IsNullOrEmpty(searchString))
            return Orders.Where(x => x.ClientID == SelectedClient?.PartyID);

        UpdateFilteredCollection(searchString);
        return await Task.FromResult(Orders.Where(x => x.ClientID == SelectedClient?.PartyID && x.OrderName.Contains(searchString, StringComparison.InvariantCultureIgnoreCase)));
    }

    // Method to load data based on the action type
    public async Task LoadData(string a)
    {
        if (SelectedOrder?.OrderID is null && SelectedClient?.PartyID is null)
        {
            snackbar.Add("Party/Contract not selected ! ", Severity.Error);
            return;
        }
        if (SelectedTariffType.TariffTypeID == null)
        {
            snackbar.Add("TafiffType not selected ! ", Severity.Error);
            return;
        }
        if (GcType.GcTypeID == null)
        {
            snackbar.Add("GcType not selected ! ", Severity.Error);
            return;
        }
        if (dateRange?.Start == null || dateRange?.End == null)
        {
            snackbar.Add("Period Date not selected ! ", Severity.Error);
            return;
        }

        // Fetch or generate data based on the action type
        if (a == "Fetch")
        {
            collection = Iservice.GetPending(SelectedClient?.PartyID, SelectedOrder?.OrderID, SelectedTariffType.TariffTypeID, GcType.GcTypeID, SelectedTruck?.TruckID, dateRange?.Start, dateRange?.End).ToList();
        }
        if (a == "Generate")
        {
            if (SelectedOrder?.OrderID is null)
            {
                snackbar.Add("Contract not selected ! ", Severity.Error);
                return;
            }
            collection = Iservice.GenerateTariffs(SelectedOrder.OrderID, SelectedTariffType.TariffTypeID, GcType.GcTypeID, dateRange?.Start, dateRange?.End).ToList();
        }
        if (collection.Count == 0)
        {
            bool? result = await DialogService.ShowMessageBoxAsync(
                "Oops !",
                "No collection found!!");
        }
    }

    // Method to download data as an Excel filev
    private async Task ExcelDownload()
    {
        var fileName = "Pending Consignments.xlsx";
        var sheetName = "Sheet1"; // Change the sheet name as needed
        var fileBytes = GenerateExcelBytes(sheetName);

        await JSRuntime.InvokeVoidAsync("triggerFileDownload", fileName, Convert.ToBase64String(fileBytes));
    }

    // Method to generate Excel file bytes
    private byte[] GenerateExcelBytes(string sheetName)
    {
        // Generate your Excel data and file here, specifying the sheet name
        // You can use libraries like EPPlus or ClosedXML to generate Excel files
        // Below is just a placeholder method, implement according to your requirements

        using (var package = new ExcelPackage())
        {
            var worksheet = package.Workbook.Worksheets.Add(sheetName);

            // Add column headers
            worksheet.Cells[1, 1].Value = "BillNumber";
            worksheet.Cells[1, 2].Value = "BillDate";
            worksheet.Cells[1, 3].Value = "Truck No";
            worksheet.Cells[1, 4].Value = "PassNumber";
            worksheet.Cells[1, 5].Value = "ConsigneeName";
            worksheet.Cells[1, 6].Value = "District";
            worksheet.Cells[1, 7].Value = "State";
            worksheet.Cells[1, 8].Value = "BillQuantity";
            worksheet.Cells[1, 9].Value = "Freight";
            worksheet.Cells[1, 10].Value = "Payment Mode";
            for (int i = 1; i <= 10; i++)
            {
                worksheet.Cells[1, i].Style.Font.Bold = true;
            }

            worksheet.Column(2).Style.Numberformat.Format = "dd-MM-yyyy"; // Date format
            worksheet.Column(8).Style.Numberformat.Format = "0.00"; // Integer format
            worksheet.Column(9).Style.Numberformat.Format = "0.00";

            // Add data rows
            int row = 2;
            foreach (var item in collection)
            {
                worksheet.Cells[row, 1].Value = item.BillNumber;
                worksheet.Cells[row, 2].Value = item.BillDate;
                worksheet.Cells[row, 3].Value = item.TruckRegNo;
                worksheet.Cells[row, 4].Value = item.PassNumber;
                worksheet.Cells[row, 5].Value = item.ConsigneeName;
                worksheet.Cells[row, 6].Value = item.DistrictName;
                worksheet.Cells[row, 7].Value = item.StateName;
                worksheet.Cells[row, 8].Value = item.BillQuantity;
                worksheet.Cells[row, 9].Value = item.Amount;
                worksheet.Cells[row, 10].Value = item.PaymentMode;

                row++;
            }

            worksheet.Cells[worksheet.Dimension.Address].Style.Border.Top.Style = ExcelBorderStyle.Thin;
            worksheet.Cells[worksheet.Dimension.Address].Style.Border.Left.Style = ExcelBorderStyle.Thin;
            worksheet.Cells[worksheet.Dimension.Address].Style.Border.Right.Style = ExcelBorderStyle.Thin;
            worksheet.Cells[worksheet.Dimension.Address].Style.Border.Bottom.Style = ExcelBorderStyle.Thin;

            // Save the Excel package to a memory stream
            using (var stream = new MemoryStream())
            {
                package.SaveAs(stream);
                return stream.ToArray();
            }
        }
    }

    // Method to create a consolidated draft bill
    private async Task Create()
    {
        if (HasPermissionFreightBillingServiceEditConsolidatedDraftBill)
        {
            DialogOptions maxWidth = new DialogOptions() { MaxWidth = MaxWidth.Large, FullWidth = true };
            if (collection.Where(x => x.IsChecked).ToList().Count > 0)
            {
                ConsolidatedDraftBillModel cdm = new()
                    {
                        UserInfo = new() { UserID = UserID },
                        BranchID = BranchID,
                        NatureOfTransaction = "Billing",
                        BookedGCs = collection.Where(x => x.IsChecked).ToList(),//selectedItems1.ToList(),
                        Order = SelectedOrder,
                        Party = new PartyModel()
                        {
                            PartyID = SelectedClient.PartyID,
                            TradeName = SelectedClient.TradeName,
                        },
                        TariffType = SelectedTariffType,
                        DocumentDate = System.DateTime.Now,
                        DocFromDate = dateRange?.Start ?? null,
                        DocToDate = dateRange?.End ?? null,
                        Truck = SelectedTruck,
                        TotalAmount = collection.Where(x => x.IsChecked).Sum(x => x.Amount)
                    };
                DialogParameters parms = new DialogParameters();
                parms.Add("model", cdm);
                parms.Add("ReadOnly", false);
                var dialog = await DialogService.ShowAsync<ConsolidateDraftBillDialog>("ConsolidateDraftBill", parms, maxWidth);
                var result = await dialog.Result;

                if (!result.Canceled)
                {
                    ConsolidatedDraftBillModel UpatedModel = (ConsolidatedDraftBillModel)result.Data;
                    Iservice.UpdateConsolidatedDraftBill(UpatedModel); // Update the consolidated draft bill
                    snackbar.Add("Created Successfully ", Severity.Success);//value = "visible";
                    await LoadData("Fetch");
                }
            }
            else
            {
                snackbar.Add("Please select consignments to bill!", Severity.Error);
            }
        }
        else
        {
            bool? result = await DialogService.ShowMessageBoxAsync(
                "Permission denied!",
                "You don't have any permission to EditConsolidatedDraftBill FreightBilling.");
        }
    }

    // Method to search for GC tariff models based on a search string
    private bool search(GcTariffModel gcTariff)
    {
        if (string.IsNullOrWhiteSpace(searchBookFreight))
            return true;

        if ((gcTariff.BillNumber != null && gcTariff.BillNumber.Contains(searchBookFreight, StringComparison.OrdinalIgnoreCase)) ||
        (gcTariff.PassNumber != null && gcTariff.PassNumber.Contains(searchBookFreight, StringComparison.OrdinalIgnoreCase)) ||
        (gcTariff.StateName != null && gcTariff.StateName.Contains(searchBookFreight, StringComparison.OrdinalIgnoreCase)) ||
        (gcTariff.TruckRegNo != null && gcTariff.TruckRegNo.Contains(searchBookFreight, StringComparison.OrdinalIgnoreCase)) ||
        (gcTariff.ConsigneeName != null && gcTariff.ConsigneeName.Contains(searchBookFreight, StringComparison.OrdinalIgnoreCase)) ||
        (gcTariff.DistrictName != null && gcTariff.DistrictName.Contains(searchBookFreight, StringComparison.OrdinalIgnoreCase)))
        {

            return true;
        }
        return false;
    }
}
