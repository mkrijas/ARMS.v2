<MudDialog >
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.Edit" Class="mr-3" />  Set Invoice Number Manually
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudTextField @bind-Value="InvoiceNumber" Label="Invoice Number" Variant="Variant.Outlined" Margin="Margin.Dense"></MudTextField>
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="CloseDialog" Class="px-10">Close</MudButton>
    </DialogActions>
</MudDialog>


@code{


    [CascadingParameter]
    MudDialogInstance MudDialog { get; set; }


    
    string InvoiceNumber;

    void CloseDialog()
    {
        if (!string.IsNullOrEmpty(InvoiceNumber))
        {
            MudDialog.Close(InvoiceNumber);
        }
    }
}