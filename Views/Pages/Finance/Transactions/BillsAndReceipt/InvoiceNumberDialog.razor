@inject ISnackbar snackbar

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.Edit" Class="mr-3" />  Set Invoice Number Manually
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudGrid>
            <MudItem xs="6">
                <MudDatePicker Label="Invoice Date" Variant="Variant.Outlined" Margin="Margin.Dense" @bind-Date="reference.InvoiceDate" DateFormat="dd/MM/yyyy" MaxDate="DateTime.Now" />
            </MudItem>
            <MudItem xs="6">
                <MudTextField MaxLength="16" @bind-Value="reference.InvoiceNumber" Label="Invoice Number" Variant="Variant.Outlined" Margin="Margin.Dense"></MudTextField>
            </MudItem>
            <MudItem xs="12">
                <MudTextField @bind-Value="reference.InvoiceRefNumber" Label="Invoice Reference Number" Variant="Variant.Outlined" Margin="Margin.Dense"></MudTextField>
            </MudItem>
        </MudGrid>
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Submit" Class="px-10">Submit</MudButton>
    </DialogActions>
</MudDialog>

@code{

    [CascadingParameter]
    MudDialogInstance MudDialog { get; set; }

    public RefModel reference { get; set; } = new ();

    void Submit()
    {
        if (reference.InvoiceNumber == null)
        {
            snackbar.Add("Please enter invoice number.", Severity.Error);
            return;
        }
        if (reference.InvoiceDate == null)
        {
            snackbar.Add("Please select invoice date.", Severity.Error);
            return;
        }
        
        MudDialog.Close(reference);
    }
}