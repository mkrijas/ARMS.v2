<MudDialog >
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.Edit" Class="mr-3" />  Set Invoice Number Manually
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudTextField MaxLength="16" @bind-Value="reference.InvoiceNumber" Label="Invoice Number" Variant="Variant.Outlined" Margin="Margin.Dense"></MudTextField>
        <MudTextField @bind-Value="reference.InvoiceRefNumber" Label="Invoice Reference Number" Variant="Variant.Outlined" Margin="Margin.Dense"></MudTextField>
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Submit" Class="px-10">Submit</MudButton>
    </DialogActions>
</MudDialog>

@code{

    [CascadingParameter]
    MudDialogInstance MudDialog { get; set; }

    public RefModel reference { get; set; } = new ();

    void Submit()
    {
        if (!string.IsNullOrEmpty(reference.InvoiceNumber))
        {
            MudDialog.Close(reference);
        }
    }
}