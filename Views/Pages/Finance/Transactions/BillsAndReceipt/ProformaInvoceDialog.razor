@using System.Threading;
@inject IFreightBillingService Iservice
@inject IOrderService Iorder
@inject IPartyService partyIservice
@inject MudBlazor.ISnackbar snackbar
@inject AuthenticationStateProvider auth
@inject IRoleService<RoleModel> Irole
@attribute [Authorize]
@inject IDialogService DialogService

<DialogForm @ref="@dialogForm" ReadOnly="@ReadOnly" Title="Proforma Invoice" formID="proInForm" model="@model">
    <FormContent>
        <MudPaper Class="p-3">
            <EditForm id="proInForm" Model="@model" OnValidSubmit="OnValidSubmit">
                <ObjectGraphDataAnnotationsValidator />
                <ValidationSummary />
                <MudGrid>
                    <MudItem xs="12" md="4">
                        <MudDatePicker ReadOnly="ReadOnly" Label="DocumentDate" Variant="Variant.Outlined" Margin="Margin.Dense" DisableToolbar="true" Editable="true" @bind-Date="model.DocumentDate" DateFormat="dd/MM/yyyy" />
                    </MudItem>
                    <MudItem xs="12" md="4">
                        <MudTextField ReadOnly="true" Value="@tradeName" Label="Client" Variant="Variant.Outlined" Margin="Margin.Dense"></MudTextField>
                    </MudItem>
                    <MudItem xs="12" md="2">
                        <MudNumericField HideSpinButtons Value="model.FreightAmount" ReadOnly="true" Label="Freight" Variant="Variant.Outlined" Margin="Margin.Dense"></MudNumericField>
                     </MudItem>
                     <MudItem xs="12" md="2">
                         <MudTextField ReadOnly="true" Value="model.Gst?.TotalGst" Label="Gst" Variant="Variant.Outlined" Margin="Margin.Dense"></MudTextField>
                     </MudItem>
                     <MudItem xs="12" md="4">
                         <MudTextField ReadOnly="ReadOnly" @bind-Value="model.Reference" Label="Reference" Variant="Variant.Outlined" Margin="Margin.Dense"></MudTextField>
                     </MudItem>
                     <MudItem xs="12" md="4">
                         <CostCenterSelector @bind-Value="model.CostCenter" ReadOnly="@ReadOnly" />
                     </MudItem>
                     <MudItem xs="12" md="4">
                         <DimensionSelector @bind-Value="model.Dimension" ReadOnly="@ReadOnly" />
                     </MudItem>
                     <MudItem xs="12">
                         <MudTable Items="@model.BookedGCs" Dense Hover Striped Outlined Elevation="0">
                             <HeaderContent>
                                 <MudTh><MudTableSortLabel SortBy="new Func<GcTariffModel, object>(x=> x.BillNumber)" InitialDirection="SortDirection.Ascending">BillNumber</MudTableSortLabel></MudTh>
                                 <MudTh><MudTableSortLabel SortBy="new Func<GcTariffModel, object>(x=> x.BillDate)" InitialDirection="SortDirection.Ascending">BillDate</MudTableSortLabel></MudTh>
                                 <MudTh><MudTableSortLabel SortBy="new Func<GcTariffModel, object>(x=> x.InvoiceDate)" InitialDirection="SortDirection.Ascending">InvoiceDate</MudTableSortLabel></MudTh>
                                 <MudTh><MudTableSortLabel SortBy="new Func<GcTariffModel, object>(x=> x.ConsigneeName)" InitialDirection="SortDirection.Ascending">ConsigneeName</MudTableSortLabel></MudTh>
                                 <MudTh><MudTableSortLabel SortBy="new Func<GcTariffModel, object>(x=> x.BillQuantity)" InitialDirection="SortDirection.Ascending">BillQuantity</MudTableSortLabel></MudTh>
                                 <MudTh><MudTableSortLabel SortBy="new Func<GcTariffModel, object>(x=> x.Amount)" InitialDirection="SortDirection.Ascending">Freight</MudTableSortLabel></MudTh>
                             </HeaderContent>
                             <RowTemplate Context="cntxt">
                                 <MudTd DataLabel="BillNumber">@cntxt.BillNumber</MudTd>
                                 <MudTd DataLabel="BillDate">@cntxt.BillDate?.ToShortDateString()</MudTd>
                                 <MudTd DataLabel="InvoiceDate">@cntxt.InvoiceDate?.ToShortDateString()</MudTd>
                                 <MudTd DataLabel="ConsigneeName">@cntxt.ConsigneeName</MudTd>
                                 <MudTd DataLabel="BillQuantity">@cntxt.BillQuantity</MudTd>
                                 <MudTd DataLabel="Amount">@cntxt.Amount</MudTd>
                             </RowTemplate>
                         </MudTable>
                     </MudItem>
                     <MudItem xs="12" md="12">
                         <MudTextField ReadOnly="ReadOnly" @bind-Value="model.Narration" Lines="2" Label="Narration" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.Narration)"></MudTextField>
                     </MudItem>
                 </MudGrid>
             </EditForm>
         </MudPaper>
     </FormContent>
     <VerificationStatus>
         <AutherizationStatusComponent DocTypeID="@DocTypeID" DocumentID="model.ProformaInvoiceID" OnApprove="Approve"></AutherizationStatusComponent>
     </VerificationStatus>
 </DialogForm>

 @code {

    [Parameter]
    public ProformaInvoiceModel model { get; set; }
    [Parameter]
    public bool ReadOnly { get; set; }
    private EditContext editContext;
    DialogForm dialogForm;
    string tradeName;

    public bool ProformaInvoiceHasAuthoriseEdit { get; set; } = false;
    int DocTypeID = 2;

    protected override async Task OnInitializedAsync()
    {
        CancellationTokenSource ctc = new CancellationTokenSource();
        ProformaInvoiceHasAuthoriseEdit = await Irole.HasClaim(DocTypeID.ToString(), "Edit", ctc.Token);

        model.NatureOfTransaction = "Proforma Invoice";
        if (model.ProformaInvoiceID != null)
        {
            model.Party = partyIservice.SelectByID(model.Party.PartyID.Value);
        }
        else
        {
            var Order = await Iorder.SelectByID(model.OrderID);
            model.Party = Order.Party;
            model.PartyCoa = partyIservice.GetCustomerReceivableCoaID(model.Party.PartyID);
        }
        tradeName = model.Party.TradeName;
    }

    protected async Task Approve(DataApprovedStatus aprvd)
    {
        if (aprvd.IsApprove)
        {
            var authprov = await auth.GetAuthenticationStateAsync();
            var user = authprov.User;
            model.UserInfo.UserID = user.Identity.Name;
            try
            {
                Iservice.ApproveProformaInvoice(model.ProformaInvoiceID, model.UserInfo.UserID, aprvd.Remarks);
                snackbar.Add("Approved Successfully", Severity.Success);
            }
            catch (Exception ex)
            {
                snackbar.Add(ex.Message, Severity.Error);
            }
        }
    }

    private async Task OnValidSubmit(EditContext context)
    {
        if (ProformaInvoiceHasAuthoriseEdit)
        {

            model.PartyCoa = partyIservice.GetCustomerReceivableCoaID(model.Party.PartyID.Value);
            dialogForm.Close(model);
        }
        else
        {
            bool? result = await DialogService.ShowMessageBox(
                "Permission denied!",
                "You dont have any permission to submit.");
        }
    }
}