@using System.Threading;

@inject IFreightBillingService Iservice
@inject IOrderService Iorder
@inject IPartyService partyIservice
@inject MudBlazor.ISnackbar snackbar
@inject AuthenticationStateProvider auth
@inject IRoleService<RoleModel> Irole
@attribute [Authorize]
@inject IDialogService DialogService

<DialogForm @ref="@dialogForm" ReadOnly="@ReadOnly" Title="Proforma Invoice" Subtitle="Generate preliminary invoices for client approval and documentation." Icon="@Icons.Material.Filled.RequestPage" AdminStyle="true" formID="proInForm" DocumentDetails="@DocumentDetails" model="@model" _busy="_busy">
    <FormContent>
        <div class="dialog-content-wrapper pa-2">
            <EditForm id="proInForm" Model="@model" OnValidSubmit="OnValidSubmit">
                <div class="admin-glass-card pa-6">
                    <ObjectGraphDataAnnotationsValidator />
                    <ValidationSummary />
                    <MudTabs Elevation="0" Rounded="true" ApplyEffectsToInnerViews="true" Class="premium-tabs">
                        <MudTabPanel Text="Invoice Details" Icon="@Icons.Material.Filled.Receipt">
                            <MudGrid Class="pt-4">
                                <MudItem xs="12" md="4">
                                    <MudDatePicker ReadOnly="ReadOnly" Label="Document Date" Variant="Variant.Outlined" Margin="Margin.Normal" DisableToolbar="true" Editable="true" @bind-Date="model.DocumentDate" DateFormat="dd/MM/yyyy" MaxDate="DateTime.Now" Class="modern-input" />
                                </MudItem>
                                <MudItem xs="12" md="8">
                                    <MudTextField ReadOnly="true" Value="@tradeName" Label="Client / Customer" Variant="Variant.Outlined" Margin="Margin.Normal" Class="modern-input"></MudTextField>
                                </MudItem>
                                <MudItem xs="12" md="4">
                                    <MudTextField ReadOnly="ReadOnly" @bind-Value="model.Reference" Label="Reference" Variant="Variant.Outlined" Margin="Margin.Normal" Class="modern-input"></MudTextField>
                                </MudItem>
                                <MudItem xs="12" md="4">
                                    <CostCenterSelector @bind-Value="model.CostCenter" ReadOnly="@ReadOnly" />
                                </MudItem>
                                <MudItem xs="12" md="4">
                                    <DimensionSelector @bind-Value="model.Dimension" ReadOnly="@ReadOnly" />
                                </MudItem>
                                <MudItem xs="12" md="6">
                                    <MudNumericField HideSpinButtons Value="model.FreightAmount" ReadOnly="true" Label="Freight Amount" Variant="Variant.Outlined" Margin="Margin.Normal" Class="modern-input"></MudNumericField>
                                </MudItem>
                                <MudItem xs="12" md="6">
                                    <MudTextField ReadOnly="true" Value="model.Gst?.TotalGst" Label="GST Amount" Variant="Variant.Outlined" Margin="Margin.Normal" Class="modern-input"></MudTextField>
                                </MudItem>
                                <MudItem xs="12">
                                    <div class="d-flex align-center mt-4 mb-2">
                                        <MudIcon Icon="@Icons.Material.Filled.LocalShipping" Color="Color.Primary" Class="mr-2" />
                                        <MudText Typo="Typo.subtitle1" Class="admin-title font-weight-bold">Booked Goods Consignments</MudText>
                                    </div>
                                    <MudTable Items="@model.BookedGCs" Dense Hover Striped Outlined Elevation="0" Class="glass-inner-panel">
                                        <HeaderContent>
                                            <MudTh><MudTableSortLabel SortBy="new Func<GcTariffModel, object>(x=> x.BillNumber)" InitialDirection="SortDirection.Ascending">Bill Number</MudTableSortLabel></MudTh>
                                            <MudTh><MudTableSortLabel SortBy="new Func<GcTariffModel, object>(x=> x.BillDate)">Bill Date</MudTableSortLabel></MudTh>
                                            <MudTh><MudTableSortLabel SortBy="new Func<GcTariffModel, object>(x=> x.InvoiceDate)">Invoice Date</MudTableSortLabel></MudTh>
                                            <MudTh><MudTableSortLabel SortBy="new Func<GcTariffModel, object>(x=> x.ConsigneeName)">Consignee Name</MudTableSortLabel></MudTh>
                                            <MudTh><MudTableSortLabel SortBy="new Func<GcTariffModel, object>(x=> x.BillQuantity)">Quantity</MudTableSortLabel></MudTh>
                                            <MudTh><MudTableSortLabel SortBy="new Func<GcTariffModel, object>(x=> x.Amount)">Freight</MudTableSortLabel></MudTh>
                                            <MudTh><MudTableSortLabel SortBy="new Func<GcTariffModel, object>(x=> x.Deduction)">Deduction</MudTableSortLabel></MudTh>
                                        </HeaderContent>
                                        <RowTemplate Context="cntxt">
                                            <MudTd DataLabel="BillNumber">@cntxt.BillNumber</MudTd>
                                            <MudTd DataLabel="BillDate">@cntxt.BillDate?.ToShortDateString()</MudTd>
                                            <MudTd DataLabel="InvoiceDate">@cntxt.InvoiceDate?.ToShortDateString()</MudTd>
                                            <MudTd DataLabel="ConsigneeName">@cntxt.ConsigneeName</MudTd>
                                            <MudTd DataLabel="BillQuantity">@cntxt.BillQuantity</MudTd>
                                            <MudTd DataLabel="Amount">@cntxt.Amount</MudTd>
                                            <MudTd DataLabel="Deduction">@cntxt.Deduction</MudTd>
                                        </RowTemplate>
                                    </MudTable>
                                </MudItem>
                                <MudItem xs="12" md="12">
                                    <MudTextField ReadOnly="ReadOnly" @bind-Value="model.Narration" Lines="2" Label="Invoice Narration" Variant="Variant.Outlined" Margin="Margin.Normal" For="@(() => model.Narration)" Class="modern-input"></MudTextField>
                                </MudItem>
                            </MudGrid>
                        </MudTabPanel>
                        <MudTabPanel Text="Billing Address" Icon="@Icons.Material.Filled.LocationOn">
                            <div class="pa-4">
                                <MudRadioGroup T="AddressModel" @bind-Value="selectedAddress">
                                    <MudGrid>
                                        @foreach (var address in addresses)
                                        {
                                            <MudItem xs="12" md="6" lg="4">
                                                <div class="admin-glass-card pa-4 @(selectedAddress == address ? "border-primary" : "")">
                                                    <div class="d-flex align-center">
                                                        <MudRadio T="AddressModel" Value="address" Color="Color.Primary" />
                                                        <div class="ml-2">
                                                            <MudText Typo="Typo.subtitle2" Class="font-weight-bold">@address.AddresseeName</MudText>
                                                            <MudText Typo="Typo.body2" Class="opacity-70">
                                                                @address.Building, @address.Street, @address.City
                                                                <br />
                                                                @address.Place, @address.City - @address.PinCode
                                                            </MudText>
                                                        </div>
                                                    </div>
                                                </div>
                                            </MudItem>
                                        }
                                    </MudGrid>
                                </MudRadioGroup>
                            </div>
                        </MudTabPanel>
                    </MudTabs>
                </div>
            </EditForm>
        </div>
    </FormContent>
    <VerificationStatus>
        <AutherizationStatusComponent CreatedBy="@model.UserInfo" DocTypeID="@FreightBillingDocTypeID" DocDate="@DocDate" DocType="@DocType" DocNumber="@DocNumber" PageToRedirectLink="@PageToRedirectLink" DocumentID="model.ProformaInvoiceID" OnApprove="Approve"></AutherizationStatusComponent>
    </VerificationStatus>
</DialogForm>

@code {

    [Parameter]
    public ProformaInvoiceModel model { get; set; }
    [Parameter]
    public bool ReadOnly { get; set; }
    [Parameter]
    public EventCallback OnApproved { get; set; }
    private EditContext editContext;
    DialogForm dialogForm;
    string tradeName;
    [Parameter]
    public string PageToRedirectLink { get; set; }
    public string DocNumber { get; set; }
    public DateTime? DocDate { get; set; }
    public string DocType { get; set; }
    private bool _busy;
    public DocumentInfoModel DocumentDetails { get; set; } = new();
    private AddressModel selectedAddress;
    private List<AddressModel> addresses = new List<AddressModel>();

    public bool HasPermissionFreightBillingServiceApprove { get; set; } = false;
    public int FreightBillingDocTypeID = 116;

    // Lifecycle method called when the component is initializedcv
    protected override async Task OnInitializedAsync()
    {
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionFreightBillingServiceApprove = await Irole.HasClaim(FreightBillingDocTypeID.ToString(), "Approve", ctc.Token);

        model.NatureOfTransaction = "Proforma Invoice";

        addresses = partyIservice.GetAddress(model.Party.PartyID)?.ToList() ?? new List<AddressModel>();

        // If the Proforma Invoice ID is not null, fetch the party details
        if (model.ProformaInvoiceID != null)
        {
            model.Party = partyIservice.SelectByID(model.Party.PartyID.Value);
            selectedAddress = addresses.FirstOrDefault(x => x.AddressID == model.AddressID);            
        }
        else
        {
            var authprov = await auth.GetAuthenticationStateAsync();
            var user = authprov.User;
            model.UserInfo.UserID = user.Identity.Name;

            // Fetch the order details
            var Order = await Iorder.SelectByID(model.OrderID);
            if (model.Party?.PartyID is null)
            {
                model.Party = Order.Party;
            }

            // Get the customer receivable COA ID for the party
            model.PartyCoa = partyIservice.GetCustomerReceivableCoaID(model.Party.PartyID);
        }

        tradeName = model.Party.TradeName;
        DocNumber = model.DocumentNumber;
        DocDate = model.DocumentDate;
        DocType = model.NatureOfTransaction;        

        if (addresses.Count == 1)
        {
            selectedAddress = addresses[0];
        }

        StateHasChanged();
    }


    // Lifecycle method called when parameters are set or changed
    protected override void OnParametersSet()
    {
        DocumentDetails.DocumentTypeID = FreightBillingDocTypeID;
        DocumentDetails.DocumentID = model.ProformaInvoiceID;
    }

    // Method to handle approval of the Proforma Invoice
    protected async Task Approve(DataApprovedStatus aprvd)
    {
        if (HasPermissionFreightBillingServiceApprove)
        {
            if (aprvd.IsApprove)
            {
                var dialog = await DialogService.ShowAsync<InvoiceNumberDialog>();

                var res = await dialog.Result;
                if (!res.Canceled)
                {
                    var Ref = (RefModel)res.Data;
                    var authprov = await auth.GetAuthenticationStateAsync();
                    var user = authprov.User;
                    model.UserInfo.UserID = user.Identity.Name;
                    try
                    {
                        // Approve the Proforma Invoice
                        Iservice.Approve(model.ProformaInvoiceID, model.UserInfo.UserID, aprvd.Remarks, Ref.InvoiceNumber, Ref.InvoiceRefNumber, Ref.InvoiceDate);
                        snackbar.Add("Approved Successfully", Severity.Success);
                        await OnApproved.InvokeAsync();
                    }
                    catch (Exception ex)
                    {
                        snackbar.Add(ex.Message, Severity.Error);
                    }
                }

            }
        }
        else
        {
            bool? result = await DialogService.ShowMessageBoxAsync(
                "Permission denied!",
                "You don't have any permission to Approve FreightBilling.");
        }
    }

    // Method to handle form submission when the form is valid
    private async Task OnValidSubmit(EditContext context)
    {
        if (selectedAddress == null)
        {
            snackbar.Add("Please select billing address!", Severity.Warning);
            return;
        }
        if (_busy)
        {
            snackbar.Add("Please wait while form is being submitted!", Severity.Warning);
            return;
        }
        _busy = true;

        model.AddressID = selectedAddress.AddressID;
        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;
        model.UserInfo.UserID = user.Identity.Name;

        // Get the customer receivable COA ID for the party
        model.PartyCoa = partyIservice.GetCustomerReceivableCoaID(model.Party.PartyID.Value);
        if (model.PartyCoa is null)
        {
            // If COA is not found, try to get a different COA ID
            model.PartyCoa = partyIservice.GetPartyCoaID(model.Party.PartyID, "SisterConcern", "Trade");
        }

        if (model.PartyCoa is null)
        {
            snackbar.Add("Party Account not mapped!!", Severity.Error);
            return;
        }
        dialogForm.Close(model);

        await Task.Delay(200);
        _busy = false;
    }
}
