@page "/ProformaInvoiceView"
@page "/ProformaInvoiceView/{id:int}"
@using System.Threading;
@layout BillsLayout
@inject IFreightBillingService Iservice
@inherits ViewComponentBase<ProformaInvoiceModel>

    <div class="fade-in">
        <div class="admin-header-tiered mb-6">
            <div class="d-flex align-center justify-space-between">
                <div>
                    <MudText Typo="Typo.h4" Class="admin-title">Proforma Invoicing Hub</MudText>
                    <MudText Typo="Typo.body2" Class="admin-subtitle">Consolidated manager for draft billing and proforma invoice issuance. Orchestrate client approvals, verify logistics data, and transition validated drafts into official tax invoices.</MudText>
                </div>
            </div>
        </div>

        <div class="admin-glass-card mb-6 pa-4">
            <div class="d-flex align-center gap-4 flex-wrap">
                <div style="flex-grow: 1; min-width: 300px;">
                    <MudTextField @bind-Value="searchTerm" Placeholder="Search by invoice #, client, or date..." Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" Variant="Variant.Outlined" Margin="Margin.Dense" Class="admin-input-group" Clearable="true" OnKeyUp="HandleSearchKeyUp" />
                </div>
                <div class="d-flex align-center gap-4">                   
                    <div class="d-flex align-center bg-glass rounded-pill px-4 py-1">
                        <MudCheckBox T="bool" Label="Approved Drafts" ValueChanged="((bool value)=>ToggleData(value))" Value="@ShowApproved" Size="Size.Small" Color="Color.Primary" Class="fw-600" />
                    </div>
                </div>
            </div>
        </div>

        <div class="admin-glass-card pa-0 overflow-hidden shadow-sm">
                    <MudTable ServerData="LoadServerData" T="ProformaInvoiceModel" @ref="_table" Elevation="0" Class="modern-admin-table" Hover="true" LoadingProgressColor="Color.Primary" >
                <HeaderContent>
                    <MudTh><MudTableSortLabel SortBy="new Func<ProformaInvoiceModel, object>(x=> x.DocumentDate)"><span class="admin-header-text">INV DATE</span></MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<ProformaInvoiceModel, object>(x=> x.DocumentNumber)"><span class="admin-header-text">DOC NUMBER</span></MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<ProformaInvoiceModel, object>(x=> x.Party.TradeName)"><span class="admin-header-text">CLIENT NAME</span></MudTableSortLabel></MudTh>
                    <MudTh><span class="admin-header-text">BILLING PERIOD</span></MudTh>
                    <MudTh Style="text-align: right;"><MudTableSortLabel SortBy="new Func<ProformaInvoiceModel, object>(x=> x.TotalAmount)"><span class="admin-header-text">TOTAL AMOUNT</span></MudTableSortLabel></MudTh>
                    <MudTh Style="text-align: right;"><span class="admin-header-text">ACTIONS</span></MudTh>
                </HeaderContent>
                <LoadingContent>
                <div @key="@("loader")" style="display: flex; justify-content: center; align-items: center; min-height: 400px;">
                    <LoaderComponent IsFullScreen="false"
                                     ShowLogo="false"
                                     Size="medium"
                                     LoadingText="Structuring Invoices"
                                     SubText="Loading..." />
                </div>
                </LoadingContent>               
                <RowTemplate>
                    <MudTd DataLabel="Date"><span class="fw-700 admin-td-primary">@context.DocumentDate?.ToString("dd MMM yyyy")</span></MudTd>
                    <MudTd DataLabel="DocNum">
                        <div class="d-flex align-center gap-2">
                            <span class="fw-700">@context.DocumentNumber</span>
                             @if (context.AuthLevelId == 100)
                            {
                                <span class="tiny fw-900 text-error uppercase">REJECTED</span>
                            }
                        </div>
                    </MudTd>
                    <MudTd DataLabel="Client">
                         <div class="d-flex align-center gap-2">
                             <div class="admin-icon-square-vibrant tiny accent-indigo">
                                <MudIcon Icon="@Icons.Material.Filled.Person" Size="Size.Small" />
                            </div>
                            <span class="fw-600">@context.Party.TradeName</span>
                        </div>
                    </MudTd>
                    <MudTd DataLabel="Period">
                        <span class="tiny fw-800 text-indigo uppercase">@context.PeriodFrom?.ToString("dd/MM/yy")</span>
                        <span class="tiny mx-1 opa-30">TO</span>
                        <span class="tiny fw-800 text-indigo uppercase">@context.PeriodTo?.ToString("dd/MM/yy")</span>
                    </MudTd>
                    <MudTd DataLabel="Amount" Style="text-align: right;">
                        <span class="fw-800 text-vibrant" style="font-size: 1.1rem;">@context.TotalAmount?.ToString("N2")</span>
                    </MudTd>
                    <MudTd DataLabel="Actions" Style="text-align: right;">
                        <div class="d-flex justify-end gap-1">
                                <MudTooltip Text="Inspect Details">
                                    <MudIconButton OnClick="@(()=> OpenForm(context,true))" Color="Color.Info" Icon="@Icons.Material.Filled.Visibility" Size="Size.Small" Variant="Variant.Text" />
                                </MudTooltip>
                                
                                <MudTooltip Text="Modify Draft">
                                        <MudIconButton Disabled="@(context.AuthLevelId != null)" OnClick="@(() => OpenForm(context, false))" Color="Color.Primary" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Variant="Variant.Text" />
                                </MudTooltip>
                                @if (@context.AuthLevelId == 99)
                                {
                                    <EntryReversedComponent DocTypeID="DocInfo.DocumentTypeID" DocumentID="context.ProformaInvoiceID" MID="context.MID" DocumentNumber="@context.DocumentNumber"></EntryReversedComponent>
                                    <MudTooltip Text="Cancel Bill">
                                        <MudIconButton OnClick="@(()=> Delete(context.ProformaInvoiceID))" Color="Color.Error" Icon="@Icons.Material.Filled.Cancel" Size="Size.Small" Variant="Variant.Text" />
                                    </MudTooltip>
                                    <MudTooltip Text="Annexure Invoice">
                                        <MudIconButton OnClick="@(()=> PrintAnnexure(context.ProformaInvoiceID))" Color="Color.Tertiary" Icon="@Icons.Material.Filled.Assignment" Size="Size.Small" Variant="Variant.Text" />
                                    </MudTooltip>
                                }
                                else if (@context.AuthLevelId != 100)
                                {
                                    <MudTooltip Text="Verify Invoice">
                                            <MudIconButton OnClick="@(() => OpenForm(context, true))" Color="Color.Success" Icon="@Icons.Material.Filled.Verified" Size="Size.Small" Variant="Variant.Text" />
                                    </MudTooltip>
                                }
                                <MudTooltip Text="Print Documentation">
                                    <MudIconButton OnClick="@(()=> Print(context.ProformaInvoiceID,(context.AuthLevelId == 99) ? "TAX INVOICE" : "PROFORMA INVOICE"))" Color="Color.Tertiary" Icon="@Icons.Material.Filled.Print" Size="Size.Small" Variant="Variant.Text" />
                                </MudTooltip>
                        </div>
                    </MudTd>
                </RowTemplate>
                <PagerContent>
                    <div class="pa-4">
                        <MudTablePager PageSizeOptions="new int[] { 10, 20, 50, 100 }" />
                    </div>
                </PagerContent>
            </MudTable>
        </div>
    </div>



@code {    

    protected override List<ProformaInvoiceModel> _collection{ get; set; } = [];

    protected override DocumentInfoModel DocInfo { get; set; } = new DocumentInfoModel()
    {
        DocumentTypeID = 116,
        DocumentName = "Proforma Invoice"
    };
   
    public string BranchName = "";
    public string ReportName { get; set; }
    public Dictionary<string, string> ReportParameters { get; set; } = new();

    // Method to print the Proforma Invoice
    private async Task Print(int? ProformaInvoiceID, string Title)
    {
        ReportParameters.Clear();
        ReportParameters.Add("ProformaInvoiceID", ProformaInvoiceID.ToString());
        ReportParameters.Add("Title", Title);
        var parameters = new DialogParameters();
        parameters.Add("Parameters", ReportParameters); // Add the dictionary as a parameter
        parameters.Add("ReportName", "PrintTaxInvoice");

        DialogOptions maxWidth = new DialogOptions() { MaxWidth = MaxWidth.Medium, FullWidth = true };
        var result = await dialogService.ShowAsync<PrintDialog>("PRINT", parameters, maxWidth);
    }

    // Method to print the annexure of the Proforma Invoice
    private async Task PrintAnnexure(int? ProformaInvoiceID)
    {
        ReportParameters.Clear();
        ReportParameters.Add("ProformaInvoiceID", ProformaInvoiceID.ToString());
        ReportParameters.Add("BranchName", BranchName);
        var parameters = new DialogParameters();
        parameters.Add("Parameters", ReportParameters); // Add the dictionary as a parameter
        parameters.Add("ReportName", "AnnexureToInvoice");

        DialogOptions maxWidth = new DialogOptions() { MaxWidth = MaxWidth.Medium, FullWidth = true };
        var result = await dialogService.ShowAsync<PrintDialog>("PRINT", parameters, maxWidth);
    } 
      
    // Lifecycle method called when the component is initialized
    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();       
        if (id != null && _collection != null && _collection.Any(g => g.ProformaInvoiceID == id))
        {
            await OpenForm(_collection.FirstOrDefault(s => s.ProformaInvoiceID == id), true);
        }        
        _isLoading = false;        
    }      

    protected override async Task OpenForm(ProformaInvoiceModel ppm, bool ReadOnly, bool DisableAddition = false)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        _busy = true;
        DialogParameters parms = new DialogParameters();
        parms.Add("model", ppm.Clone());
        parms.Add("ReadOnly", ReadOnly);
        parms.Add("OnApproved", new EventCallbackFactory().Create(this, async () => await _table.ReloadServerData()));
        var dialog = await dialogService.ShowAsync<ProformaInvoiceDialog>(ppm.ProformaInvoiceID == null ? "ADD" : "EDIT", parms, new DialogOptions() { MaxWidth = MaxWidth.Large, FullWidth = true });
        var result = await dialog.Result;
        if (!result.Canceled)
        {
            var ReturnData = (TaxPurchaseModel)result.Data;
            await _table.ReloadServerData();
        }
        await Task.Delay(200);
        _busy = false;
    }
   
}
