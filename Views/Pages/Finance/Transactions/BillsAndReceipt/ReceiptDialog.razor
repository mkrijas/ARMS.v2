@inherits DialogFormComponentBase<ReceiptModel>
@inject IReceiptService Iservice
@using PurchaseAndPayment

<DialogForm @ref="@dialogForm" ReadOnly="@ReadOnly" Title="Receipt Entry" Subtitle="Process incoming payments and settle outstanding invoices with ease." Icon="@Icons.Material.Filled.Receipt" AdminStyle="true" formID="receiptForm" DocumentDetails="DocInfo" model="@model" _busy="_busy">
    <FormContent>
        <div class="dialog-content-wrapper">
            <EditForm id="receiptForm" OnValidSubmit="OnValidSubmit" EditContext="editContext">
                <ObjectGraphDataAnnotationsValidator />
                
                <div class="admin-glass-card pa-6">
                    <span class="admin-section-label">General Information</span>
                    <MudGrid Spacing="3">
                        <MudItem xs="12" md="3">
                            <MudDatePicker ReadOnly="ReadOnly" Label="Document Date" Variant="Variant.Outlined" Margin="Margin.Dense" DisableToolbar="true" Editable="true" @bind-Date="model.DocumentDate" DateFormat="dd/MM/yyyy" MaxDate="DateTime.Now" Class="admin-input-group" />
                        </MudItem>
                        <MudItem xs="12" md="3">
                            <MudSelect Label="Party Type" Value="@model.BusinessNature" ValueChanged="BusinessNatureChanged" T="string" Variant="Variant.Outlined" Margin="Margin.Dense" Class="admin-input-group">
                                <MudSelectItem Value="@("Supplier")" />
                                <MudSelectItem Value="@("Customer")" />
                                <MudSelectItem Value="@("Renter")" />
                                <MudSelectItem Value="@("SisterConcern")">Sister Concern</MudSelectItem>
                            </MudSelect>
                        </MudItem>
                        <MudItem xs="12" md="3">
                            <PartySelector Value="model.PartyInfo" ValueChanged="PartyChanged" NatureOfBusiness="@model.BusinessNature" BranchID="BranchID" For="(() => model.PartyInfo)" Class="admin-input-group" />
                        </MudItem>
                        <MudItem xs="12" md="3">
                            <MudSelect Label="Receipt Nature" ReadOnly="ReadOnly" Value="model.NatureOfTransaction" ValueChanged="nTransactionChanged" T="string" Variant="Variant.Outlined" Margin="Margin.Dense" Class="admin-input-group">
                                @if (model.PartyInfo is not null)
                                {
                                    foreach (var item in natureOfBusinessGroup)
                                    {
                                        <MudSelectItem Value="@(item)" />
                                    }
                                }
                            </MudSelect>
                        </MudItem>
                    </MudGrid>
                </div>

                @if (model.Bills.Any())
                {
                    <div class="admin-glass-card pa-0 overflow-hidden mb-6">
                        <div class="px-6 py-4 border-bottom-subtle" style="background: rgba(255, 159, 67, 0.02);">
                            <span class="admin-section-label mb-0">Invoice Settlement</span>
                        </div>
                        <div class="modern-admin-table">
                            <MudGrid Class="admin-table-header px-6 py-3">
                                <MudItem xs="6"><span class="admin-header-text">INVOICE INFO</span></MudItem>
                                <MudItem xs="3"><span class="admin-header-text">BRANCH</span></MudItem>
                                <MudItem xs="3"><span class="admin-header-text">RECEIPT AMOUNT</span></MudItem>
                            </MudGrid>
                            @foreach (var item in model.Bills)
                            {
                                <MudGrid Class="px-6 py-3 border-bottom-subtle align-center">
                                    <MudItem xs="6">
                                        <MudText Typo="Typo.body1" Style="font-weight: 700; color: #141A46;">@item.InvoiceNumber</MudText>
                                        <MudText Typo="Typo.caption" Style="color: #667085;">@item.InvoiceDate?.ToString("dd/MM/yyyy")</MudText>
                                    </MudItem>
                                    <MudItem xs="3">
                                        <MudText Typo="Typo.body2">@item.BranchName</MudText>
                                    </MudItem>
                                    <MudItem xs="3">
                                        <MudNumericField ReadOnly="@ReadOnly" T="decimal?" @bind-Value="item.ReceiptAmount" TextChanged="setTotalAmt" Variant="Variant.Outlined" Margin="Margin.Dense" HideSpinButtons="true" Class="admin-input-group" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.CurrencyRupee" AdornmentColor="Color.Primary" />
                                    </MudItem>
                                </MudGrid>
                            }
                        </div>
                    </div>
                }

                <div class="admin-glass-card pa-6">
                    <span class="admin-section-label">Payment & Reference</span>
                    <MudGrid Spacing="3">
                        <MudItem xs="12">
                            <PaymentAccountSelector @bind-PaymentMode="@model.ReceiptMode"
                                @bind-ArdCode="@model.ReceiptArdCode" @bind-CoaID="@model.ReceiptCoaID"
                                @bind-BankCharges="@model.BankCharges" @bind-BankTool="@model.ReceiptTool" Class="admin-input-group" />
                        </MudItem>
                        <MudItem xs="12" md="4">
                            <MudDatePicker ReadOnly="ReadOnly" Label="Effective Date" Variant="Variant.Outlined" Margin="Margin.Dense" DisableToolbar="true" Editable="true" @bind-Date="model.EffectiveDate" DateFormat="dd/MM/yyyy" Class="admin-input-group" />
                        </MudItem>
                        <MudItem xs="12" md="4">
                            <MudTextField ReadOnly="ReadOnly" @bind-Value="model.Reference" Label="Reference No" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.Reference)" Class="admin-input-group"></MudTextField>
                        </MudItem>
                        <MudItem xs="12" md="4">
                            <MudNumericField ReadOnly="@ReadOnly" Disabled="@model.Bills.Any()" @bind-Value="model.TotalAmount" Label="Total Receipt Amount" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.TotalAmount)" Class="admin-input-group" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.CurrencyRupee" AdornmentColor="Color.Primary" HideSpinButtons="true" />
                        </MudItem>
                        <MudItem xs="12">
                            <MudTextField ReadOnly="ReadOnly" @bind-Value="model.Narration" Lines="3" Label="Narration / Description" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.Narration)" Class="admin-input-group"></MudTextField>
                        </MudItem>
                    </MudGrid>
                </div>
            </EditForm>
        </div>
    </FormContent>
    <VerificationStatus>
        <AutherizationStatusComponent CreatedBy="@model.UserInfo" DocTypeID="@DocInfo.DocumentTypeID" DocDate="@DocDate" DocumentID="@model.ReceiptID" OnApprove="Approve"></AutherizationStatusComponent>
    </VerificationStatus>
</DialogForm>

@code {


    [Parameter]
    public override ReceiptModel model { get { return _model; } set { _model = value; DocInfo.DocumentID = value.ReceiptID; } }
    private ReceiptModel _model;


    string[] natureOfBusinessGroup = new string[] { };
    string[] RentGroup = { "Rent", "Deposit", "Other" };
    string[] SupplierGroup = { "Deposit", "Payable", "Prepayment" };
    string[] CustomerGroup = { "Deposit", "Receivable", "Prepayment" };
    string[] SisterGroup = { "Deposit", "Trade", "Prepayment" };

    protected override DocumentInfoModel DocInfo { get; set; } = new DocumentInfoModel()
        {
            DocumentTypeID = 14,
            DocumentName = "Receipt"
        };

    // Lifecycle method called when the component is initialized
    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();

        // If a ReceiptID is provided, fetch the associated bills
        if (model.ReceiptID != null)
        {
            model.Bills = Iservice.GetBills(model.ReceiptID.Value).ToList();
        }
        else
        {
            model.BranchID = BranchID;
            model.BusinessNature = "Customer";
        }
        SetNTransaction(model.BusinessNature);
    }

    // Method to update the receipt model
    protected override async Task<int> Update(ReceiptModel editModel)
    {
        model = Iservice.Update(model); // Update the model using the service
        return model.ReceiptID.Value;
    }

    // Method to approve the receipt
    protected override int UpdateApproval(DataApprovedStatus aprvd)
    {
        int result = Iservice.Approve(model.ReceiptID, model.UserInfo.UserID, aprvd.Remarks); // Approve the receipt
        return result;
    }

    // Method to set the nature of transactions based on business type
    void SetNTransaction(string nBusiness)
    {
        if (nBusiness == "Renter")
        {
            natureOfBusinessGroup = RentGroup;
        }
        else if (nBusiness == "Customer")
        {
            natureOfBusinessGroup = CustomerGroup;
        }
        else if (nBusiness == "Supplier")
        {
            natureOfBusinessGroup = SupplierGroup;
        }
        else if (nBusiness == "SisterConcern")
        {
            natureOfBusinessGroup = SisterGroup;
        }
        else
        {
            natureOfBusinessGroup = new string[] { };
        }
    }    

    // Method to handle changes in business nature
    async Task BusinessNatureChanged(string bn)
    {
        model.BusinessNature = bn;
        await PartyChanged(null);
        SetNTransaction(bn);
        model.TotalAmount = 0;
    }

    // Method to handle changes in the selected party
    async Task PartyChanged(PartyModel party)
    {
        model.PartyInfo = party;
        await nTransactionChanged(null);
    }

    // Method to handle changes in the nature of transaction
    private async Task nTransactionChanged(string nt)
    {
        model.NatureOfTransaction = nt;
        if (model.NatureOfTransaction is not null)
        {
            // Get the Party COA ID based on the selected party and transaction nature
            model.PartyCoaID = partyService.GetPartyCoaID(model.PartyInfo.PartyID, model.BusinessNature, model.NatureOfTransaction);
            if (model.PartyCoaID == null)
            {
                bool? result = await dialogService.ShowMessageBoxAsync(
                    "Account Not Mapped!",
                    "Party Account is not mapped for " + model.NatureOfTransaction + "!");
                model.NatureOfTransaction = null;
            }
        }

        if (nt == "Receivable")
        {
            await OpenOutstandingBills();
        }
        else
        {
            model.Bills.Clear();
        }
    }    

    // Method to calculate the total amount from the bills
    private void setTotalAmt()
    {
        model.TotalAmount = model.Bills.Sum(x => x.ReceiptAmount);
    }

    // Method to open the outstanding bills dialog
    private async Task OpenOutstandingBills()
    {
        DialogOptions maxWidth = new DialogOptions() { MaxWidth = MaxWidth.Medium, FullWidth = true };
        DialogParameters parms = new DialogParameters();
        parms.Add("PartyID", model.PartyInfo?.PartyID ?? null);
        parms.Add("BranchID", BranchID);
        var dialog = await dialogService.ShowAsync<OutstandingBillView>("Outstanding Bill", parms, maxWidth);
        var result = await dialog.Result;
        List<OutstandingBillsModel> SelectedItems = new List<OutstandingBillsModel>();
        if (!result.Canceled)
        {
            SelectedItems = (List<OutstandingBillsModel>)result.Data;
            if (SelectedItems != null)
            {
                foreach (var item in SelectedItems)
                {
                        model.Bills.Add(new BillsReceiptModel()
                        {
                            MID = item.MID,
                            BranchName = item.BranchName,
                            BranchID = item.BranchID,
                            InvoiceDate = item.ReferenceDocDate,
                            InvoiceNumber = item.ReferenceDocNo,
                            ReceiptAmount = item.OutstandingAmount,
                            PartyID = item.PartyInfo.PartyID,                            
                            CoaID = item.CoaID,
                            SubArdCode = item.SubArdCode
                        });
                }
            }
        }
        else
        {
            await nTransactionChanged(null);
        }
    }
  
}
