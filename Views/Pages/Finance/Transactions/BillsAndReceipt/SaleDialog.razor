@using System.Threading;

@inject ISaleService Iservice
@inject IPartyService partyIservice
@inject IInventoryItemService itemIservice
@inject IGstItemService gstitemIservice
@inject IInventoryGroupService inventoryGroupIservice
@inject IGstUsageIDService usageIservice
@inject IInventoryGrnService grnIservice
@inject IBranchService branchIservice
@inject MudBlazor.ISnackbar snackbar
@inject ITdsRateService tdsIService
@inject AuthenticationStateProvider auth
@inject IRoleService<RoleModel> Irole
@attribute [Authorize]
@inject IDialogService DialogService
@inject IJSRuntime JsRuntime

<DialogForm @ref="@dialogForm" ReadOnly="@ReadOnly" Title="Sale" formID="saleForm" DocumentDetails="DocumentDetails" model="@model" _busy="_busy">
    <FormContent>
        <MudPaper Class="p-3">
            <EditForm id="saleForm" Model="@model" OnValidSubmit="OnValidSubmit">
                <ObjectGraphDataAnnotationsValidator />
                <ValidationSummary />
                <MudGrid Spacing="2">
                    <MudItem xs="12" md="6">
                        <PartySelector Value="model.PartyInfo" ValueChanged="PartyChanged" NatureOfBusiness="Customer" BranchID="@branchID" IncludeSisterConcern></PartySelector>
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudDatePicker Label="Document Date" ReadOnly="ReadOnly" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.DocumentDate)" DisableToolbar="true" Editable="true" @bind-Date="model.DocumentDate" DateFormat="dd/MM/yyyy" MaxDate="DateTime.Now" />
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudTextField ReadOnly="ReadOnly" @bind-Value="model.InvoiceNo" Label="Invoice No" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.InvoiceNo)"></MudTextField>
                    </MudItem>
                    @* <MudItem xs="12" md="4">
                    <MudTextField @bind-Value="model.AdditionalTCS" ReadOnly="ReadOnly" Label="Additional TDS" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.AdditionalTCS)"></MudTextField>
                    </MudItem> *@
                    <MudItem xs="12" md="12">
                        <MudTextField @bind-Value="model.Narration" ReadOnly="ReadOnly" Lines="2" Label="Narration" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.Narration)"></MudTextField>
                    </MudItem>
                    <MudItem xs="12">
                        <ExpenseListView OnExpenseAdded="AddExpense" OnAmountChange="SetTotal" BranchID="@branchID" PartyInfo="@model.PartyInfo" Local="@Local" IsTaxable="@IsTaxable" ExpenseList="@model.Particulars" ReadOnly="@ReadOnly" />
                    </MudItem>
                    <MudItem xs="12">
                        <ItemsListView OnItemAdded="AddItems" OnAmountChange="SetTotal" BranchID="@branchID" PartyInfo="@model.PartyInfo" Local="@Local" IsTaxable="@IsTaxable" ItemList="@model.Items" ReadOnly="@ReadOnly" />
                    </MudItem>
                </MudGrid>
            </EditForm>
        </MudPaper>
    </FormContent>
    <VerificationStatus>
        <AutherizationStatusComponent CreatedBy="@model.UserInfo" DocTypeID="@SaleDocTypeID" DocDate="@DocDate" DocType="@DocType" DocNumber="@DocNumber" PageToRedirectLink="@PageToRedirectLink" DocumentID="model.SID" OnApprove="Approve"></AutherizationStatusComponent>
    </VerificationStatus>
</DialogForm>

@code {

    [Parameter]
    public SaleModel model { get; set; }
    [Parameter]
    public bool ReadOnly { get; set; } = false;
    private int? branchID = null;
    private string UserID = null;
    private bool Local;
    bool IsTaxable;
    private EditContext editContext;
    DialogForm dialogForm;
    [Parameter]
    public string PageToRedirectLink { get; set; }
    public string DocNumber { get; set; }
    public DateTime? DocDate { get; set; }
    public string DocType { get; set; }
    private bool _busy;


    public DocumentInfoModel DocumentDetails { get; set; } = new();


    public bool HasPermissionSaleServiceEdit { get; set; } = false;
    public bool HasPermissionSaleServiceApprove { get; set; } = false;
    public int SaleDocTypeID = 13;

    public GstUsageCodeModel gstusge = new();
    private GstModel taxModel = new GstModel();
    DialogOptions maxWidth = new DialogOptions() { MaxWidth = MaxWidth.Medium, FullWidth = true };

    // Lifecycle method called when the component is initialized
    protected override async Task OnInitializedAsync()
    {
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionSaleServiceEdit = await Irole.HasClaim(SaleDocTypeID.ToString(), "Edit", ctc.Token);
        HasPermissionSaleServiceApprove = await Irole.HasClaim(SaleDocTypeID.ToString(), "Approve", ctc.Token);

        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;
        branchID = int.Parse(user.Claims.First(x => x.Type == "BranchID").Value);
        UserID = user.Identity.Name;

        // If a Sale ID is provided, fetch associated data
        if (model?.SID != null)
        {
            model.PartyInfo = partyIservice.SelectByID(model.PartyInfo.PartyID); // Get party information
            var ResultParticulars = Iservice.GetParticulars(model.SID); // Get particulars
            if (ResultParticulars != null) 
            {
                model.Particulars = ResultParticulars.ToList();
            }
            var ResultItems = Iservice.GetItems(model.SID); // Get items
            if (ResultItems != null)
            {
                model.Items = ResultItems.ToList();
            }
        }
        else
        {
            model.NatureOfTransaction = "Sale";
            model.BranchID = branchID;
        }
        DocNumber = model.DocumentNumber;
        DocDate = model.DocumentDate;
        DocType = model.NatureOfTransaction;
    }

    // Lifecycle method called when parameters are set or changed
    protected override void OnParametersSet()
    {
        if (editContext == null)
        {
            editContext = new EditContext(model);
        }
        DocumentDetails.DocumentTypeID = SaleDocTypeID;
        DocumentDetails.DocumentID = model.SID;
        SetTotal();
    }

    // Method to calculate the total amount from particulars and items
    void SetTotal()
    {
        model.TotalAmount = (model.Particulars.Where(x => x != null).Sum(x => x.Amount + x.IGST + x.CGST + x.SGST) ?? 0) + (model.Items.Where(y => y != null).Sum(y => y.Amount + y.IGST + y.CGST + y.SGST) ?? 0);
    }

    // Method to handle changes in the selected party
    void PartyChanged(PartyModel party)
    {
        model.PartyInfo = party;
        if (party != null)
        {
            // Determine if the party is taxable and local
            IsTaxable = party.GstType == "Registered" || party.GstType == "UnRegistered";
            Local = partyIservice.IsLocal(model.PartyInfo.PartyID, branchID);
        }
        else { Local = false; }
    }

    // Method to add an expense to the particulars
    async Task AddExpense(TaxPurchaseExpenseModel expenseModel)
    {
        model.Particulars.Add(expenseModel);
        SetTotal();
    }

    // Method to add an item to the items list
    async Task AddItems(TaxPurchaseItemModel ItemModel)
    {
        model.Items.Add(ItemModel);
        SetTotal();
    }

    // Method to approve the sale
    protected async Task Approve(DataApprovedStatus aprvd)
    {
        if (HasPermissionSaleServiceApprove)
        {
            if (aprvd.IsApprove)
            {
                try
                {
                    // Approve the sale using the service
                    Iservice.Approve(model.SID, UserID, aprvd.Remarks);
                    snackbar.Add("Approved Successfully", Severity.Success);
                }
                catch (Exception ex)
                {
                    snackbar.Add(ex.Message, Severity.Error);
                }
            }
        }
        else
        {
            bool? result = await DialogService.ShowMessageBox(
                "Permission denied!",
                "You don't have any permission to Approve Sale.");
        }
    }

    // Method to handle form submission when the form is valid
    private async Task OnValidSubmit(EditContext context)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is being submitted!", Severity.Warning);
            return;
        }
        _busy = true;

        if (HasPermissionSaleServiceEdit)
        {
            try
            {
                model.SalesType = "Item";
                model.UserInfo.UserID = UserID;

                // Update the sale using the service
                Iservice.Update(model);
                snackbar.Add("Saved Successfully", Severity.Success);
                dialogForm.Close(model);
                model = new();
            }
            catch (Exception ex)
            {
                snackbar.Add(ex.Message, Severity.Error);
            }
        }
        else
        {
            bool? result = await DialogService.ShowMessageBox(
                "Permission denied!",
                "You don't have any permission to Edit Sale.");
        }
        await Task.Delay(200);
        _busy = false;
    }
}