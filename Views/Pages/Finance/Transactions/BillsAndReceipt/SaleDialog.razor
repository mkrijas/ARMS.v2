@using System.Threading;
@attribute [Authorize]
@inherits DialogFormComponentBase<SaleModel>

@inject ISaleService Iservice
@inject IPartyService partyIservice
@* 

@inject IInventoryItemService itemIservice
@inject IGstItemService gstitemIservice
@inject IInventoryGroupService inventoryGroupIservice
@inject IGstUsageIDService usageIservice
@inject IInventoryGrnService grnIservice
@inject IBranchService branchIservice
@inject MudBlazor.ISnackbar snackbar
@inject ITdsRateService tdsIService
@inject AuthenticationStateProvider auth
@inject IRoleService<RoleModel> Irole
@attribute [Authorize]
@inject IDialogService DialogService
@inject IJSRuntime JsRuntime *@

<DialogForm @ref="@dialogForm" ReadOnly="@ReadOnly" Title="Sale" Subtitle="Record outgoing sales transactions and update inventory/ledger records." Icon="@Icons.Material.Filled.PointOfSale" AdminStyle="true" formID="saleForm" DocumentDetails="@DocInfo" model="@_model" TotalAmount="model.TotalAmount" _busy="_busy">
    <FormContent>
        <div class="dialog-content-wrapper">
            <EditForm id="saleForm" Model="@model" OnValidSubmit="OnValidSubmit">
                <ObjectGraphDataAnnotationsValidator />
                <ValidationSummary />

                <div class="admin-glass-card pa-6 mb-6">
                    <div class="d-flex align-center mb-6">
                        <MudIcon Icon="@Icons.Material.Filled.Info" Color="Color.Primary" Class="mr-2" />
                        <span class="admin-section-label mb-0">General Information</span>
                    </div>
                    <MudGrid Spacing="3">
                        <MudItem xs="12" md="6">
                            <PartySelector Value="_model.PartyInfo" ValueChanged="PartyChanged" NatureOfBusiness="Customer" BranchID="@BranchID" IncludeSisterConcern Class="admin-input-group"></PartySelector>
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <MudDatePicker Label="Document Date" ReadOnly="ReadOnly" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.DocumentDate)" DisableToolbar="true" Editable="true" @bind-Date="model.DocumentDate" DateFormat="dd/MM/yyyy" MaxDate="DateTime.Now" Class="admin-input-group" />
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <MudTextField ReadOnly="ReadOnly" @bind-Value="_model.InvoiceNo" Label="Invoice No" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.InvoiceNo)" Class="admin-input-group"></MudTextField>
                        </MudItem>
                        <MudItem xs="12">
                            <MudTextField @bind-Value="_model.Narration" ReadOnly="ReadOnly" Lines="2" Label="Narration" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.Narration)" Class="admin-input-group"></MudTextField>
                        </MudItem>
                    </MudGrid>
                </div>

                <div class="admin-glass-card pa-0 overflow-hidden mb-6">
                    <div class="px-6 py-4 border-bottom-subtle d-flex align-center" style="background: rgba(255, 159, 67, 0.03); border-bottom: 1px solid rgba(255, 159, 67, 0.3);">
                        <MudIcon Icon="@Icons.Material.Filled.List" Color="Color.Warning" Class="mr-2" />
                        <span class="admin-section-label mb-0">Invoice Items / Details</span>
                    </div>
                    <MudTabs Elevation="0" Rounded="true" ApplyEffectsToContainer="true" PanelClass="pa-6" HeaderPosition="TabHeaderPosition.After" SliderColor="Color.Primary">
                        <MudTabPanel Text="Expenses / Particulars" Icon="@Icons.Material.Filled.ReceiptLong">
                            <ExpenseListView OnExpenseAdded="AddExpense" OnAmountChange="SetTotal" DocDate="@model.DocumentDate" BranchID="@BranchID" PartyInfo="@model.PartyInfo" Local="@Local" IsTaxable="@IsTaxable" ExpenseList="@model.Particulars" ReadOnly="@ReadOnly" />
                        </MudTabPanel>
                        <MudTabPanel Text="Inventory Items" Icon="@Icons.Material.Filled.Inventory2">
                            <ItemsListView OnItemAdded="AddItems" OnAmountChange="SetTotal" DocDate="@model.DocumentDate" BranchID="@BranchID" PartyInfo="@model.PartyInfo" Local="@Local" IsTaxable="@IsTaxable" ItemList="@model.Items" ReadOnly="@ReadOnly" EditMode="@(model.SID != null)" NonInventory=true />
                        </MudTabPanel>
                        <MudTabPanel Text="Billing Address" Icon="@Icons.Material.Filled.LocationOn">
                            <MudRadioGroup T="AddressModel" @bind-Value="selectedAddress">
                                <MudGrid Spacing="3">
                                    @foreach (var address in addresses)
                                    {
                                        <MudItem xs="12" md="6">
                                            <div class="pa-4 rounded-xl border-solid border-2 transition-all cursor-pointer @(selectedAddress == address ? "border-primary" : "border-transparent")" 
                                                 style="background: rgba(0,0,0,0.02);" @onclick="(() => selectedAddress = address)">
                                                <div class="d-flex align-center mb-2">
                                                    <MudRadio T="AddressModel" Value="address" Color="Color.Primary" />
                                                    <MudText Typo="Typo.subtitle1" Class="fw-bold">@address.AddresseeName</MudText>
                                                </div>
                                                <MudText Typo="Typo.body2" Class="mud-text-secondary ml-8">@address.Building, @address.Street</MudText>
                                                <MudText Typo="Typo.body2" Class="mud-text-secondary ml-8">@address.City, @address.Place</MudText>
                                                <MudText Typo="Typo.caption" Class="mud-text-secondary ml-8">Pincode: @address.PinCode</MudText>
                                            </div>
                                        </MudItem>
                                    }
                                </MudGrid>
                            </MudRadioGroup>
                        </MudTabPanel>
                    </MudTabs>
                </div>
            </EditForm>
        </div>
    </FormContent>
    <VerificationStatus>
        <AutherizationStatusComponent CreatedBy="@model.UserInfo" DocTypeID="@DocInfo.DocumentTypeID" DocDate="@DocDate" DocType="@DocInfo.DocumentName" DocNumber="@DocNumber" DocumentID="model.SID" OnApprove="Approve"></AutherizationStatusComponent>
    </VerificationStatus>
</DialogForm>

@code {
    [Parameter]
    public override SaleModel model {get;set;}
    private SaleModel _model { get { return model; } set { model = value; DocInfo.DocumentID = value.SID; } }

     protected override DocumentInfoModel DocInfo { get; set; } = new DocumentInfoModel()
        {
            DocumentTypeID = 13,
            DocumentName = "Sales"
        };

  //  [Parameter]
   // public SaleModel model { get; set; }
    // [Parameter]
    // public bool ReadOnly { get; set; } = false;
    // private int? branchID = null;
    // private string UserID = null;
    // private bool Local;
    // bool IsTaxable;
    // private EditContext editContext;
    // DialogForm dialogForm;
    // [Parameter]
    // public string PageToRedirectLink { get; set; }
    // public string DocNumber { get; set; }
    // public DateTime? DocDate { get; set; }
    // public string DocType { get; set; }
    // private bool _busy;
    private AddressModel selectedAddress;
    private List<AddressModel> addresses = new List<AddressModel>();

    // public DocumentInfoModel DocumentDetails { get; set; } = new();


    // public bool HasPermissionSaleServiceEdit { get; set; } = false;
    // public bool HasPermissionSaleServiceApprove { get; set; } = false;
    // public int SaleDocTypeID = 13;

    // public GstUsageCodeModel gstusge = new();
    // private GstModel taxModel = new GstModel();
    DialogOptions maxWidth = new DialogOptions() { MaxWidth = MaxWidth.Medium, FullWidth = true };

    // Lifecycle method called when the component is initialized
    protected override async Task OnInitializedAsync()
    {
         await base.OnInitializedAsync();   
        if (model?.SID != null)
        {
            addresses = partyIservice.GetAddress(model.PartyInfo.PartyID)?.ToList() ?? new List<AddressModel>();
            selectedAddress = addresses.FirstOrDefault(x => x.AddressID == model.AddressID);

            model.PartyInfo = partyIservice.SelectByID(model.PartyInfo.PartyID); // Get party information
            var ResultParticulars = Iservice.GetParticulars(model.SID); // Get particulars
            if (ResultParticulars != null)
            {
                model.Particulars = ResultParticulars.ToList();
            }
            var ResultItems = Iservice.GetItems(model.SID); // Get items
            if (ResultItems != null)
            {
                model.Items = ResultItems.ToList();
            }
        }
        else
        {
            if (model.NatureOfTransaction == null)
            {
                model.NatureOfTransaction = "Sale";
                model.TotalAmount = 0;
            }
        }
    }

    protected override async Task<int> Update(SaleModel editModel)
    {         
        // Call the service to update the model
         if (selectedAddress == null)
        {
            snackbar.Add("Please select billing address!", Severity.Warning);
            return 0;
        }

        model.SalesType = "Item";
        model.AddressID = selectedAddress.AddressID;
        model.UserInfo.UserID = UserID;

        var UpdatedModel = Iservice.Update(model);
        model.SID = UpdatedModel.SID;
        return model.SID.Value;
    }

    // Method to calculate the total amount from particulars and items
    void SetTotal()
    {
        model.TotalAmount = (model.Particulars.Where(x => x != null).Sum(x => x.Amount + x.IGST + x.CGST + x.SGST) ?? 0) + (model.Items.Where(y => y != null).Sum(y => y.Amount + y.IGST + y.CGST + y.SGST) ?? 0);
    }

    // Method to handle changes in the selected party
    void PartyChanged(PartyModel party)
    {
        model.PartyInfo = party;
        if (party != null)
        {
            addresses = partyIservice.GetAddress(model.PartyInfo.PartyID)?.ToList() ?? new List<AddressModel>();
            if (addresses.Count == 1)
            {
                selectedAddress = addresses[0];
            }

            // Determine if the party is taxable and local
            IsTaxable = party.GstType == "Registered" || party.GstType == "UnRegistered";
            Local = partyIservice.IsLocal(model.PartyInfo.PartyID, BranchID);
        }
        else { Local = false; }

        
    }

    // Method to add an expense to the particulars
    async Task AddExpense(TaxPurchaseExpenseModel expenseModel)
    {
        model.Particulars.Add(expenseModel);
        SetTotal();
    }

    // Method to add an item to the items list
    async Task AddItems(TaxPurchaseItemModel ItemModel)
    {
        model.Items.Add(ItemModel);
        SetTotal();
    }
    protected override int UpdateApproval(DataApprovedStatus aprvd)
    {
        // Call the service to approve the payment and return the result
        int result = Iservice.Approve(model.SID, model.UserInfo.UserID, aprvd.Remarks);
        return result;
    }   
}
