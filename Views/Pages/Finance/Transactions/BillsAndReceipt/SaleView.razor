@page "/Sale"
@inject ISaleService Iservice
@inject MudBlazor.ISnackbar snackbar

@inject AuthenticationStateProvider auth
@attribute [Authorize]
@inject IDialogService DialogService
@using Inventory



<MudGrid Spacing="4">
    <MudItem xs="12">
        <MudTable Items="@collection" Dense="true" Hover="true" Striped="true" Elevation="10" @bind-place="model">


            <ToolBarContent>
                <MudText Typo="Typo.h6">Sale</MudText>
                <MudTooltip Text="New Sales">
                    <MudIconButton Icon="@Icons.Material.Filled.Add" Title="Add" @onclick="@(()=> OpenDialog(model,false))" Color="Color.Dark" Size="Size.Small"></MudIconButton>
                </MudTooltip>

                <MudSpacer></MudSpacer>
                <MudCheckBox Label="Approved Entries" CheckedChanged="((bool value)=>ApprovedChanged(value))" Checked="@IsApproved" Size="Size.Medium" Color="Color.Primary"></MudCheckBox>

            </ToolBarContent>
            <HeaderContent>
                <MudTh><MudTableSortLabel SortBy="new Func<SaleModel, object>(x=> x.PartyInfo.TradeName)" InitialDirection="SortDirection.Ascending">TradeName</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<SaleModel, object>(x=> x.TotalAmount)" InitialDirection="SortDirection.Ascending">TotalAmount</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<SaleModel, object>(x=> x.DocumentDate)" InitialDirection="SortDirection.Ascending">DocumentDate</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<SaleModel, object>(x=> x.DocumentNumber)" InitialDirection="SortDirection.Ascending">DocumentNumber</MudTableSortLabel></MudTh>


                <MudTh>Actions</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="GrnNO">@context.PartyInfo.TradeName</MudTd>
                <MudTd DataLabel="EntryDate">@context.TotalAmount</MudTd>
                <MudTd DataLabel="EntryDate">@context.DocumentDate?.ToShortDateString()</MudTd>

                <MudTd DataLabel="GrnNO">@context.DocumentNumber</MudTd>

                <MudTd DataLabel="">

                    @if (@context.AuthLevelId == null)
                    {
                        <MudFab @onclick="@(()=> OpenDialog(context,false))" Color="Color.Primary" title="Edit" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" IconSize="Size.Small" />
                        <MudFab @onclick="@(()=> Delete(context))" Color="Color.Error" title="Delete" Icon="@Icons.Material.Filled.Delete" Size="Size.Small" IconSize="Size.Small" />

                    }
                    @if (@context.AuthLevelId != 99)
                    {
                        <MudFab @onclick="@(()=> OpenDialog(context,true))" Color="Color.Warning" Icon="@Icons.Material.Filled.Verified" title="Verify" Size="Size.Small" IconSize="Size.Small" />

                    }
                    <MudFab @onclick="@(()=> OpenDialog(context,true))" Color="Color.Info" Icon="@Icons.Material.Filled.GridView" title="View" Size="Size.Small" IconSize="Size.Small" />



                </MudTd>
            </RowTemplate>
            <PagerContent>
                <MudTablePager PageSizeOptions="new int[] { 5, 10, 20, 50, 100 }" />
            </PagerContent>
        </MudTable>
    </MudItem>
</MudGrid>


@code {

    private SaleModel model = new SaleModel();
    private List<SaleModel> collection = new List<SaleModel>();
    private string searchTax = "";
    public bool IsApproved { get; set; } = false;

    protected override void OnInitialized()
    {
        model = new();
        GetAll(IsApproved);
    }

    void ApprovedChanged(bool value)
    {

        IsApproved = value;
        GetAll(IsApproved);

    }
    private void GetAll(bool val)
    {

        if (val)
        {
            collection = Iservice.Select().Where(x => x.AuthLevelId == 99).ToList();

        }
        else
        {
            collection = Iservice.Select().Where(x => x.AuthLevelId != 99).ToList();

        }


    }
    private void Verified()
    {

        GetAll(IsApproved);

    }

    private async Task OpenDialog(SaleModel saleModel, bool ReadOnly)
    {

        DialogOptions maxWidth = new DialogOptions() { MaxWidth = MaxWidth.Medium, FullWidth = true };

        DialogParameters parms = new DialogParameters();
        parms.Add("model", saleModel);
        parms.Add("ReadOnly", ReadOnly);

        var dialog = DialogService.Show<SaleDialog>(saleModel.SID == null ? "ADD" : "EDIT", parms, maxWidth);
        var result = await dialog.Result;
        if (!result.Cancelled)
        {
            GetAll(IsApproved);
            //model = new();
        }




    }


    private async Task Delete(SaleModel tx)
    {
        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;
        Iservice.Delete(tx.SID, user.Identity.Name);
        snackbar.Add("Deleted Successfully", Severity.Success);
        GetAll(IsApproved);
    }


 }






