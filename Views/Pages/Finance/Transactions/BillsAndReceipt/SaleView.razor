@page "/Sale"
@page "/Sale/{id:int}"
@using System.Threading;
@inject ISaleService Iservice
@inject MudBlazor.ISnackbar snackbar
@inject AuthenticationStateProvider auth
@inject IRoleService<RoleModel> Irole
@attribute [Authorize]
@inject IDialogService DialogService
@inject SignalRService signalRService
@inject IPushNotificationService IpushNotificationService
@using Inventory

@if (_isLoading)
{
    <div @key="@("loader")" style="display: flex; justify-content: center; align-items: center; min-height: 400px;">
        <LoaderComponent IsFullScreen="true" 
                        ShowLogo="false" 
                        Size="medium" 
                        LoadingText="Loading Sales" 
                        SubText="Please wait..." />
    </div>
}
else
{
@if (_isLoading)
{
    <div @key="@("loader")" style="display: flex; justify-content: center; align-items: center; min-height: 400px;">
        <LoaderComponent IsFullScreen="true" 
                        ShowLogo="false" 
                        Size="medium" 
                        LoadingText="Loading Sales Matrix" 
                        SubText="Analyzing revenue streams..." />
    </div>
}
else
{
    <div class="fade-in">
        <div class="admin-header-tiered mb-6">
            <div class="d-flex align-center justify-space-between">
                <div>
                    <MudText Typo="Typo.h4" Class="admin-title">Sales & Distribution</MudText>
                    <MudText Typo="Typo.body2" Class="admin-subtitle">Master console for tracking commercial sales and distribution cycles. Monitor trade receivables, invoice compliance, and transactional verification workflows.</MudText>
                </div>
                <MudButton StartIcon="@Icons.Material.Filled.Add" Variant="Variant.Filled" Color="Color.Primary" Class="admin-register-btn" OnClick="@(()=> OpenDialog(new SaleModel(),false))" Disabled="@_busy">NEW SALES ENTRY</MudButton>
            </div>
        </div>

        <div class="admin-glass-card mb-6 pa-4">
            <div class="d-flex align-center gap-4 flex-wrap">
                <div style="flex-grow: 1; min-width: 300px;">
                    <MudTextField @bind-Value="searchTerm" Placeholder="Search by invoice #, party, or amount..." Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" Variant="Variant.Outlined" Margin="Margin.Dense" Class="admin-input-group" Clearable="true" OnKeyUp="HandleSearchKeyUp" />
                </div>
                <div class="d-flex align-center gap-4">
                    <div class="d-flex align-center bg-glass rounded-pill px-4 py-1">
                        <MudText Typo="Typo.caption" Class="fw-700 opa-50 uppercase mr-2">Limit</MudText>
                        <MudNumericField @bind-Value="@NumberOfRecords" Variant="Variant.Text" Margin="Margin.Dense" Style="width: 50px;" Class="fw-700 mt-0" HideSpinButtons="true" />
                    </div>
                    <div class="d-flex align-center bg-glass rounded-pill px-4 py-1">
                        <MudCheckBox T="bool" Label="Approved Only" ValueChanged="((bool value)=>ApprovedChanged(value))" Value="@IsApproved" Size="Size.Small" Color="Color.Primary" Class="fw-600" />
                    </div>
                </div>
            </div>
        </div>

        <div class="admin-glass-card pa-0 overflow-hidden shadow-sm">
            <MudTable Items="@collection" Elevation="0" Class="modern-admin-table" Hover="true">
                <HeaderContent>
                    <MudTh><MudTableSortLabel SortBy="new Func<SaleModel, object>(x=> x.DocumentDate)"><span class="admin-header-text">DATE</span></MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<SaleModel, object>(x=> x.InvoiceNo)"><span class="admin-header-text">INVOICE</span></MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<SaleModel, object>(x=> x.PartyInfo.TradeName)"><span class="admin-header-text">PARTY / CUSTOMER</span></MudTableSortLabel></MudTh>
                    <MudTh Style="text-align: right;"><MudTableSortLabel SortBy="new Func<SaleModel, object>(x=> x.TotalAmount)"><span class="admin-header-text">TOTAL AMOUNT</span></MudTableSortLabel></MudTh>
                    <MudTh Style="text-align: right;"><span class="admin-header-text">ACTIONS</span></MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Date">
                        <div class="d-flex flex-column">
                            <span class="fw-700 admin-td-primary">@context.DocumentDate?.ToString("dd MMM yyyy")</span>
                            <span class="tiny opa-50">#@context.DocumentNumber</span>
                        </div>
                    </MudTd>
                    <MudTd DataLabel="Invoice">
                        <div class="d-flex align-center gap-2">
                            <MudIcon Icon="@Icons.Material.Filled.Receipt" Size="Size.Small" Class="opa-30" />
                            <span class="fw-700">@context.InvoiceNo</span>
                        </div>
                    </MudTd>
                    <MudTd DataLabel="Party">
                        <div class="d-flex align-center gap-2">
                             <div class="admin-icon-square-vibrant tiny accent-indigo">
                                <MudIcon Icon="@Icons.Material.Filled.Person" Size="Size.Small" />
                            </div>
                            <span class="fw-600">@context.PartyInfo.TradeName</span>
                        </div>
                    </MudTd>
                    <MudTd DataLabel="Amount" Style="text-align: right;">
                        <span class="fw-800 text-vibrant" style="font-size: 1.1rem;">@context.TotalAmount?.ToString("N2")</span>
                    </MudTd>
                    <MudTd DataLabel="Actions" Style="text-align: right;">
                        <div class="d-flex justify-end gap-1">
                            @if (context.AuthLevelId == 100)
                            {
                                <MudChip T="string" Color="Color.Error" Size="Size.Small" Variant="Variant.Text" Class="fw-900 tiny uppercase mr-2">REJECTED</MudChip>
                            }

                            @if (@context.AuthLevelId == 99)
                            {
                                <EntryReversedComponent DocTypeID="SaleDocTypeID" DocumentID="context.SID" MID="context.MID" DocumentNumber="@context.DocumentNumber"></EntryReversedComponent>
                                <MudTooltip Text="Print Invoice">
                                    <MudIconButton OnClick="@(()=> PrintInvoice(context.SID))" Color="Color.Tertiary" Icon="@Icons.Material.Filled.Print" Size="Size.Small" Variant="Variant.Text" />
                                </MudTooltip>
                            }
                            else if (@context.AuthLevelId != 100)
                            {
                                <MudTooltip Text="Verify Sale">
                                    <MudIconButton OnClick="@(()=> OpenDialog(context,true))" Color="Color.Warning" Icon="@Icons.Material.Filled.Verified" Size="Size.Small" Variant="Variant.Text" />
                                </MudTooltip>
                            }

                            <MudTooltip Text="Inspect Details">
                                <MudIconButton OnClick="@(()=> OpenDialog(context,true))" Color="Color.Info" Icon="@Icons.Material.Filled.Visibility" Size="Size.Small" Variant="Variant.Text" />
                            </MudTooltip>
                            
                            <MudTooltip Text="Modify Entry">
                                <MudIconButton Disabled="@(context.AuthLevelId != null)" OnClick="@(()=> OpenDialog(context,false))" Color="Color.Primary" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Variant="Variant.Text" />
                            </MudTooltip>

                            <MudTooltip Text="Delete Record">
                                <MudIconButton Disabled="@(context.AuthLevelId != null)" OnClick="@(()=> Delete(context))" Color="Color.Error" Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Variant="Variant.Text" />
                            </MudTooltip>
                        </div>
                    </MudTd>
                </RowTemplate>
                <PagerContent>
                    <div class="pa-4">
                        <MudTablePager PageSizeOptions="new int[] { 10, 20, 50, 100 }" />
                    </div>
                </PagerContent>
            </MudTable>
        </div>
    </div>
}

}

@code {

    private bool _isLoading = true;
    private DateTime _loadStartTime;

    private SaleModel model = new SaleModel();
    private List<SaleModel> collection = new List<SaleModel>();
    public bool IsApproved { get; set; } = false;
    private int numberOfRecords = 100;
    private string searchTerm = "";

    [Parameter]
    public int? id { get; set; } = null;
    private int? branchID = null;
    private bool _busy;

    public bool HasPermissionSaleServiceDelete { get; set; } = false;
    public int SaleDocTypeID = 13;

    #region SignaIR Notification

    private PushNotificationModel notificationMessage = new PushNotificationModel();
    #endregion

    private async Task HandleSearchKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await ReloadTable();
        }
    }

    // Lifecycle method called when the component is initialized
    protected override async Task OnInitializedAsync()
    {
        _loadStartTime = DateTime.Now;
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionSaleServiceDelete = await Irole.HasClaim(SaleDocTypeID.ToString(), "Delete", ctc.Token);
        model = new();
        var authprov = await auth.GetAuthenticationStateAsync();
        branchID = int.Parse(authprov.User.Claims.First(x => x.Type == "BranchID").Value);
        await GetAll(IsApproved, NumberOfRecords);
        await Task.Delay(200);
        await signalRService.StartAsync();
        if (id != null && collection != null && collection.Any(g => g.SID == id))
        {
            await OpenDialog(collection.FirstOrDefault(s => s.SID == id), true);
        }
        await EnsureMinimumLoadTime();
        _isLoading = false;
    }

    private async Task EnsureMinimumLoadTime()
    {
        var elapsed = (DateTime.Now - _loadStartTime).TotalMilliseconds;
        if (elapsed < 100)
        {
            await Task.Delay(100 - (int)elapsed);
        }
    }

    // Method to handle changes in the approval status
    async Task ApprovedChanged(bool value)
    {
        IsApproved = value;
        await GetAll(IsApproved, NumberOfRecords);
    }

    // Method to retrieve all sales based on approval status and number of records
    private async Task GetAll(bool val, int numberOfRecords)
    {
        var authprov = await auth.GetAuthenticationStateAsync();
        var brancIDString = authprov.User.Claims.First(x => x.Type == "BranchID").Value;
        int brancID = int.Parse(brancIDString);
        int NumberOfRecords = numberOfRecords;
        collection = new List<SaleModel>();

        // Load sales based on approval status
        if (val)
        {
            collection = Iservice.SelectByApproved(branchID, NumberOfRecords, searchTerm, "Sale").ToList();
        }
        else
        {
            collection = Iservice.SelectByUnapproved(branchID, NumberOfRecords, searchTerm, "Sale").ToList();
        }
    }

    // Method to reload the sales table
    private async Task ReloadTable()
    {
        await GetAll(IsApproved, NumberOfRecords);
    }

    private int NumberOfRecords
    {
        get => numberOfRecords;
        set
        {
            if (numberOfRecords != value)
            {
                numberOfRecords = value;
                _ = ReloadTable();
            }
        }
    }

    // Method to refresh the sales data
    private async Task Verified()
    {
        await GetAll(IsApproved, NumberOfRecords);
    }

    // Method to open the sale dialog for adding or editing a sale
    private async Task OpenDialog(SaleModel saleModel, bool ReadOnly)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        _busy = true;
        DialogOptions maxWidth = new DialogOptions() { MaxWidth = MaxWidth.Large, FullWidth = true };
        DialogParameters parms = new DialogParameters();
        parms.Add("model", saleModel.Clone());
        parms.Add("PageToRedirectLink", "/Sale");
        parms.Add("ReadOnly", ReadOnly);
        var dialog = await DialogService.ShowAsync<SaleDialog>(saleModel.SID == null ? "ADD" : "EDIT", parms, maxWidth);
        var result = await dialog.Result;
        var isCancelled = result.Canceled;
        if (!isCancelled)
        {
            var ReturnData = (SaleModel)result.Data;
            notificationMessage.InitiateBranch = new BranchModel() { BranchID = ReturnData.BranchID };
            notificationMessage.ReceivedBranch = new BranchModel() { BranchID = ReturnData.BranchID };
            notificationMessage.MessageTitle = IpushNotificationService.GetMessageTitle(ReturnData.NatureOfTransaction, ReturnData.DocumentNumber, "Level 1 Verification");
            notificationMessage.MessageBody = IpushNotificationService.GetMessageBody(ReturnData.NatureOfTransaction, ReturnData.DocumentNumber, "Level 1 Verification", ReturnData.DocumentDate);
            notificationMessage.RedirectedTo = 0;
            notificationMessage.ExpiredBy = 7;
            notificationMessage.DocumentID = ReturnData.SID;
            notificationMessage.MessageGroupID = "PendingVerification";
            notificationMessage.PageToRedirectLink = "/Sale";
            notificationMessage.ClaimValue = "Verify 1";
            notificationMessage.DocumentTypeID = SaleDocTypeID;
            notificationMessage.MsgDate = DateTime.Now;
            await signalRService.Send(notificationMessage);
        }
        await GetAll(IsApproved, NumberOfRecords);
        await Task.Delay(200);
        _busy = false;
    }

    // Method to delete a sale
    private async Task Delete(SaleModel model)
    {
        if (HasPermissionSaleServiceDelete)
        {
            bool? result = await DialogService.ShowMessageBoxAsync(
                "Warning !",
                "Are you sure, you want to delete - " + model.PartyInfo.TradeName + " (" + model.DocumentNumber + ") ?");
            if (result == true)
            {
                var authprov = await auth.GetAuthenticationStateAsync();
                var user = authprov.User;

                // Call the service to delete the sale
                Iservice.Delete(model.SID, user.Identity.Name);
                snackbar.Add("Deleted Successfully", Severity.Success);
                await GetAll(IsApproved, NumberOfRecords);
            }
        }
        else
        {
            bool? result = await DialogService.ShowMessageBoxAsync(
                "Permission denied!",
                "You don't have any permission to Delete Sale.");
        }
    }

    public Dictionary<string, string> ReportParameters { get; set; } = new();

    // Method to print the sales invoice
    private async Task PrintInvoice(int? SID)
    {
        ReportParameters.Clear();
        ReportParameters.Add("SID", SID.ToString());
        var parameters = new DialogParameters();
        parameters.Add("Parameters", ReportParameters); // Add the dictionary as a parameter
        parameters.Add("ReportName", "PrintSalesInvoice");

        DialogOptions maxWidth = new DialogOptions() { MaxWidth = MaxWidth.Medium, FullWidth = true };
        var result = await DialogService.ShowAsync<PrintDialog>("PRINT", parameters, maxWidth);
    }
}
