@page "/Sale"
@page "/Sale/{id:int}"
@inherits ViewComponentBase<SaleModel>
@inject ISaleService Iservice
@inject SignalRService signalRService
@inject IDialogService DialogService
@using Inventory
@using System.Threading


    <div class="fade-in">
        <div class="admin-header-tiered mb-6">
            <div class="d-flex align-center justify-space-between">
                <div>
                    <MudText Typo="Typo.h4" Class="admin-title">Sales & Distribution</MudText>
                    <MudText Typo="Typo.body2" Class="admin-subtitle">Master console for tracking commercial sales and distribution cycles. Monitor trade receivables, invoice compliance, and transactional verification workflows.</MudText>
                </div>
                <MudButton StartIcon="@Icons.Material.Filled.Add" Variant="Variant.Filled" Color="Color.Primary" Class="admin-register-btn" OnClick="@(()=> OpenForm(new SaleModel(),false))" Disabled="@_busy">NEW SALES ENTRY</MudButton>
            </div>
        </div>

        <div class="admin-glass-card mb-6 pa-4">
            <div class="d-flex align-center gap-4 flex-wrap">
                <div style="flex-grow: 1; min-width: 300px;">
                    <MudTextField @bind-Value="searchTerm" Placeholder="Search by invoice #, party, or amount..." Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" Variant="Variant.Outlined" Margin="Margin.Dense" Class="admin-input-group" Clearable="true" OnKeyUp="HandleSearchKeyUp" />
                </div>
                <div class="d-flex align-center gap-4">                   
                    <div class="d-flex align-center bg-glass rounded-pill px-4 py-1">
                        <MudCheckBox T="bool" Label="Approved Only" ValueChanged="((bool value)=>ToggleData(value))" Value="@ShowApproved" Size="Size.Small" Color="Color.Primary" Class="fw-600" />
                    </div>
                </div>
            </div>
        </div>

        <div class="admin-glass-card pa-0 overflow-hidden shadow-sm">
                <MudTable ServerData="LoadServerData" T="SaleModel" @ref="_table" Elevation="0" Class="modern-admin-table" Hover="true">
            <LoadingContent>
                <div @key="@("loader")" style="display: flex; justify-content: center; align-items: center; min-height: 400px;">
                    <LoaderComponent IsFullScreen="false"
                                     ShowLogo="false"
                                     Size="large"
                                     LoadingText="Loading...."
                                     SubText="Fetching Data..." />
                </div>
            </LoadingContent>
                <HeaderContent>
                    <MudTh><MudTableSortLabel SortBy="new Func<SaleModel, object>(x=> x.DocumentDate)"><span class="admin-header-text">DATE</span></MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<SaleModel, object>(x=> x.InvoiceNo)"><span class="admin-header-text">INVOICE</span></MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<SaleModel, object>(x=> x.PartyInfo.TradeName)"><span class="admin-header-text">PARTY / CUSTOMER</span></MudTableSortLabel></MudTh>
                    <MudTh Style="text-align: right;"><MudTableSortLabel SortBy="new Func<SaleModel, object>(x=> x.TotalAmount)"><span class="admin-header-text">TOTAL AMOUNT</span></MudTableSortLabel></MudTh>
                    <MudTh Style="text-align: right;"><span class="admin-header-text">ACTIONS</span></MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Date">
                        <div class="d-flex flex-column">
                            <span class="fw-700 admin-td-primary">@context.DocumentDate?.ToString("dd MMM yyyy")</span>
                            <span class="tiny opa-50">#@context.DocumentNumber</span>
                        </div>
                    </MudTd>
                    <MudTd DataLabel="Invoice">
                        <div class="d-flex align-center gap-2">
                            <MudIcon Icon="@Icons.Material.Filled.Receipt" Size="Size.Small" Class="opa-30" />
                            <span class="fw-700">@context.InvoiceNo</span>
                        </div>
                    </MudTd>
                    <MudTd DataLabel="Party">
                        <div class="d-flex align-center gap-2">
                             <div class="admin-icon-square-vibrant tiny accent-indigo">
                                <MudIcon Icon="@Icons.Material.Filled.Person" Size="Size.Small" />
                            </div>
                            <span class="fw-600">@context.PartyInfo.TradeName</span>
                        </div>
                    </MudTd>
                    <MudTd DataLabel="Amount" Style="text-align: right;">
                        <span class="fw-800 text-vibrant" style="font-size: 1.1rem;">@context.TotalAmount?.ToString("N2")</span>
                    </MudTd>
                    <MudTd DataLabel="Actions" Style="text-align: right;">
                        <div class="d-flex justify-end gap-1">
                            @if (context.AuthLevelId == 100)
                            {
                                <MudChip T="string" Color="Color.Error" Size="Size.Small" Variant="Variant.Text" Class="fw-900 tiny uppercase mr-2">REJECTED</MudChip>
                            }

                            @if (@context.AuthLevelId == 99)
                            {
                                    <EntryReversedComponent DocTypeID="@DocInfo.DocumentTypeID" DocumentID="context.SID" MID="context.MID" DocumentNumber="@context.DocumentNumber"></EntryReversedComponent>
                                <MudTooltip Text="Print Invoice">
                                    <MudIconButton OnClick="@(()=> PrintInvoice(context.SID))" Color="Color.Tertiary" Icon="@Icons.Material.Filled.Print" Size="Size.Small" Variant="Variant.Text" />
                                </MudTooltip>
                            }
                            else if (@context.AuthLevelId != 100)
                            {
                                <MudTooltip Text="Verify Sale">
                                    <MudIconButton OnClick="@(()=> OpenForm(context,true))" Color="Color.Warning" Icon="@Icons.Material.Filled.Verified" Size="Size.Small" Variant="Variant.Text" />
                                </MudTooltip>
                            }

                            <MudTooltip Text="Inspect Details">
                                    <MudIconButton OnClick="@(() => OpenForm(context, true))" Color="Color.Info" Icon="@Icons.Material.Filled.Visibility" Size="Size.Small" Variant="Variant.Text" />
                            </MudTooltip>
                            
                            <MudTooltip Text="Modify Entry">
                                    <MudIconButton Disabled="@(context.AuthLevelId != null)" OnClick="@(() => OpenForm(context, false))" Color="Color.Primary" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Variant="Variant.Text" />
                            </MudTooltip>

                            <MudTooltip Text="Delete Record">
                                <MudIconButton Disabled="@(context.AuthLevelId != null)" OnClick="@(()=> Delete(context.SID))" Color="Color.Error" Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Variant="Variant.Text" />
                            </MudTooltip>
                        </div>
                    </MudTd>
                </RowTemplate>
                <PagerContent>
                    <div class="pa-4">
                        <MudTablePager PageSizeOptions="new int[] { 10, 20, 50, 100 }" />
                    </div>
                </PagerContent>
            </MudTable>
        </div>
    </div>

@code { 

    protected override List<SaleModel> _collection { get; set; } = new List<SaleModel>();

    //private SaleModel model = new SaleModel();
    
    
    protected override DocumentInfoModel DocInfo { get; set; } = new DocumentInfoModel()
    {
        DocumentTypeID = 13,
        DocumentName = "Sale"
    };

    // Lifecycle method called when the component is initialized
    protected override async Task OnInitializedAsync()
    {        
        await base.OnInitializedAsync();        
        if (id != null && _collection != null && _collection.Any(g => g.SID == id))
        {
            await OpenForm(_collection.FirstOrDefault(s => s.SID == id), true);
        }       
        _isLoading = false;
    }   
     

    protected override async Task OpenForm(SaleModel _model, bool ReadOnly, bool DisableAddition = false)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        _busy = true;
        DialogParameters parms = new DialogParameters();
        parms.Add("model", _model.Clone());
        parms.Add("ReadOnly", ReadOnly);
        parms.Add("OnApproved", new EventCallbackFactory().Create(this, async () => await _table.ReloadServerData()));
        var dialog = await dialogService.ShowAsync<SaleDialog>(_model.SID == null ? "ADD" : "EDIT", parms, new DialogOptions() { MaxWidth = MaxWidth.Large, FullWidth = true });
        var result = await dialog.Result;
        if (!result.Canceled)
        {
            var ReturnData = (SaleModel)result.Data;
            await _table.ReloadServerData();
        }
        await Task.Delay(200);
        _busy = false;
    }  

    public Dictionary<string, string> ReportParameters { get; set; } = new();
    //Method to print the sales invoice
    private async Task PrintInvoice(int? SID)
    {

        ReportParameters.Clear();
        ReportParameters.Add("SID", SID.ToString());
        var parameters = new DialogParameters();
        parameters.Add("Parameters", ReportParameters); // Add the dictionary as a parameter
        parameters.Add("ReportName", "PrintSalesInvoice");

        DialogOptions maxWidth = new DialogOptions() { MaxWidth = MaxWidth.Medium, FullWidth = true };
        var result = await DialogService.ShowAsync<PrintDialog>("PRINT", parameters, maxWidth);
    }
}
