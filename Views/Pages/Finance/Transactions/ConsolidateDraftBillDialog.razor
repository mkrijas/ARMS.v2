@inject IFreightBillingService Iservice
@inject IOrderService orderIservice
@inject ITariffService tariffIservice
@inject MudBlazor.ISnackbar snackbar
@inject AuthenticationStateProvider auth
@attribute [Authorize]
@inject IDialogService DialogService


<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.Build" Class="mr-3 mb-n1" />
            Create Consolidate Draft Bill
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudContainer Style=" max-height: 450px; overflow-y: scroll">
            <EditForm id="formtdsRate" Model="@model" OnValidSubmit="OnValidSubmit">
                <ObjectGraphDataAnnotationsValidator />
                <ValidationSummary />
                <MudGrid Spacing="2">
                    <MudItem xs="12" md="4">
                        <MudSelect ReadOnly="true" Label="Order" @bind-Value="model.Order" T="OrderModel" Variant="Variant.Outlined" Margin="Margin.Dense" OffsetY="true" Direction="Direction.Top" AdornmentColor="Color.Secondary">
                            @foreach (var ditem in orders)
                            {
                                <MudSelectItem Value="@ditem">@ditem.OrderName</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12" md="4">
               <MudSelect ReadOnly="true" Label="Select Tariff" @bind-Value="model.TariffType" T="TariffTypeModel" ToStringFunc="@((p) => p?.TariffTypeName)"  Variant="Variant.Outlined" Margin="Margin.Dense" OffsetY="true" Direction="Direction.Top" AdornmentColor="Color.Secondary" >
                            @foreach (var item in tariftypes)
                            {
                                <MudSelectItem Value="@item">@item.TariffTypeName</MudSelectItem>
                            }
                        </MudSelect>
                 </MudItem>
                    <MudItem xs="12" md="4">

                        <MudDatePicker Label="DocumentDate" Variant="Variant.Outlined" Margin="Margin.Dense" DisableToolbar="true" Editable="true" @bind-Date="model.DocumentDate" DateFormat="dd/MM/yyyy" />


                    </MudItem>

                     <MudItem xs="12">
       
        <MudTable Items="@collection"   Dense="true" Hover="true"  Striped="true" Elevation="10"  @bind-place="gctariffmodel">
           

            
            <HeaderContent>
                <MudTh><MudTableSortLabel SortBy="new Func<GcTariffModel, object>(x=> x.BillNumber)" InitialDirection="SortDirection.Ascending">BillNumber</MudTableSortLabel></MudTh>
             <MudTh><MudTableSortLabel SortBy="new Func<GcTariffModel, object>(x=> x.BillDate)" InitialDirection="SortDirection.Ascending">BillDate</MudTableSortLabel></MudTh>
               <MudTh><MudTableSortLabel SortBy="new Func<GcTariffModel, object>(x=> x.InvoiceDate)" InitialDirection="SortDirection.Ascending">InvoiceDate</MudTableSortLabel></MudTh>
               <MudTh><MudTableSortLabel SortBy="new Func<GcTariffModel, object>(x=> x.ConsigneeName)" InitialDirection="SortDirection.Ascending">ConsigneeName</MudTableSortLabel></MudTh>
               <MudTh><MudTableSortLabel SortBy="new Func<GcTariffModel, object>(x=> x.BillQuantity)" InitialDirection="SortDirection.Ascending">BillQuantity</MudTableSortLabel></MudTh>
                  <MudTh><MudTableSortLabel SortBy="new Func<GcTariffModel, object>(x=> x.Amount)" InitialDirection="SortDirection.Ascending">Freight</MudTableSortLabel></MudTh>
              
                
              
            </HeaderContent>
            <RowTemplate Context="cntxt">
                <MudTd DataLabel="BillNumber">@cntxt.BillNumber</MudTd>
                <MudTd DataLabel="BillDate">@cntxt.BillDate?.ToShortDateString()</MudTd>
                <MudTd DataLabel="InvoiceDate">@cntxt.InvoiceDate?.ToShortDateString()</MudTd>
                  <MudTd DataLabel="ConsigneeName">@cntxt.ConsigneeName</MudTd>
                    <MudTd DataLabel="BillQuantity">@cntxt.BillQuantity</MudTd>
                      <MudTd DataLabel="Amount">@cntxt.Amount</MudTd>
                
                 
           
            </RowTemplate>
            <PagerContent>
                <MudTablePager PageSizeOptions="new int[] { 5, 10, 20, 50, 100 }" />
         
            </PagerContent>
        </MudTable>
         
    </MudItem>



                    <MudItem xs="12" md="12">

                        <MudTextField @bind-Value="model.Narration" Lines="3" Label="Narration" Variant="Variant.Outlined" Margin="Margin.Dense"></MudTextField>


                    </MudItem>

                </MudGrid>
            </EditForm>
        </MudContainer>
    </DialogContent>
    <DialogActions>

        <MudButton form="formtdsRate" Variant="Variant.Filled" Color="Color.Success" ButtonType="ButtonType.Submit">Create Consolidate Draft Bill</MudButton>

    </DialogActions>
</MudDialog>

@code {

    [Parameter]
    public ConsolidatedDraftBillModel model { get; set; }
    private GcTariffModel gctariffmodel = new GcTariffModel();
    private List<GcTariffModel> collection = new List<GcTariffModel>();
    [CascadingParameter] MudDialogInstance MudDialog { get; set; }
    private List<OrderModel> orders = new();
    private List<TariffTypeModel> tariftypes = new();
    protected override async Task OnInitializedAsync()
    {
        orders = await orderIservice.Select(0).ToListAsync();
        tariftypes = tariffIservice.SelectTariffTypes("All").ToList();
        collection = model.BookedGCs.ToList();
    }
    private async Task OnValidSubmit(EditContext context)
    {
        MudDialog.Close(model);


    }
}
