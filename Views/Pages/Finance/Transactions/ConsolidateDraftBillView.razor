@page "/ProformaInvoiceDialog"
@inject IFreightBillingService Iservice
@inject IDimensionService dimensionIservice
@inject ICostCenterService costIservice
@inject NavigationManager uriHelper;
@inject MudBlazor.ISnackbar snackbar
@inject AuthenticationStateProvider auth
@attribute [Authorize]
@inject IDialogService DialogService

<style>
    .selected {
        background-color: #1E88E5 !important;
    }

        .selected > td {
            color: white !important;
        }

            .selected > td .mud-input {
                color: white !important;
            }
</style>

<h3>Consolidate Draft Bill</h3>




<MudGrid Spacing="4">
    <MudItem xs="12">

        <MudTable Items="@collection" Dense="true" Hover="true" Striped="true" Elevation="10" @bind-place="model" T="ConsolidatedDraftBillModel">


            <HeaderContent>
                <MudTh><MudTableSortLabel SortBy="new Func<ConsolidatedDraftBillModel, object>(x=> x.DocumentDate)" InitialDirection="SortDirection.Ascending">DocumentDate</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<ConsolidatedDraftBillModel, object>(x=> x.DocumentNumber)" InitialDirection="SortDirection.Ascending">DocumentNumber</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<ConsolidatedDraftBillModel, object>(x=> x.TotalAmount)" InitialDirection="SortDirection.Ascending">TotalAmount</MudTableSortLabel></MudTh>
                <MudTh>Actions</MudTh>


            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="DocumentDate">@context.DocumentDate</MudTd>
                <MudTd DataLabel="DocumentNumber">@context.DocumentNumber</MudTd>
                <MudTd DataLabel="TotalAmount">@context.TotalAmount</MudTd>
                <MudTd DataLabel="">
                    <MudFab @onclick="@(()=> OpenDialogView(context))" Color="Color.Info" Icon="@Icons.Material.Filled.GridView" title="View" Size="Size.Small" IconSize="Size.Small" />

                    <MudTooltip Text="Create Proforma Invoice">
                        <MudFab @onclick="@(()=> OpenDialogproformainvoice(context))" Color="Color.Success" Icon="@Icons.Material.Filled.CreditCard" Size="Size.Small" IconSize="Size.Small" />
                    </MudTooltip>

                </MudTd>



            </RowTemplate>
            <PagerContent>
                <MudTablePager PageSizeOptions="new int[] { 5, 10, 20, 50, 100 }" />

            </PagerContent>
        </MudTable>
    </MudItem>

</MudGrid>
<br />
<br />



@code {

    private ConsolidatedDraftBillModel model = new ConsolidatedDraftBillModel();
    private List<ConsolidatedDraftBillModel> collection = new List<ConsolidatedDraftBillModel>();
    private int? branchID = null;
    private string UserID = null;

    DialogOptions maxWidth = new DialogOptions() { MaxWidth = MaxWidth.Medium, FullWidth = true };

    private async Task OpenDialogView(ConsolidatedDraftBillModel tds)
    {

        DialogParameters parms = new DialogParameters();
        parms.Add("model", tds);
        parms.Add("IsReadOnly", true);
        parms.Add("IsView", true);
        var dialog = DialogService.Show<ConsolidateDraftBillDialog>(tds.DraftBillID == null ? "ADD" : "EDIT", parms, maxWidth);
        var result = await dialog.Result;

        if (!result.Canceled)
        {

            GetConsolidatedDraftBill();


        }
    }




    protected override async Task OnInitializedAsync()
    {
        var authprov = await auth.GetAuthenticationStateAsync();
        branchID = int.Parse(authprov.User.Claims.First(x => x.Type == "BranchID").Value);
        var user = authprov.User;
        UserID = user.Identity.Name;
        GetConsolidatedDraftBill();
    }


    public void GetConsolidatedDraftBill()
    {


        collection = Iservice.SelectPendingConsolidatedDraftBillList(0, branchID).ToList();


    }

    public async Task OpenDialogproformainvoice(ConsolidatedDraftBillModel cdm)
    {

        ProformaInvoiceModel pfm = new ProformaInvoiceModel();
        pfm.BranchID = branchID;
        pfm.TotalAmount = cdm.TotalAmount;
        pfm.DraftBillID = cdm.DraftBillID;
        pfm.OrderID = cdm.Order.OrderID;
        pfm.TariffType = cdm.TariffType;
        pfm.Gst = Iservice.GetGstRate(pfm.DraftBillID);

        pfm.UserInfo.UserID = UserID;
        DialogParameters parms = new DialogParameters();
        parms.Add("model", pfm);
        parms.Add("IsReadOnly", false);
        parms.Add("IsView", false);
        var dialog = DialogService.Show<ProformaInvoceDialog>("ProformaInvoce", parms, maxWidth);
        var result = await dialog.Result;

        if (!result.Canceled)
        {
            ProformaInvoiceModel UpatedModel = (ProformaInvoiceModel)result.Data;

            Iservice.UpdateProformaInvoice(UpatedModel);
            snackbar.Add("Saved Successfully ", Severity.Success);//value = "visible";
        }
        GetConsolidatedDraftBill();

    }

}
