@using System.Threading;
@inject IContraService Iservice
@inject MudBlazor.ISnackbar snackbar
@inject AuthenticationStateProvider auth
@inject IDialogService DialogService

@inject IRoleService<RoleModel> Irole
@attribute [Authorize]

<DialogForm @ref="@dialogForm" ReadOnly="@ReadOnly" Title="Contra Entry" formID="cotraForm" model="@model">
    <FormContent>
        <MudPaper Class="p-3">
            <EditForm id="cotraForm" OnValidSubmit="OnValidSubmit" Model="model">
                <ObjectGraphDataAnnotationsValidator />
                <ValidationSummary />
                <MudGrid>
                    <MudItem xs="12" md="4">
                        <MudDatePicker Label="DocumentDate" ReadOnly="ReadOnly" Variant="Variant.Outlined" Margin="Margin.Dense" DisableToolbar="true" Editable="true" @bind-Date="model.DocumentDate" DateFormat="dd/MM/yyyy" />
                    </MudItem>
                    <MudItem xs="12" md="4">
                        <MudTextField ReadOnly="ReadOnly" @bind-Value="model.EntryReference" Label="Reference" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.EntryReference)"></MudTextField>
                    </MudItem>
                    <MudItem xs="12" md="4">
                        <MudTextField ReadOnly="ReadOnly" @bind-Value="model.TotalAmount" Label="Amount" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.TotalAmount)"></MudTextField>
                    </MudItem>
                    <MudItem xs="12" md="12">
                        <strong>Debit/Deposit A/c</strong>
                        <PaymentAccountSelector @bind-PaymentMode="@model.ContraModeHome"
                                                @bind-ArdCode="@model.ArdCodeHome" @bind-CoaID="@model.CoaIDHome"
                                                @bind-BankCharges="@model.BankCharges" HideBankCharges @bind-BankTool="@model.PaymentTool" />
                    </MudItem>
                    <MudItem xs="12" md="12">
                        <strong>Credit/Draw A/c</strong>
                        <PaymentAccountSelector @bind-PaymentMode="@model.ContraModeOther"
                        @bind-ArdCode="@model.ArdCodeOther" @bind-CoaID="@model.CoaIDOther"
                        @bind-BankCharges="@model.BankCharges" HideBankCharges @bind-BankTool="@model.PaymentTool" />
                    </MudItem>

                    @if (model.PaymentTool == "CHEQUE")
                    {
                        <MudItem xs="12" md="6">
                            <MudTextField ReadOnly="ReadOnly" @bind-Value="model.ChequeInfo.ChequeNumber" Label="ChequeNumber" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.ChequeInfo.ChequeNumber)"></MudTextField>
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <MudDatePicker ReadOnly="ReadOnly" Label="ChequeDate" Variant="Variant.Outlined" Margin="Margin.Dense" DisableToolbar="true" Editable="true" @bind-Date="model.ChequeInfo.ChequeDate" DateFormat="dd/MM/yyyy" />
                        </MudItem>
                    }
                    <MudItem xs="12" md="6">
                        <CostCenterSelector @bind-Value="model.CostCenter" ReadOnly="@ReadOnly" />
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <DimensionSelector @bind-Value="model.Dimension" ReadOnly="@ReadOnly" />
                    </MudItem>
                    <MudItem xs="12" md="12">
                        <MudTextField ReadOnly="ReadOnly" @bind-Value="model.Narration" Lines="2" Label="Narration" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.Narration)"></MudTextField>
                    </MudItem>
                </MudGrid>
            </EditForm>
        </MudPaper>
    </FormContent>
    <VerificationStatus>
        <AutherizationStatusComponent DocTypeID="@DocTypeID" DocumentID="model.ContraID" OnApprove="Approve"></AutherizationStatusComponent>
    </VerificationStatus>
</DialogForm>
@code {
    [Parameter]
    public ContraModel model { get; set; }
    [Parameter]
    public bool ReadOnly { get; set; }

    private int? branchID = null;
    private string UserID = null;

    private EditContext editContext;

    DialogForm dialogForm;

    public bool HasAuthoriseEdit { get; set; } = false;
    int DocTypeID = 3;

    protected void Approve(DataApprovedStatus aprvd)
    {
        if (aprvd.IsApprove)
        {

            model.UserInfo.UserID = UserID;
            Iservice.Approve(model.ContraID, model.UserInfo.UserID, aprvd.Remarks);
            snackbar.Add("Approved Successfully", Severity.Success);
        }
    }

    protected override async Task OnInitializedAsync()
    {

        CancellationTokenSource ctc = new CancellationTokenSource();
        HasAuthoriseEdit = await Irole.HasClaim(DocTypeID.ToString(), "Edit", ctc.Token);


        var authprov = await auth.GetAuthenticationStateAsync();
        var User = authprov.User;
        branchID = int.Parse(User.Claims.First(x => x.Type == "BranchID").Value);
        UserID = User.Identity.Name;
        model.BranchID = model.OtherBranchID = branchID;
        model.NatureOfTransaction = "Contra";
    }

    public async Task OnValidSubmit()
    {
        if (HasAuthoriseEdit)
        {
            model.IsPayment = true;
            model.UserInfo.UserID = UserID;
            Iservice.Update(model);
            dialogForm.Close(model);

        }
        else
        {

            bool? result = await DialogService.ShowMessageBox(
        "Permission denied!",
        "You dont have any permission to submit.");

        }
    }

}
