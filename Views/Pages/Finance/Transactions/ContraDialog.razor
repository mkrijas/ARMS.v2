    protected async Task IsApproveData(DataApprovedStatus aprvd)
    {
        if (aprvd.IsApprove)
        {
            var authprov = await auth.GetAuthenticationStateAsync();
            var user = authprov.User;
            model.UserInfo.UserID = user.Identity.Name;
            Iservice.Approve(model.ContraID, model.UserInfo.UserID,aprvd.Remarks);
            snackbar.Add("Approved Successfully", Severity.Success);
        }

    }
    private async Task<IEnumerable<AccountRuleDefinitionModel>> SearchAccountsH(string searchString)
    {
        await Task.Delay(5);

        var authprov = await auth.GetAuthenticationStateAsync();
        var brancIDString = authprov.User.Claims.First(x => x.Type == "BranchID").Value;
        int branchID = int.Parse(brancIDString);
        //int coID =Convert.ToInt32(configuration.GetSection("Data")[model.ContraModeHome]);
        return accountService.GetPaymentCodes(branchID,model.ContraModeHome).ToList();;
    }
    private async Task<IEnumerable<AccountRuleDefinitionModel>> SearchAccountsO(string searchString)
    {
        await Task.Delay(5);

        var authprov = await auth.GetAuthenticationStateAsync();
        var brancIDString = authprov.User.Claims.First(x => x.Type == "BranchID").Value;
        int branchID = int.Parse(brancIDString);
        //int coID =Convert.ToInt32(configuration.GetSection("Data")[model.ContraModeHome]);
        return accountService.GetPaymentCodes(branchID,model.ContraModeOther).ToList();;
    }
    //private async Task<IEnumerable<ChartOfAccountModel>> SearchAccountsOther(string searchString)
    //{
    //    await Task.Delay(5);
