@page "/ContraView"
@page "/ContraView/{id:int}"
@using System.Threading;
@inherits ViewComponentBase<ContraModel>
@inject IContraService Iservice



<div class="admin-page-container">
    <div class="admin-header-tiered mb-6">
        <div class="d-flex align-center justify-space-between">
            <div>
                <MudText Typo="Typo.h4" Class="admin-title">Contra Entries</MudText>
                <MudText Typo="Typo.body2" Class="admin-subtitle">Manage cash and bank transfers, withdrawals, and deposits.</MudText>
            </div>
            <MudButton StartIcon="@Icons.Material.Filled.Add" Variant="Variant.Filled" Color="Color.Primary" Class="admin-register-btn" OnClick="@(()=> OpenForm(new ContraModel(),false))" Disabled="@_busy">ADD CONTRA</MudButton>
        </div>
    </div>

    <div class="admin-glass-card mb-6 pa-4">
        <div class="d-flex align-center gap-4">
            <div style="flex-grow: 1;">
                <MudTextField @bind-Value="searchTerm" Placeholder="Search Contra..." Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" Variant="Variant.Outlined" Margin="Margin.Dense" Class="admin-input-group" @onkeyup="HandleSearchKeyUp" Clearable="true" />
            </div>           
            <MudCheckBox T="bool" Label="Approved Entries" ValueChanged="((bool value)=>ToggleData(value))" Value="@ShowApproved" Size="Size.Small" Color="Color.Primary" Class="fw-600" />
        </div>
    </div>

    <div class="admin-glass-card pa-0 overflow-hidden">
        <MudTable ServerData="LoadServerData" T="ContraModel" @ref="_table" Dense="true" Hover="true" Elevation="0" Class="modern-admin-table">
          
            <LoadingContent>
                <div @key="@("loader")" style="display: flex; justify-content: center; align-items: center; min-height: 400px;">
                    <LoaderComponent IsFullScreen="false"
                                     ShowLogo="false"
                                     Size="large"
                                     LoadingText="Loading...."
                                     SubText="Fetching Data..." />
                </div>
            </LoadingContent>
            <HeaderContent>
                <MudTh><MudTableSortLabel SortBy="new Func<ContraModel, object>(x=> x.DocumentDate)"><span class="admin-header-text">DOCUMENT DATE</span></MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<ContraModel, object>(x=> x.ContraID)" InitialDirection="SortDirection.Descending"><span class="admin-header-text">DOCUMENT NUMBER</span></MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<ContraModel, object>(x=> x.ContraModeHome)"><span class="admin-header-text">PAYMENT</span></MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<ContraModel, object>(x=> x.TotalAmount)"><span class="admin-header-text">AMOUNT</span></MudTableSortLabel></MudTh>
                <MudTh Style="text-align: right;"><span class="admin-header-text">ACTIONS</span></MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="DocumentDate">@context.DocumentDate?.ToShortDateString()</MudTd>
                <MudTd DataLabel="DocumentNumber">
                    <div class="d-flex align-center gap-2">
                        <MudText Typo="Typo.body2" Class="admin-td-primary fw-600">@context.DocumentNumber</MudText>
                        @if (context.AuthLevelId == 100)
                        {
                            <MudChip T="string" Color="Color.Error" Size="Size.Small" Variant="Variant.Text" Class="pa-0">Rejected</MudChip>
                        }
                    </div>
                </MudTd>
                <MudTd DataLabel="ContraModeHome"><MudText Typo="Typo.body2" Class="admin-td-secondary">@context.ContraModeHome</MudText></MudTd>
                <MudTd DataLabel="Amount"><MudText Typo="Typo.body2" Class="admin-td-amount">@context.TotalAmount?.ToString("N2")</MudText></MudTd>
                <MudTd DataLabel="Actions" Style="text-align: right;">
                    <div class="d-flex justify-end gap-1">
                        <MudTooltip Text="View Details">
                            <MudIconButton OnClick="@(()=> OpenForm(context,true))" Color="Color.Info" Icon="@Icons.Material.Filled.GridView" Size="Size.Small" Variant="Variant.Text" />
                        </MudTooltip>
                        
                        <MudTooltip Text="Edit">
                            <MudIconButton Disabled="@(context.AuthLevelId != null)" OnClick="@(()=> OpenForm(context,false))" Color="Color.Primary" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Variant="Variant.Text" />
                        </MudTooltip>
                        
                        <MudTooltip Text="Delete">
                            <MudIconButton Disabled="@(context.AuthLevelId != null)" OnClick="@(()=> Delete(context.ContraID))" Color="Color.Error" Icon="@Icons.Material.Filled.DeleteOutline" Size="Size.Small" Variant="Variant.Text" />
                        </MudTooltip>

                        @if (@context.AuthLevelId == 99)
                        {
                            <EntryReversedComponent TDS="context.TdsAmount" DocTypeID="DocInfo.DocumentTypeID" DocumentID="context.ContraID" MID="context.MID" DocumentNumber="@context.DocumentNumber"></EntryReversedComponent>
                        }
                        else if (@context.AuthLevelId != 100)
                        {
                            <MudTooltip Text="Verify">
                                <MudIconButton OnClick="@(()=> OpenForm(context,true))" Color="Color.Warning" Icon="@Icons.Material.Filled.Verified" Size="Size.Small" Variant="Variant.Text" />
                            </MudTooltip>
                        }
                    </div>
                </MudTd>
            </RowTemplate>
            <PagerContent>
                <div class="pa-4">
                    <MudTablePager PageSizeOptions="new int[] { 10, 20, 50, 100 }" />
                </div>
            </PagerContent>
        </MudTable>
    </div>
</div>

@code {


    protected override List<ContraModel> _collection { get; set; } = new List<ContraModel>();
    protected override DocumentInfoModel DocInfo { get; set; } = new DocumentInfoModel()
    {
        DocumentTypeID = 3,
        DocumentName = "Contra"
    };

    // Method to reload the table with data

    protected override async Task OnInitializedAsync()
    {        
        await base.OnInitializedAsync();
        if (id != null && _collection != null && _collection.Any(g => g.ContraID == id))
        {
            await OpenForm(_collection.FirstOrDefault(s => s.ContraID == id), true);
        }        
    }

    // Method to open the contra form for adding or editing
    protected override async Task OpenForm(ContraModel model, bool ReadOnly, bool DisableAddition = false)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        _busy = true;
        DialogParameters parms = new DialogParameters();
        parms.Add("model", model.Clone());
        parms.Add("ReadOnly", ReadOnly);
        parms.Add("OnApproved", new EventCallbackFactory().Create(this, async () => await _table.ReloadServerData()));
        var dialog = await dialogService.ShowAsync<ContraDialog>(model.ContraID == null ? "ADD" : "EDIT", parms, new DialogOptions() { MaxWidth = MaxWidth.Large, FullWidth = true });
        var result = await dialog.Result;
        if (!result.Canceled)
        {
            var ReturnData = (ContraModel)result.Data;
            await _table.ReloadServerData();
        }        
        await Task.Delay(200);
        _busy = false;
    }
}
