@using ArmsServices.DataServices.Finance.Transactions;

@attribute [Authorize]
@inject MudBlazor.ISnackbar snackbar
@inject AuthenticationStateProvider auth
@inject IRoleService<RoleModel> Irole
@inject IDocVoucherService Iservice

@inject IAssetDocumentService IDocumentService
@inject IGstUsageIDService usageService
@inject IDialogService DialogService
@inject ITdsRateService tdsService
@inject IChartOfAccountService ICoaService

<DialogForm @ref="@dialogForm" ReadOnly="@ReadOnly" Title="Asset Documents Voucher" Subtitle="Generate and track vouchers for asset-related documentation." Icon="@Icons.Material.Filled.Description" AdminStyle="true" formID="DocVoucherForm" DocumentDetails="@DocumentDetails" model="@model" TotalAmount="model.TotalAmount" _busy="_busy">
    <FormContent>
        <div class="dialog-content-wrapper">
            <EditForm id="DocVoucherForm" OnValidSubmit="OnValidSubmit" EditContext="editContext">
                <ObjectGraphDataAnnotationsValidator />
                
                <div class="admin-glass-card pa-6 mb-6">
                    <div class="d-flex align-center mb-4">
                        <MudIcon Icon="@Icons.Material.Filled.Description" Color="Color.Primary" Class="mr-2" />
                        <span class="admin-section-label mb-0">Voucher Details</span>
                    </div>
                    <MudGrid Spacing="3">
                        <MudItem xs="12" md="6">
                            <MudSelect For="@(() => model.DocumentType)" Label="Select Document Type" T="AssetDocumentTypeModel" Value="model.DocumentType" ValueChanged="OnChangeDocumentType" ToStringFunc="@(e => e == null ? null : $"{e.DocumentTypeName}")" Variant="Variant.Outlined" Margin="Margin.Dense" AdornmentColor="Color.Secondary" Class="admin-input-group modern-input">
                                @foreach (var ditem in DocumentTypeList)
                                {
                                    <MudSelectItem Value="@ditem">@ditem.DocumentTypeName</MudSelectItem>
                                }
                            </MudSelect>
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <MudDatePicker ReadOnly="ReadOnly" Label="Document Date" Variant="Variant.Outlined" Margin="Margin.Dense" DisableToolbar="true" Editable="true" @bind-Date="model.DocumentDate" DateFormat="dd/MM/yyyy" MaxDate="DateTime.Now" Class="admin-input-group modern-input" />
                        </MudItem> 
                        <MudItem xs="12">
                            <MudTextField ReadOnly="ReadOnly" @bind-Value="model.Narration" Lines="2" Label="Narration" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.Narration)" Class="admin-input-group modern-input"></MudTextField>
                        </MudItem>
                    </MudGrid>
                </div>

                <div class="admin-glass-card pa-6 mb-6">
                    <div class="d-flex align-center mb-4">
                        <MudIcon Icon="@Icons.Material.Filled.Payments" Color="Color.Primary" Class="mr-2" />
                        <span class="admin-section-label mb-0">Payment / Agent Information</span>
                    </div>
                    <MudGrid Spacing="3">
                        <MudItem xs="12">
                            <MudCheckBox T="bool" Label="Credit?" Value="@model.IsAgent" ValueChanged="((bool IsAgent)=>OnChangeIsAgentChecked(IsAgent))" Size="Size.Medium" Color="Color.Primary" Class="ml-2"></MudCheckBox>
                        </MudItem>
                        @if (model.IsAgent)
                        {
                            <MudItem xs="12">
                                <PartySelector For="@(() => model.Agent)" Value="@model.Agent" ValueChanged="OnChangeAgent" NatureOfBusiness="Supplier" BranchID="@model.BranchID" label="Agent" Class="admin-input-group modern-input"></PartySelector>
                            </MudItem>
                        }
                        else
                        {
                            <MudItem xs="12">
                                <PaymentAccountSelector @bind-PaymentMode="model.PaymentMode" @bind-CoaID="model.PaymentCoaID" @bind-ArdCode="model.PaymentArdCode" @bind-BankTool="model.PaymentTool" @bind-BankCharges="model.BankCharges" Class="admin-input-group modern-input"></PaymentAccountSelector>
                            </MudItem>
                        }
                    </MudGrid>
                </div>

                <div class="admin-glass-card pa-0 overflow-hidden">
                    <div class="px-6 py-4 border-bottom-subtle" style="background: rgba(255, 159, 67, 0.03); border-bottom: 1px solid rgba(255, 159, 67, 0.3);">
                        <span class="admin-section-label mb-0">Voucher Items</span>
                    </div>
                    <div class="modern-admin-table">
                         <MudTable Items="@model.DocVoucherSubList" Dense="true" Hover="true" Striped="true" Elevation="0" @bind-place="model" Context="SubContext">
                            <HeaderContent>
                                <MudTh><span class="admin-header-text">ASSET NAME</span></MudTh>
                                <MudTh><span class="admin-header-text">SLIP NO</span></MudTh>
                                <MudTh><span class="admin-header-text">REFERENCE</span></MudTh>
                                <MudTh><span class="admin-header-text">AMOUNT</span></MudTh>
                                <MudTh><span class="admin-header-text">USAGE</span></MudTh>
                                <MudTh><span class="admin-header-text">COST CENTER</span></MudTh>
                                <MudTh><span class="admin-header-text">DIMENSION</span></MudTh>
                            </HeaderContent>
                            <RowTemplate>
                                <MudTd DataLabel="Asset Name">
                                    <MudText Typo="Typo.body2" Style="font-weight: 700;">@SubContext.AssetName</MudText>
                                    <MudText Typo="Typo.caption" Style="color: #667085;">@SubContext.AssetCode</MudText>
                                </MudTd>
                                <MudTd DataLabel="Slip No">@SubContext.SlipNo</MudTd>
                                <MudTd DataLabel="Reference">@SubContext.Reference</MudTd>
                                <MudTd DataLabel="Amount" Style="font-weight: 800; color: #FF9F43;">₹ @SubContext.Amount</MudTd>
                                <MudTd DataLabel="Usage">@SubContext.UsageCode</MudTd>
                                <MudTd DataLabel="Cost Center">
                                    <CostCenterSelector For="@(() => SubContext.CostCenter)" @bind-Value="@SubContext.CostCenter" Class="admin-input-group modern-input" />
                                </MudTd>
                                <MudTd DataLabel="Dimension">
                                    <DimensionSelector For="@(() => SubContext.Dimension)" @bind-Value="@SubContext.Dimension" Class="admin-input-group modern-input" />
                                </MudTd>
                            </RowTemplate>
                        </MudTable>
                    </div>
                </div>
            </EditForm>
        </div>
    </FormContent>
    <VerificationStatus>
        <AutherizationStatusComponent CreatedBy="@model.UserInfo" DocTypeID="@DocVoucherDocTypeID" DocDate="@DocDate" DocType="@DocType" DocNumber="@DocNumber" PageToRedirectLink="@PageToRedirectLink" DocumentID="model.DocumentVoucherID" OnApprove="ApproveEntry"></AutherizationStatusComponent>
    </VerificationStatus>
</DialogForm>

