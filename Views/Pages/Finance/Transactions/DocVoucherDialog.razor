    // Method to add tax to the model based on the selected agent and document type
    private bool AddTax()
    {
        if (model.IsAgent)
        {
            if (model.Agent == null)
            {
                snackbar.Add("Please select agent.", Severity.Error);
                return false;
            }
        }
        if (gstusge != null && model.TotalAmount != null && model.Agent != null && model.Agent.PartyID != null)
        {
            if (model.DocumentType == null)
            {
                snackbar.Add("Please select document type.", Severity.Error);
                return false;
            }
            
            // Get the GST rate based on the document type's usage code
            model.GstRate = usageService.GetGstRate(model.DocumentType?.UsageCode?.UsageCode ?? "", DateTime.Now);
            decimal taxRate = model.GstRate ?? 0;
            if (!Local)
            {
                model.IGST = Math.Round(model.TotalAmount.Value * taxRate / 100, 2);
            }
            else
            {
                model.SGST = model.CGST = Math.Round(model.TotalAmount.Value * taxRate / 200, 2);
            }

            // Calculate TDS based on the agent's party ID
            decimal tdsRate = tdsService.GetTdsRate(model.Agent.PartyID, model.PaymentCoaID);
            model.TDS = Math.Round((model.TotalAmount.Value * tdsRate) / 100, 2);
            model.TotalTax = (model.IGST ?? 0) + (model.SGST ?? 0) + (model.CGST ?? 0) + (model.TDS ?? 0);
            return true;
        }
        return false;
    }

