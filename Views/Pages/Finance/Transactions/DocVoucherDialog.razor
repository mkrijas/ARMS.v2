    // Lifecycle method called when parameters are set or changed
    protected override async Task OnInitializedAsync()
    {
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionToEdit = await Irole.HasClaim(DocVoucherDocTypeID.ToString(), "Edit", ctc.Token);
        HasPermissionToApprove = await Irole.HasClaim(DocVoucherDocTypeID.ToString(), "Approve", ctc.Token);

        var authprov = await auth.GetAuthenticationStateAsync();
        branchID = int.Parse(authprov.User.Claims.First(x => x.Type == "BranchID").Value);
        var user = authprov.User;
        UserID = user.Identity.Name;        
        if (model == null || model != null && model.DocumentVoucherID == null || model != null && model.DocumentVoucherID == 0)
        {
            if (model == null)
            {
                model = new()
                    {
                        BranchID = branchID,
                        UserInfo = new() { UserID = UserID, },
                        TotalAmount = 0,
                        NatureOfTransaction = "Tax Voucher"
                    };
            }
            else
            {
                model.BranchID = branchID;
                model.UserInfo = new() { UserID = UserID, }; ;
                model.TotalAmount = 0;
                model.NatureOfTransaction = "Tax Voucher";
            }
        }
        else
        {
            // Fetch sub-document details if the model is already initialized
            model.DocVoucherSubList = Iservice.GetSub(model.DocumentVoucherID).ToList();
        }

        // Fetch document types and GST usage codes
        DocumentTypeList = IDocumentService.GetDocumentTypes().ToList();
        usageList = usageService.SelectByArea(Area, System.DateTime.Now).ToList();
        model.TotalTax = (model.IGST ?? 0) + (model.SGST ?? 0) + (model.CGST ?? 0) + (model.TDS ?? 0);

        DocNumber = model.DocumentNumber;
        DocDate = model.DocumentDate;
        DocType = model.NatureOfTransaction;
    }

    // Lifecycle method called when parameters are set or changed
    protected override void OnParametersSet()
    {
        editContext = new EditContext(model);

        DocumentDetails.DocumentTypeID = DocVoucherDocTypeID;
        DocumentDetails.DocumentID = model.DocumentVoucherID;
    }

    // Method to approve the document entry
    protected async Task ApproveEntry(DataApprovedStatus aprvd)
    {
        if (HasPermissionToApprove)
        {
            if (aprvd.IsApprove)
            {
                model.UserInfo.UserID = UserID;
                try
                {
                    // Call the service to approve the document voucher
                    Iservice.Approve(model.DocumentVoucherID, model.UserInfo.UserID, aprvd.Remarks);
                    snackbar.Add("Approved Successfully", Severity.Success);
                }
                catch (Exception ex)
                {
                    snackbar.Add(ex.Message, Severity.Error);
                }
            }
        }
        else
        {
            bool? result = await DialogService.ShowMessageBoxAsync(
                "Permission denied!",
                "You don't have any permission to Approve Voucher.");
        }
    }

