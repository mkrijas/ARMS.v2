    // Method to handle changes in the agent's checked status
    public void OnChangeIsAgentChecked(bool obj)
    {
        model.IsAgent = obj;
        if (!obj)
        {
            model.Agent = new();
            model.CGST = null;
            model.SGST = null;
            model.IGST = null;
            model.TDS = null;
            model.TotalTax = null;
        }
        else
        {
            model.PaymentMode = null;
            model.PaymentArdCode = null;
            model.PaymentCoaID = null;
            model.PaymentTool = null;
            model.BankCharges = null;
        }
    }

    // Method to handle form submission when the form is valid
    public async Task OnValidSubmit(EditContext context)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is being submitted!", Severity.Warning);
            return;
        }

        _busy = true;
        if (model.DocVoucherSubList == null || model.DocVoucherSubList.Count() == 0)
        {
            snackbar.Add("Items should not be empty!", Severity.Error);
            _busy = false;
            return;
        }

        // Validate cost center and dimension based on document type
        if (model.DocumentType != null && (IDocumentService.IsCostCenterIsMadatoryForGivenDocumentTypeID(model.DocumentType.DocumentTypeID) == false || IDocumentService.IsDimensionIsMadatoryForGivenDocumentTypeID(model.DocumentType.DocumentTypeID) == false))
        {
            if (model.DocVoucherSubList != null && model.DocVoucherSubList.Any(s => s.CostCenterMod == null))
            {
                snackbar.Add("CostCenter is mandatory to select!", Severity.Error);
                _busy = false;                
            }
            if (model.DocVoucherSubList != null && model.DocVoucherSubList.Any(s => s.DimensionMod == null))
            {
                snackbar.Add("Dimension is mandatory to select!", Severity.Error);
                _busy = false; 
            }

            if (_busy == false)
            {
                return;
            }
        }

        if (HasPermissionToEdit)
        {
            try
            {                
                model = Iservice.Update(model); // Update the model using the service
                snackbar.Add("Saved Successfully", Severity.Success);
                dialogForm.Close(model);
            }
            catch (Exception ex)
            {
                snackbar.Add(ex.Message, Severity.Error);
            }
        }
        else
        {
            bool? result = await DialogService.ShowMessageBoxAsync(
                "Permission denied!",
                "You don't have any permission to Edit Voucher.");
        }
        await Task.Delay(200);
        _busy = false;
    }

    // Method to delete a sub-document from the list
    private void DeleteSubList(DocumentVoucherSubModel subModel)
    {
        if (model.DocVoucherSubList.Exists(x => x.DocumentVoucherSubID == subModel.DocumentVoucherSubID))
        {
            int rowIndex = model.DocVoucherSubList.IndexOf(subModel);
            model.DocVoucherSubList.RemoveAt(rowIndex);
            model.TotalAmount = model.DocVoucherSubList.Sum(x => x.Amount);
          
        }
    }

