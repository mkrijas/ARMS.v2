                                    <MudTh><MudTableSortLabel SortBy="new Func<DocumentVoucherSubModel, object>(x=> x.SlipNo)" InitialDirection="SortDirection.Ascending"> Slip No </MudTableSortLabel></MudTh>
                                    <MudTh><MudTableSortLabel SortBy="new Func<DocumentVoucherSubModel, object>(x=> x.Reference)" InitialDirection="SortDirection.Ascending"> Refference </MudTableSortLabel></MudTh>
                                    <MudTh><MudTableSortLabel SortBy="new Func<DocumentVoucherSubModel, object>(x=> x.Amount)" InitialDirection="SortDirection.Ascending"> Amount </MudTableSortLabel></MudTh>
                                    <MudTh><MudTableSortLabel SortBy="new Func<DocumentVoucherSubModel, object>(x=> x.UsageCode)" InitialDirection="SortDirection.Ascending"> Usage Code </MudTableSortLabel></MudTh>
                                    <MudTh><MudTableSortLabel SortBy="new Func<DocumentVoucherSubModel, object>(x=> x.CostCenterMod.CostCenter)" InitialDirection="SortDirection.Ascending"> Cost Center </MudTableSortLabel></MudTh>
                                    <MudTh><MudTableSortLabel SortBy="new Func<DocumentVoucherSubModel, object>(x=> x.DimensionMod.Dimension)" InitialDirection="SortDirection.Ascending"> Dimension </MudTableSortLabel></MudTh>
                                </HeaderContent>
                                <RowTemplate>
                                    <MudTd DataLabel="Asset Name">@SubContext.AssetName | @SubContext.AssetCode</MudTd>
                                    <MudTd DataLabel="Slip No">@SubContext.SlipNo</MudTd>
                                    <MudTd DataLabel="Refference">@SubContext.Reference</MudTd>
                                    <MudTd DataLabel="Amount">@SubContext.Amount</MudTd>
                                    <MudTd DataLabel="Usage Code">@SubContext.UsageCode</MudTd>
