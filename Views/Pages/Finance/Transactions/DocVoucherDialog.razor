                <MudGrid>
                    <MudItem xs="12" md="6">
                        <MudSelect Label="Select Document Type" T="AssetDocumentTypeModel" Value="model.DocumentType" ValueChanged="OnChangeDocumentType" ToStringFunc="@(e => e == null ? null : $"{e.DocumentTypeName}")" Variant="Variant.Outlined" Margin="Margin.Dense" AdornmentColor="Color.Secondary">
                            @foreach (var ditem in DocumentTypeList)
                            {
                                <MudSelectItem Value="@ditem">@ditem.DocumentTypeName</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudDatePicker ReadOnly="ReadOnly" Label="Document Date" Variant="Variant.Outlined" Margin="Margin.Dense" DisableToolbar="true" Editable="true" @bind-Date="model.DocumentDate" DateFormat="dd/MM/yyyy" MaxDate="DateTime.Now" />
                    </MudItem> 
                    <MudItem xs="12" md="12">
                        <MudTextField ReadOnly="ReadOnly" @bind-Value="model.Narration" Lines="2" Label="Narration" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.Narration)"></MudTextField>
                    </MudItem>
                    <MudItem xs="12" md="12">
                        <MudCheckBox Label="Credit?" Checked="@model.IsAgent" CheckedChanged="((bool IsAgent)=>OnChangeIsAgentChecked(IsAgent))" Size="Size.Medium" Color="Color.Primary"></MudCheckBox>
                    </MudItem>
                    @if (model.IsAgent)
                    {
                        <MudItem xs="12" md="12">
                            <PartySelector Value="@model.Agent" ValueChanged="OnChangeAgent" NatureOfBusiness="Supplier" BranchID="@model.BranchID" label="Agent"></PartySelector>
                        </MudItem>
                    }
                    else
                    {
                        <MudItem xs="12" md="12">
                            <PaymentAccountSelector @bind-PaymentMode="model.PaymentMode" @bind-CoaID="model.PaymentCoaID" @bind-ArdCode="model.PaymentArdCode" @bind-BankTool="model.PaymentTool" @bind-BankCharges="model.BankCharges"></PaymentAccountSelector>
                        </MudItem>
                    }
                  @*   <MudItem xs="12" md="6">
                        <MudTextField @bind-Value="model.TotalAmount" Label="Total Amount" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.TotalAmount)" Disabled></MudTextField>
                    </MudItem> *@
                   
                    <MudItem xs="12">
                        <MudContainer Style="max-height: 450px;max-width: 1230px;  overflow-y: scroll;">
                            <MudTable Items="@model.DocVoucherSubList" Dense="true" Hover="true" Striped="true" Elevation="0" @bind-place="model" Context="SubContext">
                                <ToolBarContent>
