                                      @*   <MudSelect ReadOnly="ReadOnly" Label="Select CostCenter" @bind-Value="@SubContext.CostCenterMod" T="CostCenterModel" ToStringFunc="@(e => e == null ? null : $"{e.CostCenter}")" Variant="Variant.Outlined" Margin="Margin.Dense"   AdornmentColor="Color.Secondary">
                                            @foreach (var ditem in costCenter)
                                            {
                                                <MudSelectItem Value="@ditem">@ditem.CostCenter</MudSelectItem>
                                            }
                                        </MudSelect> *@
                                    </MudTd>
                                    <MudTd DataLabel="Dimension">
                                        <DimensionSelector @bind-Value="@SubContext.Dimension"></DimensionSelector>
                                      @*   <MudSelect ReadOnly="ReadOnly" Label="Select Dimension" @bind-Value="@SubContext.DimensionMod" T="DimensionModel" ToStringFunc="@(e => e == null ? null : $"{e.Dimension}")" Variant="Variant.Outlined" Margin="Margin.Dense"   AdornmentColor="Color.Secondary">
                                            @foreach (var ditem in dimension)
                                            {
                                                <MudSelectItem Value="@ditem">@ditem.Dimension</MudSelectItem>
                                            }
                                        </MudSelect> *@
                                    </MudTd>
                                </RowTemplate>
                            </MudTable>
                        </MudContainer>
                    </MudItem>
                </MudGrid>
            </EditForm>
        </MudPaper>
    </FormContent>
    <VerificationStatus>
        <AutherizationStatusComponent CreatedBy="@model.UserInfo" DocTypeID="@DocVoucherDocTypeID" DocDate="@DocDate" DocType="@DocType" DocNumber="@DocNumber" PageToRedirectLink="@PageToRedirectLink" DocumentID="model.DocumentVoucherID" OnApprove="ApproveEntry"></AutherizationStatusComponent>
    </VerificationStatus>
</DialogForm>

