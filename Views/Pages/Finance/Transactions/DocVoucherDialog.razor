    // Method to handle changes in the document type
    public async Task OnChangeDocumentType(AssetDocumentTypeModel obj)
    {
        model.DocumentType = obj;
        //AddTax();
        if (model.DocumentType != null)
        {
            DialogOptions mediumWidth = new DialogOptions() { MaxWidth = MaxWidth.Medium, FullWidth = true };
            DialogParameters parms = new DialogParameters();
            parms.Add("DocumentType", model.DocumentType);
            var dialog = DialogService.Show<AssetDocumentSelectDialoge>("Select Document", parms, mediumWidth);
            var result = await dialog.Result;
            var isCancelled = result.Canceled;
            if (!isCancelled)
            {
                var ReturnData = (DocumentVoucherModel)result.Data;

                if (ReturnData != null && ReturnData.DocVoucherSubList != null && ReturnData.DocVoucherSubList.Where(d => d.IsSelect == true) != null && ReturnData.DocVoucherSubList.Where(d => d.IsSelect == true).Count() != 0)
                {
                    model.DocVoucherSubList = ReturnData.DocVoucherSubList.Where(d => d.IsSelect == true).ToList();
                    model.TotalAmount = ReturnData.DocVoucherSubList.Where(d => d.IsSelect == true).Sum(s => s.Amount);
                }

                if (ReturnData == null || ReturnData.DocVoucherSubList == null || ReturnData.DocVoucherSubList.Where(d => d.IsSelect == true) == null || ReturnData.DocVoucherSubList.Where(d => d.IsSelect == true).Count() == 0)
                {
                    model.DocumentType = null;
                    model.DocVoucherSubList = null;
                }
            }

        }
    }
    
