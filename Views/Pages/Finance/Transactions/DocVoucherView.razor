@page "/DocumentVoucher"
@page "/DocumentVoucher/{id:int}"
@using System.Threading;
@using ArmsModels.BaseModels.Finance.Transactions;
@using ArmsServices.DataServices.Finance.Transactions;
@using Microsoft.AspNetCore.Authorization;
@using Microsoft.AspNetCore.Components.Authorization;
@using MudBlazor;
@using Views.Pages.Finance.Transactions;
@attribute [Authorize]
@inject IRoleService<RoleModel> Irole
@inject AuthenticationStateProvider auth
@inject MudBlazor.ISnackbar snackbar
@inject IDialogService DialogService
@inject IDocVoucherService Iservice
@inject SignalRService signalRService
@inject IPushNotificationService IpushNotificationService

@if (_isLoading)
{
    <div @key="@("loader")" style="display: flex; justify-content: center; align-items: center; min-height: 400px;">
        <LoaderComponent IsFullScreen="true" 
                        ShowLogo="false" 
                        Size="medium" 
                        LoadingText="Loading Document Vouchers" 
                        SubText="Please wait..." />
    </div>
}
else
{
    <div @key="@("content")">
<div class="admin-page-container">
    <div class="admin-header-tiered mb-6">
        <div class="d-flex align-center justify-space-between">
            <div>
                <MudText Typo="Typo.h4" Class="admin-title">Document Vouchers</MudText>
                <MudText Typo="Typo.body2" Class="admin-subtitle">Process and manage tax vouchers and document-linked financial records.</MudText>
            </div>
            <MudButton StartIcon="@Icons.Material.Filled.Add" Variant="Variant.Filled" Color="Color.Primary" Class="admin-register-btn" OnClick="@(()=> OpenDialog(new DocumentVoucherModel()))" Disabled="@_busy">ADD VOUCHER</MudButton>
        </div>
    </div>

    <div class="admin-glass-card mb-6 pa-4">
        <div class="d-flex align-center gap-4">
            <div style="flex-grow: 1;">
                <MudTextField T="string" Placeholder="Search Vouchers..." Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" Variant="Variant.Outlined" Margin="Margin.Dense" Class="admin-input-group" Disabled="true" HelperText="Search functionality for this view is restricted." />
            </div>
            <MudCheckBox T="bool" Label="Approved Entries" ValueChanged="((bool value)=>ApprovedToggled(value))" Value="@IsApproved" Size="Size.Small" Color="Color.Primary" Class="fw-600" />
        </div>
    </div>

    <div class="admin-glass-card pa-0 overflow-hidden">
        <MudTable Items="@collection" Dense="true" Hover="true" Elevation="0" Class="modern-admin-table">
            <HeaderContent>
                <MudTh><MudTableSortLabel SortBy="new Func<DocumentVoucherModel, object>(x=> x.DocumentDate)" InitialDirection="SortDirection.Ascending"><span class="admin-header-text">DOCUMENT DATE</span></MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<DocumentVoucherModel, object>(x=> x.DocumentNumber)" InitialDirection="SortDirection.Ascending"><span class="admin-header-text">DOCUMENT NUMBER</span></MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<DocumentVoucherModel, object>(x=> x.TotalAmount)" InitialDirection="SortDirection.Ascending"><span class="admin-header-text">AMOUNT</span></MudTableSortLabel></MudTh>
                <MudTh Style="text-align: right;"><span class="admin-header-text">ACTIONS</span></MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="DocumentDate">@context.DocumentDate?.ToShortDateString()</MudTd>
                <MudTd DataLabel="DocumentNumber">
                    <div class="d-flex align-center gap-2">
                        <MudText Typo="Typo.body2" Class="admin-td-primary fw-600">@context.DocumentNumber</MudText>
                        @if (context.AuthLevelId == 100)
                        {
                            <MudChip T="string" Color="Color.Error" Size="Size.Small" Variant="Variant.Text" Class="pa-0">Rejected</MudChip>
                        }
                    </div>
                </MudTd>
                <MudTd DataLabel="TotalAmount"><MudText Typo="Typo.body2" Class="admin-td-amount">@context.TotalAmount?.ToString("N2")</MudText></MudTd>
                <MudTd DataLabel="Actions" Style="text-align: right;">
                    <div class="d-flex justify-end gap-1">
                        <MudTooltip Text="View Details">
                            <MudIconButton OnClick="@(()=> OpenDialog(context,true))" Color="Color.Info" Icon="@Icons.Material.Filled.GridView" Size="Size.Small" Variant="Variant.Text" />
                        </MudTooltip>
                        
                        <MudTooltip Text="Edit">
                            <MudIconButton Disabled="@(context.AuthLevelId != null)" OnClick="@(()=> OpenDialog(context,false))" Color="Color.Primary" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Variant="Variant.Text" />
                        </MudTooltip>
                        
                        <MudTooltip Text="Delete">
                            <MudIconButton Disabled="@(context.AuthLevelId != null)" OnClick="@(()=> Delete(context))" Color="Color.Error" Icon="@Icons.Material.Filled.DeleteOutline" Size="Size.Small" Variant="Variant.Text" />
                        </MudTooltip>

                        @if (@context.AuthLevelId == 99)
                        {
                            <EntryReversedComponent DocTypeID="DocTypeID" DocumentID="context.DocumentVoucherID" MID="context.MID" DocumentNumber="@context.DocumentNumber"></EntryReversedComponent>
                        }
                        else if (@context.AuthLevelId != 100)
                        {
                            <MudTooltip Text="Verify">
                                <MudIconButton OnClick="@(()=> OpenDialog(context,true))" Color="Color.Warning" Icon="@Icons.Material.Filled.Verified" Size="Size.Small" Variant="Variant.Text" />
                            </MudTooltip>
                        }
                    </div>
                </MudTd>
            </RowTemplate>
            <PagerContent>
                <div class="pa-4">
                    <MudTablePager PageSizeOptions="new int[] { 10, 20, 50, 100 }" />
                </div>
            </PagerContent>
        </MudTable>
    </div>
</div>
</div>
}

@code {

    private bool _isLoading = true;
    private DateTime _loadStartTime;

    public bool IsApproved { get; set; } = false;
    private List<DocumentVoucherModel> collection = new List<DocumentVoucherModel>();
    private bool _busy;
    [Parameter]
    public int? id { get; set; } = null;
    private int? branchID = null;

    public bool HasPermissionToDelete { get; set; } = false;
    int DocTypeID = 19;    

    #region SignaIR Notification

    private PushNotificationModel notificationMessage = new PushNotificationModel();
    #endregion

    // Lifecycle method called when the component is initializedv
    protected override async Task OnInitializedAsync()
    {
        _loadStartTime = DateTime.Now;
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionToDelete = await Irole.HasClaim(DocTypeID.ToString(), "Delete", ctc.Token);

        var authprov = await auth.GetAuthenticationStateAsync();
        branchID = int.Parse(authprov.User.Claims.First(x => x.Type == "BranchID").Value);
        await GetAll(IsApproved);

        await Task.Delay(200);
        await signalRService.StartAsync();
        if (id != null && collection != null && collection.Any(g => g.DocumentVoucherID == id))
        {
            await OpenDialog(collection.FirstOrDefault(s => s.DocumentVoucherID == id), true);
        }
        await EnsureMinimumLoadTime();
        _isLoading = false;
    }

    private async Task EnsureMinimumLoadTime()
    {
        var elapsed = (DateTime.Now - _loadStartTime).TotalMilliseconds;
        if (elapsed < 100)
        {
            await Task.Delay(100 - (int)elapsed);
        }
    }

    // Method to toggle the approval status and reload the table 
    async Task ApprovedToggled(bool value)
    {
        IsApproved = value;
        await GetAll(IsApproved);
    }

    // Method to fetch all document vouchers based on approval status
    private async Task GetAll(bool val)
    {
        if (val)
        {
            collection = Iservice.Select(branchID).Where(x => x.AuthLevelId == 99).ToList(); // Fetch approved document vouchers
        }
        else
        {
            collection = Iservice.Select(branchID).Where(x => x.AuthLevelId != 99).ToList(); // Fetch unapproved document vouchers
        }
    }

    // Method to delete a document voucher
    private async Task Delete(DocumentVoucherModel model)
    {
        if (HasPermissionToDelete)
        {
            try
            {
                bool? result = await DialogService.ShowMessageBoxAsync(
                    "Warning !",
                    "Are you sure, you want to delete - " + model.DocumentNumber + " (" + model.DocumentDate + ") ?");
                if (result == true)
                {
                    var authprov = await auth.GetAuthenticationStateAsync();
                    var user = authprov.User;
                    Iservice.Delete(model.DocumentVoucherID, user.Identity.Name); // Call the service to delete the document voucher
                    snackbar.Add("Deleted Successfully", Severity.Success);
                    await GetAll(IsApproved);
                }
            }
            catch (Exception ex)
            {
                snackbar.Add(ex.Message, Severity.Error);
            }
        }
        else
        {
            bool? result = await DialogService.ShowMessageBoxAsync(
                "Permission denied!",
                "You don't have any permission to Delete Entry.");
        }
    }

    // Method to open the document voucher dialog for adding or editing
    private async Task OpenDialog(DocumentVoucherModel model, bool ReadOnly = false)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        _busy = true;
        DialogOptions mediumWidth = new DialogOptions() { MaxWidth = MaxWidth.Large, FullWidth = true };
        DialogParameters parms = new DialogParameters();
        parms.Add("model", model.Clone());
        parms.Add("PageToRedirectLink", "/DocumentVoucher");
        parms.Add("ReadOnly", ReadOnly);
        var dialog = await DialogService.ShowAsync<DocVoucherDialog>((model == null || model != null && model.DocumentVoucherID == null || model != null && model.DocumentVoucherID == 0) ? "ADD" : "EDIT", parms, mediumWidth);
        var result = await dialog.Result;
        var isCancelled = result.Canceled;
        if (!isCancelled)
        {
            var ReturnData = (DocumentVoucherModel)result.Data;
            notificationMessage.InitiateBranch = new BranchModel() { BranchID = ReturnData.BranchID };
            notificationMessage.ReceivedBranch = new BranchModel() { BranchID = ReturnData.BranchID };
            notificationMessage.MessageTitle = IpushNotificationService.GetMessageTitle(ReturnData.NatureOfTransaction, ReturnData.DocumentNumber, "Level 1 Verification");
            notificationMessage.MessageBody = IpushNotificationService.GetMessageBody(ReturnData.NatureOfTransaction, ReturnData.DocumentNumber, "Level 1 Verification", ReturnData.DocumentDate);
            notificationMessage.RedirectedTo = 0;
            notificationMessage.ExpiredBy = 7;
            notificationMessage.DocumentID = ReturnData.DocumentVoucherID;
            notificationMessage.MessageGroupID = "PendingVerification";
            notificationMessage.PageToRedirectLink = "/DocumentVoucher";
            notificationMessage.ClaimValue = "Verify 1";
            notificationMessage.DocumentTypeID = DocTypeID;     
            notificationMessage.MsgDate = DateTime.Now;
            await signalRService.Send(notificationMessage);
        }
        await GetAll(IsApproved);
        await Task.Delay(200);
        _busy = false;
    }
}
