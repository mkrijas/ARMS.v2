    private  async Task GetAll()
    {
        var authprov = await auth.GetAuthenticationStateAsync();
        var brancIDString = authprov.User.Claims.First(x => x.Type == "BranchID").Value;
        int brancID = int.Parse(brancIDString);
        collection = new List<BillInfoModel>();
        foreach (var item in Iservice.GetBillInfo(brancID,CrDrType,PartyID,string.Empty))
        {
            collection.Add(item);
        }


    }   
