@inject IDrCrNoteService Iservice
@inject MudBlazor.ISnackbar snackbar
@inject AuthenticationStateProvider auth
@attribute [Authorize]
@inject IDialogService DialogService

<MudDialog>
    <DialogContent>
        <MudGrid Class="mb-3">
            <MudItem xs="6">
                <MudText Typo="Typo.body2"><b>Selected Document :</b></MudText>
                @if (SelectedObject != null)
                {
                    <MudChip T="string" Color="Color.Default">@(((BillInfoModel)SelectedObject).DocumentNumber)</MudChip>
                }
            </MudItem>
            <MudItem xs="6" Class="d-flex align-center">
                <MudTextField @bind-Value="searchDocumentNo" Placeholder="Search Document No..." Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium"></MudTextField>
                <MudButton OnClick="Search" Variant="Variant.Filled" Color="Color.Success" Class="ml-2">SEARCH</MudButton>
            </MudItem>
        </MudGrid>
        <MudContainer Style="max-height: 500px; overflow-y: scroll">
                @foreach (BillInfoModel bill in FilterCollection)
                {
                    <MudPaper Class="p-2 mb-2" @onclick="@(() => SelectItem(bill))" Style="@(SelectedObject == bill ? "background-color:#e3f2fd;" : "background-color:transparent;")">
                         <MudGrid>
                            <MudItem xs="1"><MudIcon Icon="@Icons.Material.Filled.Bookmark" Size="Size.Small" Color="@(SelectedObject == bill ? Color.Primary : Color.Default)" /></MudItem>
                            <MudItem xs="3">@bill.DocumentDate?.ToString("dd/MM/yyyy")</MudItem>
                            <MudItem xs="3">@bill.DocumentNumber</MudItem>
                            <MudItem xs="2">@bill.TotalAmount</MudItem>
                            <MudItem xs="3">@bill.Reference</MudItem>
                        </MudGrid>
                    </MudPaper>
                }
        </MudContainer>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Disabled="@_busy" OnClick="Submit" Variant="Variant.Filled" Color="Color.Success" ButtonType="ButtonType.Button">Select</MudButton>

    </DialogActions>
</MudDialog>

@code {

    [Parameter]
    public int PartyID { get; set; }
    [Parameter]
    public string CrDrType { get; set; }
    private List<BillInfoModel> collection = new List<BillInfoModel>();
    private List<BillInfoModel> FilterCollection = new List<BillInfoModel>();
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; }
    
    Object SelectedObject;
    
    private void SelectItem(BillInfoModel bill)
    {
        SelectedObject = bill;
    }
    private string searchDocumentNo = "";
    private bool _busy;

    // Lifecycle method called when the component is initialized
    protected override async Task OnInitializedAsync()
    {
        await GetAll();
    }

    // Method to fetch all bill information based on PartyID and CrDrType
    private async Task GetAll()
    {
        var authprov = await auth.GetAuthenticationStateAsync();
        int BranchID = int.Parse(authprov.User.Claims.First(x => x.Type == "BranchID").Value);

        // Fetch bill information from the service
        collection = Iservice.GetBillInfo(BranchID, CrDrType, PartyID, string.Empty).ToList();
        FilterCollection = collection.Where(s => s.DocumentNumber != null && s.DocumentNumber.Contains(searchDocumentNo, StringComparison.OrdinalIgnoreCase) || string.IsNullOrEmpty(searchDocumentNo)).ToList();
    }

    // Method to perform search based on the document numberc
    private void Search()
    {
        if (string.IsNullOrEmpty(searchDocumentNo))
        {
            FilterCollection = collection.ToList();
            return;
        }

        FilterCollection = collection.Where(s =>
            (s.DocumentNumber != null && s.DocumentNumber.Contains(searchDocumentNo, StringComparison.OrdinalIgnoreCase)) ||
            (s.Reference != null && s.Reference.Contains(searchDocumentNo, StringComparison.OrdinalIgnoreCase))
        ).ToList();
    }

    // Method to cancel the dialogc
    private void Cancel() => MudDialog.Cancel();

    // Method to submit the selected bill information
    private async Task Submit()
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        _busy = true;
        BillInfoModel SelectedItem = (BillInfoModel)SelectedObject;
        if (SelectedItem?.TotalAmount == null)
        {
            snackbar.Add("Select Bill", Severity.Warning);
        }
        else
        {
            // Fetch particulars and items for the selected bill
            SelectedItem.Particulars = Iservice.GetBillInfoParticulars(SelectedItem.PID, SelectedItem.BillType)?.ToList() ?? new();
            SelectedItem.Items = Iservice.GetBillInfoItems(SelectedItem.PID, SelectedItem.BillType)?.ToList() ?? new();
            MudDialog.Close(SelectedItem);
        }
        await Task.Delay(200);
        _busy = false;
    }
}
