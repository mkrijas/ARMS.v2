            <HeaderContent>
                <MudTh><MudTableSortLabel SortBy="new Func<BillInfoModel, object>(x=> x.BillID)" InitialDirection="SortDirection.Ascending">BillID</MudTableSortLabel></MudTh>
             <MudTh><MudTableSortLabel SortBy="new Func<BillInfoModel, object>(x=> x.DocumentNumber)" InitialDirection="SortDirection.Ascending">DocumentNumber</MudTableSortLabel></MudTh>
               <MudTh><MudTableSortLabel SortBy="new Func<BillInfoModel, object>(x=> x.DocumentDate)" InitialDirection="SortDirection.Ascending">DocumentDate</MudTableSortLabel></MudTh>
                 <MudTh><MudTableSortLabel SortBy="new Func<BillInfoModel, object>(x=> x.TotalAmount)" InitialDirection="SortDirection.Ascending">TotalAmount</MudTableSortLabel></MudTh>
              
                
                <MudTh>Actions</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="GrnNo">@context.BillID</MudTd>
                <MudTd DataLabel="EntryDate">@context.DocumentNumber</MudTd>
                <MudTd DataLabel="Party">@context.DocumentDate</MudTd>
                  <MudTd DataLabel="Party">@context.TotalAmount</MudTd>
                 
                <MudTd DataLabel="">
                  
              
                    </MudTd>
            </RowTemplate>
            <PagerContent>
                <MudTablePager PageSizeOptions="new int[] { 5, 10, 20, 50, 100 }" />
            </PagerContent>
        </MudTable>
    </MudItem>
    </MudGrid>
         </DialogContent>
         <DialogActions>
     
            <MudButton OnClick="Cancel">Cancel</MudButton>
            <MudButton OnClick="selected" Variant="Variant.Filled" Color="Color.Success" ButtonType="ButtonType.Submit">Submit</MudButton>
        
    </DialogActions>
    </MudDialog>



@code {
