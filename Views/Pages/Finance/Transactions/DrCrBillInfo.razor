@inject IDrCrNoteService Iservice
@inject MudBlazor.ISnackbar snackbar

@inject AuthenticationStateProvider auth
@attribute [Authorize]
@inject IDialogService DialogService


<MudDialog>
    <DialogContent>
        <MudContainer Style="max-height: 500px; overflow-y: scroll">
            <MudList Clickable="true" Color="@Color.Primary" @bind-SelectedItem="selectedListItem" @bind-SelectedValue="SelectedObject">
                <MudListSubheader>
                    Selected Document :
                    <MudChip Color="Color.Default">
                        @(((BillInfoModel)SelectedObject)?.DocumentNumber ?? "Select a Bill")
                    </MudChip>
                </MudListSubheader>
                @foreach (BillInfoModel bill in collection)
                {
                    <MudDivider></MudDivider>
                    <MudListItem Icon="@Icons.Material.Filled.Bookmark" Text="@bill.DocumentNumber" Value="@bill">
                        <MudGrid>
                            <MudItem>@bill.DocumentDate</MudItem>
                            <MudItem>@bill.DocumentNumber</MudItem>
                            <MudItem>@bill.TotalAmount</MudItem>
                        </MudGrid>
                    </MudListItem>
                }
            </MudList>
        </MudContainer>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton OnClick="Submit" Variant="Variant.Filled" Color="Color.Success" ButtonType="ButtonType.Button">Select</MudButton>

    </DialogActions>
</MudDialog>



@code {
    [Parameter]
    public int PartyID { get; set; }
    [Parameter]
    public string CrDrType { get; set; }

    private List<BillInfoModel> collection = new List<BillInfoModel>();
    //private BillInfoModel SelectedItem = new();

    [CascadingParameter] MudDialogInstance MudDialog { get; set; }
    MudListItem selectedListItem;
    Object SelectedObject;


    protected override async Task OnInitializedAsync()
    {
        await GetAll();
    }

    private async Task GetAll()
    {
        var authprov = await auth.GetAuthenticationStateAsync();
        int BranchID = int.Parse(authprov.User.Claims.First(x => x.Type == "BranchID").Value);
        collection = Iservice.GetBillInfo(BranchID, CrDrType, PartyID, string.Empty).ToList();
    }

    private void Cancel() => MudDialog.Cancel();

    private void Submit()
    {
        BillInfoModel SelectedItem = (BillInfoModel)SelectedObject;
        if (SelectedItem?.TotalAmount == null)
        {
            snackbar.Add("Select Bill", Severity.Warning);
        }
        else
        {
            SelectedItem.Particulars = Iservice.GetBillInfoParticulars(SelectedItem.PID,SelectedItem.BillType)?.ToList()??new();
            SelectedItem.Items = Iservice.GetBillInfoItems(SelectedItem.PID, SelectedItem.BillType)?.ToList()??new();
            MudDialog.Close(SelectedItem);
        }
    }
}
