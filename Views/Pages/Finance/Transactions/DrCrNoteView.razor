@page "/DrCrNoteView"
@page "/DrCrNoteView/{id:int}"
@inherits ViewComponentBase<DrCrNoteModel>
@inject IDialogService DialogService
@inject IDrCrNoteService Iservice
@inject ICancellationReasonCodeService IcancellationReasonCodeService

@if (_isLoading)
{
    <div style="display: flex; justify-content: center; align-items: center; min-height: 400px;">
        <LoaderComponent IsFullScreen="true" 
                        ShowLogo="false" 
                        Size="medium" 
                        LoadingText="Loading Debit/Credit Notes" 
                        SubText="Please wait..." />
    </div>
}
else
{
        <div class="admin-page-container">
            <div class="admin-header-tiered mb-6">
                <div class="d-flex align-center justify-space-between">
                    <div>
                        <MudText Typo="Typo.h4" Class="admin-title">Debit / Credit Notes</MudText>
                        <MudText Typo="Typo.body2" Class="admin-subtitle">Issue and track debit and credit adjustments for vendors and customers.</MudText>
                    </div>
                    <MudButton StartIcon="@Icons.Material.Filled.Add" Variant="Variant.Filled" Color="Color.Primary" Class="admin-register-btn" OnClick="@(()=> OpenForm(new DrCrNoteModel(),false))" Disabled="@_busy">ADD NOTE</MudButton>
                </div>
            </div>

            <div class="admin-glass-card mb-6 pa-4">
                <div class="d-flex align-center gap-4">
                    <div style="flex-grow: 1;">
                        <MudTextField @bind-Value="searchTerm" Placeholder="Search Notes..." Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" Variant="Variant.Outlined" Margin="Margin.Dense" Class="admin-input-group" @onkeyup="HandleSearchKeyUp" Clearable="true" />
                    </div>
                    <div class="d-flex align-center gap-2">
                        <MudText Typo="Typo.body2" Class="admin-td-secondary fw-600">Max Results:</MudText>
                        <MudTextField @bind-Value="@NumberOfRecords" Variant="Variant.Outlined" Margin="Margin.Dense" Style="width: 80px; background: white;" />
                    </div>
                    <MudCheckBox T="bool" Label="Approved Entries" ValueChanged="((bool value)=>ToggleData(value))" Value="@ShowApproved" Size="Size.Small" Color="Color.Primary" Class="fw-600" />
                </div>
            </div>
            <div class="admin-glass-card pa-0 overflow-hidden">
                    <MudTable ServerData="LoadServerData" T="DrCrNoteModel" @ref="_table" Dense="true" Hover="true" Elevation="0" Class="modern-admin-table">
                    <HeaderContent>
                        <MudTh><MudTableSortLabel SortBy="new Func<DrCrNoteModel, object>(x=> x.DocumentDate)"><span class="admin-header-text">DOCUMENT DATE</span></MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<DrCrNoteModel, object>(x=> x.DrCrNoteID)" InitialDirection="SortDirection.Descending"><span class="admin-header-text">DOCUMENT NUMBER</span></MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<DrCrNoteModel, object>(x=> x.TotalAmount)"><span class="admin-header-text">TOTAL AMOUNT</span></MudTableSortLabel></MudTh>
                        <MudTh Style="text-align: right;"><span class="admin-header-text">ACTIONS</span></MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="DocumentDate">@context.DocumentDate?.ToString("d")</MudTd>
                        <MudTd DataLabel="DocumentNumber">
                            <div class="d-flex align-center gap-2">
                                <MudText Typo="Typo.body2" Class="admin-td-primary fw-600">@context.DocumentNumber</MudText>
                                @if (context.AuthLevelId == 100)
                                {
                                    <MudChip T="string" Color="Color.Error" Size="Size.Small" Variant="Variant.Text" Class="pa-0">Rejected</MudChip>
                                }
                            </div>
                        </MudTd>
                        <MudTd DataLabel="TotalAmount"><MudText Typo="Typo.body2" Class="admin-td-amount">@context.TotalAmount?.ToString("N2")</MudText></MudTd>
                        <MudTd DataLabel="Actions" Style="text-align: right;">
                            <div class="d-flex justify-end gap-1">
                                <MudTooltip Text="View Details">
                                    <MudIconButton OnClick="@(()=> OpenForm(context,true))" Color="Color.Info" Icon="@Icons.Material.Filled.GridView" Size="Size.Small" Variant="Variant.Text" />
                                </MudTooltip>
                        
                                <MudTooltip Text="Edit">
                                    <MudIconButton Disabled="@(context.AuthLevelId != null)" OnClick="@(()=> OpenForm(context,false))" Color="Color.Primary" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Variant="Variant.Text" />
                                </MudTooltip>
                        
                                <MudTooltip Text="Delete">
                                    <MudIconButton Disabled="@(context.AuthLevelId != null)" OnClick="@(()=> Delete(context.DrCrNoteID))" Color="Color.Error" Icon="@Icons.Material.Filled.DeleteOutline" Size="Size.Small" Variant="Variant.Text" />
                                </MudTooltip>

                                @if (@context.AuthLevelId == 99)
                                {
                                    <EntryReversedComponent DocTypeID="DocInfo.DocumentTypeID" DocumentID="context.DrCrNoteID" MID="context.MID" DocumentNumber="@context.DocumentNumber"></EntryReversedComponent>
                                    <MudTooltip Text="Print Invoice">
                                        <MudIconButton OnClick="@(()=> PrintInvoice(context.DrCrNoteID))" Color="Color.Tertiary" Icon="@Icons.Material.Filled.Print" Size="Size.Small" Variant="Variant.Text" />
                                    </MudTooltip>
                                }
                                else if (@context.AuthLevelId != 100)
                                {
                                    <MudTooltip Text="Verify">
                                        <MudIconButton OnClick="@(()=> OpenForm(context,true))" Color="Color.Warning" Icon="@Icons.Material.Filled.Verified" Size="Size.Small" Variant="Variant.Text" />
                                    </MudTooltip>
                                }
                            </div>
                        </MudTd>
                    </RowTemplate>
                    <PagerContent>
                        <div class="pa-4">
                            <MudTablePager PageSizeOptions="new int[] { 10, 20, 50, 100 }" />
                        </div>
                    </PagerContent>
                </MudTable>
            </div>
        </div>
}

@code {

    private bool _isLoading = true;    

    protected override List<DrCrNoteModel> _collection{ get; set; } = new List<DrCrNoteModel>();
    protected override DocumentInfoModel DocInfo { get; set; } = new DocumentInfoModel()
        {
            DocumentTypeID = 5,
            DocumentName = "DrCr Note"
        };

    // Lifecycle method called when the component is initialized
    protected override async Task OnInitializedAsync()
    {       
        await base.OnInitializedAsync();
        if (id != null && _collection != null && _collection.Any(g => g.DrCrNoteID == id))
        {
            await OpenForm(_collection.FirstOrDefault(s => s.DrCrNoteID == id), true);
        }
        
        _isLoading = false;
    }


    // Method to open a dialog form for adding or editing a DrCrNote
    protected override async Task OpenForm(DrCrNoteModel tds, bool ReadOnly, bool DisableAddition = false)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        _busy = true;
        DialogOptions maxWidth = new DialogOptions() { MaxWidth = MaxWidth.Large, FullWidth = true, BackgroundClass = "blur" };
        DialogParameters parms = new DialogParameters();
        parms.Add("model", tds.Clone());        
        parms.Add("ReadOnly", ReadOnly);
        parms.Add("OnApproved", new EventCallbackFactory().Create(this, async() => await _table.ReloadServerData()));
        var dialog = await dialogService.ShowAsync<DrCrNoteDialog>(tds.DrCrNoteID == null ? "ADD" : "EDIT", parms, maxWidth);
        var result = await dialog.Result;
        var isCancelled = result.Canceled;
        if (!isCancelled)
        {
            var ReturnData = (DrCrNoteModel)result.Data;  
            await _table.ReloadServerData();
        }       
        await Task.Delay(200);
        _busy = false;
    }

    public Dictionary<string, string> ReportParameters { get; set; } = new();

    // Method to print the invoice for a specific DrCrNoteID
    private async Task PrintInvoice(int? DrCrNoteID)
    {
        ReportParameters.Clear();
        ReportParameters.Add("DrCrNoteID", DrCrNoteID.ToString());
        var parameters = new DialogParameters();
        parameters.Add("Parameters", ReportParameters); // Add the dictionary as a parameter
        parameters.Add("ReportName", "PrintDrCrNote");

        DialogOptions maxWidth = new DialogOptions() { MaxWidth = MaxWidth.Medium, FullWidth = true };
        var result = await DialogService.ShowAsync<PrintDialog>("PRINT", parameters, maxWidth);
    }
}
