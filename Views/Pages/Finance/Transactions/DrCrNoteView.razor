@code {
    private DrCrNoteModel model = new DrCrNoteModel();
    private List<DrCrNoteModel> collection = new List<DrCrNoteModel>();
    public string value="invisible";
    public string status=null;
    DrCrNoteModel pmodel=new();
    private List<CostCenterModel> costCenter = new();
    private List<DimensionModel> dimension = new();
    DialogOptions maxWidth = new DialogOptions() { MaxWidth = MaxWidth.Medium, FullWidth = true };



    protected override async Task OnInitializedAsync()
    {
        costCenter = costIservice.Select().ToList();
        dimension = dimensionIservice.Select().ToList();
        GetPerfomaInvoice();
    }
    private async Task OpenDialog(DrCrNoteModel tds)
    {
        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;
        
        DialogParameters parms = new DialogParameters();
        parms.Add("model",tds);
        parms.Add("IsReadOnly",false);
        parms.Add("IsView",false);
        var dialog =  DialogService.Show<DrCrNoteDialog>(tds.DrCrNoteID == null?"ADD":"EDIT",parms,maxWidth);
        var result = await dialog.Result;

        if(!result.Cancelled)
        {   

            GetPerfomaInvoice();


        }
          GetPerfomaInvoice();
    }
    
     private async Task OpenDialogView(DrCrNoteModel tds)
    {
        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;
        
        DialogParameters parms = new DialogParameters();
        parms.Add("model",tds);
        parms.Add("IsReadOnly",true);
        parms.Add("IsView",true);
        var dialog =  DialogService.Show<DrCrNoteDialog>(tds.DrCrNoteID == null?"ADD":"EDIT",parms,maxWidth);
        var result = await dialog.Result;

        if(!result.Cancelled)
        {   

            GetPerfomaInvoice();


        }
          GetPerfomaInvoice();
    }
     private async Task OpenDialogVerify(DrCrNoteModel tds)
    {
        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;
        
        DialogParameters parms = new DialogParameters();
        parms.Add("model",tds);
        parms.Add("IsReadOnly",true);
        parms.Add("IsView",false);
        var dialog =  DialogService.Show<DrCrNoteDialog>(tds.DrCrNoteID == null?"ADD":"EDIT",parms,maxWidth);
        var result = await dialog.Result;

        if(!result.Cancelled)
        {   

            GetPerfomaInvoice();



        }
          GetPerfomaInvoice();
    }

    public void GetPerfomaInvoice()
    {


        collection = Iservice.Select().ToList();
        

    }
     private void Delete(DrCrNoteModel tx)
    {
        Iservice.Delete(tx.DrCrNoteID, "Rijas");
        snackbar.Add("Deleted Successfully", Severity.Success);
        GetPerfomaInvoice();
    }
    public void Edit(DrCrNoteModel pim)
    {
        value = "visible";
        status = "Edit";
        pmodel = pim;

    }
    public void View(DrCrNoteModel pim)
    {
        value = "visible";
        status = "View";
        pmodel = pim;

    }
    public  void Reverse(DrCrNoteModel pim)
    {   
        value = "invisible";
        status = "Reverse";
        pmodel = pim;
        Iservice.Reverse(pim.DrCrNoteID.Value, "Rijas","remarks");
        snackbar.Add("Update Successfully", Severity.Success);
        GetPerfomaInvoice();
    }
     public  void Approve(DrCrNoteModel pim)
    {   
        value = "invisible";
        status = "Approve";
        pmodel = pim;
        Iservice.Approve(pim.DrCrNoteID, "Rijas","remarks");
        snackbar.Add("Update Successfully", Severity.Success);
        GetPerfomaInvoice();
    }
    public async Task Update()
    {   
       // Iservice.UpdateProformaInvoice(pmodel);
        snackbar.Add("Saved Successfully", Severity.Success);
       

    }
}
