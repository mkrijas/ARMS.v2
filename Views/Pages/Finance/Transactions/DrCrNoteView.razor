@page "/DrCrNoteView"
@inject IDrCrNoteService Iservice

@inject MudBlazor.ISnackbar snackbar
@inject AuthenticationStateProvider auth
@attribute [Authorize]
@inject IDialogService DialogService


<MudGrid Spacing="4">
    <MudItem xs="12">

        <MudTable Items="@collection" Dense="true" Hover="true" Striped="true" Elevation="10" @bind-place="model">

            <ToolBarContent>
                <MudText Typo="Typo.h6">Debit Note/ Credit Note</MudText>
                <MudTooltip Text="New Document">
                    <MudIconButton Icon="@Icons.Material.Filled.Add" Title="Add" @onclick="@(()=> OpenDialog(model,false))" Color="Color.Dark" Size="Size.Small"></MudIconButton>
                </MudTooltip>
                <MudSpacer></MudSpacer>
                <MudTextField @bind-Value="searchTerm" Placeholder="Search Dr/Cr..." Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0"
                              @onkeyup="HandleSearchKeyUp">
                </MudTextField>
                <div class="tablefont">
                    <span style="margin-right: 10px;">Maximum Records: </span>
                </div>
                <MudItem xs="1">
                    <MudTextField @bind-Value="@NumberOfRecords" Variant="Variant.Outlined" Margin="Margin.Dense" Class="padding5" Style="width: 80px;"></MudTextField>
                </MudItem>
                <MudCheckBox Label="Approved Entries" CheckedChanged="((bool value)=>ApprovedChanged(value))" Checked="@IsApproved" Size="Size.Medium" Color="Color.Primary" Class="tablefont margin0"></MudCheckBox>

            </ToolBarContent>

            <HeaderContent>
                <MudTh><MudTableSortLabel SortBy="new Func<DrCrNoteModel, object>(x=> x.DocumentDate)" InitialDirection="SortDirection.Ascending">DocumentDate</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<DrCrNoteModel, object>(x=> x.DocumentNumber)" InitialDirection="SortDirection.Ascending">DocumentNumber</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<DrCrNoteModel, object>(x=> x.TotalAmount)" InitialDirection="SortDirection.Ascending">TotalAmount</MudTableSortLabel></MudTh>

                <MudTh>Actions</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="DocumentDate">@context.DocumentDate</MudTd>
                <MudTd DataLabel="DocumentNumber">@context.DocumentNumber</MudTd>
                <MudTd DataLabel="TotalAmount">@context.TotalAmount</MudTd>
                <MudTd DataLabel="">
                    <MudFab @onclick="@(()=> OpenDialog(context,true))" Color="Color.Primary" title="View" Icon="@Icons.Material.Filled.GridView" Size="Size.Small" IconSize="Size.Small" />
                    @if (@context.AuthLevelId == null)
                    {
                        <MudFab @onclick="@(()=> OpenDialog(context,false))" Color="Color.Primary" title="Edit" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" IconSize="Size.Small" />
                        <MudFab @onclick="@(()=> Delete(context))" Color="Color.Error" title="Delete" Icon="@Icons.Material.Filled.Delete" Size="Size.Small" IconSize="Size.Small" />

                    }
                    @if (@context.AuthLevelId != 99)
                    {
                        <MudFab @onclick="@(()=> OpenDialog(context,true))" Color="Color.Warning" title="Verify" Icon="@Icons.Material.Filled.Verified" Size="Size.Small" IconSize="Size.Small" />

                    }
                </MudTd>
            </RowTemplate>
            <PagerContent>
                <MudTablePager PageSizeOptions="new int[] { 5, 10, 20, 50, 100 }" />               
            </PagerContent>
        </MudTable>
    </MudItem>
</MudGrid>


<br />



@code {
    private DrCrNoteModel model = new DrCrNoteModel();
    private List<DrCrNoteModel> collection = new List<DrCrNoteModel>();

    public bool IsApproved { get; set; } = false;
    private int numberOfRecords = 100;
    private string searchTerm = "";

    private async Task HandleSearchKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await ReloadTable();
        }
    }

    protected override void OnInitialized()
    {

        GetAll(IsApproved, NumberOfRecords);
    }

    void ApprovedChanged(bool value)
    {

        IsApproved = value;
        GetAll(IsApproved, NumberOfRecords);

    }

    private async Task ReloadTable()
    {
        GetAll(IsApproved, NumberOfRecords);
    }

    private int NumberOfRecords
    {
        get => numberOfRecords;
        set
        {
            if (numberOfRecords != value)
            {
                numberOfRecords = value;
                _ = ReloadTable();
            }
        }
    }

    private async Task OpenDialog(DrCrNoteModel tds, bool ReadOnly)
    {

        DialogOptions maxWidth = new DialogOptions() { MaxWidth = MaxWidth.Medium, FullWidth = true,ClassBackground="blur" };

        DialogParameters parms = new DialogParameters();
        parms.Add("model", tds);
        parms.Add("ReadOnly", ReadOnly);       
        var dialog = DialogService.Show<DrCrNoteDialog>(tds.DrCrNoteID == null ? "ADD" : "EDIT", parms, maxWidth);
        var result = await dialog.Result;

        GetAll(IsApproved, NumberOfRecords);
    }



    public void GetAll(bool val, int numberOfRecords)
    {
        int NumberOfRecords = numberOfRecords;
        collection = new List<DrCrNoteModel>();

        if (val)
        {
            collection = Iservice.SelectByApproved(NumberOfRecords, searchTerm).ToList();
        }
        else
        {
            collection = Iservice.SelectByUnapproved(NumberOfRecords, searchTerm).ToList();
        }
    }
    private void Delete(DrCrNoteModel tx)
    {
        Iservice.Delete(tx.DrCrNoteID, "Rijas");
        snackbar.Add("Deleted Successfully", Severity.Success);
        GetAll(IsApproved, NumberOfRecords);
    }

}
