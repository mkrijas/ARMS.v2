@inherits DialogFormComponentBase<DriverSalaryPayableModel>
@inject IDriverSalaryPayableService Iservice
@inject IJSRuntime JsRuntime


<DialogForm @ref="@dialogForm" ReadOnly="@ReadOnly" Title="Driver Salary Payable" Subtitle="Review and process monthly salary disbursements for driver personnel." Icon="@Icons.Material.Filled.Payments" AdminStyle="true" formID="DriverSalaryPayableForm" DocumentDetails="DocInfo" model="@model" TotalAmount="model.TotalAmount" _busy="_busy">
    <FormContent>
        <div class="dialog-content-wrapper">
            <EditForm id="DriverSalaryPayableForm" OnValidSubmit="OnValidSubmit" EditContext="editContext">
                <ObjectGraphDataAnnotationsValidator />
                
                <div class="admin-glass-card pa-6 mb-6">
                    <span class="admin-section-label">Payroll Period & Filters</span>
                    <MudGrid Spacing="3" Class="align-center">
                        <MudItem xs="12" md="3">
                            <MudDatePicker ReadOnly="ReadOnly" Label="Document Date" Variant="Variant.Outlined" Margin="Margin.Dense" DisableToolbar="true" Editable="true" @bind-Date="model.DocumentDate" DateFormat="dd/MM/yyyy" Class="admin-input-group" />
                        </MudItem>
                        <MudItem xs="12" md="3">
                            <MudDatePicker ReadOnly="ReadOnly" Label="From Date" Variant="Variant.Outlined" Margin="Margin.Dense" DisableToolbar="true" Editable="true" @bind-Date="model.FromDate" DateFormat="dd/MM/yyyy" MaxDate="DateTime.Now" Class="admin-input-group" />
                        </MudItem>
                        <MudItem xs="12" md="3">
                            <MudDatePicker ReadOnly="ReadOnly" Label="To Date" Variant="Variant.Outlined" Margin="Margin.Dense" DisableToolbar="true" Editable="true" @bind-Date="model.ToDate" DateFormat="dd/MM/yyyy" Class="admin-input-group" />
                        </MudItem>
                        <MudItem xs="12" md="3">
                            <MudButton Disabled="DisableSearch" Variant="Variant.Filled" Color="Color.Primary" OnClick="GetDrivers" FullWidth="true" Style="height: 45px; background: #FF9F43;" StartIcon="@Icons.Material.Filled.Search">Fetch Drivers</MudButton>
                        </MudItem>
                        <MudItem xs="12">
                            <MudTextField ReadOnly="ReadOnly" @bind-Value="model.Narration" Lines="2" Label="Overall Payroll Notes" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.Narration)" Class="admin-input-group"></MudTextField>
                        </MudItem>
                    </MudGrid>
                </div>

                <div class="admin-glass-card pa-0 overflow-hidden">
                    <div class="d-flex align-center justify-space-between px-6 py-4 border-bottom-subtle" style="background: rgba(255, 159, 67, 0.03); border-bottom: 1px solid rgba(255, 159, 67, 0.3);">
                        <span class="admin-section-label mb-0">Driver Payroll Breakdown</span>
                        <div style="width: 300px;">
                            <MudTextField @bind-Value="SearchTerm" Placeholder="Search by Name or Code..." Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.FilterList" Margin="Margin.Dense" Variant="Variant.Outlined" Class="admin-input-group" />
                        </div>
                    </div>

                    <div class="modern-admin-table">
                        <MudGrid Class="admin-table-header px-6 py-3">
                            <MudItem xs="3"><span class="admin-header-text">DRIVER INFORMATION</span></MudItem>
                            <MudItem xs="1"><span class="admin-header-text">DAYS</span></MudItem>
                            <MudItem xs="1"><span class="admin-header-text">TRIPS/KM</span></MudItem>
                            <MudItem xs="2"><span class="admin-header-text">GROSS / DEDUCTION</span></MudItem>
                            <MudItem xs="1"><span class="admin-header-text">NET AMT</span></MudItem>
                            <MudItem xs="3"><span class="admin-header-text">REFERENCE / ACTION</span></MudItem>
                        </MudGrid>

                        @foreach (var item in FilteredDrivers)
                        {
                            var rowindex = model.DriversLists.IndexOf(item);
                            <MudGrid Class="px-6 py-3 border-bottom-subtle align-center">
                                @if (editrow == rowindex)
                                {
                                    <MudItem xs="3">
                                        <MudText Typo="Typo.body2" Style="font-weight: 700;">@item.DriverName</MudText>
                                        <MudText Typo="Typo.caption" Style="color: #667085;">@item.DriverCode</MudText>
                                    </MudItem>
                                    <MudItem xs="1">
                                        <MudNumericField HideSpinButtons="true" @bind-Value="@List.WorkDays" Variant="Variant.Outlined" Margin="Margin.Dense" Class="admin-input-group"></MudNumericField>
                                    </MudItem>
                                    <MudItem xs="1">
                                        <MudText Typo="Typo.caption">T: @item.NoOfTrips</MudText>
                                        <MudText Typo="Typo.caption" Style="display: block;">KM: @item.RunKM</MudText>
                                    </MudItem>
                                    <MudItem xs="2">
                                        <MudNumericField HideSpinButtons="true" @bind-Value="@List.GrossSalary" TextChanged="(()=> List.NetSalary = List.GrossSalary - List.Deduction)" Label="Gross" Variant="Variant.Outlined" Margin="Margin.Dense" Class="admin-input-group" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.CurrencyRupee"></MudNumericField>
                                        <MudNumericField HideSpinButtons="true" @bind-Value="@List.Deduction" TextChanged="(()=> List.NetSalary = List.GrossSalary - List.Deduction)" Label="Ded." Variant="Variant.Outlined" Margin="Margin.Dense" Class="admin-input-group mt-1" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.CurrencyRupee"></MudNumericField>
                                    </MudItem>
                                    <MudItem xs="1">
                                        <MudText Typo="Typo.body2" Style="font-weight: 900; color: #FF9F43;">₹ @List.NetSalary</MudText>
                                    </MudItem>
                                    <MudItem xs="3" Class="d-flex align-center gap-2">
                                        <MudTextField @bind-Value="@List.Reference" Label="Ref/Notes" Variant="Variant.Outlined" Margin="Margin.Dense" Class="admin-input-group"></MudTextField>
                                        <MudIconButton OnClick="AddParticulars" Color="Color.Success" Variant="Variant.Filled" Icon="@Icons.Material.Filled.Check" Size="Size.Small" />
                                    </MudItem>
                                }
                                else
                                {
                                    <MudItem xs="3">
                                        <MudText Typo="Typo.body2" Style="font-weight: 700;">@item.DriverName</MudText>
                                        <MudText Typo="Typo.caption" Style="color: #667085;">@item.DriverCode</MudText>
                                    </MudItem>
                                    <MudItem xs="1">
                                        <MudChip T="string" Size="Size.Small" Variant="Variant.Text" Color="Color.Primary" Style="font-weight: 800;">@item.WorkDays d</MudChip>
                                    </MudItem>
                                    <MudItem xs="1">
                                        <MudText Typo="Typo.caption">T: @item.NoOfTrips</MudText>
                                        <MudText Typo="Typo.caption" Style="display: block;">KM: @item.RunKM</MudText>
                                    </MudItem>
                                    <MudItem xs="2">
                                        <MudText Typo="Typo.body2" Style="color: #141A46;">₹ @item.GrossSalary</MudText>
                                        <MudText Typo="Typo.caption" Style="color: #F44336;">Ded: ₹ @item.Deduction</MudText>
                                    </MudItem>
                                    <MudItem xs="1">
                                        <MudText Typo="Typo.body2" Style="font-weight: 900; color: #FF9F43;">₹ @item.NetSalary</MudText>
                                    </MudItem>
                                    <MudItem xs="3" Class="d-flex align-center justify-space-between">
                                        <MudText Typo="Typo.caption" Style="font-style: italic;">@item.Reference</MudText>
                                        <MudIconButton Disabled="ReadOnly" OnClick="@(() => EditEntry(rowindex))" Color="Color.Primary" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" />
                                    </MudItem>
                                }
                            </MudGrid>
                        }
                    </div>
                </div>
            </EditForm>
        </div>
    </FormContent>
    <VerificationStatus>
        <AutherizationStatusComponent CreatedBy="@model.UserInfo" DocTypeID="@DocInfo.DocumentTypeID" DocDate="@DocDate" DocumentID="model.ID" OnApprove="Approve"></AutherizationStatusComponent>
    </VerificationStatus>
</DialogForm>
<script>
    window.preventFormSubmitOnEnter = function () {
        document.addEventListener('keydown', function (event) {
            if (event.key === 'Enter') {
                event.preventDefault(); // Prevent default form submission
            }
        });
    }
</script>

@code {

    [Parameter]
    public override DriverSalaryPayableModel model { get { return _model; } set { _model = value; DocInfo.DocumentID = value.ID; } }
    private DriverSalaryPayableModel _model;
    public bool entryedit = true;
    private bool ShowAddEntry = false;
    // [Parameter]
    // public bool DisableAddition { get; set; } = false;

    public bool DisableSearch { get; set; } = false;

    private DriverSalaryPayableListModel List = new DriverSalaryPayableListModel();

    public string SearchTerm { get; set; } = "";

    protected override DocumentInfoModel DocInfo { get; set; } = new DocumentInfoModel()
        {
            DocumentTypeID = 141,
            DocumentName = "Driver Salary Payable"
        };
    // Lifecycle method called when the component is initialized
    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();

        if (model.NatureOfTransaction == null)
        {
            model.NatureOfTransaction = "Driver Salary Payable";
            model.TotalAmount = 0;
        }
        else if (model.ID != null && model.DriversLists.Count == 0)
        {
            DisableSearch = true;
            model.DriversLists = Iservice.GetDetails(model.ID).ToList(); // Fetch driver details
        }
        model.TotalAmount = model.DriversLists.Sum(x => x.NetSalary);
    }

    // Property to filter drivers based on the search term
    public IEnumerable<DriverSalaryPayableListModel> FilteredDrivers => string.IsNullOrWhiteSpace(SearchTerm)
    ? model.DriversLists
    : model.DriversLists.Where(x =>
        (x.DriverName?.Contains(SearchTerm, StringComparison.OrdinalIgnoreCase) ?? false) ||
        (x.DriverCode?.Contains(SearchTerm, StringComparison.OrdinalIgnoreCase) ?? false));

    // Method to handle key down events
    private async Task HandleKeyDown(KeyboardEventArgs args)
    {
        if (args.Key == "Enter")
        {
            await JsRuntime.InvokeVoidAsync("preventFormSubmitOnEnter");
        }
    }

    private int editrow = -1;

    // Method to edit an entry in the driver list
    public void EditEntry(int a)
    {
        editrow = a;
        ShowAddEntry = false; // Close add row when editing
        List = (DriverSalaryPayableListModel)model.DriversLists[editrow].Clone();
    }

    // Method to update approval status of the document
    protected override int UpdateApproval(DataApprovedStatus aprvd)
    {
        int result = Iservice.Approve(model.ID, model.UserInfo.UserID, aprvd.Remarks); // Call service to approve
        return result;
    }

    // Method to add particulars to the driver list
    public void AddParticulars()
    {
        if (dialogForm.validate(List, editContext))
        {
            if (editrow > -1)
            {
                model.DriversLists[editrow] = (DriverSalaryPayableListModel)List.Clone();
                editrow = -1;
            }
            else
            {
                model.DriversLists.Add(List);
            }
            List = new();
        }
        model.TotalAmount = model.DriversLists.Sum(x => x.NetSalary);
    }

    // Method to calculate the total amount based on driver lists
    public void CalculateTotalAmount()
    {
        model.TotalAmount = model.DriversLists.Sum(x => x.NetSalary);
    }

    // Method to update the DriverSalaryPayableModel
    protected override async Task<int> Update(DriverSalaryPayableModel editModel)
    {
        var UpdatedModel = Iservice.Update(model); // Call service to update the model
        model.ID = UpdatedModel.ID;
        return model.ID.Value;
    }

    // Method to fetch drivers based on branch and date range
    private async Task GetDrivers()
    {
        model.DriversLists = Iservice.GetLists(model.BranchID, model.FromDate, model.ToDate).ToList(); // Fetch driver lists
    }

}

