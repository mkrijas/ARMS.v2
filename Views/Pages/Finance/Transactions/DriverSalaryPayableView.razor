@page "/DriverSalaryPayableView/"
@page "/DriverSalaryPayableView/{id:int}"

@inherits ViewComponentBase<DriverSalaryPayableModel>
@inject IDriverSalaryPayableService Iservice
@inject IDialogService DialogService


    <div class="fade-in">
        <div class="admin-header-tiered mb-6">
            <div class="d-flex align-center justify-space-between">
                <div>
                    <MudText Typo="Typo.h4" Class="admin-title">Driver Salary Payable</MudText>
                    <MudText Typo="Typo.body2" Class="admin-subtitle">Manage and process monthly salary disbursements for drivers. Review payable amounts, verify deductions, and authorize payroll transfers.</MudText>
                </div>
                <MudButton StartIcon="@Icons.Material.Filled.Add" Variant="Variant.Filled" Color="Color.Primary" Class="admin-register-btn" OnClick="@(()=> OpenForm(new DriverSalaryPayableModel()))" Disabled="@_busy">NEW SALARY ENTRY</MudButton>
            </div>
        </div>

        <div class="admin-glass-card mb-6 pa-4">
            <div class="d-flex align-center gap-4 flex-wrap">    
            <div style="flex-grow: 1; min-width: 300px;">
                <MudTextField @bind-Value="searchTerm" Placeholder="Search by document number or usage code..." Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" Variant="Variant.Outlined" Margin="Margin.Dense" Class="admin-input-group" Clearable="true" OnKeyUp="HandleSearchKeyUp" />
            </div>
                <div class="d-flex align-center gap-4">
                    <MudCheckBox T="bool" Label="Approved Entries" ValueChanged="((bool value)=>ToggleData(value))" Value="@ShowApproved" Size="Size.Medium" Color="Color.Primary" Class="fw-600" />
                </div>
            </div>
        </div>

        <div class="admin-glass-card pa-0 overflow-hidden">
            <MudTable ServerData="LoadServerData" T="DriverSalaryPayableModel" @ref="_table"  Elevation="0" Class="modern-admin-table" Hover="true">
            <LoadingContent>
                <div @key="@("loader")" style="display: flex; justify-content: center; align-items: center; min-height: 400px;">
                    <LoaderComponent IsFullScreen="false"
                                     ShowLogo="false"
                                     Size="large"
                                     LoadingText="Loading...."
                                     SubText="Fetching Data..." />
                </div>
            </LoadingContent>
                <HeaderContent>
                    <MudTh><MudTableSortLabel SortBy="new Func<DriverSalaryPayableModel, object>(x=> x.DocumentDate)"><span class="admin-header-text">DATE</span></MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<DriverSalaryPayableModel, object>(x=> x.DocumentNumber)" InitialDirection="SortDirection.Descending"><span class="admin-header-text">DOC NUMBER</span></MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<DriverSalaryPayableModel, object>(x=> x.TotalAmount)"><span class="admin-header-text">TOTAL AMOUNT</span></MudTableSortLabel></MudTh>
                    <MudTh Style="text-align: right;"><span class="admin-header-text">ACTIONS</span></MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Date"><span class="fw-500">@context.DocumentDate?.ToString("dd MMM yyyy")</span></MudTd>
                    <MudTd DataLabel="DocNumber">
                        <div class="d-flex flex-column">
                            <span class="admin-td-primary fw-700">@context.DocumentNumber</span>
                            @if (context.AuthLevelId == 100)
                            {
                                <MudText Typo="Typo.caption" Color="Color.Error" Class="fw-700">REJECTED</MudText>
                            }
                        </div>
                    </MudTd>
                    <MudTd DataLabel="Amount">
                        <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Text" Class="fw-700">@context.TotalAmount?.ToString("N2")</MudChip>
                    </MudTd>
                    <MudTd DataLabel="Actions" Style="text-align: right;">
                        <div class="d-flex justify-end gap-1">
                            @if (@context.AuthLevelId == 99)
                            {
                                <EntryReversedComponent DocTypeID="DocInfo.DocumentTypeID" DocumentID="context.ID" MID="context.MID" DocumentNumber="@context.DocumentNumber"></EntryReversedComponent>
                            }
                            else if (@context.AuthLevelId != 100)
                            {
                                <MudTooltip Text="Verify Salary">
                                    <MudIconButton OnClick="@(()=> OpenForm(context,true))" Color="Color.Warning" Icon="@Icons.Material.Filled.Verified" Size="Size.Small" Variant="Variant.Text" />
                                </MudTooltip>
                            }

                            <MudTooltip Text="View Details">
                                <MudIconButton OnClick="@(()=> OpenForm(context,true))" Color="Color.Info" Icon="@Icons.Material.Filled.Visibility" Size="Size.Small" Variant="Variant.Text" />
                            </MudTooltip>

                            <MudTooltip Text="Edit Salary">
                                <MudIconButton Disabled="@(context.AuthLevelId != null)" OnClick="@(()=> OpenForm(context,false))" Color="Color.Primary" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Variant="Variant.Text" />
                            </MudTooltip>

                            <MudTooltip Text="Delete Record">
                                <MudIconButton Disabled="@(context.AuthLevelId != null)" OnClick="@(()=> Delete(context.ID))" Color="Color.Error" Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Variant="Variant.Text" />
                            </MudTooltip>
                        </div>
                    </MudTd>
                </RowTemplate>
                <PagerContent>
                    <div class="pa-4">
                        <MudTablePager PageSizeOptions="new int[] { 10, 20, 50, 100 }" />
                    </div>
                </PagerContent>
            </MudTable>
        </div>
    </div>


@code {

    private bool _isLoading = true;    

    protected override List<DriverSalaryPayableModel> _collection { get; set; } = new();
    protected override DocumentInfoModel DocInfo { get; set; } = new DocumentInfoModel()
        {
            DocumentTypeID = 141,
            DocumentName = "Driver Salary Payable"
        };

    // Lifecycle method called when the component is initialized
    protected override async Task OnInitializedAsync()
    {
       
        await base.OnInitializedAsync();
        var authprov = await auth.GetAuthenticationStateAsync();
        var User = authprov.User;

        if (id != null && _collection != null && _collection.Any(g => g.ID == id))
        {
            await OpenForm(_collection.FirstOrDefault(s => s.ID == id), true);
        }       
        _isLoading = false;
    }

   
      

    // Method to open a dialog form for adding or editing a DriverSalaryPayableModel
    protected override async Task OpenForm(DriverSalaryPayableModel model, bool ReadOnly = false, bool DisableAddition = false)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        _busy = true;
        DialogOptions mediumWidth = new DialogOptions() { MaxWidth = MaxWidth.Large, FullWidth = true };
        DialogParameters parms = new DialogParameters();
        parms.Add("model", model.Clone());
        parms.Add("ReadOnly", ReadOnly);
        parms.Add("OnApproved", new EventCallbackFactory().Create(this, async () => await _table.ReloadServerData()));
        var dialog = await dialogService.ShowAsync<DriverSalaryPayableDialog>(model == null ? "ADD" : "EDIT", parms, mediumWidth);
        var result = await dialog.Result;
        var isCancelled = result.Canceled;
        if (!isCancelled)
        {
            var ReturnData = (DriverSalaryPayableModel)result.Data;
            await _table.ReloadServerData();
        }   
        await Task.Delay(200);
        _busy = false;
    }
}
