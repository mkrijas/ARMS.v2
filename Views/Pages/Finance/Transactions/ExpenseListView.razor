@inject IDialogService DialogService
@inject MudBlazor.ISnackbar snackbar
@inject ITdsRateService tdsService
@inject IGstUsageIDService usageIservice


@if (!ReadOnly || ExpenseList.Any())
{
    <MudItem xs="12" Style="overflow-x:auto; overflow-y:hidden;">
        <h6><u>Particulars</u></h6>
        <div style="width: 1600px;" class="pb-3">
            <MudGrid Justify="Justify.Center">
                <MudItem xs="3"><span class="HeadText">Usage Code</span></MudItem>
                <MudItem xs="2"><span class="HeadText">Reference</span></MudItem>
                <MudItem xs="2"><span class="HeadText">Cost Center</span></MudItem>
                <MudItem xs="2"><span class="HeadText">Dimension</span></MudItem>
                <MudItem xs="1"><span class="HeadText">Amount</span></MudItem>
                <MudItem xs="1"><span class="HeadText">Gst/TDS</span></MudItem>
                <MudItem xs="1"><span class="HeadText">Actions</span></MudItem>
                @foreach (var item in ExpenseList)
                {
                    <MudItem xs="3">@string.Format("{0} | {1}", item.UsageCode, item.UsageCodeDescription)</MudItem>
                    <MudItem xs="2">@item.BillReference</MudItem>
                    <MudItem xs="2">
                        @item.CostCenterVal
                    </MudItem>
                    <MudItem xs="2">
                        @item.DimensionVal
                    </MudItem>
                    <MudItem xs="1">@item.Amount</MudItem>
                    <MudItem xs="1">@(item.CGST + item.SGST + item.IGST)/@item.TDS</MudItem>
                    <MudItem xs="1">
                        @if (!ReadOnly)
                        {
                            <MudIconButton Title="Delete" Color="Color.Error" @onclick="@(()=> DeleteExpenses(@item))" Icon="@Icons.Material.Filled.Delete" Size="Size.Small" />
                        }
                        <MudIconButton Title="Show Taxes" Color="Color.Info" @onclick="@(()=> OpenDialogTaxRates(@item))" Icon="@Icons.Material.Filled.CurrencyExchange" Size="Size.Small" />
                    </MudItem>
                }
                @if (!ReadOnly)
                {
                    <MudItem xs="3">
                        <UsageCodeSelector Value=gstusge ValueChanged="UsageCodeSelected"></UsageCodeSelector>
                    </MudItem>
                    <MudItem xs="2">
                        <MudTextField Label="Bill Reference" @bind-Value="Model.BillReference" Variant="Variant.Outlined" Margin="Margin.Dense"></MudTextField>
                    </MudItem>
                    <MudItem xs="2">
                        <CostCenterSelector @bind-Value="@Model.CostCenter" @bind-ValueText="@Model.CostCenterVal" ReadOnly="@ReadOnly"></CostCenterSelector>
                    </MudItem>
                    <MudItem xs="2">
                        <DimensionSelector @bind-Value="@Model.Dimension" @bind-ValueText="@Model.DimensionVal" ReadOnly="@ReadOnly"></DimensionSelector>
                    </MudItem>
                    <MudItem xs="2">
                        <MudNumericField  
                HideSpinButtons
                         Label="Amount" @bind-Value="Model.Amount" Variant="Variant.Outlined" Margin="Margin.Dense"></MudNumericField>
                     </MudItem>
                    <MudItem xs="1" Class="d-flex align-center">
                        <MudIconButton Title="Add" OnClick="ADD" Color="Color.Primary" Icon="@Icons.Material.Filled.Add" Size="Size.Small" />
                    </MudItem>
                }
            </MudGrid>
        </div>
    </MudItem>
}
@code {

    [Parameter]
    public List<TaxPurchaseExpenseModel> ExpenseList { get; set; }
    [Parameter]
    public bool ReadOnly { get; set; }
    [Parameter]
    public DateTime? DocDate { get; set; }
    [Parameter]
    public int? BranchID { get; set; }
    [Parameter]
    public PartyModel PartyInfo { get; set; }
    [Parameter]
    public bool Local { get; set; } = true;
    [Parameter]
    public bool IsTaxable { get; set; } = true;
    [Parameter]
    public EventCallback<TaxPurchaseExpenseModel> OnExpenseAdded { get; set; }
    [Parameter]
    public EventCallback OnAmountChange { get; set; }
    GstUsageCodeModel gstusge;
    TaxPurchaseExpenseModel Model = new TaxPurchaseExpenseModel();
    EditContext editContext;
    private bool _busy;

    // Lifecycle method called when parameters are set
    protected override void OnParametersSet()
    {
        if (editContext == null)
        {
            editContext = new EditContext(Model);
            editContext.EnableDataAnnotationsValidation();
        }
    }

    // Method to add a new expense
    public async Task ADD()
    {
        Model.BranchID = BranchID;
        if (AddTax() && editContext.Validate())
        {
            await OnExpenseAdded.InvokeAsync(Model);
            Model = new();
            gstusge = null;
        }
        else
        {
            snackbar.Add("Entered particulars are invalid.", Severity.Error);
        }
    }

    // Method to handle selection of a GST usage code
    void UsageCodeSelected(GstUsageCodeModel u)
    {
        gstusge = u;
        Model.UsageCode = gstusge?.UsageCode;
        Model.CoaID = gstusge?.CoaID;
        Model.UsageCodeDescription = gstusge?.Description;
        Model.GstMechanism = gstusge?.GstMechanism;
    }

    // Method to open a dialog for tax rates
    private async Task OpenDialogTaxRates(TaxPurchaseExpenseModel i)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        _busy = true;
        GstModel taxModel = new GstModel();
        taxModel.CGST = i.CGST;
        taxModel.IGST = i.IGST;
        taxModel.TDS = i.TDS;
        taxModel.SGST = i.SGST;
        taxModel.GstRate = i.GstRate;
        DialogParameters parms = new DialogParameters();
        parms.Add("tax", taxModel);
        parms.Add("ReadOnly", ReadOnly);
        var dialog = DialogService.Show<TaxRatedialog>(i.PID == null ? "ADD" : "EDIT", parms, new DialogOptions() { MaxWidth = MaxWidth.Small, FullWidth = true });
        var result = await dialog.Result;
        if (!result.Canceled)
        {
            taxModel = (GstModel)result.Data;
            i.CGST = taxModel.CGST;
            i.IGST = taxModel.IGST;
            i.TDS = taxModel.TDS;
            i.SGST = taxModel.SGST;
            i.GstRate = taxModel.GstRate;

            await OnAmountChange.InvokeAsync();
        }
        await Task.Delay(200);
        _busy = false;
    }

    // Method to delete an expense from the list
    private async Task DeleteExpenses(TaxPurchaseExpenseModel i)
    {
        int rowIndex = ExpenseList.IndexOf(i);
        ExpenseList.RemoveAt(rowIndex);
        await OnAmountChange.InvokeAsync();
    }

    // Method to add tax information to the expense model
    private bool AddTax()
    {
        if (gstusge != null && Model.Amount != null)
        {
            if (PartyInfo == null)
            {
                snackbar.Add("select party", Severity.Error);
                return false;
            }

            // Get the GST rate based on the usage code
            Model.GstRate = usageIservice.GetGstRate(Model.UsageCode, DocDate) ?? 0;
            decimal tdsRate = tdsService.GetTdsRate(PartyInfo.PartyID, Model.CoaID); // Get TDS rate
            Model.TDS = Math.Round((Model.Amount.Value * tdsRate) / 100, MidpointRounding.AwayFromZero);
            if(!IsTaxable  && gstusge.GstMechanism != "RCM")
            {
                return true;
            }
            
            decimal taxRate = Model.GstRate.Value;

            if (!Local)
            {
                Model.IGST = Math.Round(Model.Amount.Value * taxRate / 100, 2);
            }
            else
            {
                Model.SGST = Model.CGST = Math.Round(Model.Amount.Value * taxRate / 200, 2);
            }
           
            return true;
        }
        return false;
    }
}