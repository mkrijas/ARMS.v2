@inject IDialogService DialogService
@inject MudBlazor.ISnackbar snackbar

@inject ITdsRateService tdsService
@inject IGstUsageIDService usageIservice



    <h6>Expenses</h6>

   
    <MudSimpleTable Hover="true" Dense="true" >
        <thead>
            <tr>
                <th width="30%" >Usage Code</th>               
                <th width="20%" >Reference</th>
                <th width="15%" >Amount</th>
                <th width="15%" >Gst/TDS</th>
                <th width="20%" ></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in ExpenseList)
            {
                <tr>
                    <td >@item.UsageCode</td>
                    <td>@item.Amount</td>
                    <td>@item.BillReference</td>
                    <td>
                        @(item.CGST+item.SGST+item.IGST)/@item.TDS
                    </td>
                    <td>
                        @if (!ReadOnly)
                        {
                            <MudFab Color="Color.Error" @onclick="@(()=> DeleteExpenses(@item))" Icon="@Icons.Material.Filled.Delete" Size="Size.Small" IconSize="Size.Small" />
                            <MudFab Color="Color.Info" @onclick="@(()=> OpenDialogTaxRates(@item))" Icon="@Icons.Material.Filled.CurrencyExchange" Size="Size.Small" IconSize="Size.Small" />
                        }
                    </td>
                </tr>
            }
            @if (!ReadOnly)
            {
                
                <tr>
                    <td>
                        <UsageCodeSelector Value=gstusge  ValueChanged="UsageCodeSelected"></UsageCodeSelector>                        
                    </td>                   
                    <td colspan="2">
                        <MudTextField Label="Bill Reference" @bind-Value="Model.BillReference" Variant="Variant.Outlined" Margin="Margin.Dense" ></MudTextField>
                    </td>
                    <td>
                        <MudTextField Label="Amount" @bind-Value="Model.Amount" Variant="Variant.Outlined" Margin="Margin.Dense" ></MudTextField>
                    </td>
                    <td>
                            <MudFab OnClick="ADD" Color="Color.Primary" Icon="@Icons.Material.Filled.Add" Size="Size.Small" IconSize="Size.Small" />
                    </td>
                </tr>
               
            }
        </tbody>
    </MudSimpleTable>
   


@code {

    [Parameter]
    public List<TaxPurchaseExpenseModel> ExpenseList { get; set; }
    [Parameter]
    public bool ReadOnly { get; set; }
    [Parameter]
    public int? BranchID { get; set; }
    [Parameter]
    public PartyModel PartyInfo { get; set; }
    [Parameter]
    public bool Local { get; set; } = true;
    [Parameter]
    public EventCallback<TaxPurchaseExpenseModel> OnExpenseAdded { get; set; }
    [Parameter]
    public EventCallback OnDelete { get; set; }


    GstUsageCodeModel gstusge;
    TaxPurchaseExpenseModel Model = new TaxPurchaseExpenseModel();
    EditContext editContext;


    protected override void OnParametersSet()
    {
        if (editContext == null)
        {
            editContext = new EditContext(Model);
            editContext.EnableDataAnnotationsValidation();
        }
    }

    public async Task ADD()
    {  
        
        Model.BranchID = BranchID;        
        if (AddTax() && editContext.Validate())
        {
            await OnExpenseAdded.InvokeAsync(Model);
            Model = new();
            gstusge = null;
        }
    }


    void UsageCodeSelected(GstUsageCodeModel u)
    {
        gstusge = u;
        Model.UsageCode = gstusge?.UsageCode;
        Model.CoaID = gstusge?.CoaID;
    }




    private async Task OpenDialogTaxRates(TaxPurchaseExpenseModel i)
    {
        GstModel taxModel = new GstModel();
        taxModel.CGST = i.CGST;
        taxModel.IGST = i.IGST;
        taxModel.TDS = i.TDS;
        taxModel.SGST = i.SGST;
        taxModel.GstRate = i.GstRate;
        DialogParameters parms = new DialogParameters();
        parms.Add("tax", taxModel);
        parms.Add("IsReadOnly", ReadOnly);
        var dialog = DialogService.Show<TaxRatedialog>(i.PID == null ? "ADD" : "EDIT", parms, new DialogOptions() { MaxWidth = MaxWidth.Small, FullWidth = true });
        var result = await dialog.Result;
        if (!result.Canceled)
        {
            taxModel = (GstModel)result.Data;            
            i.CGST = taxModel.CGST;
            i.IGST = taxModel.IGST;
            i.TDS = taxModel.TDS;
            i.SGST = taxModel.SGST;
            i.GstRate = taxModel.GstRate;
        }
    }

    private async Task DeleteExpenses(TaxPurchaseExpenseModel i)
    { 
        int rowIndex = ExpenseList.IndexOf(i);
        ExpenseList.RemoveAt(rowIndex);
        await OnDelete.InvokeAsync();
    }

    private bool AddTax()
    {
        if (gstusge != null && Model.Amount != null)
        {
            if (PartyInfo == null)
            {
                snackbar.Add("select party", Severity.Error);
                return false;
            }

            Model.GstRate = usageIservice.GetGstRate(Model.UsageCode, DateTime.Now);
            decimal taxRate = Model.GstRate ?? 0;
            if (!Local)
            {
                Model.IGST = Math.Round(Model.Amount.Value * taxRate / 100, 2);
            }
            else
            {
                Model.SGST = Model.CGST = Math.Round(Model.Amount.Value * taxRate / 200, 2);
            }

            decimal tdsRate = tdsService.GetTdsRate(PartyInfo.PartyID , Model.CoaID );            
            Model.TDS = Math.Round((Model.Amount.Value * tdsRate) / 100 ,2);
            return true;
        }
        return false;
    }


    


}
