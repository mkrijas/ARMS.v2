@inject IDialogService DialogService
@inject MudBlazor.ISnackbar snackbar
@inject ITdsRateService tdsService
@inject IGstUsageIDService usageIservice


@if (!ReadOnly || ExpenseList.Any())
{
    <MudItem xs="12">
        <div class="modern-admin-table pb-3">
            <MudGrid Justify="Justify.Center" Class="admin-table-header mb-2 py-3 px-4">
                <MudItem xs="@(ShowAdvanced ? 3 : 4)"><span class="admin-header-text" style="font-size: 0.9rem !important;">EXPENSE ACCOUNT</span></MudItem>
                <MudItem xs="@(ShowAdvanced ? 2 : 3)"><span class="admin-header-text" style="font-size: 0.9rem !important;">BILL REF</span></MudItem>
                @if (ShowAdvanced)
                {
                    <MudItem xs="2"><span class="admin-header-text" style="font-size: 0.9rem !important;">COST CENTER</span></MudItem>
                    <MudItem xs="1"><span class="admin-header-text" style="font-size: 0.9rem !important;">DIMENSION</span></MudItem>
                }
                <MudItem xs="1"><span class="admin-header-text" style="font-size: 0.9rem !important;">AMOUNT</span></MudItem>
                <MudItem xs="2"><span class="admin-header-text" style="font-size: 0.9rem !important;">TAX / TDS</span></MudItem>
                <MudItem xs="1"><span class="admin-header-text" style="font-size: 0.9rem !important;">ACTIONS</span></MudItem>
            </MudGrid>
            @foreach (var item in ExpenseList)
            {
                <MudGrid Justify="Justify.Center" Class="py-3 border-bottom-subtle px-4 align-center" style="border-bottom: 1px solid rgba(54, 117, 136, 0.2) !important;">
                    <MudItem xs="@(ShowAdvanced ? 3 : 4)">
                        <MudText Typo="Typo.body1" Style="font-weight: 700; color: #141A46; font-size: 1rem;">@( string.Format("{0} | {1}-{2}", item.UsageCode, item.UsageCodeDescription, item.GstMechanism))</MudText>
                    </MudItem>
                    <MudItem xs="@(ShowAdvanced ? 2 : 3)">
                        <MudText Typo="Typo.body1" Style="font-size: 0.95rem;">@item.BillReference</MudText>
                    </MudItem>
                    @if (ShowAdvanced)
                    {
                        <MudItem xs="2">
                            <MudText Typo="Typo.body1" Style="font-size: 0.9rem;">@item.CostCenterVal</MudText>
                        </MudItem>
                        <MudItem xs="1">
                            <MudText Typo="Typo.body1" Style="font-size: 0.9rem;">@item.DimensionVal</MudText>
                        </MudItem>
                    }
                    <MudItem xs="1">
                        <MudText Typo="Typo.body1" Style="font-weight: 800; color: #FF9F43; font-size: 1.05rem;">@item.Amount</MudText>
                    </MudItem>
                    <MudItem xs="2">
                         <MudText Typo="Typo.body2" Color="Color.Secondary" Style="font-weight: 600; font-size: 0.9rem;">@(item.CGST + item.SGST + item.IGST) / @item.TDS</MudText>
                    </MudItem>
                    <MudItem xs="1" Class="d-flex">
                        @if (!ReadOnly)
                        {
                            <MudIconButton Title="Delete" Color="Color.Error" @onclick="@(()=> DeleteExpenses(@item))" Icon="@Icons.Material.Filled.DeleteOutline" Size="Size.Medium" />
                        }
                        <MudIconButton Title="Show Taxes" Color="Color.Surface" @onclick="@(()=> OpenDialogTaxRates(@item))" Icon="@Icons.Material.Filled.Percent" Size="Size.Medium" />
                    </MudItem>
                </MudGrid>
            }
            @if (!ReadOnly)
            {
                <div class="pa-5" style="background: rgba(255, 159, 67, 0.03); border-top: 1px solid rgba(255, 159, 67, 0.1);">
                    <MudGrid Justify="Justify.Center" Spacing="2" AlignItems="AlignItems.Center">
                        <MudItem xs="12" md="@(ShowAdvanced ? 3 : 5)">
                            <UsageCodeSelector Class="admin-input-group" Value=gstusge ValueChanged="UsageCodeSelected" LabelName="Expense Account" />
                        </MudItem>
                        <MudItem xs="6" md="2">
                            <MudTextField Class="admin-input-group" Label="Bill Ref" @bind-Value="Model.BillReference" Variant="Variant.Outlined" Margin="Margin.Dense"></MudTextField>
                        </MudItem>
                        @if (ShowAdvanced)
                        {
                            <MudItem xs="6" md="2">
                                <CostCenterSelector Class="admin-input-group" @bind-Value="@Model.CostCenter" @bind-ValueText="@Model.CostCenterVal" ReadOnly="@ReadOnly"></CostCenterSelector>
                            </MudItem>
                            <MudItem xs="6" md="2">
                                <DimensionSelector Class="admin-input-group" @bind-Value="@Model.Dimension" @bind-ValueText=@Model.DimensionVal ReadOnly="@ReadOnly"></DimensionSelector>
                            </MudItem>
                        }
                        <MudItem xs="6" md="2">
                            <MudNumericField Class="admin-input-group" Label="Amount" @bind-Value="Model.Amount" Variant="Variant.Outlined" Margin="Margin.Dense" HideSpinButtons="true" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.CurrencyRupee" AdornmentColor="Color.Primary"></MudNumericField>
                        </MudItem>
                        <MudItem xs="6" md="1" Class="d-flex align-center">
                             <MudSpacer />
                             <MudIconButton Title="Add" OnClick="ADD" Color="Color.Primary" Variant="Variant.Filled" Style="background: #FF9F43; border-radius: 10px; height: 45px; width: 50px;" Icon="@Icons.Material.Filled.Add" Size="Size.Medium" />
                        </MudItem>
                    </MudGrid>
                </div>
            }
        </div>
    </MudItem>
}
else if (ReadOnly && !ExpenseList.Any())
{
    <MudItem xs="12">
        <div class="d-flex flex-column align-center justify-center py-12 modern-admin-table" style="background: rgba(54, 117, 136, 0.02); border: 1px dashed rgba(54, 117, 136, 0.3); border-radius: 16px;">
            <MudIcon Icon="@Icons.Material.Filled.ReceiptLong" Style="font-size: 3rem; color: rgba(54, 117, 136, 0.2);" Class="mb-3" />
            <MudText Typo="Typo.h6" Style="color: #667085; font-weight: 600;">No expenses recorded</MudText>
            <MudText Typo="Typo.body2" Style="color: #94a3b8;">This transaction does not contain any expense line items.</MudText>
        </div>
    </MudItem>
}
@code {

    [Parameter]
    public List<TaxPurchaseExpenseModel> ExpenseList { get; set; }
    [Parameter]
    public bool ReadOnly { get; set; }
    [Parameter]
    public DateTime? DocDate { get; set; }
    [Parameter]
    public int? BranchID { get; set; }
    [Parameter]
    public PartyModel PartyInfo { get; set; }
    [Parameter]
    public bool ShowAdvanced { get; set; }
    [Parameter]
    public bool Local { get; set; } = true;
    [Parameter]
    public bool IsTaxable { get; set; } = true;
    [Parameter]
    public EventCallback<TaxPurchaseExpenseModel> OnExpenseAdded { get; set; }
    [Parameter]
    public EventCallback OnAmountChange { get; set; }
    GstUsageCodeModel gstusge;
    TaxPurchaseExpenseModel Model = new TaxPurchaseExpenseModel();
    EditContext editContext;
    private bool _busy;

    // Lifecycle method called when parameters are set
    protected override void OnParametersSet()
    {
        if (editContext == null)
        {
            editContext = new EditContext(Model);
            editContext.EnableDataAnnotationsValidation();
        }
    }

    // Method to add a new expense
    public async Task ADD()
    {
        Model.BranchID = BranchID;
        if (AddTax() && editContext.Validate())
        {
            await OnExpenseAdded.InvokeAsync(Model);
            Model = new();
            editContext = new EditContext(Model);
            editContext.EnableDataAnnotationsValidation();
            gstusge = null;
            StateHasChanged();
        }
        else
        {
            snackbar.Add("Entered particulars are invalid.", Severity.Error);
        }
    }

    // Method to handle selection of a GST usage code
    void UsageCodeSelected(GstUsageCodeModel u)
    {
        gstusge = u;
        Model.UsageCode = gstusge?.UsageCode;
        Model.CoaID = gstusge?.CoaID;
        Model.UsageCodeDescription = gstusge?.Description;
        Model.GstMechanism = gstusge?.GstMechanism;
    }

    // Method to open a dialog for tax rates
    private async Task OpenDialogTaxRates(TaxPurchaseExpenseModel i)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        _busy = true;
        GstModel taxModel = new GstModel();
        taxModel.CGST = i.CGST;
        taxModel.IGST = i.IGST;
        taxModel.TDS = i.TDS;
        taxModel.SGST = i.SGST;
        taxModel.GstRate = i.GstRate;
        DialogParameters parms = new DialogParameters();
        parms.Add("tax", taxModel);
        parms.Add("ReadOnly", ReadOnly);
        var dialog = await DialogService.ShowAsync<TaxRatedialog>(i.PID == null ? "ADD" : "EDIT", parms, new DialogOptions() { MaxWidth = MaxWidth.Small, FullWidth = true });
        var result = await dialog.Result;
        if (!result.Canceled)
        {
            taxModel = (GstModel)result.Data;
            i.CGST = taxModel.CGST;
            i.IGST = taxModel.IGST;
            i.TDS = taxModel.TDS;
            i.SGST = taxModel.SGST;
            i.GstRate = taxModel.GstRate;

            await OnAmountChange.InvokeAsync();
        }
        await Task.Delay(200);
        _busy = false;
    }

    // Method to delete an expense from the list
    private async Task DeleteExpenses(TaxPurchaseExpenseModel i)
    {
        int rowIndex = ExpenseList.IndexOf(i);
        ExpenseList.RemoveAt(rowIndex);
        await OnAmountChange.InvokeAsync();
    }

    // Method to add tax information to the expense model
    private bool AddTax()
    {
        if (gstusge != null && Model.Amount != null)
        {
            if (PartyInfo == null)
            {
                snackbar.Add("select party", Severity.Error);
                return false;
            }

            // Get the GST rate based on the usage code
            Model.GstRate = usageIservice.GetGstRate(Model.UsageCode, DocDate) ?? 0;
            decimal tdsRate = tdsService.GetTdsRate(PartyInfo.PartyID, Model.CoaID); // Get TDS rate
            Model.TDS = Math.Round((Model.Amount.Value * tdsRate) / 100, MidpointRounding.AwayFromZero);
            if(!IsTaxable  && gstusge.GstMechanism != "RCM")
            {
                return true;
            }
            
            decimal taxRate = Model.GstRate.Value;

            if (!Local)
            {
                Model.IGST = Math.Round(Model.Amount.Value * taxRate / 100, 2);
            }
            else
            {
                Model.SGST = Model.CGST = Math.Round(Model.Amount.Value * taxRate / 200, 2);
            }
           
            return true;
        }
        return false;
    }
}
