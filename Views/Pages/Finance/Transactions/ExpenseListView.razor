@inject IDialogService DialogService
@inject MudBlazor.ISnackbar snackbar
@inject ITdsRateService tdsService
@inject IGstUsageIDService usageIservice

<h6><u>Particulars</u></h6>
<div style="width:1000px">
<MudGrid Justify="Justify.Center">
    <MudItem ><span class="HeadText">Usage Code</span></MudItem>
    <MudItem ><span class="HeadText">Reference</span></MudItem>
    <MudItem ><span class="HeadText">Amount</span></MudItem>
    <MudItem ><span class="HeadText">Gst/TDS</span></MudItem>
        <MudItem ><span class="HeadText">Cost Center</span></MudItem>
        <MudItem ><span class="HeadText">Dimension</span></MudItem>
    <MudItem xs="1"></MudItem>
    @foreach (var item in ExpenseList)
    {
        <MudItem >@string.Format("{0} | {1}", item.UsageCode,item.UsageCodeDescription)</MudItem>
        <MudItem >@item.BillReference</MudItem>
        <MudItem >@item.Amount</MudItem>
        <MudItem >@(item.CGST + item.SGST + item.IGST)/@item.TDS</MudItem>
        <MudItem >
           @Model.CostCenterVal
        </MudItem>
        <MudItem  >
            @Model.DimensionVal
        </MudItem>
        <MudItem  Class="d-flex">
            @if (!ReadOnly)
            {
                <MudIconButton Title="Delete" Color="Color.Error" @onclick="@(()=> DeleteExpenses(@item))" Icon="@Icons.Material.Filled.Delete" Size="Size.Small" />
                <MudIconButton Title="Show Taxes" Color="Color.Info" @onclick="@(()=> OpenDialogTaxRates(@item))" Icon="@Icons.Material.Filled.CurrencyExchange" Size="Size.Small" />
            }
        </MudItem>
    }
    @if (!ReadOnly)
    {
        <MudItem >
            <UsageCodeSelector Value=gstusge ValueChanged="UsageCodeSelected"></UsageCodeSelector>
        </MudItem>
        <MudItem ><MudTextField Label="Bill Reference" @bind-Value="Model.BillReference" Variant="Variant.Outlined" Margin="Margin.Dense"></MudTextField></MudItem>
        <MudItem ><MudNumericField HideSpinButtons Label="Amount" @bind-Value="Model.Amount" Variant="Variant.Outlined" Margin="Margin.Dense"></MudNumericField></MudItem>
        <MudItem >
            <CostCenterSelector @bind-Value="@Model.CostCenter" ReadOnly="@ReadOnly"></CostCenterSelector>
        </MudItem>
        <MudItem >
            <DimensionSelector @bind-Value="@Model.Dimension" ReadOnly="@ReadOnly"></DimensionSelector>
        </MudItem>
        <MudItem  Class="d-flex align-center"><MudIconButton Title="Add" OnClick="ADD" Color="Color.Primary" Icon="@Icons.Material.Filled.Add" Size="Size.Small" /></MudItem>

    }
</MudGrid>
</div>
@code {

    [Parameter]
    public List<TaxPurchaseExpenseModel> ExpenseList { get; set; }
    [Parameter]
    public bool ReadOnly { get; set; }
    [Parameter]
    public int? BranchID { get; set; }
    [Parameter]
    public PartyModel PartyInfo { get; set; }
    [Parameter]
    public bool Local { get; set; } = true;
    [Parameter]
    public EventCallback<TaxPurchaseExpenseModel> OnExpenseAdded { get; set; }
    [Parameter]
    public EventCallback OnDelete { get; set; }
    GstUsageCodeModel gstusge;
    TaxPurchaseExpenseModel Model = new TaxPurchaseExpenseModel();
    EditContext editContext;
    private bool _busy;

    protected override void OnParametersSet()
    {
        if (editContext == null)
        {
            editContext = new EditContext(Model);
            editContext.EnableDataAnnotationsValidation();
        }
    }

    public async Task ADD()
    {
        Model.BranchID = BranchID;
        if (AddTax() && editContext.Validate())
        {
            await OnExpenseAdded.InvokeAsync(Model);
            Model = new();
            gstusge = null;
        }
        else
        {
            snackbar.Add("Entered particulars are invalid.", Severity.Error);
        }
    }

    void UsageCodeSelected(GstUsageCodeModel u)
    {
        gstusge = u;
        Model.UsageCode = gstusge?.UsageCode;
        Model.CoaID = gstusge?.CoaID;
        Model.UsageCodeDescription = gstusge?.Description;
    }

    private async Task OpenDialogTaxRates(TaxPurchaseExpenseModel i)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        _busy = true;
        GstModel taxModel = new GstModel();
        taxModel.CGST = i.CGST;
        taxModel.IGST = i.IGST;
        taxModel.TDS = i.TDS;
        taxModel.SGST = i.SGST;
        taxModel.GstRate = i.GstRate;
        DialogParameters parms = new DialogParameters();
        parms.Add("tax", taxModel);
        parms.Add("ReadOnly", ReadOnly);
        var dialog = DialogService.Show<TaxRatedialog>(i.PID == null ? "ADD" : "EDIT", parms, new DialogOptions() { MaxWidth = MaxWidth.Small, FullWidth = true });
        var result = await dialog.Result;
        if (!result.Canceled)
        {
            taxModel = (GstModel)result.Data;
            i.CGST = taxModel.CGST;
            i.IGST = taxModel.IGST;
            i.TDS = taxModel.TDS;
            i.SGST = taxModel.SGST;
            i.GstRate = taxModel.GstRate;
        }
        await Task.Delay(200);
        _busy = false;
    }

    private async Task DeleteExpenses(TaxPurchaseExpenseModel i)
    {
        int rowIndex = ExpenseList.IndexOf(i);
        ExpenseList.RemoveAt(rowIndex);
        await OnDelete.InvokeAsync();
    }

    private bool AddTax()
    {
        if (gstusge != null && Model.Amount != null)
        {
            if (PartyInfo == null)
            {
                snackbar.Add("select party", Severity.Error);
                return false;
            }
            Model.GstRate = usageIservice.GetGstRate(Model.UsageCode, DateTime.Now);
            decimal taxRate = Model.GstRate ?? 0;
            if (!Local)
            {
                Model.IGST = Math.Round(Model.Amount.Value * taxRate / 100, 2);
            }
            else
            {
                Model.SGST = Model.CGST = Math.Round(Model.Amount.Value * taxRate / 200, 2);
            }
            decimal tdsRate = tdsService.GetTdsRate(PartyInfo.PartyID, Model.CoaID);
            Model.TDS = Math.Round((Model.Amount.Value * tdsRate) / 100, 2);
            return true;
        }
        return false;
    }
}