@using Core.BaseModels.Finance.Transactions;

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.Edit" Class="mr-3" /> Edit Branch For Transaction
        </MudText>
    </TitleContent>
    <DialogContent>
        <EditForm Model="@model" id="BranchForm" OnValidSubmit="Update">
            <MudGrid>
                <MudItem xs="6">
                    <MudTextField ReadOnly @bind-Value="model.NumberPlate" Label="NumberPlate" Margin="Margin.Dense" Variant="Variant.Outlined"></MudTextField>
                </MudItem>
                <MudItem xs="6">
                    <MudTextField ReadOnly @bind-Value="model.TransactionDateTime" Format="dd-MM-yyyy hh:mm tt" Label="TransactionDateTime" Margin="Margin.Dense" Variant="Variant.Outlined"></MudTextField>
                </MudItem>
                <MudItem xs="12">
                    <BranchSelector LabelName="Select Branch" Value="SelectedBranch" ValueChanged="@BranchChanged"></BranchSelector>
                </MudItem>
            </MudGrid>
            <ObjectGraphDataAnnotationsValidator />
            <ValidationSummary />
        </EditForm>
    </DialogContent>
    <DialogActions>
        <MudButton Style="margin: 0px 16px 16px 16px;" Variant="Variant.Filled" Color="Color.Success" form="BranchForm" ButtonType="ButtonType.Submit">Submit</MudButton>
    </DialogActions>
</MudDialog>

@code {

    [CascadingParameter] MudDialogInstance MudDialog { get; set; }
    [Parameter]
    public FastTagBranchEditModel model { get; set; } = new();
    public BranchModel SelectedBranch { get; set; }

    protected override void OnParametersSet()
    {
        model.ActivityType ??= "-";
        model.TripNumberDisplay ??= "-";
    }

    protected override async Task OnInitializedAsync()
    {
        SelectedBranch = model.Branch;
    }

    private async Task BranchChanged(BranchModel branch)
    {
        SelectedBranch = branch;
        model.Branch = SelectedBranch;
    }

    public void Update()
    {
        MudDialog.Close(model);
    }
}