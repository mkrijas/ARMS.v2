@using Core.BaseModels.Finance.Transactions;

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.Edit" Class="mr-3" /> Edit TripNumber For Transaction
        </MudText>
    </TitleContent>
    <DialogContent>
        <EditForm Model="@model" id="BranchForm" OnValidSubmit="Update">
            <MudGrid>
                <MudItem xs="12">
                    <MudTextField @bind-Value="model.TransactionID" Label="Enter the Unique Transaction ID" Margin="Margin.Dense" Variant="Variant.Outlined"></MudTextField>
                </MudItem>
                <MudItem xs="12">
                    @* <MudTextField @bind-Value="model.ActivityType" Label="Enter the Unique Transaction ID" Variant="Variant.Outlined" Margin="Margin.Dense"></MudTextField> *@
                    <MudSelect Value="model.ActivityType" ValueChanged="@((x) => ChangeActivityType(x))" T="string" Label="Activity Type" AnchorOrigin="Origin.BottomCenter" Margin="Margin.Dense" Variant="Variant.Outlined">
                        <MudSelectItem Value="@("TRIP")" />
                        <MudSelectItem Value="@("TRANSFER")" />
                        <MudSelectItem Value="@("MAINTENANCE")" />
                        <MudSelectItem Value="@("OFFICE VEHICLE")" />
                    </MudSelect>
                </MudItem>
                <MudItem xs="12">
                    <MudTextField Disabled="@ReadOnly" @bind-Value="model.TripNumberDisplay" Label="Enter the TripNo/JobcardNo/TransferNo" Margin="Margin.Dense" Variant="Variant.Outlined"></MudTextField>
                </MudItem>
            </MudGrid>
            <ObjectGraphDataAnnotationsValidator />
            <ValidationSummary />
        </EditForm>
    </DialogContent>
    <DialogActions>
        <MudButton Style="margin: 0px 16px 16px 16px;" Variant="Variant.Filled" Color="Color.Success" form="BranchForm" ButtonType="ButtonType.Submit">Submit</MudButton>
    </DialogActions>
</MudDialog>

@code {

    [CascadingParameter] MudDialogInstance MudDialog { get; set; }
    public FastTagBranchEditModel model { get; set; } = new FastTagBranchEditModel
        {
            Branch = new BranchModel()
        };
    public bool ReadOnly = false;

    public void ChangeActivityType(string a)
    {
        model.ActivityType = a;
        if (a == "OFFICE VEHICLE")
        {
            model.TripNumberDisplay = "OFFICE-VEHICLE";
            ReadOnly = true;
        }
        else
        {
            model.TripNumberDisplay = null;
            ReadOnly = false;
        }
    }

    public void Update()
    {
        if (model == null)
        {
            model = new FastTagBranchEditModel();
        }

        model.TripNumberDisplay = model.TripNumberDisplay.ToUpper();
        MudDialog.Close(model);
    }
}