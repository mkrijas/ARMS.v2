@using Core.BaseModels.Finance.Transactions;

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.Edit" Class="mr-3" /> Edit TripNumber For Transaction
        </MudText>
    </TitleContent>
    <DialogContent>
        <EditForm Model="@model" id="BranchForm" OnValidSubmit="Update">
            <MudGrid>
                <MudItem xs="6">
                    <MudTextField ReadOnly @bind-Value="model.NumberPlate" Label="NumberPlate" Margin="Margin.Dense" Variant="Variant.Outlined"></MudTextField>
                </MudItem>
                <MudItem xs="6">
                    <MudTextField ReadOnly @bind-Value="model.TransactionDateTime" Format="dd-MM-yyyy hh:mm tt" Label="TransactionDateTime" Margin="Margin.Dense" Variant="Variant.Outlined"></MudTextField>
                </MudItem>
                <MudItem xs="12">
                    <MudSelect Value="model.ActivityType" ValueChanged="@((x) => ChangeActivityType(x))" T="string" Label="Activity Type" AnchorOrigin="Origin.BottomCenter" Margin="Margin.Dense" Variant="Variant.Outlined">
                        <MudSelectItem Value="@("TRIP")" />
                        <MudSelectItem Value="@("FC TRIP")" />
                        <MudSelectItem Value="@("TRANSFER")" />
                        <MudSelectItem Value="@("MAINTENANCE")" />
                        <MudSelectItem Value="@("OFFICE VEHICLE")" />
                    </MudSelect>
                </MudItem>
                <MudItem xs="12">
                    <MudTextField Disabled="@ReadOnly" @bind-Value="model.TripNumberDisplay" Label="Enter the TripNo/JobcardNo/TransferNo" Margin="Margin.Dense" Variant="Variant.Outlined"></MudTextField>
                </MudItem>
            </MudGrid>
            <ObjectGraphDataAnnotationsValidator />
            <ValidationSummary />
        </EditForm>
    </DialogContent>
    <DialogActions>
        <MudButton Style="margin: 0px 16px 16px 16px;" Variant="Variant.Filled" Color="Color.Success" form="BranchForm" ButtonType="ButtonType.Submit">Submit</MudButton>
    </DialogActions>
</MudDialog>

@code {

    [CascadingParameter] MudDialogInstance MudDialog { get; set; }
    [Parameter]
    public FastTagBranchEditModel model { get; set; } = new();
    public bool ReadOnly = false;

    // Lifecycle method called when the component is initialized
    protected override async Task OnInitializedAsync()
    {
        if (model.ActivityType == "OFFICE VEHICLE" || model.ActivityType == "FC TRIP")
        {
            ReadOnly = true;
        }
    }

    // Method to change the activity type and update related propertiesc
    public void ChangeActivityType(string a)
    {
        model.ActivityType = a;
        if (a == "OFFICE VEHICLE")
        {
            model.TripNumberDisplay = "OFFICE-VEHICLE";
            ReadOnly = true;
        }
        else if (a == "FC TRIP")
        {
            model.TripNumberDisplay = "FC-TRIP";
            ReadOnly = true;
        }
        else
        {
            model.TripNumberDisplay = null;
            ReadOnly = false;
        }
    }

    // Method to update the model and close the dialog
    public void Update()
    {
        if (model == null)
        {
            model = new FastTagBranchEditModel();
        }

        model.TripNumberDisplay = model.TripNumberDisplay.ToUpper();
        MudDialog.Close(model);
    }
}