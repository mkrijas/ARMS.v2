@page "/FasTagTollProcessView"
@attribute [Authorize]
@inject AuthenticationStateProvider auth
@using Core.BaseModels.Finance.Transactions;
@using Core.IDataServices.Finance.Transactions;
@inject NavigationManager NavigationManager
@inject IFastTagService IFTService

<MudTable Items="@MainModel" Class="item-shadow" Filter="new Func<FastTagTollModel, bool>(search)" @bind-model="model">
    <ToolBarContent>
        <MudText Typo="Typo.h6">FasTag Process List</MudText>
        <MudIconButton Icon="@Icons.Material.Filled.Add" Title="Add" @onclick="@(()=> EditViewOrVerify(0, false, false))" Color="Color.Dark" Size="Size.Small"></MudIconButton>
        <MudSpacer></MudSpacer>
        <MudTextField @bind-Value="searchmodel" Placeholder="Search DocumentNumber... " Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium"></MudTextField>
    </ToolBarContent>
    <HeaderContent>
        <MudTh><MudTableSortLabel SortBy="new Func<FastTagTollModel, object>(x=> x.DocumentDate)">Document Date</MudTableSortLabel></MudTh>
        <MudTh><MudTableSortLabel SortBy="new Func<FastTagTollModel, object>(x=> x.FastTagUploadID)" InitialDirection="SortDirection.Descending">Document Number</MudTableSortLabel></MudTh>
        <MudTh><MudTableSortLabel SortBy="new Func<FastTagTollModel, object>(x=> x.ProcessDocumentNumber)">Process Document</MudTableSortLabel></MudTh>
        <MudTh>Actions</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd DataLabel="DocumentDate">@context.DocumentDate.Value.ToString("dd-MM-yyyy")</MudTd>
        <MudTd DataLabel="DocumentNumber">@context.DocumentNumber</MudTd>
        <MudTd DataLabel="ProcessDocumentNumber">
            @context.ProcessDocumentNumber
            @if (context.ReverseDocumentNumber != null)
            {
                <MudText Typo="Typo.caption" Style="color:red;">&nbsp;&nbsp;&nbsp;&nbsp;(@context.ReverseDocumentNumber)</MudText>
            }
        </MudTd>
        <MudTd DataLabel="Action">
            <MudTooltip Text="View">
                <MudFab style="font-size:5px" @onclick="@(()=> EditViewOrVerify(context.FastTagUploadID, true, false))" Color="Color.Primary" StartIcon="@Icons.Material.Filled.GridView" Size="Size.Small" />
            </MudTooltip>
            @if (context.AuthLevelId == null)
            {
                <MudTooltip Text="Edit">
                    <MudFab style="font-size:5px" @onclick="@(()=> EditViewOrVerify(context.FastTagUploadID, false, false))" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Edit" Size="Size.Small" />
                </MudTooltip>
            }
            @if (context.AuthLevelId != 99)
            {
                <MudTooltip Text="Verify">
                    <MudFab style="font-size:5px" @onclick="@(()=> EditViewOrVerify(context.FastTagUploadID, true, true))" Color="Color.Warning" StartIcon="@Icons.Material.Filled.Verified" Size="Size.Small" />
                </MudTooltip>
            }
            @if (context.AuthLevelId == 100)
            {
                <MudText Typo="Typo.caption" Style="color:red;">&nbsp;&nbsp;&nbsp;&nbsp;DENIED</MudText>
            }
            @if (@context.AuthLevelId == 99)
            {
                <MudTooltip Text="Reverse Transaction">
                    <EntryReversedComponent DocTypeID="DocInfo.DocumentTypeID" DocumentID="context.FastTagUploadID" MID="context.MID" DocumentNumber="@context.ProcessDocumentNumber"></EntryReversedComponent>
                </MudTooltip>
            }
        </MudTd>
    </RowTemplate>
    <PagerContent>
        <MudTablePager PageSizeOptions="new int[] { 10, 20, 50, 100 }" />
    </PagerContent>
</MudTable>

@code {

    private List<FastTagTollModel> MainModel = new List<FastTagTollModel>();
    private TruckModel model = new TruckModel();

    public int branchID;
    private string UserID = null;
    private string searchmodel = "";

    protected DocumentInfoModel DocInfo { get; set; } = new DocumentInfoModel()
        {
            DocumentTypeID = 120,
            DocumentName = "FasTag"
        };

    // Lifecycle method called when the component is initialized
    protected override async Task OnInitializedAsync()
    {
        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;
        branchID = int.Parse(user.Claims.FirstOrDefault(x => x.Type == "BranchID").Value);

        GetCollection();
    }

    // Method to retrieve the collection of FastTag toll models
    private async Task GetCollection()
    {
        // Fetch the process view for the current branch and convert it to a list
        MainModel = IFTService.GetProcessView(branchID).ToList();
    }

    // Method to navigate to the edit or verify view
    private async Task EditViewOrVerify(int? id, bool rdonly, bool verify)
    {
        //string url = $"/FastTagTollProcess/{id}/{rdonly}/{verify}";
        //NavigationManager.NavigateTo(url);

        string encryptedId = EncryptionHelper.Encrypt(id.ToString());
        // string encryptedReadonly = EncryptionHelper.Encrypt(rdonly.ToString());
        // string encryptedVerify = EncryptionHelper.Encrypt(verify.ToString());

        //string url = $"/FastTagTollProcess/{encryptedId}/{encryptedReadonly}/{encryptedVerify}";
        string url = $"/FasTagTollProcess/{encryptedId}/{rdonly}/{verify}";
        NavigationManager.NavigateTo(url);
    }

    // Method to filter the FastTagTollModel based on the search term
    private bool search(FastTagTollModel model)
    {
        if (model.FastTagUploadID != null && model.DocumentNumber.Contains(searchmodel, StringComparison.OrdinalIgnoreCase))
        {
            return true;
        }
        else if (model.DocumentNumber == null) return true;
        return false;
    }
}

