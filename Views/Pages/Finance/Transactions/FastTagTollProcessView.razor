@page "/FasTagTollProcessView"
@attribute [Authorize]
@inject AuthenticationStateProvider auth
@using Core.BaseModels.Finance.Transactions;
@using Core.IDataServices.Finance.Transactions;
@inject NavigationManager NavigationManager
@inject IFastTagService IFTService

@if (_isLoading)
{
    <div @key="@("loader")" style="display: flex; justify-content: center; align-items: center; min-height: 400px;">
        <LoaderComponent IsFullScreen="true" 
                        ShowLogo="false" 
                        Size="medium" 
                        LoadingText="Loading FasTag Process List" 
                        SubText="Please wait..." />
    </div>
}
else
{
<div @key="@("content")">
<div class="fade-in">
    <div class="admin-header-tiered mb-6">
        <div class="d-flex align-center justify-space-between">
            <div>
                <MudText Typo="Typo.h4" Class="admin-title">FasTag Process List</MudText>
                <MudText Typo="Typo.body2" Class="admin-subtitle">Process and verify FasTag toll transactions. Link uploads to specific accounts and perform financial reversals if necessary.</MudText>
            </div>
            <MudButton StartIcon="@Icons.Material.Filled.Add" Variant="Variant.Filled" Color="Color.Primary" Class="admin-register-btn" OnClick="@(()=> EditViewOrVerify(0, false, false))">NEW PROCESS ENTRY</MudButton>
        </div>
    </div>

    <div class="admin-glass-card mb-6 pa-4">
        <div class="d-flex align-center gap-4 flex-wrap">
            <div style="flex-grow: 1; min-width: 300px;">
                <MudTextField @bind-Value="searchmodel" Placeholder="Search by document number..." Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" Variant="Variant.Outlined" Margin="Margin.Dense" Class="admin-input-group" Clearable="true" />
            </div>
        </div>
    </div>

    <div class="admin-glass-card pa-0 overflow-hidden">
        <MudTable Items="@MainModel" Elevation="0" Class="modern-admin-table" Hover="true" Filter="new Func<FastTagTollModel, bool>(search)">
            <HeaderContent>
                <MudTh><MudTableSortLabel SortBy="new Func<FastTagTollModel, object>(x=> x.DocumentDate)"><span class="admin-header-text">DATE</span></MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<FastTagTollModel, object>(x=> x.FastTagUploadID)" InitialDirection="SortDirection.Descending"><span class="admin-header-text">UPLOAD DOC</span></MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<FastTagTollModel, object>(x=> x.ProcessDocumentNumber)"><span class="admin-header-text">PROCESS DOC</span></MudTableSortLabel></MudTh>
                <MudTh Style="text-align: right;"><span class="admin-header-text">ACTIONS</span></MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Date"><span class="fw-500">@context.DocumentDate?.ToString("dd MMM yyyy")</span></MudTd>
                <MudTd DataLabel="UploadDoc"><span class="fw-600">@context.DocumentNumber</span></MudTd>
                <MudTd DataLabel="ProcessDoc">
                    <div class="d-flex align-center gap-2">
                        <span class="admin-td-primary fw-700">@context.ProcessDocumentNumber</span>
                        @if (context.ReverseDocumentNumber != null)
                        {
                            <MudChip T="string" Size="Size.Small" Color="Color.Error" Variant="Variant.Text" Class="fw-700">(@context.ReverseDocumentNumber)</MudChip>
                        }
                    </div>
                </MudTd>
                <MudTd DataLabel="Actions" Style="text-align: right;">
                    <div class="d-flex justify-end gap-1">
                        @if (@context.AuthLevelId == 99)
                        {
                            <MudTooltip Text="Reverse Transaction">
                                <EntryReversedComponent DocTypeID="DocInfo.DocumentTypeID" DocumentID="context.FastTagUploadID" MID="context.MID" DocumentNumber="@context.ProcessDocumentNumber"></EntryReversedComponent>
                            </MudTooltip>
                        }
                        else
                        {
                            @if (context.AuthLevelId != 100)
                            {
                                <MudTooltip Text="Verify Process">
                                    <MudIconButton OnClick="@(()=> EditViewOrVerify(context.FastTagUploadID, true, true))" Color="Color.Warning" Icon="@Icons.Material.Filled.Verified" Size="Size.Small" Variant="Variant.Text" />
                                </MudTooltip>
                            }
                            @if (context.AuthLevelId == null)
                            {
                                <MudTooltip Text="Edit Process">
                                    <MudIconButton OnClick="@(()=> EditViewOrVerify(context.FastTagUploadID, false, false))" Color="Color.Primary" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Variant="Variant.Text" />
                                </MudTooltip>
                            }
                        }

                        <MudTooltip Text="View Details">
                            <MudIconButton OnClick="@(()=> EditViewOrVerify(context.FastTagUploadID, true, false))" Color="Color.Info" Icon="@Icons.Material.Filled.Visibility" Size="Size.Small" Variant="Variant.Text" />
                        </MudTooltip>

                        @if (context.AuthLevelId == 100)
                        {
                            <MudChip T="string" Label="true" Size="Size.Small" Color="Color.Error" Variant="Variant.Filled" Class="fw-700 ml-2">DENIED</MudChip>
                        }
                    </div>
                </MudTd>
            </RowTemplate>
            <PagerContent>
                <div class="pa-4">
                    <MudTablePager PageSizeOptions="new int[] { 10, 20, 50, 100 }" />
                </div>
            </PagerContent>
        </MudTable>
    </div>
</div>
</div>
}

@code {

    private bool _isLoading = true;
    private DateTime _loadStartTime;

    private List<FastTagTollModel> MainModel = new List<FastTagTollModel>();
    private TruckModel model = new TruckModel();

    public int branchID;
    private string UserID = null;
    private string searchmodel = "";

    protected DocumentInfoModel DocInfo { get; set; } = new DocumentInfoModel()
        {
            DocumentTypeID = 120,
            DocumentName = "FasTag"
        };

    // Lifecycle method called when the component is initialized
    protected override async Task OnInitializedAsync()
    {
        _loadStartTime = DateTime.Now;
        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;
        branchID = int.Parse(user.Claims.FirstOrDefault(x => x.Type == "BranchID").Value);

        GetCollection();
        await EnsureMinimumLoadTime();
        _isLoading = false;
    }

    private async Task EnsureMinimumLoadTime()
    {
        var elapsed = (DateTime.Now - _loadStartTime).TotalMilliseconds;
        if (elapsed < 100)
        {
            await Task.Delay(100 - (int)elapsed);
        }
    }

    // Method to retrieve the collection of FastTag toll models
    private async Task GetCollection()
    {
        // Fetch the process view for the current branch and convert it to a list
        MainModel = IFTService.GetProcessView(branchID).ToList();
    }

    // Method to navigate to the edit or verify view
    private async Task EditViewOrVerify(int? id, bool rdonly, bool verify)
    {
        //string url = $"/FastTagTollProcess/{id}/{rdonly}/{verify}";
        //NavigationManager.NavigateTo(url);

        string encryptedId = EncryptionHelper.Encrypt(id.ToString());
        // string encryptedReadonly = EncryptionHelper.Encrypt(rdonly.ToString());
        // string encryptedVerify = EncryptionHelper.Encrypt(verify.ToString());

        //string url = $"/FastTagTollProcess/{encryptedId}/{encryptedReadonly}/{encryptedVerify}";
        string url = $"/FasTagTollProcess/{encryptedId}/{rdonly}/{verify}";
        NavigationManager.NavigateTo(url);
    }

    // Method to filter the FastTagTollModel based on the search term
    private bool search(FastTagTollModel model)
    {
        if (model.FastTagUploadID != null && model.DocumentNumber.Contains(searchmodel, StringComparison.OrdinalIgnoreCase))
        {
            return true;
        }
        else if (model.DocumentNumber == null) return true;
        return false;
    }
}

