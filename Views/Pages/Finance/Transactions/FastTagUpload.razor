    public async Task EditBranch()
    {
        if (HasPermissionIFastTagServiceEdit)
        {
            var authprov = await auth.GetAuthenticationStateAsync();
            var user = authprov.User;

            DialogOptions options = new DialogOptions() { MaxWidth = MaxWidth.Small };
            var dialog = DialogService.Show<FastTagBranchEditDialog>("Edit Branch", options);
            var result = await dialog.Result;
            if (!result.Cancelled)
            {
                var data = (FastTagBranchEditModel)result.Data;
                try
                {
                    FastTagModel itemToUpdate = ExcelModelCollection.Find(x =>
                    {
                        string cleanedTransactionID1 = data.TransactionID?.Trim();
                        string cleanedTransactionID2 = x.TransactionID?.Trim();

                        return string.Equals(cleanedTransactionID1, cleanedTransactionID2, StringComparison.OrdinalIgnoreCase);
                    });
                    if (itemToUpdate != null)
                    {
                        itemToUpdate.BranchID = data.Branch.BranchID;
                        itemToUpdate.BranchName = data.Branch.BranchName;
                        data.FastTagTollID = itemToUpdate.FastTagTollID;
                        data.UserInfo.UserID = user.Identity.Name;

                        IFTService.UpdateBranch(data);
                        snackbar.Add("Updated Successfully", Severity.Success);
                    }
                    else
                    {
                        bool? message = await DialogService.ShowMessageBox(
                            "Oops !",
                            (MarkupString)$"TransactionID : <b>{data.TransactionID}</b> do not exist in the collection !");
                    }
                }
                catch (Exception ex)
                {
                    snackbar.Add(ex.Message, Severity.Error);
                }
            }
        }
        else
        {
            bool? result = await DialogService.ShowMessageBox(
                "Permission denied!",
                "You don't have any permission to Edit FasTag.");
        }
    }

    public async Task Cancel()
    {
        NavigationManager.NavigateTo("/FasTagTollUploadView");
    }

    public async Task OnValidSubmit()
    {
        if (HasPermissionIFastTagServiceEdit)
        {
            if (_busy)
            {
                snackbar.Add("Please wait while form is being submitted!", Severity.Warning);
                return;
            }
            _busy = true;

            try
            {
                var authprov = await auth.GetAuthenticationStateAsync();
                var user = authprov.User;
                branchID = int.Parse(user.Claims.First(x => x.Type == "BranchID").Value);
                MainModel.NatureOfTransaction = "FasTag";
                UserID = user.Identity.Name;

                MainModel.BranchID = branchID;
                MainModel.FastTagModelList = ExcelModelCollection.ToList();
                MainModel.TotalAmount = ExcelModelCollection.Sum(e => e.DebitAmount);
                MainModel.UserInfo.UserID = UserID;

                if (MainModel.FastTagModelList.Count != 0)
                {
                    if (MainModel.FastTagModelList.Any(f => !f.BranchID.HasValue))
                    {
                        bool? result = await DialogService.ShowMessageBox(
                            "Oops !",
                            "Branch not assigned to one or more Transaction !");
                    }
                    else
                    {
                        IFTService.UpdateNew(MainModel);
                        snackbar.Add("Saved Successfully", Severity.Success);
                        NavigationManager.NavigateTo("/FasTagTollUploadView");
                        // MainModel = new();
                        // collection = new();
                    }
                }
                else
                {
                    bool? result = await DialogService.ShowMessageBox(
                        "Oops !",
                        "Please Upload the file !");
                }
            }
            catch (Exception ex)
            {
                snackbar.Add(ex.Message, Severity.Error);
            }
            await Task.Delay(100);
            _busy = false;
        }
        else
        {
            bool? result = await DialogService.ShowMessageBox(
                "Permission denied!",
                "You don't have any permission to Edit FasTag.");
        }
    }

    private bool search(FastTagModel model)
    {
        if (string.IsNullOrEmpty(searchplatenumber))
        {
            return true;
        }
        return model.NumberPlate?.Contains(searchplatenumber, StringComparison.OrdinalIgnoreCase) == true;
    }

    private async Task HandleXLSXFileButtonSelected(InputFileChangeEventArgs e)
    {
        var file = e.File;

        if (file != null)
        {
            try
            {
                var extension = System.IO.Path.GetExtension(file.Name);
                fileExtension = extension.ToString();

                if (extension.Equals(".xlsx", StringComparison.OrdinalIgnoreCase)) //|| extension.Equals(".xls", StringComparison.OrdinalIgnoreCase))
                {
                    memoryStream = new MemoryStream();
                    excelcollection.Clear();
                    collection.Clear();
                    memoryStream.SetLength(0); // Reset the stream before reading new file data
                    await file.OpenReadStream().CopyToAsync(memoryStream);
                }
                else
                {
                    bool? result = await DialogService.ShowMessageBox(
                        "File Denied !",
                        "The file you uploaded is not in .xlsx format.");
                }
            }
            catch (Exception ex)
            {
                snackbar.Add(ex.Message, Severity.Error);
            }
        }
    }

    private async Task LoadExcelData()
    {
        IsLoading = true;
        StateHasChanged();
        await Task.Delay(1);

        await UploadXLSXFile();

        IsLoading = false;
        StateHasChanged();
    }

    public async Task UploadXLSXFile()
    {
        try
        {
            if (fileExtension == ".xlsx")
            {
                memoryStream.Position = 0;

                using (ExcelPackage package = new ExcelPackage(memoryStream))
                {
                    int worksheetCount = package.Workbook.Worksheets.Count;
                    if (worksheetCount > 0)
                    {
                        ExcelWorksheet worksheet = package.Workbook.Worksheets[0]; // Access the first worksheet

                        int rowCount = worksheet.Dimension.Rows;
                        int colCount = worksheet.Dimension.Columns;
                        int TransactionDateTimeRow = 0;
                        int ProcessedDateTimeRow = 0;
                        int LicencePlateNoRow = 0;
                        int PlazaCodeRow = 0;
                        int TransactionDescriptionRow = 0;
                        int UniqueTransactionIDRow = 0;
                        int Activity = 0;
                        int DRAmountRow = 0;

                        for (int row = 1; row <= (rowCount - 1); row++)
                        {
                            FastTagModel Model = new FastTagModel();
                            if (row == 1)
                            {
                                for (int col = 1; col <= colCount; col++)
                                {
                                    if (worksheet.Cells[row, col].Value?.ToString() == "Transaction Date Time")
                                    {
                                        TransactionDateTimeRow = col;
                                    }
                                    if (worksheet.Cells[row, col].Value?.ToString() == "Processed Date Time")
                                    {
                                        ProcessedDateTimeRow = col;
                                    }
                                    else if (worksheet.Cells[row, col].Value?.ToString() == "Licence Plate No")
                                    {
                                        LicencePlateNoRow = col;
                                    }
                                    else if (worksheet.Cells[row, col].Value?.ToString() == "Activity")
                                    {
                                        Activity = col;
                                    }
                                    else if (worksheet.Cells[row, col].Value?.ToString() == "Plaza Code")
                                    {
                                        PlazaCodeRow = col;
                                    }
                                    else if (worksheet.Cells[row, col].Value?.ToString() == "Transaction Description")
                                    {
                                        TransactionDescriptionRow = col;
                                    }
                                    else if (worksheet.Cells[row, col].Value?.ToString() == "Unique Transaction ID")
                                    {
                                        UniqueTransactionIDRow = col;
                                    }
                                    else if (worksheet.Cells[row, col].Value?.ToString() == "Amount(DR)")
                                    {
                                        DRAmountRow = col;
                                    }
                                }
                            }
                            else
                            {
                                for (int col = 1; col <= colCount; col++)
                                {
                                    if (TransactionDateTimeRow == col)
                                    {
                                        Model.TransactionDateTime = DateTime.Parse(worksheet.Cells[row, TransactionDateTimeRow].Value?.ToString());
                                    }
                                    if (ProcessedDateTimeRow == col)
                                    {
                                        Model.ProcessedDateTime = DateTime.Parse(worksheet.Cells[row, ProcessedDateTimeRow].Value?.ToString());
                                    }
                                    if (LicencePlateNoRow == col)
                                    {
                                        Model.NumberPlate = worksheet.Cells[row, LicencePlateNoRow].Value?.ToString();
                                    }
                                    if (Activity == col)
                                    {
                                        Model.Activity = worksheet.Cells[row, Activity].Value?.ToString();
                                    }
                                    if (PlazaCodeRow == col)
                                    {
                                        Model.PlazaCode = worksheet.Cells[row, PlazaCodeRow].Value?.ToString();
                                    }
                                    if (TransactionDescriptionRow == col)
                                    {
                                        Model.Description = worksheet.Cells[row, TransactionDescriptionRow].Value?.ToString();
                                    }
                                    if (UniqueTransactionIDRow == col)
                                    {
                                        Model.TransactionID = worksheet.Cells[row, UniqueTransactionIDRow].Value?.ToString();
                                    }
                                    if (DRAmountRow == col)
                                    {
                                        Model.DebitAmount = decimal.Parse(worksheet.Cells[row, DRAmountRow].Value?.ToString());
                                    }
                                }
                                if (((Model.DebitAmount > 0) && (Model.NumberPlate != null)) || ((Model.Activity == "ADJUSTMENT") && (Model.NumberPlate != null) && (Model.DebitAmount > 0)))
                                {
                                    excelcollection.Add(Model);
                                }
                            }
                        }

                        collectionlist = excelcollection.Select(model => new FastTagList
                            {
                                TransactionDateTime = model.TransactionDateTime,
                                NumberPlate = model.NumberPlate
                            }).ToList();
                        collection = IFTService.MatchTrucks(collectionlist).ToList();

                        MainModel.NatureOfTransaction = "FasTag";
                        MainModel.BranchID = branchID;
                        if (collection.Count == 0)
                        {
                            bool? errorresult = await DialogService.ShowMessageBox(
                                "Oops !",
                                "No matching data found.");
                            excelcollection = new();
                            collection = new();
                            collectionlist = new();
                        }
                        else if (collection.Count != 0)
                        {
                            foreach (var data in excelcollection)
                            {
                                var matchingCollectionData = collection.FirstOrDefault(x => x.TransactionDateTime == data.TransactionDateTime
                                                                                           && x.NumberPlate == data.NumberPlate);
                                if (matchingCollectionData != null)
                                {
                                    data.BranchID = matchingCollectionData.BranchID;
                                    data.BranchName = matchingCollectionData.BranchName;
                                    data.TruckID = matchingCollectionData.TruckID;
                                    data.TripID = matchingCollectionData.TripID;
                                    // data.TripPrefix = matchingCollectionData.TripPrefix;
                                    // data.TripPrefix = matchingCollectionData.TripPrefix;
                                    data.TripNumberDisplay = matchingCollectionData.TripNumberDisplay;
                                    data.ActivityType = matchingCollectionData.ActivityType;
                                    data.Destination = matchingCollectionData.Destination;
                                    // ... Update other properties as needed ...
                                }
                                else
                                {
                                    // Handle the case where there is no match in 'collection' for the current 'excelData'
                                    // You may choose to add default values or handle it as needed
                                }
                            }
                            ExcelModelCollection = excelcollection;
                        }
                    }
                    else
                    {
                        bool? errorresult = await DialogService.ShowMessageBox(
                            "File Denied !",
                            "The file you uploaded seems to be Corrupted.");
                    }
                }
                memoryStream.Dispose();
            }
        }
        catch (Exception ex)
        {
            snackbar.Add(ex.Message, Severity.Error);
        }
    }

    private async Task ExcelDownload()
    {
        var fileName = "FasTagToll UploadList.xlsx";
        var sheetName = "Sheet1"; // Change the sheet name as needed
        var fileBytes = GenerateExcelBytes(sheetName);

        await JSRuntime.InvokeVoidAsync("triggerFileDownload", fileName, Convert.ToBase64String(fileBytes));
    }

    private byte[] GenerateExcelBytes(string sheetName)
    {
        using (var package = new ExcelPackage())
        {
            var worksheet = package.Workbook.Worksheets.Add(sheetName);

            // Add column headers
            worksheet.Cells[1, 1].Value = "Transaction DateTime";
            worksheet.Cells[1, 2].Value = "Licence Plate No";
            worksheet.Cells[1, 3].Value = "Branch Name";
            worksheet.Cells[1, 4].Value = "Trip No";
            worksheet.Cells[1, 5].Value = "Activity Type";
            worksheet.Cells[1, 6].Value = "Destination";
            worksheet.Cells[1, 7].Value = "PlazaCode";
            worksheet.Cells[1, 8].Value = "Transaction Description";
            worksheet.Cells[1, 9].Value = "Unique Transaction ID";
            worksheet.Cells[1, 10].Value = "Reimbursable";
            worksheet.Cells[1, 11].Value = "Amount(Dr)";
            for (int i = 1; i <= 11; i++)
            {
                worksheet.Cells[1, i].Style.Font.Bold = true;
            }

            worksheet.Column(1).Style.Numberformat.Format = "dd-MM-yyyy hh:mm AM/PM"; // Date format
            worksheet.Column(10).Style.Numberformat.Format = "0.00"; // Integer format

            // Add data rows
            int row = 2;
            foreach (var item in ExcelModelCollection)
            {
                worksheet.Cells[row, 1].Value = item.TransactionDateTime;
                worksheet.Cells[row, 2].Value = item.NumberPlate;
                worksheet.Cells[row, 3].Value = item.BranchName;
                worksheet.Cells[row, 4].Value = item.TripNumberDisplay;
                worksheet.Cells[row, 5].Value = item.ActivityType;
                worksheet.Cells[row, 6].Value = item.Destination;
                worksheet.Cells[row, 7].Value = item.PlazaCode;
                worksheet.Cells[row, 8].Value = item.Description;
                worksheet.Cells[row, 9].Value = item.TransactionID;
                worksheet.Cells[row, 10].Value = item.Reimbursable;
                worksheet.Cells[row, 11].Value = item.DebitAmount;

                row++;
            }

            worksheet.Cells[worksheet.Dimension.Address].Style.Border.Top.Style = ExcelBorderStyle.Thin;
            worksheet.Cells[worksheet.Dimension.Address].Style.Border.Left.Style = ExcelBorderStyle.Thin;
            worksheet.Cells[worksheet.Dimension.Address].Style.Border.Right.Style = ExcelBorderStyle.Thin;
            worksheet.Cells[worksheet.Dimension.Address].Style.Border.Bottom.Style = ExcelBorderStyle.Thin;

            // Save the Excel package to a memory stream
            using (var stream = new MemoryStream())
            {
                package.SaveAs(stream);
                return stream.ToArray();
            }
        }
    }
