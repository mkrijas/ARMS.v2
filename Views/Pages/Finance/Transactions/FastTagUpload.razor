@page "/FasTagTollUpload"
@* @page "/FastTagTollUpload/{id:int}/{Readonly:bool}" *@
@page "/FasTagTollUpload/{encryptedId}/{Readonly:bool}/{Edit:bool}"

@using Core.BaseModels.Finance.Transactions;
@using Core.IDataServices.Finance.Transactions;
@using System.IO;
@using NPOI.HSSF.UserModel;
@using NPOI.SS.UserModel;
@using OfficeOpenXml;
@using System.Threading;
@using OfficeOpenXml.Style
@attribute [Authorize]
@inject AuthenticationStateProvider auth
@inject NavigationManager NavigationManager
@inject MudBlazor.ISnackbar snackbar
@inject IRoleService<RoleModel> Irole
@inject IDialogService DialogService
@inject IFastTagService IFTService
@inject IJSRuntime JSRuntime

<style>
    .mud-table-container {
        width: 100%;
        overflow-y: hidden !important;
    }
</style>

<MudPaper Style="padding-bottom: 1px;">
    <MudToolBar>
        <MudText Typo="Typo.h6" Style="font-weight:500;">FasTag Toll Transaction</MudText>
    </MudToolBar>
    <MudDivider />
    <MudItem Style="padding: 26px; background-color: whitesmoke; margin: 38px; border-radius: 4px; box-shadow: inset 0px 0px 4px 0px rgba(0,0,0,0.3);">

        <MudPaper Style="min-width:min-content;">
            <MudItem xs="12" Style="padding: 38px">
                <MudGrid>
                    @if (!Readonly)
                    {
                        <MudItem xs="4">
                            <h6>Upload XLSX File : </h6>
                            <InputFile @ref="fileInput" OnChange="HandleXLSXFileButtonSelected" />
                            <MudButton Disabled="@_busy" Style="background-color: burlywood;" OnClick="@((args) => LoadExcelData())" Variant="Variant.Filled">Upload</MudButton>
                        </MudItem>
                    }
                    <MudItem xs="@((Readonly) ? 12 : 8)">
                        <EditForm id="FastTagForm" OnValidSubmit="OnValidSubmit" Model="MainModel">
                            <MudGrid>
                                <MudItem xs="6">
                                    <MudTextField @bind-Value="@MainModel.DocumentNumber" ReadOnly="true" Label="Document" Variant="Variant.Outlined" Margin="Margin.Dense"></MudTextField>
                                </MudItem>
                                <MudItem xs="6">
                                    <MudDatePicker @bind-Date=@MainModel.DocumentDate ReadOnly="@Readonly" Label="Document Date" Variant="Variant.Outlined" Margin="Margin.Dense" DisableToolbar="true" Editable="true" DateFormat="dd/MM/yyyy" For="@(()=> MainModel.DocumentDate)" Required />
                                </MudItem>
                                <MudItem xs="12">
                                    <PaymentAccountSelector ReadOnly="@Readonly" BranchID="@branchID" @bind-PaymentMode="@MainModel.PaymentMode" @bind-ArdCode="@MainModel.PaymentArdCode" @bind-CoaID="@MainModel.PaymentCoaID" @bind-BankCharges="@MainModel.BankCharges" @bind-BankTool="@MainModel.PaymentTool" />
                                </MudItem>
                                <MudItem xs="12">
                                    <MudTextField @bind-Value="MainModel.Narration" ReadOnly="@Readonly" Lines="3" Label="Narration" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(()=> MainModel.Narration)"></MudTextField>
                                </MudItem>
                                <MudItem xs="12">
                                    <MudGrid>
                                        <MudItem xs="@((Readonly) ? 12 : 8)"><b>Total Excel Debit Amount &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;: @((Readonly) ? ((MainModel.TotalAmount ?? 0).ToString("c")) : (ExcelModelCollection.Sum(e => e.DebitAmount).ToString("c")))</b></MudItem>
                                        @if (!Readonly)
                                        {
                                            <MudItem xs="2">
                                                <MudButton Style="width: 100%; height: 110%;" Variant="Variant.Filled" Color="Color.Success" ButtonType="ButtonType.Submit">Submit</MudButton>
                                            </MudItem>
                                            <MudItem xs="2">
                                                <MudButton Style="width: 100%; height: 110%;" Variant="Variant.Filled" Color="Color.Primary" OnClick="Cancel">Cancel</MudButton>
                                            </MudItem>
                                        }
                                        else
                                        {
                                            <MudItem xs="8"><b>Total Reimbursable Amount &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;: @ExcelModelCollection.Where(e => e.Reimbursable).Sum(e => e.DebitAmount).ToString("c")</b></MudItem>
                                            <MudItem xs="4" Style="display: flex; justify-content: flex-end;">
                                                @if (Edit)
                                                {
                                                    <MudButton Style="width: 36%; height: 100%;" Variant="Variant.Filled" Color="Color.Secondary" OnClick="@(()=> EditBranch())">Edit Branch</MudButton>
                                                }
                                                else
                                                {
                                                    <MudButton OnClick="ExcelDownload" Style="width: 36%; height: 100%;" StartIcon="@Icons.Material.Outlined.Article" Variant="Variant.Filled" Color="Color.Secondary" ButtonType="ButtonType.Button">Export to Excel</MudButton>
                                                }
                                                <MudButton Style="margin-left: 2%; width: 36%; height: 100%;" Variant="Variant.Filled" Color="Color.Primary" OnClick="Cancel">Close</MudButton>
                                            </MudItem>
                                        }
                                    </MudGrid>
                                </MudItem>
                            </MudGrid>
                            <ObjectGraphDataAnnotationsValidator />
                            <ValidationSummary />
                        </EditForm>
                    </MudItem>
                </MudGrid>
            </MudItem>
        </MudPaper>

        <MudPaper Style="margin-top:26px;">
            <MudItem xs="12" Style="padding: 26px 26px 26px 26px;">
                @* <MudProgressLinear Color="Color.Primary" Value="@Value" Class="my-7" /> *@
                <div Class="fullborder" style="padding: 0px; overflow-y: auto;">
                    <MudTable Items="@ExcelModelCollection" Loading="@IsLoading" HorizontalScrollbar="true" Context="item" Filter="new Func<FastTagModel, bool>(search)" RowsPerPage="100" Style="padding: 0px;width: max-content;" Elevation="0" Dense="true" Hover="true" Striped="true">

                        <ToolBarContent>
                            <MudText Typo="Typo.h6">Transactions List</MudText>
                            <MudSpacer></MudSpacer>
                            <MudTextField @bind-Value="searchplatenumber" Placeholder="Search Licence Plate No..." Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0"></MudTextField>
                            @* @if (Readonly)
                            {
                            <MudButton OnClick="ExcelDownload" Style="margin: 14px; margin-left: 60px; margin-right: 6px;" StartIcon="@Icons.Material.Outlined.Article" Variant="Variant.Filled" Color="Color.Primary" ButtonType="ButtonType.Button">Export to Excel</MudButton>
                            } *@
                        </ToolBarContent>

                        <HeaderContent>
                            @if (Readonly)
                            {
                                <MudTh><MudTableSortLabel SortBy="new Func<FastTagModel, object>(x=> x.IsProcessed)" InitialDirection="SortDirection.Ascending"></MudTableSortLabel></MudTh>
                            }
                            <MudTh><MudTableSortLabel SortBy="new Func<FastTagModel, object>(x=> x.TransactionDateTime)" InitialDirection="SortDirection.Ascending">Transaction DateTime</MudTableSortLabel></MudTh>
                            <MudTh><MudTableSortLabel SortBy="new Func<FastTagModel, object>(x=> x.NumberPlate)" InitialDirection="SortDirection.Ascending">Licence Plate No</MudTableSortLabel></MudTh>
                            <MudTh><MudTableSortLabel SortBy="new Func<FastTagModel, object>(x=> x.BranchName)" InitialDirection="SortDirection.Ascending">Branch Name</MudTableSortLabel></MudTh>
                            <MudTh><MudTableSortLabel SortBy="new Func<FastTagModel, object>(x=> x.TripNumberDisplay)" InitialDirection="SortDirection.Ascending">Trip No</MudTableSortLabel></MudTh>
                            <MudTh><MudTableSortLabel SortBy="new Func<FastTagModel, object>(x=> x.ActivityType)" InitialDirection="SortDirection.Ascending">Activity Type</MudTableSortLabel></MudTh>
                            <MudTh><MudTableSortLabel SortBy="new Func<FastTagModel, object>(x=> x.Destination)" InitialDirection="SortDirection.Ascending">Destination</MudTableSortLabel></MudTh>
                            <MudTh><MudTableSortLabel SortBy="new Func<FastTagModel, object>(x=> x.Reimbursable)" InitialDirection="SortDirection.Ascending">Reimbursable</MudTableSortLabel></MudTh>
                            <MudTh><MudTableSortLabel SortBy="new Func<FastTagModel, object>(x=> x.DebitAmount)" InitialDirection="SortDirection.Ascending">Amount(DR)</MudTableSortLabel></MudTh>
                            <MudTh><MudTableSortLabel SortBy="new Func<FastTagModel, object>(x=> x.PlazaCode)" InitialDirection="SortDirection.Ascending">Plaza Code</MudTableSortLabel></MudTh>
                            <MudTh><MudTableSortLabel SortBy="new Func<FastTagModel, object>(x=> x.Description)" InitialDirection="SortDirection.Ascending">Transaction Description</MudTableSortLabel></MudTh>
                            <MudTh><MudTableSortLabel SortBy="new Func<FastTagModel, object>(x=> x.TransactionID)" InitialDirection="SortDirection.Ascending">Unique Transaction ID</MudTableSortLabel></MudTh>
                            @* <MudTd></MudTd> *@
                        </HeaderContent>

                        <RowTemplate>
                            @if (Readonly)
                            {
                                <MudTd DataLabel="Selected Items">
                                    <MudCheckBox T="bool" @bind-Checked="@item.IsProcessed" ReadOnly></MudCheckBox>
                                </MudTd>
                            }
                            <MudTd DataLabel="Transaction DateTime">@item.TransactionDateTime.Value.ToString("dd/MM/yyyy hh:mm tt")</MudTd>
                            <MudTd DataLabel="NumberPlate">@item.NumberPlate</MudTd>
                            @if (item.BranchID.HasValue)
                            {
                                <MudTd DataLabel="Branch Name">@item.BranchName</MudTd>
                            }
                            else
                            {
                                <MudTd DataLabel="Branch Name"><BranchSelector LabelName="Select Branch" Value="SelectedBranch" ValueChanged="@((newValue) => BranchChanged(newValue, item))" /></MudTd>
                            }
                            <MudTd DataLabel="Trip No">@item.TripNumberDisplay</MudTd>
                            <MudTd DataLabel="ActivityType">@item.ActivityType</MudTd>
                            <MudTd DataLabel="Destination">@item.Destination</MudTd>
                            <MudTd><MudCheckBox T="bool" @bind-Checked="@item.Reimbursable" ReadOnly></MudCheckBox></MudTd>
                            <MudTd DataLabel="Debit Amount">@item.DebitAmount</MudTd>
                            <MudTd DataLabel="PlazaCode">@item.PlazaCode</MudTd>
                            <MudTd DataLabel="TransactionDescription">@item.Description</MudTd>
                            <MudTd DataLabel="Unique Transaction ID">@item.TransactionID</MudTd>
                            @* <MudTd><MudIconButton Icon="@Icons.Material.Filled.Remove" Variant="Variant.Outlined" Color="Color.Error" Size="Size.Small" @onclick="@(() => Delete(item))" /></MudTd> *@
                        </RowTemplate>

                        <PagerContent>
                            <MudTablePager PageSizeOptions="new int[] {5 ,10 ,50 , 100 , 150, 200}" />
                        </PagerContent>
                    </MudTable>
                </div>
            </MudItem>
        </MudPaper>

    </MudItem>
</MudPaper>

