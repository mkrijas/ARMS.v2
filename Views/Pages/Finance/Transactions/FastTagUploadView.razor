@page "/FasTagTollUploadView"
@attribute [Authorize(Policy = "Limited_To_HO")]
@inject AuthenticationStateProvider auth
@using System.Security.Claims
@using Core.BaseModels.Finance.Transactions;
@using Core.IDataServices.Finance.Transactions;
@using System.Text.Json;
@using System.Text;
@inject NavigationManager NavigationManager
@inject IFastTagService IFTService
@inject IJSRuntime JSRuntime


@using System.IO;
@using NPOI.HSSF.UserModel;
@using NPOI.SS.UserModel;
@using OfficeOpenXml;
@using System.Threading;
@using OfficeOpenXml.Style

<MudTable Items="@MainModel" Class="item-shadow" Filter="new Func<FastTagTollModel, bool>(search)" @bind-model="model">
    <ToolBarContent>
        <MudText Typo="Typo.h6">FastTag Upload List</MudText>
        <MudIconButton Icon="@Icons.Material.Filled.Add" Title="Add" @onclick="@(()=> EditView(0, false, false))" Color="Color.Dark" Size="Size.Small"></MudIconButton>
        <MudIconButton OnClick="ExcelDownload" Title="Export Unprocessed Tolls" Icon="@Icons.Material.Outlined.Download"  Color="Color.Primary" ButtonType="ButtonType.Button"/>
        <MudSpacer></MudSpacer>
        <MudTextField @bind-Value="searchmodel" Placeholder="Search Document... " Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium"></MudTextField>
        <MudCheckBox Style="margin: 0px; margin-right: 20px;" Label="Completed List" ValueChanged="((bool value)=>Completed(value))" Value="@IsCompleted" Size="Size.Medium" Color="Color.Primary"></MudCheckBox>
    </ToolBarContent>
    <HeaderContent>
        <MudTh><MudTableSortLabel SortBy="new Func<FastTagTollModel, object>(x=> x.FastTagUploadID)" InitialDirection="SortDirection.Descending">DocumentDate</MudTableSortLabel></MudTh>
        <MudTh><MudTableSortLabel SortBy="new Func<FastTagTollModel, object>(x=> x.DocumentNumber)">Document</MudTableSortLabel></MudTh>
        <MudTh>Actions</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd DataLabel="DocumentDate">@context.DocumentDate.Value.ToString("dd-MM-yyyy")</MudTd>
        <MudTd DataLabel="DocumentNumber">@context.DocumentNumber</MudTd>
        <MudTd DataLabel="">
            @if (!IsCompleted)
            {
                <MudTooltip Text="Edit">
                    <MudFab Style="font-size:5px" @onclick="@(()=> EditView(context.FastTagUploadID, true, true))" Color="Color.Primary" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" IconSize="Size.Small" />
                </MudTooltip>
            }
            <MudTooltip Text="View">
                <MudFab Style="font-size:5px" @onclick="@(()=> EditView(context.FastTagUploadID, true, false))" Color="Color.Primary" Icon="@Icons.Material.Filled.GridView" Size="Size.Small" IconSize="Size.Small" />
            </MudTooltip>
        </MudTd>
    </RowTemplate>
    <PagerContent>
        <MudTablePager PageSizeOptions="new int[] { 10, 20, 50, 100 }" />
    </PagerContent>
</MudTable>

@code {

    private List<FastTagTollModel> MainModel = new List<FastTagTollModel>();
    private TruckModel model = new TruckModel();

    public int branchID;
    private string UserID = null;
    private string searchmodel = "";
    public bool IsCompleted { get; set; } = false;

    // Lifecycle method called when the component is initialized
    protected override async Task OnInitializedAsync()
    {
        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;
        branchID = int.Parse(user.Claims.FirstOrDefault(x => x.Type == "BranchID").Value);

        var jsonValue = await JSRuntime.InvokeAsync<string>("sessionStorage.getItem", "FTincompleteRecordsToggle");
        if (jsonValue != null)
        {
            // Parse the JSON string into a JsonDocument
            using (JsonDocument document = JsonDocument.Parse(jsonValue))
            {
                // Get the root element of the JSON document
                JsonElement root = document.RootElement;

                // Check if the root element is a boolean
                if (root.ValueKind == JsonValueKind.True || root.ValueKind == JsonValueKind.False)
                {
                    // Get the boolean value
                    IsCompleted = root.GetBoolean();
                }
                else
                {
                    // Handle the case where the JSON value is not a boolean
                    IsCompleted = false; // Or set to default value
                }
            }
        }
        else
        {
            // Handle the case where the value is not found or is null
            IsCompleted = false; // Or set to default value
        }
       await GetCollection();
    }


      private async Task ExcelDownload()
    {
        var fileName = "FasTagToll UploadList.xlsx";
        var sheetName = "Sheet1"; // Change the sheet name as needed
        var data =   IFTService.GetUploadViewCollectionUnProcessed(null,null).ToList();
        var fileBytes = GenerateExcelBytes(sheetName,data);

        await JSRuntime.InvokeVoidAsync("triggerFileDownload", fileName, Convert.ToBase64String(fileBytes));
    }
    
    // Method to Generate Excel file
    private byte[] GenerateExcelBytes(string sheetName,List<FastTagModel> data)
    {
        using (var package = new ExcelPackage())
        {
            var worksheet = package.Workbook.Worksheets.Add(sheetName);

            // Add column headers
            worksheet.Cells[1, 1].Value = "Document Number";
            worksheet.Cells[1, 2].Value = "Document Date";
            worksheet.Cells[1, 3].Value = "Branch Name";
            worksheet.Cells[1, 4].Value = "Activity Type";
            worksheet.Cells[1, 5].Value = "Amount";
            worksheet.Cells[1, 6].Value = "Truck";
            worksheet.Cells[1, 7].Value = "Plaza";
            worksheet.Cells[1, 8].Value = "Toll Entry On";
            worksheet.Cells[1, 9].Value = "Transaction ID";   
            
            for (int i = 1; i <= 9; i++)
            {
                worksheet.Cells[1, i].Style.Font.Bold = true;
            }
            worksheet.Column(2).Style.Numberformat.Format = "dd-MM-yyyy"; 
            worksheet.Column(7).Style.Numberformat.Format = "dd-MM-yyyy hh:mm AM/PM"; // Date format
            worksheet.Column(5).Style.Numberformat.Format = "0.00"; // Integer format

            // Add data rows
            int row = 2;
            foreach (var item in data)
            {
                worksheet.Cells[row, 1].Value = item.TripNumberDisplay;
                worksheet.Cells[row, 2].Value = item.ProcessedDateTime;
                worksheet.Cells[row, 3].Value = item.BranchName;                
                worksheet.Cells[row, 4].Value = item.ActivityType;
                worksheet.Cells[row, 5].Value = item.DebitAmount;
                worksheet.Cells[row, 6].Value = item.NumberPlate;
                worksheet.Cells[row, 7].Value = item.PlazaCode;
                worksheet.Cells[row, 8].Value = item.TransactionDateTime;
                worksheet.Cells[row, 9].Value = item.TransactionID;         

                row++;
            }

            worksheet.Cells[worksheet.Dimension.Address].Style.Border.Top.Style = ExcelBorderStyle.Thin;
            worksheet.Cells[worksheet.Dimension.Address].Style.Border.Left.Style = ExcelBorderStyle.Thin;
            worksheet.Cells[worksheet.Dimension.Address].Style.Border.Right.Style = ExcelBorderStyle.Thin;
            worksheet.Cells[worksheet.Dimension.Address].Style.Border.Bottom.Style = ExcelBorderStyle.Thin;

            // Save the Excel package to a memory stream
            using (var stream = new MemoryStream())
            {
                package.SaveAs(stream);
                return stream.ToArray();
            }
        }
    }

    // Method to retrieve the collection of FastTag toll models
    private async Task GetCollection()
    {
        if (!IsCompleted)
        {
            MainModel = IFTService.GetUploadViewInComplete(branchID).ToList(); // Load incomplete records
        }
        else
        {
            MainModel = IFTService.GetUploadViewComplete(branchID).ToList(); // Load complete records
        }
    }

    // Method to toggle the completion status and update session storage
    private async Task Completed(bool value)
    {
        IsCompleted = value;
        await JSRuntime.InvokeVoidAsync("sessionStorage.setItem", "FTincompleteRecordsToggle", value);
        await GetCollection();
    }

    // Method to navigate to the edit view
    private async Task EditView(int? id, bool rdonly, bool edit)
    {
        string encryptedId = EncryptionHelper.Encrypt(id.ToString());
        //string url = $"/FastTagTollUpload/{id}/{rdonly}";
        string url = $"/FasTagTollUpload/{encryptedId}/{rdonly}/{edit}";
        NavigationManager.NavigateTo(url);
    }

    // private async Task View(int? id, bool rdonly)
    // {
    //     string url = $"/FastTagTollUpload/{id}/{rdonly}";
    //     NavigationManager.NavigateTo(url);
    // }

    // Method to filter the FastTagTollModel based on the search term
    private bool search(FastTagTollModel model)
    {
        if (model.FastTagUploadID != null && model.DocumentNumber.Contains(searchmodel, StringComparison.OrdinalIgnoreCase))
        {
            return true;
        }
        else if (model.DocumentNumber == null) return true;
        return false;
    }
}