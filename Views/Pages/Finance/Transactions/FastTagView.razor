@page "/FastTagToll"
@using Core.BaseModels.Finance.Transactions;
@using Core.IDataServices.Finance.Transactions;
@using System.IO;
@using NPOI.HSSF.UserModel;
@using NPOI.SS.UserModel;
@using OfficeOpenXml;
@using System.Threading;
@attribute [Authorize]
@inject AuthenticationStateProvider auth
@inject MudBlazor.ISnackbar snackbar
@inject IDialogService DialogService
@inject IFastTagService IFTService

<MudPaper Style="padding-bottom: 15px;">
    <MudToolBar>
        <MudText Typo="Typo.h6" Style="font-weight:500;">FastTag Toll Transaction</MudText>
    </MudToolBar>
    <MudDivider />
    <MudGrid Class="item-shadow" Style="margin:36px; margin-bottom: 22px; width: fit-content;">
        <MudItem xs="12" Style="padding: 38px">
            <MudGrid Class="fullborder">
                <MudItem xs="4">
                    <h6>Upload XLSX File : </h6>
                    <InputFile @ref="fileInput" OnChange="HandleXLSXFileButtonSelected" />
                    <MudButton OnClick="UploadXLSXFile" Variant="Variant.Filled">Upload</MudButton>
                </MudItem>
                <MudItem xs="8">
                    <EditForm id="FastTagForm" OnValidSubmit="OnValidSubmit" Model="MainModel">
                        <MudGrid>
                            <MudItem xs="6">
                                <MudTextField @bind-Value="@MainModel.DocumentNumber" ReadOnly="true" Label="DocumentNumber" Variant="Variant.Outlined" Margin="Margin.Dense"></MudTextField>
                            </MudItem>
                            <MudItem xs="6">
                                <MudDatePicker @bind-Date=@MainModel.DocumentDate Label="Document Date" Variant="Variant.Outlined" Margin="Margin.Dense" DisableToolbar="true" Editable="true" DateFormat="dd/MM/yyyy" For="@(()=> MainModel.DocumentDate)" Required />
                             </MudItem>
                             <MudItem xs="12">
                                 <PaymentAccountSelector BranchID="@branchID" @bind-PaymentMode="@MainModel.PaymentMode" @bind-ArdCode="@MainModel.PaymentArdCode" @bind-CoaID="@MainModel.PaymentCoaID" @bind-BankCharges="@MainModel.BankCharges" @bind-BankTool="@MainModel.PaymentTool" />
                             </MudItem>
                             <MudItem xs="12">
                                 <MudTextField @bind-Value="MainModel.Narration" Lines="3" Label="Narration" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(()=> MainModel.Narration)"></MudTextField>
                             </MudItem>
                             <MudItem xs="12">
                                 <MudGrid>
                                     <MudItem xs="8"><b>Total Excel Debit Amount &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;: @collection.Sum(e => e.DebitAmount).ToString("c")</b></MudItem>
                                     <MudItem xs="4">
                                         <MudButton Style="margin-left: 48%; width: 52%; height: 110%;" Variant="Variant.Filled" Color="Color.Success" ButtonType="ButtonType.Submit">Submit</MudButton>
                                     </MudItem>
                                 </MudGrid>
                             </MudItem>
                             @* Style="width: 100%; height: 60%; margin-top: 18%;" <MudItem xs="10">
                            <MudGrid>
                            <MudItem xs="12"><b>Total Excel Debit Amount &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;: @collection.Sum(e => e.DebitAmount).ToString("c")</b></MudItem>
                            <MudItem xs="12"><b>Total Selected Debit Amount &nbsp;: @selectedcollection.Sum(e => e.DebitAmount).ToString("c")</b></MudItem>
                            </MudGrid>
                            </MudItem>
                            <MudItem xs="2">
                            <MudButton Style="width: 100%; height: 60%; margin-top: 18%;" Variant="Variant.Filled" Color="Color.Success" ButtonType="ButtonType.Submit">Submit</MudButton>
                            </MudItem> *@
                         </MudGrid>
                         <ObjectGraphDataAnnotationsValidator />
                         <ValidationSummary />
                     </EditForm>
                 </MudItem>
             </MudGrid>
         </MudItem>
         <MudItem xs="12" Style="padding: 0px 26px 26px 26px;">
             <MudTable Items="@collection" Context="item" Filter="new Func<FastTagModel, bool>(search)" RowsPerPage="100" Class="fullborder" Style="padding: 0px" Elevation="0" Dense="true" Hover="true" Striped="true">
                 <ToolBarContent>
                     <MudText Typo="Typo.h6">Transactions List</MudText>
                     <MudSpacer></MudSpacer>
                     <MudTextField @bind-Value="searchplatenumber" Placeholder="Search Licence Plate No..." Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0">
                     </MudTextField>
                 </ToolBarContent>
                 <HeaderContent>
                     <MudTh>Transaction DateTime</MudTh>
                     <MudTh>Licence Plate No</MudTh>
                     <MudTh>Branch Name</MudTh>
                     <MudTh>Trip No</MudTh>
                     <MudTh>Plaza Code</MudTh>
                     <MudTh>Transaction Description</MudTh>
                     <MudTh>Unique Transaction ID</MudTh>
                     <MudTh>Reimbursable</MudTh>
                     <MudTh>Amount(DR)</MudTh>
                 </HeaderContent>
                 <RowTemplate>
                     <MudTd DataLabel="Transaction DateTime">@item.TransactionDateTime</MudTd>
                     <MudTd DataLabel="NumberPlate">@item.NumberPlate</MudTd>
                     <MudTd DataLabel="Branch Name">@item.BranchName</MudTd>
                     <MudTd DataLabel="Trip No">@item.TripNumberDisplay</MudTd>
                     <MudTd DataLabel="PlazaCode">@item.PlazaCode</MudTd>
                     <MudTd DataLabel="TransactionDescription">@item.Description</MudTd>
                     <MudTd DataLabel="Unique Transaction ID">@item.TransactionID</MudTd>
                     <MudTh><MudCheckBox T="bool" @bind-Checked="@item.Reimbursable" ReadOnly></MudCheckBox></MudTh>
                     <MudTd DataLabel="Debit Amount">@item.DebitAmount</MudTd>
                 </RowTemplate>
                 <PagerContent>
                     <MudTablePager PageSizeOptions="new int[] {5 ,10 ,50 , 100 , 150, 200}" />
                 </PagerContent>
             </MudTable>
         </MudItem>
     </MudGrid>
 </MudPaper>

 @code {

    private InputFile fileInput;
    private MemoryStream memoryStream = new MemoryStream();
    //private FastTagModel model = new FastTagModel();
    private HashSet<FastTagModel> selectedcollection = new HashSet<FastTagModel>();
    private FastTagTollModel MainModel = new FastTagTollModel();
    private List<FastTagModel> collection = new List<FastTagModel>();
    private List<FastTagModel> excelcollection = new List<FastTagModel>();
    private List<FastTagList> collectionlist = new List<FastTagList>();
    private string searchplatenumber = "";
    public string fileExtension = "";
    public int branchID;
    private string UserID = null;

    protected override async Task OnInitializedAsync()
    {
        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;
        branchID = int.Parse(user.Claims.First(x => x.Type == "BranchID").Value);
        MainModel.BranchID = branchID;
        MainModel.NatureOfTransaction = "FastTag";
        UserID = user.Identity.Name;
    }

    public async Task OnValidSubmit()
    {
        try
        {
            var authprov = await auth.GetAuthenticationStateAsync();
            var user = authprov.User;
            branchID = int.Parse(user.Claims.First(x => x.Type == "BranchID").Value);
            MainModel.NatureOfTransaction = "FastTag";
            UserID = user.Identity.Name;

            MainModel.BranchID = branchID;
            MainModel.FastTagModelList = collection.ToList();
            MainModel.TotalAmount = collection.Sum(e => e.DebitAmount);
            MainModel.UserInfo.UserID = UserID;

            if (MainModel.FastTagModelList.Count != 0)
            {
                IFTService.UpdateNew(MainModel);
                snackbar.Add("Saved Successfully", Severity.Success);
            }
            else
            {
                bool? result = await DialogService.ShowMessageBox(
                    "Oops !",
                    "Please Upload the file !");
            }
        }
        catch (Exception ex)
        {
            snackbar.Add(ex.Message, Severity.Error);
        }

        MainModel = new();
        collection = new();
    }

    private bool search(FastTagModel model)
    {
        if (string.IsNullOrEmpty(searchplatenumber))
        {
            return true;
        }
        return model.NumberPlate?.Contains(searchplatenumber, StringComparison.OrdinalIgnoreCase) == true;
    }

    private async Task HandleXLSXFileButtonSelected(InputFileChangeEventArgs e)
    {
        var file = e.File;

        if (file != null)
        {
            try
            {
                var extension = System.IO.Path.GetExtension(file.Name);
                fileExtension = extension.ToString();

                if (extension.Equals(".xlsx", StringComparison.OrdinalIgnoreCase)) //|| extension.Equals(".xls", StringComparison.OrdinalIgnoreCase))
                {
                    memoryStream = new MemoryStream();
                    excelcollection.Clear();
                    collection.Clear();
                    memoryStream.SetLength(0); // Reset the stream before reading new file data
                    await file.OpenReadStream().CopyToAsync(memoryStream);
                }
                else
                {
                    bool? result = await DialogService.ShowMessageBox(
                        "File Denied !",
                        "The file you uploaded is not in .xlsx format.");
                }
            }
            catch (Exception ex)
            {
                snackbar.Add(ex.Message, Severity.Error);
            }
        }
    }

    private async Task UploadXLSXFile()
    {
        try
        {
            // if (fileExtension == ".xls")
            // {
            //     memoryStream.Position = 0;
            //     IWorkbook workbook;

            //     using (workbook = new HSSFWorkbook(memoryStream)) // Use HSSFWorkbook for .xls files
            //     {
            //         HSSFSheet sheet = (HSSFSheet)workbook.GetSheetAt(0); // Access the first worksheet

            //         int rowCount = sheet.PhysicalNumberOfRows;

            //         for (int row = 0; row < rowCount; row++)
            //         {
            //             FastTagModel Model = new FastTagModel();
            //             HSSFRow excelRow = (HSSFRow)sheet.GetRow(row);

            //             if (excelRow != null)
            //             {
            //                 int colCount = excelRow.PhysicalNumberOfCells;

            //                 for (int col = 0; col < colCount; col++)
            //                 {

            //                 }
            //             }
            //             XLSXButtoncollection.Add(Model);
            //         }
            //     }
            // }
            if (fileExtension == ".xlsx")
            {
                memoryStream.Position = 0;

                using (ExcelPackage package = new ExcelPackage(memoryStream))
                {
                    int worksheetCount = package.Workbook.Worksheets.Count;
                    if (worksheetCount > 0)
                    {
                        ExcelWorksheet worksheet = package.Workbook.Worksheets[0]; // Access the first worksheet

                        int rowCount = worksheet.Dimension.Rows;
                        int colCount = worksheet.Dimension.Columns;
                        int TransactionDateTimeRow = 0,
                            LicencePlateNoRow = 0,
                            PlazaCodeRow = 0,
                            TransactionDescriptionRow = 0,
                            UniqueTransactionIDRow = 0,
                            //CRAmountRow = 0,
                            DRAmountRow = 0;

                        for (int row = 1; row <= (rowCount - 1); row++)
                        {
                            FastTagModel Model = new FastTagModel();
                            if (row == 1)
                            {
                                for (int col = 1; col <= colCount; col++)
                                {
                                    if (worksheet.Cells[row, col].Value?.ToString() == "Transaction Date Time")
                                    {
                                        TransactionDateTimeRow = col;
                                    }
                                    else if (worksheet.Cells[row, col].Value?.ToString() == "Licence Plate No")
                                    {
                                        LicencePlateNoRow = col;
                                    }
                                    else if (worksheet.Cells[row, col].Value?.ToString() == "Plaza Code")
                                    {
                                        PlazaCodeRow = col;
                                    }
                                    else if (worksheet.Cells[row, col].Value?.ToString() == "Transaction Description")
                                    {
                                        TransactionDescriptionRow = col;
                                    }
                                    else if (worksheet.Cells[row, col].Value?.ToString() == "Unique Transaction ID")
                                    {
                                        UniqueTransactionIDRow = col;
                                    }
                                    // else if (worksheet.Cells[row, col].Value?.ToString() == "Amount(CR)")
                                    // {
                                    //     CRAmountRow = col;
                                    // }
                                    else if (worksheet.Cells[row, col].Value?.ToString() == "Amount(DR)")
                                    {
                                        DRAmountRow = col;
                                    }
                                }
                            }
                            else
                            {
                                for (int col = 1; col <= colCount; col++)
                                {
                                    if (TransactionDateTimeRow == col)
                                    {
                                        Model.TransactionDateTime = DateTime.Parse(worksheet.Cells[row, TransactionDateTimeRow].Value?.ToString());
                                    }
                                    if (LicencePlateNoRow == col)
                                    {
                                        Model.NumberPlate = worksheet.Cells[row, LicencePlateNoRow].Value?.ToString();
                                    }
                                    if (PlazaCodeRow == col)
                                    {
                                        Model.PlazaCode = worksheet.Cells[row, PlazaCodeRow].Value?.ToString();
                                    }
                                    if (TransactionDescriptionRow == col)
                                    {
                                        Model.Description = worksheet.Cells[row, TransactionDescriptionRow].Value?.ToString();
                                    }
                                    if (UniqueTransactionIDRow == col)
                                    {
                                        Model.TransactionID = worksheet.Cells[row, UniqueTransactionIDRow].Value?.ToString();
                                    }
                                    // if (CRAmountRow == col)
                                    // {
                                    //     Model.CreditAmount = decimal.Parse(worksheet.Cells[row, CRAmountRow].Value?.ToString());
                                    // }
                                    if (DRAmountRow == col)
                                    {
                                        Model.DebitAmount = decimal.Parse(worksheet.Cells[row, DRAmountRow].Value?.ToString());
                                    }
                                }
                                if (Model.NumberPlate != null && Model.DebitAmount > 0)
                                {
                                    excelcollection.Add(Model);
                                }
                            }
                        }

                        collectionlist = excelcollection.Select(model => new FastTagList
                            {
                                TransactionDateTime = model.TransactionDateTime,
                                NumberPlate = model.NumberPlate
                            }).ToList();

                        collection = IFTService.SelectForExcel(collectionlist).ToList();
                        MainModel.NatureOfTransaction = "FastTag";
                        MainModel.BranchID = branchID;

                        foreach (var data in collection)
                        {
                            var matchingCollectionData = excelcollection.FirstOrDefault(x => x.TransactionDateTime == data.TransactionDateTime
                                                                                          && x.NumberPlate == data.NumberPlate);
                            if (matchingCollectionData != null)
                            {
                                // Update 'excelData' properties with corresponding 'matchingCollectionData' values
                                data.PlazaCode = matchingCollectionData.PlazaCode;
                                data.Description = matchingCollectionData.Description;
                                data.TransactionID = matchingCollectionData.TransactionID;
                                data.CreditAmount = matchingCollectionData.CreditAmount;
                                data.DebitAmount = matchingCollectionData.DebitAmount;
                                // data.BranchName = matchingCollectionData.BranchName;
                                // if (matchingCollectionData.Trip != null)
                                // {
                                //     data.Trip = new TripModel
                                //         {
                                //             TripID = matchingCollectionData.Trip.TripID,
                                //             TruckID = matchingCollectionData.Trip.TruckID,
                                //             TripPrefix = matchingCollectionData.Trip.TripPrefix,
                                //             TripNumber = matchingCollectionData.Trip.TripNumber
                                //         };
                                // };
                                // ... Update other properties as needed ...
                            }
                            else
                            {
                                // Handle the case where there is no match in 'collection' for the current 'excelData'
                                // You may choose to add default values or handle it as needed
                            }
                        }
                    }
                    else
                    {
                        bool? errorresult = await DialogService.ShowMessageBox(
                            "File Denied !",
                            "The file you uploaded seems to be Corrupted.");
                    }
                }
                memoryStream.Dispose();
            }
        }
        catch (Exception ex)
        {
            snackbar.Add(ex.Message, Severity.Error);
        }
    }
}