@page "/FreightBooking"
@inject IFreightBillingService Iservice
@inject IOrderService orderIservice
@inject ITariffService tariffIservice
@inject NavigationManager uriHelper;
@inject MudBlazor.ISnackbar snackbar
@inject AuthenticationStateProvider auth
@attribute [Authorize]
@inject IDialogService DialogService


 <MudPaper>
     <MudContainer>
          <MudGrid   >
          <MudItem xs="12" md="3">
               <MudSelect Label="Select order" @bind-Value="Order.OrderID" T="int?"  Variant="Variant.Outlined" Margin="Margin.Dense" OffsetY="true" Direction="Direction.Top" AdornmentColor="Color.Secondary" >
                            @foreach (var ditem in orders)
                            {
                                <MudSelectItem Value="@ditem.OrderID">@ditem.OrderName</MudSelectItem>
                            }
                        </MudSelect>
       </MudItem>
       <MudItem xs="12" md="3">
               <MudSelect Label="Select Tariff" @bind-Value="TarifType" T="TariffTypeModel" ToStringFunc="@((p) => p?.TariffTypeName)"  Variant="Variant.Outlined" Margin="Margin.Dense" OffsetY="true" Direction="Direction.Top" AdornmentColor="Color.Secondary" >
                            @foreach (var item in tariftypes)
                            {
                                <MudSelectItem Value="@item">@item.TariffTypeName</MudSelectItem>
                            }
                        </MudSelect>
       </MudItem>
        <MudItem xs="12" md="3">
      <MudDatePicker Label="DateFrom" Variant="Variant.Outlined" Margin="Margin.Dense" DisableToolbar="true" Editable="true" @bind-Date="frmDate" DateFormat="dd/MM/yyyy" />
      </MudItem>  
       <MudItem xs="12" md="3">
      <MudDatePicker Label="DateTo" Variant="Variant.Outlined" Margin="Margin.Dense" DisableToolbar="true" Editable="true" @bind-Date="tDate" DateFormat="dd/MM/yyyy" />
      </MudItem>  <MudItem xs="12" md="10" ></MudItem> 
       <MudItem xs="12" md="2" >
       <MudButton OnClick="fetch" Variant="Variant.Filled" Color="Color.Success" ButtonType="ButtonType.Submit">Fetch</MudButton>
   </MudItem>     
   </MudGrid>  
      </MudContainer>
 </MudPaper>
 <br />

<MudGrid Spacing="4">
   <MudItem xs="12">
       
        <MudTable Items="@collection" @bind-SelectedItems="selectedItems1" MultiSelection="true"  Dense="true" Hover="true"  Striped="true" Elevation="10"  @bind-place="model">
           

            
            <HeaderContent>
                <MudTh><MudTableSortLabel SortBy="new Func<GcTariffModel, object>(x=> x.ConsolidatedDraftBillID)" InitialDirection="SortDirection.Ascending">ConsolidatedDraftBillID</MudTableSortLabel></MudTh>
             <MudTh><MudTableSortLabel SortBy="new Func<GcTariffModel, object>(x=> x.GcID)" InitialDirection="SortDirection.Ascending">GcID</MudTableSortLabel></MudTh>
               <MudTh><MudTableSortLabel SortBy="new Func<GcTariffModel, object>(x=> x.TariffID)" InitialDirection="SortDirection.Ascending">TariffID</MudTableSortLabel></MudTh>
               <MudTh><MudTableSortLabel SortBy="new Func<GcTariffModel, object>(x=> x.Amount)" InitialDirection="SortDirection.Ascending">Amount</MudTableSortLabel></MudTh>
                
                
               @* <MudTh>Actions</MudTh>*@
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="ConsolidatedDraftBillID">@context.ConsolidatedDraftBillID</MudTd>
                <MudTd DataLabel="GcID">@context.GcID</MudTd>
                <MudTd DataLabel="TariffID">@context.TariffID</MudTd>
                  <MudTd DataLabel="Amount">@context.Amount</MudTd>
                
                 
           
            </RowTemplate>
            <PagerContent>
                <MudTablePager PageSizeOptions="new int[] { 5, 10, 20, 50, 100 }" />
           <MudItem xs="12"md="9"> </MudItem><MudItem xs="12"md="3">
                <MudButton OnClick="selected" Variant="Variant.Filled" Color="Color.Success" ButtonType="ButtonType.Submit">Get Details</MudButton>
        </MudItem>
            </PagerContent>
        </MudTable>
    </MudItem>
    </MudGrid>
<br />
     <MudPaper Class="@value" >
    <MudContainer>
    <MudGrid   >
     <MudItem xs="12"md="12">
   
      <MudDatePicker Label="DocumentDate" Variant="Variant.Outlined" Margin="Margin.Dense" DisableToolbar="true" Editable="true" @bind-Date="docdate" DateFormat="dd/MM/yyyy" />


    </MudItem>
     <MudItem xs="12"md="12">
   
      <MudTextField @bind-Value="narrartion" Lines="2" Label="Narration" Variant="Variant.Outlined" Margin="Margin.Dense" ></MudTextField>


    </MudItem>
    <MudItem xs="12"md="10"> </MudItem><MudItem xs="12"md="2">
     <MudButton @onclick="Createbill" Variant="Variant.Filled"  Color="Color.Primary" >Submit</MudButton>
    </MudItem>

  </MudGrid></MudContainer></MudPaper>

@code {


    private GcTariffModel model = new GcTariffModel();
    private List<GcTariffModel> collection = new List<GcTariffModel>();
    private List<OrderModel> orders = new();
    private OrderModel Order=new();
    public DateTime? frmDate=System.DateTime.Now;
    public DateTime? tDate =System.DateTime.Now;
    DateTime? docdate=System.DateTime.Now;
    private List<TariffTypeModel> tariftypes = new();
    private TariffTypeModel TarifType=new();
    private HashSet<GcTariffModel> selectedItems1= new HashSet<GcTariffModel>();
    public string value="invisible";
    public string narrartion;

    protected override async Task OnInitializedAsync()
    {
        var authprov = await auth.GetAuthenticationStateAsync();
        var brancIDString = authprov.User.Claims.First(x => x.Type == "BranchID").Value;
        int brancID = int.Parse(brancIDString);
        orders = await orderIservice.Select(0).ToListAsync();
        tariftypes = tariffIservice.SelectTariffTypes("All").ToList();
    }
    public async Task fetch()
    {
        await GetTariffData();
    }
    public async Task GetTariffData()
    {
        int? ordrId = Order.OrderID;
        short? tarifftypeId = TarifType.TariffTypeID;
        //DateOnly? dtf = DateTime.FromDateTime(frmDate);
        //DateOnly? dtt = DateOnly.FromDateTime(tDate);
        var authprov = await auth.GetAuthenticationStateAsync();
        var brancIDString = authprov.User.Claims.First(x => x.Type == "BranchID").Value;
        int brancID = int.Parse(brancIDString);
        collection = Iservice.GetPending(ordrId, tarifftypeId).ToList();
      
        //DateTime k = System.DateTime.Now;

        //// Creating DateOnly object from DateTime.

        //DateOnly testDateOnly = DateOnly.FromDateTime(k);
        //Console.WriteLine(testDateOnly.ToString());
    }
    private void selected()
    {

        if(selectedItems1!=null)
        {
            value = "visible";
        }
    }


    public async Task Createbill()
    {
        var authprov = await auth.GetAuthenticationStateAsync();
        var brancIDString = authprov.User.Claims.First(x => x.Type == "BranchID").Value;
        int brancID = int.Parse(brancIDString);
        var user = authprov.User;
        ConsolidatedDraftBillModel cdm = new();
        cdm.UserInfo.UserID = user.Identity.Name;
        cdm.BranchID = brancID;
        cdm.BookedGCs = selectedItems1.ToList();
        cdm.Order = Order;
        cdm.TariffType = TarifType;
        cdm.DocumentDate = docdate;
        cdm.Narration = narrartion;
        cdm.TotalAmount = 1000;
        Iservice.UpdateConsolidatedDraftBill(cdm);
        
    }
}
