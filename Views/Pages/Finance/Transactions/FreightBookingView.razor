@page "/FreightBooking"
@inject IFreightBillingService Iservice
@inject IOrderService orderIservice
@inject ITariffService tariffIservice
@inject NavigationManager uriHelper;
@inject MudBlazor.ISnackbar snackbar
@inject AuthenticationStateProvider auth
@attribute [Authorize]
@inject IDialogService DialogService



<MudPaper>
    <MudContainer>
        <MudGrid>
            <MudItem xs="12" md="3">
                <MudSelect Label="Select order" @bind-Value="Order.OrderID" T="int?" Variant="Variant.Outlined" Margin="Margin.Dense" OffsetY="true" Direction="Direction.Top" AdornmentColor="Color.Secondary">
                    @foreach (var ditem in orders)
                    {
                        <MudSelectItem Value="@ditem.OrderID">@ditem.OrderName</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" md="3">
                <MudSelect Label="Select Tariff" @bind-Value="TarifType" T="TariffTypeModel" ToStringFunc="@((p) => p?.TariffTypeName)" Variant="Variant.Outlined" Margin="Margin.Dense" OffsetY="true" Direction="Direction.Top" AdornmentColor="Color.Secondary">
                    @foreach (var item in tariftypes)
                    {
                        <MudSelectItem Value="@item">@item.TariffTypeName</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" md="3">
                <MudDatePicker Label="DateFrom" Variant="Variant.Outlined" Margin="Margin.Dense" DisableToolbar="true" Editable="true" @bind-Date="frmDate" DateFormat="dd/MM/yyyy" />
            </MudItem>
            <MudItem xs="12" md="3">
                <MudDatePicker Label="DateTo" Variant="Variant.Outlined" Margin="Margin.Dense" DisableToolbar="true" Editable="true" @bind-Date="tDate" DateFormat="dd/MM/yyyy" />
            </MudItem>  <MudItem xs="12" md="10"></MudItem>
            <MudItem xs="12" md="2">
                <MudButton OnClick="fetch" Variant="Variant.Filled" Color="Color.Primary" ButtonType="ButtonType.Submit">Fetch</MudButton>
            </MudItem>
        </MudGrid>
    </MudContainer>
</MudPaper>
<br />

<MudGrid Spacing="4">
    <MudItem xs="12">

        <MudTable Items="@collection" @bind-SelectedItems="selectedItems1" MultiSelection="true" Dense="true" Hover="true" Striped="true" Elevation="10" @bind-place="model">



            <HeaderContent>
                <MudTh><MudTableSortLabel SortBy="new Func<GcTariffModel, object>(x=> x.BillNumber)" InitialDirection="SortDirection.Ascending">BillNumber</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<GcTariffModel, object>(x=> x.BillDate)" InitialDirection="SortDirection.Ascending">BillDate</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<GcTariffModel, object>(x=> x.InvoiceDate)" InitialDirection="SortDirection.Ascending">InvoiceDate</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<GcTariffModel, object>(x=> x.ConsigneeName)" InitialDirection="SortDirection.Ascending">ConsigneeName</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<GcTariffModel, object>(x=> x.BillQuantity)" InitialDirection="SortDirection.Ascending">BillQuantity</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<GcTariffModel, object>(x=> x.Amount)" InitialDirection="SortDirection.Ascending">Freight</MudTableSortLabel></MudTh>



            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="BillNumber">@context.BillNumber</MudTd>
                <MudTd DataLabel="BillDate">@context.BillDate?.ToShortDateString()</MudTd>
                <MudTd DataLabel="InvoiceDate">@context.InvoiceDate?.ToShortDateString()</MudTd>
                <MudTd DataLabel="ConsigneeName">@context.ConsigneeName</MudTd>
                <MudTd DataLabel="BillQuantity">@context.BillQuantity</MudTd>
                <MudTd DataLabel="Amount">@context.Amount</MudTd>



            </RowTemplate>
            <PagerContent>
                <MudTablePager PageSizeOptions="new int[] { 5, 10, 20, 50, 100 }" />

            </PagerContent>
        </MudTable>

    </MudItem>
    <MudItem xs="12" md="8"> </MudItem><MudItem xs="12" md="4">
        <MudButton OnClick="selected" Variant="Variant.Filled" Color="Color.Primary" ButtonType="ButtonType.Submit">Create Consolidate Draft Bill</MudButton>
    </MudItem>
</MudGrid>
<br />


@code {


    private GcTariffModel model = new GcTariffModel();
    private List<GcTariffModel> collection = new List<GcTariffModel>();
    private List<OrderModel> orders = new();
    private OrderModel Order = new();
    public DateTime? frmDate = System.DateTime.Now;
    public DateTime? tDate = System.DateTime.Now;

    private List<TariffTypeModel> tariftypes = new();
    private TariffTypeModel TarifType = new();
    private HashSet<GcTariffModel> selectedItems1 = new HashSet<GcTariffModel>();

    protected override async Task OnInitializedAsync()
    {

        orders = await orderIservice.Select(0).ToListAsync();
        tariftypes = tariffIservice.SelectTariffTypes("All").ToList();
    }
    public void fetch()
    {
        GetTariffData();
    }
    public void GetTariffData()
    {
        int? ordrId = Order.OrderID;
        short? tarifftypeId = TarifType.TariffTypeID;


        collection = Iservice.GetPending(ordrId, tarifftypeId, frmDate, tDate).ToList();


    }
    private async Task selected()
    {
        DialogOptions maxWidth = new DialogOptions() { MaxWidth = MaxWidth.Medium, FullWidth = true };

        if (selectedItems1.Count > 0)
        {
            var authprov = await auth.GetAuthenticationStateAsync();
            var brancIDString = authprov.User.Claims.First(x => x.Type == "BranchID").Value;
            int brancID = int.Parse(brancIDString);
            var user = authprov.User;
            ConsolidatedDraftBillModel cdm = new();
            cdm.UserInfo.UserID = user.Identity.Name;
            cdm.BranchID = brancID;
            cdm.BookedGCs = selectedItems1.ToList();
            cdm.Order = Order;
            cdm.TariffType = TarifType;
            cdm.DocumentDate = System.DateTime.Now; ;


            cdm.TotalAmount = 0;
            foreach (var item in selectedItems1)
            {
                cdm.TotalAmount = cdm.TotalAmount + item.Amount;
            }

            DialogParameters parms = new DialogParameters();
            parms.Add("model", cdm);
            parms.Add("IsReadOnly", false);
            parms.Add("IsView", false);
            var dialog = DialogService.Show<ConsolidateDraftBillDialog>("ConsolidateDraftBill", parms, maxWidth);
            var result = await dialog.Result;

            if (!result.Cancelled)
            {
                ConsolidatedDraftBillModel UpatedModel = (ConsolidatedDraftBillModel)result.Data;
                Iservice.UpdateConsolidatedDraftBill(UpatedModel);
                snackbar.Add("Saved Successfully ", Severity.Success);//value = "visible";
            }
            GetTariffData();
        }
        else
        {
            snackbar.Add("Please SelectGc", Severity.Success);

        }
    }




}
