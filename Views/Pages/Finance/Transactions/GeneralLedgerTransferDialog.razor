@inherits DialogFormComponentBase<GeneralLedgerTransferModel>

@inject IBranchService branchService
@inject IGeneralLedgerTransferService Iservice

<DialogForm @ref="@dialogForm" ReadOnly="@ReadOnly" Title="Ledger Transfer" formID="ledgerTransferForm" DocumentDetails="DocInfo" model="@_model" _busy="_busy">
    <FormContent>
        <MudPaper Class="p-3">
            <EditForm id="ledgerTransferForm" OnValidSubmit="OnValidSubmit" EditContext="editContext">
                <ObjectGraphDataAnnotationsValidator />
                <ValidationSummary />
                <MudGrid Spacing="4">
                    <MudItem xs="12" md="6">
                        <MudDatePicker Label="Document Date" ReadOnly="ReadOnly" Variant="Variant.Outlined" Margin="Margin.Dense" DisableToolbar="true" Editable="true" @bind-Date="_model.DocumentDate" DateFormat="dd/MM/yyyy" />
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudTextField ReadOnly="ReadOnly" @bind-Value="_model.Reference" Label="Reference" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => _model.Reference)"></MudTextField>
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudCard>
                            <MudCardContent>
                                <MudItem xs="12" md="12">
                                    <MudTextField ReadOnly="true" @bind-Value="hmbarnchName" Label="Home Branch" Variant="Variant.Outlined" Margin="Margin.Dense"></MudTextField>
                                </MudItem>
                                <br />
                                <MudItem xs="12" md="12">
                                    <UsageCodeSelector @bind-Value="@_model.UsageCode" LabelName="Home Usage Code" />
                                </MudItem>
                            </MudCardContent>
                        </MudCard>
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudCard>
                            <MudCardContent>
                                <MudItem xs="12" md="12">
                                    <MudSelect ReadOnly="ReadOnly" Label="Select Other Branch" @bind-Value="_model.OtherBranchID" T="int?" Variant="Variant.Outlined" Margin="Margin.Dense" OffsetY="true" Direction="Direction.Top" AdornmentColor="Color.Secondary">
                                        @foreach (var ditem in branches)
                                        {
                                            <MudSelectItem Value="@ditem.BranchID">@ditem.BranchName</MudSelectItem>
                                        }
                                    </MudSelect>
                                </MudItem>
                                <br />
                                <MudItem xs="12" md="12">
                                    <UsageCodeSelector @bind-Value="@_model.OtherUsageCode" LabelName="Other Usage Code" />
                                </MudItem>
                            </MudCardContent>
                        </MudCard>
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudTextField ReadOnly="ReadOnly" @bind-Value="_model.TotalAmount" Label="Amount" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => _model.TotalAmount)"></MudTextField>
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudRadioGroup @bind-Value="@_model.DrCrType">
                            <MudRadio T="int?" Value="1" Color="Color.Primary">Debit</MudRadio>
                            <MudRadio T="int?" Value="-1" Color="Color.Secondary">Credit</MudRadio>
                        </MudRadioGroup>
                    </MudItem>
                    <MudItem xs="12" md="12">
                        <MudTextField ReadOnly="ReadOnly" @bind-Value="_model.Narration" Lines="2" Label="Narration" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => _model.Narration)"></MudTextField>
                    </MudItem>
                </MudGrid>
            </EditForm>
        </MudPaper>
    </FormContent>
    <VerificationStatus>
        <AutherizationStatusComponent DocTypeID="DocInfo.DocumentTypeID" DocDate="@DocDate" DocumentID="_model.LedgerTransferID" OnApprove="Approve"></AutherizationStatusComponent>
    </VerificationStatus>
</DialogForm>

@code {


    [Parameter]
    public override GeneralLedgerTransferModel model { get; set; }
    private GeneralLedgerTransferModel _model { get { return model; } set { model = value; DocInfo.DocumentID = value.LedgerTransferID; } }
    private List<BranchModel> branches = new();
    private string hmbarnchName;
    private int? BranchID = null;
    private string UserID = null;

    protected override DocumentInfoModel DocInfo { get; set; } = new DocumentInfoModel()
        {
            DocumentTypeID = 132,
            DocumentName = "GeneralLedgerTransfer"
        };

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();
        var authprov = await auth.GetAuthenticationStateAsync();
        BranchID = int.Parse(authprov.User.Claims.First(x => x.Type == "BranchID").Value);
        var user = authprov.User;
        UserID = user.Identity.Name;
        var brancIDString = authprov.User.Claims.First(x => x.Type == "BranchName").Value;
        hmbarnchName = brancIDString.ToString();
        _model.BranchID = BranchID;
        _model.NatureOfTransaction = "Ledger Transfer";
        branches = branchService.Select().ToList();
    }

    public void OtherBranchChanges(int? otherBranchID)
    {
        _model.OtherBranchID = otherBranchID;
    }

    protected override async Task<int> Update(GeneralLedgerTransferModel editModel)
    {
        _model = Iservice.Update(model);
        return _model.LedgerTransferID.Value;
    }

    protected override int UpdateApproval(DataApprovedStatus aprvd)
    {
        int result = Iservice.Approve(_model.LedgerTransferID, _model.UserInfo.UserID, aprvd.Remarks);
        return result;
    }
}