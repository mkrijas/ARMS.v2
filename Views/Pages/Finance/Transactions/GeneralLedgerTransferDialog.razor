@inherits DialogFormComponentBase<GeneralLedgerTransferModel>

@inject IBranchService branchService
@inject IGeneralLedgerTransferService Iservice
@inject IInterBranchMappingService intermappingIservice

<DialogForm @ref="@dialogForm" ReadOnly="@ReadOnly" Title="Ledger Transfer" formID="ledgerTransferForm" DocumentDetails="DocInfo" model="@_model" _busy="_busy">
    <FormContent>
        <MudPaper Class="p-3">
            <EditForm id="ledgerTransferForm" OnValidSubmit="OnValidSubmit" EditContext="editContext">
                <ObjectGraphDataAnnotationsValidator />
                <ValidationSummary />
                <MudGrid Spacing="4">
                    <MudItem xs="12" md="6">
                        <MudDatePicker Label="Document Date" ReadOnly="ReadOnly" Variant="Variant.Outlined" Margin="Margin.Dense" DisableToolbar="true" Editable="true" @bind-Date="_model.DocumentDate" DateFormat="dd/MM/yyyy" MaxDate="DateTime.Now" />
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudTextField ReadOnly="ReadOnly" @bind-Value="_model.Reference" Label="Reference" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => _model.Reference)"></MudTextField>
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudCard>
                            <MudCardContent>
                                <MudItem xs="12" md="12">
                                    <MudTextField ReadOnly="true" @bind-Value="hmbarnchName" Label="Home Branch" Variant="Variant.Outlined" Margin="Margin.Dense"></MudTextField>
                                </MudItem>
                                <br />
                                <MudItem xs="12" md="12">
                                    <UsageCodeSelector @bind-Value="@_model.UsageCode" LabelName="Home Usage Code" />
                                </MudItem>
                            </MudCardContent>
                        </MudCard>
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudCard>
                            <MudCardContent>
                                <MudItem xs="12" md="12">
                                    <MudSelect ReadOnly="ReadOnly" Label="Target Branch" Value="_model.OtherBranchID" T="int?" ValueChanged="OtherBranchChanged" Variant="Variant.Outlined" Margin="Margin.Dense"   AdornmentColor="Color.Secondary">
                                        @foreach (var ditem in branches)
                                        {
                                            <MudSelectItem Value="@ditem.BranchID">@ditem.BranchName</MudSelectItem>
                                        }
                                    </MudSelect>
                                </MudItem>
                                <br />
                                <MudItem xs="12" md="12">
                                    <UsageCodeSelector @bind-Value="@_model.OtherUsageCode" LabelName="Target Usage Code" />
                                </MudItem>
                            </MudCardContent>
                        </MudCard>
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudTextField ReadOnly="ReadOnly" @bind-Value="_model.TotalAmount" Label="Amount" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => _model.TotalAmount)"></MudTextField>
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudRadioGroup T="int?" @bind-Value="@_model.DrCrType">
                            <MudRadio T="int?" Value="1" Color="Color.Primary">Debit</MudRadio>
                            <MudRadio T="int?" Value="(-1)" Color="Color.Secondary">Credit</MudRadio>
                        </MudRadioGroup>
                    </MudItem>
                    @if(_model.IsInterBranch)
                    {
                    <MudItem xs="12" md="6">
                        <MudSelect Label="Transaction Type" ReadOnly="ReadOnly" @bind-Value="_model.InterBranchTranID" T="int?" Variant="Variant.Outlined" Margin="Margin.Dense" AdornmentColor="Color.Secondary" For="@(()=> _model.InterBranchTranID)">
                            @foreach (var ditem in transactionTypeList)
                            {
                                <MudSelectItem Value="@ditem.ID">@ditem.TransactionTypeName</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                    }
                    <MudItem xs="12" md="12">
                        <MudTextField ReadOnly="ReadOnly" @bind-Value="_model.Narration" Lines="2" Label="Narration" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => _model.Narration)"></MudTextField>
                    </MudItem>
                </MudGrid>
            </EditForm>
        </MudPaper>
    </FormContent>
    <VerificationStatus>
        <AutherizationStatusComponent CreatedBy="@_model.UserInfo" DocTypeID="@DocInfo.DocumentTypeID" DocDate="@DocDate" DocumentID="@_model.LedgerTransferID" OnApprove="Approve"></AutherizationStatusComponent>
    </VerificationStatus>
</DialogForm>

@code {


    [Parameter]
    public override GeneralLedgerTransferModel model { get; set; }
    private GeneralLedgerTransferModel _model { get { return model; } set { model = value; DocInfo.DocumentID = value.LedgerTransferID; } }
    private List<BranchModel> branches = new();
    private List<InterBranchTransactionTypeModel> transactionTypeList = new();
    private string hmbarnchName;
    private int? BranchID = null;
    private string UserID = null;

    protected override DocumentInfoModel DocInfo { get; set; } = new DocumentInfoModel()
        {
            DocumentTypeID = 132,
            DocumentName = "GeneralLedgerTransfer"
        };

    // Lifecycle method called when the component is initialized
    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();
        var authprov = await auth.GetAuthenticationStateAsync();
        BranchID = int.Parse(authprov.User.Claims.First(x => x.Type == "BranchID").Value);
        var user = authprov.User;
        UserID = user.Identity.Name;
        var brancIDString = authprov.User.Claims.First(x => x.Type == "BranchName").Value;
        hmbarnchName = brancIDString.ToString();
        _model = (GeneralLedgerTransferModel) model.Clone();
        _model.BranchID = BranchID;
        _model.NatureOfTransaction = "Ledger Transfer";
        branches = branchService.Select().ToList(); // Get the list of branches
        transactionTypeList = intermappingIservice.GetTypes().ToList(); // Get the list of transaction types
    }

    // Method to handle changes in the other branch selection
    public void OtherBranchChanged(int? otherBranchID)
    {
        _model.OtherBranchID = otherBranchID;
        _model.IsInterBranch = _model.BranchID != _model.OtherBranchID;
        StateHasChanged();
    }

    // Method to update the GeneralLedgerTransferModel
    protected override async Task<int> Update(GeneralLedgerTransferModel editModel)
    {
        _model = Iservice.Update(model); // Call the service to update the model
        return _model.LedgerTransferID.Value;
    }

    // Method to update the approval status of the document
    protected override int UpdateApproval(DataApprovedStatus aprvd)
    {
        int result = Iservice.Approve(_model.LedgerTransferID, _model.UserInfo.UserID, aprvd.Remarks); // Call the service to approve
        return result;
    }
}
