@inherits DialogFormComponentBase<GeneralLedgerTransferModel>

@inject IBranchService branchService
@inject IGeneralLedgerTransferService Iservice
@inject IInterBranchMappingService intermappingIservice

<DialogForm @ref="@dialogForm" ReadOnly="@ReadOnly" Title="General Ledger Transfer" Subtitle="Seamlessly reallocate funds between branches or internal usage codes with full audit tracking." Icon="@Icons.Material.Filled.SwapHoriz" AdminStyle="true" formID="ledgerTransferForm" DocumentDetails="DocInfo" model="@_model" _busy="_busy">
    <FormContent>
        <div class="dialog-content-wrapper">
            <EditForm id="ledgerTransferForm" OnValidSubmit="OnValidSubmit" EditContext="editContext">
                <ObjectGraphDataAnnotationsValidator />
                
                <div class="admin-glass-card pa-6 mb-6">
                    <span class="admin-section-label">Transfer Metadata</span>
                    <MudGrid Spacing="3">
                        <MudItem xs="12" md="6">
                            <MudDatePicker Label="Document Date" ReadOnly="ReadOnly" Variant="Variant.Outlined" Margin="Margin.Dense" DisableToolbar="true" Editable="true" @bind-Date="_model.DocumentDate" DateFormat="dd/MM/yyyy" MaxDate="DateTime.Now" Class="admin-input-group" />
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <MudTextField ReadOnly="ReadOnly" @bind-Value="_model.Reference" Label="Reference / Voucher No" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => _model.Reference)" Class="admin-input-group"></MudTextField>
                        </MudItem>
                    </MudGrid>
                </div>

                <MudGrid Spacing="3" Class="mb-6">
                    <MudItem xs="12" md="6">
                        <div class="admin-glass-card pa-6 h-100" style="border-left: 4px solid #FF9F43;">
                            <span class="admin-section-label">Source (Home Branch)</span>
                            <MudStack Spacing="3">
                                <MudTextField ReadOnly="true" @bind-Value="hmbarnchName" Label="Branch Name" Variant="Variant.Outlined" Margin="Margin.Dense" Class="admin-input-group" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Home" AdornmentColor="Color.Primary"></MudTextField>
                                <UsageCodeSelector @bind-Value="@_model.UsageCode" LabelName="Source Account / Usage Code" Class="admin-input-group" />
                            </MudStack>
                        </div>
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <div class="admin-glass-card pa-6 h-100" style="border-left: 4px solid #141A46;">
                            <span class="admin-section-label">Destination (Target Branch)</span>
                            <MudStack Spacing="3">
                                <MudSelect For="@(() => _model.OtherBranchID)" ReadOnly="ReadOnly" Label="Select Target Branch" Value="_model.OtherBranchID" T="int?" ValueChanged="OtherBranchChanged" Variant="Variant.Outlined" Margin="Margin.Dense" Class="admin-input-group" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.LocationOn" AdornmentColor="Color.Secondary">
                                    @foreach (var ditem in branches)
                                    {
                                        <MudSelectItem Value="@ditem.BranchID">@ditem.BranchName</MudSelectItem>
                                    }
                                </MudSelect>
                                <UsageCodeSelector @bind-Value="@_model.OtherUsageCode" LabelName="Target Account / Usage Code" Class="admin-input-group" />
                            </MudStack>
                        </div>
                    </MudItem>
                </MudGrid>

                <div class="admin-glass-card pa-6 mb-6">
                    <span class="admin-section-label">Financial Impact & Classification</span>
                    <MudGrid Spacing="3" Class="align-center">
                        <MudItem xs="12" md="4">
                            <MudNumericField ReadOnly="ReadOnly" HideSpinButtons @bind-Value="_model.TotalAmount" Label="Transfer Amount" Variant="Variant.Outlined" Margin="Margin.Dense" Class="admin-input-group" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.CurrencyRupee" AdornmentColor="Color.Primary" For="@(() => _model.TotalAmount)"></MudNumericField>
                        </MudItem>
                        <MudItem xs="12" md="4">
                            <MudRadioGroup T="int?" @bind-Value="@_model.DrCrType">
                                <MudRadio T="int?" Value="1" Color="Color.Primary">Debit (+)</MudRadio>
                                <MudRadio T="int?" Value="(-1)" Color="Color.Secondary">Credit (-)</MudRadio>
                            </MudRadioGroup>
                        </MudItem>
                        @if(_model.IsInterBranch)
                        {
                            <MudItem xs="12" md="4">
                                <MudSelect Label="Internal Transaction Type" ReadOnly="ReadOnly" @bind-Value="_model.InterBranchTranID" T="int?" Variant="Variant.Outlined" Margin="Margin.Dense" Class="admin-input-group" For="@(()=> _model.InterBranchTranID)">
                                    @foreach (var ditem in transactionTypeList)
                                    {
                                        <MudSelectItem Value="@ditem.ID">@ditem.TransactionTypeName</MudSelectItem>
                                    }
                                </MudSelect>
                            </MudItem>
                        }
                        <MudItem xs="12">
                            <MudTextField ReadOnly="ReadOnly" @bind-Value="_model.Narration" Lines="3" Label="Narration / Reason for Transfer" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => _model.Narration)" Class="admin-input-group"></MudTextField>
                        </MudItem>
                    </MudGrid>
                </div>
            </EditForm>
        </div>
    </FormContent>
    <VerificationStatus>
        <AutherizationStatusComponent CreatedBy="@_model.UserInfo" DocTypeID="@DocInfo.DocumentTypeID" DocDate="@DocDate" DocumentID="@_model.LedgerTransferID" OnApprove="Approve"></AutherizationStatusComponent>
    </VerificationStatus>
</DialogForm>

@code {


    [Parameter]
    public override GeneralLedgerTransferModel model { get; set; }
    private GeneralLedgerTransferModel _model { get { return model; } set { model = value; DocInfo.DocumentID = value.LedgerTransferID; } }
    private List<BranchModel> branches = new();
    private List<InterBranchTransactionTypeModel> transactionTypeList = new();
    private string hmbarnchName;
    private BranchModel OtherBranch;
    private int? BranchID = null;
    private string UserID = null;

    protected override DocumentInfoModel DocInfo { get; set; } = new DocumentInfoModel()
        {
            DocumentTypeID = 132,
            DocumentName = "GeneralLedgerTransfer"
        };

    // Lifecycle method called when the component is initialized
    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();
        var authprov = await auth.GetAuthenticationStateAsync();
        BranchID = int.Parse(authprov.User.Claims.First(x => x.Type == "BranchID").Value);
        var user = authprov.User;
        UserID = user.Identity.Name;
        var brancIDString = authprov.User.Claims.First(x => x.Type == "BranchName").Value;
        hmbarnchName = brancIDString.ToString();
        _model = (GeneralLedgerTransferModel) model.Clone();
        _model.BranchID = BranchID;
        _model.NatureOfTransaction = "Ledger Transfer";
        branches = branchService.Select().ToList(); // Get the list of branches
        transactionTypeList = intermappingIservice.GetTypes().ToList(); // Get the list of transaction types
        if (branches != null && _model.OtherBranchID != null && branches.Any(s => s.BranchID == _model.OtherBranchID))
        {
            OtherBranch = branches.FirstOrDefault(s => s.BranchID == _model.OtherBranchID);
        }
    }

    // Method to handle changes in the other branch selection
    public void OtherBranchChanged(BranchModel branch)
    {
        OtherBranch = branch;
        _model.OtherBranchID = branch?.BranchID;
        _model.IsInterBranch = _model.BranchID != _model.OtherBranchID;
        StateHasChanged();
    }

    // Method to update the GeneralLedgerTransferModel
    protected override async Task<int> Update(GeneralLedgerTransferModel editModel)
    {
        _model = Iservice.Update(model); // Call the service to update the model
        return _model.LedgerTransferID.Value;
    }

    // Method to update the approval status of the document
    protected override int UpdateApproval(DataApprovedStatus aprvd)
    {
        int result = Iservice.Approve(_model.LedgerTransferID, _model.UserInfo.UserID, aprvd.Remarks); // Call the service to approve
        return result;
    }
}
