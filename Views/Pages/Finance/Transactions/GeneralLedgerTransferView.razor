@page "/GeneralLedgerTransfer"
@page "/GeneralLedgerTransfer/{id:int}"
@inherits ViewComponentBase<GeneralLedgerTransferModel>
@inject IGeneralLedgerTransferService Iservice

@if (_isLoading)
{
    <div @key="@("loader")" style="display: flex; justify-content: center; align-items: center; min-height: 400px;">
        <LoaderComponent IsFullScreen="true" 
                        ShowLogo="false" 
                        Size="medium" 
                        LoadingText="Loading Ledger Transfer" 
                        SubText="Please wait..." />
    </div>
}
else
{
    <div @key="@("content")">
@if (_isLoading)
{
    <div @key="@("loader")" style="display: flex; justify-content: center; align-items: center; min-height: 400px;">
        <LoaderComponent IsFullScreen="true" 
                        ShowLogo="false" 
                        Size="medium" 
                        LoadingText="Loading Ledger Transfer" 
                        SubText="Please wait..." />
    </div>
}
else
{
    <div class="fade-in">
        <div class="admin-header-tiered mb-6">
            <div class="d-flex align-center justify-space-between">
                <div>
                    <MudText Typo="Typo.h4" Class="admin-title">Ledger Transfer</MudText>
                    <MudText Typo="Typo.body2" Class="admin-subtitle">Transfer funds and adjust balances between general ledger accounts. Monitor transaction flow and verify inter-account movements with automated approval checks.</MudText>
                </div>
                <MudButton StartIcon="@Icons.Material.Filled.Add" Variant="Variant.Filled" Color="Color.Primary" Class="admin-register-btn" OnClick="@(()=> OpenForm(new GeneralLedgerTransferModel(),false))" Disabled="@_busy">NEW LEDGER TRANSFER</MudButton>
            </div>
        </div>

        <div class="admin-glass-card mb-6 pa-4">
            <div class="d-flex align-center gap-4 flex-wrap">
                <div style="flex-grow: 1; min-width: 300px;">
                    <MudTextField @bind-Value="searchTerm" Placeholder="Search by document number or usage code..." Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" Variant="Variant.Outlined" Margin="Margin.Dense" Class="admin-input-group" Clearable="true" OnKeyUp="HandleSearchKeyUp" />
                </div>
                <div class="d-flex align-center gap-4">
                    <MudTextField @bind-Value="@NumberOfRecords" Label="Max Records" Variant="Variant.Outlined" Margin="Margin.Dense" Style="width: 100px;" Dense="true" />
                    <MudCheckBox T="bool" Label="Approved Entries" ValueChanged="((bool value)=>ToggleData(value))" Value="@ShowApproved" Size="Size.Small" Color="Color.Primary" Class="fw-600" />
                </div>
            </div>
        </div>

        <div class="admin-glass-card pa-0 overflow-hidden">
            <MudTable Items="@collection" Elevation="0" Class="modern-admin-table" Hover="true">
                <HeaderContent>
                    <MudTh><MudTableSortLabel SortBy="new Func<GeneralLedgerTransferModel, object>(x=> x.DocumentDate)"><span class="admin-header-text">DATE</span></MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<GeneralLedgerTransferModel, object>(x=> x.DocumentNumber)" InitialDirection="SortDirection.Descending"><span class="admin-header-text">DOC NUMBER</span></MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<GeneralLedgerTransferModel, object>(x=> x.UsageCode)"><span class="admin-header-text">FROM ACCOUNT</span></MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<GeneralLedgerTransferModel, object>(x=> x.OtherUsageCode)"><span class="admin-header-text">TO ACCOUNT</span></MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<GeneralLedgerTransferModel, object>(x=> x.TotalAmount)"><span class="admin-header-text">TOTAL AMOUNT</span></MudTableSortLabel></MudTh>
                    <MudTh Style="text-align: right;"><span class="admin-header-text">ACTIONS</span></MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Date"><span class="fw-500">@context.DocumentDate?.ToString("dd MMM yyyy")</span></MudTd>
                    <MudTd DataLabel="DocNumber">
                        <div class="d-flex flex-column">
                            <span class="admin-td-primary fw-700">@context.DocumentNumber</span>
                            @if (context.AuthLevelId == 100)
                            {
                                <MudText Typo="Typo.caption" Color="Color.Error" Class="fw-700">REJECTED</MudText>
                            }
                        </div>
                    </MudTd>
                    <MudTd DataLabel="FromAccount"><span class="fw-600">@context.UsageCode.UsageCode</span></MudTd>
                    <MudTd DataLabel="ToAccount"><span class="fw-600">@context.OtherUsageCode.UsageCode</span></MudTd>
                    <MudTd DataLabel="Amount">
                        <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Text" Class="fw-700">@context.TotalAmount?.ToString("N2")</MudChip>
                    </MudTd>
                    <MudTd DataLabel="Actions" Style="text-align: right;">
                        <div class="d-flex justify-end gap-1">
                            @if (@context.AuthLevelId == 99)
                            {
                                <EntryReversedComponent DocTypeID="DocInfo.DocumentTypeID" DocumentID="context.LedgerTransferID" MID="context.MID" DocumentNumber="@context.DocumentNumber"></EntryReversedComponent>
                            }
                            else if (@context.AuthLevelId != 100)
                            {
                                <MudTooltip Text="Verify Transfer">
                                    <MudIconButton OnClick="@(()=> OpenForm(context,true))" Color="Color.Warning" Icon="@Icons.Material.Filled.Verified" Size="Size.Small" Variant="Variant.Text" />
                                </MudTooltip>
                            }

                            <MudTooltip Text="View Details">
                                <MudIconButton OnClick="@(()=> OpenForm(context,true))" Color="Color.Info" Icon="@Icons.Material.Filled.Visibility" Size="Size.Small" Variant="Variant.Text" />
                            </MudTooltip>
                            
                            <MudTooltip Text="Edit Transfer">
                                <MudIconButton Disabled="@(context.AuthLevelId != null)" OnClick="@(()=> OpenForm(context,false))" Color="Color.Primary" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Variant="Variant.Text" />
                            </MudTooltip>

                            <MudTooltip Text="Remove Transfer">
                                <MudIconButton Disabled="@(context.AuthLevelId != null)" OnClick="@(()=> Delete(context.LedgerTransferID))" Color="Color.Error" Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Variant="Variant.Text" />
                            </MudTooltip>
                        </div>
                    </MudTd>
                </RowTemplate>
                <PagerContent>
                    <div class="pa-4">
                        <MudTablePager PageSizeOptions="new int[] { 10, 20, 50, 100 }" />
                    </div>
                </PagerContent>
            </MudTable>
        </div>
    </div>
}
</div>

}

@code {

    private bool _isLoading = true;
    private DateTime _loadStartTime;

    protected override List<GeneralLedgerTransferModel> collection { get; set; } = new List<GeneralLedgerTransferModel>();
    protected override DocumentInfoModel DocInfo { get; set; } = new DocumentInfoModel()
        {
            DocumentTypeID = 132,
            DocumentName = "GeneralLedgerTransfer"
        };

    protected override async Task OnInitializedAsync()
    {
        _loadStartTime = DateTime.Now;
        await base.OnInitializedAsync();

        if (id != null && collection != null && collection.Any(g => g.LedgerTransferID == id))
        {
            await OpenForm(collection.FirstOrDefault(s => s.LedgerTransferID == id), true);
        }
        await EnsureMinimumLoadTime();
        _isLoading = false;
    }

    private async Task EnsureMinimumLoadTime()
    {
        var elapsed = (DateTime.Now - _loadStartTime).TotalMilliseconds;
        if (elapsed < 100)
        {
            await Task.Delay(100 - (int)elapsed);
        }
    }

    // Method to open a dialog form for adding or editing a GeneralLedgerTransferModel
    protected override async Task OpenForm(GeneralLedgerTransferModel gModel, bool ReadOnly, bool DisableAddition = false)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        _busy = true;
        DialogParameters parms = new DialogParameters();
        parms.Add("model", gModel.Clone());
        parms.Add("ReadOnly", ReadOnly);
        parms.Add("OnApproved", new EventCallbackFactory().Create(this, () => LoadData(ShowApproved, NumberOfRecords)));
        var _dialog = await dialogService.ShowAsync<GeneralLedgerTransferDialog>(gModel.LedgerTransferID == null ? "ADD" : "EDIT", parms, new DialogOptions() { MaxWidth = MaxWidth.Large, FullWidth = true });
        var result = await _dialog.Result;
        if (!result.Canceled)
        {
            var ReturnData = (GeneralLedgerTransferModel)result.Data;
        }
        LoadData(ShowApproved, NumberOfRecords);
        await Task.Delay(200);
        _busy = false;
    }
}
