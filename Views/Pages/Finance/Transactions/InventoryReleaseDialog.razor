@using ArmsModels.BaseModels.Finance.Transactions;
@using ArmsServices.DataServices.Finance.Transactions;
@attribute [Authorize]
@inject MudBlazor.ISnackbar snackbar
@inject AuthenticationStateProvider auth

@inject IInventoryReleaseService Iservice
@inject IJobcardService IJobcardService
@inject IDialogService DialogService
@inject IInventoryItemService itemIservice

<DialogForm @ref="@dialogForm" ReadOnly="@ReadOnly" Title="Inventory Release" formID="inventoryReleaseForm" model="@model">
    <FormContent>
        <MudPaper Class="p-3">
            <EditForm id="inventoryReleaseForm" OnValidSubmit="OnValidSubmit" EditContext="editContext">
                <ObjectGraphDataAnnotationsValidator />
                <ValidationSummary />
                <MudGrid>
                    <MudItem xs="12" md="6">
                        <MudDatePicker ReadOnly="ReadOnly" Label="Document Date" Variant="Variant.Outlined" Margin="Margin.Dense" DisableToolbar="true" Editable="true" @bind-Date="model.DocumentDate" DateFormat="dd/MM/yyyy" />
                    </MudItem>

                    <MudItem xs="12" md="4">
                        <MudSelect Label="Select Job Card" T="JobcardModel" Value="model.Jobcard" ValueChanged="OnChangeJobcard" ToStringFunc="@(e => e == null ? null : $"{e.JobcardNumber}")" Variant="Variant.Outlined" Margin="Margin.Dense" OffsetY="true" Direction="Direction.Top" AdornmentColor="Color.Secondary">
                            @foreach (var ditem in JobcardList)
                            {
                                <MudSelectItem Value="@ditem">@ditem.JobcardNumber</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>

                    <MudItem xs="12" md="12">
                        <TruckSelector @bind-Value="@model.Truck" BranchID="@branchID"></TruckSelector>
                    </MudItem>

                    <MudItem xs="12" md="12">
                        <StoreSelector @bind-Value="@model.Store" BranchID="@branchID.Value"></StoreSelector>
                    </MudItem>


                    <MudItem xs="12" md="6">
                        <MudTextField @bind-Value="model.TotalAmount" Label="Total Amount" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.TotalAmount)" Disabled></MudTextField>
                    </MudItem>

                    <MudItem xs="12">

                        <h6><u>Items</u></h6>

                        <MudGrid Justify="Justify.Center">
                            <MudItem xs="4" Class="d-flex align-center"><span> <strong> <u>Asset</u></strong> </span></MudItem>
                            <MudItem xs="3" Class="d-flex align-center"><span><strong><u>Amount</u></strong> </span></MudItem>
                            <MudItem xs="3" Class="d-flex align-center"><span><strong><u>Reference</u></strong> </span></MudItem>
                            <MudItem xs="2"></MudItem>
                            @foreach (var item in model.Items)
                            {
                                <MudItem xs="4"> @(ItemList.First(x => x.InventoryItemID == item.ItemID)?.InventoryItemCode) </MudItem>
                                <MudItem xs="3"> @item.ItemQty </MudItem>
                                <MudItem xs="4"> @item.ItemRate </MudItem>
                                <MudItem xs="1" Class="d-flex">
                                    @if (!ReadOnly)
                                    {
                                        <MudIconButton Title="Delete" Color="Color.Error" @onclick="@(()=> DeleteItem(@item))" Icon="@Icons.Material.Filled.Delete" Size="Size.Small" />

                                    }
                                </MudItem>
                            }
                            @if (!ReadOnly)
                            {
                                <MudItem xs="4">
                                    <InventoryItemSelector Value="SelectedItems" ValueChanged="@((InventoryItemModel newValue) => getitemCode(newValue))" />
                                </MudItem>
                                <MudItem xs="3">
                                    <MudTextField @bind-Value="Entrymodel.ItemQty" Label="Quatity" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => Entrymodel.ItemQty)"></MudTextField>
                                </MudItem>
                                <MudItem xs="4">
                                    <MudTextField @bind-Value="Entrymodel.ItemRate" Label="Rate" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => Entrymodel.ItemRate)"></MudTextField>
                                </MudItem>
                                <MudItem xs="1" Class="d-flex align-center"><MudFab OnClick="AddSubList" Color="Color.Primary" Icon="@Icons.Material.Filled.Add" Size="Size.Small" IconSize="Size.Small" /></MudItem>
                            }
                        </MudGrid>
                    </MudItem>
                </MudGrid>
            </EditForm>
        </MudPaper>
    </FormContent>
</DialogForm>

@code {

    [Parameter]
    public InventoryReleaseModel model { get; set; }
    [Parameter]
    public bool ReadOnly { get; set; }

    private GstUsageCodeModel gstusge = new();

    public string Area { get; set; } = null;
    public bool Local { get; set; } = true;
    [Parameter]
    public int? branchID { get; set; }
    private string UserID = null;

    public int SubAssetModel { get; set; }
    private List<InventoryItemModel> ItemList = new();

    private List<JobcardModel> JobcardList = new();
   
    public InventoryItemModel SelectedItems = new();
    private InventoryItemEntryModel Entrymodel = new InventoryItemEntryModel();

    private EditContext editContext;

    DialogForm dialogForm;

    protected override async Task OnInitializedAsync()
    {
        var authprov = await auth.GetAuthenticationStateAsync();
        branchID = int.Parse(authprov.User.Claims.First(x => x.Type == "BranchID").Value);
        var user = authprov.User;
        UserID = user.Identity.Name;

        if (model == null)
        {
            model = new()
                {
                    BranchID = branchID,
                    UserInfo = new() { UserID = UserID, },
                    TotalAmount = 0,
                    NatureOfTransaction = "Inventory Release"
                };
        }
        else
        {
            model.Items = Iservice.GetSub(model.RID).ToList();
        }

        ItemList = itemIservice.SearchByDescription(string.Empty).ToList();
        JobcardList = IJobcardService.SelectByBranch(branchID, true).ToList();
    }

    protected override void OnParametersSet()
    {
        editContext = new EditContext(model);
        // editContext.OnValidationRequested += OnValidationRequestedAsync;
    }

    public void AddSubList()
    {

        Entrymodel.ItemID = SelectedItems.InventoryItemID;


        if (Entrymodel.ItemID == null || Entrymodel.ItemRate == null || Entrymodel.ItemQty == null)
        {
            snackbar.Add("Please fill in all Fields", Severity.Success);
            return;
        }
        
        model.Items.Add(Entrymodel);

        decimal total = ((Entrymodel.ItemQty.Value) * (Entrymodel.ItemRate.Value));
        model.TotalAmount = model.TotalAmount + total;
        Entrymodel = new();

        SelectedItems = null;
        SelectedItems = new();
    }
    
    
    protected void getitemCode(InventoryItemModel item)
    {


        if (item != null)
        {
            if(SelectedItems!= null && SelectedItems.InventoryItemID == null)
            {
                SelectedItems = item;             
            }
            else
            {
                SelectedItems = new InventoryItemModel();
            }
        }

    }

    public void OnChangeJobcard(JobcardModel obj)
    {
        model.Jobcard = obj;

    }

    public void OnChangeTruck(TruckModel obj)
    {
        model.Truck = obj;

    }
    public void OnValidSubmit(EditContext context)
    {
        try
        {
            model = Iservice.Update(model);
            snackbar.Add("Saved Successfully", Severity.Success);
            dialogForm.Close(model);

        }
        catch (Exception ex)
        {
            snackbar.Add(ex.Message, Severity.Error);
        }
    }


    private void DeleteItem(InventoryItemEntryModel ItemDetails)
    {
        if (model.Items.Exists(x => x.ItemID == ItemDetails.ItemID))
        {
            decimal total = (((ItemDetails.ItemQty.Value) * (ItemDetails.ItemRate.Value)));
            int rowIndex = model.Items.IndexOf(ItemDetails);
            model.Items.RemoveAt(rowIndex);
            model.TotalAmount = model.TotalAmount - total;
        }
    }

}
