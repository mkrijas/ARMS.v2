@inject IDialogService DialogService
@inject MudBlazor.ISnackbar snackbar

@inject ITdsRateService tdsService
@inject IGstItemService gstIservice

    <h6>Items</h6>
    <MudSimpleTable Hover="true" Dense="true" >
        <thead>
            <tr>
                <th width="25%">Item Name</th>
                <th width="15%">Quantity</th>
                <th width="15%">Rate</th>
                <th width="15%">Amount</th>
                <th width="15%">Gst/TDS</th>
                <th width="15%"></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in ItemList)
            {
                <tr>
                    <td>@item.ItemDescription</td>
                    <td>@item.ItemQty</td>
                    <td>@item.ItemRate</td>                    
                    <td>@item.Amount</td>
                    <td> @(item.CGST+item.SGST+item.IGST)/@item.TDS </td>
                    <td>
                        @if (!ReadOnly)
                        {
                            <MudFab Color="Color.Error" @onclick="@(()=> Delete(@item))" Icon="@Icons.Material.Filled.Delete" Size="Size.Small" IconSize="Size.Small" />
                            <MudFab Color="Color.Info" @onclick="@(()=> OpenDialogTaxRates(@item))" Icon="@Icons.Material.Filled.CurrencyExchange" Size="Size.Small" IconSize="Size.Small" />
                        }
                    </td>
                </tr>
            }
            @if (!ReadOnly)
            {
                <tr>
                    <td colspan="2">
                        <InventoryItemSelector Value="InventoryItem" ValueChanged="ItemSelected" />
                    </td>
                    <td>
                        <MudTextField Label="Quantity" @bind-Value="Model.ItemQty" Variant="Variant.Outlined" Margin="Margin.Dense" ></MudTextField>
                    </td>
                    <td >
                    <MudTextField Label="Item Rate" @bind-Value="Model.ItemRate" Variant="Variant.Outlined" Margin="Margin.Dense"></MudTextField>
                    </td>                   
                    <td >
                        <MudTextField Label="Amount" @bind-Value="Model.Amount" ReadOnly="true" Variant="Variant.Outlined" Margin="Margin.Dense" ></MudTextField>
                    </td>
                    
                    <td>
                        <MudFab OnClick="AddItems" Color="Color.Primary" Icon="@Icons.Material.Filled.Add" Size="Size.Small" IconSize="Size.Small" />
                    </td>
                </tr>
            }
        </tbody>
    </MudSimpleTable>


@code {

    [Parameter]
    public List<TaxPurchaseItemModel> ItemList { get; set; }
    [Parameter]
    public bool ReadOnly { get; set; }
    [Parameter]
    public int? BranchID { get; set; }
    [Parameter]
    public PartyModel PartyInfo { get; set; }
    [Parameter]
    public bool Local { get; set; } = true;
    [Parameter]
    public bool NonInventory { get; set; } = true;
    [Parameter]
    public EventCallback<TaxPurchaseItemModel> OnItemAdded { get; set; }
    [Parameter]
    public EventCallback OnDelete { get; set; }


    InventoryItemModel InventoryItem = new();
    TaxPurchaseItemModel Model = new TaxPurchaseItemModel();
    EditContext editContext;

    protected override void OnParametersSet()
    {
        if (editContext == null)
        {
            editContext = new EditContext(Model);
            editContext.EnableDataAnnotationsValidation();
        }
    }

    public async Task AddItems()
    {
        if (AddTax() && editContext.Validate())
        {
            await OnItemAdded.InvokeAsync(Model);
            Model = new();
            InventoryItem = null;
        }
    }

    void ItemSelected(InventoryItemModel item)
    {
        InventoryItem = item;
        Model.ItemID = InventoryItem?.InventoryItemID;
        Model.ItemDescription = InventoryItem?.ItemDecription;
        Model.CoaID = NonInventory ? (InventoryItem?.Group.MappedNonInventoryPurchaseHead) : InventoryItem?.Group.MappedPurchaseHead;
    }

    private async Task OpenDialogTaxRates(TaxPurchaseItemModel i)
    {
        GstModel taxModel = new GstModel();
        taxModel.CGST = i.CGST;
        taxModel.IGST = i.IGST;
        taxModel.TDS = i.TDS;
        taxModel.SGST = i.SGST;
        taxModel.GstRate = i.GstRate;
        DialogParameters parms = new DialogParameters();
        parms.Add("tax", taxModel);
        parms.Add("ReadOnly", ReadOnly);
        var dialog = DialogService.Show<TaxRatedialog>(i.PID == null ? "ADD" : "EDIT", parms, new DialogOptions() { MaxWidth = MaxWidth.Small, FullWidth = true });
        var result = await dialog.Result;
        if (!result.Canceled)
        {
            taxModel = (GstModel)result.Data;
            i.CGST = taxModel.CGST;
            i.IGST = taxModel.IGST;
            i.TDS = taxModel.TDS;
            i.SGST = taxModel.SGST;
            i.GstRate = taxModel.GstRate;
        }
    }

    private async Task Delete(TaxPurchaseItemModel i)
    {
        int rowIndex = ItemList.IndexOf(i);
        ItemList.RemoveAt(rowIndex);
        await OnDelete.InvokeAsync();
    }


    private bool AddTax()
    {
        if (Model?.ItemID != null && Model.Amount != null)
        {
            if (PartyInfo == null)
            {
                snackbar.Add("Select Party!", Severity.Error);
                return false;
            }
            var gstItem = gstIservice.SelectByItem(Model?.ItemID ?? 0, DateTime.Today);
            Model.GstRate = gstItem?.TaxRate;

            decimal taxRate = Model.GstRate??0;
            if (!Local)
            {
                Model.IGST = Math.Round(Model.Amount.Value *  taxRate / 100, 2);
            }
            else
            {
                Model.SGST = Model.CGST = Math.Round(Model.Amount.Value * taxRate / 200, 2);
            }
            decimal tdsRate = tdsService.GetTdsRate(PartyInfo.PartyID, Model.CoaID);
            Model.TDS = Math.Round((Model.Amount.Value * tdsRate) / 100, 2);           
            return true;
        }
        return false;
    }

}

