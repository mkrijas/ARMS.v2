@inject IDialogService DialogService
@inject MudBlazor.ISnackbar snackbar
@inject ITdsRateService tdsService
@inject IGstItemService gstIservice

@if (!ReadOnly || ItemList.Any())
{
    <MudItem xs="12">
        <div class="modern-admin-table pb-3">
            <MudGrid Justify="Justify.Center" Class="admin-table-header mb-2 py-3 px-4">
                <MudItem xs="@(ShowAdvanced ? 3 : 5)"><span class="admin-header-text" style="font-size: 0.9rem !important;">ITEM DETAILS</span></MudItem>
                <MudItem xs="1"><span class="admin-header-text" style="font-size: 0.9rem !important;">QTY</span></MudItem>
                <MudItem xs="1"><span class="admin-header-text" style="font-size: 0.9rem !important;">RATE</span></MudItem>
                @if (ShowAdvanced)
                {
                    <MudItem xs="2"><span class="admin-header-text" style="font-size: 0.9rem !important;">COST CENTER</span></MudItem>
                    <MudItem xs="1"><span class="admin-header-text" style="font-size: 0.9rem !important;">DIMENSION</span></MudItem>
                }
                <MudItem xs="1"><span class="admin-header-text" style="font-size: 0.9rem !important;">AMOUNT</span></MudItem>
                <MudItem xs="2"><span class="admin-header-text" style="font-size: 0.9rem !important;">TAX / TDS</span></MudItem>
                <MudItem xs="1"><span class="admin-header-text" style="font-size: 0.9rem !important;">ACTIONS</span></MudItem>
            </MudGrid>
            @foreach (var item in ItemList)
            {
                <MudGrid Justify="Justify.Center" Class="py-3 border-bottom-subtle px-4 align-center">
                    <MudItem xs="@(ShowAdvanced ? 3 : 5)">
                        <MudText Typo="Typo.body1" Style="font-weight: 700; color: #141A46; font-size: 1rem;">
                            @item.ItemCode | @item.ItemDescription
                        </MudText>
                        <MudText Typo="Typo.caption" Style="color: #667085; font-size: 0.85rem; font-weight: 500;">@item.ItemGroupDescription @(string.IsNullOrEmpty(item.PartNumber) ? "" : $"| {item.PartNumber}")</MudText>
                    </MudItem>
                    <MudItem xs="1">
                        <MudText Typo="Typo.body1" Style="font-size: 0.95rem;">@item.ItemQty</MudText>
                    </MudItem>
                    <MudItem xs="1">
                        <MudText Typo="Typo.body1" Style="font-size: 0.95rem;">@item.ItemRate</MudText>
                    </MudItem>
                    @if (ShowAdvanced)
                    {
                        <MudItem xs="2">
                            <MudText Typo="Typo.body1" Style="font-size: 0.9rem;">@item.CostCenterVal</MudText>
                        </MudItem>
                        <MudItem xs="1">
                            <MudText Typo="Typo.body1" Style="font-size: 0.9rem;">@item.DimensionVal</MudText>
                        </MudItem>
                    }
                    <MudItem xs="1">
                        <MudText Typo="Typo.body1" Style="font-weight: 800; color: #FF9F43; font-size: 1.05rem;">@item.Amount</MudText>
                    </MudItem>
                    <MudItem xs="2">
                        <MudText Typo="Typo.body2" Color="Color.Secondary" Style="font-weight: 600; font-size: 0.9rem;">@(item.CGST + item.SGST + item.IGST) / @item.TDS</MudText>
                    </MudItem>
                    <MudItem xs="1" Class="d-flex">
                        @if (!ReadOnly)
                        {
                            <MudIconButton Title="Delete" Color="Color.Error" @onclick="@(()=> Delete(@item))" Icon="@Icons.Material.Filled.DeleteOutline" Size="Size.Medium" />
                        }
                        <MudIconButton Title="Show Taxes" Color="Color.Surface" @onclick="@(()=> OpenDialogTaxRates(@item))" Icon="@Icons.Material.Filled.Percent" Size="Size.Medium" />
                    </MudItem>
                </MudGrid>
            }
            @if (!ReadOnly && NonInventory)
            {
                <div class="pa-5 mt-4" style="background: rgba(255, 159, 67, 0.03); border-radius: 16px; border: 1px dashed rgba(255, 159, 67, 0.3);">
                    <MudGrid Justify="Justify.Center" Spacing="2">
                        <MudItem xs="12" md="@(ShowAdvanced ? 3 : 6)">
                            <InventoryItemSelector Class="admin-input-group" Value="InventoryItem" ValueChanged="ItemSelected" />
                        </MudItem>
                        <MudItem xs="4" md="1">
                            <MudNumericField Class="admin-input-group" HideSpinButtons Label="Qty" @bind-Value="Model.ItemQty" Variant="Variant.Outlined" Margin="Margin.Dense"></MudNumericField>
                        </MudItem>
                        <MudItem xs="4" md="1">
                            <MudNumericField Class="admin-input-group" HideSpinButtons Label="Rate" @bind-Value="Model.ItemRate" Variant="Variant.Outlined" Margin="Margin.Dense"></MudNumericField>
                        </MudItem>
                        @if (ShowAdvanced)
                        {
                            <MudItem xs="4" md="2">
                                <CostCenterSelector Class="admin-input-group" @bind-Value="@Model.CostCenter" @bind-ValueText="@Model.CostCenterVal" ReadOnly="@ReadOnly"></CostCenterSelector>
                            </MudItem>
                            <MudItem xs="6" md="2">
                                <DimensionSelector Class="admin-input-group" @bind-Value="@Model.Dimension" @bind-ValueText=@Model.DimensionVal ReadOnly="@ReadOnly"></DimensionSelector>
                            </MudItem>
                        }
                        <MudItem xs="6" md="2">
                            <MudNumericField Class="admin-input-group" Label="Amount" @bind-Value="Model.Amount" Variant="Variant.Outlined" Margin="Margin.Dense" HideSpinButtons="true"></MudNumericField>
                        </MudItem>
                        <MudItem xs="12" md="1" Class="d-flex align-center">
                            <MudSpacer />
                            <MudIconButton Title="Add" OnClick="AddItems" Color="Color.Primary" Variant="Variant.Filled" Style="background: #FF9F43; border-radius: 10px; height: 40px; width: 50px;" Icon="@Icons.Material.Filled.Add" Size="Size.Medium" />
                        </MudItem>
                    </MudGrid>
                </div>
            }
        </div>
    </MudItem>
}
@code {

    [Parameter]
    public List<TaxPurchaseItemModel> ItemList { get; set; }
    [Parameter]
    public bool ReadOnly { get; set; }
    [Parameter]
    public DateTime? DocDate { get; set; }
    [Parameter]
    public int? BranchID { get; set; }
    [Parameter]
    public PartyModel PartyInfo { get; set; }
    [Parameter]
    public bool Local { get; set; } = true;
    [Parameter]
    public bool IsTaxable { get; set; } = true;
    [Parameter]
    public bool ShowAdvanced { get; set; }

    [Parameter]
    public bool NonInventory { get; set; }
    [Parameter]
    public EventCallback<TaxPurchaseItemModel> OnItemAdded { get; set; }
    [Parameter]
    public EventCallback OnAmountChange { get; set; }
    [Parameter]
    public bool EditMode { get; set; } = true;
    InventoryItemModel InventoryItem = new();
    TaxPurchaseItemModel Model = new TaxPurchaseItemModel();
    EditContext editContext;
    private bool _busy;

    protected override void OnParametersSet()
    {
        if (editContext == null)
        {
            editContext = new EditContext(Model);
            editContext.EnableDataAnnotationsValidation();
        }
    }

    protected override void OnInitialized()
    {  
        if (!EditMode)
        {
            foreach (var item in ItemList)
            {
                AddTax(item);
            }
        }
    }

    // Method to add items to the inventory
    public async Task AddItems()
    {
        if (AddTax(Model) && editContext.Validate())
        {
            await OnItemAdded.InvokeAsync(Model);
            Model = new();
            InventoryItem = null;
        }
        else
        {
            snackbar.Add("Entered Items are invalid", Severity.Error);
        }
    }

    // Method to handle item selection
    void ItemSelected(InventoryItemModel item)
    {  
        InventoryItem = item;
        if (item is not null)
        {
            Model.CoaID = NonInventory ? (InventoryItem?.Group.MappedNonInventoryPurchaseHead) : InventoryItem?.Group.MappedPurchaseHead;
            if (Model.CoaID is null)
            {
                snackbar.Add("AccountHead not mapped!!", Severity.Warning);
                InventoryItem = null;
                return;
            }
            Model.ItemID = InventoryItem?.InventoryItemID;
            Model.ItemDescription = InventoryItem?.ItemDescription;
            Model.ItemGroupDescription = InventoryItem?.ItemGroup.ItemGroupDescription;
        }
    }

    // Method to open the dialog for tax rates
    private async Task OpenDialogTaxRates(TaxPurchaseItemModel i)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        _busy = true;
        GstModel taxModel = new GstModel();
        taxModel.CGST = i.CGST;
        taxModel.IGST = i.IGST;
        taxModel.TDS = i.TDS;
        taxModel.SGST = i.SGST;
        taxModel.GstRate = i.GstRate;
        DialogParameters parms = new DialogParameters();
        parms.Add("tax", taxModel);
        parms.Add("ReadOnly", ReadOnly);
        var dialog = DialogService.Show<TaxRatedialog>(i.PID == null ? "ADD" : "EDIT", parms, new DialogOptions() { MaxWidth = MaxWidth.Small, FullWidth = true });
        var result = await dialog.Result;
        if (!result.Canceled)
        {
            taxModel = (GstModel)result.Data;
            i.CGST = taxModel.CGST;
            i.IGST = taxModel.IGST;
            i.TDS = taxModel.TDS;
            i.SGST = taxModel.SGST;
            i.GstRate = taxModel.GstRate;

            await OnAmountChange.InvokeAsync();
        }
        await Task.Delay(200);
        _busy = false;
    }

    // Method to delete an item from the inventory
    private async Task Delete(TaxPurchaseItemModel i)
    {
        int rowIndex = ItemList.IndexOf(i);
        ItemList.RemoveAt(rowIndex);
        await OnAmountChange.InvokeAsync();
    }

    // Method to add tax details to the item
    private bool AddTax(TaxPurchaseItemModel item)
    {
        if (item?.ItemID != null && item.Amount != null)
        {
            if (PartyInfo == null)
            {                
                snackbar.Add("Select Party !", Severity.Error);
                return false;
            }

            // Get GST item details based on the item ID
            var gstItem = gstIservice.SelectByItem(item?.ItemID ?? 0, DocDate);
            item.GstRate = (gstItem?.TaxRate)??0;

            // Calculate TDS based on the party information
            decimal tdsRate = tdsService.GetTdsRate(PartyInfo.PartyID, item.CoaID);
            item.TDS = Math.Round((item.Amount.Value * tdsRate) / 100, MidpointRounding.AwayFromZero);
            if (!IsTaxable)
            {
                return true;
            }          

            decimal taxRate = item.GstRate.Value;
            if (!Local)
            {
                item.IGST = Math.Round(item.Amount.Value * taxRate / 100, 2);
                item.CGST = item.SGST = 0;
            }
            else
            {
                item.SGST = item.CGST = Math.Round(item.Amount.Value * taxRate / 200, 2);
                item.IGST = 0;
            }
           
            return true;
        }
        return false;
    }
}
