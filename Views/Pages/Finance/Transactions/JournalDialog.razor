@using System.Threading;
@attribute [Authorize]
@inject AuthenticationStateProvider auth
@inherits DialogFormComponentBase<JournalModel>
@inject IRoleService<RoleModel> Irole
@inject IJournalService Iservice
@inject MudBlazor.ISnackbar snackbar
@inject IDialogService DialogService

<DialogForm @ref="@dialogForm" ReadOnly="@ReadOnly" Title="Journal Entry" Subtitle="Record and balance financial transactions with double-entry precision." Icon="@Icons.Material.Filled.AccountBalance" AdminStyle="true" formID="journalForm" DocumentDetails="DocInfo" model="@model" _busy="_busy">
    <FormContent>
        <div class="dialog-content-wrapper">
            <EditForm id="journalForm" OnValidSubmit="OnValidSubmit" Model="model">
                <ObjectGraphDataAnnotationsValidator />
                
                <div class="admin-glass-card pa-6">
                    <span class="admin-section-label">General Information</span>
                    <MudGrid Spacing="3">
                        <MudItem xs="12" md="4">
                            <MudDatePicker Label="Document Date" ReadOnly="ReadOnly" Variant="Variant.Outlined" Margin="Margin.Dense" DisableToolbar="true" Editable="true" @bind-Date="model.DocumentDate" DateFormat="dd/MM/yyyy" MaxDate="DateTime.Now" Class="admin-input-group" />
                        </MudItem>
                        <MudItem xs="12">
                            <MudTextField ReadOnly="ReadOnly" @bind-Value="model.Narration" Lines="3" Label="Narration / Description" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.Narration)" Class="admin-input-group"></MudTextField>
                        </MudItem>
                    </MudGrid>
                </div>

                <div class="admin-glass-card pa-0 overflow-hidden">
                    <div class="d-flex align-center justify-space-between px-6 py-4 border-bottom-subtle" style="background: rgba(255, 159, 67, 0.02);">
                        <span class="admin-section-label mb-0">Transaction Ledger</span>
                        <div class="d-flex align-center gap-4">
                            <MudText Typo="Typo.caption" Style="color: var(--admin-text-muted); font-weight: 700;">DIFFERENCE:</MudText>
                            <MudText Typo="Typo.body2" Style="@($"font-weight: 800; color: {(CheckEqual == 0 ? "#4caf50" : "#f44336")};")">₹ @CheckEqual</MudText>
                        </div>
                    </div>

                    <div class="modern-admin-table">
                        <MudGrid Justify="Justify.Center" Class="admin-table-header mb-2 py-3 px-4">
                            <MudItem xs="3"><span class="admin-header-text">ACCOUNT HEAD</span></MudItem>
                            <MudItem xs="2"><span class="admin-header-text">REFERENCE</span></MudItem>
                            <MudItem xs="2"><span class="admin-header-text">AMOUNT</span></MudItem>
                            <MudItem xs="2"><span class="admin-header-text">COST CENTER</span></MudItem>
                            <MudItem xs="2"><span class="admin-header-text">DIMENSION</span></MudItem>
                            <MudItem xs="1"><span class="admin-header-text">ACTION</span></MudItem>
                        </MudGrid>

                        @foreach (var item in model.JournalSubList)
                        {
                            <MudGrid Justify="Justify.Center" Class="py-3 border-bottom-subtle px-4 align-center">
                                <MudItem xs="3">
                                    <MudText Typo="Typo.body1" Style="font-weight: 700; color: #141A46;">@item.Coa.AccountName</MudText>
                                </MudItem>
                                <MudItem xs="2">
                                    <MudText Typo="Typo.body2">@item.Reference</MudText>
                                </MudItem>
                                <MudItem xs="2">
                                    <div class="d-flex align-center gap-1">
                                        <MudText Typo="Typo.body1" Style="font-weight: 800; color: #FF9F43;">@item.Amount</MudText>
                                        <MudChip T="string" Size="Size.Small" Color="@(item.DrCrType == 1 ? Color.Primary : Color.Secondary)" Variant="Variant.Text" Style="font-weight: 900; font-size: 0.7rem;">@item.DrCrText</MudChip>
                                    </div>
                                </MudItem>
                                <MudItem xs="2">
                                    <MudText Typo="Typo.body2">@item.CostCenterVal</MudText>
                                </MudItem>
                                <MudItem xs="2">
                                    <MudText Typo="Typo.body2">@item.DimensionVal</MudText>
                                </MudItem>
                                <MudItem xs="1" Class="d-flex">
                                    @if (!ReadOnly)
                                    {
                                        <MudIconButton Title="Delete" Color="Color.Error" @onclick="@(()=> DeleteSubList(@item))" Icon="@Icons.Material.Filled.DeleteOutline" Size="Size.Medium" />
                                    }
                                </MudItem>
                            </MudGrid>
                        }

                        @if (!ReadOnly)
                        {
                            <div class="pa-5" style="background: rgba(255, 159, 67, 0.03); border-top: 1px solid rgba(255, 159, 67, 0.1);">
                                <MudGrid Spacing="2" Justify="Justify.Center">
                                    <MudItem xs="12" md="3">
                                        <CoaSelector @bind-Value="@JournalSub.Coa" LabelName="Select Account" Class="admin-input-group" />
                                    </MudItem>
                                    <MudItem xs="6" md="2">
                                        <MudTextField @bind-Value="@JournalSub.Reference" Label="Reference" Variant="Variant.Outlined" Margin="Margin.Dense" Class="admin-input-group"></MudTextField>
                                    </MudItem>
                                    <MudItem xs="5" md="2">
                                        <MudNumericField HideSpinButtons Label="Amount" @bind-Value="@JournalSub.Amount" Variant="Variant.Outlined" Margin="Margin.Dense" Class="admin-input-group"></MudNumericField>
                                    </MudItem>
                                    <MudItem xs="4" md="1">
                                        <MudSelect T="int?" Label="Dr/Cr" @bind-Value="@JournalSub.DrCrType" Variant="Variant.Outlined" Margin="Margin.Dense" Class="admin-input-group">
                                            <MudSelectItem T="int?" Value="1">Dr</MudSelectItem>
                                            <MudSelectItem T="int?" Value="-1">Cr</MudSelectItem>
                                        </MudSelect>
                                    </MudItem>
                                    <MudItem xs="4" md="1">
                                        <CostCenterSelector @bind-Value="JournalSub.CostCenter" @bind-ValueText="@JournalSub.CostCenterVal" Class="admin-input-group" />
                                    </MudItem>
                                    <MudItem xs="4" md="1">
                                        <DimensionSelector @bind-Value="JournalSub.Dimension" @bind-ValueText="@JournalSub.DimensionVal" Class="admin-input-group" />
                                    </MudItem>
                                    <MudItem xs="12" md="1" Class="d-flex align-center">
                                        <MudSpacer />
                                        <MudIconButton Title="Add Entry" OnClick="AddSubList" Color="Color.Primary" Variant="Variant.Filled" Style="background: #FF9F43; border-radius: 10px; height: 45px; width: 50px;" Icon="@Icons.Material.Filled.Add" Size="Size.Large" />
                                    </MudItem>
                                </MudGrid>
                            </div>
                        }
                    </div>
                </div>
            </EditForm>
        </div>
    </FormContent>
    <VerificationStatus>
        <AutherizationStatusComponent CreatedBy="@model.UserInfo" DocTypeID="@JournalDocTypeID" DocDate="@DocDate" DocType="@DocType" DocNumber="@DocNumber" PageToRedirectLink="@PageToRedirectLink" DocumentID="model.JournalID" OnApprove="Approve"></AutherizationStatusComponent>
    </VerificationStatus>
</DialogForm>

@code {

    private JournalSubModel JournalSub { get; set; } = new();
    private int? branchID = null;
    private string UserID = null;
    private decimal? CheckEqual;
    private EditContext editContext;
    [Parameter]
    public string PageToRedirectLink { get; set; }
    public string DocNumber { get; set; }
    public DateTime? DocDate { get; set; }
    public string DocType { get; set; }
    public List<JournalSubModel> SubList { get; set; }
    string UserIDTemp;
    private bool _busy;

    // Document information model for the tax purchase
    protected override DocumentInfoModel DocInfo { get; set; } = new();

    public bool HasPermissionJournalServiceEdit { get; set; } = false;
    public bool HasPermissionJournalServiceApprove { get; set; } = false;
    public int JournalDocTypeID = 18;

    protected override async Task OnInitializedAsync()
    {
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionJournalServiceEdit = await Irole.HasClaim(JournalDocTypeID.ToString(), "Edit", ctc.Token);
        HasPermissionJournalServiceApprove = await Irole.HasClaim(JournalDocTypeID.ToString(), "Approve", ctc.Token);

        DocInfo.DocumentTypeID = JournalDocTypeID;
        DocInfo.DocumentID = model.JournalID;

        await base.OnInitializedAsync();

        if (model == null || model != null && model.JournalID == null || model != null && model.JournalID == 0)
        {
            if (model == null)
            {
                model = new()
                    {
                        UserInfo = new() { UserID = UserID, },
                        TotalAmount = 0,
                        NatureOfTransaction = "Journal"
                    };
            }
            else
            {
                model.UserInfo = new() { UserID = UserID, }; ;
                model.TotalAmount = 0;
                model.NatureOfTransaction = "Journal";
            }
        }
        else
        {
            // Load sub-list if JournalID is valid
            model.JournalSubList = Iservice.GetSubList(model.JournalID).ToList();
            UserIDTemp = model.UserInfo.UserID;
        }
        DocNumber = model.DocumentNumber;
        DocDate = model.DocumentDate;
        DocType = model.NatureOfTransaction;
    }

    protected override void OnParametersSet()
    {
        editContext = new EditContext(model);

        DocInfo.DocumentTypeID = JournalDocTypeID;
        DocInfo.DocumentID = model.JournalID;
    }

    // Method to delete a sub-entry from the journal
    private void DeleteSubList(JournalSubModel JournalSub)
    {
        if (model.JournalSubList.Exists(x => x.JournalSubID == JournalSub.JournalSubID))
        {
            int rowIndex = model.JournalSubList.IndexOf(JournalSub);
            model.JournalSubList.RemoveAt(rowIndex);
            model.TotalAmount = model.JournalSubList.Where(y => y.DrCrType == 1).Sum(x => x.Amount);
            CheckEqual = model.JournalSubList.Sum(x => x.DrCrType * x.Amount);
        }
    }

    // Method to add a sub-entry to the journal
    public void AddSubList()
    {
        if (JournalSub.Coa == null)
        {
            snackbar.Add("Please select Account", Severity.Error);
            return;
        }
        if (JournalSub.DrCrType == null)
        {
            snackbar.Add("Please select Dr/Cr", Severity.Error);
            return;
        }
        if (JournalSub.Amount == null)
        {
            snackbar.Add("Please add Amount.", Severity.Error);
            return;
        }
        model.JournalSubList.Add(JournalSub);
        model.TotalAmount = model.JournalSubList.Where(y => y.DrCrType == 1).Sum(x => x.Amount);
        CheckEqual = model.JournalSubList.Sum(x => x.DrCrType * x.Amount);
        JournalSub = new();
    }

    // Method to update the Journal model
    protected override async Task<int> Update(JournalModel editModel)
    {
        if (await validate(model))
        {
            model = Iservice.Update(model); // Update the model using the service
            return model.JournalID ?? 0;
        }
        return 0;
    }

    // Method to validate the Journal model
    public async Task<bool> validate(JournalModel editModel)
    {
        CheckEqual = model.JournalSubList.Sum(x => x.DrCrType * x.Amount);
        if (CheckEqual != 0)
        {
            snackbar.Add("Please check the amount", Severity.Warning);
            return false;
        }
        foreach (var item in model.JournalSubList)
        {
            item.CoaID = item.Coa.CoaID;
        }
        return true;
    }

    // Method to approve the Journal model
    protected override int UpdateApproval(DataApprovedStatus aprvd)
    {
        int result = Iservice.Approve(model.JournalID, model.UserInfo.UserID, aprvd.Remarks); // Call the service to approve
        model.UserInfo.UserID = UserIDTemp;
        return result;
    }
}
