@inject IMileageShortageReceiptService Iservice
@using System.Threading;
@using ArmsModels.BaseModels.Finance.Transactions
@using Core.BaseModels.Finance.Transactions;

@inject ITripService tripService;
@inject IOutstandingBillsService OBIservice
@inject ICostCenterService costIservice
@inject TruckDataArrayModel data
@inject IChartOfAccountService accountService
@inject IDimensionService dimensionIservice
@inject NavigationManager uriHelper;
@inject MudBlazor.ISnackbar snackbar
@inject AuthenticationStateProvider auth
@inject IRoleService<RoleModel> Irole
@attribute [Authorize]
@inject IDialogService DialogService

<DialogForm @ref="@dialogForm" ReadOnly="@ReadOnly" Title="Mileage Shortage Receipt" formID="MileageShortageReceiptForm" DocumentDetails="DocumentDetails" model="@model" _busy="_busy">
    <FormContent>
        <MudPaper Class="p-3">
            <EditForm id="MileageShortageReceiptForm" OnValidSubmit="OnValidSubmit" EditContext="editContext">
                <ObjectGraphDataAnnotationsValidator />
                <ValidationSummary />
                <MudGrid>
                    <MudItem xs="12" md="4">
                        <MudTextField ReadOnly="ReadOnly" @bind-Value="model.TripNo" Label="Trip No" Variant="Variant.Outlined" Margin="Margin.Dense" Disabled></MudTextField>
                     </MudItem>
                     <MudItem xs="12" md="4">
                         <MudDatePicker ReadOnly="ReadOnly" Label="Document Date" Variant="Variant.Outlined" Margin="Margin.Dense" DisableToolbar="true" Editable="true" @bind-Date="model.DocumentDate" DateFormat="dd/MM/yyyy" />
                     </MudItem>
                     <MudItem xs="12" md="4">
                         <MudTextField ReadOnly="ReadOnly" @bind-Value="model.Reference" Label="Reference" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.Reference)"></MudTextField>
                     </MudItem>
                     <MudItem xs="12" md="4">
                         <CostCenterSelector @bind-Value="model.CostCenter" ReadOnly="@ReadOnly" />
                     </MudItem>
                     <MudItem xs="12" md="4">
                         <DimensionSelector @bind-Value="model.Dimension" ReadOnly="@ReadOnly" />
                     </MudItem>
                     <MudItem md="4">
                     </MudItem>
                     <MudItem xs="12" md="4">
                         <MudTextField ReadOnly="ReadOnly" @bind-Value="model.RunningKM" Label="Running KM" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.RunningKM)" Disabled></MudTextField>
                     </MudItem>
                     <MudItem xs="12" md="4">
                         <MudTextField ReadOnly="ReadOnly" @bind-Value="model.ConsumedFuel" Label="Consumed Fuel" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.ConsumedFuel)" Disabled></MudTextField>
                     </MudItem>
                     <MudItem xs="12" md="4">
                         <MudNumericField HideSpinButtons @bind-Value="model.AllottedMileage" Label="Mileage Norms" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.AllottedMileage)"></MudNumericField>
                     </MudItem>
                     <MudItem xs="12" md="4">
                         <MudNumericField HideSpinButtons @bind-Value="model.AllottedDistance" Label="Distance Norms in KM" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.AllottedDistance)"></MudNumericField>
                     </MudItem>
                     <MudItem xs="12" md="4">
                         <MudNumericField HideSpinButtons @bind-Value="model.FuelPrice" Label="Fuel Price" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.FuelPrice)"></MudNumericField>
                     </MudItem>
                     <MudItem xs="12" md="4">
                         <MudTooltip Text="Calculate">
                             <MudButton @onclick="CalculateTotalAmountToDeduct" Variant="Variant.Filled" Color="Color.Primary">Calculate Amount</MudButton>
                         </MudTooltip>
                     </MudItem>
                     <MudItem xs="12" md="4">
                         <MudTextField @bind-Value="model.TotalAmount" Label="Total Amount" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.TotalAmount)" Disabled></MudTextField>
                     </MudItem>
                     <MudItem xs="12" md="12">
                         <MudTextField ReadOnly="ReadOnly" @bind-Value="model.Narration" Lines="2" Label="Narration" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.Narration)"></MudTextField>
                     </MudItem>
                     <MudItem xs="12">
                     </MudItem>
                 </MudGrid>
             </EditForm>
         </MudPaper>
     </FormContent>
     <VerificationStatus>
         <AutherizationStatusComponent DocTypeID="@MileageShortageReceiptDocTypeID" DocDate="@DocDate" DocType="@DocType" DocNumber="@DocNumber" PageToRedirectLink="@PageToRedirectLink" DocumentID="model.MileageShortageReceiptID" OnApprove="Approve"></AutherizationStatusComponent>
     </VerificationStatus>
 </DialogForm>

 @code {

    [Parameter]
    public MileageShortageReceiptModel model { get; set; }
    [Parameter]
    public bool ReadOnly { get; set; }
    private EditContext editContext;
    DialogForm dialogForm;
    [Parameter]
    public string PageToRedirectLink { get; set; }
    public string DocNumber { get; set; }
    public DateTime? DocDate { get; set; }
    public string DocType { get; set; }
    bool IsDisableSubmit = false;
    [Parameter]
    public string TripNo { get; set; }
    private int? branchID = null;
    private string UserID = null;
    public GstUsageCodeModel gstusge = new();
    ValidationMessageStore validationMessageStore;
    private bool _busy;


    public DocumentInfoModel DocumentDetails { get; set; } = new();


    public bool HasPermissionMileageShortageReceiptServiceEdit { get; set; } = false;
    public bool HasPermissionMileageShortageReceiptServiceApprove { get; set; } = false;
    public int MileageShortageReceiptDocTypeID = 30;
    public IEnumerable<MileageShortageReceiptModel> mileages;

    protected override async Task OnInitializedAsync()
    {
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionMileageShortageReceiptServiceEdit = await Irole.HasClaim(MileageShortageReceiptDocTypeID.ToString(), "Edit", ctc.Token);
        HasPermissionMileageShortageReceiptServiceApprove = await Irole.HasClaim(MileageShortageReceiptDocTypeID.ToString(), "Approve", ctc.Token);

        editContext = new EditContext(model);
        editContext.OnFieldChanged += EditContextOnFieldChanged;
        validationMessageStore = new ValidationMessageStore(editContext);

        var authprov = await auth.GetAuthenticationStateAsync();
        var User = authprov.User;
        branchID = int.Parse(User.Claims.First(x => x.Type == "BranchID").Value);
        UserID = User.Identity.Name;
        if (model.MileageShortageReceiptID == null)
        {
            model.NatureOfTransaction = "Mileage Shortage";
            model.BranchID = branchID;
        }
        else
        {

        }
        DocNumber = model.DocumentNumber;
        DocDate = model.DocumentDate;
        DocType = model.NatureOfTransaction;
    }

    protected override void OnParametersSet()
    {

        DocumentDetails.DocumentTypeID = MileageShortageReceiptDocTypeID;
        DocumentDetails.DocumentID = model.MileageShortageReceiptID;
    }

    protected async Task Approve(DataApprovedStatus aprvd)
    {
        if (HasPermissionMileageShortageReceiptServiceApprove)
        {
            if (aprvd.IsApprove)
            {
                model.UserInfo.UserID = UserID;
                try
                {
                    Iservice.Approve(model.MileageShortageReceiptID, model.UserInfo.UserID, aprvd.Remarks);
                    snackbar.Add("Approved Successfully", Severity.Success);
                }
                catch (Exception ex)
                {
                    snackbar.Add(ex.Message, Severity.Error);
                }
            }
        }
        else
        {
            bool? result = await DialogService.ShowMessageBox(
                "Permission denied!",
                "You dont have any permission to Approve MileageShortageReceipt.");
        }
    }

    void EditContextOnFieldChanged(object obj, FieldChangedEventArgs e)
    {
        validationMessageStore.Clear();
        var fieldName = e.FieldIdentifier.FieldName;
        if (fieldName == "AllottedMileage" || fieldName == "AllottedDistance" || fieldName == "FuelPrice")
        {
            validationMessageStore.Add(e.FieldIdentifier, "Please calculate before submission!.");
            editContext.NotifyValidationStateChanged();
        }
    }

    public async Task OnValidSubmit(EditContext context)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is being submitted!", Severity.Warning);
            return;
        }
        _busy = true;

        if (HasPermissionMileageShortageReceiptServiceEdit)
        {
            model.UserInfo.UserID = UserID;
            try
            {
                
                mileages = Iservice.SelectByTripID(model.TripID);
                if(mileages.Any())
                {
                    snackbar.Add("Mileage shortage receipt already created for this Trip", Severity.Warning);
                }
                else
                {
                    Iservice.Update(model);
                    model = new();
                    snackbar.Add("Saved Successfully", Severity.Success);
                }
                
            }
            catch (Exception ex)
            {
                snackbar.Add(ex.Message, Severity.Warning);
            }
            dialogForm.Close(model);
        }
        else
        {
            bool? result = await DialogService.ShowMessageBox(
                "Permission denied!",
                "You dont have any permission to Edit MileageShortageReceipt.");
        }
        await Task.Delay(200);
        _busy = false;
    }

    private async Task CalculateTotalAmountToDeduct()
    {
        if (model.ConsumedFuel == null)
        {
            bool? result = await DialogService.ShowMessageBox(
                "Alert",
                "Can not calculate because consumed fuel is empty.");
            return;
        }
        var fuelConsumed = model.AllottedMileage != 0 ? (model.AllottedDistance / model.AllottedMileage) : 0;
        var fuelDifference = model.ConsumedFuel - fuelConsumed;
        model.TotalAmount = Math.Round(Convert.ToDecimal(fuelDifference * model.FuelPrice), 2);
        validationMessageStore.Clear();
        editContext.NotifyValidationStateChanged();
    }
}