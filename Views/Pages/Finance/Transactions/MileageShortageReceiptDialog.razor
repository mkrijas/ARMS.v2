@inject IMileageShortageReceiptService Iservice
@using System.Threading;
@using ArmsModels.BaseModels.Finance.Transactions
@using Core.BaseModels.Finance.Transactions;
@inject ITripService tripService;
@inject IOutstandingBillsService OBIservice
@inject ICostCenterService costIservice
@inject TruckDataArrayModel data
@inject IChartOfAccountService accountService
@inject IDimensionService dimensionIservice
@inject NavigationManager uriHelper;
@inject MudBlazor.ISnackbar snackbar
@inject AuthenticationStateProvider auth
@inject IRoleService<RoleModel> Irole
@attribute [Authorize]
@inject IDialogService DialogService


<DialogForm @ref="@dialogForm" ReadOnly="@ReadOnly" Title="Mileage Shortage Receipt" formID="MileageShortageReceiptForm" model="@model">
    <FormContent>
        <MudPaper Class="p-3">
            <EditForm id="MileageShortageReceiptForm" OnValidSubmit="OnValidSubmit" EditContext="editContext">
                <ObjectGraphDataAnnotationsValidator />
                <ValidationSummary />
                <MudGrid>
                    <MudItem xs="12" md="4">
                        <MudTextField ReadOnly="ReadOnly" @bind-Value="TripNo" Label="Trip No" Variant="Variant.Outlined" Margin="Margin.Dense"></MudTextField>
                    </MudItem>
                    <MudItem xs="12" md="4">
                        <MudTextField @bind-Value="model.AllottedMileage" Label="Allotted Mileage" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.AllottedMileage)"></MudTextField>
                    </MudItem>
                    <MudItem xs="12" md="4">
                        <MudTextField ReadOnly="ReadOnly" @bind-Value="model.Reference" Label="Reference" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.Reference)"></MudTextField>
                    </MudItem>
                    <MudItem xs="12" md="4">
                        <MudTextField @bind-Value="model.AllottedDistance" Label="Allotted Mileage" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.AllottedMileage)"></MudTextField>
                    </MudItem>
                    <MudItem xs="12" md="4">
                        <MudTextField @bind-Value="model.FuelPrice" Label="Allotted Mileage" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.AllottedMileage)"></MudTextField>
                    </MudItem>
                    <MudItem xs="12" md="4">
                        <MudDatePicker ReadOnly="ReadOnly" Label="DocumentDate" Variant="Variant.Outlined" Margin="Margin.Dense" DisableToolbar="true" Editable="true" @bind-Date="model.DocumentDate" DateFormat="dd/MM/yyyy" />
                    </MudItem>
                    <MudItem xs="12" md="4">
                        <CostCenterSelector @bind-Value="model.CostCenter" ReadOnly="@ReadOnly" />
                    </MudItem>
                    <MudItem xs="12" md="4">
                        <DimensionSelector @bind-Value="model.Dimension" ReadOnly="@ReadOnly" />
                    </MudItem>
                    <MudItem xs="12" md="12">
                        <MudTextField ReadOnly="ReadOnly" @bind-Value="model.Narration" Lines="2" Label="Narration" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.Narration)"></MudTextField>
                    </MudItem>
                    <MudItem xs="12">
                    </MudItem>

                </MudGrid>
            </EditForm>
        </MudPaper>
    </FormContent>
    <VerificationStatus>
        <AutherizationStatusComponent DocTypeID="@DocTypeID" DocumentID="model.MileageShortageReceiptID" OnApprove="Approve"></AutherizationStatusComponent>
    </VerificationStatus>
</DialogForm>

@code {
    [Parameter]
    public MileageShortageReceiptModel model { get; set; }
    [Parameter]
    public bool ReadOnly { get; set; }

    private EditContext editContext;

    DialogForm dialogForm;
    public bool HasAuthoriseEdit { get; set; } = false;
    int DocTypeID = 12;

    [Parameter]
    public string TripNo { get; set; }

    private int? branchID = null;
    private string UserID = null;
    public GstUsageCodeModel gstusge = new();


    protected override async Task OnInitializedAsync()
    {

        CancellationTokenSource ctc = new CancellationTokenSource();
        HasAuthoriseEdit = await Irole.HasClaim(DocTypeID.ToString(), "Edit", ctc.Token);


        var authprov = await auth.GetAuthenticationStateAsync();
        var User = authprov.User;
        branchID = int.Parse(User.Claims.First(x => x.Type == "BranchID").Value);
        UserID = User.Identity.Name;

        if (model.MileageShortageReceiptID == null)
        {
            model.NatureOfTransaction = "Sundry Receipt";
            model.BranchID = branchID;
        }
        else
        {
        }
    }

    protected override void OnParametersSet()
    {
        editContext = new EditContext(model);
    }

    protected void Approve(DataApprovedStatus aprvd)
    {
        if (aprvd.IsApprove)
        {
            model.UserInfo.UserID = UserID;
            Iservice.Approve(model.MileageShortageReceiptID, model.UserInfo.UserID, aprvd.Remarks);
            snackbar.Add("Approved Successfully", Severity.Success);
        }
    }


    public async Task OnValidSubmit(EditContext context)
    {
        if (HasAuthoriseEdit)
        {
            model.UserInfo.UserID = UserID;
            try
            {
                Iservice.Update(model);
                model = new();
                snackbar.Add("Saved Successfully", Severity.Success);
            }
            catch (Exception ex)
            {
                snackbar.Add(ex.Message, Severity.Warning);
            }
            dialogForm.Close(model);

        }
        else
        {

            bool? result = await DialogService.ShowMessageBox(
        "Permission denied!",
        "You dont have any permission to submit.");

        }
    }
}
