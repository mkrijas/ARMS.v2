@page "/MileageShortageReceiptView"
@page "/MileageShortageReceiptView/{id:int}"
@using System.Threading;
@inherits ViewComponentBase<MileageShortageReceiptModel>
@inject IMileageShortageReceiptService Iservice



    <div class="fade-in">
        <div class="admin-header-tiered mb-6">
            <div class="d-flex align-center justify-space-between">
                <div>
                    <MudText Typo="Typo.h4" Class="admin-title">Mileage Shortage Receipt</MudText>
                    <MudText Typo="Typo.body2" Class="admin-subtitle">Process and audit receipts related to mileage shortages. Link entries to specific drivers and transactions with built-in verification.</MudText>
                </div>
                @* <MudButton StartIcon="@Icons.Material.Filled.Add" Variant="Variant.Filled" Color="Color.Primary" Class="admin-register-btn" OnClick="@(()=> OpenForm(new MileageShortageReceiptModel(),false))" Disabled="@_busy">NEW RECEIPT ENTRY</MudButton> *@
            </div>
        </div>

        <div class="admin-glass-card mb-6 pa-4">
            <div class="d-flex align-center gap-4 flex-wrap">
                <div style="flex-grow: 1; min-width: 300px;">
                    <MudTextField @bind-Value="searchTerm" Placeholder="Search by document number or receipt mode..." Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" Variant="Variant.Outlined" Margin="Margin.Dense" Class="admin-input-group" Clearable="true" OnKeyUp="HandleSearchKeyUp" />
                </div>
            <div class="d-flex align-center gap-4">
                <div class="d-flex align-center gap-2 bg-glass rounded-pill px-4 py-1">
                    <MudCheckBox T="bool" Label="Approved Log" ValueChanged="((bool value) => ToggleData(value))" Value="@ShowApproved" Size="Size.Small" Color="Color.Primary" Class="fw-600" />
                </div>
            </div>
            </div>
        </div>

        <div class="admin-glass-card pa-0 overflow-hidden">
        <MudTable ServerData="LoadServerData" T="MileageShortageReceiptModel" @ref="_table" Elevation="0" Class="modern-admin-table" Hover="true">
            <LoadingContent>
                <div @key="@("loader")" style="display: flex; justify-content: center; align-items: center; min-height: 400px;">
                    <LoaderComponent IsFullScreen="false"
                                     ShowLogo="false"
                                     Size="large"
                                     LoadingText="Loading...."
                                     SubText="Fetching Data..." />
                </div>
            </LoadingContent>
            <HeaderContent>
                    <MudTh><MudTableSortLabel SortBy="new Func<MileageShortageReceiptModel, object>(x=> x.DocumentDate)"><span class="admin-header-text">DATE</span></MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<MileageShortageReceiptModel, object>(x=> x.DocumentNumber)" InitialDirection="SortDirection.Descending"><span class="admin-header-text">DOC NUMBER</span></MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<MileageShortageReceiptModel, object>(x=> x.ReceiptMode)"><span class="admin-header-text">RECEIPT MODE</span></MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<MileageShortageReceiptModel, object>(x=> x.TotalAmount)"><span class="admin-header-text">AMOUNT</span></MudTableSortLabel></MudTh>
                    <MudTh Style="text-align: right;"><span class="admin-header-text">ACTIONS</span></MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Date"><span class="fw-500">@context.DocumentDate?.ToString("dd MMM yyyy")</span></MudTd>
                    <MudTd DataLabel="DocNumber">
                        <div class="d-flex flex-column">
                            <span class="admin-td-primary fw-700">@context.DocumentNumber</span>
                            @if (context.AuthLevelId == 100)
                            {
                                <MudText Typo="Typo.caption" Color="Color.Error" Class="fw-700">REJECTED</MudText>
                            }
                        </div>
                    </MudTd>
                    <MudTd DataLabel="Mode"><span class="fw-600">@context.ReceiptMode</span></MudTd>
                    <MudTd DataLabel="Amount">
                        <MudChip T="string" Size="Size.Small" Color="Color.Success" Variant="Variant.Text" Class="fw-700">@context.TotalAmount?.ToString("N2")</MudChip>
                    </MudTd>
                    <MudTd DataLabel="Actions" Style="text-align: right;">
                        <div class="d-flex justify-end gap-1">
                            @if (@context.AuthLevelId == 99)
                            {
                                @if (@context.MID != null)
                                {
                                    <EntryReversedComponent DocTypeID="@DocInfo.DocumentTypeID" DocumentID="context.MileageShortageReceiptID" MID="context.MID" DocumentNumber="@context.DocumentNumber"></EntryReversedComponent>
                                }
                                else
                                {
                                    <MudTooltip Text="Reverse Transaction (Manual)">
                                        <MudIconButton OnClick="@(()=> Delete(context.MileageShortageReceiptID))" Color="Color.Error" Icon="@Icons.Material.Filled.ArrowBack" Size="Size.Small" Variant="Variant.Text" />
                                    </MudTooltip>
                                }
                                <MudTooltip Text="Print Proof">
                                    <MudIconButton OnClick="@(()=> Print(context.MileageShortageReceiptID))" Color="Color.Tertiary" Icon="@Icons.Material.Filled.Print" Size="Size.Small" Variant="Variant.Text" />
                                </MudTooltip>
                            }
                            else if (@context.AuthLevelId != 100)
                            {
                                <MudTooltip Text="Verify Receipt">
                                    <MudIconButton OnClick="@(()=> OpenForm(context,true))" Color="Color.Warning" Icon="@Icons.Material.Filled.Verified" Size="Size.Small" Variant="Variant.Text" />
                                </MudTooltip>
                            }

                            <MudTooltip Text="View Details">
                            <MudIconButton OnClick="@(() => OpenForm(context, true))" Color="Color.Info" Icon="@Icons.Material.Filled.Visibility" Size="Size.Small" Variant="Variant.Text" />
                            </MudTooltip>
                            
                            <MudTooltip Text="Edit Receipt">
                            <MudIconButton Disabled="@(context.AuthLevelId != null)" OnClick="@(() => OpenForm(context, false))" Color="Color.Primary" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Variant="Variant.Text" />
                            </MudTooltip>

                            <MudTooltip Text="Remove Receipt">
                                <MudIconButton Disabled="@(context.AuthLevelId != null)" OnClick="@(()=> Delete(context.MileageShortageReceiptID))" Color="Color.Error" Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Variant="Variant.Text" />
                            </MudTooltip>
                        </div>
                    </MudTd>
                </RowTemplate>
                <PagerContent>
                    <div class="pa-4">
                        <MudTablePager PageSizeOptions="new int[] { 10, 20, 50, 100 }" />
                    </div>
                </PagerContent>
            </MudTable>
        </div>
    </div>


@code {

    protected override List<MileageShortageReceiptModel> _collection { get; set; } = [];

    protected override DocumentInfoModel DocInfo { get; set; } = new DocumentInfoModel()
    {
        DocumentTypeID = 30,
        DocumentName = "Mileage Shortage Receipt"
    };

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();
        if (id != null && _collection != null && _collection.Any(g => g.MileageShortageReceiptID == id))
        {
            await OpenForm(_collection.FirstOrDefault(s => s.MileageShortageReceiptID == id), true);
        }
    }  

    protected override async Task OpenForm(MileageShortageReceiptModel _model, bool ReadOnly, bool DisableAddition = false)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        _busy = true;

        var MileageShortageReceiptDocTypeID = 0;
        if (_model.AllowanceAmount != null && _model.AllowanceAmount != 0)
        {
            MileageShortageReceiptDocTypeID = 129;
        }
        else
        {
            MileageShortageReceiptDocTypeID = 30;
        }

        DialogOptions largeWidth = new DialogOptions() { MaxWidth = MaxWidth.Large, FullWidth = true };
        DialogParameters parms = new DialogParameters();
        parms.Add("model", _model.Clone());
        parms.Add("PageToRedirectLink", "/MileageShortageReceiptView");
        parms.Add("ReadOnly", ReadOnly);
        parms.Add("MileageShortageReceiptDocTypeID", MileageShortageReceiptDocTypeID);
        var dialog = await dialogService.ShowAsync<MileageShortageReceiptDialog>(_model.MileageShortageReceiptID == null ? "ADD" : "EDIT", parms, largeWidth);
        var result = await dialog.Result;
        var isCancelled = result.Canceled;
        if (!isCancelled)
        {
            var ReturnData = (MileageShortageReceiptModel)result.Data;
            await _table.ReloadServerData();
        }
        
        await Task.Delay(200);
        _busy = false;
    }

    public Dictionary<string, string> ReportParameters { get; set; } = new();     
  
    // Method to print the mileage shortage receipt
    private async Task Print(int? MileageShortageReceiptID)
    {
        ReportParameters.Clear();
        ReportParameters.Add("MileageShortageReceiptID", MileageShortageReceiptID.ToString());
        ReportParameters.Add("BranchName", "");
        var parameters = new DialogParameters();
        parameters.Add("Parameters", ReportParameters); // Add the dictionary as a parameter
        parameters.Add("ReportName", "PrintMileageShortageReceipt");

        DialogOptions maxWidth = new DialogOptions() { MaxWidth = MaxWidth.Medium, FullWidth = true };
        var result = await dialogService.ShowAsync<PrintDialog>("PRINT", parameters, maxWidth);
    }
}
