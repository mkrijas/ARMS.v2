@inherits DialogFormComponentBase<OpTranModel>
@using ArmsModels.BaseModels.General
@using Core.BaseModels.Operations;
@using Core.IDataServices.Operations;
@using Microsoft.AspNetCore.SignalR.Client;
@using System.Threading;
@using Views.Data
@using Core.BaseModels.Finance.Transactions;
@using Pages.Operations.Expenses
@using System.Transactions;
@inject IOpTranService Iservice
@inject ITripService tripIservice
@inject ITripFuelService tripFuelIservice
@inject IConfigTable configTable
@inject IChartOfAccountService accountService
@inject IGstUsageIDService usage
@inject IDialogService DialogService
@inject ITruckService truckService
@inject ITruckAvailabilityService availabilityService
@inject ITripAdvanceService advanceService
@inject IOperationPostingGroupService IOpsArd

<DialogForm @ref="@dialogForm" ReadOnly="@ReadOnly" Title="Trip Settlement" Subtitle="Optimize trip settlements with automated expense tracking, reimbursements, and advance reconciliation." Icon="@Icons.Material.Filled.LocalShipping" AdminStyle="true" formID="Optranform" DocumentDetails="DocInfo" model="@_model" _busy="_busy">
    <FormContent>
        <div class="dialog-content-wrapper">
            <EditForm id="Optranform" EditContext="editContext" OnValidSubmit="@OnValidSubmit">
                <ObjectGraphDataAnnotationsValidator />
                
                <div class="admin-glass-card pa-6 mb-6">
                    <span class="admin-section-label">Transaction Context</span>
                    <MudGrid Spacing="3">
                        <MudItem xs="12" md="4">
                            <MudDatePicker ReadOnly="@ReadOnly" Label="Document Date" Variant="Variant.Outlined" Margin="Margin.Dense" DisableToolbar="true" Editable="true" @bind-Date="model.DocumentDate" DateFormat="dd/MM/yyyy" MaxDate="DateTime.Now" Class="admin-input-group" />
                        </MudItem>
                        <MudItem xs="12" md="4">
                            <MudSelect For="@(() => model.PaymentMode)" Label="Payment Mode" Value="model.PaymentMode" T="string" Variant="Variant.Outlined" Margin="Margin.Dense" ValueChanged="OnPaymentModeChanged" Class="admin-input-group">
                                @foreach (var mode in PaymentModes)
                                {
                                    <MudSelectItem Value="@mode">@mode</MudSelectItem>
                                }
                            </MudSelect>
                        </MudItem>
                        <MudItem xs="12" md="4">
                            <MudAutocomplete T="PaymentCodeModel"
                                             Value="SelectedArd"
                                             ValueChanged="OnAccountChanged"
                                             SearchFunc="@(async (string s, CancellationToken t) => await SearchAccounts(s, t))"
                                             ToStringFunc="@(e => e == null ? string.Empty : string.Format("{0} | {1}", string.IsNullOrWhiteSpace(e.ArdCode) ? "--" : e.ArdCode, string.IsNullOrWhiteSpace(e.Title) ? "--" : e.Title))"
                                             Label="Payment Source A/c"
                                             Variant="Variant.Outlined"
                                             Margin="Margin.Dense"
                                             Dense="true"
                                             ResetValueOnEmptyText="true"
                                             CoerceText="true"
                                             Class="admin-input-group" />
                        </MudItem>
                        <MudItem xs="12">
                            <MudTextField ReadOnly="@ReadOnly" @bind-Value="model.Narration" Lines="2" Label="Execution Narration" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.Narration)" Class="admin-input-group"></MudTextField>
                        </MudItem>
                    </MudGrid>
                </div>

                <div class="admin-glass-card pa-0 overflow-hidden mb-6">
                    <div class="px-6 py-4 border-bottom-subtle" style="background: rgba(255, 159, 67, 0.02);">
                        <span class="admin-section-label mb-0">Expense Particulars</span>
                    </div>
                    
                    <div class="modern-admin-table">
                         <MudGrid Class="admin-table-header px-6 py-3">
                             <MudItem xs="3"><span class="admin-header-text">PARTICULARS / REF</span></MudItem>
                             <MudItem xs="2"><span class="admin-header-text">COST CENTER / DIM.</span></MudItem>
                             <MudItem xs="2"><span class="admin-header-text">QTY / UNIT</span></MudItem>
                             <MudItem xs="2"><span class="admin-header-text">REIMBURSE</span></MudItem>
                             <MudItem xs="2" Class="text-right"><span class="admin-header-text">AMOUNT</span></MudItem>
                             <MudItem xs="1"></MudItem>
                         </MudGrid>

                         @foreach (var item in model.Transactions)
                         {
                            <MudGrid Class="px-6 py-3 border-bottom-subtle align-center">
                                <MudItem xs="3">
                                    <MudText Typo="Typo.body2" Style="font-weight: 700;">@item.ExpenseTitle</MudText>
                                    <MudText Typo="Typo.caption" Style="color: #667085;">@item.Reference</MudText>
                                </MudItem>
                                <MudItem xs="2">
                                    <MudText Typo="Typo.body2">@item.CostCenterVal</MudText>
                                    <MudText Typo="Typo.caption">@item.DimensionVal</MudText>
                                </MudItem>
                                <MudItem xs="2">
                                    <MudText Typo="Typo.body2">@item.Quantity @item.Unit</MudText>
                                </MudItem>
                                <MudItem xs="2">
                                    <MudChip T="string" Size="Size.Small" Color="@(item.Reimbursement == "True" || item.Reimbursement == "1" ? Color.Success : Color.Default)" Variant="Variant.Text">
                                        @(item.Reimbursement == "True" || item.Reimbursement == "1" ? "Yes" : "No")
                                    </MudChip>
                                </MudItem>
                                <MudItem xs="2" Class="text-right">
                                    <MudText Typo="Typo.body1" Style="font-weight: 800; color: #FF9F43;">₹ @item.Amount</MudText>
                                </MudItem>
                                <MudItem xs="1" Class="d-flex justify-end">
                                    @if (!ReadOnly)
                                    {
                                        <MudIconButton Title="Delete" Color="Color.Error" @onclick="@(()=> DeleteExpenses(@item))" Icon="@Icons.Material.Filled.DeleteOutline" Size="Size.Small" />
                                    }
                                </MudItem>
                            </MudGrid>
                         }

                         @if (!ReadOnly)
                         {
                             <div class="pa-6" style="background: rgba(255, 159, 67, 0.03); border-top: 1px dashed rgba(255,159,67,0.3);">
                                 <MudGrid Spacing="2" AlignItems="AlignItems.End">
                                     <!-- Row 1 -->
                                     <MudItem xs="12" md="4">
                                         <MudAutocomplete SelectValueOnTab T="OperationPostingGroupModel" Label="Expense Particulars"
                                                                  Class="admin-input-group"
                                                           Value="opTranSubModel.OperationPostingGroupModel" ValueChanged="AddOperationPostingGroup"
                                                           ResetValueOnEmptyText="true" @ref="@OperationTitleControl"
                                                           SearchFunc="@(async (string s, CancellationToken t) => await SearchOperationPostingGroup(s, t))" Variant="Variant.Outlined" Margin="Margin.Dense"
                                                           ToStringFunc="@(e => (e == null || string.IsNullOrEmpty(e.Title)) ? null : string.Format("{0} ",e.Title))"></MudAutocomplete>
                                     </MudItem>
                                     <MudItem xs="12" md="2">
                                         <CostCenterSelector For="@(() => opTranSubModel.CostCenter)" @bind-Value="opTranSubModel.CostCenter" @bind-ValueText="@opTranSubModel.CostCenterVal" ReadOnly="@ReadOnly" Class="admin-input-group" />
                                     </MudItem>
                                     <MudItem xs="12" md="2">
                                         <MudNumericField HideSpinButtons @bind-Value="opTranSubModel.Quantity" Label="Qty" Variant="Variant.Outlined" Margin="Margin.Dense" Class="admin-input-group"></MudNumericField>
                                     </MudItem>
                                     <MudItem xs="12" md="3">
                                         <MudNumericField HideSpinButtons @bind-Value="opTranSubModel.Amount" Label="Amount" Variant="Variant.Outlined" Margin="Margin.Dense" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.CurrencyRupee" AdornmentColor="Color.Primary" Class="admin-input-group"></MudNumericField>
                                     </MudItem>
                                     <MudItem xs="12" md="1">
                                     </MudItem>

                                     <!-- Row 2 -->
                                     <MudItem xs="12" md="4">
                                         <MudTextField @bind-Value="opTranSubModel.Reference" Label="Bill/Ref Number" Variant="Variant.Outlined" Margin="Margin.Dense" Class="admin-input-group"></MudTextField>
                                     </MudItem>
                                     <MudItem xs="12" md="2">
                                         <DimensionSelector For="@(() => opTranSubModel.Dimension)" @bind-Value="opTranSubModel.Dimension" @bind-ValueText="@opTranSubModel.DimensionVal" ReadOnly="@ReadOnly" Class="admin-input-group" />
                                     </MudItem>
                                     <MudItem xs="12" md="2">
                                         <MudTextField @bind-Value="opTranSubModel.Unit" Label="Unit" Variant="Variant.Outlined" Margin="Margin.Dense" Class="admin-input-group"></MudTextField>
                                     </MudItem>
                                     <MudItem xs="12" md="3">
                                        <div class="d-flex align-center px-3" style="background: white; border: 1px solid #c4c4c4; border-radius: 4px; height: 40px; margin-top: 30px; padding-top: 10px;">
                                             <MudCheckBox T="bool" Label="Reimbursement" ValueChanged="((bool value)=>ToggleData(value))" Value="@opTranSubModel.IsReimbursed" Color="Color.Primary" Dense="true" Style="margin-top: -2px;" />
                                         </div>
                                     </MudItem>
                                     <MudItem xs="12" md="1" Class="d-flex justify-start">
                                        <MudIconButton OnClick="AddItems" Color="Color.Primary" Variant="Variant.Filled" Style="background: #FF9F43; border-radius: 8px; height: 40px; width: 60px; margin-bottom: 22px; left:5px;" Icon="@Icons.Material.Filled.Add" Size="Size.Medium" Title="ADD" />
                                     </MudItem>
                                 </MudGrid>
                             </div>
                         }
                    </div>
                </div>

                <div class="admin-glass-card pa-4" style="background: rgba(255, 159, 67, 0.05); border: 1px solid rgba(255,159,67,0.2);">
                    <MudGrid Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                        <MudItem xs="12" md="4">
                            <div class="d-flex align-center">
                                <div class="pa-2 rounded-lg mr-3" style="background: rgba(244, 67, 54, 0.1);">
                                    <MudIcon Icon="@Icons.Material.Filled.AccountBalanceWallet" Color="Color.Error" />
                                </div>
                                <div>
                                    <MudText Typo="Typo.caption" Style="color: #667085;">Trip Advance Received</MudText>
                                    <MudText Typo="Typo.h6" Style="font-weight: 800; color: #F44336;">₹ @Advance.Amount</MudText>
                                </div>
                            </div>
                        </MudItem>
                        <MudItem xs="12" md="8">
                            <div class="d-flex flex-column align-end">
                                <MudText Typo="Typo.caption" Style="color: #667085;">Reconciliation Status</MudText>
                                <MudText Typo="Typo.h6" Style="font-weight: 800; color: #FF9F43;">
                                    @if (AdvanceBalance > 0)
                                    {
                                        <span style="font-size: 0.9rem; color: #2E7D32;">✓ Deducting from advance. Pending: ₹ @displayBalance</span>
                                    }
                                    else
                                    {
                                        <span>Total Payable Amount: ₹ @displayBalance</span>
                                    }
                                </MudText>
                            </div>
                        </MudItem>
                    </MudGrid>
                </div>
            </EditForm>
        </div>
    </FormContent>
    <VerificationStatus>
        <AutherizationStatusComponent CreatedBy="@model.UserInfo" DocTypeID="@DocInfo.DocumentTypeID" DocDate="@DocDate" DocNumber="@DocNumber" DocumentID="@model.OpTranID" OnApprove="Approve"></AutherizationStatusComponent>
    </VerificationStatus>
</DialogForm>

@code {

    [Parameter]
    public override OpTranModel model { get; set; }
    private OpTranModel _model { get { return model; } set { model = value; DocInfo.DocumentID = value.OpTranID; } }

    MudAutocomplete<OperationPostingGroupModel> OperationTitleControl;

    private ElementReference ScrollableDiv;

    public GstUsageCodeModel gstusge = new();
    private OpTranSubModel opTranSubModel = new();
    private List
    <OperationPostingGroupModel> OperationPostingList = new();
    private TripAdvanceModel Advance = new();
    private decimal? AdvanceBalance;
    private decimal? AdvanceReturnAmount;
    private string displayBalance;
    private GstUsageCodeModel FastTagUsageCodeModel { get; set; }
    private GstUsageCodeModel LoadingAndUnlodingUsageCodeModel { get; set; }
    string UserIDTemp;
    private List<string> PaymentModes = new()
    { "Cash", "Bank", "Others"};
    private List<PaymentCodeModel> AllAccounts = new();
    private PaymentCodeModel SelectedArd;

    protected override DocumentInfoModel DocInfo { get; set; } = new DocumentInfoModel()
        {
            DocumentTypeID = 6,
            DocumentName = "OpTran"
        };

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();
        if (model.OpTranID is null)
        {
            model.UserInfo.UserID = UserID;
            model.NatureOfTransaction = "Trip Expenses";
            var tripInfo = tripIservice.GetTripInfo(model.TripID); // Get trip information
            if (tripInfo is not null)
            {
                model.Narration = string.Format("Trip : {0}; Truck : {1}; Driver : {2};", tripInfo.TripNumber, tripInfo.Truck, tripInfo.Driver);
            }
            var TransferInfo = availabilityService.GetTransferInfo(model.RequestApprovalHistoryID);
            if (TransferInfo is not null)
            {
                model.Narration = string.Format("Transfer  : {0}; Truck : {1};", TransferInfo.DocNumber, TransferInfo.Truck.RegNo);
            }
        }
        else
        {
            UserIDTemp = model.UserInfo.UserID;
            model.Transactions = Iservice.GetExpenses(model.OpTranID).ToList(); // Get expenses for the operation transaction
        }       

        // if (model.PaymentMode == null)
        // {
        //     model.PaymentMode = "Cash";
        // }
        model.NatureOfTransaction = model.Area;
        model.BranchID = BranchID;
        OperationPostingList = IOpsArd.Select().ToList(); // Load operation posting groups

        // Get total advance for the trip
        Advance = advanceService.GetTotal(model.TripID);
        AdvanceBalance = Advance.Amount; 
        displayBalance = AdvanceBalance.ToString();

        if (!string.IsNullOrEmpty(model.PaymentMode))
        {
            await GetCodesAndSetDefault(BranchID, model.PaymentMode);
        }
    }

    private async Task<IEnumerable<PaymentCodeModel>> SearchAccounts(string searchString, CancellationToken token)
    {
        await Task.Delay(5);
        string search = searchString ?? string.Empty;

        return AllAccounts.Where(x =>
            (x.ArdCode ?? string.Empty).Contains(search, StringComparison.InvariantCultureIgnoreCase)
            || (x.Title ?? string.Empty).Contains(search, StringComparison.InvariantCultureIgnoreCase)
        );
    }


    private async Task OnPaymentModeChanged(string value)
    {
        model.PaymentMode = value;
        SelectedArd = null;
        model.PaymentArdCode = null;
        model.CreditCoaID = null;

        await GetCodesAndSetDefault(BranchID, value);
    }

    private async Task OnAccountChanged(PaymentCodeModel selected)
    {
        SelectedArd = selected;
        model.PaymentArdCode = selected?.ArdCode;
        model.CreditCoaID = selected?.CoaID;
    }

    private async Task GetCodesAndSetDefault(int? branchId, string mode)
    {
        AllAccounts = accountService.GetPaymentCodes(branchId, mode).ToList();

        if (!AllAccounts.Any())
            return;

        if (AllAccounts.Count == 1)
        {
            await OnAccountChanged(AllAccounts.First());
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        // if (OperationTitleControl is not null && firstRender)
        //    await OperationTitleControl.FocusAsync();
    }

    // Method to toggle reimbursement status
    protected void ToggleData(bool value)
    {
        opTranSubModel.IsReimbursed = value;
    }

    // Method to add an operation posting group to the transaction
    void AddOperationPostingGroup(OperationPostingGroupModel uc)
    {
        opTranSubModel.OperationPostingGroupModel = uc;

    }

    // Method to search for operation posting groups based on a search string
    private async Task<IEnumerable<OperationPostingGroupModel>> SearchOperationPostingGroup(string searchString, CancellationToken token)
    {
        return await Task.FromResult(OperationPostingList.Where(x => x.ADCode.Contains(searchString ?? string.Empty, StringComparison.InvariantCultureIgnoreCase) ||
                                                                x.Title.Contains(searchString ?? string.Empty, StringComparison.InvariantCultureIgnoreCase)));
    }

    // Method to update approval status of the operation transaction
    protected override int UpdateApproval(DataApprovedStatus aprvd)
    {
        int result = Iservice.Approve(model.OpTranID, model.UserInfo.UserID, aprvd.Remarks); // Call service to approve
        model.UserInfo.UserID = UserIDTemp;
        return result;
    }

    // Method to add items to the operation transaction
    public async Task AddItems()
    {
        if(opTranSubModel.IsReimbursed)
        {
            // Get the fast tag usage code from the configuration
            ConfigModel cFModel = configTable.GetFastTagUsageCode();
            FastTagUsageCodeModel = usage.SelectByCode(cFModel.ValueString);

            // Get the unloading charge usage code from the configuration
            ConfigModel cLModel = configTable.GetUnloadingChargeUsageCode();
            LoadingAndUnlodingUsageCodeModel = usage.SelectByCode(cLModel.ValueString);

            if((opTranSubModel.OperationPostingGroupModel.UsageCode.UsageCode != FastTagUsageCodeModel.UsageCode) && (opTranSubModel.OperationPostingGroupModel.UsageCode.UsageCode != LoadingAndUnlodingUsageCodeModel.UsageCode))
            {
                snackbar.Add("Please Check Particulars", Severity.Error);
                return;
            }
        }

        if (opTranSubModel.OperationPostingGroupModel is not null && (opTranSubModel.Amount ?? 0) != 0)
        {
            //opTranSubModel.ExpenseUsageCode = gstusge.UsageCode;
            if(opTranSubModel.Amount <= 0)
            {
                snackbar.Add("Amount Cannot be Negative or Zero!",Severity.Error);
                return;
            }

            opTranSubModel.ExpenseUsageCode = opTranSubModel.OperationPostingGroupModel.ADCode;
            opTranSubModel.ExpenseTitle = opTranSubModel.OperationPostingGroupModel.Title;
            opTranSubModel.CoaID = opTranSubModel.OperationPostingGroupModel.UsageCode.CoaID;

            model.Transactions.Add(opTranSubModel);
            model.TotalAmount = model.TotalAmount + (opTranSubModel.Amount * opTranSubModel.Quantity);
            opTranSubModel = new() { OperationPostingGroupModel = null };
            //gstusge = new();            
            await OperationTitleControl.ResetAsync();
            await OperationTitleControl.FocusAsync();
            //await JsRuntime.InvokeVoidAsync("resetHorizontalScrollbarForElement", ScrollableDiv);
        }
        SetTotal();
    }

    // Method to delete expenses from the transaction
    public void DeleteExpenses(OpTranSubModel i)
    {
        int rowIndex = model.Transactions.IndexOf(i);
        model.TotalAmount = model.TotalAmount - (i.Amount * i.Quantity);
        model.Transactions.RemoveAt(rowIndex);
        SetTotal();
    }

    // Method to set total amounts and update display balance
    private void SetTotal()
    {
        model.TotalAmount = model.Transactions.Sum(x => x.Amount);
        AdvanceBalance = Advance.Amount - model.TotalAmount;
        displayBalance = Math.Abs(AdvanceBalance ?? 0).ToString(); 
    }

    // Method to update the operation transaction
    protected override async Task<int> Update(OpTranModel editModel)
    {
        if (model.OpTranID is null || model.OpTranID == 0)
        {
            bool? yesno = false;
            if (AdvanceBalance > 0)
            {
                {
                    yesno = await DialogService.ShowMessageBoxAsync(
                    "Advance",
                    "Do you want to Use This Advance",
                    yesText: "Yes!", noText: "No");
                }
                if (yesno == null)
                {
                    return 0;
                }
                if (yesno == true)
                {
                    AdvanceReturnAmount = model.TotalAmount;
                }
            }
            else
            {
                AdvanceReturnAmount = Advance.Amount;
            }

            if (AdvanceReturnAmount > 0)
            {
                //var AdvanceUsageCode = configTable.GetTripAdvanceUsageCode();
                model.Transactions.Add(new OpTranSubModel()
                    {
                        Amount = -1 * AdvanceReturnAmount,
                        CoaID = Advance.CoaID,
                        ExpenseUsageCode = Advance.UsageCode,
                        Reference = "Advance Reimbursed",
                    });
                model.TotalAmount = model.TotalAmount - AdvanceReturnAmount;
            }
        }

        var updatedModel =  new OpTranModel();


        var scopeOptions = new TransactionOptions
            {
                IsolationLevel = IsolationLevel.ReadCommitted,
                Timeout = TransactionManager.DefaultTimeout
            };

        using (var tran = new TransactionScope(TransactionScopeOption.Required, scopeOptions, TransactionScopeAsyncFlowOption.Enabled))
        {
            try
            {
                // Call the service to update the operation transaction
                updatedModel = Iservice.Update(model);
                model.OpTranID = updatedModel.OpTranID;
                if (updatedModel.OpTranID != null && AdvanceReturnAmount > 0 && model.TripID is not null)
                {
           
                    var driverId = truckService.GetAssignedDriver(updatedModel.TruckID);

                    TripAdvanceModel advanceModel = new()
                        {
                            BranchID = BranchID,
                            TripID = Advance.TripID,
                            DriverID = Advance.DriverID,
                            Amount = - (AdvanceReturnAmount),
                            CoaID = Advance.CoaID,
                            UsageCode = Advance.UsageCode,
                            DocumentTypeID = DocInfo.DocumentTypeID,
                            DocumentID = updatedModel.OpTranID,
                            DocType = Advance.DocType,
                            RecordStatus = 3
                        };

                    // Update the advance record in the service            
                    var queryStatus = advanceService.Update(advanceModel);
                    if (queryStatus == null)
                    {
                        snackbar.Add("Something went wrong !  Please check Trip expense collect number then contact Admin", Severity.Error);
                    }
                    else
                    {
                        snackbar.Add("Created Successfully", Severity.Success);
                    }
                }
                tran.Complete();
            }
            catch (Exception e)
            {
                snackbar.Add(e.Message, Severity.Error);
            }
        }
        return updatedModel.OpTranID.Value; 
    }
}

