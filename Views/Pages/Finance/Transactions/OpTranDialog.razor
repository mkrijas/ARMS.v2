@inject IOpTranService Iservice
@inject ITripService tripIservice
@inject ITripFuelService tripFuelIservice
@inject ICostCenterService costIservice
@inject IGstUsageIDService usageIservice
@inject IDimensionService dimensionIservice
@inject MudBlazor.ISnackbar snackbar
@inject ITdsRateService tdsIService
@inject IChartOfAccountService accountService
@inject IConfiguration configuration
@using Microsoft.Extensions.Configuration
@inject IBranchService brIservice
@inject AuthenticationStateProvider auth
@attribute [Authorize]
@inject IDialogService DialogService
@inject IInventoryItemService itemIservice

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.Build" Class="mr-3 mb-n1" />
            Create Transaction
        </MudText>
        @if (IsView)
        {
            <MudText Color="Color.Error">@model.AuthStatus</MudText>
        }
    </TitleContent>
    <DialogContent>

        <MudContainer Style="max-height: 450px; overflow-y: scroll">
            <EditForm id="truckForm" Model="@model" OnValidSubmit="Submit">
                <DataAnnotationsValidator />
                <ValidationSummary />
                <MudGrid>
                    <MudItem xs="12" md="12">
                        <h6>Transaction</h6>
                    </MudItem>


                    <MudItem xs="12" md="6">

                        <MudDatePicker Label="DocumentDate" Variant="Variant.Outlined" Margin="Margin.Dense" DisableToolbar="true" Editable="true" @bind-Date="model.DocumentDate" DateFormat="dd/MM/yyyy" />


                    </MudItem>
                    <MudItem xs="12" md="6">

                        <MudSelect Label="Select CostCenter" @bind-Value="model.CostCenter" T="int?" Variant="Variant.Outlined" Margin="Margin.Dense" OffsetY="true" Direction="Direction.Top" AdornmentColor="Color.Secondary">
                            @foreach (var ditem in costCenter)
                            {
                                <MudSelectItem Value="@ditem.CostCenterID">@ditem.CostCenter</MudSelectItem>
                            }
                        </MudSelect>

                    </MudItem>
                    <MudItem xs="12" md="6">

                        <MudSelect Label="Select Dimension" @bind-Value="model.Dimension" T="int?" Variant="Variant.Outlined" Margin="Margin.Dense" OffsetY="true" Direction="Direction.Top" AdornmentColor="Color.Secondary">
                            @foreach (var ditem in dimension)
                            {
                                <MudSelectItem Value="@ditem.DimensionID">@ditem.Dimension</MudSelectItem>
                            }
                        </MudSelect>

                    </MudItem><MudItem xs="12" md="6">
                        <PaymentCodeSelector @bind-Value="accountRuleDefinition" PaymentMode="Cash" LabelName="Cash a/c"></PaymentCodeSelector>

                    </MudItem>

                    <MudItem xs="12" md="12">

                        <MudSimpleTable Hover="true" Dense="true" FixedHeader="true">
                            <thead>
                                <tr>
                                    <th>UsageCode</th>
                                    <th>Reference</th>
                                    <th>Amount</th>
                                    <th>Quantity</th>
                                    <th>Unit</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in model.Transactions)
                                {
                                    <tr>
                                        <td>@item.ExpenseUsageCode</td>
                                        <td>@item.Reference</td>
                                        <td>@item.Amount</td>
                                        <td>@item.Quantity</td>
                                        <td>@item.Unit</td>
                                        <td>
                                            <MudFab Color="Color.Error" @onclick="@(()=> DeleteExpenses(@item))" Icon="@Icons.Material.Filled.Delete" Size="Size.Small" IconSize="Size.Small" />
                                        </td>
                                    </tr>
                                }
                                @if (!IsReadOnly)
                                {
                                    <tr>
                                        <td>
                                            <UsageCodeSelector @bind-Value="@gstusge"></UsageCodeSelector>
                                        </td>
                                        <td>
                                            <MudTextField @bind-Value="opTranSubModel.Reference" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => opTranSubModel.Reference)"></MudTextField>

                                        </td>
                                        <td>
                                            <MudTextField @bind-Value="opTranSubModel.Amount" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => opTranSubModel.Amount)"></MudTextField>

                                        </td>
                                        <td>
                                            <MudTextField @bind-Value="opTranSubModel.Quantity" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => opTranSubModel.Quantity)"></MudTextField>
                                        </td>
                                        <td>
                                            <MudTextField @bind-Value="opTranSubModel.Unit" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => opTranSubModel.Unit)"></MudTextField>

                                        </td>
                                        <td>
                                            <MudFab OnClick="AddItems" Color="Color.Primary" Icon="@Icons.Material.Filled.Add" Size="Size.Small" IconSize="Size.Small" />

                                        </td>
                                    </tr>
                                }
                                <tr>
                                    <td colspan="2">Total</td>
                                    <td>@model.TotalAmount</td>
                                    <td colspan="2"></td>
                                </tr>
                            </tbody>
                        </MudSimpleTable>


                    </MudItem>
                    <MudItem xs="12">
                        @if ((IsReadOnly) && (!IsView))
                        {
                            <AutherizationStatusComponent DocTypeID="6" DocumentID="model.OpTranID" OnApprove="IsApproveData"></AutherizationStatusComponent>

                        }

                    </MudItem>

                </MudGrid>
            </EditForm>
        </MudContainer>

    </DialogContent>
    <DialogActions>
        <MudText>Total:@model.TotalAmount</MudText>
        @if (!IsReadOnly)
        {
            <MudButton Variant="Variant.Filled" Color="Color.Info" OnClick="Cancel">Cancel</MudButton>

            <MudButton form="formtdsRate" Variant="Variant.Filled" Color="Color.Success" OnClick="Submit">Submit</MudButton>
        }
        @if (IsReadOnly)
        {
            <MudButton Variant="Variant.Filled" Color="Color.Info" OnClick="Cancel">Close</MudButton>

        }
    </DialogActions>
</MudDialog>

@code {
    [Parameter]
    public OpTranModel model { get; set; }
    [Parameter]
    public string PaymentMode { get; set; }
    [Parameter]
    public string Area { get; set; }
    [Parameter]
    public bool IsReadOnly { get; set; } = false;
    [Parameter]
    public bool IsView { get; set; } = false;

    private AccountRuleDefinitionModel accountRuleDefinition = new();

    public GstUsageCodeModel gstusge = new();


    private OpTranSubModel opTranSubModel = new();

    private List<CostCenterModel> costCenter = new();
    private List<DimensionModel> dimension = new();



    [CascadingParameter] MudDialogInstance MudDialog { get; set; }

    protected override void OnInitialized()
    {
        if (model.OpTranID == null)
        {

            model.Area = Area;
            model.PaymentMode = PaymentMode;
            model.TotalAmount = 0;
        }
        else
        {
            accountRuleDefinition.CoaID = model.CreditCoaID;
            accountRuleDefinition.ArdCode = model.PaymentArdCode;

            model.Transactions = Iservice.GetExpenses(model.OpTranID).ToList();
        }

        costCenter = costIservice.Select().ToList();
        dimension = dimensionIservice.Select().ToList();

    }
    private void Cancel()
    {
        MudDialog.Cancel();
    }
    protected async Task IsApproveData(DataApprovedStatus aprvd)
    {
        if (aprvd.IsApprove)
        {
            var authprov = await auth.GetAuthenticationStateAsync();
            var user = authprov.User;
            model.UserInfo.UserID = user.Identity.Name;
            Iservice.Approve(model.OpTranID, model.UserInfo.UserID, aprvd.Remarks);
            snackbar.Add("Approved Successfully", Severity.Success);
        }
    }
    private async Task<IEnumerable<AccountRuleDefinitionModel>> SearchAccounts(string searchString)
    {
        await Task.Delay(3);

        var authprov = await auth.GetAuthenticationStateAsync();
        var brancIDString = authprov.User.Claims.First(x => x.Type == "BranchID").Value;
        int branchID = int.Parse(brancIDString);

        return accountService.GetPaymentCodes(branchID, model.PaymentMode).ToList(); ;
    }


    public void AddItems()
    {

        opTranSubModel.ExpenseUsageCode = gstusge.UsageCode;

        model.Transactions.Add(opTranSubModel);

        model.TotalAmount = model.TotalAmount + (opTranSubModel.Amount * opTranSubModel.Quantity);
        opTranSubModel = new();
        Total();
    }
    public void DeleteExpenses(OpTranSubModel i)
    {
        int rowIndex = model.Transactions.IndexOf(i);
        model.TotalAmount = model.TotalAmount - (i.Amount * i.Quantity);
        model.Transactions.RemoveAt(rowIndex);
        Total();
    }

    private void Total()
    {
        model.TotalAmount = model.Transactions.Sum(x => x.Amount);
    }

    private async Task Submit()
    {

        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;

        model.UserInfo.UserID = user.Identity.Name;
        var brancIDString = authprov.User.Claims.First(x => x.Type == "BranchID").Value;
        model.BranchID = int.Parse(brancIDString);
        model.PaymentArdCode = accountRuleDefinition.ArdCode;
        model.CreditCoaID = accountRuleDefinition.CoaID;
        model.NatureOfTransaction = "Operations";

        try
        {
            Iservice.Update(model);
            snackbar.Add("Saved Successfully", Severity.Success);
            model = new OpTranModel();
        }
        catch (Exception ex)
        {
            snackbar.Add(ex.Message, Severity.Warning);
        }
        MudDialog.Close();
    }

}
