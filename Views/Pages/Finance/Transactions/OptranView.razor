@page "/OptranView"
@page "/OptranView/{id:int}"
@inherits ViewComponentBase<OpTranModel>
@inject IOpTranService Iservice
@inject IDialogService DialogService


<div class="admin-page-container">
    <div class="admin-header-tiered mb-6">
        <div class="d-flex align-center justify-space-between">
            <div>
                <MudText Typo="Typo.h4" Class="admin-title">Trip Related Expenses</MudText>
                <MudText Typo="Typo.body2" Class="admin-subtitle"> Trip related expenses like wages, packing, loading/unloading etc. </MudText>
            </div>
        </div>
    </div>
    <div class="admin-glass-card mb-6 pa-4">
        <div class="d-flex align-center gap-4 flex-wrap">
            <div style="flex-grow: 1; min-width: 300px;">
                <MudTextField @bind-Value="searchTerm" Placeholder="Search by document #, narration, or amount..." Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.HistoryEdu" Variant="Variant.Outlined" Margin="Margin.Dense" Class="admin-input-group" @onkeyup="HandleSearchKeyUp" Clearable="true" />
            </div>
            <div class="d-flex align-center gap-4">              
                <div class="d-flex align-center gap-2 bg-glass rounded-pill px-4 py-1">
                    <MudCheckBox T="bool" Label="Approved Log" ValueChanged="((bool value)=>ToggleData(value))" Value="@ShowApproved" Size="Size.Small" Color="Color.Primary" Class="fw-600" />
                </div>
            </div>
        </div>
    </div>
    <div class="admin-glass-card pa-0 overflow-hidden">
        <MudTable ServerData="LoadServerData" T="OpTranModel" @ref="_table" Dense="true" Hover="true" Striped="true" Elevation="10">
            <LoadingContent>
                <div @key="@("loader")" style="display: flex; justify-content: center; align-items: center; min-height: 400px;">
                    <LoaderComponent IsFullScreen="false"
                                     ShowLogo="false"
                                     Size="large"
                                     LoadingText="Loading...."
                                     SubText="Fetching Data..." />
                </div>
            </LoadingContent>
            <HeaderContent>
                <MudTh><MudTableSortLabel SortBy="new Func<OpTranModel, object>(x=> x.DocumentDate)" >Document Date</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<OpTranModel, object>(x=> x.OpTranID)" InitialDirection="SortDirection.Descending">Document Number</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<OpTranModel, object>(x=> x.OpTranType)" InitialDirection="SortDirection.Descending">Trip/Transfer</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<OpTranModel, object>(x=> x.TotalAmount)" >Total Amount</MudTableSortLabel></MudTh>
                <MudTh>Actions</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="DocumentDate">@context.DocumentDate?.ToShortDateString()</MudTd>
                <MudTd DataLabel="DocumentNumber">@context.DocumentNumber

                    @if (context.AuthLevelId == 100)
                    {
                        <MudText Color="Color.Error" GutterBottom> Rejected </MudText>
                    }
                </MudTd>
                <MudTd DataLabel="OpTranType">@context.OpTranType</MudTd>
                <MudTd DataLabel="TotalAmount">@context.TotalAmount</MudTd>
                <MudTd DataLabel="">
                    <MudIconButton OnClick="@(()=> OpenForm(context,true))" Color="Color.Primary" Icon="@Icons.Material.Filled.GridView" Title="View" Class="ml-2" Size="Size.Small" Variant="Variant.Filled" />
                    <MudIconButton Disabled="@(context.AuthLevelId != null)" OnClick="@(()=> OpenForm(context,false))" Color="Color.Primary" Title="Edit" Class="ml-2" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Variant="Variant.Filled" />
                    <MudIconButton Disabled="@(context.AuthLevelId != null)" OnClick="@(()=> Delete(context.OpTranID))" Color="Color.Error" Title="Delete" Class="ml-2" Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Variant="Variant.Filled" />
                    @if (@context.AuthLevelId == 99)
                    {
                        <EntryReversedComponent DocTypeID="@DocInfo.DocumentTypeID" DocumentID="@context.OpTranID" MID="@context.MID" DocumentNumber="@context.DocumentNumber"></EntryReversedComponent>
                        <MudIconButton OnClick="@(()=> Print(context.OpTranID))" Color="Color.Tertiary" Title="Print" Class="ml-2" Icon="@Icons.Material.Filled.Print" Size="Size.Small" Variant="Variant.Filled" />
                    }
                    else if (@context.AuthLevelId != 100)
                    {
                        <MudIconButton OnClick="@(()=> OpenForm(context,true))" Color="Color.Warning" Class="ml-2" Icon="@Icons.Material.Filled.Verified" Title="Verify" Size="Size.Small" Variant="Variant.Filled" />
                    }
                </MudTd>
            </RowTemplate>
            <PagerContent>
                <MudTablePager PageSizeOptions="new int[] { 10, 20, 50, 100 }" />
                <MudItem xs="12" md="9"></MudItem>
                <MudItem xs="12" md="3"></MudItem>
            </PagerContent>
        </MudTable>
    </div>
</div>
@code {

    protected override List<OpTranModel> _collection { get; set; } = new List<OpTranModel>();
    protected override DocumentInfoModel DocInfo { get; set; } = new DocumentInfoModel()
        {
            DocumentTypeID = 6,
            DocumentName = "Trip Expenses"
        };
    public string ReportName { get; set; }
    public Dictionary<string, string> ReportParameters { get; set; } = new();
    public string BranchName = "";

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();
        var authprov = await auth.GetAuthenticationStateAsync();
        var User = authprov.User;
        BranchName = User.Claims.First(x => x.Type == "BranchName").Value;

        if (id != null && _collection != null && _collection.Any(g => g.OpTranID == id))
        {
            await OpenForm(_collection.FirstOrDefault(s => s.OpTranID == id), true);
        }
    }   

    // Asynchronous method to open a form for editing or adding a transaction
    protected override async Task OpenForm(OpTranModel ppm, bool ReadOnly, bool DisableAddition = false)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        _busy = true;

        if (ppm.TripID is null)
        {
            ppm.Area = "NonTrip";
            ppm.NatureOfTransaction = "Trip Expenses";
        }
        DialogParameters parms = new DialogParameters();
        parms.Add("model", ppm.Clone());
        parms.Add("ReadOnly", ReadOnly);
        parms.Add("OnApproved", new EventCallbackFactory().Create(this, async() => await _table.ReloadServerData()));
        var dialog = await dialogService.ShowAsync<OpTranDialog>(ppm.OpTranID == null ? "ADD" : "EDIT", parms, new DialogOptions() { MaxWidth = MaxWidth.Large, FullWidth = true });
        var result = await dialog.Result;
        var isCancelled = result.Canceled;
        if (!isCancelled)
        {
            var ReturnData = (OpTranModel)result.Data;     
            await _table.ReloadServerData();
        }
        
        await Task.Delay(200);
        _busy = false;
    }

    // Asynchronous method to print a transaction
    private async Task Print(int? OpTranID)
    {
        ReportParameters.Clear();
        ReportParameters.Add("OpTranID", OpTranID.ToString());
        ReportParameters.Add("BranchName", BranchName);
        var parameters = new DialogParameters();
        parameters.Add("Parameters", ReportParameters); // Add the dictionary as a parameter
        parameters.Add("ReportName", "PrintVoucherTripSettlement");

        DialogOptions maxWidth = new DialogOptions() { MaxWidth = MaxWidth.Medium, FullWidth = true };
        var result = await DialogService.ShowAsync<PrintDialog>("PRINT", parameters, maxWidth);
    }
}
