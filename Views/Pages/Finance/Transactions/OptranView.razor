@page "/OptranView"
@inject IOpTranService Iservice
@inject IDimensionService dimensionIservice
@inject ICostCenterService costIservice
@inject NavigationManager uriHelper;
@inject MudBlazor.ISnackbar snackbar
@inject AuthenticationStateProvider auth
@attribute [Authorize]
@inject IDialogService DialogService




<MudGrid Spacing="4">
    <MudItem xs="12">

        <MudTable Items="@collection" Dense="true" Hover="true" Striped="true" Elevation="10" @bind-place="model">
            <ToolBarContent>
                <MudText Typo="Typo.h6">Operation Transcations</MudText>



                <MudSpacer></MudSpacer>
                <MudCheckBox Label="Approved Entries" CheckedChanged="((bool value)=>ApprovedChanged(value))" Checked="@IsApproved" Size="Size.Medium" Color="Color.Primary"></MudCheckBox>

            </ToolBarContent>


            <HeaderContent>
                <MudTh><MudTableSortLabel SortBy="new Func<OpTranModel, object>(x=> x.DocumentDate)" InitialDirection="SortDirection.Ascending">DocumentDate</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<OpTranModel, object>(x=> x.DocumentNumber)" InitialDirection="SortDirection.Ascending">DocumentNumber</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<OpTranModel, object>(x=> x.TotalAmount)" InitialDirection="SortDirection.Ascending">TotalAmount</MudTableSortLabel></MudTh>


                <MudTh>Actions</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="DocumentDate">@context.DocumentDate</MudTd>
                <MudTd DataLabel="DocumentNumber">@context.DocumentNumber</MudTd>
                <MudTd DataLabel="TotalAmount">@context.TotalAmount</MudTd>

                <MudTd DataLabel="">

                    @if (@context.AuthLevelId != 99)
                    {
                        <MudTooltip Text="Verify">
                            <MudFab @onclick="@(()=> OpenDialogpayment(context,true,false))" Color="Color.Warning" Icon="@Icons.Material.Filled.Verified" title="Verify" Size="Size.Small" IconSize="Size.Small" />
                        </MudTooltip>
                    }
                    <MudTooltip Text="view">
                        <MudFab @onclick="@(()=> OpenDialogpayment(context,true,true))" Color="Color.Primary" Icon="@Icons.Material.Filled.GridView" Size="Size.Small" IconSize="Size.Small" />
                    </MudTooltip>


                </MudTd>


            </RowTemplate>
            <PagerContent>
                <MudTablePager PageSizeOptions="new int[] { 5, 10, 20, 50, 100 }" />
                <MudItem xs="12" md="9"> </MudItem><MudItem xs="12" md="3">

                </MudItem>
            </PagerContent>
        </MudTable>
    </MudItem>
</MudGrid>



@code {
    private OpTranModel model = new OpTranModel();
    private List<OpTranModel> collection = new List<OpTranModel>();
    public bool IsApproved { get; set; } = false;

    void ApprovedChanged(bool value)
    {
        IsApproved = value;
        GetOpTrans(IsApproved);
    }
    protected override void OnInitialized()
    {

        GetOpTrans(IsApproved);
    }
    public void GetOpTrans(bool val)
    {


        if (val)
        {
            collection = Iservice.SelectByTrip(0).Where(x => x.AuthLevelId == 99).ToList();
        }
        else
        {
            collection = Iservice.SelectByTrip(0).Where(x => x.AuthLevelId != 99).ToList();
        }
    }

    public async Task OpenDialogpayment(OpTranModel ppm, bool ReadOnly, bool View)
    {

        DialogParameters parms = new DialogParameters();
        parms.Add("model", ppm);
        parms.Add("PaymentMode", ppm.PaymentMode);
        parms.Add("Area", ppm.Area);
        parms.Add("IsReadOnly", ReadOnly);
        parms.Add("IsView", View);
        var dialog = DialogService.Show<OpTranDialog>(ppm.OpTranID == null ? "ADD" : "EDIT", parms, new DialogOptions() { MaxWidth = MaxWidth.Large, FullWidth = true });
        var result = await dialog.Result;
        GetOpTrans(IsApproved);
    }


}
