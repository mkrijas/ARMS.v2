    private async Task OpenOtstandingBills()
    {
        DialogParameters parms = new DialogParameters();
        parms.Add("PartyID",model.PartyBranchInfo.PartyID);
        parms.Add("GstID",model.PartyBranchInfo.GstID);
        var dialog =  DialogService.Show<OutstandingBillSelectView>("Outstanding Bill",parms,maxWidth);
        var result = await dialog.Result;

        if(!result.Cancelled)
        {

            SelectedItems = (List<OutstandingBillsModel>)result.Data;         
