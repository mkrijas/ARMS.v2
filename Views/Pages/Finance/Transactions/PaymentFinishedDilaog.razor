@using Microsoft.Extensions.Configuration
@inject IPaymentService Iservice
@inject IOutstandingBillsService OBIservice
@inject ICostCenterService costIservice
@inject TruckDataArrayModel data
@inject IDimensionService dimensionIservice
@inject IChartOfAccountService accountService
@inject IConfiguration configuration
@inject NavigationManager uriHelper;
@inject MudBlazor.ISnackbar snackbar
@inject AuthenticationStateProvider auth
@attribute [Authorize]
@inject IDialogService DialogService
@using System.Globalization

<MudDialog>
    <TitleContent>
       
        @if (IsView)
        {
            <MudText Color="Color.Error">@model.AuthStatus</MudText>
        }
    </TitleContent>
    <DialogContent>

        <EditForm id="formtfinishmemo" Model="@model" OnValidSubmit="OnValidSubmit">
            <MudPaper>
                <MudContainer Style="max-height:450px; overflow-y: scroll">
                    <PaymentMemoInitateFinishDetails model="pm" IsReadOnly="true" IsView="true"></PaymentMemoInitateFinishDetails>

                    <MudText Class="m-2">
                        <MudIcon Icon="@Icons.Material.Filled.Build" Class="mr-3 mb-n1" />
                        Finalaize Payment Memo
                    </MudText>
                   
                    <MudGrid Spacing="4">

                        <MudItem xs="12" md="12">
                            <PaymentCodeSelector IsReadonly="IsReadOnly" @bind-Value="accountRuleDefinitionModel" LabelName="Select Accounts"></PaymentCodeSelector>


                        </MudItem>
                        <MudItem xs="6" md="6">
                            <MudDatePicker @bind-Date="model.DocumentDate" ReadOnly="IsReadOnly" DisableToolbar="true" Editable="true" DateFormat="dd/MM/yyyy" Label="DocumentDate" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.DocumentDate)"></MudDatePicker>

                        </MudItem>
                        <MudItem xs="6" md="6">


                            <MudTextField @bind-Value="model.Narration" ReadOnly="IsReadOnly" Lines="2" Label="Narration" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.Narration)"></MudTextField>

                        </MudItem>




                        <MudItem xs="12">
                            @if ((IsReadOnly) && (!IsView))
                            {
                                <AutherizationStatusComponent DocTypeID="8" DocumentID="model.PfID" OnApprove="IsApproveData"></AutherizationStatusComponent>

                            }
                        </MudItem>
                    </MudGrid>
                </MudContainer>
            </MudPaper>
        </EditForm>
    </DialogContent>
    <DialogActions>
        @if (!IsReadOnly)
        {
            <MudButton OnClick="Cancel">Cancel</MudButton>
            <MudButton form="formtfinishmemo" Variant="Variant.Filled" Color="Color.Success" ButtonType="ButtonType.Submit">Submit</MudButton>
        }
    </DialogActions>
</MudDialog>



@code {
    [Parameter]
    public PaymentFinishModel model { get; set; }

    [Parameter]
    public bool IsReadOnly { get; set; }
    [Parameter]
    public bool IsView { get; set; }
    PartyPaymentMemoModel pm = new PartyPaymentMemoModel();
    public string customstr { get; set; } = "Bank";
    private ChartOfAccountModel SelectedAccount = null;
    private List<PaymentEntryModel> paymentEntry = new List<PaymentEntryModel>();
    [CascadingParameter] MudDialogInstance MudDialog { get; set; }
    private AccountRuleDefinitionModel accountRuleDefinitionModel = new();
    private async Task<IEnumerable<ChartOfAccountModel>> SearchAccounts(string searchString)
    {

        int coID = Convert.ToInt32(configuration.GetSection("Data")[customstr]);
        return await Task.FromResult(accountService.SelectChildren(coID));

    }

    public class CustomStringToBoolConverter : BoolConverter<string>
    {

        public CustomStringToBoolConverter()
        {
            SetFunc = OnSet;
            GetFunc = OnGet;
        }

        private string TrueString = "Cash";
        private string FalseString = "Bank";
        private string NullString = "Error";

        private string OnGet(bool? value)
        {
            try
            {
                return (value == true) ? TrueString : FalseString;
            }
            catch (Exception e)
            {
                UpdateGetError("Conversion error: " + e.Message);
                return NullString;
            }
        }

        private bool? OnSet(string arg)
        {
            if (arg == null)
                return null;
            try
            {
                if (arg == TrueString)
                    return true;
                if (arg == FalseString)
                    return false;
                else
                    return null;
            }
            catch (FormatException e)
            {
                UpdateSetError("Conversion error: " + e.Message);
                return null;
            }
        }


    }

    protected override async Task OnInitializedAsync()
    {
        GetPaymentEntryDetails();
    }
    public async Task GetPaymentEntryDetails()
    {
        var authprov = await auth.GetAuthenticationStateAsync();
        var brancIDString = authprov.User.Claims.First(x => x.Type == "BranchID").Value;
        int brancID = int.Parse(brancIDString);
        List<PartyPaymentMemoModel> ppmm = new List<PartyPaymentMemoModel>();

        List<PaymentFinishModel> pfm = new List<PaymentFinishModel>();
        if (model.PfID != null)
        {
            pfm = Iservice.SelectFinished(brancID, model.PfID).ToList();
            foreach (var item in pfm)
            {
                PaymentFinishModel f = new ();
                model.DocumentDate = item.DocumentDate;
                accountRuleDefinitionModel.BankTools = item.PaymentTool;
                accountRuleDefinitionModel.paymentMode = item.PaymentMode;
                accountRuleDefinitionModel.BankCharges = item.BankCharges;
                model.Narration = item.Narration;
                accountRuleDefinitionModel.CoaID = item.PaymentCoaID;

            }
        }


        ppmm = Iservice.Select(model.PiID.Value, brancID).ToList();
        // model.Payments = new();
        foreach (var item in ppmm)
        {

            //PaymentEntryModel p = new PaymentEntryModel();
            //p.PaymentMemoID = item.PaymentMemoID;
            //p.DocumentNumber = item.DocumentNumber;
            //p.Amount = null;
            //p.EffectiveDate = null;
            //p.Reference = null;
            //p.PeID = null;
            ////model.Payments.Add(p);
            //paymentEntry.Add(p);
            pm.PaymentMemoID = item.PaymentMemoID;
            pm.PaymentInitiatedID = item.PaymentInitiatedID;
            pm.DocumentNumber = item.DocumentNumber;
            pm.DocumentDate = item.DocumentDate;
            pm.PaymentStatus = item.PaymentStatus;
            pm.CostCenter = item.CostCenter;
            pm.Dimension = item.Dimension;
            pm.TotalAmount = item.TotalAmount;
            pm.Narration = item.Narration;
            pm.IsInterBranch = item.IsInterBranch;

        }

    }
    private async Task OnValidSubmit(EditContext context)
    {
        var authprov = await auth.GetAuthenticationStateAsync();
        var brancIDString = authprov.User.Claims.First(x => x.Type == "BranchID").Value;
        int brancID = int.Parse(brancIDString);

        //model.Payments = paymentEntry;
        model.PaymentMode = accountRuleDefinitionModel.paymentMode;
        model.PaymentCoaID = accountRuleDefinitionModel.CoaID;
        model.PaymentArdCode = accountRuleDefinitionModel.ArdCode;
        model.PaymentTool = accountRuleDefinitionModel.BankTools;
        model.BankCharges = accountRuleDefinitionModel.BankCharges;
        model.BranchID = brancID;
        var user = authprov.User;
        model.UserInfo.UserID = user.Identity.Name;
        Iservice.CompletePayment(model);
        snackbar.Add("Saved Successfully", Severity.Success);
        MudDialog.Close();
    }
    public void Cancel()
    {
        MudDialog.Close(); 
    }
    public void calcAmount()
    {
        model.TotalAmount = 0;
        foreach (var item in paymentEntry)
        {
            if (item.Amount != null)
            {
                model.TotalAmount = model.TotalAmount + item.Amount;
            }
        }
    }
    protected async Task IsApproveData(DataApprovedStatus aprvd)
    {
        if (aprvd.IsApprove)
        {
            try
            {
                var authprov = await auth.GetAuthenticationStateAsync();
                var user = authprov.User;
                model.UserInfo.UserID = user.Identity.Name;
                Iservice.FinalMemmoApprove(model.PfID, model.UserInfo.UserID, aprvd.Remarks);
                snackbar.Add("Approved Successfully", Severity.Success);
                MudDialog.Close();
            }
            catch (Exception ex)
            {
                snackbar.Add(ex.Message, Severity.Warning);
            }
        }

    }
}
