@inject IPaymentService Iservice

@inject MudBlazor.ISnackbar snackbar
@inject AuthenticationStateProvider auth
@attribute [Authorize]
@inject IDialogService DialogService





<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.Build" Class="mr-3 mb-n1" />
            Initial Payment Memo
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudContainer Style="min-height:100px;">
            <EditForm id="formtdsRate" Model="@model" OnValidSubmit="OnValidSubmit">
                <ObjectGraphDataAnnotationsValidator />
                <ValidationSummary />
                <MudGrid Spacing="2">
                   

                    <MudItem xs="12" md="6">
                        <MudDatePicker Label="Due Date" Variant="Variant.Outlined" Margin="Margin.Dense" DisableToolbar="true" Editable="true" @bind-Date="model.DueOn" DateFormat="dd/MM/yyyy" />
                     </MudItem>
                      <MudItem xs="12" md="6">
                        <MudDatePicker Label="DocDate" Variant="Variant.Outlined" Margin="Margin.Dense" DisableToolbar="true" Editable="true" @bind-Date="model.DocDate" DateFormat="dd/MM/yyyy" />
                     </MudItem>


                </MudGrid>
            </EditForm>
        </MudContainer>
    </DialogContent>
    <DialogActions>
      
            <MudButton form="formtdsRate" Variant="Variant.Filled" Color="Color.Success" ButtonType="ButtonType.Submit">Create Initiated PaymentMemo</MudButton>
        
    </DialogActions>
</MudDialog>

@code {
        [Parameter]
        public PaymentInitiatedModel model { get; set; }
        [CascadingParameter] MudDialogInstance MudDialog { get; set; }
        
        private async Task OnValidSubmit(EditContext context)
        {
            MudDialog.Close(model);
            

        }
}
