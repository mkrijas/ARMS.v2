@using Views.Pages.Finance.InterBranchTranscations
@inject IPaymentService Iservice
@inject IOutstandingBillsService OBIservice
@inject ICostCenterService costIservice
@inject IDimensionService dimensionIservice
@inject NavigationManager uriHelper;
@inject MudBlazor.ISnackbar snackbar
@inject AuthenticationStateProvider auth
@attribute [Authorize]
@inject IDialogService DialogService

<MudDialog>
    <TitleContent>

    </TitleContent>
    <DialogContent>
        <MudContainer Style="max-height: 450px; overflow-y: scroll">

            <MudGrid Spacing="4">
                <MudItem xs="12">
                    <MudTable Items="@collection" Dense="true" Hover="true" Striped="true" @bind-place="model1">


                        <ToolBarContent>
                            <MudText Typo="Typo.h6">Paymet Memos</MudText>
                            @if (IsView)
                            {
                                <MudText Color="Color.Error">@model.AuthStatus</MudText>
                            }

                            @* <MudButton @onclick="openpurchaseorder" @onclick="@(()=> OpenDialog(model))"  Variant="Variant.Filled" Color="Color.Primary" >Purchase Order</MudButton>
                            *@
                            <MudSpacer></MudSpacer>
                            @* <MudTextField @bind-Value="searchMemos" Placeholder="Search Tax... "
                            Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                            IconSize="Size.Medium" Class="mt-0"></MudTextField>*@
                        </ToolBarContent>
                        <HeaderContent>
                            <MudTh><MudTableSortLabel SortBy="new Func<PartyPaymentMemoModel, object>(x=> x.DocumentDate)" InitialDirection="SortDirection.Ascending">DocumentDate</MudTableSortLabel></MudTh>
                            <MudTh><MudTableSortLabel SortBy="new Func<PartyPaymentMemoModel, object>(x=> x.PartyInfo.TradeName)" InitialDirection="SortDirection.Ascending">Party Name</MudTableSortLabel></MudTh>
                            <MudTh><MudTableSortLabel SortBy="new Func<PartyPaymentMemoModel, object>(x=> x.TotalAmount)" InitialDirection="SortDirection.Ascending">TotalAmount</MudTableSortLabel></MudTh>

                            <MudTh>Actions</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd DataLabel="DocumentDate">@context.DocumentDate</MudTd>
                            <MudTd DataLabel="PartyName">@context.PartyInfo.TradeName</MudTd>
                            <MudTd DataLabel="TotalAmount">@context.TotalAmount</MudTd>
                            <MudTd DataLabel="">
                                <MudTooltip Text="View">
                                    <MudFab @onclick="@(()=> View(context))" Color="Color.Primary" Icon="@Icons.Material.Filled.GridView" Size="Size.Small" IconSize="Size.Small" />
                                </MudTooltip>
                            </MudTd>
                        </RowTemplate>

                        <PagerContent>
                            <MudTablePager PageSizeOptions="new int[] { 5, 10, 20, 50, 100 }" />

                        </PagerContent>
                    </MudTable>

                </MudItem>
                <MudItem xs="12" md="6">

                    <MudDatePicker ReadOnly="true" Label="Due Date" Variant="Variant.Outlined" Margin="Margin.Dense" DisableToolbar="true" Editable="true" @bind-Date="model.DueOn" DateFormat="dd/MM/yyyy" />


                </MudItem>
                <MudItem xs="12" md="6">

                    <MudDatePicker ReadOnly="true" Label="Document Date" Variant="Variant.Outlined" Margin="Margin.Dense" DisableToolbar="true" Editable="true" @bind-Date="model.DocDate" DateFormat="dd/MM/yyyy" />


                </MudItem>
                    <MudItem xs="12">
                        @if ((IsReadOnly) && (!IsView))
                        {
                            <AutherizationStatusComponent DocTypeID="15" DocumentID="model.PiID" OnApprove="IsApproveData"></AutherizationStatusComponent>

                        }

                    </MudItem>
            </MudGrid>

            @* <MudPaper >
            <MudContainer>
            <MudGrid   >




            </MudGrid></MudContainer></MudPaper>*@


        </MudContainer>
    </DialogContent>
    <DialogActions>


    </DialogActions>
</MudDialog>

@code {
    [Parameter]
    //public PartyPaymentMemoModel model { get; set; }
    public PaymentInitiatedModel model { get; set; }

    [Parameter]
    public bool IsReadOnly { get; set; }
    [Parameter]
    public bool IsView { get; set; }
    private PartyPaymentMemoModel model1 = new PartyPaymentMemoModel();
    private List<PartyPaymentMemoModel> collection = new List<PartyPaymentMemoModel>();
    DialogOptions mediumWidth = new DialogOptions() { MaxWidth = MaxWidth.Medium, FullWidth = true };

    protected async Task IsApproveData(DataApprovedStatus aprvd)
    {
        if (aprvd.IsApprove)
        {
            var authprov = await auth.GetAuthenticationStateAsync();
            var user = authprov.User;
            model.UserInfo.UserID = user.Identity.Name;
            Iservice.Approve(model.PiID, model.UserInfo.UserID,aprvd.Remarks);
            snackbar.Add("Approved Successfully", Severity.Success);
        }

    }





    protected override async Task OnInitializedAsync()
    {

        GetAll();
    }
    private async Task GetAll()
    {
        var authprov = await auth.GetAuthenticationStateAsync();
        var brancIDString = authprov.User.Claims.First(x => x.Type == "BranchID").Value;
        int brancID = int.Parse(brancIDString);
        collection = new List<PartyPaymentMemoModel>();
        foreach (var item in Iservice.Select(model.PiID.Value, brancID))
        {
            collection.Add(item);
        }


    }

    public void View(PartyPaymentMemoModel ppmm)
    {
        DialogParameters parms = new DialogParameters();
        parms.Add("model", ppmm);
        if(ppmm.IsInterBranch)
        {
            var dialog = DialogService.Show<InterBranchPaymentMemoDialog>(ppmm.PaymentMemoID == null ? "Payment Memo" : "Payment Memo", parms, mediumWidth);

        }
        else
        {
            var dialog = DialogService.Show<PaymentMemoDialog>(ppmm.PaymentMemoID == null ? "Payment Memo" : "Payment Memo", parms, mediumWidth);
            
        }

    }
}
