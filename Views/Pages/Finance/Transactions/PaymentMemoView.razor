@page "/PaymentMemoView"
@inject IPaymentService Iservice
@inject IOutstandingBillsService OBIservice
@inject ICostCenterService costIservice
@inject IDimensionService dimensionIservice
@inject NavigationManager uriHelper;
@inject MudBlazor.ISnackbar snackbar
@inject AuthenticationStateProvider auth
@attribute [Authorize]
@inject IDialogService DialogService





<MudGrid Spacing="4">
   <MudItem xs="12">
        <MudTable Items="@collection" @bind-SelectedItems="selectedItems1" MultiSelection="true"  Dense="true" Hover="true"  Striped="true" Elevation="10"  @bind-place="model">
           
             <ToolBarContent>
                <MudText Typo="Typo.h6">Payment Memo</MudText>
                <MudTooltip Text="New Payment Memo">
                <MudIconButton  Icon="@Icons.Material.Filled.Add" Title="Add" @onclick="@(()=> OpenDialogpayment(model,false,false))"  Color="Color.Dark" Size="Size.Small"></MudIconButton>
                </MudTooltip>


                <MudSpacer></MudSpacer>  
                <MudCheckBox Label="Approved Entries" CheckedChanged="((bool value)=>ApprovedChanged(value))" Checked="@IsApproved" Size="Size.Medium" Color="Color.Primary"></MudCheckBox>
                
            </ToolBarContent>
            <HeaderContent>
                <MudTh><MudTableSortLabel SortBy="new Func<PartyPaymentMemoModel, object>(x=> x.DocumentDate)" InitialDirection="SortDirection.Ascending">DocumentDate</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<PartyPaymentMemoModel, object>(x=> x.PartyInfo.TradeName)" InitialDirection="SortDirection.Ascending">Party Name</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<PartyPaymentMemoModel, object>(x=> x.TotalAmount)" InitialDirection="SortDirection.Ascending">TotalAmount</MudTableSortLabel></MudTh>

                <MudTh>Actions</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="DocumentDate">@context.DocumentDate</MudTd>
                <MudTd DataLabel="PartyName">@context.PartyInfo.TradeName</MudTd>
                <MudTd DataLabel="TotalAmount">@context.TotalAmount</MudTd>
                <MudTd DataLabel="">
                    @if (@context.AuthLevelId == null)
                    {
                        <MudTooltip Text="Edit">
                            <MudFab @onclick="@(()=> OpenDialogpayment(context,false,false))" Color="Color.Primary" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" IconSize="Size.Small" />
                        </MudTooltip>
                    }
                    @if (@context.AuthLevelId != 99)
                    {
                        <MudTooltip Text="Verify">
                            <MudFab @onclick="@(()=> OpenDialogpayment(context,true,false))" Color="Color.Warning" Icon="@Icons.Material.Filled.Verified" title="Verify" Size="Size.Small" IconSize="Size.Small" />
                        </MudTooltip>
                    }
                    <MudTooltip Text="view">
                   <MudFab @onclick="@(()=> OpenDialogpayment(context,true,true))" Color="Color.Primary" Icon="@Icons.Material.Filled.GridView" Size="Size.Small" IconSize="Size.Small" />
                    </MudTooltip> 
               </MudTd>
            </RowTemplate>

            <PagerContent>
                <MudTablePager PageSizeOptions="new int[] { 5, 10, 20, 50, 100 }" />

            </PagerContent>
        </MudTable>
    </MudItem> <MudItem xs="12"md="9"></MudItem><MudItem xs="12"md="3">
         <MudButton OnClick="selected" Variant="Variant.Filled" Color="Color.Success" ButtonType="ButtonType.Submit">Initiate PaymentMemo</MudButton>           
    </MudItem>
</MudGrid>

  

@code {

    private PartyPaymentMemoModel model = new PartyPaymentMemoModel();
    private List<PartyPaymentMemoModel> collection = new List<PartyPaymentMemoModel>(); 
    public bool IsApproved { get; set; } = false;

    private HashSet<PartyPaymentMemoModel> selectedItems1= new HashSet<PartyPaymentMemoModel>();
    private int? branchID = null;
    private string UserID = null;
    void ApprovedChanged(bool value)
    {
        IsApproved = value;
        GetAll(IsApproved);
    }
    protected override async Task OnInitializedAsync()
    {
        model = new();
        var authprov = await auth.GetAuthenticationStateAsync();
        branchID = int.Parse(authprov.User.Claims.First(x => x.Type == "BranchID").Value);
        var user = authprov.User;
        UserID = user.Identity.Name;
        GetAll(IsApproved);
    }

    private  void GetAll(bool val)
    {
       if (val)
        {
            collection = Iservice.Select(branchID).Where(x => x.AuthLevelId == 99).ToList();
        }
        else
        {
            collection = Iservice.Select(branchID).Where(x => x.AuthLevelId != 99).ToList();
        }
    }

    public async Task OpenDialogpayment(PartyPaymentMemoModel ppm, bool ReadOnly, bool View)
    {
        //var authprov = await auth.GetAuthenticationStateAsync();
        //var user = authprov.User;
        DialogParameters parms = new DialogParameters();
        parms.Add("model", ppm);
        parms.Add("IsReadOnly", ReadOnly);
        parms.Add("IsView", View);
        var dialog = DialogService.Show<PaymentMemoDialog>(ppm.PaymentMemoID == null ? "ADD" : "EDIT", parms, new DialogOptions() { MaxWidth = MaxWidth.Large, FullWidth = true });
        var result = await dialog.Result;
        GetAll(IsApproved);
    }

    private void Delete(PartyPaymentMemoModel tx)
    {
        Iservice.Delete(tx.PaymentMemoID, "Rijas");
        snackbar.Add("Deleted Successfully", Severity.Success);
        GetAll(IsApproved);
    }

    private async Task selected()
    {
        PaymentInitiatedModel pim = new PaymentInitiatedModel();

        if (selectedItems1.Count > 0)
        {
            foreach (var item in selectedItems1)
            {
                if (item.AuthLevelId != 99)
                {
                    snackbar.Add(item.DocumentNumber + "is Approved!", Severity.Warning);
                    return;
                }
            }            
            pim.PaymentMemos = selectedItems1.ToList();
            foreach (var item in pim.PaymentMemos)
            {
                item.Bills = Iservice.GetBills(item.PaymentMemoID).ToList();               
                item.PaymentStatus = 1;
            }
            
            DialogParameters parms = new DialogParameters();
            parms.Add("model", pim);
            var dialog = DialogService.Show<PaymentInitialMemo>("Payment", parms);
            var result = await dialog.Result;

            if(!result.Canceled)
            {   
                PaymentInitiatedModel UpatedModel = (PaymentInitiatedModel)result.Data; 
                //var authprov = await auth.GetAuthenticationStateAsync();
                //var brancIDString = authprov.User.Claims.First(x => x.Type == "BranchID").Value;
                //int brancID = int.Parse(brancIDString);
                //var user = authprov.User;
                UpatedModel.UserInfo.UserID = UserID;
                UpatedModel.BranchID = branchID;
                Iservice.InitiatePayment(UpatedModel);              
            }
        }
        else
        {
            snackbar.Add("Please Select Memo", Severity.Success);
            return;
        }
         GetAll(IsApproved);    
    }
}
