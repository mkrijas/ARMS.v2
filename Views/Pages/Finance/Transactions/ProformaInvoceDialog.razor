@inject IFreightBillingService Iservice
@inject IPartyService partyIservice
@inject IDimensionService dimensionIservice
@inject ICostCenterService costIservice
@inject MudBlazor.ISnackbar snackbar
@inject AuthenticationStateProvider auth
@attribute [Authorize]
@inject IDialogService DialogService


<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.Build" Class="mr-3 mb-n1" />
          
        </MudText>
          @if (IsView)
        {
            <MudText Color="Color.Error">@model.AuthStatus</MudText>
        }
    </TitleContent>
    <DialogContent>
        <MudContainer Style="max-height: 450px; overflow-y: scroll">
            <EditForm id="formtdsRate" Model="@model" OnValidSubmit="OnValidSubmit">
                <ObjectGraphDataAnnotationsValidator />
                <ValidationSummary />
                <MudGrid Spacing="2">
                   

       <MudItem xs="12"md="4">
   
      <MudTextField ReadOnly="IsReadOnly" @bind-Value="model.Reference"  Label="Reference" Variant="Variant.Outlined" Margin="Margin.Dense" ></MudTextField>


    </MudItem>
     <MudItem xs="12"md="4">
   
      <MudDatePicker ReadOnly="IsReadOnly" Label="DocumentDate" Variant="Variant.Outlined" Margin="Margin.Dense" DisableToolbar="true" Editable="true" @bind-Date="model.DocumentDate" DateFormat="dd/MM/yyyy" />


    </MudItem>
   
     <MudItem xs="12"md="4">
   
      <MudTextField @bind-Value="model.TotalAmount" ReadOnly="true" Label="TotalAmount" Variant="Variant.Outlined" Margin="Margin.Dense" ></MudTextField>


    </MudItem>
     <MudItem xs="12" md="4">
                        <PartySelector @bind-Value="model.Party" NatureOfBusiness="Customer"></PartySelector>
                  </MudItem>
      <MudItem xs="12" md="4">
                         <MudSelect ReadOnly="IsReadOnly" Label="Select CostCenter" @bind-Value="model.CostCenter" T="int?" Variant="Variant.Outlined" Margin="Margin.Dense" OffsetY="true" Direction="Direction.Top" AdornmentColor="Color.Secondary">
                            @foreach (var ditem in costCenter)
                            {
                                <MudSelectItem Value="@ditem.CostCenterID">@ditem.CostCenter</MudSelectItem>
                            }
                        </MudSelect>
                  </MudItem>
                    <MudItem xs="12" md="4">
                        <MudSelect ReadOnly="IsReadOnly" Label="Select Dimension" @bind-Value="model.Dimension" T="int?"  Variant="Variant.Outlined" Margin="Margin.Dense" OffsetY="true" Direction="Direction.Top" AdornmentColor="Color.Secondary" >
                            @foreach (var ditem in dimension)
                            {
                                <MudSelectItem Value="@ditem.DimensionID">@ditem.Dimension</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
        <MudItem xs="12" md="3">
            <MudTextField ReadOnly="IsReadOnly" @bind-Value="model.Gst.GstRate"  Label="GstRate" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.Gst.GstRate)"></MudTextField>
         </MudItem>

        <MudItem xs="12" md="3">
            <MudTextField ReadOnly="IsReadOnly" @bind-Value="model.Gst.Cgst"  Label="Cgst" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.Gst.Cgst)"></MudTextField>
         </MudItem>
          <MudItem xs="12" md="3">
            <MudTextField ReadOnly="IsReadOnly" @bind-Value="model.Gst.Igst"  Label="Igst" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.Gst.Igst)"></MudTextField>
         </MudItem>
          <MudItem xs="12" md="3">
            <MudTextField ReadOnly="IsReadOnly" @bind-Value="model.Gst.Sgst"  Label="Sgst" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.Gst.Sgst)"></MudTextField>
         </MudItem>
         


                     <MudItem xs="12" md="12">
                        <MudTextField ReadOnly="IsReadOnly" @bind-Value="model.Narration" Lines="2" Label="Narration" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.Narration)"></MudTextField>

                    </MudItem>
             @if ((IsReadOnly) && (!IsView))
                        {
                            <AutherizationStatusComponent DocTypeID="2" DocumentID="model.ProformaInvoiceID" OnApprove="IsApproveData"></AutherizationStatusComponent>

                        }


                </MudGrid>
            </EditForm>
        </MudContainer>
    </DialogContent>
    <DialogActions>
      
        @if (!IsReadOnly)
        {
            <MudButton Variant="Variant.Filled" Color="Color.Info" OnClick="Cancel">Cancel</MudButton>

            <MudButton form="formtdsRate" Variant="Variant.Filled" Color="Color.Success" ButtonType="ButtonType.Submit">Create Proforma Invoice</MudButton>
        }
          @if (IsReadOnly)
        {
            <MudButton Variant="Variant.Filled" Color="Color.Info" OnClick="Cancel">Close</MudButton>

        }
    </DialogActions>
</MudDialog>
@code {

    [Parameter]
    public ProformaInvoiceModel model { get; set; }
     [Parameter]
    public bool IsReadOnly { get; set; }
    [Parameter]
    public bool IsView { get; set; }
    GstModel gs = new();
    private List<CostCenterModel> costCenter = new();
    private List<DimensionModel> dimension = new();
    [CascadingParameter] MudDialogInstance MudDialog { get; set; }

    protected override async Task OnInitializedAsync()
    {
        model.NatureOfTransaction = "Proforma Invoice";
        costCenter = costIservice.Select().ToList();
        dimension = dimensionIservice.Select().ToList();
    }
     private void Cancel()
    {
        MudDialog.Cancel();
    }
      protected async Task IsApproveData(DataApprovedStatus aprvd)
    {
        if (aprvd.IsApprove)
        {
            var authprov = await auth.GetAuthenticationStateAsync();
            var user = authprov.User;
            model.UserInfo.UserID = user.Identity.Name;
          //  Iservice.Approve(model.SID, model.UserInfo.UserID,aprvd.Remarks);
            snackbar.Add("Approved Successfully", Severity.Success);
        }

    }
    private async Task OnValidSubmit(EditContext context)
    {
        model.PartyCoa = partyIservice.GetCustomerReceivableCoaID(model.Party.PartyID.Value);
        MudDialog.Close(model);
            

        }

}
