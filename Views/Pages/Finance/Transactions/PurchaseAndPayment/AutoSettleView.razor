@page "/AutoSettleView"
@page "/AutoSettleView/{id:int}"
@using System.Threading;

@inject IOutstandingBillsService Iservice
@inject MudBlazor.ISnackbar snackbar
@inject AuthenticationStateProvider auth
@inject IRoleService<RoleModel> Irole
@attribute [Authorize]
@inject IDialogService DialogService
@inject SignalRService signalRService
@inject IPushNotificationService IpushNotificationService


<style>
    .selected {
        background-color: #1E88E5 !important;
    }

        .selected > td {
            color: white !important;
        }

            .selected > td .mud-input {
                color: white !important;
            }
</style>

<MudGrid Spacing="4">
    <MudItem xs="12">
        <MudTable Items="@collection" Dense="true" Hover="true" Striped="true" Elevation="10" T="AutoSettleModel">
            <ToolBarContent>
                <MudText Typo="Typo.h6">Auto Settlement</MudText>
                <MudTooltip Text="New Auto Settlement">
                    <MudIconButton Disabled="@_busy" Icon="@Icons.Material.Filled.Add" Title="Add" @onclick="@(()=> OpenDialogpayment(new AutoSettleModel(),false))" Color="Color.Dark" Size="Size.Small"></MudIconButton>
                </MudTooltip>
                <MudSpacer></MudSpacer>
                <MudTextField @bind-Value="searchTerm" Placeholder="Search ..." Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0" @onkeyup="HandleSearchKeyUp">
                </MudTextField>
                <div class="tablefont">
                    <span style="margin-right: 10px;">Maximum Records: </span>
                </div>
                <MudItem xs="1">
                    <MudTextField @bind-Value="@NumberOfRecords" Variant="Variant.Outlined" Margin="Margin.Dense" Class="padding5" Style="width: 80px;"></MudTextField>
                </MudItem>
                <MudCheckBox Label="Approved Entries" CheckedChanged="((bool value)=>ApprovedChanged(value))" Checked="@IsApproved" Size="Size.Medium" Color="Color.Primary" Class="tablefont margin0"></MudCheckBox>
            </ToolBarContent>
            <HeaderContent>
                <MudTh><MudTableSortLabel SortBy="new Func<AutoSettleModel , object>(x=> x.DocumentDate)" InitialDirection="SortDirection.Ascending">Document Date</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<AutoSettleModel, object>(x=> x.PartyInfo.TradeName)" InitialDirection="SortDirection.Ascending">Party Name</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<AutoSettleModel, object>(x=> x.DocumentNumber)" InitialDirection="SortDirection.Ascending">Document Number</MudTableSortLabel></MudTh>                
                <MudTh>Actions</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="DocumentDate">@context.DocumentDate?.ToShortDateString()</MudTd>
                <MudTd DataLabel="PartyName">@context.PartyInfo.TradeName</MudTd>
                <MudTd DataLabel="Purpose">@context.DocumentNumber
                    @if (context.AuthLevelId == 100)
                    {
                        <MudText Color="Color.Error" GutterBottom> Rejected </MudText>
                    }
                </MudTd>
                <MudTd DataLabel="">
                    <MudIconButton OnClick="@(()=> OpenDialogpayment(context,true))" Color="Color.Primary" Icon="@Icons.Material.Filled.GridView" Title="View" Class="ml-2" Size="Size.Small" Variant="Variant.Filled" />
                    <MudIconButton Disabled="@(context.AuthLevelId != null)" OnClick="@(()=> OpenDialogpayment(context,false))" Color="Color.Primary" Title="Edit" Class="ml-2" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Variant="Variant.Filled" />
                    <MudIconButton Disabled="@((context.AuthLevelId??100) != 100 || context.AuthLevelId == 0)" OnClick="@(()=> Delete(context))" Color="Color.Error" Title="Delete" Class="ml-2" Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Variant="Variant.Filled" />

                    @if (@context.AuthLevelId == 99)
                    {
                        <EntryReversedComponent DocTypeID="PaymentDocTypeID" DocumentID="context.AutoSettleID" MID="context.MID" DocumentNumber="context.DocumentNumber"></EntryReversedComponent>
                    }
                    else
                    {
                        <MudIconButton OnClick="@(()=> OpenDialogpayment(context,true))" Color="Color.Warning" Class="ml-2" Icon="@Icons.Material.Filled.Verified" Title="Verify" Size="Size.Small" Variant="Variant.Filled" />
                    }
                </MudTd>
            </RowTemplate>
            <PagerContent>
                <MudTablePager PageSizeOptions="new int[] { 5, 10, 20, 50, 100 }" />
            </PagerContent>
        </MudTable>
    </MudItem>
</MudGrid>

@code {

    private AutoSettleModel model = new();
    private List<AutoSettleModel> collection = new();
    public bool IsApproved { get; set; } = false;
    private int numberOfRecords = 100;
    private string searchTerm = "";
    private bool _busy;

    [Parameter]
    public int? id { get; set; } = null;
    private int? branchID = null;
    private string UserID = null;

    #region SignaIR Notification

    private PushNotificationModel notificationMessage = new PushNotificationModel();
    #endregion

    private int NumberOfRecords
    {
        get => numberOfRecords;
        set
        {
            if (numberOfRecords != value)
            {
                numberOfRecords = value;
                ReloadTable();
            }
        }
    }

    public bool HasPermissionPaymentServiceDelete { get; set; } = false;
    public int PaymentDocTypeID = 7;

    public bool HasPermissionPaymentInitiatedServiceInitiate { get; set; } = false;
    public int PaymentInitiatedDocTypeID = 15;

    private void HandleSearchKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            ReloadTable();
        }
    }

    private void ReloadTable()
    {
        GetAll(IsApproved, NumberOfRecords);
    }

    void ApprovedChanged(bool value)
    {
        IsApproved = value;
        GetAll(IsApproved, NumberOfRecords);
    }

    protected override async Task OnInitializedAsync()
    {
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionPaymentServiceDelete = await Irole.HasClaim(PaymentDocTypeID.ToString(), "Delete", ctc.Token);
        HasPermissionPaymentInitiatedServiceInitiate = await Irole.HasClaim(PaymentInitiatedDocTypeID.ToString(), "Initiate", ctc.Token);

        model = new();
        var authprov = await auth.GetAuthenticationStateAsync();
        branchID = int.Parse(authprov.User.Claims.First(x => x.Type == "BranchID").Value);
        var user = authprov.User;
        UserID = user.Identity.Name;
        GetAll(IsApproved, NumberOfRecords);
        await Task.Delay(200);
        await signalRService.StartAsync();
        if (id != null && collection != null && collection.Any(g => g.AutoSettleID == id))
        {
            await OpenDialogpayment(collection.FirstOrDefault(s => s.AutoSettleID == id), true);
        }
    }

    private void GetAll(bool val, int numberOfRecords)
    {      
        if (val)
        {
            collection = Iservice.SelectAutoSettledEntriesByApproved(branchID, NumberOfRecords).ToList();
        }
        else
        {
            collection = Iservice.SelectAutoSettledEntriesByUnapproved(branchID, NumberOfRecords).ToList();
        }
    }

    public async Task OpenDialogpayment(AutoSettleModel obj, bool ReadOnly)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        _busy = true;
        DialogParameters parms = new DialogParameters();
        parms.Add("model", obj.Clone());
        parms.Add("PageToRedirectLink", "/AutoSettleView");
        parms.Add("ReadOnly", ReadOnly);
        var dialog = DialogService.Show<AutoSettleDialog>(obj.AutoSettleID == null ? "ADD" : "EDIT", parms, new DialogOptions() { MaxWidth = MaxWidth.Large, FullWidth = true });
        var result = await dialog.Result;
        if (!result.Canceled)
        {
            // var ReturnData = (Au)result.Data;
            // notificationMessage.InitiateBranch = new BranchModel() { BranchID = ReturnData.BranchID };
            // notificationMessage.ReceivedBranch = new BranchModel() { BranchID = ReturnData.BranchID };
            // notificationMessage.MessageTitle = IpushNotificationService.GetMessageTitle(ReturnData.NatureOfTransaction, ReturnData.DocumentNumber, "Level 1 Verification");
            // notificationMessage.MessageBody = IpushNotificationService.GetMessageBody(ReturnData.NatureOfTransaction, ReturnData.DocumentNumber, "Level 1 Verification", ReturnData.DocumentDate);
            // notificationMessage.RedirectedTo = 0;
            // notificationMessage.ExpiredBy = 7;
            // notificationMessage.DocumentID = ReturnData.PaymentMemoID;
            // notificationMessage.MessageGroupID = "PendingVerification";
            // notificationMessage.PageToRedirectLink = "/PaymentMemoView";
            // notificationMessage.ClaimValue = "Verify 1";
            // notificationMessage.DocumentTypeID = PaymentDocTypeID;
            // notificationMessage.MsgDate = DateTime.Now;
            // await signalRService.Send(notificationMessage);

        }
        GetAll(IsApproved, NumberOfRecords);
        await Task.Delay(200);
        _busy = false;
    }

    private async Task Delete(AutoSettleModel model)
    {
        if (HasPermissionPaymentServiceDelete)
        {
            bool? result = await DialogService.ShowMessageBox(
                "Warning !",
                "Are you sure, you want to delete - " + model.PartyInfo.TradeName + " (" + model.DocumentDate + ") ?");
            if (result == true)
            {
                Iservice.DeleteAutoSettle(model.AutoSettleID, UserID);
                snackbar.Add("Deleted Successfully", Severity.Success);
            }
            GetAll(IsApproved, NumberOfRecords);
        }
        else
        {
            bool? result = await DialogService.ShowMessageBox(
                "Permission denied!",
                "You dont have permission to Delete record!.");
        }
    }

   
}