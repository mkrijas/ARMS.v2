@page "/AutoSettleView"
@page "/AutoSettleView/{id:int}"
@using System.Threading;
@inject IOutstandingBillsService Iservice
@inherits ViewComponentBase<AutoSettleModel>



<style>
    .selected {
        background-color: #1E88E5 !important;
    }

        .selected > td {
            color: white !important;
        }

            .selected > td .mud-input {
                color: white !important;
            }
</style>


    <div class="fade-in">
        <div class="admin-header-tiered mb-6">
            <div class="d-flex align-center justify-space-between">
                <div>
                    <MudText Typo="Typo.h4" Class="admin-title">Auto Settlement</MudText>
                    <MudText Typo="Typo.body2" Class="admin-subtitle">Manage automated bill settlements and outstanding balances. Track settlement history and verify entries with integrated approval workflows.</MudText>
                </div>
                <MudButton StartIcon="@Icons.Material.Filled.Add" Variant="Variant.Filled" Color="Color.Primary" Class="admin-register-btn" OnClick="@(()=> OpenForm(new AutoSettleModel(),false))" Disabled="@_busy">NEW SETTLEMENT</MudButton>
            </div>
        </div>

        <div class="admin-glass-card mb-6 pa-4">
            <div class="d-flex align-center gap-4 flex-wrap">
                <div style="flex-grow: 1; min-width: 300px;">
                    <MudTextField @bind-Value="searchTerm" Placeholder="Search by party or document number..." Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" Variant="Variant.Outlined" Margin="Margin.Dense" Class="admin-input-group" Clearable="true" OnKeyUp="HandleSearchKeyUp" />
                </div>
                <div class="d-flex align-center gap-4">                    
                    <MudCheckBox T="bool" Label="Approved Entries" ValueChanged="((bool value)=>ToggleData(value))" Value="@ShowApproved" Size="Size.Small" Color="Color.Primary" Class="fw-600" />
                </div>
            </div>
        </div>

        <div class="admin-glass-card pa-0 overflow-hidden">
        <MudTable ServerData="LoadServerData" T="AutoSettleModel" @ref="_table" Elevation="0" Class="modern-admin-table" Hover="true" T="AutoSettleModel">
            <LoadingContent>
                <div @key="@("loader")" style="display: flex; justify-content: center; align-items: center; min-height: 400px;">
                    <LoaderComponent IsFullScreen="false"
                                     ShowLogo="false"
                                     Size="large"
                                     LoadingText="Loading...."
                                     SubText="Fetching Data..." />
                </div>
            </LoadingContent>                
                <HeaderContent>
                    <MudTh><MudTableSortLabel SortBy="new Func<AutoSettleModel, object>(x=> x.DocumentDate)" InitialDirection="SortDirection.Descending"><span class="admin-header-text">DATE</span></MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<AutoSettleModel, object>(x=> x.PartyInfo.TradeName)"><span class="admin-header-text">PARTY NAME</span></MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<AutoSettleModel, object>(x=> x.DocumentNumber)"><span class="admin-header-text">DOC NUMBER</span></MudTableSortLabel></MudTh>
                    <MudTh Style="text-align: right;"><span class="admin-header-text">ACTIONS</span></MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Date"><span class="fw-500">@context.DocumentDate?.ToString("dd MMM yyyy")</span></MudTd>
                    <MudTd DataLabel="PartyName"><span class="fw-600">@context.PartyInfo.TradeName</span></MudTd>
                    <MudTd DataLabel="DocNumber">
                        <div class="d-flex flex-column">
                            <span class="admin-td-primary fw-700">@context.DocumentNumber</span>
                            @if (context.AuthLevelId == 100)
                            {
                                <MudText Typo="Typo.caption" Color="Color.Error" Class="fw-700">REJECTED</MudText>
                            }
                        </div>
                    </MudTd>
                    <MudTd DataLabel="Actions" Style="text-align: right;">
                        <div class="d-flex justify-end gap-1">
                            @if (@context.AuthLevelId == 99)
                            {
                                @if (context.MID == null)
                                {
                                    <MudTooltip Text="Cancel Bill">
                                        <MudIconButton OnClick="@(() => Delete(context.AutoSettleID))" Color="Color.Error" Icon="@Icons.Material.Filled.DoNotDisturb" Size="Size.Small" Variant="Variant.Text" />
                                    </MudTooltip>
                                }
                                else
                                {
                                    <EntryReversedComponent DocTypeID="@DocInfo.DocumentTypeID" DocumentID="context.AutoSettleID" MID="context.MID" DocumentNumber="@context.DocumentNumber"></EntryReversedComponent>
                                }
                            }
                            else if (@context.AuthLevelId != 100)
                            {
                                <MudTooltip Text="Verify Settlement">
                                    <MudIconButton OnClick="@(()=> OpenForm(context,true))" Color="Color.Warning" Icon="@Icons.Material.Filled.Verified" Size="Size.Small" Variant="Variant.Text" />
                                </MudTooltip>
                            }

                            <MudTooltip Text="View Details">
                                <MudIconButton OnClick="@(()=> OpenForm(context,true))" Color="Color.Info" Icon="@Icons.Material.Filled.Visibility" Size="Size.Small" Variant="Variant.Text" />
                            </MudTooltip>
                            
                            <MudTooltip Text="Edit Settlement">
                                <MudIconButton Disabled="@(context.AuthLevelId != null)" OnClick="@(()=> OpenForm(context,false))" Color="Color.Primary" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Variant="Variant.Text" />
                            </MudTooltip>

                            <MudTooltip Text="Remove Settlement">
                                <MudIconButton Disabled="@(context.AutoSettleID != null)" OnClick="@(()=> Delete(context.AuthLevelId))" Color="Color.Error" Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Variant="Variant.Text" />
                            </MudTooltip>
                        </div>
                    </MudTd>
                </RowTemplate>
                <PagerContent>
                    <div class="pa-4">
                        <MudTablePager PageSizeOptions="new int[] { 10, 20, 50, 100 }" />
                    </div>
                </PagerContent>
            </MudTable>
        </div>
    </div>

@code {

    protected override List<AutoSettleModel> _collection { get; set; } = [];

    protected override DocumentInfoModel DocInfo { get; set; } = new DocumentInfoModel()
    {
        DocumentTypeID = 118,
        DocumentName = "AutoSettle"
    };

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();
        if (id != null && _collection != null && _collection.Any(g => g.AutoSettleID == id))
        {
            await OpenForm(_collection.FirstOrDefault(s => s.AutoSettleID == id), true);
        }
    }
  
    protected override async Task OpenForm(AutoSettleModel _model, bool ReadOnly, bool DisableAddition = false)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        _busy = true;
        DialogOptions largeWidth = new DialogOptions() { MaxWidth = MaxWidth.Large, FullWidth = true };
        DialogParameters parms = new DialogParameters();
        parms.Add("model", _model.Clone());
        parms.Add("PageToRedirectLink", "/AutoSettleView");
        parms.Add("ReadOnly", ReadOnly);
        var dialog = await dialogService.ShowAsync<AutoSettleDialog>(_model == null ? "ADD" : "EDIT", parms, largeWidth);
        var result = await dialog.Result;
        var isCancelled = result.Canceled;
        if (!isCancelled)
        {
            var ReturnData = (AutoSettleModel)result.Data;
            await _table.ReloadServerData();
        }
        
        await Task.Delay(200);
        _busy = false;
    }   
}
