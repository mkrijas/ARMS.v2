@inject IPaymentService Iservice
@using ArmsModels.BaseModels.Finance.Transactions
@inject MudBlazor.ISnackbar snackbar
@inject AuthenticationStateProvider auth
@attribute [Authorize]
@inject IDialogService DialogService

<MudDialog>
    <TitleContent>
        @if (Dialog)
        {
            <MudText Typo="Typo.h6">
                <MudIcon Icon="@Icons.Material.Filled.Build" Class="mr-3 mb-n1" />
                Initiate Payment
            </MudText>
        }
    </TitleContent>
    <DialogContent>
        <MudContainer Style="min-height:100px;">
            <EditForm id="InitiatePaymentForm" Model="@PI" OnValidSubmit="OnValidSubmit">
                <ObjectGraphDataAnnotationsValidator />
                <ValidationSummary />
                <MudGrid>
                    <MudItem xs="12" md="6">
                        <MudTextField Disabled @bind-Value="PI.PartyInfo.TradeName" Label="Party" Variant="Variant.Outlined" Margin="Margin.Dense"></MudTextField>
                     </MudItem>
                     <MudItem xs="12" md="6">
                         <MudTextField Disabled @bind-Value="PI.TotalAmount" Label="Amount" Variant="Variant.Outlined" Margin="Margin.Dense"></MudTextField>
                     </MudItem>
                     <MudItem xs="12" md="6">
                         <MudDatePicker Label="Document Date" Variant="Variant.Outlined" Margin="Margin.Dense" DisableToolbar="true" Editable="true" @bind-Date="PI.InitiatedDocumentDate" DateFormat="dd/MM/yyyy" />
                     </MudItem>
                     <MudItem xs="12" md="6">
                         <MudDatePicker Label="Due On" Variant="Variant.Outlined" Margin="Margin.Dense" DisableToolbar="true" Editable="true" @bind-Date="PI.DueOn" DateFormat="dd/MM/yyyy" />
                     </MudItem>
                 </MudGrid>
             </EditForm>
         </MudContainer>
     </DialogContent>
     <DialogActions>
         @if (Dialog)
        {
            <MudButton Disabled="_busy" form="InitiatePaymentForm" Variant="Variant.Filled" Color="Color.Success" ButtonType="ButtonType.Submit">Initiate Payment</MudButton>
        }
    </DialogActions>
</MudDialog>

@code {

    [Parameter]
    public PaymentInitiatedModel PI { get; set; }
    [CascadingParameter] MudDialogInstance MudDialog { get; set; }
    [Parameter]
    public bool Dialog { get; set; } = true;

    private bool _busy;

    private async void OnValidSubmit(EditContext context)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is being submitted!", Severity.Warning);
            return;
        }
        _busy = true;

        MudDialog.Close(PI);

        await Task.Delay(2000);
        _busy = false;
    }
}