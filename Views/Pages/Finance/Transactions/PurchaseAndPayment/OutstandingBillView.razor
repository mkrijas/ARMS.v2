@inject IOutstandingBillsService Iservice
@inject MudBlazor.ISnackbar snackbar
@inject AuthenticationStateProvider auth
@attribute [Authorize]
@inject IDialogService DialogService

<MudDialog>
    <DialogContent>
        <MudTable Items="@collection" MultiSelection="true" @bind-SelectedItems="selectedItems" Dense="true" Hover="true" Striped="true" Elevation="0">
            <ToolBarContent>
                <MudSpacer></MudSpacer>
                @* <MudTextField @bind-Value="searchBills" Placeholder="Search... " Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0"></MudTextField> *@
                <MudTextField @bind-Value="searchTerm" Placeholder="Search..." Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0" @onkeyup="HandleSearchKeyUp"></MudTextField>
            </ToolBarContent>
            <HeaderContent>
                <MudTh><MudTableSortLabel SortBy="new Func<OutstandingBillsModel, object>(x=> x.DocumentDate)" InitialDirection="SortDirection.Ascending">Doc Date</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<OutstandingBillsModel, object>(x=> x.DocumentNumber)" InitialDirection="SortDirection.Ascending">Doc Number</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<OutstandingBillsModel, object>(x=> x.BranchName)" InitialDirection="SortDirection.Ascending">Branch Name</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<OutstandingBillsModel, object>(x=> x.ReferenceDocDate)" InitialDirection="SortDirection.Ascending">Reference Details</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<OutstandingBillsModel, object>(x=> x.OutstandingAmount)" InitialDirection="SortDirection.Ascending">Outstanding Amount</MudTableSortLabel></MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="EntryDate">@context.DocumentDate?.ToShortDateString()</MudTd>
                <MudTd DataLabel="DocNumber">@context.DocumentNumber</MudTd>
                <MudTd DataLabel="BranchName">@context.BranchName</MudTd>
                <MudTd DataLabel="InvoiceDate"> @context.ReferenceDocNo-@context.ReferenceDocDate?.ToShortDateString()</MudTd>
                <MudTd DataLabel="OutstandingAmount">@context.OutstandingAmountDisplayText</MudTd>
            </RowTemplate>
        </MudTable>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton OnClick="Submit" Variant="Variant.Filled" Color="Color.Success" ButtonType="ButtonType.Submit">Submit</MudButton>
    </DialogActions>
</MudDialog>

@code {

    [Parameter]
    public int PartyID { get; set; }
    [Parameter]
    public int BranchID { get; set; }
    [CascadingParameter] MudDialogInstance MudDialog { get; set; }
    private HashSet<OutstandingBillsModel> selectedItems = new HashSet<OutstandingBillsModel>();
    private List<OutstandingBillsModel> collection = new List<OutstandingBillsModel>();
    private string searchTerm = "";
    private int numberOfRecords = 100;

    private int NumberOfRecords
    {
        get => numberOfRecords;
        set
        {
            if (numberOfRecords != value)
            {
                numberOfRecords = value;
                _ = ReloadTable();
            }
        }
    }

    // Lifecycle method called when the component is initialized
    protected override async Task OnInitializedAsync()
    {
        await GetAll(NumberOfRecords);
    }

    private async Task HandleSearchKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await ReloadTable();
        }
    }

    private async Task ReloadTable()
    {
        await GetAll(NumberOfRecords);
    }


    // Method to retrieve all outstanding bills for the specified party and branch
    private async Task GetAll(int numberOfRecords)
    {
        // Fetch outstanding bills from the service based on PartyID and BranchID
        collection = Iservice.SelectByParty(PartyID, BranchID, NumberOfRecords, searchTerm).ToList();
    }

    // Method to cancel the dialog
    private void Cancel() => MudDialog.Cancel();

    // Method to submit the selected items and close the dialog
    private void Submit() => MudDialog.Close(selectedItems.ToList());

}