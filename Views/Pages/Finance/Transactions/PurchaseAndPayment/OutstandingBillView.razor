@inject IOutstandingBillsService Iservice
@inject MudBlazor.ISnackbar snackbar

@inject AuthenticationStateProvider auth
@attribute [Authorize]
@inject IDialogService DialogService




<MudDialog>
    <DialogContent>
        <MudGrid Spacing="4">
            <MudItem xs="12">
                <MudTable Items="@collection" MultiSelection="true" @bind-SelectedItems="selectedItems1" Dense="true" Hover="true" Striped="true" Elevation="0" @bind-place="model">



                    <HeaderContent>
                        <MudTh><MudTableSortLabel SortBy="new Func<OutstandingBillsModel, object>(x=> x.DocumentDate)" InitialDirection="SortDirection.Ascending">DocDate</MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<OutstandingBillsModel, object>(x=> x.DocumentNumber)" InitialDirection="SortDirection.Ascending">DocNumber</MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<OutstandingBillsModel, object>(x=> x.BranchName)" InitialDirection="SortDirection.Ascending">BranchName</MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<OutstandingBillsModel, object>(x=> x.ReferenceDocDate)" InitialDirection="SortDirection.Ascending">Reference Details</MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<OutstandingBillsModel, object>(x=> x.OutstandingAmount)" InitialDirection="SortDirection.Ascending">OutstandingAmount</MudTableSortLabel></MudTh>



                    </HeaderContent>
                    <RowTemplate>

                        <MudTd DataLabel="EntryDate">@context.DocumentDate?.ToShortDateString()</MudTd>
                        <MudTd DataLabel="DocNumber">@context.DocumentNumber</MudTd>
                        <MudTd DataLabel="BranchName">@context.BranchName</MudTd>
                        <MudTd DataLabel="InvoiceDate"> @context.ReferenceDocNo-@context.ReferenceDocDate?.ToShortDateString()</MudTd>
                        <MudTd DataLabel="OutstandingAmount">@context.OutstandingAmount</MudTd>

                    </RowTemplate>
                    <PagerContent>
                        <MudTablePager PageSizeOptions="new int[] { 5, 10, 20, 50, 100 }" />
                    </PagerContent>
                </MudTable>
            </MudItem>
        </MudGrid>
    </DialogContent>
    <DialogActions>

        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton OnClick="selected" Variant="Variant.Filled" Color="Color.Success" ButtonType="ButtonType.Submit">Submit</MudButton>

    </DialogActions>
</MudDialog>

@code {
    [Parameter]
    public int PartyID { get; set; }
    [Parameter]
    public int BranchID { get; set; }

    private OutstandingBillsModel model = new OutstandingBillsModel();
    [CascadingParameter] MudDialogInstance MudDialog { get; set; }
    private HashSet<OutstandingBillsModel> selectedItems1 = new HashSet<OutstandingBillsModel>();
    private List<OutstandingBillsModel> collection = new List<OutstandingBillsModel>();

    protected override void OnInitialized()
    {

        GetAll();
        model = new();
    }
    private void GetAll()
    {


        collection = Iservice.SelectByParty(PartyID, BranchID).ToList();
    }

    private void OnValidSubmit(EditContext context)
    {

        MudDialog.Close();
    }
    private void Cancel()
    {
        MudDialog.Cancel();
    }
    private void selected()
    {
        List<OutstandingBillsModel> selecteditem = new List<OutstandingBillsModel>();

        selecteditem = selectedItems1.ToList();
        MudDialog.Close(selecteditem);

    }


}
