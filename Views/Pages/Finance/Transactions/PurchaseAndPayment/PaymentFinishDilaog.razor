@inject IDialogService DialogService
@using System.Globalization


<DialogForm @ref="@dialogForm" ReadOnly="@ReadOnly" Title="Payment"  formID="PaymentForm" model="@model" >
    <FormContent>
         <MudPaper Class="p-3" >
            <EditForm id="PaymentForm"  OnValidSubmit="OnValidSubmit" EditContext="@editContext">   
                  <ObjectGraphDataAnnotationsValidator />
                   <ValidationSummary />
                    <MudGrid>
                            <MudItem xs="12" md="6">
                                <MudTextField Disabled @bind-Value="model.PartyInfo.TradeName" Label="Party" Variant="Variant.Outlined" Margin="Margin.Dense"></MudTextField>
                            </MudItem>
                            <MudItem xs="12" md="6">
                                <MudTextField Disabled @bind-Value="model.TotalAmount" Label="Amount" Variant="Variant.Outlined" Margin="Margin.Dense"></MudTextField>
                            </MudItem>
                            <MudItem xs="12" md="6">
                                <MudDatePicker Disabled Label="Initiated On" Variant="Variant.Outlined" Margin="Margin.Dense" DisableToolbar="true" Editable="true" @bind-Date="model.InitiatedDocumentDate" DateFormat="dd/MM/yyyy" />
                            </MudItem>
                            <MudItem xs="12" md="6">
                                <MudDatePicker Disabled Label="Due On" Variant="Variant.Outlined" Margin="Margin.Dense" DisableToolbar="true" Editable="true" @bind-Date="model.DueOn" DateFormat="dd/MM/yyyy" />
                            </MudItem>
                            <MudItem xs="6" md="6">
                                <MudDatePicker @bind-Date="model.DocumentDate" ReadOnly="ReadOnly" DisableToolbar="true" Editable="true" DateFormat="dd/MM/yyyy" Label="DocumentDate" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.DocumentDate)"></MudDatePicker>

                            </MudItem>
                        <MudItem xs="12" md="12">
                            <PaymentAccountSelector @bind-PaymentMode="@model.PaymentMode"
                                                    @bind-ArdCode="@model.PaymentArdCode" @bind-CoaID="@model.PaymentCoaID"
                                                BankCharges="@model.BankCharges" BankChargesChanged="BankChargesChanged" @bind-BankTool="@model.PaymentTool" />
                        </MudItem> 
                        <MudItem xs="12" md="12">
                            <MudTextField @bind-Value="model.Narration" ReadOnly="ReadOnly" Lines="2" Label="Narration" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.Narration)"></MudTextField>

                        </MudItem>                        
                    </MudGrid>
        </EditForm>
  </MudPaper>
  </FormContent>
  <VerificationStatus>
        <AutherizationStatusComponent DocTypeID="@DocTypeID" DocumentID="model.PaymentFinalizeID" OnApprove="Approve"></AutherizationStatusComponent>
</VerificationStatus>
  </DialogForm>

        

