    protected override async Task OnInitializedAsync()
    {
        var authprov = await auth.GetAuthenticationStateAsync();
        var User = authprov.User;
        branchID = int.Parse(User.Claims.First(x => x.Type == "BranchID").Value);
        UserID = User.Identity.Name;
        model.BranchID = branchID;
        model.DocumentDate = DateTime.Today;        
        //GetPaymentEntryDetails();
    }

     protected override void OnParametersSet()
    {
        editContext = new EditContext(model);        
    }


    public async Task GetPaymentEntryDetails()
    {
        var authprov = await auth.GetAuthenticationStateAsync();
        var brancIDString = authprov.User.Claims.First(x => x.Type == "BranchID").Value;
        int brancID = int.Parse(brancIDString);
        int NumberOfRecords = numberOfRecords;
        List<PaymentMemoModel> ppmm = new List<PaymentMemoModel>();

        List<PaymentFinishModel> pfm = new List<PaymentFinishModel>();
        if (model.PaymentFinalizeID != null)
        {
            pfm = Iservice.Select(brancID, model.PaymentFinalizeID, NumberOfRecords, searchTerm).ToList();
            foreach (var item in pfm)
            {
                PaymentFinishModel f = new ();
                model.DocumentDate = item.DocumentDate;               
                model.Narration = item.Narration;
            }
        }
    }
    private void OnValidSubmit(EditContext context)
    {            
        model.UserInfo.UserID = UserID;
        Iservice.Update(model);
        snackbar.Add("Saved Successfully", Severity.Success);
        dialogForm.Close(model);
    }    
   
    protected async Task Approve(DataApprovedStatus aprvd)
    {
        if (aprvd.IsApprove)
        {
            try
            {
                var authprov = await auth.GetAuthenticationStateAsync();
                var user = authprov.User;
                model.UserInfo.UserID = user.Identity.Name;
                Iservice.Approve(model.PaymentFinalizeID, model.UserInfo.UserID, aprvd.Remarks);
                snackbar.Add("Approved Successfully", Severity.Success);                
            }
            catch (Exception ex)
            {
                snackbar.Add(ex.Message, Severity.Error);
            }
        }

    }
