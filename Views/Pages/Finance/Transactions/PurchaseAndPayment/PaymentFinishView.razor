@page "/PaymentsListView"
@page "/PaymentsListView/{id:int}"
@using System.Threading;
@inject IPaymentFinalizeService Iservice
@inject IPaymentService ImemoService
@inject MudBlazor.ISnackbar snackbar
@inject AuthenticationStateProvider auth
@inject IRoleService<RoleModel> Irole
@attribute [Authorize]
@inject IDialogService DialogService
@inject SignalRService signalRService
@inject IPushNotificationService IpushNotificationService

@if (_isLoading)
{
    <div @key="@("loader")" style="position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(255,255,255,0.9); z-index: 9999; display: flex; justify-content: center; align-items: center;">
        <LoaderComponent IsFullScreen="true" 
                        ShowLogo="false" 
                        Size="medium" 
                        LoadingText="Loading Completed Payments" 
                        SubText="Please wait..." />
    </div>
}
else
{
    <div @key="@("content")">
<div class="fade-in">
    <div class="admin-header-tiered mb-6">
        <div class="d-flex align-center justify-space-between">
            <div>
                <MudText Typo="Typo.h4" Class="admin-title">Completed Payments</MudText>
                <MudText Typo="Typo.body2" Class="admin-subtitle">View and audit finalized payment transactions. Access historical records and reversal history for completed financial batches.</MudText>
            </div>
        </div>
    </div>

    <div class="admin-glass-card mb-6 pa-4">
        <div class="d-flex align-center gap-4 flex-wrap">
            <div style="flex-grow: 1; min-width: 300px;">
                <MudTextField @bind-Value="searchTerm" Placeholder="Search by document number or mode..." Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" Variant="Variant.Outlined" Margin="Margin.Dense" Class="admin-input-group" Clearable="true" OnKeyUp="HandleSearchKeyUp" />
            </div>
            <div class="d-flex align-center gap-4">
                <MudTextField @bind-Value="@NumberOfRecords" Label="Max Records" Variant="Variant.Outlined" Margin="Margin.Dense" Style="width: 100px;" Dense="true" />
            </div>
        </div>
    </div>

    <div class="admin-glass-card pa-0 overflow-hidden">
        <MudTable Items="@collection" Elevation="0" Class="modern-admin-table" Hover="true">
            <HeaderContent>
                <MudTh><MudTableSortLabel SortBy="new Func<PaymentFinishModel, object>(x=> x.DocumentDate)" InitialDirection="SortDirection.Ascending"><span class="admin-header-text">DATE</span></MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<PaymentFinishModel, object>(x=> x.DocumentNumber)" InitialDirection="SortDirection.Ascending"><span class="admin-header-text">DOC NUMBER</span></MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<PaymentFinishModel, object>(x=> x.PaymentMode)" InitialDirection="SortDirection.Ascending"><span class="admin-header-text">PAYMENT MODE</span></MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<PaymentFinishModel, object>(x=> x.TotalAmount)" InitialDirection="SortDirection.Ascending"><span class="admin-header-text">TOTAL AMOUNT</span></MudTableSortLabel></MudTh>
                <MudTh Style="text-align: right;"><span class="admin-header-text">ACTIONS</span></MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Date">@context.DocumentDate?.ToString("dd MMM yyyy")</MudTd>
                <MudTd DataLabel="DocNumber"><span class="admin-td-primary fw-700">@context.DocumentNumber</span></MudTd>
                <MudTd DataLabel="PaymentMode">
                    <div class="d-flex align-center gap-2">
                        <span class="fw-600">@context.PaymentMode</span>
                        <MudText Typo="Typo.caption" Alpha="0.6">(@context.PaymentTool)</MudText>
                    </div>
                </MudTd>
                <MudTd DataLabel="Amount">
                    <MudChip T="string" Size="Size.Small" Color="Color.Success" Variant="Variant.Text" Class="fw-700">@context.TotalAmount?.ToString("N2")</MudChip>
                </MudTd>
                <MudTd DataLabel="Actions" Style="text-align: right;">
                    @if (@context.AuthLevelId == 99)
                    {
                        <EntryReversedComponent DocTypeID="DocTypeID" DocumentID="context.PaymentFinalizeID" MID="context.MID" DocumentNumber="@context.DocumentNumber"></EntryReversedComponent>
                    }

                    <MudTooltip Text="View Details">
                        <MudIconButton OnClick="@(()=> View(context))" Color="Color.Info" Icon="@Icons.Material.Filled.Visibility" Size="Size.Small" Variant="Variant.Text" />
                    </MudTooltip>

                    <MudTooltip Text="Print Payment Proof">
                        <MudIconButton OnClick="@(()=> Print(context.PaymentInitiatedID))" Color="Color.Tertiary" Icon="@Icons.Material.Filled.Print" Size="Size.Small" Variant="Variant.Text" />
                    </MudTooltip>
                </MudTd>
            </RowTemplate>
            <PagerContent>
                <div class="pa-4">
                    <MudTablePager PageSizeOptions="new int[] { 10, 20, 50, 100 }" />
                </div>
            </PagerContent>
        </MudTable>
    </div>
</div>
    </div>
}

@code {

    private bool _isLoading = true;
    private DateTime _loadStartTime;

    private List<PaymentFinishModel> collection = new List<PaymentFinishModel>();
    DialogOptions maxWidth = new DialogOptions() { MaxWidth = MaxWidth.Large, FullWidth = true, CloseOnEscapeKey = true };
    private int numberOfRecords = 100;
    private string searchTerm = "";
    int BranchID; string UserID;

    [Parameter]
    public int? id { get; set; } = null;
