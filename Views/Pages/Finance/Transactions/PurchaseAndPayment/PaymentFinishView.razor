    private int NumberOfRecords
    {
        get => numberOfRecords;
        set
        {
            if (numberOfRecords != value)
            {
                numberOfRecords = value;
                ReloadTable();
            }
        }
    }

    private async Task HandleSearchKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            ReloadTable();
        }
    }

    private void ReloadTable()
    {
        GetAll(NumberOfRecords);
    }

    protected override async Task OnInitializedAsync()
    {
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasAuthoriseDelete = await Irole.HasClaim(DocTypeID.ToString(), "Delete", ctc.Token);

        var authprov = await auth.GetAuthenticationStateAsync();
        BranchID = int.Parse(authprov.User.Claims.First(x => x.Type == "BranchID").Value);
        UserID = authprov.User.Identity.Name;
        GetAll(NumberOfRecords);
        await Task.Delay(200);
        await signalRService.StartAsync();
        //if (id != null && collection != null && collection.Any(g => g.PaymentFinalizeID == id))
        //{
        //    await OpenDialog(collection.FirstOrDefault(s => s.PaymentFinalizeID == id), true);
        //}
    }

    private void GetAll(int numberOfRecords)
    {
        int NumberOfRecords = numberOfRecords;
        collection = Iservice.Select(BranchID, null, NumberOfRecords, searchTerm).ToList();
    }

    public async Task Delete(PaymentFinishModel pi)
    {
        if (HasAuthoriseDelete)
        {
            //Iservice.Delete(pi.PaymentInitiatedID, UserID);
            GetAll(NumberOfRecords);
        }
        else
        {
            bool? result = await DialogService.ShowMessageBox(
                "Permission denied!",
                "You dont have any permission to delete.");
        }
    }

    public async void View(PaymentFinishModel model)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        _busy = true;
        model.SelectedMemos =  ImemoService.SelectInitiated(model.PaymentInitiatedID).ToList();
        DialogParameters parms = new DialogParameters();
        parms.Add("model", model.Clone());
        parms.Add("ReadOnly", true);
        parms.Add("PageToRedirectLink", "/PaymentsListView");
        var dialog = DialogService.Show<PaymentFinishDilaog>("Payment", parms, maxWidth);
        await Task.Delay(200);
        _busy = false;
    }

