    private int NumberOfRecords
    {
        get => numberOfRecords;
        set
        {
            if (numberOfRecords != value)
            {
                numberOfRecords = value;
                ReloadTable();
            }
        }
    }

    private async Task HandleSearchKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            ReloadTable();
        }
    }

    // Method to reload the payment finish table
    private void ReloadTable()
    {
        GetAll(NumberOfRecords);
    }

    // Lifecycle method called when the component is initialized
    protected override async Task OnInitializedAsync()
    {
        _loadStartTime = DateTime.Now;
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasAuthoriseDelete = await Irole.HasClaim(DocTypeID.ToString(), "Delete", ctc.Token);

        var authprov = await auth.GetAuthenticationStateAsync();
        BranchID = int.Parse(authprov.User.Claims.First(x => x.Type == "BranchID").Value);
        UserID = authprov.User.Identity.Name;
        GetAll(NumberOfRecords);
        await Task.Delay(200);
        await signalRService.StartAsync();
        //if (id != null && collection != null && collection.Any(g => g.PaymentFinalizeID == id))
        //{
        //    await OpenDialog(collection.FirstOrDefault(s => s.PaymentFinalizeID == id), true);
        //}
        await EnsureMinimumLoadTime();
        _isLoading = false;
    }

    private async Task EnsureMinimumLoadTime()
    {
        var elapsed = (DateTime.Now - _loadStartTime).TotalMilliseconds;
        if (elapsed < 100)
        {
            await Task.Delay(100 - (int)elapsed);
        }
    }

    // Method to retrieve all payment finishes based on the number of records
    private void GetAll(int numberOfRecords)
    {
        int NumberOfRecords = numberOfRecords;
        collection = Iservice.Select(BranchID, null, NumberOfRecords, searchTerm).ToList(); // Fetch payment finishes from the service
    }

    // Method to delete a payment finish
    public async Task Delete(PaymentFinishModel pi)
    {
        if (HasAuthoriseDelete)
        {
            //Iservice.Delete(pi.PaymentInitiatedID, UserID);
            GetAll(NumberOfRecords);
        }
        else
        {
            bool? result = await DialogService.ShowMessageBoxAsync(
                "Permission denied!",
                "You don't have any permission to delete.");
        }
    }

    // Method to open a payment memo dialog
    public async void View(PaymentFinishModel model)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        _busy = true;
        model.SelectedMemos =  ImemoService.SelectInitiated(model.PaymentInitiatedID).ToList();
        DialogParameters parms = new DialogParameters();
        parms.Add("model", model.Clone());
        parms.Add("ReadOnly", true);
        parms.Add("PageToRedirectLink", "/PaymentsListView");
        var dialog = await DialogService.ShowAsync<PaymentFinishDilaog>("Payment", parms, maxWidth);
        await Task.Delay(200);
        _busy = false;
    }

