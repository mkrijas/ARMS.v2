@page "/PaymentsListView"
@inject IPaymentFinalizeService Iservice
@inject IPaymentService ImemoService
@inject MudBlazor.ISnackbar snackbar
@inject AuthenticationStateProvider auth
@attribute [Authorize]
@inject IDialogService DialogService


<MudGrid Spacing="4">
    <MudItem xs="12">
        <MudTable Items="@collection" Dense="true" Hover="true" Striped="true" Elevation="10">
            <ToolBarContent>
                <MudText Typo="Typo.h6">Completed Payments</MudText>               
                <MudSpacer></MudSpacer>
                <MudTextField @bind-Value="searchTerm" Placeholder="Search Payments..." Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0"
                              @onkeyup="HandleSearchKeyUp">
                </MudTextField>
                <div class="tablefont">
                    <span style="margin-right: 10px;">Maximum Records: </span>
                </div>
                <MudItem xs="1">
                    <MudTextField @bind-Value="@NumberOfRecords" Variant="Variant.Outlined" Margin="Margin.Dense" Class="padding5" Style="width: 80px;"></MudTextField>
                </MudItem>
            </ToolBarContent>
            <HeaderContent>
                <MudTh><MudTableSortLabel SortBy="new Func<PaymentInitiatedModel, object>(x=> x.DocumentDate)" InitialDirection="SortDirection.Ascending">Date</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<PaymentInitiatedModel, object>(x=> x.DocumentNumber)" InitialDirection="SortDirection.Ascending">Document Number</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<PaymentInitiatedModel, object>(x=> x.PartyInfo.TradeName)" InitialDirection="SortDirection.Ascending">Party</MudTableSortLabel></MudTh>                
                <MudTh><MudTableSortLabel SortBy="new Func<PaymentInitiatedModel, object>(x=> x.TotalAmount)" InitialDirection="SortDirection.Ascending">TotalAmount</MudTableSortLabel></MudTh>
                <MudTh>Actions</MudTh>
            </HeaderContent>
            <RowTemplate>
                 <MudTd DataLabel="PaymentStatus">@context.DocumentDate?.ToShortDateString()</MudTd>
                <MudTd DataLabel="PaymentMemoID">@context.DocumentNumber</MudTd>
                <MudTd DataLabel="PaymentStatus">@context.PartyInfo?.TradeName</MudTd>               
                <MudTd DataLabel="PaymentMemoID">@context.TotalAmount</MudTd>
                <MudTd DataLabel="">
                    <MudTooltip Text="View">
                        <MudFab @onclick="@(()=> View(context))" Color="Color.Primary" Title="View" Icon="@Icons.Material.Filled.Fullscreen" Size="Size.Small" IconSize="Size.Small" />
                    </MudTooltip>
                    <MudTooltip Text="Delete">
                        <MudFab @onclick="@(()=> Delete(context))" Color="Color.Error" Icon="@Icons.Material.Filled.MoveDown" Size="Size.Small" IconSize="Size.Small" />
                    </MudTooltip>
                   @* <MudTooltip Text="Payment">
                        <MudFab @onclick="@(()=> OpenDialog(context,false))" Color="Color.Success" Icon="@Icons.Material.Filled.Check" Size="Size.Small" IconSize="Size.Small" />
                    </MudTooltip>*@
                </MudTd>
            </RowTemplate>
            <PagerContent>
                <MudTablePager PageSizeOptions="new int[] { 5, 10, 20, 50, 100 }" />
            </PagerContent>
        </MudTable>
    </MudItem>
</MudGrid>



@code {

    private List<PaymentFinishModel> collection = new List<PaymentFinishModel>();
    DialogOptions maxWidth = new DialogOptions() { MaxWidth = MaxWidth.Large, FullWidth = true, CloseOnEscapeKey = true };

    private int numberOfRecords = 100;
    private string searchTerm = "";

    int BranchID; string UserID;

    private int NumberOfRecords
    {
        get => numberOfRecords;
        set
        {
            if (numberOfRecords != value)
            {
                numberOfRecords = value;
                _ = ReloadTable();
            }
        }
    }

    private async Task HandleSearchKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await ReloadTable();
        }
    }

    private async Task ReloadTable()
    {
        GetAll(NumberOfRecords);
    }

    protected override async Task OnInitializedAsync()
    {
        var authprov = await auth.GetAuthenticationStateAsync();
        BranchID = int.Parse(authprov.User.Claims.First(x => x.Type == "BranchID").Value);
        UserID = authprov.User.Identity.Name;
        GetAll(NumberOfRecords);
    }

    private void GetAll(int numberOfRecords)
    {
        int NumberOfRecords = numberOfRecords;
        collection = Iservice.Select(BranchID, null, NumberOfRecords, searchTerm).ToList();
    }


    void Delete(PaymentFinishModel pi)
    {
        //Iservice.Delete(pi.PaymentInitiatedID, UserID);
        GetAll(NumberOfRecords);
    }


    public void View(PaymentFinishModel model)
    {
        DialogParameters parms = new DialogParameters();
        parms.Add("model", model);
        parms.Add("ReadOnly", true);
        var dialog = DialogService.Show<PaymentFinishDilaog>("Payment", parms, maxWidth);
    }




    private async Task OpenDialog(PaymentFinishModel tds, bool ReadOnly)
    {
        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;       
        PaymentFinishModel pfm = new PaymentFinishModel(ImemoService.SelectByID(tds.PaymentMemoID));
        pfm.PaymentInitiatedID = tds.PaymentInitiatedID;
        pfm.InitiatedDocumentDate = tds.InitiatedDocumentDate;
        pfm.DueOn = tds.DueOn;
        pfm.UserInfo = tds.UserInfo;

        DialogParameters parms = new DialogParameters();
        parms.Add("model", pfm);
        parms.Add("ReadOnly", ReadOnly);
        var dialog = DialogService.Show<PaymentFinishDilaog>("Payment", parms, maxWidth);
        var result = await dialog.Result;
        if (!result.Canceled)
        {
            GetAll(NumberOfRecords);
        }
    }
}
