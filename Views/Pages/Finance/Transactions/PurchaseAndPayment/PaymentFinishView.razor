@page "/PaymentsListView"
@page "/PaymentsListView/{id:int}"
@using System.Threading;
@inject IPaymentFinalizeService Iservice
@inject IPaymentService ImemoService
@inherits ViewComponentBase<PaymentFinishModel>


<div @key="@("content")">
    <div class="fade-in">
        <div class="admin-header-tiered mb-6">
            <div class="d-flex align-center justify-space-between">
                <div>
                    <MudText Typo="Typo.h4" Class="admin-title">Completed Payments</MudText>
                    <MudText Typo="Typo.body2" Class="admin-subtitle">View and audit finalized payment transactions. Access historical records and reversal history for completed financial batches.</MudText>
                </div>
            </div>
        </div>
        <div class="admin-glass-card mb-6 pa-4">
            <div class="d-flex align-center gap-4 flex-wrap">
                <div style="flex-grow: 1; min-width: 300px;">
                    <MudTextField @bind-Value="searchTerm" Placeholder="Search by document number or mode..." Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" Variant="Variant.Outlined" Margin="Margin.Dense" Class="admin-input-group" Clearable="true" OnKeyUp="HandleSearchKeyUp" />
                </div>              
            </div>
        </div>
        <div class="admin-glass-card pa-0 overflow-hidden">
            <MudTable ServerData="LoadServerData" T="PaymentFinishModel" @ref="_table" Elevation="0" Class="modern-admin-table" Hover="true">
                <LoadingContent>
                    <div @key="@("loader")" style="display: flex; justify-content: center; align-items: center; min-height: 400px;">
                        <LoaderComponent IsFullScreen="false"
                                         ShowLogo="false"
                                         Size="large"
                                         LoadingText="Loading...."
                                         SubText="Fetching Data..." />
                    </div>
                </LoadingContent>
                <HeaderContent>
                    <MudTh><MudTableSortLabel SortBy="new Func<PaymentFinishModel, object>(x => x.DocumentDate)" InitialDirection="SortDirection.Ascending"><span class="admin-header-text">DATE</span></MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<PaymentFinishModel, object>(x => x.DocumentNumber)" InitialDirection="SortDirection.Ascending"><span class="admin-header-text">DOC NUMBER</span></MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<PaymentFinishModel, object>(x => x.PaymentMode)" InitialDirection="SortDirection.Ascending"><span class="admin-header-text">PAYMENT MODE</span></MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<PaymentFinishModel, object>(x => x.TotalAmount)" InitialDirection="SortDirection.Ascending"><span class="admin-header-text">TOTAL AMOUNT</span></MudTableSortLabel></MudTh>
                    <MudTh Style="text-align: right;"><span class="admin-header-text">ACTIONS</span></MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Date">@context.DocumentDate?.ToString("dd MMM yyyy")</MudTd>
                    <MudTd DataLabel="DocNumber"><span class="admin-td-primary fw-700">@context.DocumentNumber</span></MudTd>
                    <MudTd DataLabel="PaymentMode">
                        <div class="d-flex align-center gap-2">
                            <span class="fw-600">@context.PaymentMode</span>
                            <MudText Typo="Typo.caption" Alpha="0.6">(@context.PaymentTool)</MudText>
                        </div>
                    </MudTd>
                    <MudTd DataLabel="Amount">
                        <MudChip T="string" Size="Size.Small" Color="Color.Success" Variant="Variant.Text" Class="fw-700">@context.TotalAmount?.ToString("N2")</MudChip>
                    </MudTd>
                    <MudTd DataLabel="Actions" Style="text-align: right;">
                        @if (@context.AuthLevelId == 99)
                        {
                            <EntryReversedComponent DocTypeID="@DocInfo.DocumentTypeID" DocumentID="context.PaymentFinalizeID" MID="context.MID" DocumentNumber="@context.DocumentNumber"></EntryReversedComponent>
                        }

                        <MudTooltip Text="View Details">
                            <MudIconButton OnClick="@(() => OpenForm(context))" Color="Color.Info" Icon="@Icons.Material.Filled.Visibility" Size="Size.Small" Variant="Variant.Text" />
                        </MudTooltip>

                        <MudTooltip Text="Print Payment Proof">
                            <MudIconButton OnClick="@(() => Print(context.PaymentInitiatedID))" Color="Color.Tertiary" Icon="@Icons.Material.Filled.Print" Size="Size.Small" Variant="Variant.Text" />
                        </MudTooltip>
                    </MudTd>
                </RowTemplate>
                <PagerContent>
                    <div class="pa-4">
                        <MudTablePager PageSizeOptions="new int[] { 10, 20, 50, 100 }" />
                    </div>
                </PagerContent>
            </MudTable>
        </div>
    </div>
</div>

@code {

    protected override List<PaymentFinishModel> _collection { get; set; } = new List<PaymentFinishModel>();

    protected override DocumentInfoModel DocInfo { get; set; } = new DocumentInfoModel()
    {
        DocumentTypeID = 8,
        DocumentName = "Payments"
    };


    // Lifecycle method called when the component is initialized
    protected override async Task OnInitializedAsync()
    {
        ShowApproved = true;
        await base.OnInitializedAsync();
        if (id != null && _collection != null && _collection.Any(g => g.PaymentFinalizeID == id))
        {
            await OpenForm(_collection.FirstOrDefault(s => s.PaymentFinalizeID == id), true);
        }
        
    }


    protected override async Task OpenForm(PaymentFinishModel _model, bool ReadOnly = true, bool DisableAddition = false)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        _busy = true;
        DialogParameters parms = new DialogParameters();
        parms.Add("model", _model);        
        parms.Add("ReadOnly", ReadOnly);       
        var dialog = await dialogService.ShowAsync<PaymentFinishDilaog>("View", parms, new DialogOptions() { MaxWidth = MaxWidth.Large, FullWidth = true });
        var result = await dialog.Result;
        if (!result.Canceled)
        {
            var ReturnData = (TaxPurchaseModel)result.Data;
            await _table.ReloadServerData();
        }
        await Task.Delay(200);
        _busy = false;
    }   

    // Method to print the payment memo
    private async Task Print(int? ID)
    {
        Dictionary<string, string> ReportParameters = new();
        ReportParameters.Add("ID", ID.ToString());
        ReportParameters.Add("Operation", "Initiated");
        var parameters = new DialogParameters();
        parameters.Add("Parameters", ReportParameters); // Add the dictionary as a parameter
        parameters.Add("ReportName", "PrintPaymentMemo");

        DialogOptions maxWidth = new DialogOptions() { MaxWidth = MaxWidth.Medium, FullWidth = true };
        var result = await dialogService.ShowAsync<PrintDialog>("PRINT", parameters, maxWidth);
    }
}
