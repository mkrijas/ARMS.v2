@page "/InitiatePayment"
@using System.Threading;
@inject IPaymentInitiatedService Iservice
@inject IPaymentService ImemoService
@inject MudBlazor.ISnackbar snackbar
@inject AuthenticationStateProvider auth
@inject IRoleService<RoleModel> Irole
@attribute [Authorize]
@inject IDialogService DialogService

@if (_isLoading)
{
    <div @key="@("loader")" style="display: flex; justify-content: center; align-items: center; min-height: 400px;">
        <LoaderComponent IsFullScreen="true" 
                        ShowLogo="false" 
                        Size="medium" 
                        LoadingText="Loading Initiated Payments" 
                        SubText="Please wait..." />
    </div>
}
else
{
    <div @key="@("content")">
<div class="fade-in">
    <div class="admin-header-tiered mb-6">
        <div class="d-flex align-center justify-space-between">
            <div>
                <MudText Typo="Typo.h4" Class="admin-title">Initiated Payments</MudText>
                <MudText Typo="Typo.body2" Class="admin-subtitle">Monitor and finalize payments that have been initiated. Review consolidated memos before completing the financial transaction.</MudText>
            </div>
            <MudButton StartIcon="@Icons.Material.Filled.Add" Variant="Variant.Filled" Color="Color.Primary" Class="admin-register-btn" OnClick="@(()=> SelectMemos())" Disabled="@_busy">INITIATE NEW PAYMENT</MudButton>
        </div>
    </div>

    <div class="admin-glass-card mb-6 pa-4">
        <div class="d-flex align-center gap-4">
            <div style="flex-grow: 1;">
                <MudTextField @bind-Value="searchTerm" Placeholder="Search by document number or amount..." Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" Variant="Variant.Outlined" Margin="Margin.Dense" Class="admin-input-group" Clearable="true" OnKeyUp="HandleSearchKeyUp" />
            </div>
        </div>
    </div>

    <div class="admin-glass-card pa-0 overflow-hidden">
        <MudTable Items="@collection" Elevation="0" Class="modern-admin-table" Hover="true">
            <HeaderContent>
                <MudTh><MudTableSortLabel SortBy="new Func<PaymentInitiatedModel, object>(x=> x.PaymentInitiatedID)" InitialDirection="SortDirection.Descending"><span class="admin-header-text">DOC NUMBER</span></MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<PaymentInitiatedModel, object>(x=> x.InitiatedDocumentDate)"><span class="admin-header-text">DOC DATE</span></MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<PaymentInitiatedModel, object>(x=> x.DueOn)"><span class="admin-header-text">DUE DATE</span></MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<PaymentInitiatedModel, object>(x=> x.TotalAmount)"><span class="admin-header-text">TOTAL AMOUNT</span></MudTableSortLabel></MudTh>
                <MudTh Style="text-align: right;"><span class="admin-header-text">ACTIONS</span></MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="DocNum"><span class="admin-td-primary fw-700">@context.DocumentNumber</span></MudTd>
                <MudTd DataLabel="Date">@context.InitiatedDocumentDate?.ToString("dd MMM yyyy")</MudTd>
                <MudTd DataLabel="DueOn">
                    <span class="fw-500">@context.DueOn?.ToString("dd MMM yyyy")</span>
                </MudTd>
                <MudTd DataLabel="Amount">
                    <MudChip T="string" Size="Size.Small" Color="Color.Success" Variant="Variant.Text" Class="fw-700">@context.TotalAmount?.ToString("N2")</MudChip>
                </MudTd>
                <MudTd DataLabel="Actions" Style="text-align: right;">
                    <MudTooltip Text="View Consolidated Memos">
                        <MudIconButton OnClick="@(()=> ViewMemo(context))" Color="Color.Info" Icon="@Icons.Material.Filled.Visibility" Size="Size.Small" Variant="Variant.Text" />
                    </MudTooltip>

                    @if (@context.AuthLevelId == 99)
                    {
                        <MudTooltip Text="Complete Financial Transaction">
                            <MudIconButton OnClick="@(()=> CompletePayment(context,false))" Color="Color.Success" Icon="@Icons.Material.Filled.AccountBalanceWallet" Size="Size.Small" Variant="Variant.Text" />
                        </MudTooltip>
                    }

                    <MudTooltip Text="Reject & Reverse">
                        <MudIconButton OnClick="@(()=> Reverse(context))" Color="Color.Error" Icon="@Icons.Material.Filled.Cancel" Size="Size.Small" Variant="Variant.Text" />
                    </MudTooltip>

                    <MudTooltip Text="Print Initiation Advice">
                        <MudIconButton OnClick="@(()=> Print(context.PaymentInitiatedID))" Color="Color.Tertiary" Icon="@Icons.Material.Filled.Print" Size="Size.Small" Variant="Variant.Text" />
                    </MudTooltip>
                </MudTd>
            </RowTemplate>
            <PagerContent>
                <div class="pa-4">
                    <MudTablePager PageSizeOptions="new int[] { 10, 20, 50, 100 }" />
                </div>
            </PagerContent>
        </MudTable>
    </div>
</div>
</div>

}

@code {

    private bool _isLoading = true;
    private DateTime _loadStartTime;

    private List<PaymentInitiatedModel> collection = new List<PaymentInitiatedModel>();
    DialogOptions maxWidth = new DialogOptions() { MaxWidth = MaxWidth.Large, FullWidth = true, CloseOnEscapeKey = true };
    private string searchTerm = "";
    int BranchID; string UserID;
    private bool _busy;

    public bool HasPermissionPaymentInitiatedServiceReverse { get; set; } = false;
    public int PaymentInitiatedDocTypeID = 15;

    // Method to handle search key events
    private async Task HandleSearchKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            GetAll();
        }
    }

    // Lifecycle method called when the component is initialized
    protected override async Task OnInitializedAsync()
    {
        _loadStartTime = DateTime.Now;
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionPaymentInitiatedServiceReverse = await Irole.HasClaim(PaymentInitiatedDocTypeID.ToString(), "Reverse", ctc.Token);

        var authprov = await auth.GetAuthenticationStateAsync();
        BranchID = int.Parse(authprov.User.Claims.First(x => x.Type == "BranchID").Value);
        UserID = authprov.User.Identity.Name;
        GetAll();
        await EnsureMinimumLoadTime();
        _isLoading = false;
    }

    private async Task EnsureMinimumLoadTime()
    {
        var elapsed = (DateTime.Now - _loadStartTime).TotalMilliseconds;
        if (elapsed < 100)
        {
            await Task.Delay(100 - (int)elapsed);
        }
    }

    // Method to select payment memos
    private async Task SelectMemos()
    {
        DialogParameters parms = new DialogParameters();
        parms.Add("BranchID", BranchID);
        var dialog = await DialogService.ShowAsync<PaymentMemoConsolidateSelectionDialog>("Payment", parms, maxWidth);
        var result = await dialog.Result;
        if (!result.Canceled)
        {
            var data = (List<PaymentMemoModel>)result.Data;

            PaymentInitiatedModel PI = new PaymentInitiatedModel()
                {                    
                    TotalAmount = data.Sum(x=> x.TotalAmount),
                    BranchID = BranchID,
                    UserInfo = new ArmsModels.SharedModels.UserInfoModel() { UserID = UserID },
                    SelectedMemos = data,
                };
            parms = new DialogParameters();
            parms.Add("PI", PI);
            parms.Add("ReadOnly", false);            
            var dialog2 = await DialogService.ShowAsync<PaymentConsolidateDialog>("Payment", parms, maxWidth);
            var result2 = await dialog2.Result;
            if (!result2.Canceled)
            {
                var UpdatedPI = (PaymentInitiatedModel)result2.Data;
                Iservice.Update(PI); // Update the payment initiated entry in the service
                GetAll();
            }
        }
    }

    // Method to handle approval of a payment initiated entry
    void OnApproved(int ID)
    {
        collection.First(x => x.PaymentInitiatedID == ID).AuthLevelId = 99;
        StateHasChanged();
    }

    // Method to retrieve all payment initiated entries based on the search term
    private void GetAll()
    {
        collection = Iservice.PendingForCompletion(BranchID, searchTerm).ToList(); // Fetch payment initiated entries from the service
    }
    
    // Method to reverse a payment initiated entry
    async Task Reverse(PaymentInitiatedModel pi)
    {
        if (HasPermissionPaymentInitiatedServiceReverse)
        {
            bool? result = await DialogService.ShowMessageBoxAsync(
                "Are You Sure?",
                "Do you want to Reverse this Entry ?");
            if (result == true)
            {
                Iservice.Reverse(pi.PaymentInitiatedID, UserID); // Call the service to reverse the payment initiated entry
                GetAll();
            }
        }
        else
        {
            bool? result = await DialogService.ShowMessageBoxAsync(
                "Permission denied!",
                "You don't have any permission to Reverse PaymentInitiated.");
        }
    }

    // Method to view a payment memo
    public async Task ViewMemo(PaymentInitiatedModel pim)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        _busy = true;

        // Fetch selected memos for the payment initiated ID
        pim.SelectedMemos = ImemoService.SelectInitiated(pim.PaymentInitiatedID).ToList();
        pim.TotalAmount = pim.SelectedMemos.Sum(x=> x.TotalAmount);
        DialogParameters parms = new DialogParameters();
        parms.Add("PI", pim);
        parms.Add("ReadOnly", true);
        parms.Add("OnApproved", new EventCallbackFactory().Create(this, new Action<int>(OnApproved)));
        var dialog = await DialogService.ShowAsync<PaymentConsolidateDialog>("Memo", parms, maxWidth);
        await Task.Delay(200);
        _busy = false;
    }

    // Method to complete the payment
    private async Task CompletePayment(PaymentInitiatedModel PiModel, bool ReadOnly)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        _busy = true;
        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;

        PaymentFinishModel pfm = new();
        pfm.PaymentInitiatedID = PiModel.PaymentInitiatedID;
        pfm.InitiatedDocumentDate = PiModel.InitiatedDocumentDate;
        pfm.DueOn = PiModel.DueOn;
        pfm.TotalAmount = PiModel.TotalAmount;
        pfm.BranchID = PiModel.BranchID;
        pfm.NatureOfTransaction = "Payment";        
        pfm.SelectedMemos = ImemoService.SelectInitiated(PiModel.PaymentInitiatedID).ToList(); // Fetch selected memos
        pfm.UserInfo = new ArmsModels.SharedModels.UserInfoModel()
        {
            UserID = UserID,
        };
        DialogParameters parms = new DialogParameters();
        parms.Add("model", pfm);
        parms.Add("ReadOnly", ReadOnly);
        var dialog = await DialogService.ShowAsync<PaymentFinishDilaog>("Payment", parms, maxWidth);
        var result = await dialog.Result;
        if (!result.Canceled)
        {
            GetAll();
        }
        await Task.Delay(200);
        _busy = false;
    }

    // Method to print the payment memo
    private async Task Print(int? ID)
    {        
        Dictionary<string, string> ReportParameters  = new();        
        ReportParameters.Add("ID", ID.ToString());        
        ReportParameters.Add("Operation", "Initiated");
        var parameters = new DialogParameters();
        parameters.Add("Parameters", ReportParameters); // Add the dictionary as a parameter
        parameters.Add("ReportName", "PrintPaymentMemo");

        DialogOptions maxWidth = new DialogOptions() { MaxWidth = MaxWidth.Medium, FullWidth = true };
        var result = await DialogService.ShowAsync<PrintDialog>("PRINT", parameters, maxWidth);
    }
}
