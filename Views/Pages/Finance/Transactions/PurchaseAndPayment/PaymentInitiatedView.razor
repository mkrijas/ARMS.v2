@page "/PaymentFinishMemoView"
@using System.Threading;
@inject IPaymentInitiatedService Iservice
@inject IPaymentService ImemoService
@inject MudBlazor.ISnackbar snackbar
@inject AuthenticationStateProvider auth
@inject IRoleService<RoleModel> Irole
@attribute [Authorize]
@inject IDialogService DialogService


<MudGrid Spacing="4">
    <MudItem xs="12">
        <MudTable Items="@collection" Dense="true" Hover="true" Striped="true" Elevation="10">

            <ToolBarContent>
                <MudText Typo="Typo.h6">Initiated Payments</MudText>
                @*  <MudTooltip Text="New Payment Memos">
                <MudIconButton Icon="@Icons.Material.Filled.Add" Title="Add" @onclick="openPaymentMemos" Color="Color.Dark" Size="Size.Small"></MudIconButton>

                </MudTooltip>
                <MudButton @onclick="openpurchaseorder" @onclick="@(()=> OpenDialog(model))" Variant="Variant.Filled" Color="Color.Primary">Purchase Order</MudButton>
                *@
                <MudSpacer></MudSpacer>
                <MudTextField @bind-Value="searchTerm" Placeholder="Search Initiated Payments..." Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0"
                              @onkeyup="HandleSearchKeyUp">
                </MudTextField>
                @* <MudTextField @bind-Value="searchMemos" Placeholder="Search ... "
                Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                IconSize="Size.Medium" Class="mt-0"></MudTextField>*@
            </ToolBarContent>
            <HeaderContent>
                <MudTh><MudTableSortLabel SortBy="new Func<PaymentInitiatedModel, object>(x=> x.DocumentNumber)" InitialDirection="SortDirection.Ascending">DocNumber</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<PaymentInitiatedModel, object>(x=> x.DueOn)" InitialDirection="SortDirection.Ascending">DueDate</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<PaymentInitiatedModel, object>(x=> x.DocumentDate)" InitialDirection="SortDirection.Ascending">DocDate</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<PaymentInitiatedModel, object>(x=> x.TotalAmount)" InitialDirection="SortDirection.Ascending">TotalAmount</MudTableSortLabel></MudTh>
                <MudTh>Actions</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="PaymentMemoID">@context.DocumentNumber</MudTd>
                <MudTd DataLabel="PaymentStatus">@context.DueOn?.ToShortDateString()</MudTd>
                <MudTd DataLabel="PaymentStatus">@context.DocumentDate?.ToShortDateString()</MudTd>
                <MudTd DataLabel="PaymentMemoID">@context.TotalAmount</MudTd>
                <MudTd DataLabel="">
                    <MudTooltip Text="View">
                        <MudFab @onclick="@(()=> ViewMemo(context))" Color="Color.Primary" Title="View Memo" Icon="@Icons.Material.Filled.Fullscreen" Size="Size.Small" IconSize="Size.Small" />
                    </MudTooltip>
                    <MudTooltip Text="Reject">
                        <MudFab @onclick="@(()=> Reverse(context))" Color="Color.Error" Icon="@Icons.Material.Filled.MoveDown" Size="Size.Small" IconSize="Size.Small" />
                    </MudTooltip>
                    <MudTooltip Text="Payment">
                        <MudFab @onclick="@(()=> OpenDialog(context,false))" Color="Color.Success" Icon="@Icons.Material.Filled.Check" Size="Size.Small" IconSize="Size.Small" />
                    </MudTooltip>
                </MudTd>
            </RowTemplate>
            <PagerContent>
                <MudTablePager PageSizeOptions="new int[] { 5, 10, 20, 50, 100 }" />
            </PagerContent>
        </MudTable>
    </MudItem>
</MudGrid>



@code {

    private List<PaymentInitiatedModel> collection = new List<PaymentInitiatedModel>();
    DialogOptions maxWidth = new DialogOptions() { MaxWidth = MaxWidth.Large, FullWidth = true, CloseOnEscapeKey = true };
    private string searchTerm = "";
    int BranchID; string UserID;

    public bool HasAuthoriseDelete { get; set; } = false;
    int DocTypeID = 15;

    private async Task HandleSearchKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await ReloadTable();
        }
    }

    private async Task ReloadTable()
    {
        GetAll();
    }

    protected override async Task OnInitializedAsync()
    {

        CancellationTokenSource ctc = new CancellationTokenSource();
        HasAuthoriseDelete = await Irole.HasClaim(DocTypeID.ToString(), "Delete", ctc.Token);

        var authprov = await auth.GetAuthenticationStateAsync();
        BranchID = int.Parse(authprov.User.Claims.First(x => x.Type == "BranchID").Value);
        UserID = authprov.User.Identity.Name;
        GetAll();
    }

    private void GetAll()
    {
        collection = Iservice.PendingForCompletion(BranchID, searchTerm).ToList();
    }

    async Task Reverse(PaymentInitiatedModel pi)
    {

        if (HasAuthoriseDelete)
        {
              bool? result = await DialogService.ShowMessageBox(
        "Are You Sure?",
        "Do you want to Reverse this Entry");
        Iservice.Reverse(pi.PaymentInitiatedID, UserID);
        GetAll();

        }
        else
        {

            bool? result = await DialogService.ShowMessageBox(
        "Permission denied!",
        "You dont have any permission to reverse.");
        }
    }

    public void ViewMemo(PaymentInitiatedModel pim)
    {
        DialogParameters parms = new DialogParameters();
        parms.Add("model", ImemoService.SelectByID(pim.PaymentMemoID));
        parms.Add("ReadOnly", true);
        var dialog = DialogService.Show<PaymentMemoDialog>("Memo", parms, maxWidth);
    }

    private async Task OpenDialog(PaymentInitiatedModel tds, bool ReadOnly)
    {
        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;       
        PaymentFinishModel pfm = new PaymentFinishModel(ImemoService.SelectByID(tds.PaymentMemoID));
        pfm.PaymentInitiatedID = tds.PaymentInitiatedID;
        pfm.InitiatedDocumentDate = tds.InitiatedDocumentDate;
        pfm.DueOn = tds.DueOn;
        pfm.UserInfo = tds.UserInfo;

        DialogParameters parms = new DialogParameters();
        parms.Add("model", pfm);
        parms.Add("ReadOnly", ReadOnly);
        var dialog = DialogService.Show<PaymentFinishDilaog>("Payment", parms, maxWidth);
        var result = await dialog.Result;
        if (!result.Canceled)
        {
            GetAll();
        }
    }
}
