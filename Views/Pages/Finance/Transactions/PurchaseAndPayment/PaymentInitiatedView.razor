@page "/InitiatePayment"
@using System.Threading;
@inject IPaymentInitiatedService Iservice
@inject IPaymentService ImemoService
@inject MudBlazor.ISnackbar snackbar
@inject AuthenticationStateProvider auth
@inject IRoleService<RoleModel> Irole
@attribute [Authorize]
@inject IDialogService DialogService

<MudGrid Spacing="4">
    <MudItem xs="12">
        <MudTable Items="@collection" Dense="true" Hover="true" Striped="true" Elevation="10">
            <ToolBarContent>
                <MudText Typo="Typo.h6">Initiated Payments</MudText>
                <MudTooltip Text="Initiate Payment">
                    <MudIconButton Disabled="@_busy" Icon="@Icons.Material.Filled.Add" Title="Add" @onclick="@(()=> SelectMemos())" Color="Color.Dark" Size="Size.Small"></MudIconButton>
                </MudTooltip>
                <MudSpacer></MudSpacer>
                <MudTextField @bind-Value="searchTerm" Placeholder="Search Initiated Payments..." Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0" @onkeyup="HandleSearchKeyUp">
                </MudTextField>
            </ToolBarContent>
            <HeaderContent>
                <MudTh><MudTableSortLabel SortBy="new Func<PaymentInitiatedModel, object>(x=> x.DocumentNumber)" InitialDirection="SortDirection.Ascending">Document Number</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<PaymentInitiatedModel, object>(x=> x.DueOn)" InitialDirection="SortDirection.Ascending">Due Date</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<PaymentInitiatedModel, object>(x=> x.InitiatedDocumentDate)" InitialDirection="SortDirection.Ascending">Document Date</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<PaymentInitiatedModel, object>(x=> x.TotalAmount)" InitialDirection="SortDirection.Ascending">Total Amount</MudTableSortLabel></MudTh>
                <MudTh>Actions</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="DocNum">@context.DocumentNumber</MudTd>
                <MudTd DataLabel="DueOn">@context.DueOn?.ToShortDateString()</MudTd>
                <MudTd DataLabel="Date">@context.InitiatedDocumentDate?.ToShortDateString()</MudTd>
                <MudTd DataLabel="PaymentMemoID">@context.TotalAmount</MudTd>
                <MudTd DataLabel="">
                    <MudTooltip Text="View">
                        <MudFab @onclick="@(()=> ViewMemo(context))" Color="Color.Primary" Title="View Memo" Icon="@Icons.Material.Filled.Fullscreen" Size="Size.Small" IconSize="Size.Small" />
                    </MudTooltip>
                    <MudTooltip Text="Reject">
                        <MudFab @onclick="@(()=> Reverse(context))" Color="Color.Error" Icon="@Icons.Material.Filled.MoveDown" Size="Size.Small" IconSize="Size.Small" />
                    </MudTooltip>

                    <MudTooltip Text="Payment">
                        @if (context.AuthLevelId == 99)
                        {
                            <MudFab @onclick="@(()=> CompletePayment(context,false))" Color="Color.Success" Icon="@Icons.Material.Filled.Check" Size="Size.Small" IconSize="Size.Small" />
                        }
                    </MudTooltip>

                </MudTd>
            </RowTemplate>
            <PagerContent>
                <MudTablePager PageSizeOptions="new int[] { 5, 10, 20, 50, 100 }" />
            </PagerContent>
        </MudTable>
    </MudItem>
</MudGrid>

@code {

    private List<PaymentInitiatedModel> collection = new List<PaymentInitiatedModel>();
    DialogOptions maxWidth = new DialogOptions() { MaxWidth = MaxWidth.Large, FullWidth = true, CloseOnEscapeKey = true };
    private string searchTerm = "";
    int BranchID; string UserID;
    private bool _busy;

    public bool HasPermissionPaymentInitiatedServiceReverse { get; set; } = false;
    public int PaymentInitiatedDocTypeID = 15;

    private async Task HandleSearchKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            GetAll();
        }
    }



    protected override async Task OnInitializedAsync()
    {
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionPaymentInitiatedServiceReverse = await Irole.HasClaim(PaymentInitiatedDocTypeID.ToString(), "Reverse", ctc.Token);

        var authprov = await auth.GetAuthenticationStateAsync();
        BranchID = int.Parse(authprov.User.Claims.First(x => x.Type == "BranchID").Value);
        UserID = authprov.User.Identity.Name;
        GetAll();
    }

    private async Task SelectMemos()
    {
        DialogParameters parms = new DialogParameters();
        parms.Add("BranchID", BranchID);
        var dialog = DialogService.Show<PaymentMemoConsolidateSelectionDialog>("Payment", parms, maxWidth);
        var result = await dialog.Result;
        if (!result.Canceled)
        {
            var data = (List<PaymentMemoModel>)result.Data;

            PaymentInitiatedModel PI = new PaymentInitiatedModel()
                {
                    TotalAmount = data.Sum(x=> x.TotalAmount),
                    BranchID = BranchID,
                    UserInfo = new ArmsModels.SharedModels.UserInfoModel() { UserID = UserID },
                    SelectedMemos = data,
                };
            parms = new DialogParameters();
            parms.Add("PI", PI);
            parms.Add("ReadOnly", false);            
            var dialog2 = DialogService.Show<PaymentConsolidateDialog>("Payment", parms, maxWidth);
            var result2 = await dialog2.Result;
            if (!result2.Canceled)
            {
                var UpdatedPI = (PaymentInitiatedModel)result2.Data;
                Iservice.Update(PI);
                GetAll();
            }
        }
    }


    void OnApproved(int ID)
    {
        collection.First(x => x.PaymentInitiatedID == ID).AuthLevelId = 99;
        StateHasChanged();
    }


    private void GetAll()
    {
        collection = Iservice.PendingForCompletion(BranchID, searchTerm).ToList();
    }

    async Task Reverse(PaymentInitiatedModel pi)
    {
        if (HasPermissionPaymentInitiatedServiceReverse)
        {
            bool? result = await DialogService.ShowMessageBox(
                "Are You Sure?",
                "Do you want to Reverse this Entry ?");
            if (result == true)
            {
                Iservice.Reverse(pi.PaymentInitiatedID, UserID);
                GetAll();
            }
        }
        else
        {
            bool? result = await DialogService.ShowMessageBox(
                "Permission denied!",
                "You dont have any permission to Reverse PaymentInitiated.");
        }
    }

    public async void ViewMemo(PaymentInitiatedModel pim)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        _busy = true;
        pim.SelectedMemos = ImemoService.SelectInitiated(pim.PaymentInitiatedID).ToList();
        DialogParameters parms = new DialogParameters();
        parms.Add("PI", pim);
        parms.Add("ReadOnly", true);
        parms.Add("OnApproved", new EventCallbackFactory().Create(this, new Action<int>(OnApproved)));
        var dialog = DialogService.Show<PaymentConsolidateDialog>("Memo", parms, maxWidth);
        await Task.Delay(200);
        _busy = false;
    }

    private async Task CompletePayment(PaymentInitiatedModel PiModel, bool ReadOnly)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        _busy = true;
        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;

        PaymentFinishModel pfm = new();
        pfm.PaymentInitiatedID = PiModel.PaymentInitiatedID;
        pfm.InitiatedDocumentDate = PiModel.InitiatedDocumentDate;
        pfm.DueOn = PiModel.DueOn;
        pfm.TotalAmount = PiModel.TotalAmount;
        pfm.BranchID = PiModel.BranchID;
        pfm.NatureOfTransaction = "Payment";        
        pfm.SelectedMemos = ImemoService.SelectInitiated(PiModel.PaymentInitiatedID).ToList();
        pfm.UserInfo = new ArmsModels.SharedModels.UserInfoModel()
        {
            UserID = UserID,
        };
        DialogParameters parms = new DialogParameters();
        parms.Add("model", pfm);
        parms.Add("ReadOnly", ReadOnly);
        var dialog = DialogService.Show<PaymentFinishDilaog>("Payment", parms, maxWidth);
        var result = await dialog.Result;
        if (!result.Canceled)
        {
            GetAll();
        }
        await Task.Delay(200);
        _busy = false;
    }
}