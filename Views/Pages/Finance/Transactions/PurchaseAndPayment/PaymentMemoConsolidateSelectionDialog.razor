@inject IPaymentService iservice
@inject MudBlazor.ISnackbar snackbar

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.Build" Class="mr-3 mb-n1" />
            Select Memos to Initiate Payment
            <MudText> (@selectedItems?.Count) Memos Selected</MudText>
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudGrid>
            <MudItem xs="5">
                <BranchSelector @bind-Value="@SelectedBranch" LabelName="Select Branch"></BranchSelector>
            </MudItem>
            <MudItem xs="5">
                <PartySelector BranchID="@(SelectedBranch?.BranchID)" @bind-Value="@SelectedParty" label="Select Party" />
            </MudItem>
            <MudItem xs="2">
                <MudButton OnClick="@FetchMemos">Show</MudButton>
            </MudItem>
            <MudItem xs="12">
                <MudTable T="PaymentMemoModel" Items="@Memos"
                          Hover="true" SelectOnRowClick Filter="new Func<PaymentMemoModel, bool>(search)">
                    <ToolBarContent>
                        <MudSpacer></MudSpacer>
                        <MudTextField @bind-Value="searchMemo" Placeholder="Search.... " Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0"></MudTextField>
                    </ToolBarContent>
                    <HeaderContent>
                        <MudTh><MudCheckBox ValueChanged="(bool isChecked) => SelectAll(isChecked)"></MudCheckBox></MudTh>
                        <MudTh>Memo Number</MudTh>
                        <MudTh>Branch Name</MudTh>
                        <MudTh>Memo Date</MudTh>
                        <MudTh>Party</MudTh>
                        <MudTh>Amount</MudTh>
                        <MudTh>Reference</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd><MudCheckBox @bind-Value="@context.IsChecked"></MudCheckBox></MudTd>
                        <MudTd DataLabel="DocumentNumber">@context.DocumentNumber</MudTd>
                        <MudTd DataLabel="BranchName">@context.OtherBranch</MudTd>
                        <MudTd DataLabel="DocumentDate">@context.DocumentDate?.ToShortDateString()</MudTd>
                        <MudTd DataLabel="Party">@context.PartyInfo.TradeName</MudTd>
                        <MudTd DataLabel="Amount">@context.TotalAmount</MudTd>
                        <MudTd DataLabel="Reference">@context.Reference</MudTd>
                    </RowTemplate>
                </MudTable>
            </MudItem>
        </MudGrid>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(()=> MudDialog.Cancel())">Cancel</MudButton>
        <MudButton Disabled="@_busy" Variant="Variant.Filled" Color="Color.Success" ButtonType="ButtonType.Button" OnClick="Submit">Submit</MudButton>
    </DialogActions>
</MudDialog>


@code {

    [Parameter]
    public int? BranchID { get; set; }
    private bool _busy;

    private BranchModel SelectedBranch;
    private PartyModel SelectedParty;

    [CascadingParameter] MudDialogInstance MudDialog { get; set; }
    private HashSet<PaymentMemoModel> selectedItems = new();
    private List<PaymentMemoModel> Memos = new List<PaymentMemoModel>();
    private string searchMemo = "";

    IEnumerable<PaymentMemoModel> FilteredCollection { get; set; }

    void SelectAll(bool isChecked)
    {
        FilteredCollection = Memos.Where(item => search(item));
        foreach (var item in FilteredCollection)
        {
            item.IsChecked = isChecked;
        }
    }

    protected override void OnInitialized()
    {

    }

    void FetchMemos()
    {
        if(SelectedBranch is null)
        {
            snackbar.Add("Branch not selected!", Severity.Warning);
            return;
        }
        Memos = iservice.SelectPending(SelectedBranch.BranchID,SelectedParty.PartyID).ToList();
    }

    private async Task Submit()
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        _busy = true;

        if (Memos.Where(x => x.IsChecked).ToList().Count > 0)
        {
            MudDialog.Close(Memos.Where(x => x.IsChecked).ToList());
        }
        else
        {
            snackbar.Add("Please select atleast one Memo!", Severity.Warning);
        }

        await Task.Delay(200);
        _busy = false;
    }


    void OnRowClick(TableRowClickEventArgs<PaymentMemoModel> args)
    {
        //_selectedItemText = $"{args.Item.Name} ({args.Item.Sign})";
    }

    private bool search(PaymentMemoModel memo)
    {
        if ((memo.DocumentNumber != null && memo.DocumentNumber.Contains(searchMemo, StringComparison.OrdinalIgnoreCase)) ||
        (memo.PartyInfo.TradeName != null && memo.PartyInfo.TradeName.Contains(searchMemo, StringComparison.OrdinalIgnoreCase)) ||
        (memo.OtherBranch != null && memo.OtherBranch.Contains(searchMemo, StringComparison.OrdinalIgnoreCase)) ||
        (memo.Reference != null && memo.Reference.Contains(searchMemo, StringComparison.OrdinalIgnoreCase)))
        {
            return true;
        }
        return false;
    }
}
