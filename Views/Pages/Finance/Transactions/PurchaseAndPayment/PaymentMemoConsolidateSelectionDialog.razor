@inject IPaymentService iservice
@inject MudBlazor.ISnackbar snackbar

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.Build" Class="mr-3 mb-n1" />
            Select Memos to Initiate Payment  
            <MudText> (@selectedItems?.Count) Memos Selected</MudText>
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudTable T="PaymentMemoModel" Items="@Memos" MultiSelection="true"
                   @bind-SelectedItems="selectedItems" Hover="true" SelectOnRowClick>
            <HeaderContent>
                <MudTh>Memo Date</MudTh>
                <MudTh>Party</MudTh>
                <MudTh>Amount</MudTh>
                <MudTh>Reference</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="DocumentDate">@context.DocumentDate</MudTd>
                <MudTd DataLabel="Party">@context.PartyInfo.TradeName</MudTd>
                <MudTd DataLabel="Amount">@context.TotalAmount</MudTd>
                <MudTd DataLabel="Reference">@context.Reference</MudTd>
            </RowTemplate>
        </MudTable>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(()=> MudDialog.Cancel())">Cancel</MudButton>
        <MudButton Disabled="@_busy" Variant="Variant.Filled" Color="Color.Success" ButtonType="ButtonType.Button" OnClick="Submit">Submit</MudButton>
    </DialogActions>
</MudDialog>


@code {

    [Parameter]
    public int? BranchID { get; set; }

    private bool _busy;

    [CascadingParameter] MudDialogInstance MudDialog { get; set; }
    private HashSet<PaymentMemoModel> selectedItems = new();
    private List<PaymentMemoModel> Memos = new();

    protected override void OnInitialized()
    {
        Memos = iservice.SelectPending(BranchID).ToList();
    }


    private async Task Submit()
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        _busy = true;

        if (selectedItems.Count > 0)
        {
            MudDialog.Close(selectedItems.ToList());
        }
        else
        {
            snackbar.Add("Please select atleast one Memo!", Severity.Warning);
        }

        await Task.Delay(200);
        _busy = false;
    }


    void OnRowClick(TableRowClickEventArgs<PaymentMemoModel> args)
    {
        //_selectedItemText = $"{args.Item.Name} ({args.Item.Sign})";
    }
}
