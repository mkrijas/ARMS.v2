@page "/NewPaymentMemo"

@inherits DialogFormComponentBase<PaymentMemoModel>
@inject IPaymentService Iservice


<DialogForm @ref="@dialogForm" ReadOnly="@ReadOnly" Title="Payment Memo" Subtitle="Manage and settle outstanding invoices with centralized party balance tracking." Icon="@Icons.Material.Filled.Payments" AdminStyle="true" formID="PaymentMemoForm" DocumentDetails="DocInfo" model="@_model" _busy="_busy">
    <FormContent>
        <div class="dialog-content-wrapper">
            <EditForm id="PaymentMemoForm" OnValidSubmit="OnValidSubmit" EditContext="editContext">
                <ObjectGraphDataAnnotationsValidator />
                
                <div class="admin-glass-card pa-6 mb-6">
                    <div class="d-flex align-center mb-6">
                        <MudIcon Icon="@Icons.Material.Filled.DateRange" Color="Color.Primary" Class="mr-2" />
                        <span class="admin-section-label mb-0">Classification & Timeline</span>
                    </div>
                    <MudGrid Spacing="3">
                        <MudItem xs="12" md="6">
                            <MudDatePicker ReadOnly="ReadOnly" Label="Document Date" Variant="Variant.Outlined" Margin="Margin.Dense" DisableToolbar="true" Editable="true" @bind-Date="_model.DocumentDate" DateFormat="dd/MM/yyyy" MaxDate="DateTime.Now" Class="admin-input-group" />
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <MudTextField ReadOnly="ReadOnly" @bind-Value="_model.Reference" Label="Purpose / Reference" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => _model.Reference)" Class="admin-input-group"></MudTextField>
                        </MudItem>
                    </MudGrid>
                </div>

                <div class="admin-glass-card pa-6 mb-6">
                    <div class="d-flex align-center mb-6">
                        <MudIcon Icon="@Icons.Material.Filled.Groups" Color="Color.Primary" Class="mr-2" />
                        <span class="admin-section-label mb-0">Party Engagement</span>
                    </div>
                    <MudGrid Spacing="3">
                        <MudItem xs="12" md="4">
                            <MudSelect Label="Nature of Party" ReadOnly="ReadOnly" Value="@_model.BusinessNature" T="string" ValueChanged="nbusinesschanged" Variant="Variant.Outlined" Margin="Margin.Dense" Class="admin-input-group" AdornmentColor="Color.Primary">
                                <MudSelectItem Value="@("Supplier")" />
                                <MudSelectItem Value="@("Customer")" />
                                <MudSelectItem Value="@("Renter")" />
                                <MudSelectItem Value="@("SisterConcern")">Sister-Concern</MudSelectItem>
                            </MudSelect>
                        </MudItem>
                        <MudItem xs="12" md="4">
                            <PartySelector Value="_model.PartyInfo" ValueChanged="PartyChanged" BranchID="BranchID" NatureOfBusiness="@_model.BusinessNature" Class="admin-input-group"></PartySelector>
                        </MudItem>
                        <MudItem xs="12" md="4">
                            <MudSelect Label="Nature Of Payment" ReadOnly="ReadOnly" Value="_model.NatureOfTransaction" ValueChanged="nTransactionChanged" T="string" Variant="Variant.Outlined" Margin="Margin.Dense" Class="admin-input-group">
                                @if (_model.PartyInfo is not null)
                                {
                                    foreach (var item in natureOfBusinessGroup)
                                    {
                                        <MudSelectItem Value="@(item)" />
                                    }
                                }
                            </MudSelect>
                        </MudItem>
                    </MudGrid>
                </div>

                @if (_model.Bills.Any())
                {
                    <div class="admin-glass-card pa-0 overflow-hidden mb-6">
                        <div class="px-6 py-4 border-bottom-subtle d-flex align-center" style="background: rgba(255, 159, 67, 0.03); border-bottom: 1px solid rgba(255, 159, 67, 0.3);">
                            <MudIcon Icon="@Icons.Material.Filled.History" Color="Color.Warning" Class="mr-2" />
                            <span class="admin-section-label mb-0">Outstanding Settlements</span>
                        </div>
                        <div class="modern-admin-table">
                            <MudGrid Class="admin-table-header px-6 py-3">
                                <MudItem xs="4"><span class="admin-header-text">INVOICE INFO</span></MudItem>
                                <MudItem xs="2"><span class="admin-header-text">BRANCH</span></MudItem>
                                <MudItem xs="3"><span class="admin-header-text">OUTSTANDING</span></MudItem>
                                <MudItem xs="3"><span class="admin-header-text">PAY AMOUNT</span></MudItem>
                            </MudGrid>

                            @foreach (var item in _model.Bills)
                            {
                                <MudGrid Class="px-6 py-3 border-bottom-subtle align-center">
                                    <MudItem xs="4">
                                        <MudText Typo="Typo.body2" Style="font-weight: 700;">@item.InvoiceNumber</MudText>
                                        <MudText Typo="Typo.caption" Style="color: #667085;">@item.InvoiceDate?.ToString("dd/MM/yyyy")</MudText>
                                    </MudItem>
                                    <MudItem xs="2">
                                        <MudText Typo="Typo.body2">@item.BranchName</MudText>
                                    </MudItem>
                                    <MudItem xs="3">
                                        <MudText Typo="Typo.body2" Style="color: #141A46;">₹ @item.OutstandingAmount</MudText>
                                    </MudItem>
                                    <MudItem xs="3">
                                        <MudNumericField T="decimal?" ReadOnly="@ReadOnly" @bind-Value="item.PayAmount" TextChanged="SetTotalAmt" Variant="Variant.Outlined" Margin="Margin.Dense" HideSpinButtons Class="admin-input-group" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.CurrencyRupee" AdornmentColor="Color.Primary" />
                                    </MudItem>
                                </MudGrid>
                            }
                        </div>
                    </div>
                }

                <div class="admin-glass-card pa-6">
                    <div class="d-flex align-center mb-6">
                        <MudIcon Icon="@Icons.Material.Filled.Notes" Color="Color.Primary" Class="mr-2" />
                        <span class="admin-section-label mb-0">Final Remarks</span>
                    </div>
                    <MudGrid Spacing="3">
                        @if (_model.NatureOfTransaction == "Deposit" || _model.NatureOfTransaction == "Prepayment" || _model.NatureOfTransaction == "Other")
                        {
                            <MudItem xs="12">
                                <MudNumericField ReadOnly="ReadOnly" HideSpinButtons @bind-Value="_model.TotalAmount" Label="Total Amount" Variant="Variant.Outlined" Margin="Margin.Dense" Class="admin-input-group" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.CurrencyRupee" AdornmentColor="Color.Primary" For="@(() => _model.TotalAmount)"></MudNumericField>
                            </MudItem>
                        }
                        <MudItem xs="12">
                            <MudTextField ReadOnly="ReadOnly" @bind-Value="_model.Narration" Lines="3" Label="Narration / Process Notes" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => _model.Narration)" Class="admin-input-group"></MudTextField>
                        </MudItem>
                    </MudGrid>
                </div>
            </EditForm>
        </div>
    </FormContent>
    <VerificationStatus>
        <AutherizationStatusComponent CreatedBy="@_model.UserInfo" DocTypeID="@DocInfo.DocumentTypeID" DocDate="@DocDate" DocType="@DocInfo.DocumentName" DocNumber="@DocNumber" DocumentID="DocInfo.DocumentID" OnApprove="Approve"></AutherizationStatusComponent>
    </VerificationStatus>
</DialogForm>

@code {

    [Parameter]
    public override PaymentMemoModel model { get { return _model; } set { _model = value; DocInfo.DocumentID = value.PaymentMemoID; } }
    private PaymentMemoModel _model;
    string UserIDTemp;

    string[] natureOfBusinessGroup = new string[] { };
    string[] RentGroup = { "Rent", "Deposit", "Other" };
    string[] SupplierGroup = { "Deposit", "Payable", "Prepayment" };
    string[] CustomerGroup = { "Deposit", "Receivable", "Prepayment" };
    string[] SisterGroup = { "Deposit", "Trade", "Prepayment" };

    protected override DocumentInfoModel DocInfo { get; set; } = new DocumentInfoModel()
        {
            DocumentTypeID = 7,
            DocumentName = "PaymentMemo"
        };

    // Lifecycle method called when the component is initialized
    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();
        if (model.PaymentMemoID != null)
        {
            UserIDTemp = model.UserInfo.UserID;
            model.Bills = Iservice.GetBills(model.PaymentMemoID.Value).ToList(); // Fetch bills related to the payment memo
        }
        else
        {
            model.BranchID = BranchID;
            model.BusinessNature = "Supplier";
        }
        SetNTransaction(model.BusinessNature);
    }

    // Method to update the payment memo
    protected override async Task<int> Update(PaymentMemoModel editModel)
    {
        model = Iservice.Update(model); // Update the model using the service
        return model.PaymentMemoID.Value;
    }

    // Method to approve the payment memo
    protected override int UpdateApproval(DataApprovedStatus aprvd)
    {
        int result = Iservice.Approve(model.PaymentMemoID, model.UserInfo.UserID, aprvd.Remarks); // Call the service to approve
        model.UserInfo.UserID = UserIDTemp;
        return result;
    }

    // Method to set the total amount based on bills
    private void SetTotalAmt()
    {
        model.TotalAmount = (model.Bills.Sum(x => x.PayAmount) ?? 0);
    }

    // Method to handle changes in business nature
    async Task nbusinesschanged(string val)
    {
        model.BusinessNature = val;
        SetNTransaction(val);
        await PartyChanged(null);
    }

    // Method to set the nature of transaction based on business nature
    void SetNTransaction(string nBusiness)
    {
        if (nBusiness == "Renter")
        {
            natureOfBusinessGroup = RentGroup;
        }
        else if (nBusiness == "Customer")
        {
            natureOfBusinessGroup = CustomerGroup;
        }
        else if (nBusiness == "Supplier")
        {
            natureOfBusinessGroup = SupplierGroup;
        }
        else if (nBusiness == "SisterConcern")
        {
            natureOfBusinessGroup = SisterGroup;
        }
        else
        {
            natureOfBusinessGroup = new string[] { };
        }
    }

    // Method to handle changes in the selected party
    async Task PartyChanged(PartyModel party)
    {
        model.PartyInfo = party;
        await nTransactionChanged(null);
    }

    // Method to handle changes in the nature of transaction
    private async Task nTransactionChanged(string nt)
    {
        model.NatureOfTransaction = nt;
        if (model.NatureOfTransaction is not null)
        {
            // Get the COA ID for the selected party and transaction type
            model.PartyCoaID = partyService.GetPartyCoaID(model.PartyInfo.PartyID, model.BusinessNature, model.NatureOfTransaction);
            if (model.PartyCoaID == null)
            {
                bool? result = await dialogService.ShowMessageBoxAsync(
                    "Account Not Mapped!",
                    "Party Account is not mapped for " + model.NatureOfTransaction + "!");
                model.NatureOfTransaction = null;
            }
        }

        if (nt == "Payable" || nt == "Rent" || nt == "Trade")
        {
            await OpenOutstandingBills();
        }
        else
        {
            model.Bills.Clear();
        }
    }

    // Method to open the outstanding bills dialog
    private async Task OpenOutstandingBills()
    {
        DialogOptions Doptions = new DialogOptions() { MaxWidth = MaxWidth.Large, FullWidth = true };
        DialogParameters parms = new DialogParameters();
        parms.Add("PartyID", model.PartyInfo.PartyID);
        parms.Add("BranchID", BranchID);
        var dialog = await dialogService.ShowAsync<OutstandingBillView>("Outstanding Bill", parms, Doptions);
        var result = await dialog.Result;
        if (!result.Canceled)
        {
            List<OutstandingBillsModel> SelectedItems = new List<OutstandingBillsModel>();
            SelectedItems = (List<OutstandingBillsModel>)result.Data;
            model.Bills.Clear();
            foreach (var item in SelectedItems)
            {
                model.Bills.Add(new BillsPaidModel()
                    {
                        MID = item.MID,
                        BranchName = item.BranchName,
                        InvoiceDate = item.ReferenceDocDate,
                        InvoiceNumber = item.ReferenceDocNo,
                        OutstandingAmount = item.OutstandingAmount,
                        PayAmount = -(item.OutstandingAmount),
                        IsMemo = item.isMemo,
                        CoaID = item.CoaID,
                        SubArdCode = item.SubArdCode,
                        PartyID = item.PartyInfo.PartyID,
                        BranchID = item.BranchID
                    });
            }
            //model.Reference = string.Join(",", SelectedItems.Select(x => x.ReferenceDocNo));
        }
        if (!model.Bills.Any())
        {
            model.NatureOfTransaction = null;
        }
    }
}
