@page "/NewPaymentMemo"
@using System.Threading;
@using Core.BaseModels.General;
@inject IPaymentService Iservice
@inject IOutstandingBillsService OBIservice
@inject IPartyService partyService
@inject MudBlazor.ISnackbar snackbar
@inject IDialogService DialogService
@inject AuthenticationStateProvider auth
@inject IRoleService<RoleModel> Irole
@attribute [Authorize]

<DialogForm @ref="@dialogForm" ReadOnly="@ReadOnly" Title="Payment Memo" formID="PaymentMemoForm" DocumentDetails="DocumentDetails" model="@model" _busy="_busy">
    <FormContent>
        <MudPaper Class="p-3">
            <EditForm id="PaymentMemoForm" OnValidSubmit="OnValidSubmit" EditContext="editContext">
                <ObjectGraphDataAnnotationsValidator />
                <ValidationSummary />
                <MudGrid>
                    <MudItem xs="12" md="4">
                        <MudSelect Label="Select Party" ReadOnly="ReadOnly" Value="@model.BusinessNature" T="string" ValueChanged="nbusinesschanged" Variant="Variant.Outlined" Margin="Margin.Dense" OffsetY="true" Direction="Direction.Top" AdornmentColor="Color.Secondary">
                            <MudSelectItem Value="@("Supplier")" />
                            <MudSelectItem Value="@("Customer")" />
                            <MudSelectItem Value="@("Renter")" />
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12" md="4">
                        <PartySelector Value="model.PartyInfo" ValueChanged="PartyChanged" NatureOfBusiness="@model.BusinessNature"></PartySelector>
                    </MudItem>
                    <MudItem xs="12" md="4">
                        <MudSelect Label="Nature Of Business" ReadOnly="ReadOnly" Value="model.NatureOfTransaction" ValueChanged="nTransactionChanged" T="string" Variant="Variant.Outlined" Margin="Margin.Dense" OffsetY="true" Direction="Direction.Top" AdornmentColor="Color.Secondary">
                            @if (model.PartyInfo != null)
                            {
                                <MudSelectItem Value="@("Deposit")" />
                                <MudSelectItem Value="@("Payment")" />
                                <MudSelectItem Value="@("Prepayment")" />
                            }
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12" md="4">
                        <MudDatePicker ReadOnly="ReadOnly" Label="Document Date" Variant="Variant.Outlined" Margin="Margin.Dense" DisableToolbar="true" Editable="true" @bind-Date="model.DocumentDate" DateFormat="dd/MM/yyyy" />
                    </MudItem>
                    <MudItem xs="12" md="4">
                        <CostCenterSelector @bind-Value="model.CostCenter" ReadOnly="@ReadOnly" />
                    </MudItem>
                    <MudItem xs="12" md="4">
                        <DimensionSelector @bind-Value="model.Dimension" ReadOnly="@ReadOnly" />
                    </MudItem>
                    @if (model.Bills.Any())
                    {
                        <MudItem xs="12">
                            <MudSimpleTable Hover="true" Dense="true" FixedHeader="true" Elevation="0">
                                <thead>
                                    <tr>
                                        <th>Invoice info</th>
                                        <th>Branch</th>
                                        <th>Outstanding Amount</th>
                                        <th>Pay Amount</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in model.Bills)
                                    {
                                        <tr>
                                            <td>@item.InvoiceNumber - @item.InvoiceDate?.ToShortDateString()</td>
                                            <td>@item.BranchName</td>
                                            <td>@item.OutstandingAmount</td>
                                            <td> <MudTextField T="decimal?" ReadOnly="@ReadOnly" @bind-Value="item.PayAmount" TextChanged="SetTotalAmt" Variant="Variant.Outlined" Margin="Margin.Dense"> </MudTextField></td>
                                        </tr>
                                    }
                                </tbody>
                            </MudSimpleTable>
                        </MudItem>
                    }
                    @if (model.NatureOfTransaction == "Deposit" || model.NatureOfTransaction == "Prepayment")
                    {
                        <MudItem xs="12" md="12">
                            <MudNumericField ReadOnly="ReadOnly" HideSpinButtons @bind-Value="model.TotalAmount" Label="Amount" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.TotalAmount)"></MudNumericField>
                         </MudItem>
                    }
                    <MudItem xs="12" md="12">
                        <MudTextField ReadOnly="ReadOnly" @bind-Value="model.Narration" Lines="2" Label="Narration" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.Narration)"></MudTextField>
                    </MudItem>
                </MudGrid>
            </EditForm>
        </MudPaper>
    </FormContent>
    <VerificationStatus>
        <AutherizationStatusComponent DocTypeID="@PaymentDocTypeID" DocDate="@DocDate" DocType="@DocType" DocNumber="@DocNumber" PageToRedirectLink="@PageToRedirectLink" DocumentID="model.PaymentMemoID" OnApprove="Approve"></AutherizationStatusComponent>
    </VerificationStatus>
</DialogForm>

@code {

    [Parameter]
    public PaymentMemoModel model { get; set; }
    [Parameter]
    public bool ReadOnly { get; set; }
    [Parameter]
    public bool Dialog { get; set; } = true;
    private EditContext editContext;
    DialogForm dialogForm;
    private int? branchID = null;
    private string UserID = null;

    [Parameter]
    public string PageToRedirectLink { get; set; }
    public string DocNumber { get; set; }
    public DateTime? DocDate { get; set; }
    public string DocType { get; set; }
    private bool _busy;

    public DocumentDetailsModel DocumentDetails { get; set; } = new();

    public bool HasPermissionPaymentServiceEdit { get; set; } = false;
    public bool HasPermissionPaymentServiceApprove { get; set; } = false;
    public int PaymentDocTypeID = 7;

    protected override async Task OnInitializedAsync()
    {
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionPaymentServiceEdit = await Irole.HasClaim(PaymentDocTypeID.ToString(), "Edit", ctc.Token);
        HasPermissionPaymentServiceApprove = await Irole.HasClaim(PaymentDocTypeID.ToString(), "Approve", ctc.Token);

        var authprov = await auth.GetAuthenticationStateAsync();
        branchID = int.Parse(authprov.User.Claims.First(x => x.Type == "BranchID").Value);
        var user = authprov.User;
        UserID = user.Identity.Name;
        if (model.PaymentMemoID != null)
        {
            model.Bills = Iservice.GetBills(model.PaymentMemoID.Value).ToList();
        }
        else
        {
            model.BranchID = branchID;
            model.BusinessNature = "Supplier";
        }
        GetBills();

        DocNumber = model.DocumentNumber;
        DocDate = model.DocumentDate;
        DocType = model.NatureOfTransaction;
    }

    protected override void OnParametersSet()
    {
        editContext = new EditContext(model);
        DocumentDetails.DocumentTypeID = PaymentDocTypeID;
        DocumentDetails.DocumentID = model.PaymentMemoID;
    }

    protected async Task Approve(DataApprovedStatus aprvd)
    {
        if (HasPermissionPaymentServiceApprove)
        {
            if (aprvd.IsApprove)
            {
                try
                {
                    model.UserInfo.UserID = UserID;
                    Iservice.Approve(model.PaymentMemoID, model.UserInfo.UserID, aprvd.Remarks);
                    snackbar.Add("Approved Successfully", Severity.Success);
                }
                catch (Exception ex)
                {
                    snackbar.Add(ex.Message, Severity.Error);
                }
            }
        }
        else
        {
            bool? result = await DialogService.ShowMessageBox(
                "Permission denied!",
                "You dont have any permission to Approve Payment.");
        }
    }

    private void GetBills()
    {
        List<OutstandingBillsModel> collection = new List<OutstandingBillsModel>();

        if (model?.PartyInfo?.PartyID != null)
        {
            collection = OBIservice.SelectByParty(model.PartyInfo.PartyID, branchID).ToList();
        }
    }

    private async Task OnValidSubmit(EditContext context)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is being submitted!", Severity.Warning);
            return;
        }
        _busy = true;

        if (HasPermissionPaymentServiceEdit)
        {
            try
            {
                model.UserInfo.UserID = UserID;
                model.PartyCoaID = partyService.GetPartyCoaID(model.PartyInfo.PartyID, model.BusinessNature, model.NatureOfTransaction);
                if (model.PartyCoaID == null)
                {
                    throw new Exception("Party Account is not mapped for " + model.NatureOfTransaction + "!");
                }
                model = Iservice.Update(model);
                snackbar.Add("Submitted Successfully", Severity.Success);
                dialogForm.Close(model);
            }
            catch (Exception ex)
            {
                snackbar.Add(ex.Message, Severity.Error);
            }
        }
        else
        {
            bool? result = await DialogService.ShowMessageBox(
                "Permission denied!",
                "You dont have any permission to Edit Payment.");
        }
        await Task.Delay(200);
        _busy = false;
    }

    private void SetTotalAmt()
    {
        model.TotalAmount = (model.Bills.Sum(x => x.PayAmount) ?? 0);
    }

    async Task nbusinesschanged(string val)
    {
        model.BusinessNature = val;
        await PartyChanged(null);
    }

    async Task PartyChanged(PartyModel party)
    {
        model.PartyInfo = party;
        await nTransactionChanged(null);
    }

    private async Task nTransactionChanged(string nt)
    {
        model.NatureOfTransaction = nt;
        if (nt == "Payment")
        {
            await OpenOutstandingBills();
        }
        else
        {
            model.Bills.Clear();
        }
    }

    private async Task OpenOutstandingBills()
    {
        DialogOptions Doptions = new DialogOptions() { MaxWidth = MaxWidth.Large, FullWidth = true };
        DialogParameters parms = new DialogParameters();
        parms.Add("PartyID", model.PartyInfo.PartyID);
        parms.Add("BranchID", branchID);
        var dialog = DialogService.Show<OutstandingBillView>("Outstanding Bill", parms, Doptions);
        var result = await dialog.Result;
        if (!result.Canceled)
        {
            List<OutstandingBillsModel> SelectedItems = new List<OutstandingBillsModel>();
            SelectedItems = (List<OutstandingBillsModel>)result.Data;
            model.Bills.Clear();
            foreach (var item in SelectedItems)
            {
                model.Bills.Add(new BillsPaidModel()
                    {
                        MID = item.MID,
                        BranchName = item.BranchName,
                        InvoiceDate = item.ReferenceDocDate,
                        InvoiceNumber = item.ReferenceDocNo,
                        OutstandingAmount = item.OutstandingAmount,
                        PayAmount = -(item.OutstandingAmount)
                    });
            }
            model.Reference = string.Join(",", SelectedItems.Select(x => x.ReferenceDocNo));
        }
        if (!model.Bills.Any())
        {
            model.NatureOfTransaction = null;
        }
    }
}