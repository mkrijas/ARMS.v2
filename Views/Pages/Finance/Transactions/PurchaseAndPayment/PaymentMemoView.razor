@page "/PaymentMemoView"
@page "/PaymentMemoView/{id:int}"
@inherits ViewComponentBase<PaymentMemoModel>
@inject IDialogService DialogService
@inject IPaymentService Iservice
@inject IPaymentInitiatedService IinitiateService


@if (_isLoading)
{
    <div @key="@("loader")" style="display: flex; justify-content: center; align-items: center; min-height: 400px;">
        <LoaderComponent IsFullScreen="true" 
                        ShowLogo="false" 
                        Size="medium" 
                        LoadingText="Loading Payment Memos" 
                        SubText="Please wait..." />
    </div>
}
else
{
    <div @key="@("content")">
<div class="fade-in">
    <div class="admin-header-tiered mb-6">
        <div class="d-flex align-center justify-space-between">
            <div>
                <MudText Typo="Typo.h4" Class="admin-title">Payment Memos</MudText>
                <MudText Typo="Typo.body2" Class="admin-subtitle">Process and manage payment memos for vendors and parties with integrated verification workflows.</MudText>
            </div>
            <MudButton StartIcon="@Icons.Material.Filled.Add" Variant="Variant.Filled" Color="Color.Primary" Class="admin-register-btn" OnClick="@(()=> OpenForm(new PaymentMemoModel(),false))" Disabled="@_busy">NEW PAYMENT MEMO</MudButton>
        </div>
    </div>

    <div class="admin-glass-card mb-6 pa-4">
        <div class="d-flex align-center gap-4 flex-wrap">
            <div style="flex-grow: 1; min-width: 300px;">
                <MudTextField @bind-Value="searchTerm" Placeholder="Search by memo #, party, or purpose..." Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" Variant="Variant.Outlined" Margin="Margin.Dense" Class="admin-input-group" Clearable="true" OnKeyUp="HandleSearchKeyUp" />
            </div>
            <div class="d-flex align-center gap-4">
                <MudTextField @bind-Value="@NumberOfRecords" Label="Max Records" Variant="Variant.Outlined" Margin="Margin.Dense" Style="width: 100px;" Dense="true" />
                <MudCheckBox T="bool" Label="Approved Entries" ValueChanged="((bool value)=>ToggleData(value))" Value="@ShowApproved" Size="Size.Small" Color="Color.Primary" Class="fw-600" />
            </div>
        </div>
    </div>

    <div class="admin-glass-card pa-0 overflow-hidden">
        <MudTable Items="@collection" Elevation="0" T="PaymentMemoModel" Class="modern-admin-table" Hover="true">
            <HeaderContent>
                <MudTh><MudTableSortLabel SortBy="new Func<PaymentMemoModel, object>(x=> x.DocumentDate)"><span class="admin-header-text">DATE</span></MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<PaymentMemoModel, object>(x=> x.PaymentMemoID)" InitialDirection="SortDirection.Descending"><span class="admin-header-text">MEMO NUMBER</span></MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<PaymentMemoModel, object>(x=> x.PartyInfo.TradeName)"><span class="admin-header-text">PARTY / VENDOR</span></MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<PaymentMemoModel, object>(x=> x.Reference)"><span class="admin-header-text">PURPOSE</span></MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<PaymentMemoModel, object>(x=> x.TotalAmount)"><span class="admin-header-text">AMOUNT</span></MudTableSortLabel></MudTh>
                <MudTh Style="text-align: right;"><span class="admin-header-text">ACTIONS</span></MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Date">
                    <div class="d-flex flex-column">
                        <span class="fw-500">@context.DocumentDate?.ToString("dd MMM yyyy")</span>
                        @if (context.AuthLevelId == 100)
                        {
                            <MudText Typo="Typo.caption" Color="Color.Error" Class="fw-700">REJECTED</MudText>
                        }
                    </div>
                </MudTd>
                <MudTd DataLabel="Docnum"><span class="admin-td-primary fw-700">@context.DocumentNumber</span></MudTd>
                <MudTd DataLabel="PartyName"><span class="fw-600">@context.PartyInfo.TradeName</span></MudTd>
                <MudTd DataLabel="Purpose">@context.Reference</MudTd>
                <MudTd DataLabel="TotalAmount">
                    <MudChip T="string" Size="Size.Small" Color="Color.Success" Variant="Variant.Text" Class="fw-700">@context.TotalAmount?.ToString("N2")</MudChip>
                </MudTd>
                <MudTd DataLabel="Actions" Style="text-align: right;">
                    @if (@context.AuthLevelId == 99)
                    {
                        @if (context.MID != null)
                        {
                            <EntryReversedComponent DocTypeID="DocInfo.DocumentTypeID" DocumentID="context.PaymentMemoID" MID="context.MID" DocumentNumber="@context.DocumentNumber"></EntryReversedComponent>
                        }
                        else
                        {
                            <MudTooltip Text="Reverse Entry">
                                <MudIconButton @onclick="@(()=> DeleteNoMID(context.PaymentMemoID))" Color="Color.Error" Icon="@Icons.Material.Filled.ArrowBack" Size="Size.Small" Variant="Variant.Text" />
                            </MudTooltip>
                        }
                        <MudTooltip Text="Print Memo">
                            <MudIconButton OnClick="@(()=> Print(context.PaymentMemoID))" Color="Color.Tertiary" Icon="@Icons.Material.Filled.Print" Size="Size.Small" Variant="Variant.Text" />
                        </MudTooltip>
                    }
                    else if (@context.AuthLevelId != 100)
                    {
                        <MudTooltip Text="Verify Memo">
                            <MudIconButton OnClick="@(()=> OpenForm(context,true))" Color="Color.Warning" Icon="@Icons.Material.Filled.Verified" Size="Size.Small" Variant="Variant.Text" />
                        </MudTooltip>
                    }

                    <MudTooltip Text="View Details">
                        <MudIconButton OnClick="@(()=> OpenForm(context,true))" Color="Color.Info" Icon="@Icons.Material.Filled.Visibility" Size="Size.Small" Variant="Variant.Text" />
                    </MudTooltip>
                    
                    <MudTooltip Text="Edit Memo">
                        <MudIconButton Disabled="@(context.AuthLevelId != null)" OnClick="@(()=> OpenForm(context,false))" Color="Color.Primary" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Variant="Variant.Text" />
                    </MudTooltip>

                    <MudTooltip Text="Remove Memo">
                        <MudIconButton Disabled="@(context.AuthLevelId != null)" OnClick="@(()=> Delete(context.PaymentMemoID))" Color="Color.Error" Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Variant="Variant.Text" />
                    </MudTooltip>
                </MudTd>
            </RowTemplate>
            <PagerContent>
                <div class="pa-4">
                    <MudTablePager PageSizeOptions="new int[] { 10, 20, 50, 100 }" />
                </div>
            </PagerContent>
        </MudTable>
    </div>
</div>

</div>
}

@code {

    private bool _isLoading = true;
    private DateTime _loadStartTime;


    protected override List<PaymentMemoModel> collection { get; set; } = new List<PaymentMemoModel>();

    protected override DocumentInfoModel DocInfo { get; set; } = new DocumentInfoModel()
        {
            DocumentTypeID = 7,
            DocumentName = "PaymentMemo"
        };

    // Lifecycle method called when the component is initialized
    protected override async Task OnInitializedAsync()
    {
        _loadStartTime = DateTime.Now;
        await base.OnInitializedAsync();

        if (id != null && collection != null && collection.Any(g => g.PaymentMemoID == id))
        {
            await OpenForm(collection.FirstOrDefault(s => s.PaymentMemoID == id), true);
        }
        await EnsureMinimumLoadTime();
        _isLoading = false;
    }

    private async Task EnsureMinimumLoadTime()
    {
        var elapsed = (DateTime.Now - _loadStartTime).TotalMilliseconds;
        if (elapsed < 100)
        {
            await Task.Delay(100 - (int)elapsed);
        }
    }

    // Method to delete a payment memo if there are no financial entries against it
    private async Task DeleteNoMID(int? PaymentMemoID)
    {
        try
        {
            bool? result = await DialogService.ShowMessageBoxAsync(
                "Warning !",
                "There are no Financial entries against this entry. Are you sure, you want to delete ?");
            if (result == true)
            {
                Iservice.Delete(PaymentMemoID, UserID); // Call the service to delete the payment memo
                snackbar.Add("Deleted Successfully", Severity.Success);
                LoadData(ShowApproved, NumberOfRecords);
            }
        }
        catch (Exception ex)
        {
            snackbar.Add(ex.Message, Severity.Warning);
        }
    }

    // Method to open the payment memo form for adding or editing
    protected override async Task OpenForm(PaymentMemoModel ppm, bool ReadOnly, bool DisableAddition = false)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        _busy = true;
        ppm.IsInterBranch = interbranch;
        DialogParameters parms = new DialogParameters();
        parms.Add("model", ppm.Clone());
        parms.Add("ReadOnly", ReadOnly);
        parms.Add("OnApproved", new EventCallbackFactory().Create(this, () => LoadData(ShowApproved, NumberOfRecords)));
        var dialog = await dialogService.ShowAsync<PaymentMemoDialog>(ppm.PaymentMemoID == null ? "ADD" : "EDIT", parms, new DialogOptions() { MaxWidth = MaxWidth.Large, FullWidth = true });
        var result = await dialog.Result;
        if (!result.Canceled)
        {
            var ReturnData = (PaymentMemoModel)result.Data;
        }
        LoadData(ShowApproved, NumberOfRecords);
        await Task.Delay(200);
        _busy = false;
    }

    // Method to print the payment memo
    private async Task Print(int? ID)
    {
        Dictionary<string, string> ReportParameters = new();
        ReportParameters.Add("ID", ID.ToString());
        ReportParameters.Add("Operation", "Memo");
        var parameters = new DialogParameters();
        parameters.Add("Parameters", ReportParameters); // Add the dictionary as a parameter
        parameters.Add("ReportName", "PrintPaymentMemo");

        DialogOptions maxWidth = new DialogOptions() { MaxWidth = MaxWidth.Medium, FullWidth = true };
        var result = await DialogService.ShowAsync<PrintDialog>("PRINT", parameters, maxWidth);
    }
}
