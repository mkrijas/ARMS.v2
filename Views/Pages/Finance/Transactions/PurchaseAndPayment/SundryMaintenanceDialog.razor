@inherits DialogFormComponentBase<SundryMaintenanceModel>

@inject ISundryMaintenanceService Iservice
@inject IGstItemService gstitemIservice
@inject ITdsRateService tdsIService


<DialogForm @ref="@dialogForm" ReadOnly="@ReadOnly" Title="Sundry Maintenance" Subtitle="Record maintenance services, repair jobs, and associated GST/TDS allocations." Icon="@Icons.Material.Filled.Build" AdminStyle="true" formID="formSundryMain" DocumentDetails="DocInfo" OnFileRemoved="RemoveFileChange" model="@model" _busy="_busy">
    <FormContent>
        <div class="dialog-content-wrapper">
            <EditForm autocomplete="off" id="formSundryMain" OnValidSubmit="OnValidSubmit" EditContext="editContext">
                <ObjectGraphDataAnnotationsValidator />
                
                <div class="admin-glass-card pa-6 mb-6">
                    <span class="admin-section-label">Maintenance Context</span>
                    <MudGrid Spacing="3">
                        <MudItem xs="12" md="4">
                            <MudDatePicker ReadOnly="ReadOnly" Label="Document Date" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.DocumentDate)" DisableToolbar="true" Editable="true" @bind-Date="model.DocumentDate" DateFormat="dd/MM/yyyy" MaxDate="DateTime.Now" Class="admin-input-group" />
                        </MudItem>
                        <MudItem xs="12" md="4">
                            <PartySelector Value="model.PartyInfo" For="@(()=> model.PartyInfo)" ValueChanged="PartyChanged" BranchID="BranchID" NatureOfBusiness="Supplier" IncludeRenter IncludeSisterConcern Class="admin-input-group"></PartySelector>
                            @if (model.PartyInfo != null)
                            {
                                <MudText Typo="Typo.caption" Class="ml-2 mt-1" Style="color: #667085;">
                                    <MudIcon Icon="@Icons.Material.Filled.Info" Size="Size.Small" Style="vertical-align: middle; margin-right: 4px;" />
                                    @model.PartyInfo?.GstRegType | @model.PartyInfo?.GstNo
                                </MudText>
                            }
                        </MudItem>
                        <MudItem xs="12" md="4">
                            <MudSelect Label="Service Type" @bind-Value="model.BreakDownType" Variant="Variant.Outlined" Margin="Margin.Dense" Class="admin-input-group">
                                @foreach (var ditem in BreakdownTypes)
                                {
                                    <MudSelectItem Value="@ditem">@ditem</MudSelectItem>
                                }
                            </MudSelect>
                        </MudItem>
                        <MudItem xs="12">
                            <MudTextField ReadOnly="ReadOnly" @bind-Value="model.Narration" Lines="3" Label="Narration / General Notes" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.Narration)" Class="admin-input-group"></MudTextField>
                        </MudItem>
                    </MudGrid>
                </div>

                <div class="admin-glass-card pa-0 overflow-hidden">
                    <div class="px-6 py-4 border-bottom-subtle" style="background: rgba(255, 159, 67, 0.02);">
                        <span class="admin-section-label mb-0">Service Breakdown</span>
                    </div>
                    <div class="modern-admin-table">
                        <MudGrid Class="admin-table-header px-6 py-3">
                            <MudItem xs="3"><span class="admin-header-text">JOB / USAGE</span></MudItem>
                            <MudItem xs="2"><span class="admin-header-text">INVOICE DT & NO</span></MudItem>
                            <MudItem xs="2"><span class="admin-header-text">TRUCK / LOCATION</span></MudItem>
                            <MudItem xs="2"><span class="admin-header-text">COST & DIMENSION</span></MudItem>
                            <MudItem xs="1"><span class="admin-header-text">AMOUNT</span></MudItem>
                            <MudItem xs="1"><span class="admin-header-text">TAXES</span></MudItem>
                            <MudItem xs="1"><span class="admin-header-text">ACTION</span></MudItem>
                        </MudGrid>

                        @if (model.Entries is not null && model.Entries.Any())
                        {
                            @foreach (var item in model.Entries)
                            {
                                <MudGrid Class="px-6 py-3 border-bottom-subtle align-center">
                                    <MudItem xs="3">
                                        <MudText Typo="Typo.body2" Style="font-weight: 700;">@item.JobTitle</MudText>
                                        <MudText Typo="Typo.caption" Style="color: #667085;">@item.UsageCode | @item.UsageCodeDescription</MudText>
                                    </MudItem>
                                    <MudItem xs="2">
                                        <MudText Typo="Typo.body2">@item.InvoiceDate?.ToString("dd/MM/yyyy")</MudText>
                                        <MudText Typo="Typo.caption" Style="font-family: monospace; color: #FF9F43;">#@item.InvoiceNo</MudText>
                                    </MudItem>
                                    <MudItem xs="2">
                                        <MudChip T="string" Size="Size.Small" Color="Color.Dark" Variant="Variant.Text" Icon="@Icons.Material.Filled.LocalShipping">@item.TruckRegNo</MudChip>
                                    </MudItem>
                                    <MudItem xs="2">
                                        <MudText Typo="Typo.caption" Style="display: block;">CC: @item.CostCenterVal</MudText>
                                        <MudText Typo="Typo.caption" Style="display: block;">DIM: @item.DimensionVal</MudText>
                                    </MudItem>
                                    <MudItem xs="1">
                                        <MudText Typo="Typo.body2" Style="font-weight: 700; color: #141A46;">₹ @item.Amount</MudText>
                                    </MudItem>
                                    <MudItem xs="1">
                                        <MudTooltip Text="GST Sum / TDS">
                                            <MudText Typo="Typo.caption" Style="color: #FF9F43; font-weight: 700;">₹ @(item.CGST + item.SGST + item.IGST)</MudText>
                                            <MudText Typo="Typo.caption" Style="color: #667085;">/ ₹ @item.TDS</MudText>
                                        </MudTooltip>
                                    </MudItem>
                                    <MudItem xs="1" Class="d-flex gap-1">
                                        @if (!ReadOnly)
                                        {
                                            <MudIconButton Title="Delete" Color="Color.Error" @onclick="@(()=> DeleteExpenses(@item))" Icon="@Icons.Material.Filled.Delete" Size="Size.Small" />
                                        }
                                        <MudIconButton Title="View Taxes" Color="Color.Info" @onclick="@(()=> OpenDialogTaxRates(@item))" Icon="@Icons.Material.Filled.ReceiptLong" Size="Size.Small" />
                                    </MudItem>
                                </MudGrid>
                            }
                        }

                        @if (!ReadOnly)
                        {
                            <div class="pa-5" style="background: rgba(255, 159, 67, 0.03); border-top: 1px solid rgba(255, 159, 67, 0.1);">
                                <MudGrid Spacing="2">
                                    <MudItem xs="12" md="3">
                                        <ServiceJobSelector ReadOnly="ReadOnly" Value="@_selectedJob" ValueChanged="JobSelected" Class="admin-input-group"></ServiceJobSelector>
                                    </MudItem>
                                    <MudItem xs="12" md="3">
                                        <UsageCodeSelector Value=gstusage ValueChanged="UsageCodeSelected" Class="admin-input-group"></UsageCodeSelector>
                                    </MudItem>
                                    <MudItem xs="6" md="2">
                                        <MudDatePicker ReadOnly="ReadOnly" Label="Invoice Date" Variant="Variant.Outlined" Margin="Margin.Dense" DisableToolbar="true" Editable="true" DateFormat="dd/MM/yyyy" @bind-Date="_entryModel.InvoiceDate" For="@(() => _entryModel.InvoiceDate)" Class="admin-input-group" />
                                    </MudItem>
                                    <MudItem xs="6" md="2">
                                        <MudTextField ReadOnly="ReadOnly" @bind-Value="_entryModel.InvoiceNo" Label="Invoice No" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => _entryModel.InvoiceNo)" Class="admin-input-group"></MudTextField>
                                    </MudItem>
                                    <MudItem xs="6" md="2">
                                        <TruckSelector IsDisabled="ReadOnly" Value="@_truck" ValueChanged="@truckChanged" Filter="All" Class="admin-input-group"></TruckSelector>
                                    </MudItem>
                                    <MudItem xs="6" md="2">
                                        <CostCenterSelector @bind-Value="@(_entryModel.CostCenter)" @bind-ValueText="@_entryModel.CostCenterVal" ReadOnly="@ReadOnly" Class="admin-input-group"></CostCenterSelector>
                                    </MudItem>
                                    <MudItem xs="6" md="2">
                                        <DimensionSelector @bind-Value="@(_entryModel.Dimension)" @bind-ValueText="@(_entryModel.DimensionVal)" ReadOnly="@ReadOnly" Class="admin-input-group"></DimensionSelector>
                                    </MudItem>
                                    <MudItem xs="6" md="2">
                                        <MudNumericField HideSpinButtons Label="Amount" @bind-Value="@_entryModel.Amount" Variant="Variant.Outlined" Margin="Margin.Dense" Class="admin-input-group" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.CurrencyRupee" AdornmentColor="Color.Primary"></MudNumericField>
                                    </MudItem>
                                    <MudItem xs="12" md="1" Class="d-flex align-center">
                                        <MudIconButton OnClick="ADD" Color="Color.Primary" Variant="Variant.Filled" Style="background: #FF9F43; border-radius: 10px; height: 45px; width: 50px; margin-top: 4px;" Icon="@Icons.Material.Filled.Add" Size="Size.Large" />
                                    </MudItem>
                                </MudGrid>
                            </div>
                        }
                    </div>
                </div>
            </EditForm>
        </div>
    </FormContent>
    <VerificationStatus>
        <AutherizationStatusComponent CreatedBy="@_model.UserInfo" DocTypeID="@DocInfo.DocumentTypeID" DocumentID="@model.ID" OnApprove="Approve"></AutherizationStatusComponent>
    </VerificationStatus>
</DialogForm>

@code {

    [Parameter]
    public override SundryMaintenanceModel model { get { return _model; } set { _model = value; DocInfo.DocumentID = value.ID; } }
    private SundryMaintenanceModel _model;


    GstUsageCodeModel gstusage = new();

    protected override DocumentInfoModel DocInfo { get; set; } = new DocumentInfoModel()
        {
            DocumentTypeID = 130,
            DocumentName = "SundryMaintenance"
        };

    public SundryMaintenanceEntryModel _entryModel { get; set; }
    private RepairJobModel _selectedJob;
    private TruckModel _truck { get; set; }

    private List<string> BreakdownTypes = new()
    { "Accident Claim", "Accident Non Claim", "Work Order", "General Service", "FC Work", "Periodic Service", "Special Work" , "Tyre Work", "Engine Work", "Body Work", "Gear Box Work", "Differential Work", "Clutch Work", "Battery"};
    // Lifecycle method called when the component is initialized
    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();
        if (model.ID == null)
        {
            model.BreakDownType = "General Service";
            model.NatureOfTransaction = DocInfo.DocumentName;
            model.BranchID = BranchID;
            if (model.PartyInfo != null)
                PartyChanged(model.PartyInfo);
        }
        else
        {
            model.PartyInfo = partyService.SelectByID(model.PartyInfo.PartyID); // Fetch party info
            model.Entries = Iservice.GetEntries(model.ID).ToList(); // Fetch entries related to the payment memo
        }
        model.NatureOfTransaction = "Sundry Maintenance";

        _entryModel = new SundryMaintenanceEntryModel()
            {
                BranchID = BranchID
            };
    }

    // Method to handle changes in the selected truck
    void truckChanged(TruckModel truck)
    {
        _truck = truck;
        _entryModel.TruckID = truck?.TruckID;
        _entryModel.TruckRegNo = truck?.RegNo;
    }

    // Method to handle selection of a repair job
    void JobSelected(RepairJobModel job)
    {
        _selectedJob = job;
        _entryModel.Job = job?.RepairJobID;
        _entryModel.JobTitle = job?.Title;
    }

    // Method to set the total amount based on entries
    void SetTotal()
    {
        model.TotalAmount = (model.Entries.Where(x => x != null).Sum(x => x.Amount + x.IGST + x.CGST + x.SGST) ?? 0);
    }

    // Method to handle changes in the selected party
    void PartyChanged(PartyModel party)
    {
        model.PartyInfo = party;
        if (party != null)
        {
            IsTaxable = party.GstType == "Registered" || party.GstType == "SEZ";
            Local = partyService.IsLocal(model.PartyInfo.PartyID, BranchID); // Check if the party is local
        } 
        else { Local = false; }
    }

    // Method to update the payment memo
    protected override async Task<int> Update(SundryMaintenanceModel editModel)
    {
        if (await validate(model))
        {
            model = Iservice.Update(model); // Update the model using the service
            return model.ID.Value;
        }
        return 0;
    }

    // Method to approve the payment memo
    protected override int UpdateApproval(DataApprovedStatus aprvd)
    {
        int result = Iservice.Approve(model.ID, model.UserInfo.UserID, aprvd.Remarks); // Call the service to approve
        return result;
    }

    async Task<bool> validate(SundryMaintenanceModel editModel)
    {
        return true;
    }

    // Method to add a new entry to the payment memo
    private void ADD()
    {
        if (model.Entries is null)
        {
            model.Entries = new();
        }
        editContext = new EditContext(_entryModel);
        editContext.EnableDataAnnotationsValidation();       

        if (AddTax() && editContext.Validate())
        {

            model.Entries.Add((SundryMaintenanceEntryModel)_entryModel.Clone());
            SetTotal();
            gstusage = null;
            _entryModel = new SundryMaintenanceEntryModel()
                {
                    BranchID = BranchID
                };
            _truck = null;
            _selectedJob = null;
        }
        else
        {
            editContext.NotifyValidationStateChanged();
        }
    }

    // Method to handle selection of a GST usage code
    void UsageCodeSelected(GstUsageCodeModel u)
    {
        gstusage = u;
        _entryModel.UsageCode = u?.UsageCode;
        _entryModel.CoaID = u?.CoaID;
        _entryModel.UsageCodeDescription = u?.Description;
    }
    
    // Method to open the tax rates dialog
    private async Task OpenDialogTaxRates(SundryMaintenanceEntryModel i)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        _busy = true;
        GstModel taxModel = new GstModel();
        taxModel.CGST = i.CGST;
        taxModel.IGST = i.IGST;
        taxModel.TDS = i.TDS;
        taxModel.SGST = i.SGST;
        taxModel.GstRate = i.GstRate;
        DialogParameters parms = new DialogParameters();
        parms.Add("tax", taxModel);
        parms.Add("ReadOnly", ReadOnly);
        var dialog = dialogService.Show<TaxRatedialog>(i.ID == null ? "ADD" : "EDIT", parms, new DialogOptions() { MaxWidth = MaxWidth.Small, FullWidth = true });
        var result = await dialog.Result;
        if (!result.Canceled)
        {
            taxModel = (GstModel)result.Data;
            i.CGST = taxModel.CGST;
            i.IGST = taxModel.IGST;
            i.TDS = Math.Round((taxModel.TDS??0),0);
            i.SGST = taxModel.SGST;
            i.GstRate = taxModel.GstRate;
            SetTotal();
        }
        await Task.Delay(200);
        _busy = false;
    }

    // Method to delete expenses from the payment memo
    private void DeleteExpenses(SundryMaintenanceEntryModel i)
    {
        int rowIndex = model.Entries.IndexOf(i);
        model.Entries.RemoveAt(rowIndex);
        SetTotal();
    }

    // Method to add tax to the entry model
    private bool AddTax()
    {
        if (gstusage != null && _entryModel.Amount != null)
        {
            if (model.PartyInfo == null)
            {
                snackbar.Add("select party", Severity.Error);
                return false;
            }

            // Get the GST rate for the selected usage code
            _entryModel.GstRate = usageCodeService.GetGstRate(_entryModel.UsageCode, DateTime.Now) ?? 0;

            // Get the TDS rate for the selected party and COA ID
            decimal tdsRate = tdsIService.GetTdsRate(model.PartyInfo.PartyID, _entryModel.CoaID);
            _entryModel.TDS = Math.Round((_entryModel.Amount.Value * tdsRate) / 100, MidpointRounding.AwayFromZero);
            if (!IsTaxable)
            {
                return true;
            }

            decimal taxRate = _entryModel.GstRate.Value;
            if (!Local)
            {
                _entryModel.IGST = Math.Round(_entryModel.Amount.Value * taxRate / 100, 2);
            }
            else
            {
                _entryModel.SGST = _entryModel.CGST = Math.Round(_entryModel.Amount.Value * taxRate / 200, 2);
            }

            return true;
        }
        return false;
    }
}
