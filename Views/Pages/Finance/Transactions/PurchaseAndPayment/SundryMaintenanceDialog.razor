@inherits DialogFormComponentBase<SundryMaintenanceModel>

@inject ISundryMaintenanceService Iservice
@inject IGstItemService gstitemIservice
@inject ITdsRateService tdsIService


<DialogForm @ref="@dialogForm" ReadOnly="@ReadOnly" Title="Sundry Maintenance" formID="formSundryMain" DocumentDetails="DocInfo" OnFileRemoved="RemoveFileChange" model="@model" _busy="_busy">
    <FormContent>
        <MudPaper Class="p-3">
            <EditForm autocomplete="off" id="formSundryMain" OnValidSubmit="OnValidSubmit" EditContext="editContext">
                <ObjectGraphDataAnnotationsValidator />
                <ValidationSummary />
                <MudGrid>
                    <MudItem xs="12" md="6">
                        <MudDatePicker ReadOnly="ReadOnly" Label="Document Date" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.DocumentDate)" DisableToolbar="true" Editable="true" @bind-Date="model.DocumentDate" DateFormat="dd/MM/yyyy" MaxDate="DateTime.Now" />
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <PartySelector Value="model.PartyInfo" For="@(()=> model.PartyInfo)" ValueChanged="PartyChanged" BranchID="BranchID" NatureOfBusiness="Supplier" IncludeRenter IncludeSisterConcern></PartySelector>
                        <MudText Typo="Typo.caption"> @model.PartyInfo?.GstRegType  @model.PartyInfo?.GstNo</MudText>
                    </MudItem>
                    <MudItem xs="12" md="12">
                        <MudTextField ReadOnly="ReadOnly" @bind-Value="model.Narration" Lines="2" Label="Narration" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.Narration)"></MudTextField>
                    </MudItem>
                    <MudItem xs="12">
                        <MudTextField Disabled @bind-Value="model.BreakDownType" Label="Service Type" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.BreakDownType)"></MudTextField>
                    </MudItem>
                    <MudItem xs="12" Style="overflow-x:auto; overflow-y:hidden;">
                        <h6><u>Particulars</u></h6>
                        <div style="width: 1600px;" class="pb-3">
                            <MudGrid Justify="Justify.Center">
                                @if (model.Entries is not null && model.Entries.Any())
                                {
                                    <MudItem xs="3"><span class="HeadText">Usage Code</span></MudItem>
                                    <MudItem xs="1"><span class="HeadText">InvoiceRef</span></MudItem>
                                    <MudItem xs="2"><span class="HeadText">Job</span></MudItem>
                                    <MudItem xs="1"><span class="HeadText">Truck</span></MudItem>
                                    <MudItem xs="1"><span class="HeadText">Cost Center</span></MudItem>
                                    <MudItem xs="1"><span class="HeadText">Dimension</span></MudItem>
                                    <MudItem xs="1"><span class="HeadText">Amount</span></MudItem>
                                    <MudItem xs="1"><span class="HeadText">Gst/TDS</span></MudItem>
                                    <MudItem xs="1"><span class="HeadText">Actions</span></MudItem>
                                    @foreach (var item in model.Entries)
                                    {
                                        <MudItem xs="3">@string.Format("{0} | {1}", item.UsageCode, item.UsageCodeDescription)</MudItem>
                                        <MudItem xs="1">@item.InvoiceNo</MudItem>
                                          <MudItem xs="2">
                                            @item.JobTitle
                                        </MudItem>
                                        <MudItem xs="1">
                                            @item.TruckRegNo
                                        </MudItem>
                                        <MudItem xs="1">
                                            @item.CostCenterVal
                                        </MudItem>
                                        <MudItem xs="1">
                                            @item.DimensionVal
                                        </MudItem>
                                        <MudItem xs="1">@item.Amount</MudItem>
                                        <MudItem xs="1">@(item.CGST + item.SGST + item.IGST)/@item.TDS</MudItem>
                                        <MudItem xs="1">
                                            @if (!ReadOnly)
                                            {
                                                <MudIconButton Title="Delete" Color="Color.Error" @onclick="@(()=> DeleteExpenses(@item))" Icon="@Icons.Material.Filled.Delete" Size="Size.Small" />
                                            }
                                            <MudIconButton Title="Show Taxes" Color="Color.Info" @onclick="@(()=> OpenDialogTaxRates(@item))" Icon="@Icons.Material.Filled.CurrencyExchange" Size="Size.Small" />
                                        </MudItem>
                                    }
                                }
                                @if (!ReadOnly)
                                {
                                    <MudItem xs="12" Class="d-flex gap-4">
                                        <UsageCodeSelector Value=gstusage ValueChanged="UsageCodeSelected"></UsageCodeSelector>                                   
                                        <MudDatePicker ReadOnly="ReadOnly" Label="Invoice Date" Variant="Variant.Outlined" Margin="Margin.Dense" DisableToolbar="true" Editable="true" DateFormat="dd/MM/yyyy" @bind-Date="_entryModel.InvoiceDate" For="@(() => _entryModel.InvoiceDate)" />
                                        <MudTextField ReadOnly="ReadOnly" @bind-Value="_entryModel.InvoiceNo" Label="Invoice No" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => _entryModel.InvoiceNo)"></MudTextField>
                                        <ServiceJobSelector ReadOnly="ReadOnly" Value="@_selectedJob" ValueChanged="JobSelected"></ServiceJobSelector>
                                        <TruckSelector IsDisabled="ReadOnly" BranchID="@BranchID" Value="@_truck" ValueChanged="@truckChanged"></TruckSelector>
                                        <CostCenterSelector @bind-Value="@(_entryModel.CostCenter)" @bind-ValueText="@_entryModel.CostCenterVal" ReadOnly="@ReadOnly"></CostCenterSelector>
                                        <DimensionSelector @bind-Value="@(_entryModel.Dimension)" @bind-ValueText="@(_entryModel.DimensionVal)" ReadOnly="@ReadOnly"></DimensionSelector>
                                        <MudNumericField HideSpinButtons Label="Amount" @bind-Value="@_entryModel.Amount" Variant="Variant.Outlined" Margin="Margin.Dense"></MudNumericField>
                                        <MudIconButton Title="Add" OnClick="ADD" Color="Color.Primary" Icon="@Icons.Material.Filled.Add" Size="Size.Small" />
                                    </MudItem>
                                }
                            </MudGrid>
                        </div>
                    </MudItem>
                </MudGrid>
            </EditForm>
        </MudPaper>
    </FormContent>
    <VerificationStatus>
        <AutherizationStatusComponent CreatedBy="@_model.UserInfo" DocTypeID="@DocInfo.DocumentTypeID" DocumentID="@model.ID" OnApprove="Approve"></AutherizationStatusComponent>
    </VerificationStatus>
</DialogForm>

@code {

    [Parameter]
    public override SundryMaintenanceModel model { get { return _model; } set { _model = value; DocInfo.DocumentID = value.ID; } }
    private SundryMaintenanceModel _model;


    GstUsageCodeModel gstusage = new();

    protected override DocumentInfoModel DocInfo { get; set; } = new DocumentInfoModel()
        {
            DocumentTypeID = 130,
            DocumentName = "SundryMaintenance"
        };

    public SundryMaintenanceEntryModel _entryModel { get; set; }
    private RepairJobModel _selectedJob;
    private TruckModel _truck { get; set; }


    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();
        if (model.ID == null)
        {
            model.BreakDownType = "General Service";
            model.NatureOfTransaction = DocInfo.DocumentName;
            model.BranchID = BranchID;
            if (model.PartyInfo != null)
                PartyChanged(model.PartyInfo);
        }
        else
        {
            model.PartyInfo = partyService.SelectByID(model.PartyInfo.PartyID);
            model.Entries = Iservice.GetEntries(model.ID).ToList();
        }
        model.NatureOfTransaction = "Sundry Maintenance";

        _entryModel = new SundryMaintenanceEntryModel()
            {
                BranchID = BranchID
            };
    }

    void truckChanged(TruckModel truck)
    {
        _truck = truck;
        _entryModel.TruckID = truck?.TruckID;
        _entryModel.TruckRegNo = truck?.RegNo;
    }

    void JobSelected(RepairJobModel job)
    {
        _selectedJob = job;
        _entryModel.Job = job?.RepairJobID;
        _entryModel.JobTitle = job?.Title;
    }

    void SetTotal()
    {
        model.TotalAmount = (model.Entries.Where(x => x != null).Sum(x => x.Amount + x.IGST + x.CGST + x.SGST) ?? 0);
    }
    void PartyChanged(PartyModel party)
    {
        model.PartyInfo = party;
        if (party != null)
        {
            IsTaxable = party.GstType == "Registered" || party.GstType == "SEZ";
            Local = partyService.IsLocal(model.PartyInfo.PartyID, BranchID);
        }
        else { Local = false; }
    }

    protected override async Task<int> Update(SundryMaintenanceModel editModel)
    {
        if (await validate(model))
        {
            model = Iservice.Update(model);
            return model.ID.Value;
        }
        return 0;
    }

    protected override int UpdateApproval(DataApprovedStatus aprvd)
    {
        int result = Iservice.Approve(model.ID, model.UserInfo.UserID, aprvd.Remarks);
        return result;
    }

    async Task<bool> validate(SundryMaintenanceModel editModel)
    {
        return true;
    }


    private void ADD()
    {
        if (model.Entries is null)
        {
            model.Entries = new();
        }
        editContext = new EditContext(_entryModel);
        editContext.EnableDataAnnotationsValidation();       

        if (AddTax() && editContext.Validate())
        {

            model.Entries.Add((SundryMaintenanceEntryModel)_entryModel.Clone());
            SetTotal();
            gstusage = null;
            _entryModel = new SundryMaintenanceEntryModel()
                {
                    BranchID = BranchID
                };
            _truck = null;
            _selectedJob = null;
        }
        else
        {
            editContext.NotifyValidationStateChanged();
        }
    }



    void UsageCodeSelected(GstUsageCodeModel u)
    {
        gstusage = u;
        _entryModel.UsageCode = u?.UsageCode;
        _entryModel.CoaID = u?.CoaID;
        _entryModel.UsageCodeDescription = u?.Description;
    }

    private async Task OpenDialogTaxRates(SundryMaintenanceEntryModel i)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        _busy = true;
        GstModel taxModel = new GstModel();
        taxModel.CGST = i.CGST;
        taxModel.IGST = i.IGST;
        taxModel.TDS = i.TDS;
        taxModel.SGST = i.SGST;
        taxModel.GstRate = i.GstRate;
        DialogParameters parms = new DialogParameters();
        parms.Add("tax", taxModel);
        parms.Add("ReadOnly", ReadOnly);
        var dialog = dialogService.Show<TaxRatedialog>(i.ID == null ? "ADD" : "EDIT", parms, new DialogOptions() { MaxWidth = MaxWidth.Small, FullWidth = true });
        var result = await dialog.Result;
        if (!result.Canceled)
        {
            taxModel = (GstModel)result.Data;
            i.CGST = taxModel.CGST;
            i.IGST = taxModel.IGST;
            i.TDS = Math.Round((taxModel.TDS??0),0);
            i.SGST = taxModel.SGST;
            i.GstRate = taxModel.GstRate;
            SetTotal();
        }
        await Task.Delay(200);
        _busy = false;
    }

    private void DeleteExpenses(SundryMaintenanceEntryModel i)
    {
        int rowIndex = model.Entries.IndexOf(i);
        model.Entries.RemoveAt(rowIndex);
        SetTotal();
    }

    private bool AddTax()
    {
        if (gstusage != null && _entryModel.Amount != null)
        {
            if (model.PartyInfo == null)
            {
                snackbar.Add("select party", Severity.Error);
                return false;
            }
            _entryModel.GstRate = usageCodeService.GetGstRate(_entryModel.UsageCode, DateTime.Now) ?? 0;
            decimal tdsRate = tdsIService.GetTdsRate(model.PartyInfo.PartyID, _entryModel.CoaID);
            _entryModel.TDS = Math.Round((_entryModel.Amount.Value * tdsRate) / 100, MidpointRounding.AwayFromZero);
            if (!IsTaxable)
            {
                return true;
            }

            decimal taxRate = _entryModel.GstRate.Value;
            if (!Local)
            {
                _entryModel.IGST = Math.Round(_entryModel.Amount.Value * taxRate / 100, 2);
            }
            else
            {
                _entryModel.SGST = _entryModel.CGST = Math.Round(_entryModel.Amount.Value * taxRate / 200, 2);
            }

            return true;
        }
        return false;
    }
}