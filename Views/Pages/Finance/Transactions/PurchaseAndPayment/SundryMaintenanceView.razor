@page "/SundryMaintenance"
@page "/SundryMaintenance/{id:int}"
@using Inventory.GoodsReceipt
@inherits ViewComponentBase<SundryMaintenanceModel>
@inject ISundryMaintenanceService Iservice

@if (_isLoading)
{
    <div @key="@("loader")" style="display: flex; justify-content: center; align-items: center; min-height: 400px;">
        <LoaderComponent IsFullScreen="true" 
                        ShowLogo="false" 
                        Size="medium" 
                        LoadingText="Loading Sundry Maintenance Expenses" 
                        SubText="Please wait..." />
    </div>
}
else
{
    <div @key="@("content")">
<div class="fade-in">
    <div class="admin-header-tiered mb-6">
        <div class="d-flex align-center justify-space-between">
            <div>
                <MudText Typo="Typo.h4" Class="admin-title">Sundry Maintenance Expenses</MudText>
                <MudText Typo="Typo.body2" Class="admin-subtitle">Record and audit miscellaneous maintenance expenses. Link costs to specific service types and parties with integrated verification.</MudText>
            </div>
            <MudButton StartIcon="@Icons.Material.Filled.Add" Variant="Variant.Filled" Color="Color.Primary" Class="admin-register-btn" OnClick="@(()=> OpenForm(new SundryMaintenanceModel(),false))" Disabled="@_busy">NEW MAINTENANCE ENTRY</MudButton>
        </div>
    </div>

    <div class="admin-glass-card mb-6 pa-4">
        <div class="d-flex align-center gap-4 flex-wrap">
            <div style="flex-grow: 1; min-width: 300px;">
                <MudTextField @bind-Value="searchTerm" Placeholder="Search by party, service type or document number..." Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" Variant="Variant.Outlined" Margin="Margin.Dense" Class="admin-input-group" Clearable="true" OnKeyUp="HandleSearchKeyUp" />
            </div>
            <div class="d-flex align-center gap-4">               
                <MudCheckBox T="bool" Label="Approved Entries" ValueChanged="((bool value)=>ToggleData(value))" Value="@ShowApproved" Size="Size.Small" Color="Color.Primary" Class="fw-600" />
            </div>
        </div>
    </div>

    <div class="admin-glass-card pa-0 overflow-hidden">
                <MudTable ServerData="LoadServerData" T="SundryMaintenanceModel" @ref="_table" Elevation="0" Class="modern-admin-table" Hover="true">
            <HeaderContent>
                <MudTh><MudTableSortLabel SortBy="new Func<SundryMaintenanceModel, object>(x=> x.BreakDownType)"><span class="admin-header-text">SERVICE TYPE</span></MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<SundryMaintenanceModel, object>(x=> x.PartyInfo.TradeName)"><span class="admin-header-text">PARTY NAME</span></MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<SundryMaintenanceModel, object>(x=> x.DocumentDate)"><span class="admin-header-text">DATE</span></MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<SundryMaintenanceModel, object>(x=> x.ID)" InitialDirection="SortDirection.Descending"><span class="admin-header-text">DOC NUMBER</span></MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<SundryMaintenanceModel, object>(x=> x.TotalAmount)"><span class="admin-header-text">TOTAL AMOUNT</span></MudTableSortLabel></MudTh>
                <MudTh Style="text-align: right;"><span class="admin-header-text">ACTIONS</span></MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="ServiceType"><span class="fw-600">@context.BreakDownType</span></MudTd>
                <MudTd DataLabel="PartyName">@context.PartyInfo.TradeName</MudTd>
                <MudTd DataLabel="Date">@context.DocumentDate?.ToString("dd MMM yyyy")</MudTd>
                <MudTd DataLabel="DocNumber">
                    <div class="d-flex flex-column">
                        <span class="admin-td-primary fw-700">@context.DocumentNumber</span>
                        @if (context.AuthLevelId == 100)
                        {
                            <MudText Typo="Typo.caption" Color="Color.Error" Class="fw-700">REJECTED</MudText>
                        }
                    </div>
                </MudTd>
                <MudTd DataLabel="Amount">
                    <MudChip T="string" Size="Size.Small" Color="Color.Success" Variant="Variant.Text" Class="fw-700">@context.TotalAmount?.ToString("N2")</MudChip>
                </MudTd>
                <MudTd DataLabel="Actions" Style="text-align: right;">
                    @if (@context.AuthLevelId == 99)
                    {
                        <EntryReversedComponent DocTypeID="DocInfo.DocumentTypeID" TDS="context.TDS" DocumentID="context.ID" MID="context.MID" DocumentNumber="@context.DocumentNumber"></EntryReversedComponent>
                    }
                    else if (@context.AuthLevelId != 100)
                    {
                        <MudTooltip Text="Verify Entry">
                            <MudIconButton OnClick="@(()=> OpenForm(context,true))" Color="Color.Warning" Icon="@Icons.Material.Filled.Verified" Size="Size.Small" Variant="Variant.Text" />
                        </MudTooltip>
                    }

                    <MudTooltip Text="View Details">
                        <MudIconButton OnClick="@(()=> OpenForm(context,true))" Color="Color.Info" Icon="@Icons.Material.Filled.Visibility" Size="Size.Small" Variant="Variant.Text" />
                    </MudTooltip>
                    
                    <MudTooltip Text="Edit Entry">
                        <MudIconButton Disabled="@(context.AuthLevelId != null)" OnClick="@(()=> OpenForm(context,false))" Color="Color.Primary" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Variant="Variant.Text" />
                    </MudTooltip>

                    <MudTooltip Text="Remove Entry">
                        <MudIconButton Disabled="@(context.AuthLevelId != null)" OnClick="@(()=> Delete(context.ID))" Color="Color.Error" Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Variant="Variant.Text" />
                    </MudTooltip>
                </MudTd>
            </RowTemplate>
            <PagerContent>
                <div class="pa-4">
                    <MudTablePager PageSizeOptions="new int[] { 10, 20, 50, 100 }" />
                </div>
            </PagerContent>
        </MudTable>
    </div>
</div>
</div>

}

@code {

    private bool _isLoading = true;
    private DateTime _loadStartTime;

    protected override List<SundryMaintenanceModel> _collection { get; set; } = new List<SundryMaintenanceModel>();
    protected override DocumentInfoModel DocInfo { get; set; } = new DocumentInfoModel()
        {
            DocumentTypeID = 130,
            DocumentName = "SundryMaintenance"
        };

    // Lifecycle method called when the component is initialized
    protected override async Task OnInitializedAsync()
    {
        _loadStartTime = DateTime.Now;
        await base.OnInitializedAsync();

        if (id != null && _collection != null && _collection.Any(g => g.ID == id))
        {
            await OpenForm(_collection.FirstOrDefault(s => s.ID == id), true);
        }
        await EnsureMinimumLoadTime();
        _isLoading = false;
    }

    private async Task EnsureMinimumLoadTime()
    {
        var elapsed = (DateTime.Now - _loadStartTime).TotalMilliseconds;
        if (elapsed < 100)
        {
            await Task.Delay(100 - (int)elapsed);
        }
    }

    // Method to open the sundry maintenance form for adding or editing
    protected override async Task OpenForm(SundryMaintenanceModel ppm, bool ReadOnly, bool DisableAddition = false)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        _busy = true;
        DialogParameters parms = new DialogParameters();
        parms.Add("model", ppm.Clone());
        parms.Add("ReadOnly", ReadOnly);
        parms.Add("OnApproved", new EventCallbackFactory().Create(this, async() => await _table.ReloadServerData()));
        var dialog = await dialogService.ShowAsync<SundryMaintenanceDialog>(ppm.ID == null ? "ADD" : "EDIT", parms, new DialogOptions() { MaxWidth = MaxWidth.Large, FullWidth = true });
        var result = await dialog.Result;
        if (!result.Canceled)
        {
            var ReturnData = (SundryMaintenanceModel)result.Data;
            await _table.ReloadServerData();
        }   
        await Task.Delay(200);
        _busy = false;
    }
}
