@attribute [Authorize]
@inject AuthenticationStateProvider auth
@inject IDialogService DialogService
@inject MudBlazor.ISnackbar snackbar

@inject ITaxPurchaseService Iservice
@inject IInventoryGrnService grnIservice


@inject IPartyService partyIservice
@inject IInventoryItemService itemIservice
@inject IGstItemService gstitemIservice

@inject IInventoryGroupService inventoryGroupIservice


@*@inject IBranchService branchIservice*@

@inject ITdsRateService tdsIService

<DialogForm @ref="@dialogForm" ReadOnly="@ReadOnly" Title="Tax Purchase" formID="formTaxPurchase" model="@model">
    <FormContent>
         <MudPaper Class="p-3" >
        <EditForm id="formTaxPurchase" OnValidSubmit="OnValidSubmit" EditContext="editContext">
            <ObjectGraphDataAnnotationsValidator />
            <ValidationSummary />
            <MudGrid>
                <MudItem xs="12" md="6">
                    <MudDatePicker ReadOnly="ReadOnly" Label="Document Date" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.DocumentDate)" DisableToolbar="true" Editable="true" @bind-Date="model.DocumentDate" DateFormat="dd/MM/yyyy" />
                </MudItem>
                <MudItem xs="12" md="6">
                    <PartySelector Value="model.PartyInfo" For="@(()=> model.PartyInfo)"  ValueChanged="PartyChanged" NatureOfBusiness="Supplier" ></PartySelector>
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudDatePicker ReadOnly="ReadOnly" Label="Invoice Date" Variant="Variant.Outlined" Margin="Margin.Dense" DisableToolbar="true" Editable="true" DateFormat="dd/MM/yyyy" @bind-Date="model.InvoiceDate" For="@(() => model.InvoiceDate)" />
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudTextField ReadOnly="ReadOnly" @bind-Value="model.InvoiceNo" Label="Invoice No" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.InvoiceNo)"></MudTextField>
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudTextField ReadOnly="ReadOnly" @bind-Value="model.AdditionalTDS" Label="Additional TDS" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.AdditionalTDS)"></MudTextField>
                </MudItem>
                <MudItem xs="12" md="6">
                    <CostCenterSelector @bind-Value="@model.CostCenter" ReadOnly="@ReadOnly"></CostCenterSelector>
                </MudItem>
                <MudItem xs="12" md="6">
                    <DimensionSelector @bind-Value="@model.Dimension" ReadOnly="@ReadOnly"></DimensionSelector>
                </MudItem>
                <MudItem xs="12" md="12">
                    <MudTextField ReadOnly="ReadOnly" @bind-Value="model.Narration" Lines="2" Label="Narration" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.Narration)"></MudTextField>
                </MudItem>
                <MudItem xs="12">
                    <ExpenseListView OnExpenseAdded="AddExpense" OnDelete="SetTotal" BranchID="@branchID" PartyInfo="@model.PartyInfo" Local="@Local" ExpenseList="@model.Expenses" ReadOnly="@ReadOnly" />
                </MudItem >
                <MudItem xs="12">
                    <ItemsListView OnItemAdded="AddItems" OnDelete="SetTotal" BranchID="@branchID" PartyInfo="@model.PartyInfo" Local="@Local" ItemList="@model.Items" ReadOnly="@ReadOnly" />
                </MudItem>  
            </MudGrid>
        </EditForm>
    </MudPaper>
    </FormContent>
    <VerificationStatus>
        <AutherizationStatusComponent DocTypeID="@DocTypeID" DocumentID="@model.PID" OnApprove="ApproveEntry"></AutherizationStatusComponent>
    </VerificationStatus>
</DialogForm>


@code {

    [Parameter]
    public TaxPurchaseModel model { get; set; }
    [Parameter]
    public bool ReadOnly { get; set; }
    private int? branchID = null;
    private string UserID = null;
    private bool Local;

    private EditContext editContext;
    DialogForm dialogForm;
    int DocTypeID = 9;


    ValidationMessageStore messageStore;


    protected override async Task OnInitializedAsync()
    {
        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;
        branchID = int.Parse(user.Claims.First(x => x.Type == "BranchID").Value);
        UserID = user.Identity.Name;



        //List<InventoryItemEntryModel> iitem = new();
        //if (model.PID == null && model.GRNID != null)
        //{
        //    model.PartyInfo = partyIservice.SelectByID(model.PartyInfo.PartyID);
        //    iitem = grnIservice.GetItemEntries(model.GRNID.Value).ToList();

        //    foreach (var item in iitem)
        //    {
        //        InventoryItemModel iim = itemIservice.SelectByID(item.ItemID);
        //        model.Items.Add(new()
        //            {
        //                ItemID = item.ItemID,
        //                ItemQty = item.ItemQty,
        //                ItemRate = item.ItemRate,
        //                Amount = item.ItemQty * item.ItemRate,
        //                CoaID = iim.Group.MappedPurchaseHead,
        //            });
        //    }
        //}

        if (model.PID != null)
        {
            //model.PartyInfo = partyIservice.SelectByID(model.PartyInfo.PartyID);
            model.Expenses = Iservice.GetExpenses(model.PID).ToList();
            model.Items = Iservice.GetItems(model.PID).ToList();
        }
        else
        {
            model.NatureOfTransaction = "TaxPurchase";
            model.BranchID = branchID;            
            model.NonStoreInventory = model.GRNID == null;
        }
    }

    protected override void OnParametersSet()
    {
        if (editContext == null)
        {
            editContext = new EditContext(model);
        }
    }

    void SetTotal()
    {   
        model.TotalAmount = (model.Expenses.Sum(x => x.Amount) ?? 0) + (model.Items.Sum(y => y.Amount) ?? 0);
    }


    void PartyChanged(PartyModel party)
    {
        model.PartyInfo = party;
        if (party != null)
        {
            Local = partyIservice.IsLocal(model.PartyInfo.PartyID, branchID);
        }else{ Local = false; }
    }

    async Task AddExpense(TaxPurchaseExpenseModel expenseModel)
    {      
        model.Expenses.Add(expenseModel);   
        SetTotal();
    }

    async Task AddItems(TaxPurchaseItemModel ItemModel)
    {        
        model.Items.Add(ItemModel);
        SetTotal();
    }

    protected void ApproveEntry(DataApprovedStatus aprvd)
    {
        if (aprvd.IsApprove)
        {            
            Iservice.Approve(model.PID, UserID, aprvd.Remarks);
            snackbar.Add("Approved Successfully", Severity.Success);
        }
    }  

    private void OnValidSubmit(EditContext context)
    {        
        try
        {
            model.UserInfo.UserID = UserID;
            Iservice.Update(model);
            snackbar.Add("Saved Successfully", Severity.Success);
            dialogForm.Close(model);
            model = new();            
        }
        catch (Exception ex)
        {
            snackbar.Add(ex.Message, Severity.Error);
        }
    }
    
}
