@attribute [Authorize]
@inherits DialogFormComponentBase<TaxPurchaseModel>
@inject AuthenticationStateProvider auth
@inject ITaxPurchaseService Iservice
@inject IInventoryGrnService grnIservice
@inject IInventoryItemService itemIservice
@inject IGstItemService gstitemIservice
@inject IInventoryGroupService inventoryGroupIservice
@inject ITdsRateService tdsIService
@inject ITripFuelService Ifuelservice
@inject IJSRuntime JSRuntime

<DialogForm @ref="@dialogForm" ReadOnly="@ReadOnly" Title="Purchase" formID="formTaxPurchase" DocumentDetails="DocInfo" OnFileRemoved="RemoveFileChange" model="@model" _busy="_busy">
    <FormContent>
        <MudPaper Class="p-3">
            <EditForm autocomplete="off" id="formTaxPurchase" OnValidSubmit="OnValidSubmit" EditContext="editContext">
                <ObjectGraphDataAnnotationsValidator />
                <ValidationSummary />
                <MudGrid>
                    <MudItem xs="12" md="6">
                        <MudDatePicker Disabled="@Disable" ReadOnly="ReadOnly" Label="Document Date" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.DocumentDate)" DisableToolbar="true" Editable="true" @bind-Date="model.DocumentDate" DateFormat="dd/MM/yyyy" MaxDate="DateTime.Now" />
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <PartySelector Value="model.PartyInfo" For="@(()=> model.PartyInfo)" ValueChanged="PartyChanged" BranchID="BranchID"></PartySelector>
                        <MudText Typo="Typo.caption"> @model.PartyInfo?.GstRegType  @model.PartyInfo?.GstNo</MudText>
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudDatePicker ReadOnly="ReadOnly" Label="Invoice Date" Variant="Variant.Outlined" Margin="Margin.Dense" DisableToolbar="true" Editable="true" DateFormat="dd/MM/yyyy" @bind-Date="model.InvoiceDate" For="@(() => model.InvoiceDate)" />
                    </MudItem>
                    <MudItem xs="12" md="6">
                        @* <MudTextField ReadOnly="ReadOnly" @bind-Value="model.InvoiceNo" Label="Invoice No" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.InvoiceNo)"></MudTextField> *@
                        <MudTextField ReadOnly="ReadOnly" 
                            Value="model.InvoiceNo" 
                            T="string"
                            Immediate=true
                            Label="Invoice No" 
                            Variant="Variant.Outlined" 
                            Margin="Margin.Dense" 
                            For="@(() => model.InvoiceNo)"
                            ValueChanged="((e)=> OnInputChange(e))">
                        </MudTextField>
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudNumericField HideSpinButtons Label="Billed Amount" @bind-Value="TotalBillAmount" Variant="Variant.Outlined" Margin="Margin.Dense" Required></MudNumericField>
                    </MudItem>
                    <MudItem xs="12" md="12">
                        <MudTextField ReadOnly="ReadOnly" @bind-Value="model.Narration" Lines="2" Label="Narration" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.Narration)"></MudTextField>
                    </MudItem>
                    <MudItem xs="12">
                        <ExpenseListView OnExpenseAdded="AddExpense" OnAmountChange="SetTotal" BranchID="@BranchID" PartyInfo="@model.PartyInfo" Local="@Local" IsTaxable="@IsTaxable" ExpenseList="@model.Expenses" ReadOnly="@ReadOnly" />

                    </MudItem>
                    <MudItem xs="12">
                        <ItemsListView OnItemAdded="AddItems" OnAmountChange="SetTotal" BranchID="@BranchID" PartyInfo="@model.PartyInfo" Local="@Local" IsTaxable="@IsTaxable" ItemList="@model.Items" ReadOnly="@Disable" EditMode="@(model.PID != null)" NonInventory="@model.NonStoreInventory" />
                    </MudItem>
                    @if (model.Assets != null && model.Assets.Count > 0)
                    {
                        <MudItem xs="12">
                            <AssetsListViewForPurchase OnAssetAdded="AddAssets" OnAmountChange="SetTotal" BranchID="@BranchID" PartyInfo="@model.PartyInfo" Local="@Local" IsTaxable="@IsTaxable" AssetList="@model.Assets" ReadOnly="@ReadOnly" EditMode="@(model.PID != null)" />
                        </MudItem>
                    }
                </MudGrid>
            </EditForm>
        </MudPaper>
    </FormContent>
    <VerificationStatus>
        <AutherizationStatusComponent CreatedBy="@model.UserInfo" DocTypeID="@DocInfo.DocumentTypeID" DocumentID="@model.PID" OnReject="OnReject" OnApprove="Approve"></AutherizationStatusComponent>
    </VerificationStatus>
</DialogForm>

@code {

    [Parameter]
    public override TaxPurchaseModel model { get { return _model; } set { _model = value; } }
    private TaxPurchaseModel _model;
    private TripFuelModel fuelModel;
    bool Disable;
    int branchID;
    string UserID;
    string UserIDTemp;
    private decimal? TotalBillAmount;

    ValidationMessageStore messageStore;

    // Method to handle input changes for the invoice number
    private void OnInputChange(string value)
    {
        model.InvoiceNo = value.Replace(" ", string.Empty);
    }

    // Document information model for the tax purchase
    protected override DocumentInfoModel DocInfo { get; set; }

    // Lifecycle method called when the component is initialized
    protected override async Task OnInitializedAsync()
    {
        Console.WriteLine("Page loaded");
        DocInfo = GetDocumentInfoByType(model.TaxPurchaseType);
        DocInfo.DocumentID = model.PID;

        await base.OnInitializedAsync();

        if (model.PartyInfo != null)
        {
            PartyChanged(model.PartyInfo);
        }
        if (model.PID != null)
        {
            UserIDTemp = model.UserInfo.UserID;
            model.PartyInfo = partyService.SelectByID(model.PartyInfo.PartyID); // Fetch party info
            model.Expenses = Iservice.GetExpenses(model.PID).ToList(); // Fetch expenses related to the tax purchase
            model.Items = Iservice.GetItems(model.PID).ToList(); // Fetch items related to the tax purchase
            model.Assets = new List<AssetPOModel>();
            TotalBillAmount = model.TotalAmount;
        }
        else
        {
            model.NatureOfTransaction = "Purchase";
            model.BranchID = BranchID;
            model.NonStoreInventory = (model.GRNID ?? 0) == 0;
        }
        if (model.TaxPurchaseType == "Fuel" || ReadOnly)
        {
            Disable = true;
        }
    }

    private DocumentInfoModel GetDocumentInfoByType(string purchaseType)
    {
        return purchaseType switch
        {
            "Fuel" => new DocumentInfoModel { DocumentTypeID = 133, DocumentName = "FUEL PURCHASE" },
            "Maintenance" => new DocumentInfoModel { DocumentTypeID = 134, DocumentName = "MAINTENANCE PURCHASE" },
            _ => new DocumentInfoModel { DocumentTypeID = 9, DocumentName = "Purchase" }
        };
    }


    // Method to set the total amount based on expenses, items, and assets
    void SetTotal()
    {
        model.TotalAmount =
          (model.Expenses.Where(x => x != null).Sum(x => x.Amount) ?? 0)
        + (model.Expenses.Where(x => x != null && x.GstMechanism != "RCM").Sum(x => x.IGST + x.CGST + x.SGST) ?? 0)
        + (model.Items.Where(y => y != null).Sum(y => y.Amount + y.IGST + y.CGST + y.SGST) ?? 0)
        + (model.Assets.Where(z => z != null).Sum(z => z.BookValue) ?? 0)
        + (model.Assets.Where(z => z != null && z.GstMechanism != "RCM").Sum(z => z.GSTValue) ?? 0);
    }

    // Method to handle changes in the selected party
    void PartyChanged(PartyModel party)
    {
        model.PartyInfo = party;
        if (party != null)
        {
            IsTaxable = party.GstType == "Registered" || party.GstType == "SEZ";
            Local = partyService.IsLocal(model.PartyInfo.PartyID, BranchID); // Check if the party is local
        }
        else { Local = false; }
    }

    // Method to add an expense to the tax purchase model
    async Task AddExpense(TaxPurchaseExpenseModel expenseModel)
    {
        model.Expenses.Add(expenseModel);
        SetTotal();
    }

    // Method to add an item to the tax purchase model
    async Task AddItems(TaxPurchaseItemModel ItemModel)
    {
        model.Items.Add(ItemModel);
        SetTotal();
    }

    // Method to add an asset to the tax purchase model
    async Task AddAssets(AssetPOModel AssetModel)
    {
        model.Assets.Add(AssetModel);
        SetTotal();
    }

    // Method to update the tax purchase model
    protected override async Task<int> Update(TaxPurchaseModel editModel)
    {
        if (await validate(model))
        {
            model = Iservice.Update(model); // Update the model using the service
            return model.PID.Value;
        }
        return 0;
    }

    // Method to approve the tax purchase model
    protected override int UpdateApproval(DataApprovedStatus aprvd)
    {
        int result = Iservice.Approve(model.PID, model.UserInfo.UserID, aprvd.Remarks); // Call the service to approve
        model.UserInfo.UserID = UserIDTemp; 
        return result;
    }

    // Method to validate the tax purchase model
    public async Task<bool> validate(TaxPurchaseModel editModel)
    {
        if (!DayOpenService.ValidateDayOpen(editModel.DocumentDate, DocInfo.DocumentTypeID, editModel.BranchID).Value)
        {
            bool? result = await dialogService.ShowMessageBox(
                "Oops !",
                new MarkupString("The specified DocumentDate : <b>" + editModel.DocumentDate.Value.ToString("dd/MM/yyyy") + "</b> is closed ! <br>Please create a request to open the date."));
            return false;
        }
        SetTotal();
        if (TotalBillAmount != editModel.TotalAmount)
        {
            snackbar.Add("Please Set Billed amount", Severity.Warning);
            return false;
        }
        // Check for invoice duplication
        TaxPurchaseModel check = Iservice.CheckInvoiceDuplication(model);
        if (check?.PID is not null)
        {
            bool? result = await dialogService.ShowMessageBox(
                "Warning",
                new MarkupString("Invoice already entered On <b>" + check.DocumentDate + "</b> as <b>" + check.DocumentNumber + "</b>!"));
            return false;
        }
        return true;
    }

    // Method to handle rejection of the tax purchase
    protected async void OnReject()
    {
        try
        {
            // If a GRN ID is present, cancel the invoice
            if (model.GRNID != null)
            {
                grnIservice.ToInvoiceCancel(model.GRNID);
            }

            // Fetch the fuel model associated with the tax purchase
            fuelModel = Ifuelservice.SelectByTaxPurchase(model.PID);
            if (fuelModel != null && fuelModel.TripFuelID != null)
            {
                var authprov = await auth.GetAuthenticationStateAsync();
                var user = authprov.User;
                branchID = int.Parse(authprov.User.Claims.First(x => x.Type == "BranchID").Value);
                UserID = user.Identity.Name;
                Ifuelservice.Delete(fuelModel.TripFuelID, UserID); // Delete the fuel entry
                snackbar.Add("Fuel Removed", Severity.Warning);
            }
        }
        catch (Exception ex)
        {
            snackbar.Add(ex.Message, Severity.Error);
        }
    }
}