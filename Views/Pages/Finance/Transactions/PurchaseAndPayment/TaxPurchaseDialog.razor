@attribute [Authorize]
@using System.Threading;
@inject AuthenticationStateProvider auth
@inject IRoleService<RoleModel> Irole
@inject IDialogService DialogService
@inject MudBlazor.ISnackbar snackbar
@inject ITaxPurchaseService Iservice
@inject IInventoryGrnService grnIservice
@inject IPartyService partyIservice
@inject IInventoryItemService itemIservice
@inject IGstItemService gstitemIservice
@inject IInventoryGroupService inventoryGroupIservice
@inject ITdsRateService tdsIService
@inject IJSRuntime JsRuntime

<DialogForm @ref="@dialogForm" ReadOnly="@ReadOnly" Title="Purchase" formID="formTaxPurchase" model="@model" _busy="_busy">
    <FormContent>
        <MudPaper Class="p-3">
            <EditForm autocomplete="off" id="formTaxPurchase" OnValidSubmit="OnValidSubmit" EditContext="editContext">
                <ObjectGraphDataAnnotationsValidator />
                <ValidationSummary />
                <MudGrid>
                    <MudItem xs="12" md="6">
                        <MudDatePicker ReadOnly="ReadOnly" Label="Document Date" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.DocumentDate)" DisableToolbar="true" Editable="true" @bind-Date="model.DocumentDate" DateFormat="dd/MM/yyyy" />
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <PartySelector Value="model.PartyInfo" For="@(()=> model.PartyInfo)" ValueChanged="PartyChanged" NatureOfBusiness="Supplier"></PartySelector>
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudDatePicker ReadOnly="ReadOnly" Label="Invoice Date" Variant="Variant.Outlined" Margin="Margin.Dense" DisableToolbar="true" Editable="true" DateFormat="dd/MM/yyyy" @bind-Date="model.InvoiceDate" For="@(() => model.InvoiceDate)" />
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudTextField ReadOnly="ReadOnly" @bind-Value="model.InvoiceNo" Label="Invoice No" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.InvoiceNo)"></MudTextField>
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudTextField ReadOnly="ReadOnly" @bind-Value="model.AdditionalTDS" Label="Additional TDS" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.AdditionalTDS)"></MudTextField>
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <CostCenterSelector @bind-Value="@model.CostCenter" ReadOnly="@ReadOnly"></CostCenterSelector>
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <DimensionSelector @bind-Value="@model.Dimension" ReadOnly="@ReadOnly"></DimensionSelector>
                    </MudItem>
                    <MudItem xs="12" md="12">
                        <MudTextField ReadOnly="ReadOnly" @bind-Value="model.Narration" Lines="2" Label="Narration" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.Narration)"></MudTextField>
                    </MudItem>
                    <MudItem xs="12">
                        <ExpenseListView OnExpenseAdded="AddExpense" OnDelete="SetTotal" BranchID="@branchID" PartyInfo="@model.PartyInfo" Local="@Local" ExpenseList="@model.Expenses" ReadOnly="@ReadOnly" />
                    </MudItem>
                    <MudItem xs="12">
                        <ItemsListView OnItemAdded="AddItems" OnDelete="SetTotal" BranchID="@branchID" PartyInfo="@model.PartyInfo" Local="@Local" ItemList="@model.Items" ReadOnly="@ReadOnly" EditMode="@(model.PID != null)" />
                    </MudItem>
                </MudGrid>
            </EditForm>
        </MudPaper>
    </FormContent>
    <VerificationStatus>
        <AutherizationStatusComponent DocTypeID="@DocTypeID" DocDate="@DocDate" DocType="@DocType" DocNumber="@DocNumber" PageToRedirectLink="@PageToRedirectLink" DocumentID="@model.PID" OnApprove="ApproveEntry"></AutherizationStatusComponent>
    </VerificationStatus>
</DialogForm>

@code {

    [Parameter]
    public TaxPurchaseModel model { get; set; }
    [Parameter]
    public bool ReadOnly { get; set; }
    private int? branchID = null;
    private string UserID = null;
    private bool Local;
    [Parameter]
    public string PageToRedirectLink { get; set; }
    public string DocNumber { get; set; }
    public DateTime? DocDate { get; set; }
    public string DocType { get; set; }
    private EditContext editContext;
    DialogForm dialogForm;
    ValidationMessageStore messageStore;

    public bool HasAuthoriseEdit { get; set; } = false;
    int DocTypeID = 9;
    private bool _busy;

    protected override async Task OnInitializedAsync()
    {
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasAuthoriseEdit = await Irole.HasClaim(DocTypeID.ToString(), "Edit", ctc.Token);

        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;
        branchID = int.Parse(user.Claims.First(x => x.Type == "BranchID").Value);
        UserID = user.Identity.Name;

        if (model.PID == null && model.PartyInfo != null)
        {
            PartyChanged(model.PartyInfo);
        }

        if (model.PID != null)
        {
            model.PartyInfo = partyIservice.SelectByID(model.PartyInfo.PartyID);
            model.Expenses = Iservice.GetExpenses(model.PID).ToList();
            model.Items = Iservice.GetItems(model.PID).ToList();
        }
        else
        {
            model.NatureOfTransaction = "TaxPurchase";
            model.BranchID = branchID;
            model.NonStoreInventory = model.GRNID == null;
        }
        DocNumber = model.DocumentNumber;
        DocDate = model.DocumentDate;
        DocType = model.NatureOfTransaction;
    }

    protected override void OnParametersSet()
    {
        if (editContext == null)
        {
            editContext = new EditContext(model);
        }
    }

    void SetTotal()
    {
        model.TotalAmount = (model.Expenses.Sum(x => x.Amount) ?? 0) + (model.Items.Sum(y => y.Amount) ?? 0);
    }

    void PartyChanged(PartyModel party)
    {
        model.PartyInfo = party;
        if (party != null)
        {
            Local = partyIservice.IsLocal(model.PartyInfo.PartyID, branchID);
        }
        else { Local = false; }
    }

    async Task AddExpense(TaxPurchaseExpenseModel expenseModel)
    {
        model.Expenses.Add(expenseModel);
        SetTotal();
    }

    async Task AddItems(TaxPurchaseItemModel ItemModel)
    {
        model.Items.Add(ItemModel);
        SetTotal();
    }

    protected void ApproveEntry(DataApprovedStatus aprvd)
    {
        if (aprvd.IsApprove)
        {
            try
            {
                Iservice.Approve(model.PID, UserID, aprvd.Remarks);
                snackbar.Add("Approved Successfully", Severity.Success);
            }
            catch (Exception ex)
            {
                snackbar.Add(ex.Message, Severity.Error);
            }
        }
    }

    private async Task OnValidSubmit(EditContext context)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is being submitted!", Severity.Warning);
            return;
        }
        _busy = true;

        if (HasAuthoriseEdit)
        {
            try
            {
                TaxPurchaseModel check = Iservice.CheckInvoiceDuplication(model);
                if (check == null)
                {
                    model.UserInfo.UserID = UserID;
                    var result = Iservice.Update(model);
                    snackbar.Add("Saved Successfully", Severity.Success);
                    dialogForm.Close(result);
                    model = new();
                }
                else
                {
                    bool? result = await DialogService.ShowMessageBox(
                        "Warning",
                        "Invoice already entered On " + check.DocumentDate + " as " + check.DocumentNumber + "!");
                }
            }
            catch (Exception ex)
            {
                snackbar.Add(ex.Message, Severity.Error);
            }
        }
        else
        {
            bool? result = await DialogService.ShowMessageBox(
                "Permission denied!",
                "You dont have any permission to edit.");
        }
        await Task.Delay(2000);
        _busy = false;
    }
}