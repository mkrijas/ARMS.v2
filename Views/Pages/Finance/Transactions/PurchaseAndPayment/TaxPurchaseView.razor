@page "/TaxPurchase"
@page "/TaxPurchase/{id:int}"
@inherits ViewComponentBase<TaxPurchaseModel>

@inject ITaxPurchaseService Iservice
@using Inventory.GoodsReceipt



<MudTable Items="@collection" Dense="true" Hover="true" Striped="true" Elevation="10">
    <ToolBarContent>
        <MudText Typo="Typo.h6">Purchase</MudText>
        <MudTooltip Text="New TaxPurchase">
            <MudIconButton Disabled="@_busy" Icon="@Icons.Material.Filled.Add" Title="Add" @onclick="@(()=> OpenForm(new TaxPurchaseModel(),false))" Color="Color.Dark" Size="Size.Small"></MudIconButton>
        </MudTooltip>
        <MudTooltip Text="Add from GRN">
            <MudIconButton Disabled="@_busy" Icon="@Icons.Material.Filled.AddLink" @onclick="openGrn" Color="Color.Dark" Size="Size.Small"></MudIconButton>
        </MudTooltip>
        <MudSpacer></MudSpacer>
        <MudTextField @bind-Value="searchTerm" Placeholder="Search Tax..." Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0" @onkeyup="HandleSearchKeyUp">
        </MudTextField>
        <div class="tablefont">
            <span style="margin-right: 10px;">Maximum Records: </span>
        </div>
        <MudItem xs="1">
            <MudTextField @bind-Value="@NumberOfRecords" Variant="Variant.Outlined" Margin="Margin.Dense" Class="padding5" Style="width: 80px;"></MudTextField>
        </MudItem>
        <MudCheckBox Label="Approved Entries" CheckedChanged="((bool value)=>ToggleData(value))" Checked="@ShowApproved" Size="Size.Medium" Color="Color.Primary" Class="tablefont margin0"></MudCheckBox>
    </ToolBarContent>
    <HeaderContent>
        <MudTh><MudTableSortLabel SortBy="new Func<TaxPurchaseModel, object>(x=> x.InvoiceDate)" InitialDirection="SortDirection.Ascending">Invoice Date</MudTableSortLabel></MudTh>
        <MudTh><MudTableSortLabel SortBy="new Func<TaxPurchaseModel, object>(x=> x.InvoiceNo)" InitialDirection="SortDirection.Ascending">Invoice No</MudTableSortLabel></MudTh>
        <MudTh><MudTableSortLabel SortBy="new Func<TaxPurchaseModel, object>(x=> x.DocumentDate)" InitialDirection="SortDirection.Ascending">Document Date</MudTableSortLabel></MudTh>
        <MudTh><MudTableSortLabel SortBy="new Func<TaxPurchaseModel, object>(x=> x.DocumentNumber)" InitialDirection="SortDirection.Ascending">Document Number</MudTableSortLabel></MudTh>
        <MudTh>Actions</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd DataLabel="InvoiceDate">@context.InvoiceDate?.ToShortDateString()</MudTd>
            <MudTd DataLabel="InvoiceNo">@context.InvoiceNo</MudTd>
            <MudTd DataLabel="DocumentDate">@context.DocumentDate?.ToShortDateString()</MudTd>
            <MudTd DataLabel="DocumentNumber">@context.DocumentNumber</MudTd>
            <MudTd DataLabel="">
                @if (@context.AuthLevelId == null)
            {
                <MudIconButton @onclick="@(()=> OpenForm(context,false))" Color="Color.Primary" Title="Edit" Class="ml-2" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Variant="Variant.Filled" />
                <MudIconButton @onclick="@(()=> Delete(context.PID))" Color="Color.Error" Title="Delete" Class="ml-2" Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Variant="Variant.Filled" />
            }
            @if (@context.AuthLevelId != 99)
            {
                <MudIconButton @onclick="@(()=> OpenForm(context,true))" Color="Color.Warning" Icon="@Icons.Material.Filled.Verified" Title="Verify" Size="Size.Small" Variant="Variant.Filled" />
            }
            @* @if (@context.AuthLevelId == 99)
            {
            <MudFab @onclick="@(()=> GetAccountDetails(context))" Color="Color.Info" Icon="@Icons.Material.Filled.CurrencyExchange" title="Accounts" Size="Size.Small" IconSize="Size.Small"  Variant="Variant.Filled"/>
            } *@
            <MudIconButton @onclick="@(()=> OpenForm(context,true))" Color="Color.Info" Icon="@Icons.Material.Filled.GridView" Title="View" Size="Size.Small" Variant="Variant.Filled" />

            @if (@context.AuthLevelId == 99)
            {
                <EntryReversedComponent DocTypeID="DocInfo.DocumentTypeID" DocumentID="context.PID" MID="context.MID" DocumentNumber="context.DocumentNumber"></EntryReversedComponent>
            }
        </MudTd>
    </RowTemplate>
    <PagerContent>
        <MudTablePager PageSizeOptions="new int[] { 5, 10, 20, 50, 100 }" />
    </PagerContent>
</MudTable>


@code {
    protected override List<TaxPurchaseModel> collection { get; set; } = new List<TaxPurchaseModel>();
    protected override DocumentInfoModel DocInfo { get; set; } = new DocumentInfoModel()
        {
            DocumentTypeID = 9,
            DocumentName = "Purchase"
        };



    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();

        if (id != null && collection != null && collection.Any(g => g.PID == id))
        {
            await OpenForm(collection.FirstOrDefault(s => s.PID == id), true);
        }
    }

    protected override async Task OpenForm(TaxPurchaseModel ppm, bool ReadOnly, bool DisableAddition = false)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        _busy = true;
        DialogParameters parms = new DialogParameters();
        parms.Add("model", ppm.Clone());
        parms.Add("ReadOnly", ReadOnly);
        var dialog = dialogService.Show<TaxPurchaseDialog>(ppm.PID == null ? "ADD" : "EDIT", parms, new DialogOptions() { MaxWidth = MaxWidth.Large, FullWidth = true });
        var result = await dialog.Result;
        if (!result.Canceled)
        {
            var ReturnData = (TaxPurchaseModel)result.Data;
        }
        LoadData(ShowApproved, NumberOfRecords);
        await Task.Delay(200);
        _busy = false;
    }


    protected override void LoadData(bool val, int numberOfRecords)
    {
        if (val)
        {
            collection = Iservice.SelectByApproved(BranchID, numberOfRecords, searchTerm, "Purchase").ToList();
        }
        else
        {
            collection = Iservice.SelectByUnapproved(BranchID, numberOfRecords, searchTerm, "Purchase").ToList();
        }
    }


    public async Task openGrn()
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        _busy = true;
        DialogParameters parms = new DialogParameters();
        var dialog = dialogService.Show<InventoryGrnViewDialog>("GRN", parms, new DialogOptions() { MaxWidth = MaxWidth.Large });
        var result = await dialog.Result;
        LoadData(ShowApproved, NumberOfRecords);
        await Task.Delay(200);
        _busy = false;
    }
}