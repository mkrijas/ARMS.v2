@page "/TaxPurchase"
@page "/TaxPurchase/{id:int}"
@using Inventory.GoodsReceipt
@using System.Threading
@inherits ViewComponentBase<TaxPurchaseModel>
@inject ITaxPurchaseService Iservice

@if (_isLoading)
{
    <div @key="@("loader")" style="display: flex; justify-content: center; align-items: center; min-height: 400px;">
        <LoaderComponent IsFullScreen="true" 
                        ShowLogo="false" 
                        Size="medium" 
                        LoadingText="Loading Purchase Hub" 
                        SubText="Syncing tax acquisitions..." />
    </div>
}
else
{
    <div class="fade-in">
        <div class="admin-header-tiered mb-6">
            <div class="d-flex align-center justify-space-between">
                <div>
                    <MudText Typo="Typo.h4" Class="admin-title">Purchase Central</MudText>
                    <MudText Typo="Typo.body2" Class="admin-subtitle">Consolidated manager for tax acquisitions, fuel procurement, and maintenance logistics. oversee documentation, verification, and audit trails for all external liabilities.</MudText>
                </div>
                <div class="d-flex gap-3">
                    <MudButton StartIcon="@Icons.Material.Filled.AddCircle" Variant="Variant.Filled" Color="Color.Primary" Class="admin-register-btn" OnClick="@(()=> OpenForm(new TaxPurchaseModel(),false))" Disabled="@_busy">NEW PURCHASE</MudButton>
                    <MudButton StartIcon="@Icons.Material.Filled.Link" Variant="Variant.Outlined" Color="Color.Secondary" Class="admin-register-btn" OnClick="openGrn" Disabled="@_busy">GRN IMPORT</MudButton>
                </div>
            </div>
        </div>

        <div class="admin-glass-card mb-6 pa-4">
            <div class="d-flex align-center gap-6 flex-wrap">
                <div style="flex-grow: 1; min-width: 300px;">
                    <MudTextField @bind-Value="searchTerm" Placeholder="Search by invoice #, party, or document..." Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" Variant="Variant.Outlined" Margin="Margin.Dense" Class="admin-input-group" Clearable="true" OnKeyUp="HandleSearchKeyUp" />
                </div>
                
                <div class="d-flex align-center bg-glass rounded-pill px-6 py-1">
                    <MudRadioGroup Value="@model.TaxPurchaseType" T="string" ValueChanged="OnSelectedOptionChanged" Class="admin-radio-group-compact">
                        <MudRadio Value="@("Normal")" Color="Color.Primary" Dense="true"><span class="fw-600 tiny">NORMAL</span></MudRadio>
                        <MudRadio Value="@("Fuel")" Color="Color.Primary" Dense="true"><span class="fw-600 tiny">FUEL</span></MudRadio>
                        <MudRadio Value="@("Maintenance")" Color="Color.Primary" Dense="true"><span class="fw-600 tiny">MAINTENANCE</span></MudRadio>
                    </MudRadioGroup>
                </div>

                <div class="d-flex align-center gap-4">                   
                    <div class="d-flex align-center bg-glass rounded-pill px-4 py-1">
                        <MudCheckBox T="bool" Label="Approved Only" ValueChanged="((bool value)=>ToggleData(value))" Value="@ShowApproved" Size="Size.Small" Color="Color.Primary" Class="fw-600" />
                    </div>
                </div>
            </div>
        </div>

        <div class="admin-glass-card pa-0 overflow-hidden shadow-sm">
            <MudTable ServerData="LoadServerData" T="TaxPurchaseModel" @ref="_table" Elevation="0" Class="modern-admin-table" Hover="true">
                <HeaderContent>
                    <MudTh><MudTableSortLabel SortBy="new Func<TaxPurchaseModel, object>(x=> x.InvoiceDate)"><span class="admin-header-text">INVOICE DATE</span></MudTableSortLabel></MudTh>
                    <MudTh><span class="admin-header-text">IDENTIFIERS</span></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<TaxPurchaseModel, object>(x=> x.PartyInfo.TradeName)"><span class="admin-header-text">PARTY / VENDOR</span></MudTableSortLabel></MudTh>
                    <MudTh Style="text-align: right;"><MudTableSortLabel SortBy="new Func<TaxPurchaseModel, object>(x=> x.TotalAmount)"><span class="admin-header-text">TOTAL AMOUNT</span></MudTableSortLabel></MudTh>
                    <MudTh Style="text-align: right;"><span class="admin-header-text">ACTIONS</span></MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Date">
                        <div class="d-flex flex-column">
                            <span class="fw-700 admin-td-primary">@context.InvoiceDate?.ToString("dd MMM yyyy")</span>
                            <span class="tiny opa-50">Doc: @context.DocumentDate?.ToString("dd/MM/yy")</span>
                        </div>
                    </MudTd>
                    <MudTd DataLabel="Identifiers">
                        <div class="d-flex flex-column">
                            <div class="d-flex align-center gap-1">
                                <span class="fw-700">Inv: #@context.InvoiceNo</span>
                            </div>
                            <div class="d-flex align-center gap-2">
                                <span class="tiny fw-800 text-indigo">ID: @context.DocumentNumber</span>
                                @if (context.AuthLevelId == 100)
                                {
                                    <span class="tiny fw-900 text-error uppercase">REJECTED</span>
                                }
                            </div>
                        </div>
                    </MudTd>
                    <MudTd DataLabel="Party">
                        <div class="d-flex align-center gap-2">
                            <div class="admin-icon-square-vibrant tiny accent-indigo">
                                <MudIcon Icon="@Icons.Material.Filled.Business" Size="Size.Small" />
                            </div>
                            <span class="fw-600">@context.PartyInfo.TradeName</span>
                        </div>
                    </MudTd>
                    <MudTd DataLabel="Amount" Style="text-align: right;">
                        <span class="fw-800 text-vibrant" style="font-size: 1.1rem;">@context.TotalAmount?.ToString("N2")</span>
                    </MudTd>
                    <MudTd DataLabel="Actions" Style="text-align: right;">
                        <div class="d-flex justify-end gap-1">
                            @if (@context.AuthLevelId == 99)
                            {
                                <EntryReversedComponent DocTypeID="@DocInfo.DocumentTypeID" TDS="@context.TDS" DocumentID="@context.PID" MID="@context.MID" DocumentNumber="@context.DocumentNumber"></EntryReversedComponent>
                            }
                            else if (@context.AuthLevelId != 100)
                            {
                                <MudTooltip Text="Verify Entry">
                                    <MudIconButton OnClick="@(()=> OpenForm(context,true))" Color="Color.Warning" Icon="@Icons.Material.Filled.Verified" Size="Size.Small" Variant="Variant.Text" />
                                </MudTooltip>
                            }

                            <MudTooltip Text="Inspect Details">
                                <MudIconButton OnClick="@(()=> OpenForm(context,true))" Color="Color.Info" Icon="@Icons.Material.Filled.Visibility" Size="Size.Small" Variant="Variant.Text" />
                            </MudTooltip>
                            
                            <MudTooltip Text="Modify Entry">
                                <MudIconButton Disabled="@(context.AuthLevelId != null)" OnClick="@(()=> OpenForm(context,false))" Color="Color.Primary" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Variant="Variant.Text" />
                            </MudTooltip>

                            <MudTooltip Text="Purge Record">
                                <MudIconButton Disabled="@(context.AuthLevelId != null)" OnClick="@(()=> Delete(context.PID))" Color="Color.Error" Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Variant="Variant.Text" />
                            </MudTooltip>
                        </div>
                    </MudTd>
                </RowTemplate>
                <PagerContent>
                    <div class="pa-4">
                        <MudTablePager PageSizeOptions="new int[] { 10, 20, 50, 100 }" />
                    </div>
                </PagerContent>
            </MudTable>
        </div>
    </div>
}

@code {    

    protected override List<TaxPurchaseModel> _collection { get; set; } = new List<TaxPurchaseModel>();

    public TaxPurchaseModel model { get; set; } = new TaxPurchaseModel();

    protected override DocumentInfoModel DocInfo { get; set; } = new DocumentInfoModel()
        {
            DocumentTypeID = 9,
            DocumentName = "Purchase"
        };

    // Method to handle changes in the selected option
    public async Task OnSelectedOptionChanged(string value)
    {
        model.TaxPurchaseType = value;
        switch (value)
        {
            case "Fuel":
                DocInfo.DocumentTypeID = 133; // Set the appropriate DocumentTypeID for Fuel
                DocInfo.DocumentName = "Fuel Purchase";
                break;
            case "Maintenance":
                DocInfo.DocumentTypeID = 134; // Set the appropriate DocumentTypeID for Maintenance
                DocInfo.DocumentName = "Maintenance Purchase";
                break;
            default:
                DocInfo.DocumentTypeID = 9; // Default DocumentTypeID for Normal
                DocInfo.DocumentName = "Purchase";
                break;
        }
        await _table.ReloadServerData(); 
    }

    // Lifecycle method called when the component is initialized
    protected override async Task OnInitializedAsync()
    {        
        await base.OnInitializedAsync();
        string type = model.TaxPurchaseType;
        if (id != null && _collection != null && _collection.Any(g => g.PID == id))
        {
            await OpenForm(_collection.FirstOrDefault(s => s.PID == id), true);
        }
        model.TaxPurchaseType = "Normal";        
        _isLoading = false;
    } 

    // Method to open the tax purchase form for adding or editing
    protected override async Task OpenForm(TaxPurchaseModel ppm, bool ReadOnly, bool DisableAddition = false)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        _busy = true;
        DialogParameters parms = new DialogParameters();
        parms.Add("model", ppm.Clone());
        parms.Add("ReadOnly", ReadOnly);
        parms.Add("OnApproved", new EventCallbackFactory().Create(this, async() => await _table.ReloadServerData()));
        var dialog = await dialogService.ShowAsync<TaxPurchaseDialog>(ppm.PID == null ? "ADD" : "EDIT", parms, new DialogOptions() { MaxWidth = MaxWidth.Large, FullWidth = true });
        var result = await dialog.Result;
        if (!result.Canceled)
        {
            var ReturnData = (TaxPurchaseModel)result.Data;
            await _table.ReloadServerData();
        }        
        await Task.Delay(200);
        _busy = false;
    }

    //Load Data to table based on search and filters
    protected override async Task<TableData<TaxPurchaseModel>> LoadServerData(TableState state, CancellationToken token)
    {        

        var list = Iservice.SelectAll(BranchID, searchTerm,"Purchase" ,model.TaxPurchaseType , state.Page, state.PageSize,  ShowApproved);

        _collection = list.Items;       

        StateHasChanged();

        return new TableData<TaxPurchaseModel>
        {
            Items = _collection,
            TotalItems = list.TotalRecords ?? 0
        };
    }

    // Method to open the GRN (Goods Receipt Note) dialog
    public async Task openGrn()
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        _busy = true;
        DialogParameters parms = new DialogParameters();
        var dialog = await dialogService.ShowAsync<InventoryGrnViewDialog>("GRN", parms, new DialogOptions() { MaxWidth = MaxWidth.Large });
        var result = await dialog.Result;
        await _table.ReloadServerData();
        //await Task.Delay(200);
        _busy = false;
    }
}
