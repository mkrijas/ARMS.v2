@page "/PaymentFinishMemoView"
@inject IPaymentService Iservice
@inject IOutstandingBillsService OBIservice
@inject ICostCenterService costIservice
@inject IDimensionService dimensionIservice
@inject NavigationManager uriHelper;
@inject MudBlazor.ISnackbar snackbar
@inject AuthenticationStateProvider auth
@attribute [Authorize]
@inject IDialogService DialogService


<MudGrid Spacing="4">
   <MudItem xs="12">
        <MudTable Items="@collection"    Dense="true" Hover="true"  Striped="true" Elevation="10"  @bind-place="model">
           

             <ToolBarContent>
                <MudText Typo="Typo.h6">Pending Initiated Payment memo</MudText>
                <MudTooltip Text="New Payment Memos">
              @*  <MudIconButton  Icon="@Icons.Material.Filled.Add" Title="Add" @onclick="openPaymentMemos"  Color="Color.Dark" Size="Size.Small"></MudIconButton>
              *@  </MudTooltip>
               
               @* <MudButton @onclick="openpurchaseorder" @onclick="@(()=> OpenDialog(model))"  Variant="Variant.Filled" Color="Color.Primary" >Purchase Order</MudButton>
               *@ 
                <MudSpacer></MudSpacer>
               @* <MudTextField @bind-Value="searchMemos" Placeholder="Search Tax... "
                              Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                              IconSize="Size.Medium" Class="mt-0"></MudTextField>*@
                <MudCheckBox Label="Finalized Entries" CheckedChanged="((bool value)=>ApprovedChanged(value))" Checked="@IsApproved" Size="Size.Medium" Color="Color.Primary"></MudCheckBox>

            </ToolBarContent>
            <HeaderContent>
                <MudTh><MudTableSortLabel SortBy="new Func<PaymentInitiatedModel, object>(x=> x.DocNumber)" InitialDirection="SortDirection.Ascending">DocNumber</MudTableSortLabel></MudTh>
             <MudTh><MudTableSortLabel SortBy="new Func<PaymentInitiatedModel, object>(x=> x.DueOn)" InitialDirection="SortDirection.Ascending">DueDate</MudTableSortLabel></MudTh>
              <MudTh><MudTableSortLabel SortBy="new Func<PaymentInitiatedModel, object>(x=> x.DocDate)" InitialDirection="SortDirection.Ascending">DocDate</MudTableSortLabel></MudTh>
             
             <MudTh><MudTableSortLabel SortBy="new Func<PaymentInitiatedModel, object>(x=> x.TotalAmount)" InitialDirection="SortDirection.Ascending">TotalAmount</MudTableSortLabel></MudTh>
            
             <MudTh>Actions</MudTh>
                
               
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="PaymentMemoID">@context.DocNumber</MudTd>
                <MudTd DataLabel="PaymentStatus">@context.DueOn?.ToShortDateString()</MudTd>
             <MudTd DataLabel="PaymentStatus">@context.DocDate?.ToShortDateString()</MudTd>
              <MudTd DataLabel="PaymentMemoID">@context.TotalAmount</MudTd>

                <MudTd DataLabel="">

                 @if (!IsApproved)
                    {
                        <MudFab @onclick="@(()=> OpenDialog(context,false,false))" Color="Color.Primary" title="Finish" Icon="@Icons.Material.Filled.Check" Size="Size.Small" IconSize="Size.Small" />
                        <MudTooltip Text="View">
                            <MudFab @onclick="@(()=> View(context))" Color="Color.Primary" Icon="@Icons.Material.Filled.GridView" Size="Size.Small" IconSize="Size.Small" />
                        </MudTooltip>
                    }
                    @if (IsApproved && @context.AuthLevelId != 99)
                    {
                        <MudFab @onclick="@(()=> OpenDialog(context,true,false))" Color="Color.Warning" Icon="@Icons.Material.Filled.Verified" title="Verify" Size="Size.Small" IconSize="Size.Small" />
                   
                    }   
                   @if (IsApproved && @context.AuthLevelId == 99)
                    {
                        <MudTooltip Text="View">
                            <MudFab @onclick="@(()=> View(context))" Color="Color.Primary" Icon="@Icons.Material.Filled.GridView" Size="Size.Small" IconSize="Size.Small" />
                        </MudTooltip>
                    }

                  </MudTd>
              
            </RowTemplate>
          
            <PagerContent>
                <MudTablePager PageSizeOptions="new int[] { 5, 10, 20, 50, 100 }" />
                
           
            </PagerContent>
        </MudTable>
    </MudItem>
    </MudGrid>



@code {
    private PaymentInitiatedModel model = new PaymentInitiatedModel();
    private List<PaymentInitiatedModel> collection = new List<PaymentInitiatedModel>();
    DialogOptions maxWidth = new DialogOptions() { MaxWidth = MaxWidth.Medium, FullWidth = true };

    public bool IsApproved { get; set; } = false;
    async Task ApprovedChanged(bool value)
    {
        IsApproved = value;
        await GetAll(IsApproved);

    }
    protected override async Task OnInitializedAsync()

    {
        model = new();
        GetAll(false);
    }

    private async Task GetAll(bool val)
    {
        var authprov = await auth.GetAuthenticationStateAsync();
        var brancIDString = authprov.User.Claims.First(x => x.Type == "BranchID").Value;
        int brancID = int.Parse(brancIDString);
        collection = new List<PaymentInitiatedModel>();
        if(val)
        {

            foreach (var item in Iservice.SelectFinInitiated(brancID))
            {
                collection.Add(item);
            }
        }
        else
        {
            foreach (var item in Iservice.SelectInitiated(brancID))
            {
                collection.Add(item);
            }
        }



    } 
    public async Task View(PaymentInitiatedModel pim)
    {
        DialogParameters parms = new DialogParameters();
        parms.Add("model",pim);

        parms.Add("IsReadOnly",true);
        parms.Add("IsView",true);
        var dialog = DialogService.Show<PaymentInitiatedDialog>("Payment",parms,maxWidth);
        var result = await dialog.Result;

        if(!result.Cancelled)
        {   

            await GetAll(false);


        }


    }
    public async Task ViewVerify(PaymentInitiatedModel pim)
    {
        DialogParameters parms = new DialogParameters();
        parms.Add("model",pim);
        parms.Add("IsReadOnly",true);
        parms.Add("IsView",false);
        var dialog = DialogService.Show<PaymentInitiatedDialog>("Payment",parms,maxWidth);
        var result = await dialog.Result;

        if(!result.Cancelled)
        {   

            await GetAll(false);


        }

    }
    private async Task OpenDialog(PaymentInitiatedModel tds, bool ReadOnly, bool View)
    {
        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;
        PaymentFinishModel pfm = new PaymentFinishModel();
   
        pfm.PiID = tds.PiID;
        pfm.TotalAmount = tds.TotalAmount;
        pfm.PfID = tds.pfID;
        DialogParameters parms = new DialogParameters();
        parms.Add("model",pfm);
        parms.Add("IsReadOnly", ReadOnly);
        parms.Add("IsView", View);
        var dialog =  DialogService.Show<PaymentFinishedDilaog>("Finalize Payment Memo",parms,maxWidth);
        var result = await dialog.Result;

        if(!result.Cancelled)
        {   

            GetAll(IsApproved);


        }
    }
}
