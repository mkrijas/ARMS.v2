    private async Task OpenDialog(ReceiptModel tds)
    {
        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;

        DialogParameters parms = new DialogParameters();
        parms.Add("model",tds);
        parms.Add("IsReadOnly",false);
        parms.Add("IsView",false);
        var dialog =  DialogService.Show<ReceiptView>(tds.ReceiptID == null?"ADD":"EDIT",parms,maxWidth);
        var result = await dialog.Result;

        if(!result.Cancelled)
        {   

            GetReceiptBill(IsApproved);


        }
        GetReceiptBill(IsApproved);
    }
    private async Task OpenDialogVerify(ReceiptModel tds)
    {
