</MudPaper>
 </MudContainer>
</DialogContent>
<DialogActions>
       @if (!IsReadOnly)
        {
            <MudButton Variant="Variant.Filled" Color="Color.Info" OnClick="Cancel">Cancel</MudButton>

                 <MudButton @onclick="CreateReceipt" Variant="Variant.Filled" Color="Color.Primary">Submit</MudButton>
       }
        @if (IsReadOnly)
        {
            <MudButton Variant="Variant.Filled" Color="Color.Info" OnClick="Cancel">Close</MudButton>

        }
</DialogActions>
</MudDialog>
@code {
    [Parameter]
    public ReceiptModel model { get; set; }
    [Parameter]
    public bool IsReadOnly { get; set; }
    [Parameter]
    public bool IsView { get; set; }
    private List<OutstandingPaymentModel> collection = new List<OutstandingPaymentModel>();
    public string value = "invisible";
    public bool readvalue = true;
    public string nbusiness = "Supplier";
    public bool checkread = false;
    public string status = null;
    private bool Isbill = false;
    ProformaInvoiceModel pmodel = new();
    private AccountRuleDefinitionModel accountRuleDefinitionModel = new();
    public bool Basic_CheckBox2 { get; set; } = false;
    private HashSet<OutstandingPaymentModel> selectedItems1 = new HashSet<OutstandingPaymentModel>();
    private List<OutstandingBillsModel> SelectedItems = new List<OutstandingBillsModel>();
    private List<BillsReceiptModel> billsReceipt = new List<BillsReceiptModel>();
    DialogOptions maxWidth = new DialogOptions() { MaxWidth = MaxWidth.Medium, FullWidth = true };
    private List<CostCenterModel> costCenter = new();
    private List<DimensionModel> dimension = new();
    private List<string> NatureOfBusiness = new List<string>() { "Supplier", "Customer", "Renter" };
    [CascadingParameter] MudDialogInstance MudDialog { get; set; }

    protected override void OnInitialized()
    {
        if(model.ReceiptID!=null)
        {
            nbusiness = model.ReceiptType;
            model.Bills = Iservice.GetBills(model.ReceiptID).ToList();
            model.PartyInfo = partyIservice.SelectByID(model.PartyInfo.PartyID);
            value = "visible";
            Isbill = true;
        }
        costCenter = costIservice.Select().ToList();
        dimension = dimensionIservice.Select().ToList();
        // GetOutstandingBill();
    }
    private void nbusinesschanged()
    {
        StateHasChanged();
    }
    private void Cancel()
    {
        MudDialog.Cancel();
    }
    private void nTransactionchanged()
    {
        if (model.NatureOfTransaction == "Payable")
        {
            value = "visible";
            Isbill = true;
        }
        else if (model.NatureOfTransaction == "Receivable")
        {
            value = "visible";
            Isbill = true;
        }
        else
        {
            value = "visible";
            Isbill = false;
        }
    }
    public void ReceiptToolChange()
    {
        if (model.ReceiptTool == "Cheque")
        {
            checkread = true;
        }
        else
        {

            Basic_CheckBox2 = false;
            checkread = false;
        }
    }
    private void calcTotalAmt()
    {
        model.TotalAmount = 0;
        foreach (var item in billsReceipt)
        {
            model.TotalAmount = model.TotalAmount + item.ReceiptAmount;
        }
    }
    public void ReceiptModeChange()
    {
        if (model.ReceiptMode == "Cash")
        {
            readvalue = false;
        }
        else
        {
            readvalue = true;
        }
    }

    private async Task OpenOtstandingBills()
    {
        DialogParameters parms = new DialogParameters();
        parms.Add("PartyID", model.PartyInfo.PartyID);
        var dialog = DialogService.Show<OutstandingBillView>("Outstanding Bill", parms, maxWidth);
        var result = await dialog.Result;

        if (!result.Cancelled)
        {

            SelectedItems = (List<OutstandingBillsModel>)result.Data;
            //  List<OutstandingBillsModel> SelectedItems = new List<OutstandingBillsModel>();
            //SelectedItems=result.Data;
            // GetAll();
            if (SelectedItems != null)
            {
                value = "visible";
                foreach (var item in SelectedItems)
                {
                    BillsReceiptModel bpm = new BillsReceiptModel();
                    //bpm.BoID = item.BoID;
                    //bpm.BranchName = item.BranchName;
                    //bpm.DocDate = item.DocDate;
                    //bpm.BranchID = item.BranchID;
                    //bpm.DocNumber = item.DocNumber;
                    //bpm.InvoiceDate = item.InvoiceDate;
                    //bpm.InvoiceNumber = item.InvoiceNumber;
                    //bpm.ReceiptAmount = 0;
                    //billsReceipt.Add(bpm);
                }

            }


        }

    }


    public async Task CreateReceipt()
    {
        model.ReceiptCoaID = Convert.ToInt32(configuration.GetSection("Data")["DefaultCashCoa"]);



        model.Bills = billsReceipt;
        var authprov = await auth.GetAuthenticationStateAsync();
        var brancIDString = authprov.User.Claims.First(x => x.Type == "BranchID").Value;
        int brancID = int.Parse(brancIDString);
        var user = authprov.User;
        model.ReceiptMode = accountRuleDefinitionModel.paymentMode;
        model.ReceiptCoaID = accountRuleDefinitionModel.CoaID;
        model.ReceiptArdCode = accountRuleDefinitionModel.ArdCode;
        model.ReceiptTool = accountRuleDefinitionModel.BankTools;
        model.BankCharges = accountRuleDefinitionModel.BankCharges;
        if (nbusiness == "Supplier")
        {
            if (model.NatureOfTransaction=="Deposit")
            {
                model.PartyCoaID = partyIservice.GetVendorDepositCoaID(model.PartyInfo.PartyID);
            }
            if (model.NatureOfTransaction=="Payable")
            {
                model.PartyCoaID = partyIservice.GetVendorPayableCoaID(model.PartyInfo.PartyID);
            }
            if (model.NatureOfTransaction=="Prepayment")
            {
                model.PartyCoaID = partyIservice.GetVendorPrepaymentCoaID(model.PartyInfo.PartyID);
            }

        }
        if (nbusiness == "Customer")
        {
            if (model.NatureOfTransaction=="Receivable")
            {
                model.PartyCoaID = partyIservice.GetCustomerReceivableCoaID(model.PartyInfo.PartyID);
            }
            if (model.NatureOfTransaction=="Deposit")
            {
                model.PartyCoaID = partyIservice.GetCustomerDepositCoaID(model.PartyInfo.PartyID);
            }
            if (model.NatureOfTransaction=="Prepayment")
            {
                model.PartyCoaID = partyIservice.GetCustomerPrepaymentCoaID(model.PartyInfo.PartyID);
            }
        }
        if (nbusiness == "Renter")
        {

            if (model.NatureOfTransaction=="Rent")
            {
                model.PartyCoaID = partyIservice.GetRenterRentCoaID(model.PartyInfo.PartyID);
            }
            if (model.NatureOfTransaction=="Deposit")
            {
                model.PartyCoaID = partyIservice.GetRenterDepositCoaID(model.PartyInfo.PartyID);
            }
            if (model.NatureOfTransaction=="Other")
            {
                model.PartyCoaID = partyIservice.GetRenterOtherCoaID(model.PartyInfo.PartyID);
            }
        }
        model.ReceiptType = nbusiness;
        model.UserInfo.UserID = user.Identity.Name;
        model.BranchID = brancID;
        Iservice.Update(model);
        snackbar.Add("Saved Successfully", Severity.Success);
        MudDialog.Close();
    }

     protected async Task IsApproveData(DataApprovedStatus aprvd)
    {
        if (aprvd.IsApprove)
        {
            var authprov = await auth.GetAuthenticationStateAsync();
            var user = authprov.User;
            model.UserInfo.UserID = user.Identity.Name;
            Iservice.Approve(model.ReceiptID, model.UserInfo.UserID);
            snackbar.Add("Approved Successfully", Severity.Success);
        }

    }

}
