<MudPaper Class="@value">
    <MudContainer>
        <MudGrid>
            @if (Isbill)
            {
                <MudItem xs="12">
                    <MudSimpleTable Hover="true" Dense="true" FixedHeader="true">
                        <thead>
                            <tr>
                                <th>Invoice info</th>
                                <th>Accounting Info</th>
                                <th>Branch</th>
                                <th>ReceiptAmount</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in billsReceipt)
                            {
                                <tr>
                                    <td>@item.InvoiceNumber - @item.InvoiceDate?.ToShortDateString()</td>
                                    <td>@item.DocNumber - @item.DocDate?.ToShortDateString()</td>
                                    <td>@item.BranchName</td>
                                    <td> <MudTextField T="decimal?" @bind-Value="item.ReceiptAmount" TextChanged="calcTotalAmt" Variant="Variant.Outlined" Margin="Margin.Dense"> </MudTextField></td>

                                </tr>
                            }
                            <tr>
                                <td></td>
                                <td></td>
                                <td></td>
                                <td>Total:@model.TotalAmount</td>
                            </tr>


                        </tbody>
                    </MudSimpleTable>
                </MudItem>
            }
            <MudItem xs="12" md="12">
                @* <MudSelect Label="Select ReceiptType" @bind-Value="model.ReceiptType" T="string" Variant="Variant.Outlined" Margin="Margin.Dense" OffsetY="true" Direction="Direction.Top" AdornmentColor="Color.Secondary">
                <MudSelectItem Value="@("Advance")" />
                <MudSelectItem Value="@("Deposit")" />
                <MudSelectItem Value="@("Settlement")" />
                </MudSelect>
                </MudItem>
                <MudItem xs="12" md="3">
                <MudSelect Label="Select ReceiptMode" @bind-Value="model.ReceiptMode" TextChanged="ReceiptModeChange" T="string" Variant="Variant.Outlined" Margin="Margin.Dense" OffsetY="true" Direction="Direction.Top" AdornmentColor="Color.Secondary">
                <MudSelectItem Value="@("Cash")" />
                <MudSelectItem Value="@("Bank")" />

                </MudSelect>
                </MudItem>
                <MudItem xs="12" md="3">
                <MudSelect Label="Select ReceiptTool" ReadOnly="@readvalue" TextChanged="ReceiptToolChange" @bind-Valu="model.ReceiptTool" T="string" Variant="Variant.Outlined" Margin="Margin.Dense" OffsetY="true" Direction="Direction.Top" AdornmentColor="Color.Secondary">
                @foreach (var item in data.BankTools)
                {
                <MudSelectItem Value="@item">@item</MudSelectItem>
                }

                </MudSelect>*@

                <PaymentCodeSelector @bind-Value="accountRuleDefinitionModel" LabelName="Select Accounts"></PaymentCodeSelector>


            </MudItem>
            <MudItem xs="12" md="4">

                <MudDatePicker ReadOnly="IsReadOnly" Label="Effective Date" Variant="Variant.Outlined" Margin="Margin.Dense" DisableToolbar="true" Editable="true" @bind-Date="model.EffectiveDate" DateFormat="dd/MM/yyyy" />


            </MudItem>
            <MudItem xs="12" md="4">

                <MudTextField ReadOnly="IsReadOnly" @bind-Value="model.Reference" Label="Reference" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.Reference)"></MudTextField>

            </MudItem>
            @if (!Isbill)
            {
                <MudItem xs="12" md="4">

                    <MudTextField ReadOnly="IsReadOnly" @bind-Value="model.TotalAmount" Label="TotalAmount" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.TotalAmount)"></MudTextField>

                </MudItem>
            }
            <MudItem xs="12" md="3">

                <MudDatePicker ReadOnly="IsReadOnly" Label="DocumentDate" Variant="Variant.Outlined" Margin="Margin.Dense" DisableToolbar="true" Editable="true" @bind-Date="model.DocumentDate" DateFormat="dd/MM/yyyy" />


            </MudItem>
            <MudItem xs="12" md="3">

                <MudSelect ReadOnly="IsReadOnly" Label="Select CostCenter" @bind-Value="model.CostCenter" T="int?" Variant="Variant.Outlined" Margin="Margin.Dense" OffsetY="true" Direction="Direction.Top" AdornmentColor="Color.Secondary">
                    @foreach (var ditem in costCenter)
