@using Core.BaseModels.Finance;

@inject IReverseEntryService Iservice
@if (CancellationReasonCodeModel!= null && CancellationReasonCodeModel.MID != null)
{
    <h6 style="color:red;display:block;">Reversed with @(ResultString)</h6>
}

@code {


    [Parameter]
    public DocumentInfoModel DocumentDetails { get; set; } = new();


    public string ResultString { get; set; }
    public CancellationReasonCodesByDocumentType CancellationReasonCodeModel { get; set; }

    // Method that is called when parameters are set or changed
    protected override void OnParametersSet()
    {
        if (DocumentDetails != null && DocumentDetails.DocumentTypeID != null && DocumentDetails.DocumentID != null)
        {
            // Retrieve cancellation reason code details based on the document ID and type
            CancellationReasonCodeModel = Iservice.GetReverseEntryDetailsByDocumentTypeAndDocumentID(DocumentDetails.DocumentID, DocumentDetails.DocumentTypeID);
            if (CancellationReasonCodeModel != null && CancellationReasonCodeModel.MID != null)
            {
                ResultString = CancellationReasonCodeModel.DocumentNumber + (CancellationReasonCodeModel.DocumentDate != null ? (" on " + CancellationReasonCodeModel.DocumentDate.Value.ToString("dd/MM/yyyy")) : "");
            }
            
        }
    }
}
