    private  async Task GetAll(int val)
    {
        var authprov = await auth.GetAuthenticationStateAsync();
        var brancIDString = authprov.User.Claims.First(x => x.Type == "BranchID").Value;
        int brancID = int.Parse(brancIDString);
        if (val == 1)
        {
            collection = Iservice.Select().Where(x => x.AuthLevelId != 99).ToList();
        }
        else
        {
            collection = Iservice.Select().Where(x => x.AuthLevelId == 99).ToList();

        }


    }   
    private  void Verified(int val)
    {

        GetAll(val);

    }   

    private async Task OpenDialog(SaleModel tds)
    {
        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;
        
        DialogParameters parms = new DialogParameters();
        parms.Add("model",tds);
        parms.Add("IsReadOnly",false);
        parms.Add("IsView",false);
        var dialog =  DialogService.Show<SaleDialog>(tds.SID == null?"ADD":"EDIT",parms,maxWidth);
        var result = await dialog.Result;

        if(!result.Cancelled)
        {   

            GetAll(1);


        }
    }
    private async Task OpenDialogView(SaleModel tds)
    {
        var authprov = await auth.GetAuthenticationStateAsync();
