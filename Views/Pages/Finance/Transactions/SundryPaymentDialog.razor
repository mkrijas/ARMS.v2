@inherits DialogFormComponentBase<SundryPaymentModel>
@inject ISundryPaymentService Iservice
@inject IChartOfAccountService Icoa
@inject ITripAdvanceService Iadvance

<DialogForm @ref="@dialogForm" ReadOnly="@ReadOnly" Title="Sundry Payment" Subtitle="Manage miscellaneous payments, payee details, and cost allocations efficiently." Icon="@Icons.Material.Filled.Payments" AdminStyle="true" formID="sundryPaymentForm" OnFileRemoved="RemoveFileChange" DocumentDetails="DocInfo" model="@model" _busy="_busy" @key="model.TotalAmount">
    <FormContent>
        <div class="dialog-content-wrapper">
            <EditForm id="sundryPaymentForm" OnValidSubmit="OnValidSubmit" EditContext="editContext">
                <ObjectGraphDataAnnotationsValidator />
                
                @if (model.IsInterBranch)
                {
                    <div class="admin-glass-card pa-6 mb-6">
                        <span class="admin-section-label">Inter-Branch Allocation</span>
                        <MudGrid Spacing="3">
                            <MudItem xs="12" md="6">
                                <BranchSelector For="@(() => OtherBranch)" Value="@OtherBranch" ValueChanged="@OtherBranchSelected" LabelName="Target Branch (Payment Made For)" Class="admin-input-group"></BranchSelector>
                            </MudItem>
                            <MudItem xs="12" md="6">
                                <MudSelect For="@(() => model.InterBranchTranID)" Label="Transaction Type" ReadOnly="ReadOnly" @bind-Value="model.InterBranchTranID" T="int?" Variant="Variant.Outlined" Margin="Margin.Dense" Class="admin-input-group">
                                    @foreach (var ditem in InterBranchTranTypes)
                                    {
                                        <MudSelectItem Value="@ditem.ID">@ditem?.TransactionTypeName</MudSelectItem>
                                    }
                                </MudSelect>
                            </MudItem>
                        </MudGrid>
                    </div>
                }

                <div class="admin-glass-card pa-6 mb-6">
                    <div class="d-flex align-center mb-4">
                        <MudIcon Icon="@Icons.Material.Filled.Person" Color="Color.Primary" Class="mr-2" />
                        <span class="admin-section-label mb-0">Payee & Timeline</span>
                    </div>
                    <MudGrid Spacing="3">
                        <MudItem xs="12" md="4">
                            <MudDatePicker ReadOnly="ReadOnly" Label="Document Date" Variant="Variant.Outlined" Margin="Margin.Dense" DisableToolbar="true" Editable="true" @bind-Date="model.DocumentDate" DateFormat="dd/MM/yyyy" MaxDate="DateTime.Now" Class="admin-input-group modern-input" />
                        </MudItem>
                        <MudItem xs="12" md="4">
                            <MudTextField ReadOnly="ReadOnly" @bind-Value="model.PayeeName" Label="Payee Name" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.PayeeName)" Class="admin-input-group modern-input"></MudTextField>
                        </MudItem>
                        <MudItem xs="12" md="4">
                            <MudTextField MaxLength="10" InputType="InputType.Text" InputMode="InputMode.numeric" ReadOnly="ReadOnly" @bind-Value="model.PayeeContactNo" Label="Payee Contact No" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.PayeeContactNo)" Class="admin-input-group modern-input"></MudTextField>
                        </MudItem>
                        <MudItem xs="12">
                            <PaymentAccountSelector BranchID="@(BranchID ?? 0)" PaymentMode="@model.PaymentMode" PaymentModeChanged="OnChangePaymentMode" @bind-ArdCode="@model.PaymentArdCode" @bind-CoaID="@model.PaymentCoaID" BankCharges="@model.BankCharges" @bind-BankTool="@model.PaymentTool" BankChargesChanged="CalculateTotalAmount" Class="admin-input-group modern-input" />
                        </MudItem>
                    </MudGrid>
                </div>

                <div class="admin-glass-card pa-6 mb-6">
                    <div class="d-flex align-center mb-4">
                        <MudIcon Icon="@Icons.Material.Filled.Info" Color="Color.Primary" Class="mr-2" />
                        <span class="admin-section-label mb-0">Additional Details</span>
                    </div>
                    <MudGrid Spacing="3">
                        <MudItem xs="12" md="4">
                            <MudTextField ReadOnly="ReadOnly" @bind-Value="model.Reference" Label="Reference No" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.Reference)" Class="admin-input-group modern-input"></MudTextField>
                        </MudItem>
                        <MudItem xs="12" md="8" Class="d-flex align-center">
                            <MudCheckBox Label="Deferred Expenditure" @bind-Value="@model.deferredExpenditure" Size="Size.Medium" Color="Color.Primary" Class="ml-2"></MudCheckBox>
                            @if (model.deferredExpenditure)
                            {
                                <MudGrid Spacing="2" Class="ml-4 flex-grow-1">
                                    <MudItem xs="6">
                                        <MudDatePicker ReadOnly="ReadOnly" Label="Begin Date" Variant="Variant.Outlined" Margin="Margin.Dense" DisableToolbar="true" Editable="true" @bind-Date="model.beginDate" DateFormat="dd/MM/yyyy" Class="admin-input-group modern-input" />
                                    </MudItem>
                                    <MudItem xs="6">
                                        <MudDatePicker ReadOnly="ReadOnly" Label="End Date" Variant="Variant.Outlined" Margin="Margin.Dense" DisableToolbar="true" Editable="true" @bind-Date="model.EndDate" DateFormat="dd/MM/yyyy" Class="admin-input-group modern-input" />
                                    </MudItem>
                                </MudGrid>
                            }
                        </MudItem>
                        <MudItem xs="12">
                            <MudTextField ReadOnly="ReadOnly" @bind-Value="model.Narration" Lines="3" Label="Narration / Description" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.Narration)" Class="admin-input-group modern-input"></MudTextField>
                        </MudItem>
                    </MudGrid>
                </div>

                <div class="admin-glass-card pa-0 overflow-hidden">
                    <div class="px-6 py-4 border-bottom-subtle" style="background: rgba(255, 159, 67, 0.03); border-bottom: 1px solid rgba(255, 159, 67, 0.3);">
                        <span class="admin-section-label mb-0">Payment Breakdown</span>
                    </div>
                    <div class="modern-admin-table">
                        <MudGrid Class="admin-table-header px-6 py-3">
                            <MudItem xs="3"><span class="admin-header-text">ACCOUNT / USAGE</span></MudItem>
                            <MudItem xs="2"><span class="admin-header-text">COST CENTER</span></MudItem>
                            <MudItem xs="2"><span class="admin-header-text">DIMENSION</span></MudItem>
                            <MudItem xs="2"><span class="admin-header-text">AMOUNT</span></MudItem>
                            <MudItem xs="2"><span class="admin-header-text">REFERENCE</span></MudItem>
                            <MudItem xs="1"><span class="admin-header-text">ACTION</span></MudItem>
                        </MudGrid>

                        @foreach (var item in model.Entries)
                        {
                            var rowindex = model.Entries.IndexOf(item);
                            <MudGrid Class="px-6 py-3 border-bottom-subtle align-center">
                                @if (editrow == rowindex)
                                {
                                    <MudItem xs="3">
                                        <UsageCodeSelector For="@(() => gstusge)" Value="gstusge" ValueChanged="UsageCodeChanged" Class="admin-input-group"></UsageCodeSelector>
                                    </MudItem>
                                    <MudItem xs="2">
                                        <CostCenterSelector For="@(() => spe.CostCenter)" @bind-Value="@spe.CostCenter" @bind-ValueText="@spe.CostCenterVal" Class="admin-input-group" />
                                    </MudItem>
                                    <MudItem xs="2">
                                        <DimensionSelector For="@(() => spe.Dimension)" @bind-Value="@spe.Dimension" @bind-ValueText="@spe.DimensionVal" Class="admin-input-group" />
                                    </MudItem>
                                    <MudItem xs="2">
                                        <MudNumericField HideSpinButtons @bind-Value="@spe.Amount" Label="Amount" Variant="Variant.Outlined" Margin="Margin.Dense" Class="admin-input-group" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.CurrencyRupee" AdornmentColor="Color.Primary"></MudNumericField>
                                    </MudItem>
                                    <MudItem xs="2">
                                        <MudTextField @bind-Value="@spe.Reference" Label="Ref" Variant="Variant.Outlined" Margin="Margin.Dense" Class="admin-input-group"></MudTextField>
                                    </MudItem>
                                    <MudItem xs="1">
                                        <MudIconButton OnClick="AddParticulars" Color="Color.Success" Icon="@Icons.Material.Filled.CheckCircleOutline" Size="Size.Large" />
                                    </MudItem>
                                }
                                else
                                {
                                    <MudItem xs="3">
                                        <MudText Typo="Typo.body1" Style="font-weight: 700; color: #141A46;">@item.UsageCode</MudText>
                                        <MudText Typo="Typo.caption" Style="color: #667085;">@item.UsageCodeDescription</MudText>
                                    </MudItem>
                                    <MudItem xs="2"><MudText Typo="Typo.body2">@item.CostCenterVal</MudText></MudItem>
                                    <MudItem xs="2"><MudText Typo="Typo.body2">@item.DimensionVal</MudText></MudItem>
                                    <MudItem xs="2"><MudText Typo="Typo.body1" Style="font-weight: 800; color: #FF9F43;">₹ @item.Amount</MudText></MudItem>
                                    <MudItem xs="2"><MudText Typo="Typo.body2">@item.Reference</MudText></MudItem>
                                    <MudItem xs="1">
                                        <MudIconButton OnClick="@(() => EditEntry(rowindex))" Color="Color.Primary" Icon="@Icons.Material.Filled.Edit" Size="Size.Medium" />
                                    </MudItem>
                                }
                            </MudGrid>
                        }

                        @if (!ReadOnly && editrow < 0)
                        {
                            <div class="pa-5" style="background: rgba(255, 159, 67, 0.03); border-top: 1px solid rgba(255, 159, 67, 0.3);">
                                <MudGrid Spacing="2" Justify="Justify.Center">
                                    <MudItem xs="12" md="3">
                                        <UsageCodeSelector For="@(() => gstusge)" Value="gstusge" ValueChanged="UsageCodeChanged" Class="admin-input-group modern-input"></UsageCodeSelector>
                                    </MudItem>
                                    <MudItem xs="4" md="2">
                                        <CostCenterSelector For="@(() => spe.CostCenter)" @bind-Value="spe.CostCenter" @bind-ValueText="@spe.CostCenterVal" ReadOnly="@ReadOnly" Class="admin-input-group modern-input" />
                                    </MudItem>
                                    <MudItem xs="4" md="2">
                                        <DimensionSelector For="@(() => spe.Dimension)" @bind-Value="spe.Dimension" @bind-ValueText="@spe.DimensionVal" ReadOnly="@ReadOnly" Class="admin-input-group modern-input" />
                                    </MudItem>
                                    <MudItem xs="4" md="2">
                                        <MudNumericField HideSpinButtons @bind-Value="spe.Amount" Label="Amount" Variant="Variant.Outlined" Margin="Margin.Dense" Class="admin-input-group modern-input" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.CurrencyRupee" AdornmentColor="Color.Primary"></MudNumericField>
                                    </MudItem>
                                    <MudItem xs="8" md="2">
                                        <MudTextField @bind-Value="spe.Reference" Label="Reference" Variant="Variant.Outlined" Margin="Margin.Dense" Class="admin-input-group modern-input"></MudTextField>
                                    </MudItem>
                                    <MudItem xs="4" md="1" Class="d-flex align-center">
                                        <MudSpacer />
                                        <MudIconButton OnClick="AddParticulars" Color="Color.Primary" Variant="Variant.Filled" Style="background: #FF9F43; border-radius: 10px; height: 45px; width: 50px;" Icon="@Icons.Material.Filled.Add" Size="Size.Large" />
                                    </MudItem>
                                </MudGrid>
                            </div>
                        }
                    </div>
                </div>
            </EditForm>
        </div>
    </FormContent>
    <VerificationStatus>
        <AutherizationStatusComponent CreatedBy="@model.UserInfo" DocTypeID="@DocInfo.DocumentTypeID" DocDate="@DocDate" DocumentID="model.SundryPaymentID" OnReject="OnReject" OnApprove="Approve"></AutherizationStatusComponent>
    </VerificationStatus>
</DialogForm>

@code {

    [Parameter]
    public override SundryPaymentModel model { get { return _model; } set { _model = value; DocInfo.DocumentID = value.SundryPaymentID; } }
    private SundryPaymentModel _model;
    private TripAdvanceModel advanceModel;
    public bool entryedit = true;

    [Parameter]
    public bool DisableAddition { get; set; } = false;

    private SundryPaymentEntryModel spe = new SundryPaymentEntryModel();
    private GstUsageCodeModel gstusge = new();

    protected override DocumentInfoModel DocInfo { get; set; } = new DocumentInfoModel()
        {
            DocumentTypeID = 11,
            DocumentName = "SundryPayment"
        };


    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();

        if (model.NatureOfTransaction == null)
        {
            model.NatureOfTransaction = "Sundry Payment";
            model.TotalAmount = 0;
        }
        else if (model.SundryPaymentID != null && model.Entries.Count == 0)
        {
            // Load entries if the model has a valid ID and no entries
            model.Entries = Iservice.GetEntries(model.SundryPaymentID).ToList();
        }
        model.TotalAmount = model.Entries.Sum(x => x.Amount);
    }

    private int editrow = -1;

    // Method to edit a specific entry
    public void EditEntry(int a)
    {
        editrow = a;
        gstusge = new()
            {
                UsageCode = model.Entries[editrow].UsageCode,
                CoaID = model.Entries[editrow].CoaID,
                Description = model.Entries[editrow].UsageCodeDescription
            };
        spe = (SundryPaymentEntryModel)model.Entries[editrow].Clone();
    }

    // Method to handle changes in the GST usage code
    void UsageCodeChanged(GstUsageCodeModel uc)
    {
        gstusge = uc;
        spe.UsageCode = uc?.UsageCode;
        spe.UsageCodeDescription = uc?.Description;
        spe.CoaID = uc?.CoaID;
    }

    // Method to approve the sundry payment
    protected override int UpdateApproval(DataApprovedStatus aprvd)
    {
        // Call the service to approve the payment and return the result
        int result = Iservice.Approve(model.SundryPaymentID, model.UserInfo.UserID, aprvd.Remarks);
        return result;
    }

    // Method to handle rejection of the payment
    protected void OnReject()
    {
        // Cancel the advance associated with the paymentc
        advanceModel = Iadvance.Cancel(DocInfo.DocumentTypeID, DocInfo.DocumentID);
        if (advanceModel.TripAdvanceID != null)
        {
            snackbar.Add("Advance Removed", Severity.Warning);
        }
    }

    // Method to add particulars to the payment entry
    public void AddParticulars()
    {
        spe.BranchID = BranchID;
        if (dialogForm.validate(spe, editContext))
        {
            if (editrow > -1)
            {
                model.Entries[editrow] = (SundryPaymentEntryModel)spe.Clone();
                editrow = -1;
            }
            else
            {
                model.Entries.Add(spe);
            }
            CalculateTotalAmount(model.BankCharges);
            spe = new();
            gstusge = null;
        }
    }

    // Method to calculate the total amount based on bank charges
    public void CalculateTotalAmount(decimal? val)
    {
        model.BankCharges = val;
        model.TotalAmount = model.Entries.Sum(x => x.Amount);
        if (model.PaymentMode != null)
        {
            if (model.PaymentMode.ToLower().Trim() == ("Bank").ToLower().Trim())
            {
                model.TotalAmount += model?.BankCharges ?? 0;
            }
        }
        else
        {
            snackbar.Add("PaymentMode is not selected !", Severity.Warning);
        }
    }

    // Method to handle changes in the payment mode
    public void OnChangePaymentMode(string? val)
    {
        model.PaymentMode = val;
        CalculateTotalAmount(model.BankCharges);
    }

    // Asynchronous method to update the SundryPaymentModel
    protected override async Task<int> Update(SundryPaymentModel editModel)
       {
        // Get the available balance for the branch
        var balance = Icoa.GetBalance(BranchID, 0, model.PaymentArdCode, null, DateTime.Today);
        if (model.TotalAmount > balance && model.PaymentMode != "Bank")
        {
            snackbar.Add(string.Format("insufficient balance! Only Rs {0} Available for {1}", balance, DateTime.Today.ToShortDateString()), Severity.Warning);
            return 0;
        }
        if (model.OtherBranchID is not null && model.OtherBranchID != BranchID)
        {
            model.IsInterBranch = true;
            model.Entries.ForEach(x => x.BranchID = model.OtherBranchID);
        }
        if (model.PaymentMode == "Cash" && model.TotalAmount > 10000)
        {
            snackbar.Add("Cash Payment above 10000 is Restricted!", Severity.Warning);
        }

        // Call the service to update the model
        var UpdatedModel = Iservice.Update(model);
        model.SundryPaymentID = UpdatedModel.SundryPaymentID;
        return model.SundryPaymentID.Value;
    }
}

