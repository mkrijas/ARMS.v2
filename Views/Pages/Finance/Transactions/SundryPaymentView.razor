@page "/SundryPaymentView/"
@page "/SundryPaymentView/{interbranch:bool}/{id:int}"
@page "/SundryPaymentView/{interbranch:bool}"

@inherits ViewComponentBase<SundryPaymentModel>
@inject ISundryPaymentService Iservice
@inject IDialogService DialogService
@inject IGstUsageIDService Iusage
@inject IConfigTable Iconfig

@if (_isLoading)
{
    <div style="display: flex; justify-content: center; align-items: center; min-height: 400px;">
        <LoaderComponent IsFullScreen="true" 
                        ShowLogo="false" 
                        Size="medium" 
                        LoadingText="Loading Sundry Payments" 
                        SubText="Please wait..." />
    </div>
}
else
{
<div class="admin-page-container">
    <div class="admin-header-tiered mb-6">
        <div class="d-flex align-center justify-space-between">
            <div>
                <MudText Typo="Typo.h4" Class="admin-title">
                    @(interbranch ? "Interbranch Sundry Payments" : "Sundry Payments")
                </MudText>
                <MudText Typo="Typo.body2" Class="admin-subtitle">Process miscellaneous payments, inter-branch transfers, and driver salary settlements.</MudText>
            </div>
            <div class="d-flex gap-2">
                <MudButton StartIcon="@Icons.Material.Filled.AirlineSeatReclineNormal" Variant="Variant.Outlined" Color="Color.Secondary" Class="admin-register-btn" OnClick="DriverPendingSalary" Disabled="@_busy">DRIVER SALARY</MudButton>
                <MudButton StartIcon="@Icons.Material.Filled.Add" Variant="Variant.Filled" Color="Color.Primary" Class="admin-register-btn" OnClick="@(()=> OpenForm(new SundryPaymentModel()))" Disabled="@_busy">ADD PAYMENT</MudButton>
            </div>
        </div>
    </div>

    <div class="admin-glass-card mb-6 pa-4">
        <div class="d-flex align-center gap-4">
            <div style="flex-grow: 1;">
                <MudTextField @bind-Value="searchTerm" Placeholder="Search Sundry Payments..." Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" Variant="Variant.Outlined" Margin="Margin.Dense" Class="admin-input-group" @onkeyup="HandleSearchKeyUp" Clearable="true" />
            </div>
            <div class="d-flex align-center gap-2">
                <MudText Typo="Typo.body2" Class="admin-td-secondary fw-600">Max Results:</MudText>
                <MudTextField @bind-Value="@NumberOfRecords" Variant="Variant.Outlined" Margin="Margin.Dense" Style="width: 80px; background: white;" />
            </div>
            <MudCheckBox T="bool" Label="Approved Entries" ValueChanged="((bool value)=>ToggleData(value))" Value="@ShowApproved" Size="Size.Small" Color="Color.Primary" Class="fw-600" />
        </div>
    </div>

    <div class="admin-glass-card pa-0 overflow-hidden">
        <MudTable Items="@collection" Dense="true" Hover="true" Elevation="0" Class="modern-admin-table">
            <HeaderContent>
                <MudTh><MudTableSortLabel SortBy="new Func<SundryPaymentModel, object>(x=> x.DocumentDate)"><span class="admin-header-text">DATE</span></MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<SundryPaymentModel, object>(x=> x.SundryPaymentID)" InitialDirection="SortDirection.Descending"><span class="admin-header-text">DOC NUMBER</span></MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<SundryPaymentModel, object>(x=> x.PaymentMode)"><span class="admin-header-text">MODE</span></MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<SundryPaymentModel, object>(x=> x.TotalAmount)"><span class="admin-header-text">AMOUNT</span></MudTableSortLabel></MudTh>
                <MudTh Style="text-align: right;"><span class="admin-header-text">ACTIONS</span></MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="DocumentDate">@context.DocumentDate?.ToShortDateString()</MudTd>
                <MudTd DataLabel="DocumentNumber">
                    <div class="d-flex align-center gap-2">
                        <MudText Typo="Typo.body2" Class="admin-td-primary fw-600">@context.DocumentNumber</MudText>
                        @if (context.AuthLevelId == 100)
                        {
                            <MudChip T="string" Color="Color.Error" Size="Size.Small" Variant="Variant.Text" Class="pa-0">Rejected</MudChip>
                        }
                    </div>
                </MudTd>
                <MudTd DataLabel="PaymentMode"><MudText Typo="Typo.body2" Class="admin-td-secondary">@context.PaymentMode</MudText></MudTd>
                <MudTd DataLabel="TotalAmount"><MudText Typo="Typo.body2" Class="admin-td-amount">@context.TotalAmount?.ToString("N2")</MudText></MudTd>
                <MudTd DataLabel="Actions" Style="text-align: right;">
                    <div class="d-flex justify-end gap-1">
                        <MudTooltip Text="View Details">
                            <MudIconButton OnClick="@(()=> OpenForm(context,true))" Color="Color.Info" Icon="@Icons.Material.Filled.GridView" Size="Size.Small" Variant="Variant.Text" />
                        </MudTooltip>
                        
                        <MudTooltip Text="Edit">
                            <MudIconButton Disabled="@(context.AuthLevelId != null)" OnClick="@(()=> OpenForm(context,false))" Color="Color.Primary" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Variant="Variant.Text" />
                        </MudTooltip>
                        
                        <MudTooltip Text="Delete">
                            <MudIconButton Disabled="@(context.AuthLevelId != null)" OnClick="@(()=> Delete(context.SundryPaymentID))" Color="Color.Error" Icon="@Icons.Material.Filled.DeleteOutline" Size="Size.Small" Variant="Variant.Text" />
                        </MudTooltip>

                        @if (@context.AuthLevelId == 99)
                        {
                            <EntryReversedComponent DocTypeID="DocInfo.DocumentTypeID" DocumentID="context.SundryPaymentID" MID="context.MID" DocumentNumber="@context.DocumentNumber"></EntryReversedComponent>
                            <MudTooltip Text="Print">
                                <MudIconButton OnClick="@(()=> Print(context.SundryPaymentID))" Color="Color.Tertiary" Icon="@Icons.Material.Filled.Print" Size="Size.Small" Variant="Variant.Text" />
                            </MudTooltip>
                        }
                        else if (@context.AuthLevelId != 100)
                        {
                            <MudTooltip Text="Verify">
                                <MudIconButton OnClick="@(()=> OpenForm(context,true))" Color="Color.Warning" Icon="@Icons.Material.Filled.Verified" Size="Size.Small" Variant="Variant.Text" />
                            </MudTooltip>
                        }
                    </div>
                </MudTd>
            </RowTemplate>
            <PagerContent>
                <div class="pa-4">
                    <MudTablePager PageSizeOptions="new int[] { 10, 20, 50, 100 }" />
                </div>
            </PagerContent>
        </MudTable>
    </div>
</div>

}

@code {

    private bool _isLoading = true;
    private DateTime _loadStartTime;

    protected override List<SundryPaymentModel> collection { get; set; } = new();
    protected override DocumentInfoModel DocInfo { get; set; } = new DocumentInfoModel()
        {
            DocumentTypeID = 11,
            DocumentName = "SundryPayment"
        };

    public Dictionary<string, string> ReportParameters { get; set; } = new();
    public string BranchName = "";

    protected override async Task OnInitializedAsync()
    {
        _loadStartTime = DateTime.Now;
        await base.OnInitializedAsync();
        var authprov = await auth.GetAuthenticationStateAsync();
        var User = authprov.User;
        BranchName = User.Claims.First(x => x.Type == "BranchName").Value;

        if (id != null && collection != null && collection.Any(g => g.SundryPaymentID == id))
        {
            await OpenForm(collection.FirstOrDefault(s => s.SundryPaymentID == id), true);
        }
        await EnsureMinimumLoadTime();
        _isLoading = false;
    }

    private async Task EnsureMinimumLoadTime()
    {
        var elapsed = (DateTime.Now - _loadStartTime).TotalMilliseconds;
        if (elapsed < 100)
        {
            await Task.Delay(100 - (int)elapsed);
        }
    }

    // Asynchronous method to open a form for adding or editing a SundryPaymentModelc
    protected override async Task OpenForm(SundryPaymentModel model, bool ReadOnly = false, bool DisableAddition = false)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        _busy = true;
        model.IsInterBranch = interbranch;
        DialogOptions mediumWidth = new DialogOptions() { MaxWidth = MaxWidth.Large, FullWidth = true };
        DialogParameters parms = new DialogParameters();
        parms.Add("model", model.Clone());
        parms.Add("ReadOnly", ReadOnly);
        parms.Add("OnApproved", new EventCallbackFactory().Create(this, () => LoadData(ShowApproved, NumberOfRecords)));
        var dialog = await dialogService.ShowAsync<SundryPaymentDialog>(model == null ? "ADD" : "EDIT", parms, mediumWidth);
        var result = await dialog.Result;
        var isCancelled = result.Canceled;
        if (!isCancelled)
        {
            var ReturnData = (SundryPaymentModel)result.Data;
        }
        LoadData(ShowApproved, NumberOfRecords);
        await Task.Delay(200);
        _busy = false;
    }

    // Asynchronous method to print the sundry payment
    private async Task Print(int? SundryPaymentID)
    {
        ReportParameters.Clear();
        ReportParameters.Add("SundryPaymentID", SundryPaymentID.ToString());
        ReportParameters.Add("BranchName", BranchName);
        var parameters = new DialogParameters();
        parameters.Add("Parameters", ReportParameters); // Add the dictionary as a parameter
        parameters.Add("ReportName", "PrintSundryPayment");

        DialogOptions maxWidth = new DialogOptions() { MaxWidth = MaxWidth.Medium, FullWidth = true };
        var result = await DialogService.ShowAsync<PrintDialog>("PRINT", parameters, maxWidth);
    }

    // Asynchronous method to handle driver pending salary
    private async Task DriverPendingSalary()
    {
        DialogOptions mediumWidth = new DialogOptions() { MaxWidth = MaxWidth.Large, FullWidth = true };
        DialogParameters parms = new DialogParameters();
        parms.Add("BranchID", BranchID);
        var dialog = await dialogService.ShowAsync<DriverPendingSalary>("Stockists Freight", parms, mediumWidth);

        var result = await dialog.Result;
        if (!result.Canceled)
        {
            var data = (List<DriverPendingSalaryModel>)result.Data;

            try
            {
                SundryPaymentModel DriverPayableModel = new SundryPaymentModel()
                    {
                        BranchID = BranchID,
                        NatureOfTransaction = "Driver Salary",
                        PayeeContactNo = data.First().Driver.Mobile,
                        PayeeName = data.First().Driver.DriverName,
                        TotalAmount = data.Sum(x => x.Amount)

                    };

                // Retrieve the usage code for driver salary payable
                GstUsageCodeModel UsageCode = Iusage.SelectByCode(Iconfig.GetByID("DriverSalaryPayable").ValueString);

                foreach (var item in data)
                {
                    DriverPayableModel.Entries.Add(new SundryPaymentEntryModel()
                        {
                            Amount = item.Amount,
                            BranchID = BranchID,
                            CoaID = UsageCode.CoaID,
                            Reference = $"{item.Driver.DriverCode} - {item.Driver.DriverName} - {item.EntryRef}",
                            UsageCode = UsageCode.UsageCode,
                            UsageCodeDescription = UsageCode.Description,
                            SubArdCode = item.Driver.DriverCode
                        });
                }

                await OpenForm(DriverPayableModel, false, true);

            }
            catch (Exception ex)
            {
                snackbar.Add(ex.Message, Severity.Error);
            }
        }
    }
}
