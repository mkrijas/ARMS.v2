@page "/SundryPaymentView"
@using ArmsModels.BaseModels.Finance.Transactions
@inject ISundryPaymentService Iservice
@inject ICostCenterService costIservice
@inject IDimensionService dimensionIservice
@inject NavigationManager uriHelper;
@inject MudBlazor.ISnackbar snackbar
@inject AuthenticationStateProvider auth
@attribute [Authorize]
@inject IDialogService DialogService




<MudGrid Spacing="4">
    <MudItem xs="12">
        <MudTable Items="@collection" Dense="true" Hover="true" Striped="true" Elevation="10" @bind-place="model">
            <ToolBarContent>
                <MudText Typo="Typo.h6">Sundry Payment </MudText>
                <MudTooltip Text="New Sundry Paymnet">
                    <MudIconButton Icon="@Icons.Material.Filled.Add" Title="Add" @onclick="@(()=> OpenDialog(model,false,false))" Color="Color.Dark" Size="Size.Small"></MudIconButton>
                </MudTooltip>
                <MudSpacer></MudSpacer>
                <MudCheckBox Label="Approved Entries" CheckedChanged="((bool value)=>ApprovedChanged(value))" Checked="@IsApproved" Size="Size.Medium" Color="Color.Primary"></MudCheckBox>

            </ToolBarContent>
            <HeaderContent>
                <MudTh><MudTableSortLabel SortBy="new Func<SundryPaymentModel, object>(x=> x.DocumentDate)" InitialDirection="SortDirection.Ascending">DocumentDate</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<SundryPaymentModel, object>(x=> x.DocumentNumber)" InitialDirection="SortDirection.Ascending">DocumentNumber</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<SundryPaymentModel, object>(x=> x.PaymentMode)" InitialDirection="SortDirection.Ascending">Payment Route</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<SundryPaymentModel, object>(x=> x.TotalAmount)" InitialDirection="SortDirection.Ascending">Amount</MudTableSortLabel></MudTh>
                <MudTh>Actions</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="DocumentDate">@context.DocumentDate?.ToShortDateString()</MudTd>


                <MudTd DataLabel="DocumentNumber">@context.DocumentNumber</MudTd>
                <MudTd DataLabel="PaymentMode">@context.PaymentMode</MudTd>
                <MudTd DataLabel="TotalAmount">@context.TotalAmount</MudTd>
                <MudTd DataLabel="">
                    @if (@context.AuthLevelId == null)
                    {
                        <MudTooltip Text="Edit">
                            <MudFab @onclick="@(()=> OpenDialog(context,false,false))" Color="Color.Primary" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" IconSize="Size.Small" />
                        </MudTooltip>
                        <MudFab @onclick="@(()=> Delete(context))" Color="Color.Error" title="Delete" Icon="@Icons.Material.Filled.Delete" Size="Size.Small" IconSize="Size.Small" />

                    }
                    @if (@context.AuthLevelId != 99)
                    {
                        <MudFab @onclick="@(()=> OpenDialog(context,true,false))" Color="Color.Warning" Icon="@Icons.Material.Filled.Verified" title="Verify" Size="Size.Small" IconSize="Size.Small" />

                    }
                    <MudFab @onclick="@(()=> OpenDialog(context,true,true))" Color="Color.Info" Icon="@Icons.Material.Filled.GridView" title="View" Size="Size.Small" IconSize="Size.Small" />



                </MudTd>
            </RowTemplate>

            <PagerContent>
                <MudTablePager PageSizeOptions="new int[] { 5, 10, 20, 50, 100 }" />

            </PagerContent>
        </MudTable>
    </MudItem>
</MudGrid>

@code {

    private SundryPaymentModel model = new SundryPaymentModel();
    public bool IsApproved { get; set; } = false;
    private List<SundryPaymentModel> collection = new List<SundryPaymentModel>();
    protected override void OnInitialized()
    {
        model = new();
        GetAll(IsApproved);
    }
    void ApprovedChanged(bool value)
    {

        IsApproved = value;
        GetAll(IsApproved);

    }
    private void GetAll(bool val)
    {


        if (val)
        {
            collection = Iservice.Select().Where(x => x.AuthLevelId == 99).ToList();

        }
        else
        {
            collection = Iservice.Select().Where(x => x.AuthLevelId != 99).ToList();

        }


    }
    private void Delete(SundryPaymentModel tx)
    {
        Iservice.Delete(tx.SundryPaymentID, "Rijas");
        snackbar.Add("Deleted Successfully", Severity.Success);
        GetAll(IsApproved);
    }

    private async Task OpenDialog(SundryPaymentModel tds, bool ReadOnly, bool View)
    {

        DialogOptions mediumWidth = new DialogOptions() { MaxWidth = MaxWidth.Medium, FullWidth = true };

        DialogParameters parms = new DialogParameters();
        parms.Add("model", tds);
        parms.Add("IsReadOnly", ReadOnly);
        parms.Add("IsView", View);
        var dialog = DialogService.Show<SundryPaymentDialog>(tds.SundryPaymentID == null ? "ADD" : "EDIT", parms, mediumWidth);
        var result = await dialog.Result;


        GetAll(IsApproved);



    }

}
