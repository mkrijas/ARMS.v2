@inject ISundryReceiptService Iservice
@inherits DialogFormComponentBase<SundryReceiptModel>


<DialogForm @ref="@dialogForm" ReadOnly="@ReadOnly" Title="Sundry Receipt" Subtitle="Efficiently record miscellaneous incoming funds with multi-account distribution." Icon="@Icons.Material.Filled.Receipt" AdminStyle="true" formID="sundryReceiptForm" DocumentDetails="DocInfo" model="@_model" TotalAmount="model.TotalAmount" _busy="_busy">
    <FormContent>
        <div class="dialog-content-wrapper">
            <EditForm id="sundryReceiptForm" OnValidSubmit="OnValidSubmit" EditContext="editContext">
                <ObjectGraphDataAnnotationsValidator />
                
                <div class="admin-glass-card pa-6 mb-6">
                    <div class="d-flex align-center mb-4">
                        <MudIcon Icon="@Icons.Material.Filled.AccountBalance" Color="Color.Primary" Class="mr-2" />
                        <span class="admin-section-label mb-0">Source & Mode</span>
                    </div>
                    <MudGrid Spacing="3">
                        @if (_model.IsInterBranch)
                        {
                            <MudItem xs="12" md="6">
                                <BranchSelector For="@(() => OtherBranch)" Value="@OtherBranch" ValueChanged="@OtherBranchSelected" LabelName="Target Branch (Payment Made for)" Class="admin-input-group modern-input" />
                            </MudItem>
                            <MudItem xs="12" md="6">
                                <MudSelect For="@(() => _model.InterBranchTranID)" Label="Internal Transaction Type" ReadOnly="ReadOnly" @bind-Value="_model.InterBranchTranID" T="int?" Variant="Variant.Outlined" Margin="Margin.Dense" Class="admin-input-group modern-input">
                                    @foreach (var ditem in InterBranchTranTypes)
                                    {
                                        <MudSelectItem Value="@ditem.ID">@ditem?.TransactionTypeName</MudSelectItem>
                                    }
                                </MudSelect>
                            </MudItem>
                        }
                        <MudItem xs="12">
                            <PaymentAccountSelector BranchID="@(BranchID ?? 0)" @bind-PaymentMode="@_model.ReceiptMode" HideBankCharges HideTool @bind-ArdCode="@_model.ReceiptArdCode" @bind-CoaID="@_model.ReceiptCoaID" Class="admin-input-group modern-input" />
                        </MudItem>
                    </MudGrid>
                </div>

                <div class="admin-glass-card pa-6 mb-6">
                    <div class="d-flex align-center mb-4">
                        <MudIcon Icon="@Icons.Material.Filled.Person" Color="Color.Primary" Class="mr-2" />
                        <span class="admin-section-label mb-0">Payer & Document Details</span>
                    </div>
                    <MudGrid Spacing="3">
                        <MudItem xs="12" md="4">
                            <MudTextField ReadOnly="ReadOnly" @bind-Value="_model.Reference" Label="Reference / Chq No" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => _model.Reference)" Class="admin-input-group modern-input" />
                        </MudItem>
                        <MudItem xs="12" md="4">
                            <MudTextField ReadOnly="ReadOnly" @bind-Value="_model.PayerName" Label="Payer Name" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => _model.PayerName)" Class="admin-input-group modern-input" />
                        </MudItem>
                        <MudItem xs="12" md="4">
                            <MudNumericField ReadOnly="ReadOnly" MaxLength="10" HideSpinButtons @bind-Value="_model.PayerContactNo" Label="Payer Contact No" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => _model.PayerContactNo)" Class="admin-input-group modern-input" />
                        </MudItem>
                        <MudItem xs="12" md="4">
                            <MudDatePicker ReadOnly="ReadOnly" Label="Document Date" Variant="Variant.Outlined" Margin="Margin.Dense" DisableToolbar="true" Editable="true" @bind-Date="_model.DocumentDate" DateFormat="dd/MM/yyyy" MaxDate="DateTime.Now" Class="admin-input-group modern-input" />
                        </MudItem>
                        <MudItem xs="12">
                            <MudTextField ReadOnly="ReadOnly" @bind-Value="_model.Narration" Lines="2" Label="Narration" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => _model.Narration)" Class="admin-input-group modern-input" />
                        </MudItem>
                    </MudGrid>
                </div>

                <div class="admin-glass-card pa-0 overflow-hidden">
                    <div class="px-6 py-4 border-bottom-subtle" style="background: rgba(255, 159, 67, 0.03); border-bottom: 1px solid rgba(255, 159, 67, 0.3);">
                        <span class="admin-section-label mb-0">Receipt Breakdown</span>
                    </div>

                    <div class="modern-admin-table">
                        <MudGrid Class="admin-table-header px-6 py-3">
                            <MudItem xs="3"><span class="admin-header-text">ACCOUNT / USAGE CODE</span></MudItem>
                            <MudItem xs="2"><span class="admin-header-text">COST CENTER</span></MudItem>
                            <MudItem xs="2"><span class="admin-header-text">DIMENSION</span></MudItem>
                            <MudItem xs="2"><span class="admin-header-text">AMOUNT</span></MudItem>
                            <MudItem xs="2"><span class="admin-header-text">REFERENCE</span></MudItem>
                            <MudItem xs="1"></MudItem>
                        </MudGrid>

                        @foreach (var item in _model.Entries)
                        {
                            <MudGrid Class="px-6 py-3 border-bottom-subtle align-center">
                                <MudItem xs="3">
                                    <MudText Typo="Typo.body2" Style="font-weight: 700;">@item.UsageCodeDescription</MudText>
                                    <MudText Typo="Typo.caption" Style="color: #667085;">@item.UsageCode</MudText>
                                </MudItem>
                                <MudItem xs="2">
                                    <MudText Typo="Typo.body2">@item.CostCenterVal</MudText>
                                </MudItem>
                                <MudItem xs="2">
                                    <MudText Typo="Typo.body2">@item.DimensionVal</MudText>
                                </MudItem>
                                <MudItem xs="2">
                                    <MudText Typo="Typo.body2" Style="font-weight: 800; color: #141A46;">₹ @item.Amount</MudText>
                                </MudItem>
                                <MudItem xs="2">
                                    <MudText Typo="Typo.caption" Style="font-style: italic;">@item.Reference</MudText>
                                </MudItem>
                                <MudItem xs="1"></MudItem>
                            </MudGrid>
                        }

                        @if (!ReadOnly && !DisableAddition)
                        {
                            <div class="pa-5" style="background: rgba(255, 159, 67, 0.03); border-top: 1px solid rgba(255, 159, 67, 0.3);">
                                <MudGrid Spacing="2" Class="align-center">
                                    <MudItem xs="12" md="3">
                                        <UsageCodeSelector For="@(() => gstusge)" Value="gstusge" ValueChanged="UsageCodeChanged" Class="admin-input-group modern-input" />
                                    </MudItem>
                                    <MudItem xs="12" md="2">
                                        <CostCenterSelector For="@(() => spe.CostCenter)" @bind-Value="spe.CostCenter" @bind-ValueText="@spe.CostCenterVal" ReadOnly="@ReadOnly" Class="admin-input-group modern-input" />
                                    </MudItem>
                                    <MudItem xs="12" md="2">
                                        <DimensionSelector For="@(() => spe.Dimension)" @bind-Value="spe.Dimension" @bind-ValueText="@spe.DimensionVal" ReadOnly="@ReadOnly" Class="admin-input-group modern-input" />
                                    </MudItem>
                                    <MudItem xs="6" md="2">
                                        <MudNumericField HideSpinButtons @bind-Value="spe.Amount" Label="Amount" Variant="Variant.Outlined" Margin="Margin.Dense" Class="admin-input-group modern-input" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.CurrencyRupee" AdornmentColor="Color.Primary" />
                                    </MudItem>
                                    <MudItem xs="6" md="2">
                                        <MudTextField @bind-Value="spe.Reference" Label="Reference" Variant="Variant.Outlined" Margin="Margin.Dense" Class="admin-input-group modern-input" />
                                    </MudItem>
                                    <MudItem xs="12" md="1" Class="d-flex justify-center">
                                        <MudIconButton OnClick="AddParticulars" Color="Color.Primary" Variant="Variant.Filled" Style="background: #FF9F43; border-radius: 10px; height: 45px; width: 50px;" Icon="@Icons.Material.Filled.Add" Size="Size.Large" />
                                    </MudItem>
                                </MudGrid>
                            </div>
                        }
                    </div>
                </div>
            </EditForm>
        </div>
    </FormContent>
    <VerificationStatus>
        <AutherizationStatusComponent CreatedBy="@_model.UserInfo" DocTypeID="@DocInfo.DocumentTypeID" DocDate="@DocDate" DocumentID="_model.SundryReceiptID" OnApprove="Approve" OnVerified="Verified"></AutherizationStatusComponent>
    </VerificationStatus>
</DialogForm>

@code {

    [Parameter]
    public override SundryReceiptModel model { get { return _model; } set { _model = value; DocInfo.DocumentID = value.SundryReceiptID; } }
    private SundryReceiptModel _model;

    [Parameter]
    public bool DisableAddition { get; set; } = false;

    private SundryReceiptEntryModel spe = new SundryReceiptEntryModel();
    private GstUsageCodeModel gstusge = new();
    //public stringBranchIDer { get; set; }

    protected override DocumentInfoModel DocInfo { get; set; } = new DocumentInfoModel()
        {
            DocumentTypeID = 12,
            DocumentName = "SundryReceipt"
        };

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();
        if (model.SundryReceiptID == null)
        {
            model.NatureOfTransaction = "Sundry Receipt";
        }
        else
        {
            // Load entries if the model has a valid ID
            model.Entries = Iservice.GetEntries(model.SundryReceiptID).ToList();
        }
    }

    // Method to handle changes in the amount for a specific entry
    void AmountChanged(decimal? e, SundryReceiptEntryModel sr)
    {
        sr.Amount = e;
        model.TotalAmount = model.Entries.Sum(x => x.Amount);
    }

    // Method to handle changes in the GST usage code
    void UsageCodeChanged(GstUsageCodeModel uc)
    {
        gstusge = uc;
        spe.UsageCode = uc?.UsageCode;
        spe.UsageCodeDescription = uc?.Description;
        spe.CoaID = uc?.CoaID;
    }

    // Method to add particulars to the receipt entry
    public void AddParticulars()
    {
        spe.BranchID = BranchID;
        if (dialogForm.validate(spe, editContext))
        {
            model.Entries.Add(spe);
            model.TotalAmount = model.Entries.Sum(x => x.Amount);
            spe = new();
            gstusge = null;
        }
    }

    // Method to approve the sundry receipt
    protected override int UpdateApproval(DataApprovedStatus aprvd)
    {
        // Call the service to approve the receipt and return the result
        int result = Iservice.Approve(model.SundryReceiptID, model.UserInfo.UserID, aprvd.Remarks);
        return result;
    }

    // Asynchronous method to update the SundryReceiptModel
    protected override async Task<int> Update(SundryReceiptModel editModel)
    {
        if (model.OtherBranchID is not null && model.OtherBranchID != BranchID)
        {
            model.IsInterBranch = true;
            model.Entries.ForEach(x => x.BranchID = model.OtherBranchID);
        }

        // Call the service to update the model
        model = Iservice.Update(model);
        return model.SundryReceiptID.Value;
    }

}

