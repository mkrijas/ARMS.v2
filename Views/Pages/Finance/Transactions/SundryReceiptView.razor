@page "/SundryReceiptView/"
@page "/SundryReceiptView/{interbranch:bool}" 
@page "/SundryReceiptView/{interbranch:bool}/{id:int}"
@inherits ViewComponentBase<SundryReceiptModel>
@inject ISundryReceiptService Iservice
@inject IConfigTable Iconfig
@inject IGstUsageIDService Iusage
@inject ITripAdvanceService Iadvance
@inject ITripService ItripService
@inject ITruckService ItruckService
@inject ITruckAvailabilityService ItruckavailablityService
@inject IDialogService DialogService
@using Core.IDataServices.Operations;
@using Views.Data
@using System.Threading;

@if (_isLoading)
{
    <div style="display: flex; justify-content: center; align-items: center; min-height: 400px;">
        <LoaderComponent IsFullScreen="true" 
                        ShowLogo="false" 
                        Size="medium" 
                        LoadingText="Loading Sundry Receipts" 
                        SubText="Please wait..." />
    </div>
}
else
{
<div class="admin-page-container">
    <div class="admin-header-tiered mb-6">
        <div class="d-flex align-center justify-space-between">
            <div>
                <MudText Typo="Typo.h4" Class="admin-title">
                    @(interbranch ? "Interbranch Sundry Receipts" : "Sundry Receipts")
                </MudText>
                <MudText Typo="Typo.body2" Class="admin-subtitle">Manage miscellaneous receipts, settlements for freight, advances, and compensation.</MudText>
            </div>
            <div class="d-flex gap-2">
                <MudTooltip Text="Stockists Freight">
                    <MudButton StartIcon="@Icons.Material.Filled.NaturePeople" Variant="Variant.Outlined" Color="Color.Secondary" Class="admin-register-btn" OnClick="StockistsFreightSelection" Disabled="@_busy">FREIGHT</MudButton>
                </MudTooltip>
                <MudTooltip Text="Advance Receivable">
                    <MudButton StartIcon="@Icons.Material.Filled.Money" Variant="Variant.Outlined" Color="Color.Secondary" Class="admin-register-btn" OnClick="AdvaceReceivableSelection" Disabled="@_busy">ADVANCE</MudButton>
                </MudTooltip>
                <MudTooltip Text="Damage Receivable">
                    <MudButton StartIcon="@Icons.Material.Filled.BrokenImage" Variant="Variant.Outlined" Color="Color.Secondary" Class="admin-register-btn" OnClick="DamageReceivableSelection" Disabled="@_busy">DAMAGE</MudButton>
                </MudTooltip>
                <MudButton StartIcon="@Icons.Material.Filled.Add" Variant="Variant.Filled" Color="Color.Primary" Class="admin-register-btn" OnClick="@(()=> OpenForm(new SundryReceiptModel(),false))" Disabled="@_busy">ADD RECEIPT</MudButton>
            </div>
        </div>
    </div>

    <div class="admin-glass-card mb-6 pa-4">
        <div class="d-flex align-center gap-4">
            <div style="flex-grow: 1;">
                <MudTextField @bind-Value="searchTerm" Placeholder="Search Sundry Receipts..." Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" Variant="Variant.Outlined" Margin="Margin.Dense" Class="admin-input-group" @onkeyup="HandleSearchKeyUp" Clearable="true" />
            </div>
            <div class="d-flex align-center gap-2">
                <MudText Typo="Typo.body2" Class="admin-td-secondary fw-600">Max Results:</MudText>
                <MudTextField @bind-Value="@NumberOfRecords" Variant="Variant.Outlined" Margin="Margin.Dense" Style="width: 80px; background: white;" />
            </div>
            <MudCheckBox T="bool" Label="Approved Entries" ValueChanged="((bool value)=>ToggleData(value))" Value="@ShowApproved" Size="Size.Small" Color="Color.Primary" Class="fw-600" />
        </div>
    </div>

    <div class="admin-glass-card pa-0 overflow-hidden">
        <MudTable Items="@collection" Dense="true" Hover="true" Elevation="0" Class="modern-admin-table">
            <HeaderContent>
                <MudTh><MudTableSortLabel SortBy="new Func<SundryReceiptModel, object>(x=> x.DocumentDate)"><span class="admin-header-text">DATE</span></MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<SundryReceiptModel, object>(x=> x.SundryReceiptID)" InitialDirection="SortDirection.Descending"><span class="admin-header-text">DOC NUMBER</span></MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<SundryReceiptModel, object>(x=> x.ReceiptMode)"><span class="admin-header-text">MODE</span></MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<SundryReceiptModel, object>(x=> x.TotalAmount)"><span class="admin-header-text">AMOUNT</span></MudTableSortLabel></MudTh>
                <MudTh Style="text-align: right;"><span class="admin-header-text">ACTIONS</span></MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="DocumentDate">@context.DocumentDate?.ToShortDateString()</MudTd>
                <MudTd DataLabel="DocumentNumber">
                    <div class="d-flex align-center gap-2">
                        <MudText Typo="Typo.body2" Class="admin-td-primary fw-600">@context.DocumentNumber</MudText>
                        @if (context.AuthLevelId == 100)
                        {
                            <MudChip T="string" Color="Color.Error" Size="Size.Small" Variant="Variant.Text" Class="pa-0">Rejected</MudChip>
                        }
                    </div>
                </MudTd>
                <MudTd DataLabel="ReceiptMode"><MudText Typo="Typo.body2" Class="admin-td-secondary">@context.ReceiptMode</MudText></MudTd>
                <MudTd DataLabel="TotalAmount"><MudText Typo="Typo.body2" Class="admin-td-amount">@context.TotalAmount?.ToString("N2")</MudText></MudTd>
                <MudTd DataLabel="Actions" Style="text-align: right;">
                    <div class="d-flex justify-end gap-1">
                        <MudTooltip Text="View Details">
                            <MudIconButton OnClick="@(()=> OpenForm(context,true))" Color="Color.Info" Icon="@Icons.Material.Filled.GridView" Size="Size.Small" Variant="Variant.Text" />
                        </MudTooltip>
                        
                        <MudTooltip Text="Edit">
                            <MudIconButton Disabled="@(context.AuthLevelId != null)" OnClick="@(()=> OpenForm(context,false))" Color="Color.Primary" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Variant="Variant.Text" />
                        </MudTooltip>
                        
                        <MudTooltip Text="Delete">
                            <MudIconButton Disabled="@(context.AuthLevelId != null)" OnClick="@(()=> Delete(context.SundryReceiptID))" Color="Color.Error" Icon="@Icons.Material.Filled.DeleteOutline" Size="Size.Small" Variant="Variant.Text" />
                        </MudTooltip>

                        @if (@context.AuthLevelId == 99)
                        {
                            <EntryReversedComponent DocTypeID="DocInfo.DocumentTypeID" DocumentID="context.SundryReceiptID" MID="context.MID" DocumentNumber="@context.DocumentNumber"></EntryReversedComponent>
                            <MudTooltip Text="Print">
                                <MudIconButton OnClick="@(()=> Print(context.SundryReceiptID))" Color="Color.Tertiary" Icon="@Icons.Material.Filled.Print" Size="Size.Small" Variant="Variant.Text" />
                            </MudTooltip>
                        }
                        else if (@context.AuthLevelId != 100)
                        {
                            <MudTooltip Text="Verify">
                                <MudIconButton OnClick="@(()=> OpenForm(context,true))" Color="Color.Warning" Icon="@Icons.Material.Filled.Verified" Size="Size.Small" Variant="Variant.Text" />
                            </MudTooltip>
                        }
                    </div>
                </MudTd>
            </RowTemplate>
            <PagerContent>
                <div class="pa-4">
                    <MudTablePager PageSizeOptions="new int[] { 10, 20, 50, 100 }" />
                </div>
            </PagerContent>
        </MudTable>
    </div>
</div>

}

@code {

    private bool _isLoading = true;
    private DateTime _loadStartTime;

    protected override List<SundryReceiptModel> collection { get; set; } = new();
    protected override DocumentInfoModel DocInfo { get; set; } = new DocumentInfoModel()
        {
            DocumentTypeID = 12,
            DocumentName = "SundryReceipt"
        };

    public Dictionary<string, string> ReportParameters { get; set; } = new();
    public string BranchName = "";

    // Method called when the component is initialized 
    protected override async Task OnInitializedAsync()
    {
        _loadStartTime = DateTime.Now;
        await base.OnInitializedAsync();
        var authprov = await auth.GetAuthenticationStateAsync();
        var User = authprov.User;
        BranchName = User.Claims.First(x => x.Type == "BranchName").Value;

        if (id != null && collection != null && collection.Any(g => g.SundryReceiptID == id))
        {
            await OpenForm(collection.FirstOrDefault(s => s.SundryReceiptID == id), true);
        }
        await EnsureMinimumLoadTime();
        _isLoading = false;
    }

    private async Task EnsureMinimumLoadTime()
    {
        var elapsed = (DateTime.Now - _loadStartTime).TotalMilliseconds;
        if (elapsed < 100)
        {
            await Task.Delay(100 - (int)elapsed);
        }
    }

    // Method to handle selection of stockists freight
    private async Task StockistsFreightSelection()
    {
        DialogOptions mediumWidth = new DialogOptions() { MaxWidth = MaxWidth.Large, FullWidth = true };
        DialogParameters parms = new DialogParameters();
        parms.Add("BranchID", BranchID);
        var dialog = await dialogService.ShowAsync<StockistsFreightView>("Stockists Freight", parms, mediumWidth);       

        var result = await dialog.Result;
        if (!result.Canceled)
        {
            var data = (List<StockistFreightReceivableModel>)result.Data;

            try
            {
                SundryReceiptModel StockistsReceiptModel = new SundryReceiptModel()
                {
                    BranchID = BranchID,
                    NatureOfTransaction = "StockistFreight",
                    PayerContactNo = data.First().Consignee.Mobile,
                    PayerName = data.First().Consignee.ConsigneeName,
                    TotalAmount = data.Sum(x => x.Amount)

                };

                // Get usage code for the consignee
                GstUsageCodeModel UsageCode = Iusage.SelectByCode(Iconfig.GetByID("ConsigneeUsageCode").ValueString);

                foreach (var item in data)
                {
                    StockistsReceiptModel.Entries.Add(new SundryReceiptEntryModel()
                    {
                        Amount = item.Amount,
                        BranchID = BranchID,
                        CoaID = UsageCode.CoaID,
                        Reference = item.EntryRef,
                        UsageCode = UsageCode.UsageCode,
                        UsageCodeDescription = UsageCode.Description,
                        SubArdCode = item.Consignee.ArdCode
                    });
                }

                await OpenForm(StockistsReceiptModel, false, true);

            }
            catch (Exception ex)
            {
                snackbar.Add(ex.Message, Severity.Error);
            }
        }
    }

