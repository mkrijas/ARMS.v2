@page "/TaxPurchase"
@inject ITaxPurchaseService Iservice
@inject MudBlazor.ISnackbar snackbar

@inject AuthenticationStateProvider auth
@attribute [Authorize]
@inject IDialogService DialogService
@using Inventory


<MudGrid Spacing="4">
   <MudItem xs="12">
        <MudTable Items="@collection"   Dense="true" Hover="true"  Striped="true" Elevation="10" Filter="new Func<TaxPurchaseModel, bool>(search)" @bind-place="model">
           

             <ToolBarContent>
                <MudText Typo="Typo.h6">Tax Purchase</MudText>
                <MudTooltip Text="New TaxPurchase">
                <MudIconButton  Icon="@Icons.Material.Filled.Add" Title="Add" @onclick="@(()=> OpenDialog(model))"  Color="Color.Dark" Size="Size.Small"></MudIconButton>
                </MudTooltip>
                 <MudTooltip Text="Add from GRN">
                <MudIconButton  Icon="@Icons.Material.Filled.AddLink"  @onclick="openGrn"  Color="Color.Dark" Size="Size.Small"></MudIconButton>
                </MudTooltip>
                <MudCheckBox Label="Approved Entries"  CheckedChanged="((bool value)=>ApprovedChanged(value))" Checked="@IsApproved" Size="Size.Medium" Color="Color.Primary"></MudCheckBox>

               @* <MudButton @onclick="openpurchaseorder"  Variant="Variant.Filled" Color="Color.Primary" >Purchase Order</MudButton>
               *@ 
                <MudSpacer></MudSpacer>
                <MudTextField @bind-Value="searchTax" Placeholder="Search Tax... "
                              Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                              IconSize="Size.Medium" Class="mt-0">
                </MudTextField>
            </ToolBarContent>
            <HeaderContent>
                <MudTh><MudTableSortLabel SortBy="new Func<TaxPurchaseModel, object>(x=> x.InvoiceDate)" InitialDirection="SortDirection.Ascending">Invoice No</MudTableSortLabel></MudTh>
             <MudTh><MudTableSortLabel SortBy="new Func<TaxPurchaseModel, object>(x=> x.InvoiceNo)" InitialDirection="SortDirection.Ascending">Invoice Date</MudTableSortLabel></MudTh>
               <MudTh><MudTableSortLabel SortBy="new Func<TaxPurchaseModel, object>(x=> x.DocumentDate)" InitialDirection="SortDirection.Ascending">DocumentDate</MudTableSortLabel></MudTh>
             <MudTh><MudTableSortLabel SortBy="new Func<TaxPurchaseModel, object>(x=> x.DocumentNumber)" InitialDirection="SortDirection.Ascending">DocumentNumber</MudTableSortLabel></MudTh>
            
                
                <MudTh>Actions</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="GrnNO">@context.InvoiceNo</MudTd>
                <MudTd DataLabel="EntryDate">@context.InvoiceDate?.ToShortDateString()</MudTd>
                <MudTd DataLabel="EntryDate">@context.DocumentDate?.ToShortDateString()</MudTd>
             
                  <MudTd DataLabel="GrnNO">@context.DocumentNumber</MudTd>
             
                <MudTd DataLabel="">
                    @if(@context.AuthLevelId==null)
                    {
                      @*<MudFab @onclick="@(()=> Approve(context))" Color="Color.Success" title="Approve" Icon="@Icons.Material.Filled.Check" Size="Size.Small" IconSize="Size.Small" />*@
                    <MudFab @onclick="@(()=> OpenDialog(context))" Color="Color.Primary" title="Edit" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" IconSize="Size.Small" />
                    <MudFab @onclick="@(()=> Delete(context))" Color="Color.Error" title="Delete" Icon="@Icons.Material.Filled.Delete" Size="Size.Small" IconSize="Size.Small" />
                  
                    }
                    @if (@context.AuthLevelId!= 99)
                    {
                    <MudFab @onclick="@(()=> OpenDialogVerify(context))" Color="Color.Warning" Icon="@Icons.Material.Filled.Verified" title="Verify" Size="Size.Small" IconSize="Size.Small" />
                        
                    }
                     @if (@context.AuthLevelId== 99)
                   {
                    <MudFab @onclick="@(()=> GetAccountDetails(context))" Color="Color.Info" Icon="@Icons.Material.Filled.CurrencyExchange" title="Accounts" Size="Size.Small" IconSize="Size.Small" />
                    }
                      <MudFab @onclick="@(()=> OpenDialogView(context))" Color="Color.Info" Icon="@Icons.Material.Filled.GridView" title="View" Size="Size.Small" IconSize="Size.Small" />
                   
                    
                  
                    </MudTd>
            </RowTemplate>
            <PagerContent>
                <MudTablePager PageSizeOptions="new int[] { 5, 10, 20, 50, 100 }" />
            </PagerContent>
        </MudTable>
    </MudItem>
    </MudGrid>



@code {


    private TaxPurchaseModel model = new TaxPurchaseModel();
    private List<TaxPurchaseModel> collection = new List<TaxPurchaseModel>();
    DialogOptions maxWidth = new DialogOptions() { MaxWidth = MaxWidth.Medium, FullWidth = true };
     public bool IsApproved { get; set; } = false;

    private string searchTax = "";

    protected override async Task OnInitializedAsync()
    {
        model = new();
        GetAll(IsApproved);
    }
     async Task ApprovedChanged(bool value)
    {

        IsApproved = value;
        await GetAll(IsApproved);

    }
    private  async Task GetAll(bool val)
    {
        var authprov = await auth.GetAuthenticationStateAsync();
        var brancIDString = authprov.User.Claims.First(x => x.Type == "BranchID").Value;
        int brancID = int.Parse(brancIDString);
       
         if (val)
        {
            collection = Iservice.Select().Where(x => x.AuthLevelId == 99).ToList();
            
        }
        else
        {
             collection = Iservice.Select().Where(x => x.AuthLevelId != 99).ToList();
       
        }


    }   

    private async Task OpenDialog(TaxPurchaseModel tds)
    {
        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;
        
        DialogParameters parms = new DialogParameters();
        parms.Add("model",tds);
         parms.Add("IsReadOnly",false);
        parms.Add("IsView",false);
        var dialog =  DialogService.Show<TaxPurchaseDialog>(tds.PID == null?"ADD":"EDIT",parms,maxWidth);
        var result = await dialog.Result;

        if(!result.Cancelled)
        {   

            GetAll(IsApproved);


        }
    }
     private async Task OpenDialogView(TaxPurchaseModel tds)
    {
        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;
        
        DialogParameters parms = new DialogParameters();
        parms.Add("model",tds);
         parms.Add("IsReadOnly",true);
        parms.Add("IsView",true);
        var dialog =  DialogService.Show<TaxPurchaseDialog>(tds.PID == null?"ADD":"EDIT",parms,maxWidth);
        var result = await dialog.Result;

        if(!result.Cancelled)
        {   

            GetAll(IsApproved);


        }
    }
     private async Task OpenDialogVerify(TaxPurchaseModel tds)
    {
        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;
        
        DialogParameters parms = new DialogParameters();
        parms.Add("model",tds);
         parms.Add("IsReadOnly",true);
        parms.Add("IsView",false);
        var dialog =  DialogService.Show<TaxPurchaseDialog>(tds.PID == null?"ADD":"EDIT",parms,maxWidth);
        var result = await dialog.Result;

        if(!result.Cancelled)
        {   

            GetAll(IsApproved);


        }
    }

    private void Delete(TaxPurchaseModel tx)
    {
        Iservice.Delete(tx.PID, "Rijas");
        snackbar.Add("Deleted Successfully", Severity.Success);
        GetAll(IsApproved);
    }
