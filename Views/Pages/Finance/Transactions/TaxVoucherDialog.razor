@using System.Threading;
@using ArmsModels.BaseModels.Finance.Transactions;
@using ArmsServices.DataServices.Finance.Transactions;
@attribute [Authorize]
@inject MudBlazor.ISnackbar snackbar
@inject AuthenticationStateProvider auth
@inject IRoleService<RoleModel> Irole
@inject ITaxVoucherService Iservice
@inject IAssetDocumentService IDocumentService
@inject IGstUsageIDService usageService
@inject IDialogService DialogService
@inject ITdsRateService tdsService

<DialogForm @ref="@dialogForm" ReadOnly="@ReadOnly" Title="Tax Voucher" formID="taxVoucherForm" model="@model">
    <FormContent>
        <MudPaper Class="p-3">
            <EditForm id="taxVoucherForm" OnValidSubmit="OnValidSubmit" EditContext="editContext">
                <ObjectGraphDataAnnotationsValidator />
                <ValidationSummary />
                <MudGrid>
                    <MudItem xs="12" md="6">
                        <MudDatePicker ReadOnly="ReadOnly" Label="Document Date" Variant="Variant.Outlined" Margin="Margin.Dense" DisableToolbar="true" Editable="true" @bind-Date="model.DocumentDate" DateFormat="dd/MM/yyyy" />
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudDatePicker ReadOnly="ReadOnly" Label="Invoice Date" Variant="Variant.Outlined" Margin="Margin.Dense" DisableToolbar="true" Editable="true" @bind-Date="model.InvoiceDate" DateFormat="dd/MM/yyyy" />
                    </MudItem>
                    <MudItem xs="12" md="4">
                        <MudSelect Label="Select Document Type" T="AssetDocumentTypeModel" Value="model.DocumentType" ValueChanged="OnChangeDocumentType" ToStringFunc="@(e => e == null ? null : $"{e.DocumentTypeName}")" Variant="Variant.Outlined" Margin="Margin.Dense" OffsetY="true" Direction="Direction.Top" AdornmentColor="Color.Secondary">
                            @foreach (var ditem in DocumentTypeList)
                            {
                                <MudSelectItem Value="@ditem">@ditem.DocumentTypeName</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12" md="4">
                        <MudDatePicker ReadOnly="ReadOnly" Label="From Date" Variant="Variant.Outlined" Margin="Margin.Dense" DisableToolbar="true" Editable="true" @bind-Date="model.FromDate" DateFormat="dd/MM/yyyy" />
                    </MudItem>
                    <MudItem xs="12" md="4">
                        <MudDatePicker ReadOnly="ReadOnly" Label="To Date" Variant="Variant.Outlined" Margin="Margin.Dense" DisableToolbar="true" Editable="true" @bind-Date="model.ToDate" DateFormat="dd/MM/yyyy" />
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <CostCenterSelector @bind-Value="model.CostCenter" ReadOnly="@ReadOnly" />
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <DimensionSelector @bind-Value="model.Dimension" ReadOnly="@ReadOnly" />
                    </MudItem>
                    <MudItem xs="12" md="12">
                        <MudTextField ReadOnly="ReadOnly" @bind-Value="model.Narration" Lines="2" Label="Narration" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.Narration)"></MudTextField>
                    </MudItem>
                    <MudItem xs="12" md="12">
                        <MudCheckBox Label="Credit?" Checked="@model.IsAgent" CheckedChanged="((bool? IsAgent)=>OnChangeIsAgentChecked(IsAgent))" Size="Size.Medium" Color="Color.Primary"></MudCheckBox>
                    </MudItem>
                    @if (model.IsAgent.Value)
                    {
                        <MudItem xs="12" md="12">
                            <PartySelector Value="@model.Agent" ValueChanged="OnChangeAgent" NatureOfBusiness="Supplier" label="Agent"></PartySelector>
                        </MudItem>
                    }
                    else
                    {
                        <MudItem xs="12" md="12">
                            <PaymentAccountSelector @bind-PaymentMode="model.PaymentMode" @bind-CoaID="model.PaymentCoaID" @bind-ArdCode="model.PaymentArdCode" @bind-BankTool="model.PaymentTool" @bind-BankCharges="model.BankCharges"></PaymentAccountSelector>
                        </MudItem>
                    }
                    <MudItem xs="12" md="6">
                        <MudTextField @bind-Value="model.TotalAmount" Label="Total Amount" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.TotalAmount)" Disabled></MudTextField>
                     </MudItem>
                     <MudItem xs="12" md="6">
                         <MudGrid>
                             <MudItem xs="11" md="11">
                                 <MudTextField @bind-Value="model.TotalTax" Label="Total Tax" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.TotalTax)" Disabled></MudTextField>
                             </MudItem>
                             <MudItem xs="1" md="1">
                                 @if (model.IsAgent.Value)
                                {
                                    <MudIconButton Title="Show Taxes" Color="Color.Info" @onclick="@(()=> OpenDialogTaxRates(model))" Icon="@Icons.Material.Filled.CurrencyExchange" Size="Size.Small" />
                                }
                            </MudItem>
                        </MudGrid>
                    </MudItem>
                    <MudItem xs="12">
                        <h6><u>Items</u></h6>
                        <MudGrid Justify="Justify.Center">
                            <MudItem xs="4" Class="d-flex align-center"><span> <strong> <u>Asset</u></strong> </span></MudItem>
                            <MudItem xs="3" Class="d-flex align-center"><span><strong><u>Amount</u></strong> </span></MudItem>
                            <MudItem xs="3" Class="d-flex align-center"><span><strong><u>Reference</u></strong> </span></MudItem>
                            <MudItem xs="2"></MudItem>
                            @foreach (var item in model.TaxVoucherSubList)
                            {
                                <MudItem xs="4"> @item.Asset.Description </MudItem>
                                <MudItem xs="3"> @item.Amount </MudItem>
                                <MudItem xs="4"> @item.Reference </MudItem>
                                <MudItem xs="1" Class="d-flex">
                                    @if (!ReadOnly)
                                    {
                                        <MudIconButton Title="Delete" Color="Color.Error" @onclick="@(()=> DeleteSubList(@item))" Icon="@Icons.Material.Filled.Delete" Size="Size.Small" />

                                    }
                                </MudItem>
                            }
                            @if (!ReadOnly)
                            {
                                <MudItem xs="4"><AssetSelector @bind-Value="TaxVoucherSub.Asset" PassedListAssets="@(model.TaxVoucherSubList.Select(s=>s.Asset).ToList())" BranchID="branchID.Value" /></MudItem>
                                <MudItem xs="3"><MudNumericField HideSpinButtons Label="Item Rate" @bind-Value="@TaxVoucherSub.Amount" Variant="Variant.Outlined" Margin="Margin.Dense"></MudNumericField></MudItem>
                                <MudItem xs="4"><MudTextField ReadOnly="ReadOnly" @bind-Value="@TaxVoucherSub.Reference" Label="Reference" Variant="Variant.Outlined" Margin="Margin.Dense"></MudTextField></MudItem>
                                <MudItem xs="1" Class="d-flex align-center"><MudIconButton Title="Add" OnClick="AddSubList" Color="Color.Primary" Icon="@Icons.Material.Filled.Add" Size="Size.Small" /></MudItem>
                            }
                        </MudGrid>
                    </MudItem>
                </MudGrid>
            </EditForm>
        </MudPaper>
    </FormContent>
    <VerificationStatus>
        <AutherizationStatusComponent DocTypeID="@DocTypeID" DocumentID="model.TaxVoucherID" OnApprove="ApproveEntry"></AutherizationStatusComponent>
    </VerificationStatus>
</DialogForm>

@code {

    [Parameter]
    public TaxVoucherModel model { get; set; }
    [Parameter]
    public bool ReadOnly { get; set; }
    private List<GstUsageCodeModel> usageList = new();

    public bool HasAuthoriseEdit { get; set; } = false;
    int DocTypeID = 19;

    private TaxVoucherSubModel TaxVoucherSub { get; set; } = new();
    private GstUsageCodeModel gstusge = new();
    public string Area { get; set; } = null;
    public bool Local { get; set; } = true;
    private int? branchID = null;
    private string UserID = null;
    public int SubAssetModel { get; set; }
    public List<TaxVoucherSubModel> SubList { get; set; }
    private List<AssetDocumentTypeModel> DocumentTypeList = new();
    private EditContext editContext;
    DialogForm dialogForm;

    protected override async Task OnInitializedAsync()
    {
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasAuthoriseEdit = await Irole.HasClaim(DocTypeID.ToString(), "Edit", ctc.Token);

        var authprov = await auth.GetAuthenticationStateAsync();
        branchID = int.Parse(authprov.User.Claims.First(x => x.Type == "BranchID").Value);
        var user = authprov.User;
        UserID = user.Identity.Name;
        if (model == null || model != null && model.TaxVoucherID == null || model != null && model.TaxVoucherID == 0)
        {
            if (model == null)
            {
                model = new()
                    {
                        BranchID = branchID,
                        UserInfo = new() { UserID = UserID, },
                        TotalAmount = 0,
                        NatureOfTransaction = "Tax Voucher"
                    };
            }
            else
            {
                model.BranchID = branchID;
                model.UserInfo = new() { UserID = UserID, }; ;
                model.TotalAmount = 0;
                model.NatureOfTransaction = "Tax Voucher";
            }
        }
        else
        {
            model.TaxVoucherSubList = Iservice.GetSub(model.TaxVoucherID).ToList();
        }
        DocumentTypeList = IDocumentService.GetDocumentTypes().ToList();
        usageList = usageService.SelectByArea(Area, System.DateTime.Now).ToList();
        model.TotalTax = (model.IGST ?? 0) + (model.SGST ?? 0) + (model.CGST ?? 0) + (model.TDS ?? 0);
    }

    protected override void OnParametersSet()
    {
        editContext = new EditContext(model);
        // editContext.OnValidationRequested += OnValidationRequestedAsync;
    }

    protected void ApproveEntry(DataApprovedStatus aprvd)
    {
        if (aprvd.IsApprove)
        {
            model.UserInfo.UserID = UserID;
            try
            {
                Iservice.Approve(model.TaxVoucherID, model.UserInfo.UserID, aprvd.Remarks);
                snackbar.Add("Approved Successfully", Severity.Success);
            }
            catch (Exception ex)
            {
                snackbar.Add(ex.Message, Severity.Error);
            }
        }
    }

    public void AddSubList()
    {
        if (TaxVoucherSub.Asset == null)
        {
            snackbar.Add("Please select Asset", Severity.Error);
            return;
        }
        if (TaxVoucherSub.Amount == null)
        {
            snackbar.Add("Please add rate.", Severity.Error);
            return;
        }
        if (dialogForm.validate(TaxVoucherSub, editContext))
        {
            model.TaxVoucherSubList.Add(TaxVoucherSub);
            model.TotalAmount = model.TaxVoucherSubList.Sum(x => x.Amount);
            AddTax();
            TaxVoucherSub = new();
        }
    }

    public void OnChangeDocumentType(AssetDocumentTypeModel obj)
    {
        model.DocumentType = obj;
        AddTax();
    }

    public void OnChangeAgent(PartyModel obj)
    {
        model.Agent = obj;
        AddTax();
    }

    public void OnChangeIsAgentChecked(bool? obj)
    {
        model.IsAgent = obj;
        if (!obj.Value)
        {
            model.Agent = new();
            model.CGST = null;
            model.SGST = null;
            model.IGST = null;
            model.TDS = null;
            model.TotalTax = null;
        }
        else
        {
            model.PaymentMode = null;
            model.PaymentArdCode = null;
            model.PaymentCoaID = null;
            model.PaymentTool = null;
            model.BankCharges = null;
        }
    }

    public async Task OnValidSubmit(EditContext context)
    {
        if (HasAuthoriseEdit)
        {
            try
            {
                model = Iservice.Update(model);
                snackbar.Add("Saved Successfully", Severity.Success);
                dialogForm.Close(model);
            }
            catch (Exception ex)
            {
                snackbar.Add(ex.Message, Severity.Error);
            }
        }
        else
        {
            bool? result = await DialogService.ShowMessageBox(
                "Permission denied!",
                "You dont have any permission to submit.");
        }
    }


    private void DeleteSubList(TaxVoucherSubModel TaxVoucherSub)
    {
        if (model.TaxVoucherSubList.Exists(x => x.TaxVoucherSubID == TaxVoucherSub.TaxVoucherSubID))
        {
            int rowIndex = model.TaxVoucherSubList.IndexOf(TaxVoucherSub);
            model.TaxVoucherSubList.RemoveAt(rowIndex);
            model.TotalAmount = model.TaxVoucherSubList.Sum(x => x.Amount);
            AddTax();
        }
    }

    private async Task OpenDialogTaxRates(TaxVoucherModel i)
    {
        GstModel taxModel = new GstModel();
        taxModel.CGST = i.CGST;
        taxModel.IGST = i.IGST;
        taxModel.TDS = i.TDS;
        taxModel.SGST = i.SGST;
        taxModel.GstRate = i.GstRate;
        DialogParameters parms = new DialogParameters();
        parms.Add("tax", taxModel);
        parms.Add("ReadOnly", ReadOnly);
        var dialog = DialogService.Show<TaxRatedialog>(i.TaxVoucherID == null ? "ADD" : "EDIT", parms, new DialogOptions() { MaxWidth = MaxWidth.Small, FullWidth = true });
        var result = await dialog.Result;
        if (!result.Canceled)
        {
            taxModel = (GstModel)result.Data;
            i.CGST = taxModel.CGST;
            i.IGST = taxModel.IGST;
            i.TDS = taxModel.TDS;
            i.SGST = taxModel.SGST;
            i.GstRate = taxModel.GstRate;
            i.TotalTax = i.IGST.Value + i.SGST.Value + i.CGST.Value + i.TDS.Value;
        }
    }

    private bool AddTax()
    {
        if (model.IsAgent.Value)
        {
            if (model.Agent == null)
            {
                snackbar.Add("Please select agent.", Severity.Error);
                return false;
            }
        }
        if (gstusge != null && model.TotalAmount != null && model.Agent != null && model.Agent.PartyID != null)
        {
            if (model.DocumentType == null)
            {
                snackbar.Add("Please select document type.", Severity.Error);
                return false;
            }
            model.GstRate = usageService.GetGstRate(model.DocumentType?.UsageCode?.UsageCode ?? "", DateTime.Now);
            decimal taxRate = model.GstRate ?? 0;
            if (!Local)
            {
                model.IGST = Math.Round(model.TotalAmount.Value * taxRate / 100, 2);
            }
            else
            {
                model.SGST = model.CGST = Math.Round(model.TotalAmount.Value * taxRate / 200, 2);
            }
            decimal tdsRate = tdsService.GetTdsRate(model.Agent.PartyID, model.PaymentCoaID);
            model.TDS = Math.Round((model.TotalAmount.Value * tdsRate) / 100, 2);
            model.TotalTax = (model.IGST ?? 0) + (model.SGST ?? 0) + (model.CGST ?? 0) + (model.TDS ?? 0);

            return true;
        }
        return false;
    }

    void SubElementSelected(AssetModel Asset)
    {
        TaxVoucherSub.Asset = Asset;
    }
}