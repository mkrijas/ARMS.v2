@inherits DialogFormComponentBase<TdsTransactionModel>
@inject ItdsEntryService Iservice
@inject ITdsRateService tdsIService
@inject IBankAccountOwnService bankService


<DialogForm @ref="@dialogForm" ReadOnly="@ReadOnly" Title="TDS/TCS Entry" Subtitle="Record Tax Deducted at Source (TDS) or Tax Collected at Source (TCS) with precision." Icon="@Icons.Material.Filled.AccountBalance" AdminStyle="true" formID="formTdsEntry" DocumentDetails="DocInfo" model="@model" _busy="_busy">
    <FormContent>
        <div class="dialog-content-wrapper">
            <EditForm autocomplete="off" id="formTdsEntry" OnValidSubmit="OnValidSubmit" EditContext="editContext">
                <ObjectGraphDataAnnotationsValidator />
                
                <div class="admin-glass-card pa-6 mb-6">
                    <span class="admin-section-label">Classification & Timeline</span>
                    <MudGrid Spacing="3" Class="align-center">
                        <MudItem xs="12" md="3">
                            <MudRadioGroup T="string" @bind-Value="@model.TdsType" ReadOnly="ReadOnly">
                                <MudRadio Value=@("TDS") Color="Color.Primary">TDS</MudRadio>
                                <MudRadio Value=@("TCS") Color="Color.Secondary">TCS</MudRadio>
                            </MudRadioGroup>
                        </MudItem>
                        <MudItem xs="12" md="3">
                            <MudRadioGroup T="bool" @bind-Value="@model.IsTdsPayable" ReadOnly="ReadOnly">
                                <MudRadio Value="@(true)" Color="Color.Primary">Payable</MudRadio>
                                <MudRadio Value="@(false)" Color="Color.Secondary">Receivable</MudRadio>
                            </MudRadioGroup>
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <MudDatePicker ReadOnly="ReadOnly" Label="Document Date" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.DocumentDate)" DisableToolbar="true" Editable="true" @bind-Date="model.DocumentDate" DateFormat="dd/MM/yyyy" MaxDate="DateTime.Now" Class="admin-input-group" />
                        </MudItem>
                    </MudGrid>
                </div>

                <div class="admin-glass-card pa-6 mb-6">
                    <span class="admin-section-label">Party & Transaction Details</span>
                    <MudGrid Spacing="3">
                        <MudItem xs="12" md="6">
                            <MudSelect Label="Nature of Party" ReadOnly="ReadOnly" Value="@model.BusinessNature" T="string" ValueChanged="nbusinesschanged" Variant="Variant.Outlined" Margin="Margin.Dense" Class="admin-input-group">
                                <MudSelectItem Value="@("Supplier")" />
                                <MudSelectItem Value="@("Customer")" />
                                <MudSelectItem Value="@("Renter")" />
                                <MudSelectItem Value="@("SisterConcern")">Sister-Concern</MudSelectItem>
                                <MudSelectItem Value="@("Bank")">Bank</MudSelectItem>
                            </MudSelect>
                        </MudItem>

                        @if (model.BusinessNature == "Bank")
                        {
                            <MudItem xs="12" md="6">
                                <BankSelector BranchID="@BranchID" IsDisabled="@ReadOnly" Value="@model.Bank" ValueChanged="BankChanged" Class="admin-input-group"></BankSelector>
                            </MudItem>
                        }
                        else
                        {
                            <MudItem xs="12" md="6">
                                <PartySelector Value="model.Party" For="@(()=> model.Party)" ValueChanged="PartyChanged" BranchID="BranchID" NatureOfBusiness="@model.BusinessNature" Class="admin-input-group"></PartySelector>
                            </MudItem>

                            <MudItem xs="12" md="6">
                                <MudSelect Label="Nature Of Payment" ReadOnly="ReadOnly" Value="model.TransactionType" ValueChanged="nTransactionChanged" T="string" Variant="Variant.Outlined" Margin="Margin.Dense" Class="admin-input-group">
                                    @if (model.Party is not null)
                                    {
                                        foreach (var item in natureOfBusinessGroup)
                                        {
                                            <MudSelectItem Value="@(item)" />
                                        }
                                    }
                                </MudSelect>
                            </MudItem>
                        }

                        <MudItem xs="12">
                            <MudTextField ReadOnly="ReadOnly" @bind-Value="model.Narration" Lines="2" Label="Narration / Description" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.Narration)" Class="admin-input-group"></MudTextField>
                        </MudItem>
                    </MudGrid>
                </div>

                <div class="admin-glass-card pa-0 overflow-hidden">
                    <div class="px-6 py-4 border-bottom-subtle" style="background: rgba(255, 159, 67, 0.02);">
                        <span class="admin-section-label mb-0">Tax Particulars</span>
                    </div>
                    <div class="modern-admin-table">
                        <MudGrid Class="admin-table-header px-6 py-3">
                            <MudItem xs="3"><span class="admin-header-text">SECTION / NATURE</span></MudItem>
                            <MudItem xs="2"><span class="admin-header-text">INVOICE DT</span></MudItem>
                            <MudItem xs="2"><span class="admin-header-text">INVOICE NO</span></MudItem>
                            <MudItem xs="2"><span class="admin-header-text">TAXABLE AMT</span></MudItem>
                            <MudItem xs="1"><span class="admin-header-text">RATE (%)</span></MudItem>
                            <MudItem xs="1"><span class="admin-header-text">TAX AMT</span></MudItem>
                            <MudItem xs="1"><span class="admin-header-text">ACTION</span></MudItem>
                        </MudGrid>

                        @if (model.Tds is not null && model.Tds.Any())
                        {
                            @foreach (var item in model.Tds)
                            {
                                <MudGrid Class="px-6 py-3 border-bottom-subtle align-center">
                                    <MudItem xs="3">
                                        <MudText Typo="Typo.body2" Style="font-weight: 700;">@item.TdsNP</MudText>
                                    </MudItem>
                                    <MudItem xs="2">
                                        <MudText Typo="Typo.body2">@item.InvoiceDate?.ToString("dd/MM/yyyy")</MudText>
                                    </MudItem>
                                    <MudItem xs="2">
                                        <MudText Typo="Typo.body2" Style="font-family: monospace;">@item.InvoiceNumber</MudText>
                                    </MudItem>
                                    <MudItem xs="2">
                                        <MudText Typo="Typo.body2" Style="font-weight: 700; color: #141A46;">₹ @item.TaxableAmount</MudText>
                                    </MudItem>
                                    <MudItem xs="1">
                                        <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Text" Style="font-weight: 800;">@item.RateOfTds%</MudChip>
                                    </MudItem>
                                    <MudItem xs="1">
                                        <MudText Typo="Typo.body2" Style="font-weight: 800; color: #FF9F43;">₹ @item.TdsAmount</MudText>
                                    </MudItem>
                                    <MudItem xs="1">
                                        @if (!ReadOnly)
                                        {
                                            <MudIconButton Title="Delete" Color="Color.Error" @onclick="@(()=> DeleteRow(@item))" Icon="@Icons.Material.Filled.Delete" Size="Size.Small" />
                                        }
                                    </MudItem>
                                </MudGrid>
                            }
                        }

                        @if (!ReadOnly)
                        {
                            <div class="pa-5" style="background: rgba(255, 159, 67, 0.03); border-top: 1px solid rgba(255, 159, 67, 0.1);">
                                <MudGrid Spacing="2">
                                    <MudItem xs="12" md="3">
                                        <MudSelect Label="Nature of payment" Value="_entryModel.TdsNpID" ValueChanged="TdsNPSelected" T="int?" Variant="Variant.Outlined" Margin="Margin.Dense" Class="admin-input-group">
                                            @foreach (var ditem in TdsNPs)
                                            {
                                                <MudSelectItem Value="@ditem.TdsNPID">@ditem.NatureOfPayment</MudSelectItem>
                                            }
                                        </MudSelect>
                                    </MudItem>
                                    <MudItem xs="6" md="2">
                                        <MudDatePicker ReadOnly="ReadOnly" Label="Invoice Date" Variant="Variant.Outlined" Margin="Margin.Dense" DisableToolbar="true" Editable="true" DateFormat="dd/MM/yyyy" @bind-Date="_entryModel.InvoiceDate" For="@(() => _entryModel.InvoiceDate)" Class="admin-input-group" />
                                    </MudItem>
                                    <MudItem xs="6" md="2">
                                        <MudTextField ReadOnly="ReadOnly" @bind-Value="_entryModel.InvoiceNumber" Label="Invoice No" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => _entryModel.InvoiceNumber)" Class="admin-input-group"></MudTextField>
                                    </MudItem>
                                    <MudItem xs="4" md="2">
                                        <MudNumericField HideSpinButtons Label="Taxable Amt" Value="@_entryModel.TaxableAmount" ValueChanged="TaxableAmountChanged" T="decimal?" Variant="Variant.Outlined" Margin="Margin.Dense" Class="admin-input-group" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.CurrencyRupee" AdornmentColor="Color.Primary"></MudNumericField>
                                    </MudItem>
                                    <MudItem xs="3" md="1">
                                        <MudNumericField HideSpinButtons Label="Rate" @bind-Value="@_entryModel.RateOfTds" Variant="Variant.Outlined" Margin="Margin.Dense" Class="admin-input-group"></MudNumericField>
                                    </MudItem>
                                    <MudItem xs="3" md="1">
                                        <MudNumericField HideSpinButtons Label="Tax" @bind-Value="@_entryModel.TdsAmount" Variant="Variant.Outlined" Margin="Margin.Dense" Class="admin-input-group"></MudNumericField>
                                    </MudItem>
                                    <MudItem xs="2" md="1" Class="d-flex align-center">
                                        <MudIconButton OnClick="ADD" Color="Color.Primary" Variant="Variant.Filled" Style="background: #FF9F43; border-radius: 10px; height: 45px; width: 50px;" Icon="@Icons.Material.Filled.Add" Size="Size.Large" />
                                    </MudItem>
                                </MudGrid>
                            </div>
                        }
                    </div>
                </div>
            </EditForm>
        </div>
    </FormContent>
    <VerificationStatus>
        <AutherizationStatusComponent CreatedBy="@model.UserInfo" DocTypeID="@DocInfo.DocumentTypeID" DocumentID="@model.ID" OnApprove="Approve"></AutherizationStatusComponent>
    </VerificationStatus>
</DialogForm>


@code {

    [Parameter]
    public override TdsTransactionModel model { get; set; }
    private TdsTransactionModel _model { get { return model; } set { model = value; DocInfo.DocumentID = value.ID; } }


    protected override DocumentInfoModel DocInfo { get; set; } = new DocumentInfoModel()
        {
            DocumentTypeID = 131,
            DocumentName = "TdsEntry"
        };

    private TdsTransactionEntryModel _entryModel = new();
    private List<NatureOfPaymentModel> TdsNPs = new();

    protected override async Task OnInitializedAsync()
    {
        DocInfo.DocumentID = model.ID;
        await base.OnInitializedAsync();
        TdsNPs = tdsIService.SelectTdsNP().ToList(); // Load the nature of payment options
        if (model.ID == null)
        {
            model.BranchID = BranchID;
            if (model.Party != null)
                await PartyChanged(model.Party);
        }
        else
        {
            // Load existing party and TDS entries if editing an existing model
            if (model.Bank?.ID is not null)
            {
                model.Bank = bankService.SelectByID(model.Bank.ID ?? 0);
            }
            else
            {
                model.Party = partyService.SelectByID(model.Party.PartyID);
            }
            model.Tds = Iservice.GetEntries(model.ID).ToList();
        }
        model.NatureOfTransaction = "TdsEntry";
    }

    // Method to handle selection of nature of payment
    private void TdsNPSelected(int? val)
    {
        _entryModel.TdsNpID = val;
        _entryModel.TdsNP = TdsNPs.FirstOrDefault(x => x.TdsNPID == val)?.NatureOfPayment;
        if (model.IsTdsPayable)
        {
            SetTds(_entryModel);
        }
    }

    // Method to handle changes in taxable amount
    private void TaxableAmountChanged(decimal? val)
    {
        _entryModel.TaxableAmount = val;
        if (model.IsTdsPayable)
        {
            SetTds(_entryModel);
        }
    }

    // Method to calculate the total amount of TDS entries
    void SetTotal()
    {
        model.TotalAmount = model.Tds.Sum(x => x.TdsAmount);
    }


    // Method to handle changes in business nature
    async Task nbusinesschanged(string val)
    {
        model.BusinessNature = val;
        SetNTransaction(val);
        await PartyChanged(null);
    }

    void BankChanged(OwnBankModel bank)
    {
        model.Bank = bank;        
        model.TransactionType = "Bank";
        var ID = bankService.GetBankAccountCoaID(bank?.ID);
        model.PartyCoaID = ID;
    }


    // Method to handle changes in party selection
    async Task PartyChanged(PartyModel party)
    {
        model.Party = party;
        // Get the default COA ID for the selected party
        // if (party is not null)
        //     model.PartyCoaID = partyService.GetPartyDefaultCoaID(model.Party?.PartyID);
        // else
        //     model.PartyCoaID = null;
        await nTransactionChanged(null);
    }

    private async Task nTransactionChanged(string nt)
    {
        model.TransactionType = nt;
        if (model.TransactionType is not null)
        {
            // Get the COA ID for the selected party and transaction type
            model.PartyCoaID = partyService.GetPartyCoaID(model.Party.PartyID, model.BusinessNature, model.TransactionType);
            if (model.PartyCoaID == null)
            {
                bool? result = await dialogService.ShowMessageBoxAsync(
                    "Account Not Mapped!",
                    "Party Account is not mapped for " + model.TransactionType + "!");
                model.NatureOfTransaction = null;
            }
        }
        else
        {
            model.PartyCoaID = null;
        }

    }

    string[] natureOfBusinessGroup = new string[] { };
    string[] RentGroup = { "Rent", "Deposit", "Other" };
    string[] SupplierGroup = { "Deposit", "Payable", "Prepayment" };
    string[] CustomerGroup = { "Deposit", "Receivable", "Prepayment" };
    string[] SisterGroup = { "Deposit", "Trade", "Prepayment" };

    // Method to set the nature of transaction based on business nature
    void SetNTransaction(string nBusiness)
    {
        if (nBusiness == "Renter")
        {
            natureOfBusinessGroup = RentGroup;
        }
        else if (nBusiness == "Customer")
        {
            natureOfBusinessGroup = CustomerGroup;
        }
        else if (nBusiness == "Supplier")
        {
            natureOfBusinessGroup = SupplierGroup;
        }
        else if (nBusiness == "SisterConcern")
        {
            natureOfBusinessGroup = SisterGroup;
        }
        else
        {
            natureOfBusinessGroup = new string[] { };
        }
    }




    // Method to update the TDS transaction model
    protected override async Task<int> Update(TdsTransactionModel editModel)
    {
        if (await validate(model))
        {
            try
            {
                model = Iservice.Update(model); // Update the model
                return model.ID.Value;
            }
            catch (Exception ex)
            {
                snackbar.Add(ex.Message, Severity.Warning);
            }
        }
        return 0;
    }

    // Method to update approval status of the transaction
    protected override int UpdateApproval(DataApprovedStatus aprvd)
    {
        int result = Iservice.Approve(model.ID, model.UserInfo.UserID, aprvd.Remarks); // Approve the transaction
        return result;
    }

    // Method to validate the TDS transaction model
    async Task<bool> validate(TdsTransactionModel editModel)
    {
        return true;
    }

    // Method to add a new TDS entry
    private void ADD()
    {
        if (model.Tds is null)
        {
            model.Tds = new();
        }
        editContext = new EditContext(_entryModel);
        editContext.EnableDataAnnotationsValidation();

        if (editContext.Validate())
        {
            model.Tds.Add((TdsTransactionEntryModel)_entryModel);
            SetTotal();
            _entryModel = new();
        }
        else
        {
            editContext.NotifyValidationStateChanged();
        }
    }

    // Method to delete a TDS entry
    private void DeleteRow(TdsTransactionEntryModel i)
    {
        int rowIndex = model.Tds.IndexOf(i);
        model.Tds.RemoveAt(rowIndex);
        SetTotal();
    }

    // Method to set TDS amount based on taxable amount and nature of payment
    private void SetTds(TdsTransactionEntryModel e)
    {
        if (e.TaxableAmount is not null && e.TdsNpID is not null && model.Party is not null)
        {
            // Get the TDS rate and calculate the TDS amount
            e.RateOfTds = tdsIService.GetTdsRate2(model.Party.PartyID, e.TdsNpID);
            e.TdsAmount = Math.Round((e.TaxableAmount.Value * e.RateOfTds.Value / 100), MidpointRounding.AwayFromZero);
        }
        else
        {
            e.RateOfTds = null;
            e.TdsAmount = null;
        }
    }
}
