@inject IConsigneeService Iservice
@inject MudBlazor.ISnackbar snackbar
@inject AuthenticationStateProvider auth
@attribute [Authorize]
@inject IDialogService DialogService

<MudDialog>
    <DialogContent>
        
            <EditForm Model="@model" OnValidSubmit="OnValidSubmit">
                <DataAnnotationsValidator />
                <ValidationSummary />
              
                <MudCardContent>
                    <MudTextField @bind-Value="model.ConsigneeID" Label="Consginee Id" Variant="Variant.Outlined" Margin="Margin.Normal" For="@(() => model.ConsigneeID)"></MudTextField>
                    <MudTextField  @bind-Value="model.ConsigneeName" Label="Name" Variant="Variant.Outlined" Margin="Margin.Normal" For="@(() => model.ConsigneeName)"></MudTextField>
                    <MudTextField @bind-Value="model.Address.Place" Label="Adress" Variant="Variant.Outlined" Margin="Margin.Normal" For="@(() => model.Address.Place)"></MudTextField>
                      <MudTextField @bind-Value="model.Address.City" Label="Adress" Variant="Variant.Outlined" Margin="Margin.Normal" For="@(() => model.Address.City)"></MudTextField>
                    <MudTextField @bind-Value="model.Mobile" Label="Mobile" Variant="Variant.Outlined" Margin="Margin.Normal" For="@(() => model.Mobile)"></MudTextField>
                    <MudTextField @bind-Value="model.Consignor" Label="Consignor" Variant="Variant.Outlined" Margin="Margin.Normal" For="@(() => model.Consignor)"></MudTextField>
                    
                    <MudButton Variant="Variant.Filled" Color="Color.Success" ButtonType="ButtonType.Submit">Save</MudButton>
                </MudCardContent>
            </EditForm>
      
    </DialogContent>
    
</MudDialog>


@code {

    [Parameter]
    public ConsigneeModel model { get; set; }

    private List<ConsigneeModel> collection = new List<ConsigneeModel>();
   
     protected override async Task OnInitializedAsync()
    {       
        await Task.Run(() => GetAll());
    }   

    private async Task GetAll()
    {
        await foreach (var content in Iservice.Select(0))
        {
            collection.Add(content);
        }
    }
     private async void OnValidSubmit(EditContext context)
    {

        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;
        model.UserInfo.UserID = user.Identity.Name;

        try
        {
            model = await Iservice.Update(model);

            if (collection.Exists(x => x.ConsigneeID == model.ConsigneeID))
            {
                collection[collection.FindIndex(x => x.ConsigneeID == model.ConsigneeID)] = model;
            }
            else
            {
                collection.Add(model);
            }
            model = new ConsigneeModel();
            snackbar.Add("Saved Successfully", Severity.Success);
            StateHasChanged();
        }
        catch (Exception ex)
        {
            snackbar.Add(ex.Message, Severity.Warning);
        }

    }
    
}