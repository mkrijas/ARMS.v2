@inject IConsigneeService Iservice
@inject MudBlazor.ISnackbar snackbar
@inject AuthenticationStateProvider auth
@attribute [Authorize]
@inject IDialogService DialogService

@inject IPlaceService Iplace
@inject IOrderService Iorder

    
            <EditForm Model="@model" OnValidSubmit="OnValidSubmit">
                <DataAnnotationsValidator />
                <ValidationSummary />
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudSwitch @bind-Checked="customstr" Color="Color.Error" Converter="@(new CustomStringToBoolConverter())"> <MudText Typo="Typo.h6">Add/Edit @(customstr)</MudText></MudSwitch>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent>
                    <MudGrid Spacing="4">
                        <MudItem xs="12" md="6">
                    <MudTextField @bind-Value="model.ConsigneeName" Label="Consignee Name" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.ConsigneeName)"></MudTextField>
                        </MudItem>
                        <MudItem xs="12" md="6">
                    <MudTextField @bind-Value="model.Mobile" Label="Mobile" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.Mobile)"></MudTextField>
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <MudAutocomplete T="PlaceModel" Label="Place" @bind-Value="Place" ResetValueOnEmptyText="true" Variant="Variant.Outlined"
                                             SearchFunc="@Search" ToStringFunc="@(e => e == null ? null : $"{e.PlaceName}")"></MudAutocomplete>
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <MudAutocomplete T="OrderModel" Label="Order" @bind-Value="Order" ResetValueOnEmptyText="true" Variant="Variant.Outlined"
                                             SearchFunc="@SearchOrders" ToStringFunc="@(e => e == null ? null : $"{e.OrderName}")"></MudAutocomplete>
                        </MudItem>

                        <MudItem xs="12">
                            <MudText Typo="Typo.subtitle2">Address Info</MudText>
                        </MudItem>
                        <MudItem xs="12" md="6">
                    <MudTextField @bind-Value="model.Address.Building" Label="Building" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.Address.Building)"></MudTextField>
                        </MudItem>
                        <MudItem xs="12" md="6">
                    <MudTextField @bind-Value="model.Address.Street" Label="Street" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.Address.Street)"></MudTextField>
                        </MudItem>
                        <MudItem xs="12" md="6">
                    <MudTextField @bind-Value="model.Address.City" Label="City" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.Address.City)"></MudTextField>
                        </MudItem>
                        <MudItem xs="12" md="6">
                    <MudTextField @bind-Value="model.Address.PinCode" Label="PinCode" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.Address.PinCode)"></MudTextField>
                        </MudItem>
                    </MudGrid>
                    <MudButton Variant="Variant.Filled" Color="Color.Success" ButtonType="ButtonType.Submit">Save @customstr</MudButton>

                </MudCardContent>
            </EditForm>



@code {

    [Parameter]
    public ConsigneeModel model { get; set; }
    [Parameter]
    public OrderModel Order { get; set; }

    [CascadingParameter] MudDialogInstance MudDialog { get; set; }

    private PlaceModel Place = new PlaceModel();
    private List<PlaceModel> places = new List<PlaceModel>();
    private List<OrderModel> orders = new List<OrderModel>();

    public string customstr { get; set; } = "CONSIGNEE";

    private string searchConsignee = "";

    protected override async Task OnInitializedAsync()
    {
        places = Iplace.Select(0).ToList();

        await foreach (var item in Iorder.Select(0))
        {
            orders.Add(item);
        }   

        if (model.Address == null)
        { model.Address = new AddressModel() { AddresseeName = "temp", Place = "temp" }; }



        CustomStringToBoolConverter cs = new CustomStringToBoolConverter();
        customstr = cs.GetFunc(model.Consignor);

        Place = places.FirstOrDefault(x => x.PlaceID == model.PlaceID);
    }


    public class CustomStringToBoolConverter : BoolConverter<string>
    {

        public CustomStringToBoolConverter()
        {
            SetFunc = OnSet;
            GetFunc = OnGet;
        }

        private string TrueString = "CONSIGNOR";
        private string FalseString = "CONSIGNEE";
        private string NullString = "SELECT";

        private string OnGet(bool? value)
        {
            try
            {
                return (value == true) ? TrueString : FalseString;
            }
            catch (Exception e)
            {
                UpdateGetError("Conversion error: " + e.Message);
                return NullString;
            }
        }

        private bool? OnSet(string arg)
        {
            if (arg == null)
                return null;
            try
            {
                if (arg == TrueString)
                    return true;
                if (arg == FalseString)
                    return false;
                else
                    return null;
            }
            catch (FormatException e)
            {
                UpdateSetError("Conversion error: " + e.Message);
                return null;
            }
        }
    }

    private async Task<IEnumerable<PlaceModel>> Search(string searchString)
    {
        return await Task.FromResult(
            places.Where(x => x.PlaceName.Contains(searchString == null ? string.Empty : searchString, StringComparison.InvariantCultureIgnoreCase)));
    }

    private async Task<IEnumerable<OrderModel>> SearchOrders(string searchString)
    {
        var o = orders.Where(x => x.OrderName.Contains(searchString == null ? string.Empty : searchString, StringComparison.InvariantCultureIgnoreCase));
        return await Task.FromResult(o);
    }


    private async void OnValidSubmit(EditContext context)
    {
        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;
        model.UserInfo.UserID = user.Identity.Name;

        if (Place?.PlaceID == 0)
        {
            snackbar.Add("Place is not selected", Severity.Error);
            return;
        }
        else
        if (!places.Select(x => x.PlaceName).Contains(Place.PlaceName))
        {
            snackbar.Add("Invalid Place", Severity.Error);
            return;
        }

        model.PlaceID = Place.PlaceID;
        model.Address.Place = Place.PlaceName;
        model.OrderID = Order.OrderID;
        model.Address.AddresseeName = model.ConsigneeName;
        CustomStringToBoolConverter cs = new CustomStringToBoolConverter();
        model.Consignor = cs.SetFunc(customstr).Value;

        MudDialog.Close(model);
    }

}