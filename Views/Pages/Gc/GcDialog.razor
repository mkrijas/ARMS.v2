
@inject IGcService Iservice
@inject IRouteService Iroute
@inject IOrderService Iorder
@inject IConsigneeService Iconsignee

@inject MudBlazor.ISnackbar snackbar
@attribute [Authorize]
@inject AuthenticationStateProvider auth



<MudDialog>
    @*<TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.Create" Class="mr-3 mb-n1" />
            Consignment
        </MudText>
    </TitleContent>*@
    <DialogContent>
        <MudContainer Style="min-height:500px;max-height: 800px;">
            <EditForm id="form" Model="@model" OnValidSubmit="OnValidSubmit">
                <ObjectGraphDataAnnotationsValidator />
                <ValidationSummary />
                <MudGrid Spacing="4">
                    @if (IsLoading)
                    {
                        <MudProgressCircular Color="Color.Primary" Style="height: 200px; width: 200px; display: block; margin: 150px auto auto auto; " Indeterminate="true" />
                    }
                    else
                    {
                        <MudItem xs="12" md="12">
                            <MudAutocomplete Clearable="true" Variant="Variant.Outlined" T="OrderModel" Label="Order" ResetValueOnEmptyText="true" ValueChanged="OrderSelected" Value="Order"
                                             SearchFunc="SearchOrders" ToStringFunc="@(e=> e==null?null : $"{e.OrderName}")"></MudAutocomplete>
                        </MudItem>
                        @if (Order?.OrderID > 0)
                        {
                            <MudItem xs="12" md="12">
                                <MudAutocomplete T="RouteModel" Variant="Variant.Outlined" Label="Route" @bind-Value="Route" ResetValueOnEmptyText="true"
                                                 SearchFunc="SearchRoutes" ToStringFunc="@(e => e == null ? null : $"{e.RouteName}")"></MudAutocomplete>
                            </MudItem>
                            <MudItem xs="12" md="6">
                                <MudAutocomplete T="ConsigneeModel" Variant="Variant.Outlined" Label="Consignor" @bind-Value="Consignor" ResetValueOnEmptyText="true"
                                                 SearchFunc="SearchConsignor" ToStringFunc="@(e => e == null ? null : $"{e.ConsigneeName}")"></MudAutocomplete>
                            </MudItem>
                            <MudItem xs="12" md="6">
                                <MudAutocomplete T="ConsigneeModel" Variant="Variant.Outlined" Label="Consignee" @bind-Value="Consignee" ResetValueOnEmptyText="true"
                                                 SearchFunc="SearchConsignee" ToStringFunc="@(e => e == null ? null : $"{e.ConsigneeName}")"></MudAutocomplete>
                            </MudItem>

                            <MudItem xs="12">
                                <MudTabs Outlined="true" ApplyEffectsToContainer="false" >

                                    @foreach (var wrapperitem in model.Gcs.Select((value, i) => new { i, value }))
                                    {                                        
                                            var item = wrapperitem.value;
                                            string head = item.GcID > 0 ? item.GcPrefix + item.GcNumber : "New " + (wrapperitem.i + 1);
                                          
                                        <MudTabPanel Text="@head">
                                            <MudItem xs="12">
                                                <MudDivider DividerType="DividerType.Middle" Class="my-6" />
                                            </MudItem>
                                            <MudItem xs="12">
                                                <MudDatePicker Label="Bill Date" Variant="Variant.Outlined" Margin="Margin.Dense" DisableToolbar="true" Editable="true" @bind-Date="item.BillDate" HelperText="Enter Date" DateFormat="dd/MM/yyyy" />
                                            </MudItem>
                                            <MudItem xs="12">
                                                <MudTextField @bind-Value="item.BillNumber" Label="Bill Number" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => item.BillNumber)"></MudTextField>
                                            </MudItem>
                                            <MudItem xs="12">
                                                <MudTextField @bind-Value="item.BillQuantity" Label="Bill Quantity" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => item.BillQuantity)"></MudTextField>
                                            </MudItem>
                                            <MudItem xs="12">
                                                @if (model.Gcs.Count > 1)
                                                {
                                                    <MudFab Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small" DisableElevation="true" IconSize="Size.Medium" OnClick="(() => RemoveInvoice(wrapperitem.i))" />
                                                }
                                            </MudItem>
                                            <MudItem xs="12">
                                                <MudSelect Label="Select Type" @bind-Value="item.GcType" Variant="Variant.Outlined" Margin="Margin.Dense" OffsetY="true" Direction="Direction.Top" AdornmentColor="Color.Secondary">
                                                    @foreach (var ditem in GcTypes)
                                                                {
                                                        <MudSelectItem Value="@ditem.GcTypeID">@ditem.GcTypeName</MudSelectItem>
                                                                }
                                                </MudSelect>
                                            </MudItem>
                                            <MudItem xs="12">
                                                <MudTextField @bind-Value="item.PassNumber" Label="Pass Number" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => item.PassNumber)"></MudTextField>
                                            </MudItem>
                                        </MudTabPanel>
                                    }
                                </MudTabs>
                            </MudItem>
                        }
                    }
                </MudGrid>
            </EditForm>
            </MudContainer>
    </DialogContent>
    <DialogActions>
        <MudButton StartIcon="@Icons.Material.Filled.AddTask" OnClick="AddMoreInvoice" IconColor="Color.Default" Color="Color.Primary">More Invoices</MudButton>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton form="form" Variant="Variant.Filled" Color="Color.Success" ButtonType="ButtonType.Submit">Save Gc</MudButton>

    </DialogActions>
</MudDialog>

@code {

        [CascadingParameter] MudDialogInstance MudDialog { get; set; }
        [Parameter] public GcSetModel model { get; set; }

        private void Cancel()
        {
            MudDialog.Cancel();
        }

    private bool IsLoading = false;

    private OrderModel Order = new ();
    private RouteModel Route = new ();
    private ConsigneeModel Consignor = new ();
    private ConsigneeModel Consignee = new ();

    private List<RouteModel> Routes = new ();
    private List<OrderModel> Orders = new ();
    private List<GcTypeModel> GcTypes = new ();
    private List<ConsigneeModel> Consignees = new ();


    protected override async Task OnInitializedAsync()
    {

        IsLoading = true;
        GcTypes = new();
        foreach (var item in Iservice.SelectGcTypes())
        {
            GcTypes.Add(item);
        }
        await foreach (var item in Iorder.Select(0))
        {
            Orders.Add(item);
        }

        if (model?.GcSetID > 0)
            Order = Orders.Find(x => x.OrderID == model.OrderID);
        else
        if (Orders.Count == 1) Order = Orders.First();

        await OrderChanged(Order);

        if (model?.GcSetID > 0)
        {
            Route = Routes.Find(x => x.RouteID == model.RouteID);
            Consignor = Consignees.Find(x => x.ConsigneeID == model.ConsignorID);
            Consignee = Consignees.Find(x => x.ConsigneeID == model.ConsigneeID);
        }
        else
        {
            model.Gcs.Add(new GcModel());
        }
        IsLoading = false;

    }
    protected override async Task OnParametersSetAsync()
    {

    }



    private async Task OrderChanged( OrderModel Order)
    {
        IsLoading = true;
        Routes.Clear();
        Consignees.Clear();
        Route = null;
        Consignor = null;
        Consignee = null;

        if (Order != null)
        {
            await foreach (var item in Iroute.SelectByOrder(Order?.OrderID))
            {
                Routes.Add(item);
            }

            await foreach (var item in Iconsignee.SelectByOrder(Order.OrderID))
            {
                Consignees.Add(item);
            }
            if (Routes.Count() == 1) Route = Routes.First();
            if(Consignees.Where(x=> x.Consignor == true).Count() == 1)
            {
                Consignor = Consignees.First(x => x.Consignor == true);
            }
            if (Consignees.Where(x => x.Consignor == false).Count() == 1)
            {
                Consignee = Consignees.First(x => x.Consignor == false);
            }
        }
        IsLoading = false;
    }

    private async Task<IEnumerable<ConsigneeModel>> SearchConsignee(string searchString)
    {
        return await Task.FromResult(Consignees.Where(x => x.Consignor == false).Where(x => x.ConsigneeName.Contains(searchString == null ? string.Empty : searchString, StringComparison.InvariantCultureIgnoreCase)));
    }

    private async Task<IEnumerable<ConsigneeModel>> SearchConsignor(string searchString)
    {
        return await Task.FromResult(Consignees.Where(x => x.Consignor == true).Where(x => x.ConsigneeName.Contains(searchString == null ? string.Empty : searchString, StringComparison.InvariantCultureIgnoreCase)));
    }

    private async Task<IEnumerable<OrderModel>> SearchOrders(string searchString)
    {
        return await Task.FromResult(Orders.Where(x => x.OrderName.Contains(searchString == null ? string.Empty : searchString, StringComparison.InvariantCultureIgnoreCase)));
    }

    private async Task<IEnumerable<RouteModel>> SearchRoutes(string searchString)
    {
        return await Task.FromResult(Routes.Where(x => x.RouteName.Contains(searchString == null ? string.Empty : searchString, StringComparison.InvariantCultureIgnoreCase)));
    }

    private async Task OnValidSubmit(EditContext context)
    {
        if (!Orders.Select(x => x.OrderName).Contains(Order.OrderName))
        {
            snackbar.Add("Invalid Order", Severity.Error);
            return;
        }
        else
             if (!Routes.Select(x => x.RouteName).Contains(Route.RouteName))
        {
            snackbar.Add("Invalid Route", Severity.Error);
            return;
        }

        model.OrderID = Order.OrderID;
        model.RouteID = Route.RouteID;
        model.ConsignorID = Consignor.ConsigneeID;
        model.ConsigneeID = Consignee.ConsigneeID;

        var authprov = await auth.GetAuthenticationStateAsync();

        foreach (var item in model.Gcs)
        {
            item.UserInfo.UserID = authprov.User.Identity.Name;
        }
        try
        {
            model = Iservice.Update(model);
            snackbar.Add("Saved Successfully", Severity.Success);
            MudDialog.Close(DialogResult.Ok(model));

            //if (collection.Exists(x => x.GcID == model.GcID))
            //{
            //    collection[collection.FindIndex(x => x.GcID == model.GcID)] = model;
            //}
            //else
            //{
            //    collection.Add(model);
            //}
            model = new GcSetModel();
            Order = new OrderModel();
            Route = new RouteModel();
            Consignor = new ConsigneeModel();
            Consignee = new ConsigneeModel();

        }
        catch (Exception ex)
        {
            snackbar.Add(ex.Message, Severity.Warning);
        }
    }

    private async Task OrderSelected(OrderModel SelectedOrder)
    {
        Order = SelectedOrder;
        await OrderChanged(SelectedOrder);
    }


    private void AddMoreInvoice()
    {
        if(model.Gcs.Last().BillQuantity != 0)
            model.Gcs.Add(new GcModel());
    }

    private void RemoveInvoice(int index)
    {
        model.Gcs.RemoveAt(index);
    }
}
