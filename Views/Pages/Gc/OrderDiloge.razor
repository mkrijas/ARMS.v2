@inject IOrderService Iservice
@inject IContentService Icontent
@inject IPartyService Iparty

@inject MudBlazor.ISnackbar snackbar
@attribute [Authorize]
@inject AuthenticationStateProvider auth

@inject NavigationManager UriHelper
   
 
<MudItem xs="12" md="12">
        <MudCard Elevation="10">
            <EditForm Model="@model" OnValidSubmit="OnValidSubmit">
                <ObjectGraphDataAnnotationsValidator />
                <ValidationSummary/>
             
                <MudCardContent>
                    <MudGrid Spacing="4">
                        <MudItem xs="12" md="6">
                            <MudTextField @bind-Value="model.OrderName" Label="Order Title" Variant="Variant.Outlined" Margin="Margin.Normal" For="@(() => model.OrderName)"></MudTextField>
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <MudAutocomplete T="PartyModel" Label="Client" @bind-Value="model.Party" ResetValueOnEmptyText="true" Variant="Variant.Outlined" Margin="Margin.Normal"
                                             SearchFunc="@SearchParty" ToStringFunc="@(e => e == null ? null : $"{e.PartyName}")"></MudAutocomplete>
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <MudSelect Label="Content" T="short?" @bind-Value="@model.ContentID" Variant="Variant.Outlined" Margin="Margin.Normal" OffsetY="true" AdornmentColor="Color.Secondary">
                                @foreach (var item in contents)
                                {
                                    <MudSelectItem Value="@item.ContentID">@item.ContentName</MudSelectItem>
                                }
                            </MudSelect>
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <MudTextField   @bind-Value="model.OrderQuantity" Label="Order Quantity" Variant="Variant.Outlined" Margin="Margin.Normal" For="@(() => model.OrderQuantity)"
                                          Adornment="Adornment.End" AdornmentText="@model?.Content?.PrimaryUnit" AdornmentColor="Color.Dark"  ></MudTextField>
                        </MudItem>
                    </MudGrid>
                    <MudButton Variant="Variant.Filled" Color="Color.Success" ButtonType="ButtonType.Submit">Save Order</MudButton>

                </MudCardContent>
            </EditForm>
        </MudCard>
    </MudItem>
@code {
    [Parameter]
    public OrderModel model { get; set; }
    private List<OrderModel> collection = new List<OrderModel>();
    private List<PartyModel> parties = new List<PartyModel>();
    private List<ContentModel> contents = new List<ContentModel>();
    [CascadingParameter] MudDialogInstance MudDialog { get; set; }
    private string searchString = "";
    private string unit = "";

    protected override async Task OnInitializedAsync()
    {
        await foreach (var item in Iparty.Select(0))
        {
            parties.Add(item);
        }
        await foreach (var item in Icontent.Select(0))
        {
            contents.Add(item);
        }
        await GetAll();
    }


    private async Task<IEnumerable<ContentModel>> Search(string searchString)
    {
        return await Task.FromResult(
            contents.Where(x => x.ContentName.Contains(searchString == null ? string.Empty : searchString, StringComparison.InvariantCultureIgnoreCase)));
    }
    private async Task<IEnumerable<PartyModel>> SearchParty(string searchString)
    {
        return await Task.FromResult(
            parties.Where(x => x.PartyName.Contains(searchString == null ? string.Empty : searchString, StringComparison.InvariantCultureIgnoreCase)));
    }


    private async Task GetAll()
    {
        await foreach (var item in Iservice.Select(0))
        {
            collection.Add(item);
        }
    }



    private void OnValidSubmit(EditContext context)
    {
        if (model.Party?.PartyID == 0)
        {
            snackbar.Add("Client is not selected", Severity.Error);
            return;
        }
        else
        if (!parties.Select(x => x.PartyName).Contains(model.Party.PartyName))
        {
            snackbar.Add("Invalid Party", Severity.Error);
            return;
        }
        

        model.ClientID = model.Party.PartyID;       

        MudDialog.Close(model); 


    }

}
