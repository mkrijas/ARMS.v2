@inject IRouteService Iservice
@inject IPlaceService Iplace
@inject MudBlazor.ISnackbar snackbar
@inject AuthenticationStateProvider auth
@attribute [Authorize]
@inject IDialogService DialogService

<MudDialog>
 <DialogActions> 
       <MudItem xs="12" md="12">
        <MudCard Elevation="10">
            <EditForm Model="@routemodel" OnValidSubmit="OnValidSubmit">
                <DataAnnotationsValidator />
                <ValidationSummary />
               
                <MudCardContent>
                    <MudGrid Spacing="4">
                        <MudItem xs="12" md="4">
                            <MudAutocomplete T="PlaceModel" Label="Origin" @bind-Value="@routemodel.Origin" ResetValueOnEmptyText="true"
                                             SearchFunc="@Search" ToStringFunc="@(e=> e==null?null : $"{e.PlaceName}")"
                                             Immediate="true"></MudAutocomplete>
                        </MudItem>
                        <MudItem xs="12" md="4">
                            <MudAutocomplete T="PlaceModel" Label="Via" @bind-Value="@routemodel.Via" ResetValueOnEmptyText="true"
                                             SearchFunc="@Search" ToStringFunc="@(e=> e==null?null : $"{e.PlaceName}")"
                                             Immediate="true"></MudAutocomplete>
                        </MudItem>
                        <MudItem xs="12" md="4">
                            <MudAutocomplete T="PlaceModel" Label="Destination" @bind-Value="@routemodel.Destination" ResetValueOnEmptyText="true"
                                             SearchFunc="@Search" ToStringFunc="@(e=> e==null?null : $"{e.PlaceName}")"
                                             Immediate="true"></MudAutocomplete>
                        </MudItem>
                        <MudItem xs="12" md="3">
                            <MudTextField @bind-Value="@routemodel.Distance" Label="Distance" Variant="Variant.Outlined" Margin="Margin.Normal" For="@(() => routemodel.Distance)"></MudTextField>
                        </MudItem>
                        <MudItem xs="12" md="3">
                            <MudTextField @bind-Value="@routemodel.SpeedLimit" Label="Speed Limit" Variant="Variant.Outlined" Margin="Margin.Normal" For="@(() => routemodel.SpeedLimit)"></MudTextField>
                        </MudItem>
                        <MudItem xs="12" md="3">
                            <MudTextField @bind-Value="@routemodel.RunningHours" Label="Running Hours" Variant="Variant.Outlined" Margin="Margin.Normal" For="@(() =>routemodel.RunningHours)"></MudTextField>
                        </MudItem>
                        <MudItem xs="12" md="3">
                            <MudNumericField  @bind-Value="@routemodel.TollBooths" Label="No of TollBooths" Variant="Variant.Outlined" Margin="Margin.Normal" For="@(() => routemodel.TollBooths)"></MudNumericField>
                        </MudItem>
                        <MudItem xs="12">
                            <MudRadioGroup @bind-SelectedOption="@routemodel.RouteType">
                                @foreach (var rtype in RouteTypes)
                                {
                                    <MudRadio Option="@rtype" Color="Color.Primary">@rtype</MudRadio>
                                }
                            </MudRadioGroup>
                        </MudItem>
                    </MudGrid>
                    <MudButton Variant="Variant.Filled" Color="Color.Success" ButtonType="ButtonType.Submit">Save Route</MudButton>

                </MudCardContent>
            </EditForm>
        </MudCard>
    </MudItem>


        </DialogActions>
        </MudDialog>

@code {
    [Parameter]
    public RouteModel routemodel { get; set; }
    private List<RouteModel> collection = new List<RouteModel>();
    public List<PlaceModel> places = new List<PlaceModel>();

    private List<string> RouteTypes = new List<string>() { "Highland", "City", "Highway", "Other" };

    private string searchRoute = "";

    protected override async Task OnInitializedAsync()
    {
        places = Iplace.Select(0).ToList();
        await GetAll();
    }

    private async Task<IEnumerable<PlaceModel>> Search(string searchString)
    {
        return await Task.FromResult(places.Where(x => x.PlaceName.Contains(searchString == null ? string.Empty : searchString, StringComparison.InvariantCultureIgnoreCase)));
    }

    private async Task GetAll()
    {
        await foreach (var route in Iservice.Select(0))
        {
            collection.Add(route);
        }
    }

    private async Task OnValidSubmit(EditContext context)
    {
        if (!places.Select(x => x.PlaceName).Contains(routemodel.Origin.PlaceName))
        {
            snackbar.Add("Invalid Origin", Severity.Error);
            return;
        }
        else
             if (!places.Select(x => x.PlaceName).Contains(routemodel.Via.PlaceName))
        {
            snackbar.Add("Invalid Via", Severity.Error);
            return;
        }
        else
        if (!places.Select(x => x.PlaceName).Contains(routemodel.Destination.PlaceName))
        {
            snackbar.Add("Invalid Destination", Severity.Error);
            return;
        }
        var authprov = await auth.GetAuthenticationStateAsync();
        routemodel.UserInfo.UserID = authprov.User.Identity.Name;
        routemodel.RouteName = routemodel.Origin.PlaceName + "-" + routemodel.Via.PlaceName + "-" + routemodel.Destination.PlaceName;
        routemodel.MieageModifier = 1;
        try
        {
            routemodel = await Iservice.Update(routemodel);
            snackbar.Add("Saved Successfully", Severity.Success);
            if (collection.Exists(x => x.RouteID == routemodel.RouteID))
            {
                collection[collection.FindIndex(x => x.RouteID == routemodel.RouteID)] = routemodel;
            }
            else
            {
                collection.Add(routemodel);
            }
            routemodel = new RouteModel();
        }
        catch(Exception ex)
        {
            snackbar.Add(ex.Message, Severity.Warning);
        }
    }

    private void Edit(int? id)
    {
        routemodel = collection.FirstOrDefault(x => x.RouteID == id);
        routemodel.Origin = places.FirstOrDefault(x => x.PlaceID == routemodel.Origin.PlaceID);
        routemodel.Via = places.FirstOrDefault(x => x.PlaceID == routemodel.Via.PlaceID);
        routemodel.Destination = places.FirstOrDefault(x => x.PlaceID == routemodel.Destination.PlaceID);

    }
    private async void Delete(int? id)
    {
        await Iservice.Delete(id, "Rijas");
        snackbar.Add("Deleted Successfully", Severity.Success);
        await GetAll();
    }


}
