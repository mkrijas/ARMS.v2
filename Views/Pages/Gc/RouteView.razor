@page "/routeView"
@inject IRouteService Iservice
@inject IPlaceService Iplace
@inject MudBlazor.ISnackbar snackbar
@attribute [Authorize]
@inject AuthenticationStateProvider auth


<MudGrid Spacing="4">
    <MudItem xs="12" md="12">
        <MudCard Elevation="10">
            <EditForm Model="@model" OnValidSubmit="OnValidSubmit">
                <DataAnnotationsValidator />
                <ValidationSummary />
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6">Add/Edit Routes</MudText>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent>
                    <MudGrid Spacing="4">
                        <MudItem xs="12" md="4">
                            <MudAutocomplete T="PlaceModel" Label="Origin" @bind-Value="@model.Origin" ResetValueOnEmptyText="true"
                                             SearchFunc="@Search" ToStringFunc="@(e=> e==null?null : $"{e.PlaceName}")"
                                             Immediate="true"></MudAutocomplete>
                        </MudItem>
                        <MudItem xs="12" md="4">
                            <MudAutocomplete T="PlaceModel" Label="Via" @bind-Value="@model.Via" ResetValueOnEmptyText="true"
                                             SearchFunc="@Search" ToStringFunc="@(e=> e==null?null : $"{e.PlaceName}")"
                                             Immediate="true"></MudAutocomplete>
                        </MudItem>
                        <MudItem xs="12" md="4">
                            <MudAutocomplete T="PlaceModel" Label="Destination" @bind-Value="@model.Destination" ResetValueOnEmptyText="true"
                                             SearchFunc="@Search" ToStringFunc="@(e=> e==null?null : $"{e.PlaceName}")"
                                             Immediate="true"></MudAutocomplete>
                        </MudItem>
                        <MudItem xs="12" md="4">
                            <MudTextField @bind-Value="@model.Distance" Label="Distance" Variant="Variant.Text" Margin="Margin.Normal" For="@(() => model.Distance)"></MudTextField>
                        </MudItem>
                        <MudItem xs="12" md="4">
                            <MudTextField @bind-Value="@model.SpeedLimit" Label="Speed Limit" Variant="Variant.Text" Margin="Margin.Normal" For="@(() => model.SpeedLimit)"></MudTextField>
                        </MudItem>
                        <MudItem xs="12" md="4">
                            <MudTextField @bind-Value="@model.RunningHours" Label="Running Hours" Variant="Variant.Text" Margin="Margin.Normal" For="@(() => model.RunningHours)"></MudTextField>
                        </MudItem>
                        <MudItem xs="12">
                            <MudRadioGroup @bind-SelectedOption="@model.RouteType">
                                @foreach (var rtype in RouteTypes)
                                {
                                    <MudRadio Option="@rtype" Color="Color.Primary">@rtype</MudRadio>
                                }
                            </MudRadioGroup>
                        </MudItem>
                    </MudGrid>
                    <MudButton Variant="Variant.Filled" Color="Color.Success" ButtonType="ButtonType.Submit">Save Route</MudButton>

                </MudCardContent>
            </EditForm>
        </MudCard>
    </MudItem>
    <MudItem xs="12" md="12">
        <MudTable Items="@collection" Elevation="10" Filter="new Func<RouteModel, bool>(search)" @bind-model="model">
            <ToolBarContent>
                <MudText Typo="Typo.h6">Routes</MudText>
                <MudToolBarSpacer></MudToolBarSpacer>
                <MudTextField @bind-Value="searchRoute" Placeholder="Search Routes... "
                              Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                              IconSize="Size.Medium" Class="mt-0"></MudTextField>
            </ToolBarContent>
            <HeaderContent>
                <MudTh><MudTableSortLabel SortBy="new Func<RouteModel, object>(x=> x.RouteName)" InitialDirection="SortDirection.Ascending">Route</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<RouteModel, object>(x=> x.Distance)" InitialDirection="SortDirection.Ascending">Distance</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<RouteModel, object>(x=> x.SpeedLimit)" InitialDirection="SortDirection.Ascending">Speed Limit</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<RouteModel, object>(x=> x.RunningHours)" InitialDirection="SortDirection.Ascending">Speed Limit</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<RouteModel, object>(x=> x.RouteType)" InitialDirection="SortDirection.Ascending">Route Type</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<RouteModel, object>(x=> x.TollBooths)" InitialDirection="SortDirection.Ascending">No of Tollbooths</MudTableSortLabel></MudTh>
                <MudTh>Actions</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Route">@context.RouteID</MudTd>
                <MudTd DataLabel="Distance">@context.Distance</MudTd>
                <MudTd DataLabel="SpeedLimit">@context.SpeedLimit</MudTd>
                <MudTd DataLabel="RunningHours">@context.RunningHours</MudTd>
                <MudTd DataLabel="RouteType">@context.RouteType</MudTd>
                <MudTd DataLabel="TollBooths">@context.TollBooths</MudTd>
                <MudTd DataLabel="">
                    <MudFab @onclick="@(()=> Edit(context.RouteID))" Color="Color.Primary" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" IconSize="Size.Small" />
                    <MudFab @onclick="@(()=> Delete(context.RouteID))" Color="Color.Primary" Icon="@Icons.Material.Filled.Delete" Size="Size.Small" IconSize="Size.Small" />
                </MudTd>
            </RowTemplate>
            <PagerContent>
                <MudTablePager PageSizeOptions="new int[] { 5, 10, 20, 50, 100 }" />
            </PagerContent>
        </MudTable>
    </MudItem>



</MudGrid>
@code {

    private RouteModel model = new RouteModel();
    private List<RouteModel> collection = new List<RouteModel>();
    public List<PlaceModel> places = new List<PlaceModel>();

    private List<string> RouteTypes = new List<string>() { "Highland", "City", "Highway", "Other" };

    private string searchRoute = "";

    protected override async Task OnInitializedAsync()
    {
        await foreach (var place in Iplace.Select(0))
        {
            places.Add(place);
        }

        await GetAll();
    }

    private async Task<IEnumerable<PlaceModel>> Search(string searchString)
    {
        return await Task.FromResult(places.Where(x => x.PlaceName.Contains(searchString == null ? string.Empty : searchString, StringComparison.InvariantCultureIgnoreCase)));
    }

    private async Task GetAll()
    {
        await foreach (var route in Iservice.Select(0))
        {
            collection.Add(route);
        }
    }

    private async Task OnValidSubmit(EditContext context)
    {
        if (!places.Select(x => x.PlaceName).Contains(model.Origin.PlaceName))
        {
            snackbar.Add("Invalid Origin", Severity.Error);
            return;
        }
        else
             if (!places.Select(x => x.PlaceName).Contains(model.Via.PlaceName))
        {
            snackbar.Add("Invalid Via", Severity.Error);
            return;
        }
        else
        if (!places.Select(x => x.PlaceName).Contains(model.Destination.PlaceName))
        {
            snackbar.Add("Invalid Destination", Severity.Error);
            return;
        }
        var authprov = await auth.GetAuthenticationStateAsync();
        model.UserInfo.UserID = authprov.User.Identity.Name;
        model.RouteName = model.Origin.PlaceName + "-" + model.Via.PlaceName + "-" + model.Destination.PlaceName;
        model.MieageModifier = 1;
        try
        {
            model = await Iservice.Update(model);
            snackbar.Add("Saved Successfully", Severity.Success);
            if (collection.Exists(x => x.RouteID == model.RouteID))
            {
                collection[collection.FindIndex(x => x.RouteID == model.RouteID)] = model;
            }
            else
            {
                collection.Add(model);
            }
            model = new RouteModel();
        }
        catch(Exception ex)
        {
            snackbar.Add(ex.Message, Severity.Warning);
        }
    }

    private void Edit(int id)
    {
        model = collection.FirstOrDefault(x => x.RouteID == id);
    }
    private async void Delete(int id)
    {
        await Iservice.Delete(id, "Rijas");
        snackbar.Add("Deleted Successfully", Severity.Success);
        await GetAll();
    }


    private bool search(RouteModel model)
    {
        if (model.RouteName != null && model.RouteName.Contains(searchRoute, StringComparison.OrdinalIgnoreCase))
        {
            return true;
        }
        return false;
    }
}


