@page "/branch"
@using System.Threading;
@using ArmsAdmin.Pages.User;
@layout AdminMainLayout
@inject IBranchService Iservice
@inject IPlaceService Iplace
@inject IOrderService Iorder
@inject IChartOfAccountService Icoa
@inject IAddressService Iaddress
@inject MudBlazor.ISnackbar snackbar
@attribute [Authorize]
@inject AuthenticationStateProvider auth
@inject IDialogService DialogService
@inject IRoleService<RoleModel> Irole

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-8 mb-12">
    <!-- Header Section -->
    <div class="header-section mb-10">
        <div class="d-flex justify-space-between align-end">
            <div>
                <MudText Typo="Typo.h4" Class="admin-title mb-2"><b>Branch Management</b></MudText>
                <div class="title-accent mb-4"></div>
                <MudText Typo="Typo.body1" Class="admin-subtitle" Style="color: #667085;">
                    Manage physical locations, assign roles, and configure regional settings.
                </MudText>
            </div>
            <div class="admin-top-actions mb-1">
                <MudButton Disabled="@_busy" StartIcon="@Icons.Material.Filled.AddLocationAlt" Variant="Variant.Filled" Color="Color.Primary" Class="rounded-lg py-2 px-6 shadow-sm" @onclick="@(() => Edit(new BranchModel()))">Add New Branch</MudButton>
            </div>
        </div>
    </div>

    <div class="admin-glass-card">
        <MudTable Items="@collection" Elevation="0" Dense="true" Filter="new Func<BranchModel, bool>(search)" Hover="true" Breakpoint="Breakpoint.Sm">
            <ToolBarContent>
                <div class="d-flex align-center gap-4 w-100">
                    <MudText Typo="Typo.h6" Class="card-title" Style="color: #367588;"><b>Active Branches</b></MudText>
                    <MudSpacer />
                    <MudTextField @bind-Value="searchBranch" Placeholder="Search branches..." Adornment="Adornment.Start" Variant="Variant.Outlined" Margin="Margin.Dense" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="search-field" Style="max-width: 300px; background: white;"></MudTextField>
                </div>
            </ToolBarContent>
            <HeaderContent>
                <MudTh><MudTableSortLabel SortBy="new Func<BranchModel, object>(x => x.BranchName)" InitialDirection="SortDirection.Ascending">Branch Name</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<BranchModel, object>(x => x.SoDisplayText)">Assigned Role</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<BranchModel, object>(x => x.Place.PlaceName)">Location</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<BranchModel, object>(x => x.Active)">Status</MudTableSortLabel></MudTh>
                <MudTh Style="text-align: right;">Operations</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="BranchName"><b>@context.BranchName</b></MudTd>
                <MudTd DataLabel="Role"><MudChip T="string" Size="Size.Small" Variant="Variant.Text" Color="Color.Primary">@context.SoDisplayText</MudChip></MudTd>
                <MudTd DataLabel="Place">@context.Place.PlaceName</MudTd>
                <MudTd DataLabel="Active">
                    <MudIcon Icon="@(context.Active ? Icons.Material.Filled.CheckCircle : Icons.Material.Filled.Cancel)" 
                             Color="@(context.Active ? Color.Success : Color.Error)" Size="Size.Small" />
                </MudTd>
                <MudTd DataLabel="" Style="text-align: right;">
                    <div class="d-flex justify-end gap-1">
                        <MudIconButton OnClick="@(() => openOrders(context.BranchID))" Color="Color.Primary" Icon="@Icons.Material.Filled.ListAlt" Size="Size.Small" Variant="Variant.Filled" Title="Open Orders" />
                        <MudIconButton OnClick="@(() => Edit(context))" Color="Color.Info" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Variant="Variant.Filled" Title="Edit Branch" />
                        <MudIconButton OnClick="@(() => Delete(context))" Color="Color.Error" Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Variant="Variant.Filled" Title="Delete Branch" />
                        <MudIconButton OnClick="@(() => AddContact(context.BranchID))" Color="Color.Warning" Icon="@Icons.Material.Filled.ContactPhone" Size="Size.Small" Variant="Variant.Filled" Title="Contact Details" />
                        <MudIconButton OnClick="@(() => Settings(context.BranchID))" Color="Color.Dark" Icon="@Icons.Material.Filled.Settings" Size="Size.Small" Variant="Variant.Filled" Title="Branch Settings" />
                        <MudIconButton OnClick="@(() => UserList(context.BranchID))" Color="Color.Tertiary" Icon="@Icons.Material.Filled.Group" Size="Size.Small" Variant="Variant.Filled" Title="User List" />
                    </div>
                </MudTd>
            </RowTemplate>
            <PagerContent>
                <div class="pa-4">
                    <MudTablePager PageSizeOptions="new int[] { 10, 20, 50, 100 }" />
                </div>
            </PagerContent>
        </MudTable>
    </div>
</MudContainer>
    <MudDialog @bind-IsVisible="visibleOrders" DisableSidePadding="true">
        <TitleContent>
            <MudText Typo="Typo.h6">
                <MudIcon Icon="@Icons.Material.Filled.Edit" Class="mr-3" /> @collection.Find(x=> x.BranchID == ClickedBranchID).BranchName Orders
            </MudText>
        </TitleContent>
        <DialogContent>
            <MudContainer Style="height: 300px; overflow-y: auto">
                @if (ClickedBranchID != 0)
                {
                    <MudTable Items="@AssignedOrders">
                        <RowTemplate>
                            <MudTd DataLabel="Order Name">
                                <MudText Typo="Typo.h6">
                                    @context.OrderName
                                    <MudFab Class="float-right" @onclick="@(() => removeOrder(context.OrderID))" Color="Color.Dark" StartIcon="@Icons.Material.Filled.Remove" Size="Size.Small" />
                                </MudText>
                            </MudTd>
                        </RowTemplate>
                    </MudTable>
                    <MudItem>
                        <MudAutocomplete T="OrderModel" Label="Order" Value="OrderAssigned" ResetValueOnEmptyText="true" SearchFunc="@(async (string s, CancellationToken t) => await SearchOrders(s, t))" ToStringFunc="@(e => e == null ? null : $"{e.OrderName}")" ValueChanged="addOrder"></MudAutocomplete>
                    </MudItem>
                }
            </MudContainer>
        </DialogContent>
    </MudDialog>


@code {

    private BranchModel model = new BranchModel();
    private List<BranchModel> collection = new List<BranchModel>();
    private List<OrderModel> AssignedOrders = new List<OrderModel>();
    private List<OrderModel> Orders = new List<OrderModel>();
    private OrderModel OrderAssigned { get; set; }
    DialogOptions maxWidth = new DialogOptions() { MaxWidth = MaxWidth.Medium, FullWidth = true };

    public bool HasPermissionOrderServiceAddRemoveOrder { get; set; } = false;
    public int OrderDocTypeID = 45;
    public bool HasPermissionBranchServiceEdit { get; set; } = false;
    public bool HasPermissionBranchServiceDelete { get; set; } = false;
    public int BranchDocTypeID = 73;

    private bool _busy;
    private string searchBranch = "";
    private bool visibleOrders;
    private int? ClickedBranchID;
    private bool isLoaded = false;

    protected override async Task OnInitializedAsync()
    {
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionOrderServiceAddRemoveOrder = await Irole.HasClaim(OrderDocTypeID.ToString(), "AddRemoveOrder", ctc.Token);
        HasPermissionBranchServiceEdit = await Irole.HasClaim(BranchDocTypeID.ToString(), "Edit", ctc.Token);
        HasPermissionBranchServiceDelete = await Irole.HasClaim(BranchDocTypeID.ToString(), "Delete", ctc.Token);

        await GetAll();
    }

    private async Task openOrders(int? BranchID)
    {
        ClickedBranchID = BranchID;
        await refreshOrders();
        visibleOrders = true;
    }

    private async Task<IEnumerable<OrderModel>> SearchOrders(string searchString, CancellationToken token)
    {
        return await Task.FromResult(
            Orders.Where(x => x.OrderName.Contains(searchString == null ? string.Empty : searchString, StringComparison.InvariantCultureIgnoreCase))
             .Where(x => AssignedOrders.All(y => y.OrderID != x.OrderID)));
    }

    private async Task GetAll()
    {
        collection = Iservice.Select().ToList();
        isLoaded = true;
    }

    private async Task Edit(BranchModel model)
    {
        try
        {
            if (HasPermissionBranchServiceEdit)
            {
                if (_busy)
                {
                    snackbar.Add("Please wait while form is closing!", Severity.Warning);
                    return;
                }
                _busy = true;
                if (model.BranchID != null)
                {
                    model.Address = Iaddress.SelectByID(model.Address.AddressID);
                    model.Place = await Iplace.SelectByID(model.Place.PlaceID);                    
                }
                DialogParameters parms = new DialogParameters();
                parms.Add("model", model.Clone());
                var dialog = DialogService.Show<BranchDialog>("Add/Edit Branch", parms, new DialogOptions() { MaxWidth = MaxWidth.Medium });
                var result = await dialog.Result;
                if (!result.Canceled)
                {
                    BranchModel UpdatedModel = (BranchModel)result.Data;
                    if ((UpdatedModel.BranchID == null && !collection.Exists(x => x.BranchName == UpdatedModel.BranchName)) ||
                        (UpdatedModel.BranchID != null && !collection.Exists(x => x.BranchName == UpdatedModel.BranchName && x.BranchID != UpdatedModel.BranchID)))
                    {
                        var authState = await auth.GetAuthenticationStateAsync();
                        UpdatedModel.UserInfo.UserID = authState.User.Identity.Name;
                        Iservice.Update(UpdatedModel);
                        snackbar.Add("Saved Successfully", Severity.Success);
                    }
                    else
                    {
                        bool? value = await DialogService.ShowMessageBox(
                            "Error !",
                            (MarkupString)$"BranchName - <b>{UpdatedModel.BranchName}</b> already exist !");
                    }
                }
            }
            else
            {
                bool? result = await DialogService.ShowMessageBox(
                    "Permission denied!",
                    "You don't have any permission to Edit Branch.");
            }
            await GetAll();
        }
        catch (Exception a)
        {
            snackbar.Add(a.Message, Severity.Error);
        }
        finally
        {
            await Task.Delay(200);
            _busy = false;
        }
    }

    private async Task Settings(int? BranchID)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        _busy = true;
        DialogParameters parms = new DialogParameters();
        parms.Add("branchID", BranchID);
        var dialog = DialogService.Show<SettingsDialog>("Branch Settings", parms, new DialogOptions() { MaxWidth = MaxWidth.Large });
        await Task.Delay(200);
        _busy = false;
    }

    private async Task UserList(int? BranchID)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        _busy = true;
        DialogParameters parms = new DialogParameters();
        parms.Add("branchID", BranchID);
        var dialog = DialogService.Show<UserListDialog>("Users List", parms, new DialogOptions() { MaxWidth = MaxWidth.Medium });
        await Task.Delay(200);
        _busy = false;
    }

    private async Task refreshOrders()
    {
        AssignedOrders = new List<OrderModel>();
        Orders = new List<OrderModel>();
        await foreach (var item in Iorder.SelectByBranch(ClickedBranchID))
        {
            AssignedOrders.Add(item);
        }
        await foreach (var item in Iorder.Select(0))
        {
            if (!AssignedOrders.Contains(item))
            {
                Orders.Add(item);
            }
        }
    }

    private async Task Delete(BranchModel model)
    {
        if (HasPermissionBranchServiceDelete)
        {
            bool? result = await DialogService.ShowMessageBox(
                "Warning !",
                "Are you sure, you want to delete branch - " + model.BranchName + "?");
            if (result == true)
            {
                var authprov = await auth.GetAuthenticationStateAsync();
                Iservice.Delete(model.BranchID, authprov.User.Identity.Name);
                snackbar.Add("Deleted Successfully", Severity.Success);
            }
        }
        else
        {
            bool? result = await DialogService.ShowMessageBox(
                "Permission denied!",
                "You don't have any permission to Delete Branch.");
        }
        await GetAll();
    }

    private async void AddContact(int? id)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        _busy = true;
        DialogParameters parms = new DialogParameters();
        parms.Add("branchID", id);
        var dialog = DialogService.Show<BranchContactDetailsView>("Contact Details", parms, maxWidth);
        var result = await dialog.Result;
        if (!result.Canceled)
        {
            //BranchModel UpdatedModel = (BranchModel)result.Data;
            //var authState = await auth.GetAuthenticationStateAsync();
            //UpdatedModel.UserInfo.UserID = authState.User.Identity.Name;
            //Iservice.Update(UpdatedModel);
            //await GetAll();
        }
        await Task.Delay(200);
        _busy = false;
    }

    private async Task addOrder(OrderModel obj)
    {
        if (HasPermissionOrderServiceAddRemoveOrder)
        {
            OrderAssigned = obj;
            if (OrderAssigned?.OrderID > 0)
            {
                var authprov = await auth.GetAuthenticationStateAsync();
                int result = await Iorder.BranchOrderUpdate(ClickedBranchID, OrderAssigned.OrderID, authprov.User.Identity.Name, "Update");
                await refreshOrders();
                OrderAssigned = new OrderModel();
            }
        }
        else
        {
            bool? result = await DialogService.ShowMessageBox(
                "Permission denied!",
                "You don't have any permission to Add/Remove Order.");
        }
    }

    private async Task removeOrder(int? OrderID)
    {
        if (HasPermissionOrderServiceAddRemoveOrder)
        {
            var authprov = await auth.GetAuthenticationStateAsync();
            int result = await Iorder.BranchOrderUpdate(ClickedBranchID, OrderID, authprov.User.Identity.Name, "Delete");
            await refreshOrders();
        }
        else
        {
            bool? result = await DialogService.ShowMessageBox(
                "Permission denied!",
                "You don't have any permission to Add/Remove Order.");
        }
    }

    private bool search(BranchModel model)
    {
        if (model.BranchName != null && model.BranchName.Contains(searchBranch, StringComparison.OrdinalIgnoreCase))
        {
            return true;
        }
        return false;
    }
}

