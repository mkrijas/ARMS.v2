@page "/dashboard"
@using System.Threading;
@using System.Globalization
@attribute [Authorize]
@inject AuthenticationStateProvider auth
@inject ITruckService TruckService
@inject IDashboardService DashboardService
@inject IJSRuntime JSRuntime
@inject MudBlazor.ISnackbar snackbar
@inject IDialogService DialogService
@using Microsoft.JSInterop



@if (_isLoading)
{
    <LoaderComponent IsFullScreen="true"
                     ShowLogo="false"
                     Size="large"
                     LoadingText="Loading Logistics Dashboard"
                     SubText="Fetching Logistics data..." />
}
else
{

    <div class="dashboard-container">
        <!-- Header Section -->
        <div class="dashboard-header d-flex justify-space-between align-center mb-6">
            <div>
                <MudText Typo="Typo.h4" Style="font-weight: 700; color: #2d3748;">Dashboard</MudText>
                <MudText Typo="Typo.subtitle1" Class="text-muted mt-2">
                    Overview of logistics performance
                </MudText>
            </div>
            <div class="d-flex align-center gap-3">
                <MudPaper Elevation="0" Class="py-2 px-4 rounded-lg d-flex align-center gap-2" Style="background: #eef2f6; color: #5b6b79;">
                    <MudIcon Icon="@Icons.Material.Filled.CalendarToday" Size="Size.Small" />
                    <MudText Typo="Typo.body2" Style="font-weight:500">@CurrentDateTime.Value.ToString("dd MMM yyyy")</MudText>
                </MudPaper>
                <MudButton StartIcon="@Icons.Material.Outlined.Refresh" 
                          Variant="Variant.Filled" 
                          Color="Color.Primary" 
                          OnClick="@(() => Refresh())"
                          Class="rounded-lg shadow-sm"
                          Style="text-transform: none; font-weight: 600;">
                    Refresh Data
                </MudButton>
            </div>
        </div>

        <MudGrid Spacing="4">
            <!-- Main Chart Section -->
            <MudItem md="8" xs="12">
                <MudPaper Elevation="0" Class="dashboard-card pa-0" Style="height: 100%;">
                    <div class="card-header d-flex justify-space-between align-center pa-6">
                        <div class="d-flex align-center gap-4">
                             <MudIcon Icon="@Icons.Material.Filled.BarChart" Color="Color.Primary" Size="Size.Large" />
                             <div>
                                <MudText Typo="Typo.h6" Style="font-weight: 700; line-height: 1.2;">Tonnage Analytics</MudText>
                                <MudText Typo="Typo.body2" Class="text-muted mt-1">Consignment data for @ConsignmentTitle</MudText>
                             </div>
                        </div>
                        <MudSelect T="int" Value="@SelectedPeriod" ValueChanged="(Value) => SelectedValueChanged(Value)"
                                  Variant="Variant.Outlined" Margin="Margin.Dense" Dense="true"
                                  Class="rounded-lg ml-5" Style="min-width: 180px; background: white;" AnchorOrigin="Origin.BottomLeft">
                            <MudSelectItem Value="1">Last 10 Days</MudSelectItem>
                            <MudSelectItem Value="2">Current Month</MudSelectItem>
                            <MudSelectItem Value="3">Last Month</MudSelectItem>
                        </MudSelect>
                    </div>
                    <div class="pa-6">
                        <MudChart T="double" ChartType="ChartType.Bar" ChartOptions="@_barOptions" ChartSeries="@BarSeries" XAxisLabels="@BarLabels" Width="100%" Height="500px" />
                    </div>
                </MudPaper>
            </MudItem>

            <!-- Key Metrics Section -->
            <MudItem md="4" xs="12">
                <MudGrid Spacing="3">
                    <MudItem xs="12" sm="6" md="12">
                         <MudPaper Elevation="0" Class="dashboard-card stat-card pa-4">
                            <div class="d-flex justify-space-between align-start">
                                <div>
                                    <MudText Typo="Typo.subtitle2" Style="opacity: 0.8; font-weight: 600;">TRIPS INITIATED</MudText>
                                    <MudText Typo="Typo.h3" Style="font-weight: 800; margin-top: 8px;">@dict["CountOfTrips"].ToString()</MudText>
                                </div>
                                <MudPaper Elevation="0" Class="d-flex justify-center align-center rounded-circle" Width="48px" Height="48px" Style="background: rgba(255,255,255,0.5);">
                                    <MudIcon Icon="@Icons.Material.Filled.LocalShipping" Size="Size.Medium" Color="Color.Primary" />
                                </MudPaper>
                            </div>
                            <div class="mt-4">
                                <MudChip T="string" Size="Size.Small" Color="Color.Error" Variant="Variant.Filled" Icon="@Icons.Material.Filled.Cancel" Class="rounded-lg">
                                    Cancelled: @dict["CountOfCancelledTrips"].ToString()
                                </MudChip>
                            </div>
                        </MudPaper>
                    </MudItem>

                    <MudItem xs="12" sm="6" md="12">
                        <MudPaper Elevation="0" Class="dashboard-card stat-card pa-4" >
                            <div class="d-flex justify-space-between align-start">
                                <div>
                                    <MudText Typo="Typo.subtitle2" Style="opacity: 0.8; font-weight: 600;">FUEL PENDING</MudText>
                                    <MudText Typo="Typo.h3" Style="font-weight: 800; margin-top: 8px;">@dict["FuelSettlementPending"].ToString()</MudText>
                                </div>
                                <MudPaper Elevation="0" Class="d-flex justify-center align-center rounded-circle" Width="48px" Height="48px" Style="background: rgba(255,255,255,0.5);">
                                    <MudIcon Icon="@Icons.Material.Filled.LocalGasStation" Size="Size.Medium" Color="Color.Success" />
                                </MudPaper>
                            </div>
                             <div class="mt-4">
                                <MudChip T="string" Size="Size.Small" Color="Color.Warning" Variant="Variant.Filled" Icon="@Icons.Material.Filled.HourglassEmpty" Class="rounded-lg">
                                    Not fueled: @dict["FuelPending"].ToString()
                                </MudChip>
                            </div>
                        </MudPaper>
                    </MudItem>

                     <MudItem xs="12">
                        <MudPaper Elevation="0" Class="dashboard-card pa-4 d-flex flex-column align-center justify-center" Style="min-height: 335px;">
                             <MudText Typo="Typo.subtitle1" Class="mb-4" Style="font-weight: 600; color: #455a64;">Driver Allocation</MudText>
                            <MudChart T="double" ChartOptions="@_noDriverChartOptions" ChartType="ChartType.Donut" InputData="@NoDriverData" InputLabels="@NoDriverLabels" Height="220px" Width="220px" LegendPosition="Position.Right">
                                <CustomGraphics>
                                    <text class="donut-inner-text" x="50%" y="45%" dominant-baseline="middle" text-anchor="middle" fill="#37474f" font-family="Roboto" font-weight="bold" font-size="16">No Driver</text>
                                    <text class="donut-inner-text" x="50%" y="60%" dominant-baseline="middle" text-anchor="middle" fill="#ef5350" font-family="Roboto" font-weight="900" font-size="24">@noDriverPercent.ToString("P0")</text>
                                </CustomGraphics>
                            </MudChart>
                        </MudPaper>
                    </MudItem>
                </MudGrid>
            </MudItem>

            <!-- Bottom Status Section -->
            <MudItem md="6" xs="12">
                <MudPaper Elevation="0" Class="dashboard-card pa-0">
                    <div class="card-header">
                        <MudText Typo="Typo.h6" Style="font-weight: 600; color: #37474f;">Truck Status</MudText>
                    </div>
                    <div class="pa-4 d-flex justify-center">
                          <MudChart T="double" ChartType="ChartType.Donut" InputData="@TruckData" InputLabels="@TruckLabels" Height="280px" Width="280px" SelectedIndex="@SelectedTruckChartIndex" SelectedIndexChanged="@SelectedTruckChartIndexChanged" LegendPosition="Position.Right">
                            <CustomGraphics>
                                <text class="donut-inner-text" x="50%" y="45%" dominant-baseline="middle" text-anchor="middle" fill="#37474f" font-family="Roboto" font-weight="bold" font-size="18">Total Trucks</text>
                                <text class="donut-inner-text" x="50%" y="60%" dominant-baseline="middle" text-anchor="middle" fill="#1976d2" font-family="Roboto" font-weight="900" font-size="32">@TruckData.Sum().ToString()</text>
                            </CustomGraphics>
                        </MudChart>
                    </div>
                </MudPaper>
            </MudItem>

             <MudItem md="6" xs="12">
                <MudPaper Elevation="0" Class="dashboard-card pa-0">
                    <div class="card-header">
                        <MudText Typo="Typo.h6" Style="font-weight: 600; color: #37474f;">Driver Status</MudText>
                    </div>
                    <div class="pa-4 d-flex justify-center">
                         <MudChart T="double" ChartType="ChartType.Donut" InputData="@DriverData" InputLabels="@DriverLabels" Height="280px" Width="280px" SelectedIndex="@SelectedDriverChartIndex" SelectedIndexChanged="@SelectedDriverChartIndexChanged" LegendPosition="Position.Right">
                            <CustomGraphics>
                                <text class="donut-inner-text" x="50%" y="45%" dominant-baseline="middle" text-anchor="middle" fill="#37474f" font-family="Roboto" font-weight="bold" font-size="18">Total Drivers</text>
                                <text class="donut-inner-text" x="50%" y="60%" dominant-baseline="middle" text-anchor="middle" fill="#388e3c" font-family="Roboto" font-weight="900" font-size="32">@DriverData.Sum().ToString()</text>
                            </CustomGraphics>
                        </MudChart>
                    </div>
                </MudPaper>
            </MudItem>

        </MudGrid>
    </div>}

<style>
    .wide_chart svg {
        width: 100% !important;
        height: 100% !important;
    }
    
    /* Dynamic stroke width based on data count */
    .mud-chart-bar {
        stroke-width: @BarChartStrokeWidth !important;
    }
</style>


@code {

    private string BarChartStrokeWidth = "25px";
    private bool _isLoading = true;

    private DateTime _loadStartTime;

    public List<ChartSeries<double>> BarSeries = new List<ChartSeries<double>>();
    string[] BarLabels;
    BarChartOptions _barOptions = new BarChartOptions();

    public List<ChartSeries<double>> LineSeries = new List<ChartSeries<double>>();
    string[] Linelabels;
    LineChartOptions _lineOptions = new LineChartOptions();

    string ConsignmentTitle = "";
    string FreightMonth = "";

    string[] TruckLabels;
    double[] TruckData;
    int SelectedTruckChartIndex;

    string[] DriverLabels;
    double[] DriverData;
    int SelectedDriverChartIndex;

    string[] NoDriverLabels;
    double[] NoDriverData;
    double noDriverPercent;
    DonutChartOptions _noDriverChartOptions = new DonutChartOptions();

    private int BranchID;
    Dictionary<string, decimal> dict = new Dictionary<string, decimal>();
    DateTime? FromDate = null;
    DateTime? ToDate = null;
    DateTime? CurrentDateTime = DateTime.Now;
    int SelectedPeriod = 1;

    private TruckStatusModel truckStatusModel = new TruckStatusModel();

    List<DashboardModel> TruckStatusData = new List<DashboardModel>();
    List<DashboardModel> ConsignmentLoadData = new List<DashboardModel>();
    List<DashboardModel> DriverStatusData = new List<DashboardModel>();
    List<DashboardModel> FreightStatusData = new List<DashboardModel>();

    protected override async Task OnInitializedAsync()
    {
        _isLoading = true;
        var authprov = await auth.GetAuthenticationStateAsync();
        var User = authprov.User;
        string BranchIDString = User.Claims.First(x => x.Type == "BranchID").Value;
        BranchID = int.Parse(BranchIDString);
        await Refresh();
        _isLoading = false;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {

    }

    async Task Refresh()
    {
        _isLoading = true;
        StateHasChanged();
        await Task.Yield();
        CurrentDateTime = DateTime.Now;
        dict = DashboardService.Collection(BranchID);
        await SelectedValueChanged(1);
        await TruckStatus();
        await DriverStatus();
        //await FreightStatus();
        await DriverAssignStatusChart();
    }

    async Task ConsignmentLoad(DateTime? From, DateTime? To)
    {
        ConsignmentLoadData = DashboardService.SelectChartData(BranchID, From, To).ToList();
        var BarData = ConsignmentLoadData.Select(x => (double)x.Total.Value).ToArray();

        BarSeries.Clear();
        BarLabels = ConsignmentLoadData.Select(x => x.DateList.Value.ToString("dd")).ToArray();
        BarSeries.Add(new ChartSeries<double>() { Name = "Tonnage", Data = BarData });

        if (BarData.Length > 0)
        {
            // Calculate width based on number of items 
            // Reduced width to avoid overlapping with Y-axis labels - drastic reduction as per user feedback
            if (BarData.Length <= 10) BarChartStrokeWidth = "15px";
            else if (BarData.Length <= 20) BarChartStrokeWidth = "12px";
             else if (BarData.Length <= 31) BarChartStrokeWidth = "8px";
            else BarChartStrokeWidth = "4px";
        }

        _barOptions.YAxisTicks = GetSeriesValue((int)BarData.Max()) / 10;
        _barOptions.ShowLegend = false;
    }


    async Task DriverAssignStatusChart()
    {
        double DriverAssigned = TruckData.Sum() - (double)dict["NodriverTrucks"];
        NoDriverLabels = new string[]{ "Driver Assigned", "No Driver" };
        NoDriverData = new double[] { DriverAssigned, (double)dict["NodriverTrucks"] };
        noDriverPercent = ((double)dict["NodriverTrucks"]) / TruckData.Sum();
        _noDriverChartOptions.ChartPalette = new string[] { "#00c864", "#FF0000" };
    }

    async Task TruckStatus()
    {
        TruckStatusData = DashboardService.SelectTruckDonutData(BranchID).ToList();
        TruckLabels = TruckStatusData.Select(x => x.Label + " - " + x.Data).ToArray();
        TruckData = TruckStatusData.Select(x => (double)x.Data).ToArray();
    }

    async Task SelectedTruckChartIndexChanged(int index)
    {
        SelectedTruckChartIndex = index;
        var val = TruckLabels[index];
        await HandleSelectedData(val);
    }

    [JSInvokable]
    public async Task HandleSelectedData(string selectedValue)
    {
        string result = selectedValue;
        string extractedNumber = result.Substring(result.LastIndexOf(" ") + 1);

        int lastSpaceIndex = selectedValue.LastIndexOf('-');
        if (lastSpaceIndex >= 0)
        {
            result = selectedValue.Substring(0, lastSpaceIndex);
        }

        DialogOptions MediumWidth = new DialogOptions() { MaxWidth = MaxWidth.Medium, FullWidth = true };
        DialogParameters parms = new DialogParameters();
        parms.Add("BranchId", BranchID);
        parms.Add("SelectedValue", result);
        parms.Add("Count", extractedNumber);
        var dialog = await DialogService.ShowAsync<TruckStatusView>("TruckStatusList", parms, MediumWidth);
    }

    public async Task DriverStatus()
    {
        DriverStatusData = DashboardService.SelectDriverDonutData(BranchID);
        DriverLabels = DriverStatusData.Select(x => x.Label + " : " + x.Data).ToArray();
        DriverData = DriverStatusData.Select(x => (double)x.Data).ToArray();
        //var objRef = DotNetObjectReference.Create(this);
        //await JSRuntime.InvokeVoidAsync("ChartResult.DonutChartDriver", DonutLabels, DonutData, objRef);
    }

    async Task SelectedDriverChartIndexChanged(int index)
    {
        SelectedDriverChartIndex = index;
        var val = DriverLabels[index];
        await HandleSelectedDriverData(val);
    }

    [JSInvokable]
    public async Task HandleSelectedDriverData(string selectedValue)
    {
        string result = selectedValue;
        string extractedNumber = result.Substring(result.LastIndexOf(" ") + 1);
        int colonIndex = selectedValue.IndexOf(":");
        if (colonIndex >= 0)
        {
            result = selectedValue.Substring(0, colonIndex).Trim();
        }
        else
        {
            int lastSpaceIndex = selectedValue.LastIndexOf(':');
            if (lastSpaceIndex >= 0)
            {
                result = selectedValue.Substring(0, lastSpaceIndex);
            }
        }

        DialogOptions mediumWidth = new DialogOptions() { MaxWidth = MaxWidth.Small, FullWidth = true };
        DialogParameters parms = new DialogParameters();
        parms.Add("BranchId", BranchID);
        parms.Add("SelectedValue", result);
        parms.Add("Count", extractedNumber);
        var dialog = await DialogService.ShowAsync<DriverStatusView>("DriverStatusList", parms, mediumWidth);
    }

    public async Task FreightStatus()
    {
        DateTime today = DateTime.Today;
        FreightMonth = today.ToString("MMMM");
        FreightStatusData = DashboardService.SelectLineChart(BranchID, today).ToList();

        var TargetFreightSeries = FreightStatusData.Select(x => (double)x.CumulativeTarget / 100000).ToArray();
        var ActualFreightSeries = FreightStatusData.Select(x => (double)x.Total / 100000).ToArray();



        LineSeries.Add(new ChartSeries<double> { Name = "Target Freight", Data = TargetFreightSeries });
        LineSeries.Add(new ChartSeries<double> { Name = "Actual Freight", Data = ActualFreightSeries });
        Linelabels = FreightStatusData.Select(x => x.DateList.Value.ToString("dd")).ToArray();

        _lineOptions.YAxisFormat = "0.##L";
        _lineOptions.YAxisTicks = GetSeriesValue((int)TargetFreightSeries.Max()) / 10;
    }

    static int GetSeriesValue(int number)
    {
        if (number <= 5)
            return 5;

        int magnitude = (int)Math.Pow(10, Math.Floor(Math.Log10(number)));

        if (number <= magnitude)
            return magnitude;

        if (number <= magnitude * 5)
            return magnitude * 5;

        return magnitude * 10;
    }

    public async Task SelectedValueChanged(int val)
    {
        SelectedPeriod = val;
        DateTime? From = null, To = null;
        DateTime today = DateTime.Today;
        switch (val)
        {
            case 1:
                From = DateTime.Today.AddDays(-9);
                To = DateTime.Today;
                ConsignmentTitle = "Last 10 Days";
                break;
            case 2:
                DateTime firstDayOfMonth = new DateTime(today.Year, today.Month, 1);
                From = firstDayOfMonth;
                To = today;
                ConsignmentTitle = "Current Month";
                break;
            case 3:
                DateTime firstDayOfLastMonth = new DateTime(today.Year, today.Month, 1).AddMonths(-1);
                DateTime lastDayOfLastMonth = firstDayOfLastMonth.AddMonths(1).AddDays(-1);
                From = firstDayOfLastMonth;
                To = lastDayOfLastMonth;
                ConsignmentTitle = "Last Month";
                break;
        }
        await ConsignmentLoad(From, To);



    }
}
