@code {

    string[] PieLabels;
    double[] PieData;
    string[] BarLabels;
    string[] BarData;
    private int BranchID;

    List<TruckStatusModel> TruckStatusData = new List<TruckStatusModel>();
    List<GcModel> ConsignmentLoadData = new List<GcModel>();

    protected override async Task OnInitializedAsync()
    {
        var authprov = await auth.GetAuthenticationStateAsync();
        var User = authprov.User;

        string BranchIDString = User.Claims.First(x => x.Type == "BranchID").Value;
        BranchID = int.Parse(BranchIDString);

        TruckStatusData = TruckService.GetTruckStatus(BranchID).ToList();
        ConsignmentLoadData = GcService.SelectChartData(BranchID).ToList();

        PieLabels = TruckStatusData.Select(x => x.StatusText + " " + x.LoadStatus).ToArray();
        PieData = TruckStatusData.Select(x => (double)x.NoOfTrucks).ToArray();

        BarLabels = ConsignmentLoadData.Select(x => x.BillDate.Value.ToString("dd MMM yyyy")).ToArray();
        BarData = ConsignmentLoadData.Select(x => (x.TotalBillQuantity.Value.ToString())).ToArray();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JSRuntime.InvokeVoidAsync("ChartResult.PieChart", PieLabels, PieData);
            await JSRuntime.InvokeVoidAsync("ChartResult.BarGraph", BarLabels, BarData);
            StateHasChanged();
        }
    }
}