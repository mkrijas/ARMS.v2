@page "/dashboard"
@inject AuthenticationStateProvider auth
@inject ITruckService truckService

<MudPaper Class="pa-4">
    <MudChart ChartType="ChartType.Pie" InputData="@data" @bind-SelectedIndex="Indexed" InputLabels="@labels" ChartOptions="@ops" Width="300px" Height="300px" />
</MudPaper>
<MudText Typo="Typo.h6">Selected portion of the chart: @Indexed</MudText>

@code {

    string[] labels;
    double[] data;
    string[] xLabels;
    ChartOptions ops = new ChartOptions();
    List<TruckStatusModel> Status = new List<TruckStatusModel>();

    protected override async Task OnInitializedAsync()
    {
        var authprov = await auth.GetAuthenticationStateAsync();
        var User = authprov.User;
        if (int.TryParse(User.Claims.First(x => x.Type == "BranchID").Value, out int BranchID))
        {
            Status = truckService.GetTruckStatus(BranchID).ToList();
        }
        labels = Status.Select(x => x.StatusText + " " + x.LoadStatus).ToArray();
        data = Status.Select(x => (double)x.NoOfTrucks).ToArray();
        // ops.ChartPalette = Status.Select(x => x.NoOfTrucks.ToString()).ToArray();
    }

    private int Indexed = -1;
    //default value cannot be 0 -> first selectedindex is 0.
    //Random random = new Random();
}