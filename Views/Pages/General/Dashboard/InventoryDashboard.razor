@page "/inventorydashboard"
@using ArmsModels.BaseModels
@using ArmsServices.DataServices
@inject IInventoryGrnService GrnService
@inject IStoreService StoreService
@inject NavigationManager NavManager
@inject AuthenticationStateProvider auth

@if (_isLoading)
{
    <div @key="@("loader")" style="display: flex; justify-content: center; align-items: center; min-height: 500px;">
        <LoaderComponent IsFullScreen="true" 
                        ShowLogo="false" 
                        Size="large" 
                        LoadingText="Loading Inventory Dashboard" 
                        SubText="Fetching inventory data..." />
    </div>
}
else
{
<MudContainer @key="@("content")" MaxWidth="MaxWidth.False" Class="mt-4">
    <MudText Typo="Typo.h5" Class="mb-4" Style="font-weight: 700; color: #5E5873;">Inventory Overview</MudText>

    <!-- 1. Summary Cards -->
    <MudGrid Class="mb-4">
        <!-- Pending GRNs -->
        <MudItem xs="12" sm="6" md="3">
             <MudPaper Class="pa-4 d-flex flex-column gap-2" Elevation="2" Style="border-radius: 12px; background: linear-gradient(135deg, #ffffff 0%, #f8f9fa 100%);">
                 <div class="d-flex justify-space-between align-start">
                     <MudText Typo="Typo.subtitle2" Style="color: #667085;">Pending GRNs</MudText>
                     <MudIcon Icon="@Icons.Material.Filled.AssignmentReturn" Color="Color.Warning" Size="Size.Small" />
                 </div>
                 <MudText Typo="Typo.h4" Style="font-weight: 700; color: #FF9F43;">@PendingGrnCount</MudText>
                 <MudText Typo="Typo.caption" Style="color: #667085;">Awaiting Approval</MudText>
            </MudPaper>
        </MudItem>

        <!-- Active Stores -->
        <MudItem xs="12" sm="6" md="3">
             <MudPaper Class="pa-4 d-flex flex-column gap-2" Elevation="2" Style="border-radius: 12px; background: linear-gradient(135deg, #ffffff 0%, #f8f9fa 100%);">
                 <div class="d-flex justify-space-between align-start">
                     <MudText Typo="Typo.subtitle2" Style="color: #667085;">Active Stores</MudText>
                     <MudIcon Icon="@Icons.Material.Filled.Store" Color="Color.Primary" Size="Size.Small" />
                 </div>
                 <MudText Typo="Typo.h4" Style="font-weight: 700; color: #7367F0;">@ActiveStoresCount</MudText>
                 <MudText Typo="Typo.caption" Style="color: #667085;">Warehouses</MudText>
            </MudPaper>
        </MudItem>

         <!-- Recent GRN Value -->
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Class="pa-4 d-flex flex-column gap-2" Elevation="2" Style="border-radius: 12px; background: linear-gradient(135deg, #ffffff 0%, #f8f9fa 100%);">
                 <div class="d-flex justify-space-between align-start">
                     <MudText Typo="Typo.subtitle2" Style="color: #667085;">Recent GRN Value</MudText>
                     <MudIcon Icon="@Icons.Material.Filled.AttachMoney" Color="Color.Success" Size="Size.Small" />
                 </div>
                 <MudText Typo="Typo.h4" Style="font-weight: 700; color: #28C76F;">@RecentGrnValue.ToString("C0")</MudText>
                 <MudText Typo="Typo.caption" Style="color: #667085;">Latest Inflow (Pending)</MudText>
            </MudPaper>
        </MudItem>
        
        <!-- Placeholder for Low Stock -->
         <MudItem xs="12" sm="6" md="3">
            <MudPaper Class="pa-4 d-flex flex-column gap-2" Elevation="2" Style="border-radius: 12px; background: linear-gradient(135deg, #ffffff 0%, #f8f9fa 100%);">
                 <div class="d-flex justify-space-between align-start">
                     <MudText Typo="Typo.subtitle2" Style="color: #667085;">Invoices to Process</MudText>
                     <MudIcon Icon="@Icons.Material.Filled.Receipt" Color="Color.Info" Size="Size.Small" />
                 </div>
                 <MudText Typo="Typo.h4" Style="font-weight: 700; color: #00CFDD;">@PendingInvoiceCount</MudText>
                 <MudText Typo="Typo.caption" Style="color: #667085;">GRNs Ready for Invoice</MudText>
            </MudPaper>
        </MudItem>

    </MudGrid>

    <MudGrid>
        <!-- Recent GRNs Table -->
        <MudItem xs="12" md="8">
            <MudPaper Class="pa-4" Elevation="2" Style="height: 100%; border-radius: 12px;">
                <div class="d-flex justify-space-between align-center mb-4">
                     <MudText Typo="Typo.h6" Style="font-weight: 600; color: #5E5873;">Recent GRNs</MudText>
                     <MudButton Variant="Variant.Text" Color="Color.Primary" OnClick="@(() => NavManager.NavigateTo("/InventoryGrn"))">View All</MudButton>
                </div>
                
                <MudTable Items="@RecentGrns" Hover="true" Breakpoint="Breakpoint.None" Dense="true" Elevation="0">
                    <HeaderContent>
                        <MudTh>GRN #</MudTh>
                        <MudTh>Date</MudTh>
                        <MudTh>Vendor</MudTh>
                        <MudTh>Store</MudTh>
                        <MudTh Style="text-align:right">Value</MudTh>
                        <MudTh>Status</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="GRN">@context.GrnNo</MudTd>
                        <MudTd DataLabel="Date">@context.EntryDate?.ToString("dd MMM yyyy")</MudTd>
                        <MudTd DataLabel="Vendor">@context.PartyName</MudTd>
                        <MudTd DataLabel="Store">@context.Store?.StoreName</MudTd>
                        <MudTd DataLabel="Value" Style="text-align:right">@context.TotalValue?.ToString("N2")</MudTd>
                        <MudTd DataLabel="Status">
                            @if(context.AuthStatus == "Approved")
                            {
                                <MudChip T="string" Size="Size.Small" Color="Color.Success">Approved</MudChip>
                            }
                            else
                            {
                                <MudChip T="string" Size="Size.Small" Color="Color.Warning">Pending</MudChip>
                            }
                        </MudTd>
                    </RowTemplate>
                </MudTable>
            </MudPaper>
        </MudItem>

        <!-- GRN by Store Chart -->
        <MudItem xs="12" md="4">
            <MudPaper Class="pa-4" Elevation="2" Style="height: 100%; border-radius: 12px;">
                <MudText Typo="Typo.h6" Class="mb-4" Style="font-weight: 600; color: #5E5873;">Incoming by Store</MudText>
                 @if (ChartData.Sum() > 0)
                {
                     <MudChart ChartType="ChartType.Donut" InputData="@ChartData" InputLabels="@ChartLabels" Width="100%" Height="300px" />
                }
                else
                {
                     <div class="d-flex justify-center align-center" style="height: 300px;">
                        <MudText Typo="Typo.body2" Color="Color.Secondary">No Data Available</MudText>
                     </div>
                }
            </MudPaper>
        </MudItem>
    </MudGrid>
</MudContainer>
}

@code {
    private bool _isLoading = true;
    private DateTime _loadStartTime;
    private int BranchID;
    
    // Metrics
    private int PendingGrnCount = 0;
    private int ActiveStoresCount = 0;
    private decimal RecentGrnValue = 0;
    private int PendingInvoiceCount = 0;

    // Data
    private List<InventoryGrnModel> RecentGrns = new();

    // Chart
    public double[] ChartData = { };
    public string[] ChartLabels = { };

    protected override async Task OnInitializedAsync()
    {
        _loadStartTime = DateTime.Now;
        await LoadData();
        await EnsureMinimumLoadTime();
        _isLoading = false;
    }

    private async Task EnsureMinimumLoadTime()
    {
        var elapsed = (DateTime.Now - _loadStartTime).TotalMilliseconds;
        if (elapsed < 100)
        {
            await Task.Delay(100 - (int)elapsed);
        }
    }

    private async Task LoadData()
    {
        var authprov = await auth.GetAuthenticationStateAsync();
        var User = authprov.User;
        var claim = User.Claims.FirstOrDefault(x => x.Type == "BranchID");
        if (claim == null) return;
        string BranchIDString = claim.Value;
        BranchID = int.Parse(BranchIDString);

        // 1. Pending GRNs
        var pendingGrns = GrnService.SelectPending(BranchID).ToList();
        PendingGrnCount = pendingGrns.Count;
        RecentGrnValue = pendingGrns.Sum(x => x.TotalValue ?? 0);
        RecentGrns = pendingGrns.OrderByDescending(x => x.EntryDate).Take(5).ToList();

        // 2. Active Stores
        var stores = StoreService.SelectByBranch(BranchID).ToList();
        ActiveStoresCount = stores.Count;

        // 3. Pending Invoices
        var pendingInvoices = GrnService.PendingToInvoice(BranchID).ToList();
        PendingInvoiceCount = pendingInvoices.Count;

        // 4. Chart Data (Pending GRNs by Store)
        // Group by StoreName
        var grouped = pendingGrns
            .GroupBy(x => x.Store?.StoreName ?? "Unknown")
            .Select(g => new { Store = g.Key, Count = g.Count() })
            .ToList();
        
        ChartLabels = grouped.Select(x => x.Store).ToArray();
        ChartData = grouped.Select(x => (double)x.Count).ToArray();
    }
}
