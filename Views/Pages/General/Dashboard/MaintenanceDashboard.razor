@page "/maintenancedashboard"
@using ArmsModels.BaseModels
@using ArmsServices.DataServices
@inject IDashboardService DashboardService
@inject ITruckService TruckService
@inject IJobcardService JobcardService
@inject IBreakdownService BreakdownService
@inject NavigationManager NavManager
@inject AuthenticationStateProvider auth

@if (_isLoading)
{
    <div @key="@("loader")" style="display: flex; justify-content: center; align-items: center; min-height: 500px;">
        <LoaderComponent IsFullScreen="true" 
                        ShowLogo="false" Size="large" 
                        LoadingText="Loading Maintenance Dashboard" 
                        SubText="Fetching maintenance data..." />
    </div>
}
else
{
<div class="admin-page-container fade-in">
    <div class="admin-header-tiered mb-6">
        <MudText Typo="Typo.h4" Class="admin-title">Maintenance Overview</MudText>
        <div class="title-accent"></div>
    </div>

    <!-- 1. Summary Cards -->
    <MudGrid Class="mb-4">
        <!-- Total Vehicles -->
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Class="premium-card pa-5 d-flex flex-column gap-3">
                 <div class="d-flex justify-space-between align-center">
                     <div class="icon-badge primary-badge">
                        <MudIcon Icon="@Icons.Material.Filled.DirectionsCar" />
                     </div>
                     <MudText Typo="Typo.caption" Class="label-caps">Total Vehicles</MudText>
                 </div>
                 <div>
                    <MudText Typo="Typo.h4" Class="admin-title">@TotalVehicles</MudText>
                    <MudText Typo="Typo.caption" Class="admin-subtitle">Fleet Size</MudText>
                 </div>
            </MudPaper>
        </MudItem>

        <!-- Active Vehicles -->
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Class="premium-card pa-5 d-flex flex-column gap-3">
                 <div class="d-flex justify-space-between align-center">
                     <div class="icon-badge bg-success-light" style="color: #28C76F;">
                        <MudIcon Icon="@Icons.Material.Filled.CheckCircle" />
                     </div>
                     <MudText Typo="Typo.caption" Class="label-caps">Active / On Road</MudText>
                 </div>
                 <div>
                    <MudText Typo="Typo.h4" Class="admin-title" Style="color: #28C76F;">@ActiveVehicles</MudText>
                    <MudText Typo="Typo.caption" Class="admin-subtitle">Available for Ops</MudText>
                 </div>
            </MudPaper>
        </MudItem>

        <!-- In Maintenance -->
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Class="premium-card pa-5 d-flex flex-column gap-3">
                 <div class="d-flex justify-space-between align-center">
                     <div class="icon-badge bg-warning-light" style="color: #FF9F43;">
                        <MudIcon Icon="@Icons.Material.Filled.Build" />
                     </div>
                     <MudText Typo="Typo.caption" Class="label-caps">In Workshop</MudText>
                 </div>
                 <div>
                    <MudText Typo="Typo.h4" Class="admin-title" Style="color: #FF9F43;">@InMaintenance</MudText>
                    <MudText Typo="Typo.caption" Class="admin-subtitle">Open Job Cards</MudText>
                 </div>
            </MudPaper>
        </MudItem>

         <!-- Breakdown -->
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Class="premium-card pa-5 d-flex flex-column gap-3">
                 <div class="d-flex justify-space-between align-center">
                     <div class="icon-badge bg-error-light" style="color: #EA5455;">
                        <MudIcon Icon="@Icons.Material.Filled.ReportProblem" />
                     </div>
                     <MudText Typo="Typo.caption" Class="label-caps">Work Orders</MudText>
                 </div>
                 <div>
                    <MudText Typo="Typo.h4" Class="admin-title" Style="color: #EA5455;">@Breakdowns</MudText>
                    <MudText Typo="Typo.caption" Class="admin-subtitle">Pending Repairs</MudText>
                 </div>
            </MudPaper>
        </MudItem>
    </MudGrid>

    <MudGrid>
        <!-- Secondary Metrics Row -->
         <MudItem xs="12" md="4">
            <MudPaper Class="premium-card pa-4 mb-4">
                <MudText Typo="Typo.caption" Class="label-caps">Maint. Cost (This Month)</MudText>
                <MudText Typo="Typo.h5" Class="admin-title" Style="color: var(--mud-palette-primary);">@MaintenanceCost.ToString("C0")</MudText>
            </MudPaper>
         </MudItem>
          <MudItem xs="12" md="4">
            <MudPaper Class="premium-card pa-4 mb-4">
                <MudText Typo="Typo.caption" Class="label-caps">Avg Downtime (Last 30 Days)</MudText>
                <MudText Typo="Typo.h5" Class="admin-title" Style="color: #FF9F43;">@AvgDowntime hrs</MudText>
            </MudPaper>
         </MudItem>
          <MudItem xs="12" md="4">
            <MudPaper Class="premium-card pa-4 mb-4">
                <MudText Typo="Typo.caption" Class="label-caps">Work Order Rate</MudText>
                <MudText Typo="Typo.h5" Class="admin-title" Style="color: #EA5455;">@BreakdownRate %</MudText>
            </MudPaper>
         </MudItem>


        <!-- Breakdown Reasons Chart -->
        <MudItem xs="12" md="4">
            <MudPaper Class="premium-card pa-5" Style="height: 100%;">
                <MudText Typo="Typo.h6" Class="admin-title mb-6">Work Order Reasons</MudText>
                @if (ReasonData.Sum() > 0)
                {
                     <MudChart T="double" ChartType="ChartType.Donut" ChartSeries="@ReasonSeries" ChartLabels="@ReasonLabels" Width="100%" Height="300px" />
                }
                else
                {
                     <div class="d-flex justify-center align-center" style="height: 300px;">
                        <MudText Typo="Typo.body2" Class="admin-subtitle">No Work Order Data</MudText>
                     </div>
                }
            </MudPaper>
        </MudItem>

        <!-- Live Workshop Table -->
        <MudItem xs="12" md="8">
            <MudPaper Class="premium-card pa-5" Style="height: 100%;">
                <div class="d-flex justify-space-between align-center mb-6">
                     <MudText Typo="Typo.h6" Class="admin-title">Live Workshop Status</MudText>
                     <MudButton Variant="Variant.Text" Color="Color.Primary" OnClick="@(() => NavManager.NavigateTo("/JobCardView"))" Class="action-btn-primary">View All</MudButton>
                </div>
                
                <MudTable Items="@ActiveJobCards" Hover="true" Breakpoint="Breakpoint.None" Dense="true" Elevation="0" Class="modern-admin-table">
                    <HeaderContent>
                        <MudTh>JobCard #</MudTh>
                        <MudTh>Vehicle</MudTh>
                        <MudTh>Entry Date</MudTh>
                        <MudTh>Status</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="Code" Class="admin-td-primary">@context.JobcardNumber</MudTd>
                        <MudTd DataLabel="Vehicle" Class="admin-td-secondary">@context.RegNo</MudTd>
                        <MudTd DataLabel="Date" Class="admin-td-secondary">@context.CreatedOn?.ToString("dd MMM yyyy")</MudTd>
                        <MudTd DataLabel="Status">
                             <MudChip T="string" Size="Size.Small" Class="admin-chip-pending">In Progress</MudChip>
                        </MudTd>
                    </RowTemplate>
                </MudTable>
            </MudPaper>
        </MudItem>

        <!-- Recent Breakdowns Table -->
         <MudItem xs="12">
            <MudPaper Class="premium-card pa-5">
                 <MudText Typo="Typo.h6" Class="admin-title mb-6">Recent Work Orders</MudText>
                 <MudTable Items="@RecentBreakdowns" Hover="true" Breakpoint="Breakpoint.None" Dense="true" Elevation="0" Class="modern-admin-table">
                    <HeaderContent>
                        <MudTh>Date</MudTh>
                        <MudTh>Vehicle</MudTh>
                        <MudTh>Type</MudTh>
                        <MudTh>Details</MudTh>
                         <MudTh>Status</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="Date" Class="admin-td-secondary">@context.BreakdownTime?.ToString("dd MMM yyyy HH:mm")</MudTd>
                        <MudTd DataLabel="Vehicle" Class="admin-td-primary">@context.RegNo</MudTd>
                        <MudTd DataLabel="Type" Class="admin-td-secondary">@context.BreakdownType</MudTd>
                        <MudTd DataLabel="Details" Class="admin-td-secondary">@context.Detail</MudTd>
                        <MudTd DataLabel="Status">
                            <MudChip T="string" Size="Size.Small" Class="admin-chip-rejected">Reported</MudChip>
                        </MudTd>
                    </RowTemplate>
                </MudTable>
            </MudPaper>
         </MudItem>

    </MudGrid>
</div>
}

@code {
    private bool _isLoading = true;
    private DateTime _loadStartTime;
    private int BranchID;

    // Metrics
    private int TotalVehicles = 0;
    private int ActiveVehicles = 0;
    private int InMaintenance = 0;
    private int Breakdowns = 0;

    private decimal MaintenanceCost = 0;
    private double AvgDowntime = 0;
    private double BreakdownRate = 0;

    // Collections
    private List<JobcardModel> ActiveJobCards = new();
    private List<BreakdownModel> RecentBreakdowns = new();

    // Charts
    public double[] ReasonData = { };
    public string[] ReasonLabels = { };
    public List<ChartSeries<double>> ReasonSeries = new();

    private Dictionary<string, decimal> dict = new();

    protected override async Task OnInitializedAsync()
    {
        _loadStartTime = DateTime.Now;
        await LoadData();
        await EnsureMinimumLoadTime();
        _isLoading = false;
    }

    private async Task EnsureMinimumLoadTime()
    {
        var elapsed = (DateTime.Now - _loadStartTime).TotalMilliseconds;
        if (elapsed < 100)
        {
            await Task.Delay(100 - (int)elapsed);
        }
    }

    private async Task LoadData()
    {
         var authprov = await auth.GetAuthenticationStateAsync();
        var User = authprov.User;
        var claim = User.Claims.FirstOrDefault(x => x.Type == "BranchID");
        if (claim == null) return;
        string BranchIDString = claim.Value;
        BranchID = int.Parse(BranchIDString);

        dict = DashboardService.MaintenanceCollection(BranchID);

        // 1. Total Fleet
        var allTrucks = TruckService.SelectAllByBranch(true, BranchID, "AvailableForBranch", "Operation").ToList();
        TotalVehicles = allTrucks.Count;

        // 2. In Maintenance (Active Job Cards)
        // Assuming SelectByBranch with true gets active/open job cards
        var activeJobs = JobcardService.SelectByBranch(BranchID, true).ToList();
        InMaintenance = activeJobs.Count;
        ActiveJobCards = activeJobs.OrderByDescending(x => x.CreatedOn).Take(5).ToList();

        // 3. Breakdowns (Pending Breakdown)
        var pendingBreakdowns = BreakdownService.SelectPending(BranchID).ToList();
        Breakdowns = pendingBreakdowns.Count;
        RecentBreakdowns = pendingBreakdowns.OrderByDescending(x => x.BreakdownTime).Take(5).ToList();

        // 4. Active Vehicles
        // Basic calculation: Total - (InMaint + Breakdowns)
        // A vehicle could theoretically be in both if data is messy, but we'll assume exclusive for now or overlap is acceptable.
        // Or we could check unique truck IDs.
        var outOfServiceTruckIds = activeJobs.Select(x => x.TruckID).Union(pendingBreakdowns.Select(x => x.TruckID)).Distinct().ToList();
        ActiveVehicles = TotalVehicles - outOfServiceTruckIds.Count();
        if (ActiveVehicles < 0) ActiveVehicles = 0;


        // 5. Breakdown Reasons Chart
        var groupedReasons = pendingBreakdowns
            .GroupBy(x => x.BreakdownType ?? "Unknown")
            .Select(g => new { Reason = g.Key, Count = g.Count() })
            .ToList();
        
        ReasonLabels = groupedReasons.Select(x => x.Reason).ToArray();
        ReasonData = groupedReasons.Select(x => (double)x.Count).ToArray();
        ReasonSeries = new List<ChartSeries<double>> { new ChartSeries<double> { Name = "Reasons", Data = ReasonData } };

        // 6. Advanced Metrics (Mock logic / Basic estimation as Services for these specific aggregations might not exist yet)
        
        // Maintenance Cost (This Month) - Need to fetch closed jobcards for cost? 
        // JobCard Active=false implies history.
        // Note: This might be heavy if getting ALL history. 
        // For now, let's just set placeholder or try a limited fetch if possible.
        // Since we don't have a specific "GetExpenseByMonth" service, we might skip heavy calc or just show 0 for now until specifically implemented.
        MaintenanceCost = dict["CostOfMaintenance"]; // Placeholder

        // Avg Downtime
        AvgDowntime = (double)dict["AvgDownTime"]; // Placeholder

        // Breakdown Rate
        if (TotalVehicles > 0)
        {
            BreakdownRate = Math.Round(((double)Breakdowns / TotalVehicles) * 100, 1);
        }
    }
}
