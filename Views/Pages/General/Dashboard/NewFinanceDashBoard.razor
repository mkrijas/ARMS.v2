@page "/newfinancedashboard"
@attribute [Authorize]
@inject AuthenticationStateProvider auth
@inject IConfigTable config
@inject IFinanceDashboardService Iservice
@inject ISaleService SaleService
@inject IBankAccountOwnService Ibankservice
@inject IJSRuntime JSRuntime
@using System
@using Pages.General.Dashboard
@using MudBlazor
@using MudBlazor.Components
@using ArmsModels.BaseModels.Finance.Transactions

<style>
    .finance-dashboard {
        padding: 0px;
        background-color: transparent;
    }

    .dashboard-container {
        padding: 24px;
        max-width: 1600px;
        margin: 0 auto;
    }

    .stat-card {
        transition: transform 0.3s ease, box-shadow 0.3s ease;
        border-radius: 12px;
        overflow: hidden;
        position: relative;
        height: 100%;
    }

        .stat-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 20px rgba(0,0,0,0.1) !important;
        }

    .stat-icon-circle {
        width: 48px;
        height: 48px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-right: 16px;
    }

    .chart-card {
        border-radius: 12px;
        height: 100%;
        min-height: 400px;
    }

    .table-container {
        border-radius: 12px;
        overflow: hidden;
    }

    .section-title {
        font-family: 'Inter', sans-serif;
        font-weight: 700;
        color: #344054;
        margin-bottom: 16px;
        letter-spacing: -0.02em;
    }

    .trend-indicator-up {
        color: #10B981;
        font-size: 0.85rem;
        display: flex;
        align-items: center;
        gap: 2px;
    }

    .trend-indicator-down {
        color: #F04438;
        font-size: 0.85rem;
        display: flex;
        align-items: center;
        gap: 2px;
    }
</style>

<div class="dashboard-container">
    <!-- Header -->
    <div class="d-flex justify-space-between align-center mb-6">
        <div>
            <MudText Typo="Typo.h4" Style="font-weight: 800; color: #101828;">Finance Overview</MudText>
            <MudText Typo="Typo.body1" Style="color: #667085;">Track your financial health, identifying trends and opportunities.</MudText>
        </div>
        <div class="d-flex gap-2">
            <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.Refresh" Color="Color.Primary" Class="rounded-lg" OnClick="RefreshData">Refresh</MudButton>
            <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.Download" Color="Color.Secondary" Class="rounded-lg">Export Report</MudButton>
        </div>
    </div>

    <!-- 1. Pro Metrics Row (Revenue & Profit) -->
    <MudGrid Class="mb-6">
        <!-- Revenue Card -->
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Class="pa-4 stat-card" Elevation="2">
                <div class="d-flex flex-column gap-1">
                    <div class="d-flex justify-space-between align-start">
                        <MudText Typo="Typo.subtitle2" Style="color: #667085;">Total Revenue (MTD)</MudText>
                        <MudIcon Icon="@Icons.Material.Filled.ShowChart" Color="Color.Success" Size="Size.Small" />
                    </div>
                    <MudText Typo="Typo.h4" Style="font-weight: 700;">@RevenueMTD.ToString("C0")</MudText>
                    <div class="d-flex align-center gap-2 mt-2">
                        <MudChip T="string" Size="Size.Small" Color="Color.Success" Variant="Variant.Text" Icon="@Icons.Material.Filled.CalendarToday">Today: @RevenueToday.ToString("C0")</MudChip>
                    </div>
                    <MudText Typo="Typo.caption" Style="color: #98A2B3;">YTD: @RevenueYTD.ToString("C0")</MudText>
                </div>
            </MudPaper>
        </MudItem>

        <!-- Net Profit Card -->
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Class="pa-4 stat-card" Elevation="2">
                <div class="d-flex flex-column gap-1">
                    <div class="d-flex justify-space-between align-start">
                        <MudText Typo="Typo.subtitle2" Style="color: #667085;">Net Profit (MTD)</MudText>
                        <MudIcon Icon="@Icons.Material.Filled.PieChart" Color="Color.Primary" Size="Size.Small" />
                    </div>
                    <MudText Typo="Typo.h4" Style="font-weight: 700; color: #101828;">@NetProfitMTD.ToString("C0")</MudText>
                    <div class="d-flex align-center mt-2">
                        @if (ProfitMargin >= 0)
                        {
                            <span class="trend-indicator-up"><MudIcon Icon="@Icons.Material.Filled.ArrowUpward" Size="Size.Small" /> @ProfitMargin.ToString("F1")% Margin</span>
                        }
                        else
                        {
                            <span class="trend-indicator-down"><MudIcon Icon="@Icons.Material.Filled.ArrowDownward" Size="Size.Small" /> @ProfitMargin.ToString("F1")% Margin</span>
                        }
                        <MudText Typo="Typo.caption" Class="ml-2" Style="color: #98A2B3;">vs Exp</MudText>
                    </div>
                    <MudText Typo="Typo.caption" Style="color: #98A2B3;">Based on MTD Revenue & Expenses</MudText>
                </div>
            </MudPaper>
        </MudItem>

        <!-- Total Expenses Card -->
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Class="pa-4 stat-card" Elevation="2">
                <div class="d-flex flex-column gap-1">
                    <div class="d-flex justify-space-between align-start">
                        <MudText Typo="Typo.subtitle2" Style="color: #667085;">Total Expenses (MTD)</MudText>
                        <MudIcon Icon="@Icons.Material.Filled.MoneyOff" Color="Color.Error" Size="Size.Small" />
                    </div>
                    <MudText Typo="Typo.h4" Style="font-weight: 700;">@TotalExpenseMTD.ToString("C0")</MudText>
                    <div class="d-flex align-center mt-2">
                        <span class="trend-indicator-down"><MudIcon Icon="@Icons.Material.Filled.TrendingUp" Size="Size.Small" /> Outflow</span>
                        <MudText Typo="Typo.caption" Class="ml-2" Style="color: #98A2B3;">Operational Costs</MudText>
                    </div>
                </div>
            </MudPaper>
        </MudItem>

        <!-- Cash Position -->
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Class="pa-4 stat-card" Elevation="2">
                <div class="d-flex flex-column gap-1">
                    <div class="d-flex justify-space-between align-start">
                        <MudText Typo="Typo.subtitle2" Style="color: #667085;">Cash & Bank Position</MudText>
                        <MudIcon Icon="@Icons.Material.Filled.AccountBalanceWallet" Color="Color.Warning" Size="Size.Small" />
                    </div>
                    <MudText Typo="Typo.h4" Style="font-weight: 700;">@((TotalCashBalance + TotalBankBalance).ToString("C0"))</MudText>
                    <div class="d-flex align-center mt-2 gap-2">
                        <MudChip T="string" Size="Size.Small" Color="Color.Info" Variant="Variant.Outlined">Bank: @TotalBankBalance.ToString("0.0a")</MudChip>
                        <MudChip T="string" Size="Size.Small" Color="Color.Warning" Variant="Variant.Outlined">Cash: @TotalCashBalance.ToString("0.0a")</MudChip>
                    </div>
                </div>
            </MudPaper>
        </MudItem>

    </MudGrid>

    <!-- 2. Charts Row (Pro Visuals) -->
    <MudGrid Class="mb-6">
        <!-- Revenue vs Expense Trend -->
        <MudItem xs="12" md="8">
            <MudPaper Class="pa-6 chart-card" Elevation="2">
                <div class="d-flex justify-space-between align-center mb-4">
                    <div>
                        <MudText Typo="Typo.h6" Class="section-title mb-0">Revenue vs Expense Trend</MudText>
                        <MudText Typo="Typo.caption" Style="color: #667085;">Daily financial performance for @ExpenseMonth @ExpenseYear</MudText>
                    </div>
                    <div class="d-flex gap-2">
                        <div class="d-flex align-center gap-1"><MudIcon Icon="@Icons.Material.Filled.Circle" Size="Size.Small" Color="Color.Success" /> Revenue</div>
                        <div class="d-flex align-center gap-1"><MudIcon Icon="@Icons.Material.Filled.Circle" Size="Size.Small" Color="Color.Error" /> Expense</div>
                    </div>
                </div>

                <!-- Combined Line Chart -->
                <MudChart ChartType="ChartType.Line" ChartSeries="@RevExpSeries" XAxisLabels="@TrendLabels" Width="100%" Height="350px"></MudChart>
            </MudPaper>
        </MudItem>

        <!-- Liquidity / Profit Breakdown -->
        <MudItem xs="12" md="4">
            <MudGrid>
                <MudItem xs="12">
                    <MudPaper Class="pa-4" Elevation="2" Style="border-radius: 12px;">
                        <MudText Typo="Typo.subtitle1" Class="section-title">Liquidity Mix</MudText>
                        <div class="d-flex justify-center align-center" style="height: 200px;">
                            @if (LiquidityData.Sum() > 0)
                            {
                                <MudChart ChartType="ChartType.Donut" InputData="@LiquidityData" InputLabels="@LiquidityLabels" Width="100%" Height="100%" />
                            }
                            else
                            {
                                <MudText Typo="Typo.body2" Color="Color.Secondary">No Liquidity Data</MudText>
                            }
                        </div>
                    </MudPaper>
                </MudItem>
                <MudItem xs="12">
                    <!-- Profit Margin Gauge proxy using Progress Bar for now as Gauge isn't standard in older MudBlazor or easy to configure quickly -->
                    <MudPaper Class="pa-4" Elevation="2" Style="border-radius: 12px;">
                        <MudText Typo="Typo.subtitle1" Class="section-title">Profit Margin Health</MudText>
                        <MudText Typo="Typo.h3" Align="Align.Center" Color="@(ProfitMargin > 20 ? Color.Success : (ProfitMargin > 0 ? Color.Warning : Color.Error))" Style="font-weight: 800;">@ProfitMargin.ToString("F1")%</MudText>
                        <MudProgressLinear Color="@(ProfitMargin > 20 ? Color.Success : (ProfitMargin > 0 ? Color.Warning : Color.Error))" Value="@((double)ProfitMargin)" Max="100" Class="my-4" Size="Size.Large" Rounded="true" Striped="true" />
                        <MudText Typo="Typo.caption" Align="Align.Center" Style="display:block; color: #667085;">Target: >20% Margin</MudText>
                    </MudPaper>
                </MudItem>
            </MudGrid>
        </MudItem>
    </MudGrid>

    <!-- 3. Tables Row (Outstanding) -->
    <MudGrid>
        <!-- Payables List -->
        <MudItem xs="12" md="6">
            <MudPaper Class="table-container" Elevation="2">
                <MudToolBar Class="px-6 pt-4 pb-2" DisableGutters="true">
                    <div>
                        <MudText Typo="Typo.h6" Class="section-title mb-0">Outstanding Payables</MudText>
                        <MudText Typo="Typo.caption" Style="color: #667085;">Total Outstanding: @PayableAmount?.ToString("C0")</MudText>
                    </div>
                    <MudSpacer />
                    <MudButton Variant="Variant.Text" Color="Color.Primary" Size="Size.Small">View All</MudButton>
                </MudToolBar>
                <MudTable Items="@PayablesortedList.Take(5)" Hover="true" Breakpoint="Breakpoint.None" Dense="true" Elevation="0" Class="px-0">
                    <HeaderContent>
                        <MudTh Style="font-weight: 600; color: #667085;">Party Name</MudTh>
                        <MudTh Style="font-weight: 600; color: #667085; text-align: right;">Amount</MudTh>
                    </HeaderContent>
                    <RowTemplate Context="party">
                        <MudTd>
                            <div class="d-flex align-center">
                                <MudAvatar Size="Size.Small" Color="Color.Error" Variant="Variant.Outlined" Class="mr-2">@party.TradeName.Substring(0, 1)</MudAvatar>
                                <MudText Typo="Typo.body2" Style="font-weight: 500;">@party.TradeName</MudText>
                            </div>
                        </MudTd>
                        <MudTd Style="text-align: right;">
                            <MudText Typo="Typo.body2" Style="font-weight: 600; color: #F04438;">@party.TotalAmount?.ToString("C0")</MudText>
                        </MudTd>
                    </RowTemplate>
                </MudTable>
            </MudPaper>
        </MudItem>

        <!-- Receivables List -->
        <MudItem xs="12" md="6">
            <MudPaper Class="table-container" Elevation="2">
                <MudToolBar Class="px-6 pt-4 pb-2" DisableGutters="true">
                    <div>
                        <MudText Typo="Typo.h6" Class="section-title mb-0">Outstanding Receivables</MudText>
                        <MudText Typo="Typo.caption" Style="color: #667085;">Total Outstanding: @ReceivableAmount?.ToString("C0")</MudText>
                    </div>
                    <MudSpacer />
                    <MudButton Variant="Variant.Text" Color="Color.Primary" Size="Size.Small">View All</MudButton>
                </MudToolBar>
                <MudTable Items="@ReceivablesortedList.Take(5)" Hover="true" Breakpoint="Breakpoint.None" Dense="true" Elevation="0" Class="px-0">
                    <HeaderContent>
                        <MudTh Style="font-weight: 600; color: #667085;">Party Name</MudTh>
                        <MudTh Style="font-weight: 600; color: #667085; text-align: right;">Amount</MudTh>
                    </HeaderContent>
                    <RowTemplate Context="party">
                        <MudTd>
                            <div class="d-flex align-center">
                                <MudAvatar Size="Size.Small" Color="Color.Success" Variant="Variant.Outlined" Class="mr-2">@party.TradeName.Substring(0, 1)</MudAvatar>
                                <MudText Typo="Typo.body2" Style="font-weight: 500;">@party.TradeName</MudText>
                            </div>
                        </MudTd>
                        <MudTd Style="text-align: right;">
                            <MudText Typo="Typo.body2" Style="font-weight: 600; color: #10B981;">@party.TotalAmount?.ToString("C0")</MudText>
                        </MudTd>
                    </RowTemplate>
                </MudTable>
            </MudPaper>
        </MudItem>
    </MudGrid>
</div>


@code {

    private int BranchID;
    string ExpenseMonth = "";
    string ExpenseYear = "";

    // Pro Metrics
    private decimal RevenueToday = 0;
    private decimal RevenueMTD = 0;
    private decimal RevenueYTD = 0;
    private decimal TotalExpenseMTD = 0;
    private decimal NetProfitMTD = 0;
    private decimal ProfitMargin = 0;

    // Charts
    public List<ChartSeries> RevExpSeries = new List<ChartSeries>();
    public string[] TrendLabels = { };
    public double[] LiquidityData = { 0, 0 };
    public string[] LiquidityLabels = { "Bank", "Cash" };

    // Outstanding totals
    private Decimal? PayableAmount;
    private Decimal? ReceivableAmount;

    // Cash Positions
    private Decimal TotalBankBalance = 0;
    private Decimal TotalCashBalance = 0;

    public AccountBalanceModel PayableModel { get; set; } = new();
    public AccountBalanceModel RecievableModel { get; set; } = new();

    List<DueBalanceModel> PayableDuesList = new List<DueBalanceModel>();
    List<DueBalanceModel> PayablesortedList = new List<DueBalanceModel>();
    List<DueBalanceModel> ReceivableDuesList = new List<DueBalanceModel>();
    List<DueBalanceModel> ReceivablesortedList = new List<DueBalanceModel>();

    List<BankAccountBalanceModel> BankAccountBalanceList = new List<BankAccountBalanceModel>();
    List<CashAccountBalanceModel> CashAccountBalanceList = new List<CashAccountBalanceModel>();

    List<DashboardModel> ExpensesData = new List<DashboardModel>();

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task RefreshData()
    {
        await LoadData();
        StateHasChanged();
    }

    private async Task LoadData()
    {
        var authprov = await auth.GetAuthenticationStateAsync();
        var User = authprov.User;
        var claim = User.Claims.FirstOrDefault(x => x.Type == "BranchID");
        if (claim == null) return;
        string BranchIDString = claim.Value;
        BranchID = int.Parse(BranchIDString);

        // Parallel Loading
        var t1 = GetAccountBalance();
        var t2 = GetPayableDueBalance();
        var t3 = GetReceivableDueBalance();
        var t4 = GetBankAccountBalance();
        var t5 = GetCashAccountBalance();
        var t6 = GetExpensesAndRevenue();

        await Task.WhenAll(t1, t2, t3, t4, t5, t6);
    }

    public async Task GetAccountBalance()
    {
        ConfigModel cpModel = config.GetFinancePayableGroupID();
        PayableModel.CoaID = int.Parse(cpModel.ValueString);
        ConfigModel crModel = config.GetFinanceReceivableGroupID();
        RecievableModel.CoaID = int.Parse(crModel.ValueString);
        PayableModel = Iservice.GetAccountBalance(PayableModel.CoaID, BranchID, PayableModel.Date);
        PayableAmount = PayableModel.TotalAmount > 0 ? PayableModel.TotalAmount : 0;
        RecievableModel = Iservice.GetAccountBalance(RecievableModel.CoaID, BranchID, RecievableModel.Date);
        ReceivableAmount = RecievableModel.TotalAmount > 0 ? RecievableModel.TotalAmount : 0;
    }

    public async Task GetPayableDueBalance()
    {
        PayableDuesList = Iservice.GetPayableDueBalance(BranchID).ToList();
        PayablesortedList = PayableDuesList
            .GroupBy(item => new { item.PartyID, item.TradeName })
            .Select(group => new DueBalanceModel
            {
                PartyID = group.Key.PartyID.GetValueOrDefault(),
                TradeName = group.Key.TradeName,
                TotalAmount = group.Sum(item => item.Amount)
            })
            .OrderByDescending(item => item.TotalAmount)
            .ToList();
    }

    public async Task GetReceivableDueBalance()
    {
        ReceivableDuesList = Iservice.GetReceivableDueBalance(BranchID).ToList();
        ReceivablesortedList = ReceivableDuesList
            .GroupBy(item => new { item.PartyID, item.TradeName })
            .Select(group => new DueBalanceModel
            {
                PartyID = group.Key.PartyID.GetValueOrDefault(),
                TradeName = group.Key.TradeName,
                TotalAmount = group.Sum(item => item.Amount)
            })
            .OrderByDescending(item => item.TotalAmount)
            .ToList();
    }

    public async Task GetBankAccountBalance()
    {
        BankAccountBalanceList = Iservice.GetBankAccountBalance(BranchID).ToList();
        TotalBankBalance = BankAccountBalanceList.Sum(x => x.Amount ?? 0);
        UpdateLiquidityChart();
    }

    public async Task GetCashAccountBalance()
    {
        CashAccountBalanceList = Iservice.GetCashAccountBalance(BranchID).ToList();
        TotalCashBalance = CashAccountBalanceList.Sum(x => x.Amount ?? 0);
        UpdateLiquidityChart();
    }

    private void UpdateLiquidityChart()
    {
        LiquidityData = new double[] { (double)TotalBankBalance, (double)TotalCashBalance };
    }

    public async Task GetExpensesAndRevenue()
    {
        DateTime today = DateTime.Today;
        DateTime yesterday = today.AddDays(-1);
        ExpenseMonth = yesterday.ToString("MMMM");
        ExpenseYear = yesterday.ToString("yyyy");
        DateTime firstDayOfMonth = new DateTime(yesterday.Year, yesterday.Month, 1);
        DateTime firstDayOfYear = new DateTime(yesterday.Year, 1, 1);

        // 1. Fetch Expenses (MTD)
        var ExpRev = Iservice.SelectExpenses(BranchID);
        ExpensesData = ExpRev.Where(exp => exp.Label == "EXPENSES").ToList();

        TotalExpenseMTD = ExpensesData.Sum(x => x.Total ?? 0);

        // 2. Fetch Revenue (Sales) - Fetch Approved Sales and filter in memory
        // Using SelectByApproved as a fallback since SelectByPeriod has SQL parameter issues
        // var salesAll = SaleService.SelectByApproved(BranchID, 10000, "", "").ToList();
        // var salesYTD = salesAll.Where(x => x.DocumentDate >= firstDayOfYear && x.DocumentDate <= today).ToList();

        var RevenueData = ExpRev.Where(exp => exp.Label == "REVENUE").ToList();

        // 3. Calculate Metrics
        RevenueYTD = RevenueData.Sum(x => x.Total ?? 0);
        RevenueMTD = RevenueData.Where(x => x.DateList >= firstDayOfMonth).Sum(x => x.Total ?? 0);
        RevenueToday = RevenueData.Where(x => x.DateList?.Date == yesterday).Sum(x => x.Total ?? 0);

        // 4. Calculate Profit
        NetProfitMTD = RevenueMTD - TotalExpenseMTD;
        ProfitMargin = RevenueMTD > 0 ? (NetProfitMTD / RevenueMTD) * 100 : 0;

        // 5. Prepare Chart Data (Daily Trend for Current Month)
        var salesMTD = RevenueData.Where(x => x.DateList >= firstDayOfMonth).ToList();

        // Group Sales by Day
        var dailyRevenue = salesMTD
            .GroupBy(x => x.DateList?.Day)
            .ToDictionary(g => g.Key ?? 0, g => g.Sum(x => x.Total ?? 0));

        // Expenses are already grouped by day in ExpensesData ("DateList" usually holds the date)
        var dailyExpenses = ExpensesData
            .ToDictionary(x => x.DateList?.Day ?? 0, x => x.Total ?? 0);

        // Merge Days (1 to Today/End of Month)
        int daysInMonth = DateTime.DaysInMonth(yesterday.Year, yesterday.Month);
        List<string> labels = new List<string>();
        List<double> revSeries = new List<double>();
        List<double> expSeries = new List<double>();

        // We chart up to today or end of month? Usually up to today avoids empty trailing zeros looking like "drop"
        int maxDayToChart = yesterday.Day;

        for (int i = 1; i <= maxDayToChart; i++)
        {
            labels.Add(i.ToString());
            revSeries.Add((double)(dailyRevenue.ContainsKey(i) ? dailyRevenue[i] : 0));
            expSeries.Add((double)(dailyExpenses.ContainsKey(i) ? dailyExpenses[i] : 0));
        }

        TrendLabels = labels.ToArray();
        RevExpSeries.Clear();
        RevExpSeries.Add(new ChartSeries() { Name = "Revenue", Data = revSeries.ToArray() });
        RevExpSeries.Add(new ChartSeries() { Name = "Expenses", Data = expSeries.ToArray() });
    }
}
