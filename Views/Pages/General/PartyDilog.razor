@using System.Text.RegularExpressions;
@inject IPartyService Iservice
@inject IContactService Icontact
@inject IDistrictService Idistrict
@inject IVendorPostingGroupService vendorService
@inject IRenterPostingGroupService renterService
@inject ICustomerPostingGroupService customerService
@inject ISisterPostingGroupService sisterService
@inject MudBlazor.ISnackbar snackbar
@inject ITdsRateService tdsIservice
@attribute [Authorize]
@inject AuthenticationStateProvider auth
@inject NavigationManager nav
@inject IBankAccountService bankAccountService
@inject IAddressService addressService
@using System.Threading;
@inject IRoleService<RoleModel> Irole
@inject IDialogService DialogService

<DialogForm @ref="@dialogForm" Title="Party Registry" Subtitle="Manage comprehensive profile details for customers, suppliers, and business entities." Icon="@Icons.Material.Filled.Business" AdminStyle="true" formID="formtdsRate" model="@model" _busy="_busy">
    <FormContent>
        <div class="dialog-content-wrapper pa-2" style="max-height: 70vh; overflow-y: auto;">
            <EditForm id="formtdsRate" Model="@model" OnValidSubmit="OnValidSubmit">
                <ObjectGraphDataAnnotationsValidator />
                <ValidationSummary />
                
                <div class="admin-glass-card pa-6 mb-4">
                    <div class="d-flex align-center mb-4">
                        <MudIcon Icon="@Icons.Material.Filled.Category" Color="Color.Primary" Class="mr-2" />
                        <MudText Typo="Typo.subtitle1" Class="admin-title font-weight-bold">Business Nature & classification</MudText>
                    </div>
                    <MudGrid Spacing="2">
                        <MudItem xs="12">
                            <MudRadioGroup T="string" @bind-Value="model.NatureOfBusiness" Disabled="@(model.PartyID != null && model.PartyID != 0)">
                                <MudRadio Value="@("Supplier")" Color="Color.Primary">Supplier</MudRadio>
                                <MudRadio Value="@("Customer")" Color="Color.Primary">Customer</MudRadio>
                                <MudRadio Value="@("Renter")" Color="Color.Primary">Renter</MudRadio>
                                <MudRadio Value="@("SisterConcern")" Color="Color.Primary">Sister Concern</MudRadio>
                            </MudRadioGroup>
                        </MudItem>
                        @if (model.NatureOfBusiness == "Supplier" || model.NatureOfBusiness == "Renter")
                        {
                            <MudItem xs="12" md="6">
                                <MudSelect For="@(() => model.GoodsAndServiceType)" T="string" Variant="Variant.Outlined" Margin="Margin.Normal" Label="Goods & Service Type" @bind-Value="@model.GoodsAndServiceType" Class="modern-input">
                                    @foreach (var types in goodsAndServiceTypes)
                                    {
                                        <MudSelectItem Value="@types">@types</MudSelectItem>
                                    }
                                </MudSelect>
                            </MudItem>
                        }
                    </MudGrid>
                </div>

                <div class="admin-glass-card pa-6 mb-4">
                    <div class="d-flex align-center mb-4">
                        <MudIcon Icon="@Icons.Material.Filled.Badge" Color="Color.Primary" Class="mr-2" />
                        <MudText Typo="Typo.subtitle1" Class="admin-title font-weight-bold">General Identification</MudText>
                    </div>
                    <MudGrid Spacing="3">
                        <MudItem xs="12" md="6">
                            <MudTextField @bind-Value="model.PartyCode" Label="Entity Code" Variant="Variant.Outlined" Margin="Margin.Normal" For="@(() => model.PartyCode)" Disabled Class="modern-input"></MudTextField>
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <MudTextField @bind-Value="model.TradeName" Label="Trading Name" Variant="Variant.Outlined" Margin="Margin.Normal" For="@(() => model.TradeName)" Class="modern-input"></MudTextField>
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <MudTextField @bind-Value="model.RegName" Label="Registered Name (Legal)" Variant="Variant.Outlined" Margin="Margin.Normal" For="@(() => model.RegName)" Class="modern-input"></MudTextField>
                        </MudItem>
                        <MudItem xs="12" md="6" Class="d-flex align-center">
                            <MudCheckBox T="bool" @bind-Value="model.PanAvailable" Color="Color.Primary" Dense="true" Label="PAN Available" />
                        </MudItem>
                        @if (model.PanAvailable == true)
                        {
                            <MudItem xs="12" md="6">
                                <MudTextField @bind-Value="model.PAN" Label="PAN Number" Variant="Variant.Outlined" Margin="Margin.Normal" For="@(() => model.PAN)" Class="modern-input" />
                            </MudItem>
                        }
                    </MudGrid>
                </div>
                <div class="admin-glass-card pa-6 mb-4">
                    <div class="d-flex align-center mb-4">
                        <MudIcon Icon="@Icons.Material.Filled.Description" Color="Color.Primary" Class="mr-2" />
                        <MudText Typo="Typo.subtitle1" Class="admin-title font-weight-bold">Tax & GST compliance</MudText>
                    </div>
                    <MudGrid Spacing="3">
                        <MudItem xs="12" md="6">
                            <MudCheckBox T="bool" @bind-Value="model.TdsApplicable" Color="Color.Primary" Dense="true" Label="TDS Applicable" />
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <MudSelect For="@(() => model.GstType)" Label="Registration Type" @bind-Value="model.GstType" T="string" Variant="Variant.Outlined" Margin="Margin.Normal" Class="modern-input">
                                @foreach (var ditem in GstType)
                                {
                                    <MudSelectItem Value="@ditem">@ditem</MudSelectItem>
                                }
                            </MudSelect>
                        </MudItem>
                        @if (model.GstType == "Registered")
                        {
                            <MudItem xs="12" md="6">
                                <MudSelect For="@(() => model.GstRegType)" Label="GST Registry Sub-Type" @bind-Value="model.GstRegType" T="string" Variant="Variant.Outlined" Margin="Margin.Normal" Class="modern-input">
                                    @foreach (var ditem in GstRegType)
                                    {
                                        <MudSelectItem Value="@ditem">@ditem</MudSelectItem>
                                    }
                                </MudSelect>
                            </MudItem>
                            <MudItem xs="12" md="6">
                                <MudTextField Value="model.GstNo" T ="string" ValueChanged="GstNumberChanged" MaxLength=15 Label="GSTIN / UIN" Variant="Variant.Outlined" Margin="Margin.Normal" For="@(() => model.GstNo)" HelperText="Format: 00AAAAA0000A1Z1" Mask="@(new PatternMask("00aaaaa0000a***"))" Class="modern-input" />
                            </MudItem>
                        }
                        <MudItem xs="12" md="6">
                            <MudSelect ReadOnly="@(model.GstType == "Registered")" Label="Registered Jurisdiction (State)" @bind-Value="model.GstStateCode" T="Int32?" Variant="Variant.Outlined" Margin="Margin.Normal" For="@(() => model.GstStateCode)" Class="modern-input">
                                @foreach (var ditem in GstStates)
                                {
                                    <MudSelectItem Value="@ditem.GstCode">@ditem.StateName</MudSelectItem>
                                }
                            </MudSelect>
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <MudTextField @bind-Value="model.TanNo" Label="TAN Number" Variant="Variant.Outlined" Margin="Margin.Normal" For="@(() => model.TanNo)" HelperText="Format: AAAA11111A" Mask="@(new PatternMask("aaaa00000a"))" Class="modern-input" />
                        </MudItem>
                    </MudGrid>
                </div>
                <div class="admin-glass-card pa-6 mb-4">
                    <div class="d-flex align-center mb-4">
                        <MudIcon Icon="@Icons.Material.Filled.Payments" Color="Color.Primary" Class="mr-2" />
                        <MudText Typo="Typo.subtitle1" Class="admin-title font-weight-bold">Financial & Accounting Parameters</MudText>
                    </div>
                    <MudGrid Spacing="3">
                        <MudItem xs="12" md="6">
                            <MudTextField @bind-Value="model.CreditPeriod" Label="Credit Period (Days)" Variant="Variant.Outlined" Margin="Margin.Normal" For="@(() => model.CreditPeriod)" InputMode="InputMode.numeric" InputType="InputType.Number" Class="modern-input" />
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <MudTextField @bind-Value="model.CreditLimit" Label="Credit Limit (Amount)" Variant="Variant.Outlined" Margin="Margin.Normal" For="@(() => model.CreditLimit)" InputType="InputType.Number" Class="modern-input" />
                        </MudItem>
                        <MudItem xs="12" md="12">
                            <MudRadioGroup T="string" Value="model.PaymentMode" ValueChanged="OnSelectedOptionChanged">
                                <MudRadio Value="@("Cash")" Color="Color.Secondary" Dense="true">Cash Mode</MudRadio>
                                <MudRadio Value="@("Bank")" Color="Color.Secondary" Dense="true">Bank Transfer</MudRadio>
                            </MudRadioGroup>
                        </MudItem>
                        <MudItem xs="12" md="6">
                            @if (model.NatureOfBusiness == "Supplier")
                            {
                                <MudSelect For="@(() => model.VendorPostingGroup)" Label="Vendor Posting Policy" @bind-Value="model.VendorPostingGroup" T="VendorPostingGroupModel" Variant="Variant.Outlined" Margin="Margin.Normal" ToStringFunc="@(e => e == null ? null : $"{e.Title}")" Class="modern-input">
                                    @foreach (var ditem in VendorList)
                                    {
                                        <MudSelectItem Value="@ditem">@ditem.Title</MudSelectItem>
                                    }
                                </MudSelect>
                            }
                            @if (model.NatureOfBusiness == "Customer")
                            {
                                <MudSelect For="@(() => model.CustomerPostingGroup)" Label="Customer Posting Policy" @bind-Value="model.CustomerPostingGroup" T="CustomerPostingGroupModel" Variant="Variant.Outlined" Margin="Margin.Normal" ToStringFunc="@(e => e == null ? null : $"{e.Title}")" Class="modern-input">
                                    @foreach (var ditem in CustomerList)
                                    {
                                        <MudSelectItem Value="@ditem">@ditem.Title</MudSelectItem>
                                    }
                                </MudSelect>
                            }
                            @if (model.NatureOfBusiness == "Renter")
                            {
                                <MudSelect For="@(() => model.RenterPostingGroup)" Label="Renter Posting Policy" @bind-Value="model.RenterPostingGroup" T="RenterPostingGroupModel" Variant="Variant.Outlined" Margin="Margin.Normal" ToStringFunc="@(e => e == null ? null : $"{e.Title}")" Class="modern-input">
                                    @foreach (var ditem in RenterList)
                                    {
                                        <MudSelectItem Value="@ditem">@ditem.Title</MudSelectItem>
                                    }
                                </MudSelect>
                            }
                            @if (model.NatureOfBusiness == "SisterConcern")
                            {
                                <MudSelect For="@(() => model.SisterPostingGroup)" Label="Intra-Group Policy" @bind-Value="model.SisterPostingGroup" T="SisterPostingGroupModel" Variant="Variant.Outlined" Margin="Margin.Normal" ToStringFunc="@(e => e == null ? null : $"{e.Title}")" Class="modern-input">
                                    @foreach (var ditem in SisterList)
                                    {
                                        <MudSelectItem Value="@ditem">@ditem.Title</MudSelectItem>
                                    }
                                </MudSelect>
                            }
                        </MudItem>
                        <MudItem xs="12" md="6" Class="d-flex align-center">
                            <MudCheckBox T="bool" @bind-Value="model.InterCompany" Color="Color.Primary" Dense="true" Label="Inter-Company Transaction" />
                        </MudItem>
                        @if (model.InterCompany == true)
                        {
                            <MudItem xs="12" md="6">
                                <MudTextField @bind-Value="model.IcPartnerCode" Label="IC Partner Code" MaxLength="15" Variant="Variant.Outlined" Margin="Margin.Normal" For="@(() => model.IcPartnerCode)" Class="modern-input" />
                            </MudItem>
                        }
                    </MudGrid>
                </div>
                <div class="admin-glass-card pa-6 mb-4">
                    <div class="d-flex align-center mb-4">
                        <MudIcon Icon="@Icons.Material.Filled.LocationCity" Color="Color.Primary" Class="mr-2" />
                        <MudText Typo="Typo.subtitle1" Class="admin-title font-weight-bold">Address Registry</MudText>
                    </div>
                    
                    @foreach (var address in model.Addresses)
                    {
                        <div class="glass-inner-panel mb-3 pa-4 d-flex align-center justify-between">
                            <div class="flex-grow-1">
                                <MudText Typo="Typo.subtitle2" Class="font-weight-bold">
                                    @address.AddresseeName @(address.IsDefault ? "(Default)" : "")
                                </MudText>
                                <MudText Typo="Typo.body2" Class="opacity-70">
                                    @address.Building, @address.Street, @address.Place, @address.City - @address.PinCode
                                </MudText>
                            </div>
                            <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small" OnClick="@(() => DeleteAddress(address))" />
                        </div>
                    }

                    <div class="mt-4 pa-4 glass-inner-panel border-dashed">
                        <MudText Typo="Typo.subtitle2" Class="mb-3">Add New Address</MudText>
                        <MudGrid Spacing="2">
                            <MudItem xs="12" md="6">
                                <MudTextField @bind-Value="newAddress.AddresseeName" Label="Address Label / Contact" Variant="Variant.Outlined" Margin="Margin.Dense" Class="modern-input" />
                            </MudItem>
                            <MudItem xs="12" md="6">
                                <MudTextField @bind-Value="newAddress.Building" Label="Building / House No" Variant="Variant.Outlined" Margin="Margin.Dense" Class="modern-input" />
                            </MudItem>
                            <MudItem xs="12" md="6">
                                <MudTextField @bind-Value="newAddress.Street" Label="Street / Road" Variant="Variant.Outlined" Margin="Margin.Dense" Class="modern-input" />
                            </MudItem>
                            <MudItem xs="12" md="6">
                                <MudTextField @bind-Value="newAddress.Place" Label="Locality / Landmark" Variant="Variant.Outlined" Margin="Margin.Dense" Class="modern-input" />
                            </MudItem>
                            <MudItem xs="12" md="4">
                                <MudTextField @bind-Value="newAddress.City" Label="City" Variant="Variant.Outlined" Margin="Margin.Dense" Class="modern-input" />
                            </MudItem>
                            <MudItem xs="12" md="4">
                                <MudNumericField HideSpinButtons @bind-Value="newAddress.PinCode" Label="Postal Code" Variant="Variant.Outlined" MaxLength="6" Margin="Margin.Dense" Class="modern-input" />
                            </MudItem>
                            <MudItem xs="12" md="4" Class="d-flex align-center">
                                <MudCheckBox T="bool" Value="@newAddress.IsDefault" ValueChanged="@((bool isDefault) => SetDefaultAddress(newAddress, isDefault))" Label="Primary" Color="Color.Primary" />
                                <MudSpacer />
                                <MudFab OnClick="AddAddress" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" Size="Size.Small" />
                            </MudItem>
                        </MudGrid>
                    </div>
                </div>


                @if (IsShowBankInformation)
                {
                    <div class="admin-glass-card pa-6 mb-4">
                        <div class="d-flex align-center mb-4">
                            <MudIcon Icon="@Icons.Material.Filled.AccountBalance" Color="Color.Primary" Class="mr-2" />
                            <MudText Typo="Typo.subtitle1" Class="admin-title font-weight-bold">Banking Credentials</MudText>
                        </div>
                        <MudGrid Spacing="3">
                            <MudItem xs="12" md="6">
                                <MudTextField MaxLength="50" Class="ToUpperCase modern-input" @bind-Value="model.BankAccount.BeneficiaryName" Label="Payee Name" Variant="Variant.Outlined" Margin="Margin.Normal" For="@(() => model.BankAccount.BeneficiaryName)" />
                            </MudItem>
                            <MudItem xs="12" md="6">
                                <MudTextField MaxLength="25" @bind-Value="model.BankAccount.AccountNumber" Label="Account Number" Variant="Variant.Outlined" Margin="Margin.Normal" For="@(() => model.BankAccount.AccountNumber)" Class="modern-input" />
                            </MudItem>
                            <MudItem xs="12" md="6">
                                <MudTextField MaxLength="11" @bind-Value="model.BankAccount.IfscCode" Label="IFSC Code" Variant="Variant.Outlined" Margin="Margin.Normal" For="@(() => model.BankAccount.IfscCode)" Class="modern-input" />
                            </MudItem>
                            <MudItem xs="12" md="6">
                                <MudTextField MaxLength="9" @bind-Value="model.BankAccount.MicrCode" Label="MICR Code" Variant="Variant.Outlined" Margin="Margin.Normal" For="@(() => model.BankAccount.MicrCode)" Class="modern-input" />
                            </MudItem>
                            <MudItem xs="12" md="6">
                                <MudTextField @bind-Value="model.BankAccount.BankTitle" Label="Financial Institution" Variant="Variant.Outlined" Margin="Margin.Normal" For="@(() => model.BankAccount.BankTitle)" Class="modern-input" />
                            </MudItem>
                            <MudItem xs="12" md="6">
                                <MudTextField @bind-Value="model.BankAccount.BankBranch" Label="Branch Office" Variant="Variant.Outlined" Margin="Margin.Normal" For="@(() => model.BankAccount.BankBranch)" Class="modern-input" />
                            </MudItem>
                        </MudGrid>
                    </div>
                }
                <div class="admin-glass-card pa-6">
                    <div class="d-flex align-center mb-4">
                        <MudIcon Icon="@Icons.Material.Filled.ContactPhone" Color="Color.Primary" Class="mr-2" />
                        <MudText Typo="Typo.subtitle1" Class="admin-title font-weight-bold">Contact Directory</MudText>
                    </div>
                    
                    <MudTable Items="Contactlist" Dense="true" Hover="true" Bordered="false" Elevation="0" Class="glass-inner-panel">
                        <HeaderContent>
                            <MudTh>Full Name</MudTh>
                            <MudTh>Designation / info</MudTh>
                            <MudTh>Mobile No</MudTh>
                            <MudTh>Email Address</MudTh>
                            <MudTh>Action</MudTh>
                        </HeaderContent>
                        <RowTemplate Context="item">
                            <MudTd>@item.ContactName</MudTd>
                            <MudTd>@item.AdditionalInfo</MudTd>
                            <MudTd>@item.Phone</MudTd>
                            <MudTd>@item.Email</MudTd>
                            <MudTd>
                                <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small" OnClick="@(() => DeleteContact(item))" />
                            </MudTd>
                        </RowTemplate>
                        <FooterContent>
                            <MudTd><MudTextField Label="Name" @bind-Value="contactModel.ContactName" Variant="Variant.Outlined" Margin="Margin.Dense" Class="modern-input" /></MudTd>
                            <MudTd><MudTextField Label="Info" @bind-Value="contactModel.AdditionalInfo" Variant="Variant.Outlined" Margin="Margin.Dense" Class="modern-input" /></MudTd>
                            <MudTd><MudNumericField HideSpinButtons Label="Phone" @bind-Value="contactModel.Phone" Variant="Variant.Outlined" Margin="Margin.Dense" Class="modern-input" /></MudTd>
                            <MudTd><MudTextField Label="Email" @bind-Value="contactModel.Email" Variant="Variant.Outlined" Margin="Margin.Dense" Class="modern-input" /></MudTd>
                            <MudTd><MudFab OnClick="AddItems" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" Size="Size.Small" /></MudTd>
                        </FooterContent>
                    </MudTable>
                </div>
            </EditForm>
        </div>
    </FormContent>
</DialogForm>

@code {

    [Parameter]
    public PartyModel model { get; set; }
    private List<VendorPostingGroupModel> VendorList = new();
    private List<CustomerPostingGroupModel> CustomerList = new();
    private List<RenterPostingGroupModel> RenterList = new();
    private List<SisterPostingGroupModel> SisterList = new();
    private List<ContactModel> Contactlist = new();
    private ContactModel contactModel = new();
    bool IsShowBankInformation { get; set; } = false;
    private bool _busy;
    DialogForm dialogForm;
    List<string> goodsAndServiceTypes = new List<string>();
    private List<StateModel> GstStates = new();
    private AddressModel newAddress = new AddressModel();

    public bool HasPermissionPartyServiceEdit { get; set; } = false;
    public int PartyDocTypeID = 85;

    private void OnNatureOfBusinessChanged(string newValue)
    {
        model.GoodsAndServiceType = null;
        model.NatureOfBusiness = newValue;
        if (model.NatureOfBusiness == "Supplier" || model.NatureOfBusiness == "Renter")
        {
            goodsAndServiceTypes = new List<string> { "Tyre Work", "Tyre", "Spare", "Lube", "Fuel", "Ad - Blue", "Vehicle Tax", "Market Truck", "Repairs_Truck", "Repairs_Office Vehicle", "Repairs_Building", "Repairs_Computer", "Admin", "Capital Goods"};
        }
    }

    void GstNumberChanged(string gstNo)
    {
        model.GstNo = gstNo;
        if(!string.IsNullOrEmpty(gstNo))
        {
            int gstCode = 0;
            if (gstNo.Length >= 2)
            {
                int.TryParse(gstNo.Substring(0, 2), out gstCode);
                if (GstStates.Any(z => z.GstCode == gstCode))
                {
                    model.GstStateCode = gstCode;
                }
                else
                {
                    model.GstStateCode = 0;
                }
            }

        }
    }

    private void AddAddress()
    {
        if (string.IsNullOrEmpty(newAddress.AddresseeName) ||
            string.IsNullOrEmpty(newAddress.Building) ||
            string.IsNullOrEmpty(newAddress.Street) ||
            string.IsNullOrEmpty(newAddress.Place) ||
            string.IsNullOrEmpty(newAddress.City) ||
            string.IsNullOrEmpty(newAddress.PinCode))
        {
            snackbar.Add("Please fill all address fields.", Severity.Error);
            return;
        }

        // If the new address is marked as default, reset all other addresses to not default
        if (newAddress.IsDefault)
        {
            ResetDefaultAddresses();
        }

        model.Addresses.Add(newAddress);
        EnsureDefaultAddress();

        newAddress = new AddressModel();
    }

    private void ResetDefaultAddresses()
    {
        foreach (var address in model.Addresses)
        {
            address.IsDefault = false;
        }
    }

    private void DeleteAddress(AddressModel address)
    {
        model.Addresses.Remove(address);

        EnsureDefaultAddress();
    }

    private void SetDefaultAddress(AddressModel address, bool isDefault)
    {
        if (isDefault)
        {
            ResetDefaultAddresses();
            address.IsDefault = true;
        }
        else
        {
            address.IsDefault = false;
            EnsureDefaultAddress();
        }
    }

    private void EnsureDefaultAddress()
    {
        if (!model.Addresses.Any(a => a.IsDefault) && model.Addresses.Any())
        {
            model.Addresses.First().IsDefault = true;
        }
    }

    // Example of initializing or resetting the model
    private void InitializeOrResetModel()
    {
        model.Addresses = new List<AddressModel>
    {
        new AddressModel { IsDefault = true, /* other properties */ },
        new AddressModel { IsDefault = false, /* other properties */ }
    };
    }

    private async Task OnValidSubmit(EditContext context)
    {
        if ((model.NatureOfBusiness == "Supplier" || model.NatureOfBusiness == "Renter") && model.GoodsAndServiceType == null)
        {
            snackbar.Add("Goods and service type is required", Severity.Warning);
            return;
        }

        if (model.Addresses == null || !model.Addresses.Any())
        {
            snackbar.Add("At least one address is required.", Severity.Error);
            return;
        }

        if (_busy)
        {
            snackbar.Add("Please wait while form is being submitted!", Severity.Warning);
            return;
        }
        _busy = true;
        if (HasPermissionPartyServiceEdit)
        {
            var authprov = await auth.GetAuthenticationStateAsync();
            var user = authprov.User;
            model.UserInfo.UserID = user.Identity.Name;
            model.Contacts = Contactlist;
            try
            {
                model.TradeName = FontStyle.ConvertToCamelCase(model.TradeName);
                model.RegName = FontStyle.ConvertToCamelCase(model.RegName);
                foreach (var address in model.Addresses)
                {
                    address.AddresseeName = FontStyle.ConvertToCamelCase(address.AddresseeName);
                    address.Building = FontStyle.ConvertToCamelCase(address.Building);
                    address.Street = FontStyle.ConvertToCamelCase(address.Street);
                    address.Place = FontStyle.ConvertToCamelCase(address.Place);
                    address.City = FontStyle.ConvertToCamelCase(address.City);
                }
                model.GstNo = model.GstNo?.ToUpper() ?? null;
                model = Iservice.Update(model);
                snackbar.Add("Saved Successfully", Severity.Success);
                dialogForm.Close(model);
                model = new();
            }
            catch (Exception ex)
            {
                snackbar.Add(ex.Message, Severity.Warning);
            }
        }
        else
        {
            bool? result = await DialogService.ShowMessageBoxAsync(
                "Permission denied!",
                "You don't have any permission to Edit Party.");
        }
        await Task.Delay(200);
        _busy = false;
    }

    private void OnSelectedOptionChanged(string option)
    {
        model.PaymentMode = option;
        if (option == "Bank")
        {
            model.BankAccount = new();
            IsShowBankInformation = true;
        }
        else
        {
            model.BankAccount = null;
            IsShowBankInformation = false;
        }
    }

    private List<string> GstType = new List<string>() { "Registered", "UnRegistered", "Export", "Deemed Export", "Exempted", "SEZ" };
    private List<string> GstRegType = new List<string>() { "GSTIN", "UID", "GID" };

    protected override async Task OnInitializedAsync()
    {
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionPartyServiceEdit = await Irole.HasClaim(PartyDocTypeID.ToString(), "Edit", ctc.Token);

        if (VendorList != null)
        {
            VendorList.Clear();
        }
        if (CustomerList != null)
        {
            CustomerList.Clear();
        }
        if (RenterList != null)
        {
            RenterList.Clear();
        }
        if (SisterList != null)
        {
            SisterList.Clear();
        }
        VendorList = vendorService.Select().ToList();
        CustomerList = customerService.Select().ToList();
        RenterList = renterService.Select().ToList();
        SisterList = sisterService.Select().ToList();
        GstStates = Idistrict.GetStates().ToList();

        if (model.NatureOfBusiness == null)
        {
            model.NatureOfBusiness = "Supplier";
            model.PanAvailable = false;
        }

        if (model.NatureOfBusiness == "Supplier" || model.NatureOfBusiness == "Renter")
        {
            goodsAndServiceTypes = new List<string> { "Tyre Work", "Tyre", "Spare", "Lube", "Fuel", "Ad - Blue", "Vehicle Tax", "Market Truck", "Repairs_Truck", "Repairs_Office Vehicle", "Repairs_Building", "Repairs_Computer", "Admin" };
        }

        if (model.GoodsAndServiceType == null)
        {
            OnNatureOfBusinessChanged(model.NatureOfBusiness);
        }
        // if (model.PaymentMode == "Bank")
        // {
        //     model.BankAccount = new();
        //     IsShowBankInformation = true;
        // }
        // else
        // {
        //     model.BankAccount = null;
        //     IsShowBankInformation = false;
        // }
        if (model.BankAccount != null && model.BankAccount.BankAccountID != null && model.BankAccount.BankAccountID != 0)
        {
            model.BankAccount = bankAccountService.SelectByID(model.BankAccount.BankAccountID ?? 0);
        }
        // if (model.Address != null && model.Address.AddressID != null && model.Address.AddressID != 0)
        // {
        //     model.Address = addressService.SelectByID(model.Address.AddressID);
        // }
        if (VendorList != null && VendorList.Count() != 0 && model.VendorPostingGroup != null && model.VendorPostingGroup.VendorPostingGroupID != null && model.VendorPostingGroup.VendorPostingGroupID != 0)
        {
            if (VendorList.Any(s => s.VendorPostingGroupID == model.VendorPostingGroup.VendorPostingGroupID))
                model.VendorPostingGroup = VendorList.FirstOrDefault(s => s.VendorPostingGroupID == model.VendorPostingGroup.VendorPostingGroupID);
        }
        if (CustomerList != null && CustomerList.Count() != 0 && model.CustomerPostingGroup != null && model.CustomerPostingGroup.CustomerPostingGroupID != null && model.CustomerPostingGroup.CustomerPostingGroupID != 0)
        {
            if (CustomerList.Any(s => s.CustomerPostingGroupID == model.CustomerPostingGroup.CustomerPostingGroupID))
                model.CustomerPostingGroup = CustomerList.FirstOrDefault(s => s.CustomerPostingGroupID == model.CustomerPostingGroup.CustomerPostingGroupID);
        }
        if (RenterList != null && RenterList.Count() != 0 && model.RenterPostingGroup != null && model.RenterPostingGroup.RenterPostingGroupID != null && model.RenterPostingGroup.RenterPostingGroupID != 0)
        {
            if (RenterList.Any(s => s.RenterPostingGroupID == model.RenterPostingGroup.RenterPostingGroupID))
                model.RenterPostingGroup = RenterList.FirstOrDefault(s => s.RenterPostingGroupID == model.RenterPostingGroup.RenterPostingGroupID);
        }
        if (SisterList != null && SisterList.Count() != 0 && model.SisterPostingGroup != null && model.SisterPostingGroup.SisterPostingGroupID != null && model.SisterPostingGroup.SisterPostingGroupID != 0)
        {
            if (SisterList.Any(s => s.SisterPostingGroupID == model.SisterPostingGroup.SisterPostingGroupID))
                model.SisterPostingGroup = SisterList.FirstOrDefault(s => s.SisterPostingGroupID == model.SisterPostingGroup.SisterPostingGroupID);
        }

        if (model.PartyID != null && model.PartyID != 0)
        {
            if (model.Addresses != null)
            {
                model.Addresses.Clear();
            }
            model.Addresses = Iservice.GetAddress(model.PartyID).ToList();
        }

        if (model.PartyID != null && model.PartyID != 0)
        {
            if (Contactlist != null)
            {
                Contactlist.Clear();
            }
            Contactlist = Iservice.GetContacts(model.PartyID).ToList();
        }
        if (model.PaymentMode == "Bank")
        {
            IsShowBankInformation = true;
        }
        if (model.PaymentMode == "Cash")
        {
            model.BankAccount = null;
            IsShowBankInformation = false;
        }
    }

    public void DeleteContact(ContactModel cm)
    {
        int rowIndex = Contactlist.IndexOf(cm);
        Contactlist.RemoveAt(rowIndex);
    }

    public void AddItems()
    {
        if (contactModel.ContactName == null || contactModel.AdditionalInfo == null || contactModel.Phone == null)
        {
            snackbar.Add("Please fill all entries.", Severity.Error);
            return;
        }
        if (contactModel.Phone == null || contactModel.Phone.Length != 10)
        {
            snackbar.Add("Phone number should be 10 digit", Severity.Error);
            return;
        }
        var pattern = @"^[a-zA-Z0-9.!#$%&'*+-/=?^_`{|}~]+@[a-zA-Z0-9-]+(?:\.[a-zA-Z0-9-]+)*$";
        var regex = new Regex(pattern);
        if (contactModel.Email != null && !regex.IsMatch(contactModel.Email))//contactModel.Email == null ||
        {
            snackbar.Add("Enter valid Email address.", Severity.Error);
            return;
        }
        contactModel.RefTable = "Party";
        Contactlist.Add(contactModel);
        contactModel = new();
    }
}

