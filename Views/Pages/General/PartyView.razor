@page "/party"
@using System.Threading;
@using Newtonsoft.Json
@using OfficeOpenXml
@using System.IO
@using OfficeOpenXml.Style
@attribute [Authorize]
@inject AuthenticationStateProvider auth
@inject IPartyService Iservice
@inject IContactService Icontact
@inject MudBlazor.ISnackbar snackbar
@inject IDialogService DialogService
@inject IRoleService<RoleModel> Irole
@inject IJSRuntime JSRuntime
@inject NavigationManager NavigationManager

<div class="fade-in">
    <div class="admin-header-tiered mb-6">
        <div class="d-flex align-center justify-space-between">
            <div>
                <MudText Typo="Typo.h4" Class="admin-title">Trading Partners</MudText>
                <MudText Typo="Typo.body2" Class="admin-subtitle">Central repository for customers, vendors, and business associates. Manage trade terms, tax profiles, and contact hierarchies for seamless procurement and sales operations.</MudText>
            </div>
            <MudButton StartIcon="@Icons.Material.Filled.Add" Variant="Variant.Filled" Color="Color.Primary" Class="admin-register-btn" OnClick="(()=>Edit(new PartyModel()))" Disabled="@_busy">REGISTER NEW PARTY</MudButton>
        </div>
    </div>

    <div class="admin-glass-card mb-6 pa-4">
        <div class="d-flex align-center gap-4 flex-wrap">
            <div style="flex-grow: 1; min-width: 300px;">
                <MudTextField @bind-Value="searchParty" Placeholder="Search by name, code, or business nature..." Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" Variant="Variant.Outlined" Margin="Margin.Dense" Class="admin-input-group" Clearable="true" />
            </div>
            <div class="d-flex align-center gap-4">
                <MudButton OnClick="ExcelDownload" StartIcon="@Icons.Material.Outlined.FileDownload" Variant="Variant.Filled" Color="Color.Tertiary" Class="fw-600 px-6">EXPORT DATA</MudButton>
            </div>
        </div>
    </div>

    <div class="admin-glass-card pa-0 overflow-hidden">
        <MudTable Items="@collection" Elevation="0" Class="modern-admin-table" Hover="true" Filter="new Func<PartyModel, bool>(search)">
            <HeaderContent>
                <MudTh><MudTableSortLabel SortBy="new Func<PartyModel, object>(x=> x.PartyCode)" InitialDirection="SortDirection.Ascending"><span class="admin-header-text">CODE</span></MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<PartyModel, object>(x=> x.TradeName)" InitialDirection="SortDirection.Ascending"><span class="admin-header-text">TRADE NAME</span></MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<PartyModel, object>(x=> x.NatureOfBusiness)" InitialDirection="SortDirection.Ascending"><span class="admin-header-text">NATURE</span></MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<PartyModel, object>(x=> x.TdsApplicable)" InitialDirection="SortDirection.Ascending"><span class="admin-header-text">TDS</span></MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<PartyModel, object>(x=> x.RegName)" InitialDirection="SortDirection.Ascending"><span class="admin-header-text">LEGAL ENTITY</span></MudTableSortLabel></MudTh>
                <MudTh Style="text-align: right;"><span class="admin-header-text">ACTIONS</span></MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Code"><span class="admin-td-primary fw-700">@context.PartyCode</span></MudTd>
                <MudTd DataLabel="TradeName"><span class="fw-600">@context.TradeName</span></MudTd>
                <MudTd DataLabel="Nature"><span class="fw-500">@context.NatureOfBusiness</span></MudTd>
                <MudTd DataLabel="TDS">
                    <MudChip T="string" Size="Size.Small" Color="@(context.TdsApplicable ? Color.Warning : Color.Default)" Variant="Variant.Text" Class="fw-700">@(context.TdsApplicable ? "Yes" : "No")</MudChip>
                </MudTd>
                <MudTd DataLabel="LegalName"><span class="fw-500 opa-70">@context.RegName</span></MudTd>
                <MudTd DataLabel="Actions" Style="text-align: right;">
                    <div class="d-flex justify-end gap-1">
                        <MudTooltip Text="Edit Profile">
                            <MudIconButton OnClick="@(()=> Edit(context))" Color="Color.Primary" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Variant="Variant.Text" />
                        </MudTooltip>
                        
                        <MudTooltip Text="Allocated Branches">
                            <MudIconButton OnClick="@(()=> GetBranches(context))" Color="Color.Info" Icon="@Icons.Material.Outlined.Apartment" Size="Size.Small" Variant="Variant.Text" />
                        </MudTooltip>

                        <MudTooltip Text="Delete Partner">
                            <MudIconButton OnClick="@(()=> Delete(context))" Color="Color.Error" Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Variant="Variant.Text" />
                        </MudTooltip>
                    </div>
                </MudTd>
            </RowTemplate>
            <PagerContent>
                <div class="pa-4">
                    <MudTablePager PageSizeOptions="new int[] { 10, 20, 50, 100 }" />
                </div>
            </PagerContent>
        </MudTable>
    </div>
</div>

@code {

    private PartyModel model = new PartyModel();
    private List<PartyModel> collection = new List<PartyModel>();
    DialogOptions maxWidth = new DialogOptions() { MaxWidth = MaxWidth.Large, FullWidth = true };
    private List<string> PartyTypes = new List<string>() { "Proprietorship", "Partnership", "Company" };
    private bool _busy;
    private string searchParty = "";

    public bool HasPermissionContactServiceServiceEdit { get; set; } = false;
    public int ContactServiceDocTypeID = 71;
    public bool HasPermissionPartyServiceEdit { get; set; } = false;
    public bool HasPermissionPartyServiceDelete { get; set; } = false;
    public int PartyDocTypeID = 85;

    string UserID;
    protected override async Task OnInitializedAsync()
    {
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionContactServiceServiceEdit = await Irole.HasClaim(ContactServiceDocTypeID.ToString(), "Edit", ctc.Token);
        HasPermissionPartyServiceEdit = await Irole.HasClaim(PartyDocTypeID.ToString(), "Edit", ctc.Token);
        HasPermissionPartyServiceDelete = await Irole.HasClaim(PartyDocTypeID.ToString(), "Delete", ctc.Token);

        var authprov = await auth.GetAuthenticationStateAsync();
        UserID = authprov.User.Identity.Name;

        GetAll();
    }

    private void GetAll()
    {
        collection = Iservice.Select(null).ToList();        
    }

    private void AddContact()
    {
        model.Contacts.Add(new ContactModel()
            {
                RefTable = "PARTY"
            });
    }

    private async Task OnValidSubmit(EditContext context)
    {
        if (HasPermissionPartyServiceEdit)
        {            
            model.UserInfo.UserID = UserID;
            try
            {
                var contacts = model.Contacts;
                model = Iservice.Update(model);
                snackbar.Add("Saved Successfully", Severity.Success);
                if (collection.Exists(x => x.PartyID == model.PartyID))
                {
                    collection[collection.FindIndex(x => x.PartyID == model.PartyID)] = model;
                }
                else
                {
                    collection.Add(model);
                }
                if (HasPermissionContactServiceServiceEdit)
                {
                    foreach (var item in contacts)
                    {
                        item.RefKey = model.PartyID;
                        item.UserInfo = model.UserInfo;
                        Icontact.Update(item);
                    }
                }
                else
                {
                    bool? ResultModel = await DialogService.ShowMessageBoxAsync(
                        "Permission denied!",
                        "You don't have any permission to Edit Contact.");
                }
                model = new PartyModel();
            }
            catch (Exception ex)
            {
                snackbar.Add(ex.Message, Severity.Warning);
            }
        }
        else
        {
            bool? ResultModel = await DialogService.ShowMessageBoxAsync(
                "Permission denied!",
                "You don't have any permission to Edit Party.");
        }
    }

    private async Task Edit(PartyModel model)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        _busy = true;
        DialogParameters parms = new DialogParameters();
        parms.Add("model", model.Clone());
        var dialog = await DialogService.ShowAsync<PartyDilog>("ADD PARTY", parms, maxWidth);
        var result = await dialog.Result;

        // you can check if the modal was cancelled
        var isCancelled = result.Canceled;
        if (!isCancelled)
        {
            PartyModel UpatedModel = (PartyModel)result.Data;
            if (UpatedModel != null)
            {
                if (collection.Exists(x => x.PartyID == UpatedModel.PartyID))
                {
                    collection[collection.FindIndex(x => x.PartyID == UpatedModel.PartyID)] = UpatedModel;
                }
                else
                {
                    collection.Insert(0, UpatedModel);
                }
            }
            model = new();
        }
        await Task.Delay(200);
        _busy = false;
    }

    private async Task Delete(PartyModel model)
    {
        if (HasPermissionPartyServiceDelete)
        {
            bool? value = await DialogService.ShowMessageBoxAsync(
                "Warning !",
                "Are you sure, you want to delete - " + model.RegName + " (" + model.PartyCode + ") ?");
            if (value == true)
            {
                var authprov = await auth.GetAuthenticationStateAsync();
                int result = Iservice.Delete(model.PartyID, authprov.User.Identity.Name);
                if (result != -1)
                {
                    if (collection != null && collection.Any(s => s.PartyID == model.PartyID))
                    {
                        collection.Remove(collection.FirstOrDefault(s => s.PartyID == model.PartyID));
                        snackbar.Add("Deleted Successfully", Severity.Success);
                    }
                }
            }
        }
        else
        {
            bool? ResultModel = await DialogService.ShowMessageBoxAsync(
                "Permission denied!",
                "You don't have any permission to Delete Party.");
        }
    }

    private void OpenPartyLedgerViews(PartyModel Party)
    {
        if (Party != null && Party.PartyID != null)
        {
            NavigationManager.NavigateTo("/PartyLedgerView/" + Party.PartyID.ToString() );
        }
    }

    private bool search(PartyModel model)
    {
        if (model.TradeName != null && (model.TradeName.Contains(searchParty, StringComparison.OrdinalIgnoreCase) || model.PartyCode.Contains(searchParty, StringComparison.OrdinalIgnoreCase)))
        {
            return true;
        }
        return false;
    }


    async Task GetBranches(PartyModel val)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        _busy = true;

        var brs =  Iservice.GetAllocatedBranches(val.PartyID.Value).ToList();

        DialogParameters parms = new DialogParameters();
        parms.Add("SelectedBranches", brs);
        var dialog = await DialogService.ShowAsync<MultiBranchSelector>("Select Branches", parms, maxWidth);
        var result = await dialog.Result;

        if (!result.Canceled)
        {
            var updatedBrs = (List<int>)result.Data;
            foreach (var item in updatedBrs.Except(brs))
            {
                Iservice.AddToBranch(val.PartyID, item, UserID);
            }

            foreach(var item in brs.Except(updatedBrs))
            {
                Iservice.RemoveFromBranch(val.PartyID, item, UserID);
            }
        }
            
        await Task.Delay(200);
        _busy = false;
    }

    private async Task ExcelDownload()
    {
        var fileName = "TradingPartners.xlsx";
        var sheetName = "Sheet1"; // Change the sheet name as needed
        var fileBytes = GenerateExcelBytes(sheetName);

        await JSRuntime.InvokeVoidAsync("triggerFileDownload", fileName, Convert.ToBase64String(fileBytes));
    }

    private byte[] GenerateExcelBytes(string sheetName)
    {
        using (var package = new ExcelPackage())
        {
            var worksheet = package.Workbook.Worksheets.Add(sheetName);

            // Add column headers
            worksheet.Cells[1, 1].Value = "Nature of Firm";
            worksheet.Cells[1, 2].Value = "Party Type";
            worksheet.Cells[1, 3].Value = "Party Code";
            worksheet.Cells[1, 4].Value = "Trade Name";
            worksheet.Cells[1, 5].Value = "Reg Name";
            worksheet.Cells[1, 6].Value = "Tds Applicable";
            worksheet.Cells[1, 7].Value = "PAN";
            worksheet.Cells[1, 8].Value = "Gst Type";
            worksheet.Cells[1, 9].Value = "Gst No";
            worksheet.Cells[1, 10].Value = "Tan No";
            worksheet.Cells[1, 11].Value = "Account Rules";
            worksheet.Cells[1, 12].Value = "Credit Period";
            worksheet.Cells[1, 13].Value = "Credit Limit";
            worksheet.Cells[1, 14].Value = "Payment Mode";
            worksheet.Cells[1, 15].Value = "Account Number";
            worksheet.Cells[1, 16].Value = "Addressee Name";
            worksheet.Cells[1, 17].Value = "Building";
            worksheet.Cells[1, 18].Value = "Street";
            worksheet.Cells[1, 19].Value = "Place";
            worksheet.Cells[1, 20].Value = "City";
            worksheet.Cells[1, 21].Value = "PinCode";
            for (int i = 1; i <= 21; i++)
            {
                worksheet.Cells[1, i].Style.Font.Bold = true;
            }

            // Add data rows
            int row = 2;
            foreach (var item in collection)
            {
                worksheet.Cells[row, 1].Value = item.NatureOfBusiness;
                worksheet.Cells[row, 2].Value = item.GoodsAndServiceType;
                worksheet.Cells[row, 3].Value = item.PartyCode;
                worksheet.Cells[row, 4].Value = item.TradeName;
                worksheet.Cells[row, 5].Value = item.RegName;
                worksheet.Cells[row, 6].Value = item.TdsApplicable;
                worksheet.Cells[row, 7].Value = item.PAN;
                worksheet.Cells[row, 8].Value = item.GstType;
                worksheet.Cells[row, 9].Value = item.GstNo;
                worksheet.Cells[row, 10].Value = item.TanNo;
                worksheet.Cells[row, 11].Value = item.PostingGroupTitle;
                worksheet.Cells[row, 12].Value = item.CreditPeriod;
                worksheet.Cells[row, 13].Value = item.CreditLimit;
                worksheet.Cells[row, 14].Value = item.PaymentMode;
                worksheet.Cells[row, 15].Value = item.BankAccount.AccountNumber;
                // worksheet.Cells[row, 16].Value = item.Address.AddresseeName;
                // worksheet.Cells[row, 17].Value = item.Address.Building;
                // worksheet.Cells[row, 18].Value = item.Address.Street;
                // worksheet.Cells[row, 19].Value = item.Address.Place;
                // worksheet.Cells[row, 20].Value = item.Address.City;
                // worksheet.Cells[row, 21].Value = item.Address.PinCode;

                row++;
            }

            worksheet.Cells[worksheet.Dimension.Address].Style.Border.Top.Style = ExcelBorderStyle.Thin;
            worksheet.Cells[worksheet.Dimension.Address].Style.Border.Left.Style = ExcelBorderStyle.Thin;
            worksheet.Cells[worksheet.Dimension.Address].Style.Border.Right.Style = ExcelBorderStyle.Thin;
            worksheet.Cells[worksheet.Dimension.Address].Style.Border.Bottom.Style = ExcelBorderStyle.Thin;

            // Save the Excel package to a memory stream
            using (var stream = new MemoryStream())
            {
                package.SaveAs(stream);
                return stream.ToArray();
            }
        }
    }
}

