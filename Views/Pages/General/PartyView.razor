@page "/party"
@using Newtonsoft.Json
@attribute [Authorize]
@inject AuthenticationStateProvider auth
@inject NavigationManager nav
@inject IPartyService Iservice
@inject IContactService Icontact
@inject MudBlazor.ISnackbar snackbar
@inject IDialogService DialogService

<MudGrid Spacing="4">
    <MudItem xs="12" md="12">
        <MudTable Items="@collection" Elevation="10" Filter="new Func<PartyModel, bool>(search)" @bind-model="model">
            <ToolBarContent>
                <MudText Typo="Typo.h6">List of Customers and Vendors</MudText>
                <MudIconButton Disabled="@_busy" Icon="@Icons.Material.Filled.Add" Title="Add" @onclick="(()=>Edit(new PartyModel()))" Color="Color.Dark" Size="Size.Small"></MudIconButton>
                <MudSpacer></MudSpacer>
                <MudTextField @bind-Value="searchParty" Placeholder="Search Partys... " Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0"></MudTextField>
            </ToolBarContent>
            <HeaderContent>
                <MudTh><MudTableSortLabel SortBy="new Func<PartyModel, object>(x=> x.RegName)" InitialDirection="SortDirection.Ascending">Party Name</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<PartyModel, object>(x=> x.NatureOfBusiness)" InitialDirection="SortDirection.Ascending">Nature</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<PartyModel, object>(x=> x.TdsApplicable)" InitialDirection="SortDirection.Ascending">TDS Applicable</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<PartyModel, object>(x=> x.PartyCode)" InitialDirection="SortDirection.Ascending">Party Code</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<PartyModel, object>(x=> x.TradeName)" InitialDirection="SortDirection.Ascending">Trade Name</MudTableSortLabel></MudTh>
                <MudTh>Actions</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Party">@context.RegName</MudTd>
                <MudTd DataLabel="Distance">@context.NatureOfBusiness</MudTd>
                <MudTd DataLabel="SpeedLimit">@context.TdsApplicable</MudTd>
                <MudTd DataLabel="RunningHours">@context.PartyCode</MudTd>
                <MudTd DataLabel="PartyType">@context.TradeName</MudTd>
                <MudTd DataLabel="">
                    <MudFab @onclick="@(()=> Edit(context))" Color="Color.Primary" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" IconSize="Size.Small" />
                    <MudFab @onclick="@(()=> Delete(context.PartyID))" Color="Color.Primary" Icon="@Icons.Material.Filled.Delete" Size="Size.Small" IconSize="Size.Small" />
                </MudTd>
            </RowTemplate>
            <PagerContent>
                <MudTablePager PageSizeOptions="new int[] { 5, 10, 20, 50, 100 }" />
            </PagerContent>
        </MudTable>
    </MudItem>
</MudGrid>

@code {

    private PartyModel model = new PartyModel();
    private List<PartyModel> collection = new List<PartyModel>();
    DialogOptions maxWidth = new DialogOptions() { MaxWidth = MaxWidth.Large, FullWidth = true };
    private List<string> PartyTypes = new List<string>() { "Proprietorship", "Partnership", "Company" };
    private bool _busy;
    private string searchParty = "";

    protected override async Task OnInitializedAsync()
    {
        GetAll();
    }

    private void GetAll()
    {
        foreach (var route in Iservice.Select(0))
        {
            collection.Add(route);
        }
    }

    private void AddContact()
    {
        model.Contacts.Add(new ContactModel()
            {
                RefTable = "PARTY"
            });
    }

    private async Task OnValidSubmit(EditContext context)
    {
        var authprov = await auth.GetAuthenticationStateAsync();
        model.UserInfo.UserID = authprov.User.Identity.Name;
        try
        {
            var contacts = model.Contacts;
            model = Iservice.Update(model);
            snackbar.Add("Saved Successfully", Severity.Success);
            if (collection.Exists(x => x.PartyID == model.PartyID))
            {
                collection[collection.FindIndex(x => x.PartyID == model.PartyID)] = model;
            }
            else
            {
                collection.Add(model);
            }
            foreach (var item in contacts)
            {
                item.RefKey = model.PartyID;
                item.UserInfo = model.UserInfo;
                Icontact.Update(item);
            }
            model = new PartyModel();
        }
        catch (Exception ex)
        {
            snackbar.Add(ex.Message, Severity.Warning);
        }
    }

    private async Task Edit(PartyModel model)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        _busy = true;
        DialogParameters parms = new DialogParameters();
        parms.Add("model", model.Clone());
        var dialog = DialogService.Show<PartyDilog>("ADD PARTY", parms, maxWidth);
        var result = await dialog.Result;

        // you can check if the modal was cancelled
        var isCancelled = result.Canceled;
        if (!isCancelled)
        {
            PartyModel UpatedModel = (PartyModel)result.Data;
            if (UpatedModel != null)
            {
                if (collection.Exists(x => x.PartyID == UpatedModel.PartyID))
                {
                    collection[collection.FindIndex(x => x.PartyID == UpatedModel.PartyID)] = UpatedModel;
                }
                else
                {
                    collection.Insert(0, UpatedModel);
                }
            }
            model = new();
        }
        await Task.Delay(200);
        _busy = false;
    }

    private async Task Delete(int? id)
    {
        var authprov = await auth.GetAuthenticationStateAsync();
        int result = Iservice.Delete(id, authprov.User.Identity.Name);
        if (result != -1)
        {
            if (collection != null && collection.Any(s => s.PartyID == id))
            {
                collection.Remove(collection.FirstOrDefault(s => s.PartyID == id));
                snackbar.Add("Deleted Successfully", Severity.Success);
            }
        }
    }

    private bool search(PartyModel model)
    {
        if (model.TradeName != null && model.TradeName.Contains(searchParty, StringComparison.OrdinalIgnoreCase))
        {
            return true;
        }
        return false;
    }
}