@inject ITruckService Iservice

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6"><b>@SelectedValue.ToUpper() TRUCKS</b> (Count: @Count)</MudText>
    </TitleContent>
    <DialogContent>
        <MudTable T="TruckStatusModel" Items="@truckStatus">
            <HeaderContent>
                <MudTh>Reg NO</MudTh>
                <MudTh>Event Time</MudTh>
                <MudTh>Duration</MudTh>
                <MudTh>Driver</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="TripNO">@context.RegNo</MudTd>
                <MudTd DataLabel="Driver">@context.EventTime</MudTd>
                <MudTd DataLabel="Diff">@context.EventDateTimeDiff</MudTd>
                <MudTd DataLabel="Diff">@context.DriverSince</MudTd>
            </RowTemplate>
            <PagerContent>
                <MudTablePager PageSizeOptions="new int[] { 10, 25, 50, 100 }" />
            </PagerContent>
        </MudTable>
    </DialogContent>
</MudDialog>

@code {

    [CascadingParameter]
    IMudDialogInstance MudDialog { get; set; }
    [Parameter]
    public int? BranchID { get; set; }
    [Parameter]
    public string SelectedValue { get; set; }
    [Parameter]
    public string Count{ get; set; }

    private List<TruckStatusModel> truckStatus = new List<TruckStatusModel>();

    protected override async Task OnInitializedAsync()
    {
        truckStatus = Iservice.GetTruckStatusByEvent(BranchID, SelectedValue).ToList();
    }
}
