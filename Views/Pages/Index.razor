@page "/"
@layout Views.Shared.LandingLayout
@using System.IO
@using Microsoft.JSInterop
@using Microsoft.AspNetCore.Components
@using Microsoft.AspNetCore.Hosting;
@inject AuthenticationStateProvider auth
@inject NavigationManager nav
@inject IAssetDocumentService AssetDocService
@inject MudBlazor.ISnackbar snackbar
@inject IJSRuntime JsRuntime
@inject IWebHostEnvironment _env;
@inject IDialogService DialogService
@using Views.Data;
@using System.Text;

@using System.Net;

<AuthorizeView>
    <Authorized>
        <!-- TopBanner: Force Z-Index Hierarchy (Outside all other wrappers) -->
        <div style="position: sticky; top: 0; z-index: 9999; width: 100%;">
            <Views.Shared.TopBanner ShowDrawerIcon="true" OnDrawerToggle="@ToggleDrawer" />
        </div>

        <!-- Background Layer -->
        <div class="fixed-background-light">
            <div class="mesh-gradient"></div>
            <div class="pattern-overlay"></div>
        </div>

        <!-- Content Container -->
        <div class="dashboard-wrapper">
             
             <!-- Side Drawer for Navigation -->
             <MudDrawer @bind-Open="@_drawerOpen" Elevation="1" Width="300px" Variant="@DrawerVariant.Temporary" Style="z-index: 10001;">
                 <MudDrawerHeader Class="d-flex align-center justify-center py-4">
                     <img src="images/thailogo.png" height="30" />
                 </MudDrawerHeader>
                 <MudNavMenu>
                      <Views.Shared.NavMenu IsOpen="@_drawerOpen" />
                 </MudNavMenu>
             </MudDrawer>

             <!-- Main Grid Content -->
             <MudContainer MaxWidth="MaxWidth.False" Class="py-12 px-8 flex-grow-1 d-flex flex-column justify-center relative z-10" Style="min-height: 90vh;">
                
                <!-- Header / Welcome Area -->
                <div class="d-flex flex-column align-center mb-8 header-animate">
                    <MudText Typo="Typo.h3" Class="mb-2" Style="font-weight: 800; color: #5E5873; text-transform: uppercase; letter-spacing: 2px;">
                        ARMS <span style="color: #FF9F43;">V2</span>
                    </MudText>
                    <MudText Typo="Typo.h6" Class="fade-text" Style="color: #6E6B7B; opacity: 0.9; font-weight: 400;">Transforming the future of logistics with seamless innovation</MudText>
                </div>

                <!-- Bento Grid -->
                <div class="bento-grid">
                    
                    <!-- 1. PLM -->
                    <div class="white-card" @onclick="@(() => nav.NavigateTo("/dashboard"))">
                         <div class="card-bg"></div>
                         <div class="card-content">
                             <div class="icon-box"><MudIcon Icon="@Icons.Material.Filled.LocalShipping" /></div>
                             <div class="card-text">
                                 <div class="card-title">Operations</div>
                                 <div class="card-desc">Manage Trips, Fleet, Consignment and Drivers</div>
                             </div>
                         </div>
                    </div>

                    <!-- 2. Supply Chain -->
                    <div class="white-card" @onclick="@(() => nav.NavigateTo("/newfinancedashboard"))">
                        <div class="card-bg"></div>
                        <div class="card-content">
                            <div class="icon-box"><MudIcon Icon="@Icons.Material.Filled.MonetizationOn" /></div>
                            <div class="card-text">
                                <div class="card-title">Finance</div>
                                <div class="card-desc">Track revenue and expenses and manage accounts</div>
                            </div>
                        </div>
                    </div>

                    <!-- 3. WMS -->
                    <div class="white-card" @onclick="@(() => nav.NavigateTo("/AssetSimpleView"))">
                        <div class="card-bg"></div>
                        <div class="card-content">
                            <div class="icon-box"><MudIcon Icon="@Icons.Material.Filled.HomeWork" /></div>
                            <div class="card-text">
                                <div class="card-title">Assets</div>
                                <div class="card-desc">Asset register, tracking and depreciation</div>
                            </div>
                        </div>
                    </div>

                    <!-- 4. Accounting -->
                    <div class="white-card" @onclick="@(() => nav.NavigateTo("/FreightBooking"))">
                        <div class="card-bg"></div>
                         <div class="card-content">
                            <div class="icon-box"><MudIcon Icon="@Icons.Material.Filled.ReceiptLong" /></div>
                            <div class="card-text">
                                <div class="card-title">Billing</div>
                                <div class="card-desc">Manage contracts, tariffs and generate invoices</div>
                            </div>
                        </div>
                    </div>
                    
                    <!-- 5. CRM -->
                    <div class="white-card" @onclick="@(() => nav.NavigateTo("/InventorySummaryReport"))">
                        <div class="card-bg"></div>
                        <div class="card-content">
                            <div class="icon-box"><MudIcon Icon="@Icons.Material.Filled.Warehouse" /></div>
                             <div class="card-text">
                                <div class="card-title">Inventory</div>
                                <div class="card-desc">Warehouse stocks, spares and purchase orders</div>
                            </div>
                        </div>
                    </div>

                    <!-- 6. E-Commerce -->
                    <div class="white-card" @onclick="@(() => nav.NavigateTo("/Breakdowns"))">
                        <div class="card-bg"></div>
                        <div class="card-content">
                            <div class="icon-box"><MudIcon Icon="@Icons.Material.Filled.Build" /></div>
                            <div class="card-text">
                                <div class="card-title">Maintenance</div>
                                <div class="card-desc">Workshop jobs, repairs and mechanics</div>
                            </div>
                        </div>
                    </div>
                    
                    <!-- 7. QMS -->
                    <div class="white-card" @onclick="@(() => nav.NavigateTo("/OperationSummaryReport"))">
                        <div class="card-bg"></div>
                        <div class="card-content">
                            <div class="icon-box"><MudIcon Icon="@Icons.Material.Filled.Analytics" /></div>
                            <div class="card-text">
                                <div class="card-title">Reports</div>
                                <div class="card-desc">Performance reports and data insights</div>
                            </div>
                        </div>
                    </div>

                    <!-- 8. Inventory -->
                    <div class="white-card" @onclick="@(() => nav.NavigateTo("/HelpCenter"))">
                        <div class="card-bg"></div>
                        <div class="card-content">
                            <div class="icon-box"><MudIcon Icon="@Icons.Material.Filled.TipsAndUpdates" /></div>
                            <div class="card-text">
                                <div class="card-title">Help Center</div>
                                <div class="card-desc">Documentation and support contacts</div>
                            </div>
                        </div>
                    </div>

                </div>
             </MudContainer>
        </div>
    </Authorized>
    
    <NotAuthorized>
         <!-- Re-use existing landing hero if needed, or update if user wants specific change here too. For now keeping existing. -->
       <div class="landing-hero" style="height: 100vh; width: 100%; background-color: #F8F9FA; display: flex; align-items: center; position: relative; overflow: hidden;">
            <div style="position: absolute; top: 0; right: 0; width: 60%; height: 100%; background-image: url('ArmsStaticFiles/Gemini_Generated_Image_52x78z52x78z52x7.png'); background-size: cover; background-position: center; clip-path: polygon(15% 0, 100% 0, 100% 100%, 0% 100%); z-index: 0;">
                <div style="width: 100%; height: 100%; "></div>
            </div>
            <MudContainer MaxWidth="MaxWidth.Large" Style="z-index: 10; padding-left: 2rem;">
                <MudGrid>
                    <MudItem xs="12" md="5" Class="d-flex flex-column justify-center" Style="height: 90vh;">
                        <div class="d-flex align-center gap-2 mb-6">
                            <MudIcon Icon="@Icons.Material.Filled.LocalShipping" Size="Size.Large" Style="color: #FF9F43; font-size: 2.5rem;" />
                            <MudText Typo="Typo.h4" Style="font-weight: 800; color: #5E5873; letter-spacing: 1px;">ARMS v2</MudText>
                        </div>
                        <MudText Typo="Typo.h1" Class="mb-4" Style="font-weight: 900; color: #1E1E2D; line-height: 1.1; font-size: 4rem;">The Future of <br/><span style="color: #FF9F43;">Logistics</span></MudText>
                        <MudText Typo="Typo.h5" Class="mb-8" Style="color: #6E6B7B;">Streamline your supply chain, track assets in real-time.</MudText>
                        <div class="d-flex gap-4">
                            <MudButton Variant="Variant.Filled" Size="Size.Large" Style="background-color: #FF9F43; color: white; padding: 16px 48px;" OnClick="@OpenLoginDialog">Login</MudButton>
                             <MudButton Variant="Variant.Outlined" Size="Size.Large" Style="color: #FF9F43; border-color: #FF9F43; padding: 16px 32px;" OnClick="@OpenRegisterDialog">Register</MudButton>
                        </div>
                    </MudItem>
                </MudGrid>
            </MudContainer>
        </div>
    </NotAuthorized>
</AuthorizeView>

<style>
    /* 1. Global Setup */
    .dashboard-wrapper {
        position: relative;
        z-index: 1;
        width: 100%;
        min-height: 100vh;
    }

    /* 2. Fixed Background (Renamed for Cache Busting) */
    .fixed-background-light {
        position: fixed;
        top: 0; left: 0; right: 0; bottom: 0;
        z-index: 0;
        background-color: #DDDD !important; /* Force Light Gray/White */
        overflow: hidden;
    }

    .mesh-gradient {
        position: absolute;
        top: -50%; left: -50%; width: 200%; height: 200%;
        background: 
            radial-gradient(circle at 50% 50%, rgba(255, 159, 67, 0.05) 0%, transparent 40%),
            radial-gradient(circle at 80% 20%, rgba(50, 40, 100, 0.03) 0%, transparent 40%),
            radial-gradient(circle at 20% 80%, rgba(100, 40, 60, 0.03) 0%, transparent 40%);
        animation: meshSpin 60s linear infinite;
    }

    .pattern-overlay {
        position: absolute;
        top: 0; left: 0; width: 100%; height: 100%;
        background-image: 
            linear-gradient(rgba(0,0,0,0.03) 1px, transparent 1px),
            linear-gradient(90deg, rgba(0,0,0,0.03) 1px, transparent 1px);
        background-size: 60px 60px;
        opacity: 0.6;
    }

    @@keyframes meshSpin {
        0% { transform: rotate(0deg); }
        100% { transform: rotate(360deg); }
    }

    /* 3. Bento Grid Layout */
    .bento-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: 24px;
        width: 100%;
        max-width: 1400px;
        margin: 0 auto;
        opacity: 0;
        animation: fadeInUp 0.8s ease-out 0.3s forwards;
    }

    /* 4. White Card (Renamed from Glass Card) */
    .white-card {
        position: relative;
        height: 180px;
        border-radius: 16px;
        overflow: hidden;
        cursor: pointer;
        transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
        border: 1px solid rgba(0,0,0,0.05);
        background: #FFFFFF !important;
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05), 0 2px 4px -1px rgba(0, 0, 0, 0.03);
    }

    /* Background Blur Layer - subtle shine on light mode */
    .white-card .card-bg {
        position: absolute;
        top: 0; left: 0; width: 100%; height: 100%;
        background: linear-gradient(135deg, rgba(255,255,255,0.4) 0%, rgba(255,255,255,0) 100%);
        z-index: 1;
        transition: all 0.4s ease;
    }

    /* Content Layer */
    .white-card .card-content {
        position: relative;
        z-index: 2;
        height: 100%;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        padding: 24px;
        text-align: center;
    }

    /* Hover Effects */
    .white-card:hover {
        transform: translateY(-5px);
        border-color: rgba(255, 159, 67, 0.4);
        box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.05), 0 10px 10px -5px rgba(0, 0, 0, 0.02);
    }

    .white-card:hover .card-bg {
        background: rgba(255, 159, 67, 0.02); 
    }

    /* Icon Styling */
    .icon-box {
        margin-bottom: 16px;
        color: #FF9F43;
        transition: all 0.4s ease;
    }
    
    .icon-box .mud-icon-root {
        font-size: 3.5rem;
        filter: drop-shadow(0 4px 6px rgba(255, 159, 67, 0.2));
    }

    .white-card:hover .icon-box {
        transform: scale(1.1);
        color: #FF9F43;
        filter: drop-shadow(0 4px 12px rgba(255, 159, 67, 0.4));
    }

    /* Text Styling */
    .card-title {
        color: #5E5873; /* Darker Text */
        font-family: 'Inter', sans-serif;
        font-weight: 800;
        font-size: 1.25rem;
        letter-spacing: 0.5px;
        margin-bottom: 4px;
        text-transform: uppercase;
    }

    .card-desc {
        color: #6E6B7B;
        font-size: 0.85rem;
        font-weight: 500;
    }
    
    .white-card:hover .card-title {
        color: #FF9F43;
    }
    
    .white-card:hover .card-desc {
        color: #5E5873;
    }

    /* Animations */
    @@keyframes fadeInUp {
        from { opacity: 0; transform: translateY(30px); }
        to { opacity: 1; transform: translateY(0); }
    }
    
    .header-animate {
        animation: fadeInDown 0.8s ease-out forwards;
    }

    @@keyframes fadeInDown {
        from { opacity: 0; transform: translateY(-30px); }
        to { opacity: 1; transform: translateY(0); }
    }
    
    /* Responsive Adjustments */
    @@media (min-width: 1600px) {
        .bento-grid {
             grid-template-columns: repeat(4, 1fr);
        }
    }
    
    /* Ensure the existing banner floats correctly */
    .banner-wrapper {
        position: relative;
        z-index: 1400; /* Must be higher than MudDrawer (1300) */
    }

    .landing-hero { font-family: 'Inter', sans-serif; }
</style>

@code {
    protected override async Task OnInitializedAsync()
    {
        base.OnInitialized();
    }
    
    // Sidebar State
    private bool _drawerOpen = false;

    private void ToggleDrawer()
    {
        _drawerOpen = !_drawerOpen;
        StateHasChanged();
    }

    private void OpenLoginDialog()
    {
        var options = new DialogOptions { CloseOnEscapeKey = false, BackdropClick = false, FullScreen = true, CloseButton = false }; 
        DialogService.Show<Views.Pages.UserAccount.LoginDialog>("", options);
    }

    private void OpenRegisterDialog()
    {
        var options = new DialogOptions { CloseOnEscapeKey = false, BackdropClick = false, FullScreen = true, CloseButton = false };
        DialogService.Show<Views.Pages.UserAccount.RegisterDialog>("", options);
    }
}
