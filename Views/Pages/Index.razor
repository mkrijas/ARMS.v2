    </NotAuthorized>
</AuthorizeView>

<style>
    /* 3. Bento Grid Layout */
    .bento-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: 24px;
        width: 100%;
        max-width: 1400px;
        margin: 0 auto;
        opacity: 0;
        animation: fadeInUp 0.8s ease-out 0.3s forwards;
    }

    /* 4. White Card (Renamed from Glass Card) */
    .white-card {
        position: relative;
        height: 180px;
        border-radius: 16px;
        overflow: hidden;
        cursor: pointer;
        transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
        border: 1px solid rgba(0,0,0,0.05);
        background: #FFFFFF !important;
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05), 0 2px 4px -1px rgba(0, 0, 0, 0.03);
    }

    /* Background Blur Layer - subtle shine on light mode */
    .white-card .card-bg {
        position: absolute;
        top: 0; left: 0; width: 100%; height: 100%;
        background: linear-gradient(135deg, rgba(255,255,255,0.4) 0%, rgba(255,255,255,0) 100%);
        z-index: 1;
        transition: all 0.4s ease;
    }

    /* Content Layer */
    .white-card .card-content {
        position: relative;
        z-index: 2;
        height: 100%;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        padding: 24px;
        text-align: center;
    }

    /* Hover Effects */
    .white-card:hover {
        transform: translateY(-5px);
        border-color: rgba(255, 159, 67, 0.4);
        box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.05), 0 10px 10px -5px rgba(0, 0, 0, 0.02);
    }

    .white-card:hover .card-bg {
        background: rgba(255, 159, 67, 0.02); 
    }

    /* Icon Styling */
    .icon-box {
        margin-bottom: 16px;
        color: #FF9F43;
        transition: all 0.4s ease;
    }
    
    .icon-box .mud-icon-root {
        font-size: 3.5rem;
        filter: drop-shadow(0 4px 6px rgba(255, 159, 67, 0.2));
    }

    .white-card:hover .icon-box {
        transform: scale(1.1);
        color: #FF9F43;
        filter: drop-shadow(0 4px 12px rgba(255, 159, 67, 0.4));
    }

    /* Text Styling */
    .card-title {
        color: #5E5873; /* Darker Text */
        font-family: 'Inter', sans-serif;
        font-weight: 800;
        font-size: 1.25rem;
        letter-spacing: 0.5px;
        margin-bottom: 4px;
        text-transform: uppercase;
    }

    .card-desc {
        color: #6E6B7B;
        font-size: 0.85rem;
        font-weight: 500;
    }
    
    .white-card:hover .card-title {
        color: #FF9F43;
    }
    
    .white-card:hover .card-desc {
        color: #5E5873;
    }

    /* Animations */
    @@keyframes fadeInUp {
        from { opacity: 0; transform: translateY(30px); }
        to { opacity: 1; transform: translateY(0); }
    }
    
    .header-animate {
        animation: fadeInDown 0.8s ease-out forwards;
    }

    @@keyframes fadeInDown {
        from { opacity: 0; transform: translateY(-30px); }
        to { opacity: 1; transform: translateY(0); }
    }
    
    /* Responsive Adjustments */
    @@media (min-width: 1600px) {
        .bento-grid {
             grid-template-columns: repeat(4, 1fr);
        }
    }
    
    /* Ensure the existing banner floats correctly */
    .banner-wrapper {
        position: relative;
        z-index: 1400; /* Must be higher than MudDrawer (1300) */
    }

    .landing-hero { font-family: 'Inter', sans-serif; }
</style>

@implements IAsyncDisposable

@code {
    private DotNetObjectReference<Index>? _objRef;
    private bool _isDialogOpen = false;

    protected override async Task OnInitializedAsync()
    {
        base.OnInitialized();
        var authState = await auth.GetAuthenticationStateAsync();
        bool Isauthenticated = (authState.User.Identity.IsAuthenticated);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _objRef = DotNetObjectReference.Create(this);
            await JsRuntime.InvokeVoidAsync("BlazorHelpers.addEnterKeyListener", _objRef);
        }
    }

    [JSInvokable]
    public async Task OnEnterKeyPressed()
    {
        // Guard 1: Verify user is not already logged in
        var authState = await auth.GetAuthenticationStateAsync();
        if (authState.User.Identity.IsAuthenticated) return;

        // Guard 2: Prevent opening if already open
        if (_isDialogOpen) return;

        await OpenLoginDialog();
    }

    private async Task OpenLoginDialog()
    {
        if (_isDialogOpen) return;
        _isDialogOpen = true;

        var options = new DialogOptions { CloseOnEscapeKey = false, BackdropClick = false, FullScreen = true, CloseButton = false }; 
        var dialog = DialogService.Show<Views.Pages.UserAccount.LoginDialog>("", options);
        var result = await dialog.Result;

        _isDialogOpen = false;
    }

    private void OpenRegisterDialog()
    {
        var options = new DialogOptions { CloseOnEscapeKey = false, BackdropClick = false, FullScreen = true, CloseButton = false };
        DialogService.Show<Views.Pages.UserAccount.RegisterDialog>("", options);
    }

    public async ValueTask DisposeAsync()
    {
        // Use try-catch for robustness, but awaiting ensures the call is tracked
        try
        {
            await JsRuntime.InvokeVoidAsync("BlazorHelpers.removeEnterKeyListener");
        }
        catch (Exception ex) when (ex is JSDisconnectedException || ex is OperationCanceledException)
        {
            // Expected exceptions when the user navigates away or closes the tab
        }
        catch (Exception)
        {
            // Silently ignore other errors during disposal
        }
        
        _objRef?.Dispose();
    }
}
