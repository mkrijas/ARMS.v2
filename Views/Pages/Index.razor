                    </div>
                    
                    <!-- 5. CRM -->
                    <div class="white-card" @onclick="@(() => nav.NavigateTo("/inventorydashboard"))">
                        <div class="card-bg"></div>
                        <div class="card-content">
                            <div class="icon-box"><MudIcon Icon="@Icons.Material.Filled.Warehouse" /></div>
