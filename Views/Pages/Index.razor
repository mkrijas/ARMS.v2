@page "/"
@layout Views.Shared.LandingLayout
@using System.IO
@using Microsoft.JSInterop
@using Microsoft.AspNetCore.Components
@using Microsoft.AspNetCore.Hosting;
@inject AuthenticationStateProvider auth
@inject NavigationManager nav
@inject IAssetDocumentService AssetDocService
@inject MudBlazor.ISnackbar snackbar
@inject IJSRuntime JsRuntime
@inject IWebHostEnvironment _env;
@using Views.Data;
@using System.Text;
@using System.Net;

<AuthorizeView>
    <Authorized>
        <!-- Dashboard View (Logged In) -->
        <!-- We use MainLayout usually for dashboard, but since we are forcing LandingLayout here, 
             we might need to redirect to a different dashboard page or manually add header if they are logged in. 
             OR, better, just show the welcome banner essentially as a standalone dashboard. -->
        
        <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-8 mb-8">
            
            <!-- Hero Welcome Section -->
            <div class="mb-10 px-6 py-8 d-flex flex-column justify-center" 
                 style="background: linear-gradient(135deg, #FF9F43 0%, #ffb36b 100%); border-radius: 16px; color: white; box-shadow: 0 10px 30px rgba(255, 159, 67, 0.3);">
                <MudText Typo="Typo.h3" Style="font-weight: 800; letter-spacing: 0.5px;">Welcome Back, @context.User.Identity.Name</MudText>
                <MudText Typo="Typo.subtitle1" Class="mt-2" Style="opacity: 0.9;">Here's what's happening with your fleet today.</MudText>
                
                <div class="d-flex gap-4 mt-6">
                    <div class="d-flex align-center rounded-lg px-4 py-2" style="background-color: white; box-shadow: 0 4px 6px rgba(0,0,0,0.1);">
                        <MudIcon Icon="@Icons.Material.Filled.LocalShipping" Class="mr-2" Style="color: #FF9F43;" />
                        <MudText Typo="Typo.body2" Style="font-weight: 700; color: #FF9F43;">Active Trips: 24</MudText>
                    </div>
                     <div class="d-flex align-center rounded-lg px-4 py-2" style="background-color: white; box-shadow: 0 4px 6px rgba(0,0,0,0.1);">
                        <MudIcon Icon="@Icons.Material.Filled.Warning" Class="mr-2" Style="color: #FF9F43;" />
                        <MudText Typo="Typo.body2" Style="font-weight: 700; color: #FF9F43;">Alerts: 3</MudText>
                    </div>
                </div>
            </div>

            <MudGrid Class="px-4" Spacing="4">
                <!-- Operations (Amber) -->
                <MudItem xs="12" sm="6" md="4" lg="3">
                    <MudPaper Class="d-flex flex-column pa-6 quick-action-card hover-lift" 
                              Style="cursor: pointer; height: 220px; border-radius: 16px; background: white; border-bottom: 4px solid #FF9F43;"
                              @onclick="@(() => nav.NavigateTo("/operations"))">
                        <div class="d-flex justify-space-between align-start w-100 mb-2">
                             <MudAvatar Style="background-color: rgba(255, 159, 67, 0.1); color: #FF9F43; width: 72px; height: 72px;">
                                <MudIcon Icon="@Icons.Material.Filled.LocalShipping" Style="font-size: 3rem;" />
                            </MudAvatar>
                            <MudIconButton Icon="@Icons.Material.Filled.ArrowForward" Size="Size.Small" Color="Color.Default" />
                        </div>
                        <div class="d-flex flex-column align-center w-100 mt-2">
                             <MudText Typo="Typo.h5" Style="font-weight: 800; color: #5E5873;">Operations</MudText>
                             <MudText Typo="Typo.body1" Class="mt-1" Style="color: #6E6B7B;">Manage trips & fleet</MudText>
                        </div>
                    </MudPaper>
                </MudItem>

                 <!-- Finance (Green) -->
                <MudItem xs="12" sm="6" md="4" lg="3">
                    <MudPaper Class="d-flex flex-column pa-6 quick-action-card hover-lift" 
                              Style="cursor: pointer; height: 220px; border-radius: 16px; background: white; border-bottom: 4px solid #28C76F;"
                              @onclick="@(() => nav.NavigateTo("/financedashboard"))">
                        <div class="d-flex justify-space-between align-start w-100 mb-2">
                             <MudAvatar Style="background-color: rgba(40, 199, 111, 0.1); color: #28C76F; width: 72px; height: 72px;">
                                <MudIcon Icon="@Icons.Material.Filled.AttachMoney" Style="font-size: 3rem;" />
                            </MudAvatar>
                             <MudIconButton Icon="@Icons.Material.Filled.ArrowForward" Size="Size.Small" Color="Color.Default" />
                        </div>
                        <div class="d-flex flex-column align-center w-100 mt-2">
                             <MudText Typo="Typo.h5" Style="font-weight: 800; color: #5E5873;">Finance</MudText>
                             <MudText Typo="Typo.body1" Class="mt-1" Style="color: #6E6B7B;">Revenue & accounts</MudText>
                        </div>
                    </MudPaper>
                </MudItem>

                 <!-- Inventory (Blue) -->
                <MudItem xs="12" sm="6" md="4" lg="3">
                    <MudPaper Class="d-flex flex-column pa-6 quick-action-card hover-lift" 
                              Style="cursor: pointer; height: 220px; border-radius: 16px; background: white; border-bottom: 4px solid #00CFE8;"
                              @onclick="@(() => nav.NavigateTo("/InventorySummaryReport"))">
                        <div class="d-flex justify-space-between align-start w-100 mb-2">
                             <MudAvatar Style="background-color: rgba(0, 207, 232, 0.1); color: #00CFE8; width: 72px; height: 72px;">
                                <MudIcon Icon="@Icons.Material.Filled.Inventory2" Style="font-size: 3rem;" />
                            </MudAvatar>
                             <MudIconButton Icon="@Icons.Material.Filled.ArrowForward" Size="Size.Small" Color="Color.Default" />
                        </div>
                        <div class="d-flex flex-column align-center w-100 mt-2">
                             <MudText Typo="Typo.h5" Style="font-weight: 800; color: #5E5873;">Inventory</MudText>
                             <MudText Typo="Typo.body1" Class="mt-1" Style="color: #6E6B7B;">Stock & stores</MudText>
                        </div>
                    </MudPaper>
                </MudItem>
                
                 <!-- Assets (Purple) -->
                <MudItem xs="12" sm="6" md="4" lg="3">
                     <MudPaper Class="d-flex flex-column pa-6 quick-action-card hover-lift" 
                              Style="cursor: pointer; height: 220px; border-radius: 16px; background: white; border-bottom: 4px solid #7367F0;"
                              @onclick="@(() => nav.NavigateTo("/AssetSimpleView"))">
                        <div class="d-flex justify-space-between align-start w-100 mb-2">
                             <MudAvatar Style="background-color: rgba(115, 103, 240, 0.1); color: #7367F0; width: 72px; height: 72px;">
                                <MudIcon Icon="@Icons.Material.Filled.DevicesOther" Style="font-size: 3rem;" />
                            </MudAvatar>
                             <MudIconButton Icon="@Icons.Material.Filled.ArrowForward" Size="Size.Small" Color="Color.Default" />
                        </div>
                        <div class="d-flex flex-column align-center w-100 mt-2">
                             <MudText Typo="Typo.h5" Style="font-weight: 800; color: #5E5873;">Assets</MudText>
                             <MudText Typo="Typo.body1" Class="mt-1" Style="color: #6E6B7B;">Tracking & register</MudText>
                        </div>
                    </MudPaper>
                </MudItem>

                 <!-- Maintenance (Red) -->
                <MudItem xs="12" sm="6" md="4" lg="3">
                     <MudPaper Class="d-flex flex-column pa-6 quick-action-card hover-lift" 
                              Style="cursor: pointer; height: 220px; border-radius: 16px; background: white; border-bottom: 4px solid #EA5455;"
                              @onclick="@(() => nav.NavigateTo("/jobcards"))">
                        <div class="d-flex justify-space-between align-start w-100 mb-2">
                             <MudAvatar Style="background-color: rgba(234, 84, 85, 0.1); color: #EA5455; width: 72px; height: 72px;">
                                <MudIcon Icon="@Icons.Material.Filled.Handyman" Style="font-size: 3rem;" />
                            </MudAvatar>
                             <MudIconButton Icon="@Icons.Material.Filled.ArrowForward" Size="Size.Small" Color="Color.Default" />
                        </div>
                        <div class="d-flex flex-column align-center w-100 mt-2">
                             <MudText Typo="Typo.h5" Style="font-weight: 800; color: #5E5873;">Maintenance</MudText>
                             <MudText Typo="Typo.body1" Class="mt-1" Style="color: #6E6B7B;">Jobs & repairs</MudText>
                        </div>
                    </MudPaper>
                </MudItem>
                
                <!-- Reports (Dark) -->
                <MudItem xs="12" sm="6" md="4" lg="3">
                     <MudPaper Class="d-flex flex-column pa-6 quick-action-card hover-lift" 
                              Style="cursor: pointer; height: 220px; border-radius: 16px; background: white; border-bottom: 4px solid #4B4B4B;"
                              @onclick="@(() => nav.NavigateTo("/TripEventsReport"))">
                        <div class="d-flex justify-space-between align-start w-100 mb-2">
                             <MudAvatar Style="background-color: rgba(75, 75, 75, 0.1); color: #4B4B4B; width: 72px; height: 72px;">
                                <MudIcon Icon="@Icons.Material.Filled.Analytics" Style="font-size: 3rem;" />
                            </MudAvatar>
                             <MudIconButton Icon="@Icons.Material.Filled.ArrowForward" Size="Size.Small" Color="Color.Default" />
                        </div>
                        <div class="d-flex flex-column align-center w-100 mt-2">
                             <MudText Typo="Typo.h5" Style="font-weight: 800; color: #5E5873;">Reports</MudText>
                             <MudText Typo="Typo.body1" Class="mt-1" Style="color: #6E6B7B;">Analytics & data</MudText>
                        </div>
                    </MudPaper>
                </MudItem>
                
                 <!-- Help (Gray) -->
                <MudItem xs="12" sm="6" md="4" lg="3">
                     <MudPaper Class="d-flex flex-column pa-6 quick-action-card hover-lift" 
                              Style="cursor: pointer; height: 220px; border-radius: 16px; background: white; border-bottom: 4px solid #A8AAAE;"
                              @onclick="@(() => nav.NavigateTo("/HelpCenter"))">
                        <div class="d-flex justify-space-between align-start w-100 mb-2">
                             <MudAvatar Style="background-color: rgba(168, 170, 174, 0.1); color: #5E5873; width: 72px; height: 72px;">
                                <MudIcon Icon="@Icons.Material.Filled.SupportAgent" Style="font-size: 3rem;" />
                            </MudAvatar>
                             <MudIconButton Icon="@Icons.Material.Filled.ArrowForward" Size="Size.Small" Color="Color.Default" />
                        </div>
                        <div class="d-flex flex-column align-center w-100 mt-2">
                             <MudText Typo="Typo.h5" Style="font-weight: 800; color: #5E5873;">Help</MudText>
                             <MudText Typo="Typo.body1" Class="mt-1" Style="color: #6E6B7B;">Support & docs</MudText>
                        </div>
                    </MudPaper>
                </MudItem>

            </MudGrid>
        </MudContainer>
    </Authorized>
    
    <NotAuthorized>
        <!-- Public Landing (Logistics Hero) -->
        <div class="landing-hero" style="height: 100vh; width: 100vw; background-color: #F8F9FA; display: flex; align-items: center; position: relative; overflow: hidden;">
            
            <!-- Dynamic Background (Split) -->
            <!-- Using bgImage.jpg with strong blur/overlay for abstract look (User disliked Truck.jpg) -->
            <div style="position: absolute; top: 0; right: 0; width: 60%; height: 100%; background-image: url('ArmsStaticFiles/Gemini_Generated_Image_52x78z52x78z52x7.png'); background-size: cover; background-position: center; clip-path: polygon(15% 0, 100% 0, 100% 100%, 0% 100%); z-index: 0;">
                <div style="width: 100%; height: 100%; "></div>
            </div>

            <MudContainer MaxWidth="MaxWidth.Large" Style="z-index: 10; padding-left: 2rem;">
                <MudGrid>
                    <MudItem xs="12" md="5" Class="d-flex flex-column justify-center" Style="height: 90vh;">
                        <div class="d-flex align-center gap-2 mb-6">
                            <MudIcon Icon="@Icons.Material.Filled.LocalShipping" Size="Size.Large" Style="color: #FF9F43; font-size: 2.5rem;" />
                            <MudText Typo="Typo.h4" Style="font-weight: 800; color: #5E5873; letter-spacing: 1px;">ARMS v2</MudText>
                        </div>

                        <MudText Typo="Typo.h1" Class="mb-4" Style="font-weight: 900; color: #1E1E2D; line-height: 1.1; font-size: 4rem;">
                            The Future of <br/>
                            <span style="color: #FF9F43; background: linear-gradient(120deg, rgba(255,159,67,0.2) 0%, transparent 100%); padding-left: 10px;">Logistics</span>
                        </MudText>

                        <MudText Typo="Typo.h5" Class="mb-8" Style="color: #6E6B7B; font-weight: 400; max-width: 500px; line-height: 1.6;">
                            Streamline your supply chain, track assets in real-time, and optimize fleet performance.
                        </MudText>

                        <div class="d-flex gap-4">
                            <MudButton Variant="Variant.Filled" Size="Size.Large" 
                                       Style="background-color: #FF9F43; color: white; border-radius: 8px; padding: 16px 48px; font-weight: 700; font-size: 1.1rem; box-shadow: 0 10px 25px rgba(255, 159, 67, 0.4); text-transform: none;"
                                       OnClick="@(() => nav.NavigateTo("/login", true))">
                                Login
                            </MudButton>
                            <!-- Removed Register button if not needed, or add it if requested. User said "login and register button are not visible" -->
                             <MudButton Variant="Variant.Outlined" Size="Size.Large" 
                                       Style="color: #FF9F43; border-color: #FF9F43; border-radius: 8px; font-weight: 600; padding: 16px 32px; text-transform: none;"
                                       Link="#" Target="_blank">
                                Register
                            </MudButton>
                        </div>

                        <div class="mt-12 d-flex gap-8">
                             <div class="d-flex align-center gap-3">
                                <MudAvatar Size="Size.Small" Style="background: rgba(255,159,67,0.1); color: #FF9F43;">
                                    <MudIcon Icon="@Icons.Material.Filled.Check" Size="Size.Small"/>
                                </MudAvatar>
                                <MudText Typo="Typo.body2" Style="font-weight: 600; color: #5E5873;">Real-time Tracking</MudText>
                            </div>
                            <div class="d-flex align-center gap-3">
                                <MudAvatar Size="Size.Small" Style="background: rgba(255,159,67,0.1); color: #FF9F43;">
                                    <MudIcon Icon="@Icons.Material.Filled.Check" Size="Size.Small"/>
                                </MudAvatar>
                                <MudText Typo="Typo.body2" Style="font-weight: 600; color: #5E5873;">Fleet Management</MudText>
                            </div>
                        </div>

                    </MudItem>
                </MudGrid>
            </MudContainer>
        </div>
    </NotAuthorized>
</AuthorizeView>

<style>
    .quick-action-card {
        transition: all 0.3s ease;
        border: 1px solid transparent;
    }
    .quick-action-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 15px 30px rgba(0,0,0,0.08) !important;
        border-color: #FF9F43;
    }
    .landing-hero {
        font-family: 'Inter', sans-serif;
    }
</style>

@code {
    protected override async Task OnInitializedAsync()
    {
        base.OnInitialized();
    }
}
