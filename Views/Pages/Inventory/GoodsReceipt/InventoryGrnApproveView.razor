@inject IInventoryGrnService Iservice

@inject MudBlazor.ISnackbar snackbar
@inject AuthenticationStateProvider auth
@attribute [Authorize]
@inject IDialogService DialogService

<MudDialog>
   
    <DialogContent>
        <MudContainer Style="min-height:300px;max-height: 450px;overflow-y: scroll">
     
<MudGrid Spacing="4">
   <MudItem xs="12">
        <MudTable Items="@collection"   Dense="true" Hover="true"  Striped="true" Elevation="10" Filter="new Func<InventoryGrnModel, bool>(search)"  @bind-place="model">           
             <ToolBarContent>
                <MudText Typo="Typo.h6">Inventory GRN</MudText>
                <MudSpacer></MudSpacer>
                 <MudTextField @bind-Value="searchPurchase" Placeholder="Search Purchase order... "
                              Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                              IconSize="Size.Medium" Class="mt-0"></MudTextField>
          
            </ToolBarContent>
             <HeaderContent>
                <MudTh><MudTableSortLabel SortBy="new Func<InventoryGrnModel, object>(x=> x.GrnNo)" InitialDirection="SortDirection.Ascending">GrnNo</MudTableSortLabel></MudTh>
             <MudTh><MudTableSortLabel SortBy="new Func<InventoryGrnModel, object>(x=> x.EntryDate)" InitialDirection="SortDirection.Ascending">EntryDate</MudTableSortLabel></MudTh>
               <MudTh><MudTableSortLabel SortBy="new Func<InventoryGrnModel, object>(x=> x.PartyName)" InitialDirection="SortDirection.Ascending">Party</MudTableSortLabel></MudTh>
                
                <MudTh>Actions</MudTh>
            </HeaderContent>
          

            <RowTemplate>   
               <MudTd DataLabel="GrnNO">@context.GrnNo</MudTd>
                <MudTd DataLabel="EntryDate">@context.EntryDate?.ToShortDateString()</MudTd>
                <MudTd DataLabel="Party">@context.PartyName</MudTd>
                 
                <MudTd DataLabel="">
                   
                      <MudFab @onclick="@(()=> View(context))" Color="Color.Success" Icon="@Icons.Material.Filled.GridView" title="View" Size="Size.Small" IconSize="Size.Small" />
                                          


                    </MudTd>
            </RowTemplate>
            <PagerContent>
                <MudTablePager PageSizeOptions="new int[] { 5, 10, 20, 50, 100 }" />
            </PagerContent>
        </MudTable>
    </MudItem>
    </MudGrid>
        </MudContainer>
        </DialogContent>
        </MudDialog>

@code {




    [Parameter]
    public InventoryGrnModel model { get; set; }

    private List<InventoryGrnModel> collection = new List<InventoryGrnModel>();
    DialogOptions maxWidth = new DialogOptions() { MaxWidth = MaxWidth.Medium, FullWidth = true };
    private string searchPurchase = "";


    protected override async Task OnInitializedAsync()
    {
        model = new();
        GetAll();//View only approved
    }
    private  async Task GetAll()
    {
        var authprov = await auth.GetAuthenticationStateAsync();
        var brancIDString = authprov.User.Claims.First(x => x.Type == "BranchID").Value;
        int brancID = int.Parse(brancIDString);
        collection = new List<InventoryGrnModel>();
        foreach (var item in Iservice.SelectPending(brancID))
        {

            collection.Add(item);
        }


    }
    public void View(InventoryGrnModel pm)
    {
        DialogParameters parms = new DialogParameters();
        parms.Add("model",pm);
        var dialog =  DialogService.Show<InventoryGrnDialog>(pm.GrnID == null?"ADD":"EDIT",parms,maxWidth);
        
    }
    private bool search(InventoryGrnModel tds)
    {
        if (tds.GrnNo != null && tds.GrnNo.Contains(searchPurchase, StringComparison.OrdinalIgnoreCase))
        {
            return true;
        }
        else if (tds.GrnNo == null)
            return true;
        return false;
    }

}
