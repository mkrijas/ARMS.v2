@using System.Threading;
@using Views.Pages.Finance.Transactions
@inject IInventoryGrnService Iservice
@inject IPartyService partyIservice
@inject IInventoryItemService itemIservice
@inject IStoreService storeIservice
@inject IPurchaseOrderService pIservice
@inject IGstItemService gstIservice
@inject MudBlazor.ISnackbar snackbar
@inject AuthenticationStateProvider auth
@inject IRoleService<RoleModel> Irole
@attribute [Authorize]
@inject IDialogService DialogService

<MudDialog Class="admin-dialog-glass">
    <TitleContent>
        <div class="header-section mb-2 pt-4 px-4">
            <div class="d-flex align-center justify-space-between">
                <div class="d-flex align-center">
                    <div class="icon-badge primary-badge mr-4">
                        <div class="admin-header-icon-badge mb-3">
                            <MudIcon Icon="@Icons.Material.Filled.Build" Color="Color.Secondary" Style="font-size: 3rem;" />
                        </div>
                    </div>
                    <div>
                        <MudText Typo="Typo.h5" Class="admin-title"><b>Goods Receipt Note</b></MudText>
                        <MudText Typo="Typo.body2" Class="admin-subtitle">Record received inventory items and update stock levels.</MudText>
                    </div>
                </div>
            </div>
            <div class="title-accent mt-4"></div>
        </div>
    </TitleContent>
    <DialogContent>
        <MudContainer Class="admin-dialog-container">
            <div class="dialog-content-wrapper pa-4">
                <EditForm id="formtdsRate" Model="@model" OnValidSubmit="OnValidSubmit">
                    <ObjectGraphDataAnnotationsValidator />
                    
                    <div class="admin-glass-card pa-6 mb-6">
                        <div class="d-flex align-center mb-6">
                            <MudIcon Icon="@Icons.Material.Filled.Info" Color="Color.Primary" Class="mr-2" />
                            <span class="admin-section-label mb-0">General Information</span>
                        </div>
                        <MudGrid Spacing="3">
                            <MudItem xs="12">
                                 <PartySelector For="@(() => partyinfo)" ReadOnly="ReadOnly" Value="partyinfo" ValueChanged="PartyChanged" NatureOfBusiness="Supplier" BranchID="branchID" IncludeSisterConcern Class="admin-input-group"></PartySelector>
                            </MudItem>
                            <MudItem xs="12" md="4">
                                <MudDatePicker ReadOnly="ReadOnly" Label="Entry Date" Variant="Variant.Outlined" Margin="Margin.Dense" DisableToolbar="true" Editable="true" @bind-Date="model.EntryDate" DateFormat="dd/MM/yyyy" Class="admin-input-group" />
                            </MudItem>
                            <MudItem xs="12" md="4">
                                <MudTextField ReadOnly="ReadOnly" @bind-Value="model.Reference" Label="Reference" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.Reference)" Class="admin-input-group"></MudTextField>
                            </MudItem>
                            <MudItem xs="12" md="4">
                                 <StoreSelector For="@(() => model.Store)" IsDisabled="ReadOnly" @bind-Value="model.Store" VariantParameter="Variant.Outlined" MarginParameter="Margin.Dense" BranchID="@(branchID ?? 0)" Class="admin-input-group"></StoreSelector>
                            </MudItem>
                            <MudItem xs="12">
                                <MudTextField ReadOnly="ReadOnly" @bind-Value="model.Remarks" Label="Remarks / Description" Variant="Variant.Outlined" Margin="Margin.Dense" Lines="2" For="@(() => model.Remarks)" Class="admin-input-group"></MudTextField>
                            </MudItem>
                        </MudGrid>
                    </div>

                    <div class="admin-glass-card pa-0 overflow-hidden mb-6">
                        <div class="px-6 py-4 border-bottom-subtle d-flex align-center" style="background: rgba(255, 159, 67, 0.03); border-bottom: 1px solid rgba(255, 159, 67, 0.3);">
                            <MudIcon Icon="@Icons.Material.Filled.Inventory" Color="Color.Warning" Class="mr-2" />
                            <span class="admin-section-label mb-0">Items Received</span>
                        </div>
                        <div class="modern-admin-table">
                            <MudSimpleTable Style="width:100%" Hover="true" FixedHeader="true" Dense="true" Elevation="0">
                                <thead>
                                    <tr>
                                        <th style="width: 40%">ITEM DETAILS</th>
                                        <th>QUANTITY</th>
                                        <th>RATE</th>
                                        <th>GST</th>
                                        <th style="width: 50px"></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in model.Entries)
                                    {
                                        var itemInfo = itm.FirstOrDefault(x => x.InventoryItemID == item.ItemID);
                                        <tr>
                                            <td>
                                                <div class="d-flex flex-column">
                                                    <MudText Typo="Typo.body2" Class="fw-bold">@itemInfo?.InventoryItemCode | @itemInfo?.ItemDescription</MudText>
                                                    <MudText Typo="Typo.caption" Class="mud-text-secondary">@itemInfo?.ItemGroup?.ItemGroupDescription | PN: @itemInfo?.PartNumber</MudText>
                                                </div>
                                            </td>
                                            <td>
                                                @if (!ReadOnly)
                                                {
                                                    <div class="d-flex align-center">
                                                        <MudNumericField Immediate=true T="decimal" Value="@item.ItemQty" ValueChanged="@(e => CalculateAndDisplay(e, @item))" 
                                                                         Variant="Variant.Outlined" Margin="Margin.Dense" Class="admin-input-group" Style="max-width: 120px" HideSpinButtons />
                                                        <MudText Typo="Typo.caption" Class="ml-2">@item.UOM</MudText>
                                                    </div>
                                                }
                                                else
                                                {
                                                    <MudText Typo="Typo.body2">@item.ItemQty <span class="mud-text-secondary">@item.UOM</span></MudText>
                                                }
                                            </td>
                                            <td>@item.ItemRate?.ToString("N2")</td>
                                            <td>@item.ItemGstVal?.ToString("N2")</td>
                                            <td>
                                                @if (!ReadOnly)
                                                {
                                                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small" OnClick="@(()=> Delete(@item))" />
                                                }
                                            </td>
                                        </tr>
                                    }
                                    @if (!ReadOnly && model.POID == null)
                                    {
                                        <tr style="background: rgba(54, 117, 136, 0.05);">
                                            <td>
                                                 <InventoryItemSelector For="@(() => SelectedItem)" Value="SelectedItem" ValueChanged="@((InventoryItemModel newValue) => ItemChanged(newValue))" Class="admin-input-group" />
                                            </td>
                                            <td>
                                                <div class="d-flex align-center">
                                                    <MudNumericField @bind-Value="Entrymodel.ItemQty" Variant="Variant.Outlined" Margin="Margin.Dense" Class="admin-input-group" Style="max-width: 120px" HideSpinButtons />
                                                    @if (!string.IsNullOrEmpty(UOM)) { <MudText Typo="Typo.caption" Class="ml-2">@UOM</MudText> }
                                                </div>
                                            </td>
                                            <td>
                                                <MudNumericField @bind-Value="Entrymodel.ItemRate" Variant="Variant.Outlined" Margin="Margin.Dense" Class="admin-input-group" Style="max-width: 100px" HideSpinButtons />
                                            </td>
                                            <td>-</td>
                                            <td>
                                                <MudIconButton Icon="@Icons.Material.Filled.AddCircle" Color="Color.Primary" OnClick="AddItems" />
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </MudSimpleTable>
                        </div>
                        <div class="px-6 py-4 d-flex justify-end" style="background: rgba(0,0,0,0.02);">
                            <MudText Typo="Typo.h6" Class="fw-bold">TOTAL: <span class="mud-text-primary">@(model.TotalValue?.ToString("C") ?? "0.00")</span></MudText>
                        </div>
                    </div>

                    @if ((ReadOnly) && (!IsView))
                    {
                        <div class="admin-glass-card pa-6 mt-6">
                            <AutherizationStatusComponent CreatedBy="@model.UserInfo" DocTypeID="16" DocDate="@DocDate" DocType="@DocType" DocNumber="@DocNumber" PageToRedirectLink="@PageToRedirectLink" DocumentID="model.GrnID" OnApprove="IsApproveData"></AutherizationStatusComponent>
                        </div>
                    }
                </EditForm>
            </div>
        </MudContainer>
    </DialogContent>
    <DialogActions>
        <div class="d-flex w-100 flex-wrap pa-4 gap-3 align-center">
            @if (!ReadOnly && model.POID != null && model.GrnID == null)
            {
                <MudButton Variant="Variant.Filled" Color="Color.Warning" OnClick="CancelOrder" Class="rounded-lg shadow-none mr-2">Cancel PO</MudButton>
            }
            <MudSpacer />
            <MudButton Variant="Variant.Outlined" Color="Color.Default" OnClick="Cancel" Style="border-radius: 12px; font-weight: 700; text-transform: none; border-color: rgba(0,0,0,0.15);">Discard</MudButton>
            @if (!ReadOnly)
            {
                <MudButton Disabled="@_busy" form="formtdsRate" Variant="Variant.Filled" Color="Color.Primary" ButtonType="ButtonType.Submit" Style="background: var(--mud-palette-primary); color: white; font-weight: 800; border-radius: 12px; text-transform: none; white-space: nowrap; padding: 8px 32px;" StartIcon="@Icons.Material.Filled.Save">Authorize Receipt</MudButton>
            }
        </div>
    </DialogActions>
</MudDialog>

@code {
    private DialogForm dialogForm;

    [Parameter]
    public InventoryGrnModel model { get; set; }
    [Parameter]
    public bool ReadOnly { get; set; }
    [Parameter]
    public bool IsView { get; set; }
    private List<StoreModel> store = new();
    private List<InventoryItemModel> itm = new();
    public PartyModel partyinfo = new();
    private int? branchID = null;
    private string UserID = null;
    private bool _busy;

    [Parameter]
    public string PageToRedirectLink { get; set; }
    public string DocNumber { get; set; }
    public DateTime? DocDate { get; set; }
    public string DocType { get; set; }

    public bool HasPermissionInventoryGrnServiceEdit { get; set; } = false;
    public bool HasPermissionInventoryGrnServiceApprove { get; set; } = false;
    public int InventoryGrnDocTypeID = 16;

    public bool HasPermissionPurchaseOrderServiceCancel { get; set; } = false;
    public int PurchaseOrderDocTypeID = 17;

    public InventoryItemModel SelectedItem = new();
    private InventoryItemEntryModel Entrymodel = new InventoryItemEntryModel();
    public string UOM { get; set; }

    decimal ItemGSTValue = 0;
    decimal TotalValue = 0;

    [CascadingParameter] IMudDialogInstance MudDialogInstance { get; set; }

    protected override async Task OnInitializedAsync()
    {
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionInventoryGrnServiceEdit = await Irole.HasClaim(InventoryGrnDocTypeID.ToString(), "Edit", ctc.Token);
        HasPermissionInventoryGrnServiceApprove = await Irole.HasClaim(InventoryGrnDocTypeID.ToString(), "Approve", ctc.Token);

        HasPermissionPurchaseOrderServiceCancel = await Irole.HasClaim(PurchaseOrderDocTypeID.ToString(), "Cancel", ctc.Token);

        var authprov = await auth.GetAuthenticationStateAsync();
        var brancIDString = authprov.User.Claims.First(x => x.Type == "BranchID").Value;
        branchID = int.Parse(brancIDString);
        var user = authprov.User;
        UserID = user.Identity.Name;
        store = storeIservice.SelectByBranch(branchID ?? 0).ToList();
        if (store.Any(s => s.StoreID == model.StoreID))
        {
            model.Store = store.FirstOrDefault(s => s.StoreID == model.StoreID);
        }
        itm = itemIservice.SearchByDescription(string.Empty).ToList();
        if (model.GrnID != null)
        {
            model.Entries = Iservice.GetItemEntries(model.GrnID.Value).ToList();
            partyinfo = partyIservice.SelectByID(model.PartyID);
            model.PartyID = partyinfo.PartyID;
        }
        else if (model.POID != null)
        {
            partyinfo = partyIservice.SelectByID(model.PartyID); 
            model.PartyID = partyinfo.PartyID;
            if (partyinfo != null)
            {
                IsTaxable = partyinfo.GstType == "Registered" || partyinfo.GstType == "SEZ";
                if(IsTaxable)
                {
                    foreach (var item in model.Entries)
                    {
                        CalculateAndDisplay(item.ItemQty, item);
                    }
                }
            }             
        }
        else
        {
            model.TotalValue = 0;
        }

        DocNumber = model.GrnNo;
        DocDate = model.EntryDate;
        DocType = "Goods Receipt Note";
    }

    private async Task OnValidSubmit(EditContext context)
    {
        if (HasPermissionInventoryGrnServiceEdit)
        {
            if (_busy)
            {
                snackbar.Add("Please wait while form is being submitted!", Severity.Warning);
                return;
            }
            if (model.Entries == null || (model.Entries != null && model.Entries.Count() == 0))
            {
                snackbar.Add("Add at least one Entry before Submitting", Severity.Error);
                return;
            }

            else
            {
                model.PartyCode = partyinfo.PartyCode;
                model.PartyID = partyinfo.PartyID;
                model.PartyName = partyinfo.TradeName;
                model.UsedInventory = 0;
                model.StoreID = model.Store?.StoreID ?? null;
                model.UserInfo.UserID = UserID;
                _busy = true;
                try
                {
                    Iservice.Update(model);
                    model = new();
                    snackbar.Add("Saved Successfully", Severity.Success);
                    MudDialogInstance.Close(model);     
                    model = new InventoryGrnModel();
                }
                catch (Exception ex)
                {
                    snackbar.Add(ex.Message, Severity.Warning);
                }
                await Task.Delay(200);
                _busy = false;
            }
        }
        else
        {
            bool? result = await DialogService.ShowMessageBoxAsync(
                "Permission denied!",
                "You don't have any permission to Edit InventoryGrn.");
        }
    }

    protected async Task IsApproveData(DataApprovedStatus aprvd)
    {
        if (HasPermissionInventoryGrnServiceApprove)
        {
            if (aprvd.IsApprove)
            {
                if (model.EntryDate.HasValue && model.EntryDate.Value.Date < DateTime.Today)
                {
                    bool? confirmResult = await DialogService.ShowMessageBoxAsync(
                        "Confirmation",
                        $"The document date is set to a previous date ({model.EntryDate.Value.ToString("dd MMM yyyy")}). Do you want to continue?",
                        yesText: "Yes", cancelText: "No");
                    
                    if (confirmResult != true)
                    {
                        return;
                    }
                }

                try
                {
                    model.UserInfo.UserID = UserID;
                    if (model.GrnID != null)
                    {
                        Iservice.Approve(model.GrnID.Value, model.UserInfo.UserID, string.Empty);
                        snackbar.Add("Approved Successfully", Severity.Success);
                    }
                }
                catch (Exception ex)
                {
                    snackbar.Add(ex.Message, Severity.Error);
                }
            }
        }
        else
        {
            bool? result = await DialogService.ShowMessageBoxAsync(
                "Permission denied!",
                "You don't have any permission to Approve InventoryGrn.");
        }
    }

    private void Cancel()
    {
        MudDialogInstance.Cancel();
    }

    private async Task CancelOrder()
    {
        if (HasPermissionPurchaseOrderServiceCancel)
        {
            if (model.POID != null)
            {     
                bool? result = await DialogService.ShowMessageBoxAsync(
                "Cancel PO ?",
                "Are you sure you want to cancel the purchase order. This cannot be undone!.");
                if (result.Value)
                {
                    pIservice.CancelOrder(model.POID.Value, UserID, string.Empty);
                    MudDialogInstance.Close(model);
                }
            }
        }
        else
        {
            bool? result = await DialogService.ShowMessageBoxAsync(
                "Permission denied!",
                "You don't have any permission to Cancel PurchaseOrder.");
        }
    }

    private void Delete(InventoryItemEntryModel i)
    {
        int rowIndex = model.Entries.IndexOf(i);
        model.Entries.RemoveAt(rowIndex);
        SetTotal();
    }

    protected void getitemCode(InventoryItemModel item)
    {
        if (item != null)
        {
            if (SelectedItem != null && SelectedItem.InventoryItemID == null)
            {
                SelectedItem = item;
            }
            else
            {
                SelectedItem = new InventoryItemModel();
            }
        }
    }

    public decimal getgstrate(int itemID)
    {
        var itemGst = gstIservice.SelectByItem(itemID, (model.EntryDate ?? DateTime.Today));
        decimal? gstrate = itemGst.TaxRate;
        return gstrate ?? 0;
    }

    //protected bool Local;
    protected bool IsTaxable;

    void PartyChanged(PartyModel party)
    {
        partyinfo = party;
        model.PartyID = party?.PartyID;
        model.PartyCode = party.PartyCode;
        model.PartyName = party.TradeName;

        if (partyinfo != null)
        {
            IsTaxable = partyinfo.GstType == "Registered" || partyinfo.GstType == "SEZ";
        }

    }

    private void AddItems()
    {
        if (Entrymodel.ItemID == null || Entrymodel.ItemRate == null || Entrymodel.ItemQty == 0)
        {
            snackbar.Add("Please fill in all Fields", Severity.Error);
            return;
        }
        decimal gstrt = 0;
        Entrymodel.ItemGstVal = 0;
        try
        {
            if (Entrymodel.ItemID != null)
            {
                gstrt = getgstrate(Entrymodel.ItemID.Value);
            }
        }
        catch { }

        if (gstrt != 0 && IsTaxable)
        {
            Entrymodel.ItemGstVal = (((Entrymodel.ItemRate ?? 0m) * (Entrymodel.ItemQty)) * gstrt) / 100;
        }
        Entrymodel.UOM = UOM;
        model.Entries.Add(Entrymodel);
        Entrymodel = new();
        SelectedItem = new();

        SetTotal();
    }

    void SetTotal()
    {
        model.TotalValue = model.Entries.Sum(x => (x.ItemQty * x.ItemRate) + x.ItemGstVal);
    }

    protected void ItemChanged(InventoryItemModel item)
    {
        SelectedItem = item;
        Entrymodel.ItemID = item?.InventoryItemID;
        UOM = item?.UoM;
    }

    decimal CalculateAndDisplay(decimal ItemQty, InventoryItemEntryModel entryModel)
    {
        entryModel.ItemQty = ItemQty;
        model.TotalValue = 0;
        decimal gstrt = 0;
        try
        {
            if (entryModel.ItemID != null)
            {
                gstrt = getgstrate(entryModel.ItemID.Value);
            }
        }
        catch { }

        if (gstrt != 0 && IsTaxable)
        {
            entryModel.ItemGstVal = (((entryModel.ItemRate ?? 0m) * (entryModel.ItemQty)) * gstrt) / 100;
        }
        foreach (var item in model.Entries)
        {
            model.TotalValue += (item.ItemQty * item.ItemRate) + (item.ItemGstVal ?? 0);
        }
        return entryModel.ItemGstVal ?? 0;
    }
}

