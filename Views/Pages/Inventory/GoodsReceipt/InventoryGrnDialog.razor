@using System.Threading;
@using Views.Pages.Finance.Transactions
@inject IInventoryGrnService Iservice
@inject IPartyService partyIservice
@inject IInventoryItemService itemIservice
@inject IStoreService storeIservice
@inject IPurchaseOrderService pIservice
@inject IGstItemService gstIservice
@inject MudBlazor.ISnackbar snackbar
@inject AuthenticationStateProvider auth
@inject IRoleService<RoleModel> Irole
@attribute [Authorize]
@inject IDialogService DialogService

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.Build" Class="mr-3 mb-n1" />
            Create Goods Reciept Note
        </MudText>
        @if (IsView)
        {
            <MudText Color="Color.Error">@model.AuthStatus</MudText>
        }
    </TitleContent>
    <DialogContent>
        <MudContainer Style="min-height:300px;max-height: 450px;overflow-y: scroll">
            <EditForm id="formtdsRate" Model="@model" OnValidSubmit="OnValidSubmit">
                <ObjectGraphDataAnnotationsValidator />
                <ValidationSummary />
                <MudGrid Spacing="2">
                    <MudItem xs="12" md="12">
                        <PartySelector ReadOnly="ReadOnly" @bind-Value="partyinfo" NatureOfBusiness="Supplier"></PartySelector>
                    </MudItem>
                    <MudItem xs="12" md="4">
                        <MudDatePicker ReadOnly="ReadOnly" Label="Entry Date" Variant="Variant.Outlined" Margin="Margin.Dense" DisableToolbar="true" Editable="true" @bind-Date="model.EntryDate" DateFormat="dd/MM/yyyy" />
                    </MudItem>
                    <MudItem xs="12" md="4">
                        <MudTextField ReadOnly="ReadOnly" @bind-Value="model.Reference" Label="Reference" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.Reference)"></MudTextField>
                    </MudItem>
                    <MudItem xs="12" md="4">
                        <StoreSelector IsDisabled="ReadOnly" @bind-Value="model.Store" VariantParameter="Variant.Outlined" MarginParameter="Margin.Dense" BranchID="@branchID.Value"></StoreSelector>
                    </MudItem>
                    <MudItem xs="12" md="12">
                        <MudTextField ReadOnly="ReadOnly" @bind-Value="model.Remarks" Label="Remarks" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.Remarks)"></MudTextField>
                    </MudItem>
                    <MudItem xs="12" md="12">
                        <MudSimpleTable Hover="true" Dense="true" FixedHeader="true">
                            <thead>
                                <tr>
                                    <th></th>
                                    <th></th>
                                    <th></th>
                                    <th>Total</th>
                                    <th>@model.TotalValue</th>
                                </tr>
                                <tr>
                                    <th>Items</th>
                                    <th>Quantity</th>
                                    <th>Rate</th>
                                    <th>GST</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in model.Entries)
                                {
                                    <tr>
                                        <td>@(itm.FirstOrDefault(x => x.InventoryItemID == item.ItemID)?.InventoryItemCode)</td>
                                        <td>@item.ItemQty</td>
                                        <td>@item.ItemRate</td>
                                        <td>@item.ItemGstVal</td>
                                        <td>
                                            @if (!ReadOnly)
                                            {
                                                <MudFab Color="Color.Error" @onclick="@(()=> Delete(@item))" Icon="@Icons.Material.Filled.Delete" Size="Size.Small" IconSize="Size.Small" />
                                            }
                                        </td>
                                    </tr>
                                }
                                @if (!ReadOnly && model.POID == null)
                                {
                                    <tr>
                                        <td colspan="2"><InventoryItemSelector Value="SelectedItems" ValueChanged="@((InventoryItemModel newValue) => getitemCode(newValue))" /></td>
                                        <td><MudTextField @bind-Value="Entrymodel.ItemQty" Label="Quatity" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => Entrymodel.ItemQty)"></MudTextField></td>
                                        <td><MudTextField @bind-Value="Entrymodel.ItemRate" Label="Rate" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => Entrymodel.ItemRate)"></MudTextField></td>
                                        <td></td>
                                        <td><MudFab OnClick="AddItems" Color="Color.Primary" Icon="@Icons.Material.Filled.Add" Size="Size.Small" IconSize="Size.Small" /></td>
                                    </tr>
                                }
                            </tbody>
                        </MudSimpleTable>
                    </MudItem>
                    <MudItem xs="12">
                        @if ((ReadOnly) && (!IsView))
                        {
                            <AutherizationStatusComponent DocTypeID="16" DocumentID="model.GrnID" OnApprove="IsApproveData"></AutherizationStatusComponent>
                        }
                    </MudItem>
                </MudGrid>
            </EditForm>
        </MudContainer>
    </DialogContent>
    <DialogActions>
        @if (!ReadOnly)
        {
            @if (model.POID != null && model.GrnID == null)
            {
                <MudButton Variant="Variant.Filled" Color="Color.Warning" OnClick="CancelOrder">Cancel Order</MudButton>
            }
            <MudButton Variant="Variant.Filled" Color="Color.Info" OnClick="Cancel">Cancel</MudButton>
            <MudButton form="formtdsRate" Variant="Variant.Filled" Color="Color.Success" ButtonType="ButtonType.Submit">Submit</MudButton>
        }
        @if (ReadOnly)
        {
            <MudButton Variant="Variant.Filled" Color="Color.Info" OnClick="Cancel">Close</MudButton>
        }
    </DialogActions>
</MudDialog>

@code {

    [Parameter]
    public InventoryGrnModel model { get; set; }
    [Parameter]
    public bool ReadOnly { get; set; }
    [Parameter]
    public bool IsView { get; set; }
    private List<StoreModel> store = new();
    private List<InventoryItemModel> itm = new();
    public PartyModel partyinfo = new();
    private int? branchID = null;
    private string UserID = null;


    public bool HasAuthoriseEdit { get; set; } = false;
    int DocTypeID = 16;

    public InventoryItemModel SelectedItems = new();
    private InventoryItemEntryModel Entrymodel = new InventoryItemEntryModel();

    [CascadingParameter] MudDialogInstance MudDialog { get; set; }

    protected override async Task OnInitializedAsync()
    {
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasAuthoriseEdit = await Irole.HasClaim(DocTypeID.ToString(), "Edit", ctc.Token);

        var authprov = await auth.GetAuthenticationStateAsync();
        var brancIDString = authprov.User.Claims.First(x => x.Type == "BranchID").Value;
        branchID = int.Parse(brancIDString);
        var user = authprov.User;
        UserID = user.Identity.Name;
        store = storeIservice.SelectByBranch(branchID.Value).ToList();
        if (store.Any(s => s.StoreID == model.StoreID))
        {
            model.Store = store.FirstOrDefault(s => s.StoreID == model.StoreID);
        }
        itm = itemIservice.SearchByDescription(string.Empty).ToList();
        if (model.GrnID != null)
        {
            model.Entries = Iservice.GetItemEntries(model.GrnID.Value).ToList();
            partyinfo = partyIservice.SelectByID(model.PartyID);
            model.PartyID = partyinfo.PartyID;
        }
        else if (model.POID != null)
        {
            partyinfo = partyIservice.SelectByID(model.PartyID);
            model.PartyID = partyinfo.PartyID;
        }
        else
        {
            model.TotalValue = 0;
        }
    }

    private async Task OnValidSubmit(EditContext context)
    {
        if (HasAuthoriseEdit)
        {
            if (model.Entries == null || (model.Entries != null && model.Entries.Count() == 0))
            {
                snackbar.Add("Add at least one Entry before Submitting", Severity.Error);
                return;
            }
            else
            {
                model.PartyCode = partyinfo.PartyCode;
                model.PartyID = partyinfo.PartyID;
                model.PartyName = partyinfo.TradeName;
                model.StoreID = model.Store?.StoreID ?? null;
                model.UserInfo.UserID = UserID;
                try
                {
                    Iservice.Update(model);
                    model = new();
                    snackbar.Add("Saved Successfully", Severity.Success);
                    model = new InventoryGrnModel();
                }
                catch (Exception ex)
                {
                    snackbar.Add(ex.Message, Severity.Warning);
                }
                MudDialog.Close(model);
            }
        }
        else
        {
            bool? result = await DialogService.ShowMessageBox(
                "Permission denied!",
                "You dont have any permission to submit.");
        }
    }

    protected void IsApproveData(DataApprovedStatus aprvd)
    {
        if (aprvd.IsApprove)
        {
            try
            {
                model.UserInfo.UserID = UserID;
                Iservice.Approve(model.GrnID.Value, model.UserInfo.UserID, string.Empty);
                snackbar.Add("Approved Successfully", Severity.Success);
            }
            catch (Exception ex)
            {
                snackbar.Add(ex.Message, Severity.Error);
            }
        }
    }

    private void Cancel()
    {
        MudDialog.Cancel();
    }

    private void CancelOrder()
    {
        pIservice.CancelOrder(model.POID.Value, UserID, string.Empty);
        MudDialog.Close(model);
    }

    private void Delete(InventoryItemEntryModel i)
    {
        decimal total = (((i.ItemQty.Value) * (i.ItemRate.Value)) + (i.ItemGstVal.Value));
        model.TotalValue = model.TotalValue - total;
        int rowIndex = model.Entries.IndexOf(i);
        model.Entries.RemoveAt(rowIndex);
    }

    protected void getitemCode(InventoryItemModel item)
    {
        if (item != null)
        {
            if (SelectedItems != null && SelectedItems.InventoryItemID == null)
            {
                SelectedItems = item;
            }
            else
            {
                SelectedItems = new InventoryItemModel();
            }
        }
    }

    public decimal getgstrate(int itemID)
    {
        List<GstItemModel> gstitem = new();
        gstitem = gstIservice.SelectByItem(itemID).ToList();
        decimal gstrate = gstitem[0].TaxRate.Value;
        return gstrate;
    }
    private void AddItems()
    {
        model.PartyID = partyinfo.PartyID;
        Entrymodel.ItemID = SelectedItems.InventoryItemID;
        if (Entrymodel.ItemID == null || Entrymodel.ItemRate == null || Entrymodel.ItemQty == null)
        {
            snackbar.Add("Please fill in all Fields", Severity.Error);
            return;
        }
        decimal gstrt = 0;
        decimal gstrate = 0;
        try
        {
            gstrt = getgstrate(Entrymodel.ItemID.Value);
        }
        catch (Exception)
        {
            gstrt = 0;
        }
        if (gstrt != 0)
        {
            gstrate = (((Entrymodel.ItemRate.Value) * (Entrymodel.ItemQty.Value)) * gstrt) / 100;
        }
        Entrymodel.ItemGstVal = gstrate;
        model.Entries.Add(Entrymodel);
        decimal total = ((Entrymodel.ItemQty.Value) * (Entrymodel.ItemRate.Value) + (Entrymodel.ItemGstVal.Value));
        model.TotalValue = model.TotalValue + total;
        Entrymodel = new();
        SelectedItems = null;
        SelectedItems = new();
    }
}