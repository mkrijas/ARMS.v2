@page "/InventoryGrn"
@page "/InventoryGrn/{id:int}"
@using System.Threading;
@using PurchaseOrder
@attribute [Authorize]
@inject AuthenticationStateProvider auth
@inject IRoleService<RoleModel> Irole
@inject IDialogService DialogService
@inject IInventoryGrnService Iservice
@inject MudBlazor.ISnackbar snackbar
@inject SignalRService signalRService
@inject IPushNotificationService IpushNotificationService

<MudGrid Spacing="4">
    <MudItem xs="12">
        <MudTable Items="@collection" RowStyleFunc="TableRowStyle" Dense="true" Hover="true" Striped="true" Elevation="10" Filter="new Func<InventoryGrnModel, bool>(search)" @bind-place="model">
            <ToolBarContent>
                <MudText Typo="Typo.h6">GRN</MudText>
                <MudTooltip Text="New Grn">
                    <MudIconButton Disabled="@_busy" Icon="@Icons.Material.Filled.Add" Title="Add" @onclick="@(()=> OpenDialog(new InventoryGrnModel(){UsedInventory=0},false,false))" Color="Color.Dark" Size="Size.Small"></MudIconButton>
                </MudTooltip>
                <MudTooltip Text="Pending Purchase Order">
                    <MudIconButton Disabled="@_busy" Icon="@Icons.Material.Filled.AddLink" @onclick="openpurchaseorder" Color="Color.Dark" Size="Size.Small"></MudIconButton>
                </MudTooltip>
                <MudTooltip Text="Approved Data">
                    <MudIconButton Disabled="@_busy" Icon="@Icons.Material.Filled.TableView" Title="Approved Data" @onclick="@(()=> OpenDialogApproved(model))" Color="Color.Dark" Size="Size.Small"></MudIconButton>
                </MudTooltip>
                <MudSpacer></MudSpacer>
                <MudTextField @bind-Value="searchGrn" Placeholder="Search Grn... " Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0"></MudTextField>
                <MudCheckBox Label="Approved Entries" CheckedChanged="((bool value)=>ApprovedChanged(value))" Checked="@IsApproved" Size="Size.Medium" Color="Color.Primary"></MudCheckBox>
            </ToolBarContent>
            <HeaderContent>
                <MudTh><MudTableSortLabel SortBy="new Func<InventoryGrnModel, object>(x=> x.GrnNo)" InitialDirection="SortDirection.Ascending">GRN No</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<InventoryGrnModel, object>(x=> x.EntryDate)" InitialDirection="SortDirection.Ascending">Entry Date</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<InventoryGrnModel, object>(x=> x.PartyName)" InitialDirection="SortDirection.Ascending">Party</MudTableSortLabel></MudTh>
                <MudTh>Actions</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="GrnNO">@context.GrnNo</MudTd>
                <MudTd DataLabel="EntryDate">@context.EntryDate?.ToShortDateString()</MudTd>
                <MudTd DataLabel="Party">@context.PartyName</MudTd>
                <MudTd DataLabel="">
                    @if (@context.AuthLevelID == null)
                    {
                        <MudFab @onclick="@(()=> OpenDialog(context,false,false))" Color="Color.Primary" title="Edit" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" IconSize="Size.Small" />
                        <MudFab @onclick="@(()=> Delete(context))" Color="Color.Error" title="Delete" Icon="@Icons.Material.Filled.Delete" Size="Size.Small" IconSize="Size.Small" />
                    }
                    @if (@context.AuthLevelID != 99)
                    {
                        <MudFab @onclick="@(()=> OpenDialog(context,true,false))" Color="Color.Warning" Icon="@Icons.Material.Filled.Verified" title="Verify" Size="Size.Small" IconSize="Size.Small" />
                    }
                    <MudFab @onclick="@(()=> OpenDialog(context,true,true))" Color="Color.Info" Icon="@Icons.Material.Filled.GridView" title="View" Size="Size.Small" IconSize="Size.Small" />
                </MudTd>
            </RowTemplate>
            <PagerContent>
                <MudTablePager PageSizeOptions="new int[] { 10, 20, 50, 100 }" />
            </PagerContent>
        </MudTable>
    </MudItem>
</MudGrid>

@code {

    private InventoryGrnModel model = new InventoryGrnModel();
    private List<InventoryGrnModel> collection = new List<InventoryGrnModel>();
    DialogOptions maxWidth = new DialogOptions() { MaxWidth = MaxWidth.Medium, FullWidth = true };
    private string searchGrn = "";
    public bool IsApproved { get; set; } = false;
    private bool _busy;
    
    [Parameter]
    public int? id { get; set; } = null;

    public bool HasPermissionInventoryGrnServiceDelete { get; set; } = false;
    public int InventoryGrnDocTypeID = 16;
    
    #region SignaIR Notification

    private PushNotificationModel notificationMessage = new PushNotificationModel();
    #endregion

    protected override async Task OnInitializedAsync()
    {
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionInventoryGrnServiceDelete = await Irole.HasClaim(InventoryGrnDocTypeID.ToString(), "Delete", ctc.Token);

        model = new();
        await GetAll(IsApproved);

        await Task.Delay(200);
        await signalRService.StartAsync();
        if (id != null && collection != null && collection.Any(g => g.GrnID == id))
        {
            await OpenDialog(collection.FirstOrDefault(s => s.GrnID == id), true,false);
        }

    }

    async Task ApprovedChanged(bool value)
    {
        IsApproved = value;
        await GetAll(IsApproved);
    }

    private async Task GetAll(bool val)
    {
        var authprov = await auth.GetAuthenticationStateAsync();
        var brancIDString = authprov.User.Claims.First(x => x.Type == "BranchID").Value;
        int brancID = int.Parse(brancIDString);
        if (val)
        {
            collection = Iservice.SelectPending(brancID).Where(x => x.AuthLevelID == 99 && x.UsedInventory == 0).ToList();
        }
        else
        {
            collection = Iservice.SelectPending(brancID).Where(x => x.AuthLevelID != 99 && x.UsedInventory == 0).ToList();
        }
    }

    private async Task OpenDialog(InventoryGrnModel tds, bool ReadOnly, bool View)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        _busy = true;
        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;

        DialogOptions maxWidth = new DialogOptions() { MaxWidth = MaxWidth.Large, FullWidth = true };
        DialogParameters parms = new DialogParameters();
        parms.Add("model", tds.Clone());
        parms.Add("PageToRedirectLink", "/InventoryGrn");
        parms.Add("ReadOnly", ReadOnly);
        parms.Add("IsView", View);
        var dialog = DialogService.Show<InventoryGrnDialog>(tds.GrnID == null ? "ADD" : "EDIT", parms, maxWidth);
        var result = await dialog.Result;

        var isCancelled = result.Cancelled;
        if (!isCancelled)
        {
            var brancIDString = authprov.User.Claims.First(x => x.Type == "BranchID").Value;
            int brancID = int.Parse(brancIDString);
            var ReturnData = (InventoryGrnModel)result.Data;
            notificationMessage.InitiateBranch = new BranchModel() { BranchID = brancID };
            notificationMessage.ReceivedBranch = new BranchModel() { BranchID = brancID };
            notificationMessage.MessageTitle = IpushNotificationService.GetMessageTitle("Goods Receipt Note", ReturnData.GrnNo, "Level 1 Verification");
            notificationMessage.MessageBody = IpushNotificationService.GetMessageBody("Goods Receipt Note", ReturnData.GrnNo, "Level 1 Verification", ReturnData.EntryDate);
            notificationMessage.RedirectedTo = 0;
            notificationMessage.ExpiredBy = 7;
            notificationMessage.DocumentID = ReturnData.GrnID;
            notificationMessage.MessageGroupID = "PendingVerification";
            notificationMessage.PageToRedirectLink = "/InventoryGrn";
            notificationMessage.ClaimValue = "Verify 1";
            notificationMessage.DocumentTypeID = InventoryGrnDocTypeID;
            notificationMessage.MsgDate = DateTime.Now;
            await signalRService.Send(notificationMessage);
        }

        await GetAll(IsApproved);

        await Task.Delay(200);
        _busy = false;
    }

    public async void OpenDialogApproved(InventoryGrnModel p)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        _busy = true;
        DialogParameters parms = new DialogParameters();
        parms.Add("model", p.Clone());
        var dialog = DialogService.Show<InventoryGrnApproveView>(p.GrnID == null ? "Approved Data" : "Approved Data", parms, maxWidth);
        await Task.Delay(200);
        _busy = false;
    }

    private async Task Delete(InventoryGrnModel model)
    {
        if (HasPermissionInventoryGrnServiceDelete)
        {
            bool? result = await DialogService.ShowMessageBox(
                "Warning !",
                "Are you sure, you want to delete - " + model.GrnNo + " ?");
            if (result == true)
            {
                var authprov = await auth.GetAuthenticationStateAsync();
                var user = authprov.User;
                Iservice.Delete(model.GrnID, user.Identity.Name);
                snackbar.Add("Deleted Successfully", Severity.Success);
                await GetAll(IsApproved);
            }
        }
        else
        {
            bool? result = await DialogService.ShowMessageBox(
                "Permission denied!",
                "You don't have any permission to delete InventoryGrn.");
        }
    }

    public async Task openpurchaseorder()
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        _busy = true;
        PurchaseOrderModel tds = new();
        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;
        DialogParameters parms = new DialogParameters();
        var dialog = DialogService.Show<PurchaseOrderViewDialog>("Purchase Order", parms, maxWidth);
        var result = await dialog.Result;
        if (!result.Canceled)
        {
            await GetAll(IsApproved);
        }
        await GetAll(IsApproved);

        await Task.Delay(200);
        _busy = false;
    }

    private bool search(InventoryGrnModel tds)
    {
        if (tds.GrnNo != null && tds.GrnNo.Contains(searchGrn, StringComparison.OrdinalIgnoreCase))
        {
            return true;
        }
        else if (tds.GrnNo == null)
            return true;
        return false;
    }

    private string TableRowStyle(InventoryGrnModel IG, int index)
    {
        if (IG.AuthLevelID == 99)
        {
            return "background-color:#CCCCFF";
        }
        return string.Empty;
    }
}