@page "/InventoryGrn"
@page "/InventoryGrn/{id:int}"
@using System.Threading;
@using PurchaseOrder
@attribute [Authorize]
@inject AuthenticationStateProvider auth
@inject IRoleService<RoleModel> Irole
@inject IDialogService DialogService
@inject IInventoryGrnService Iservice
@inject MudBlazor.ISnackbar snackbar
@inject SignalRService signalRService
@inject IPushNotificationService IpushNotificationService

@if (_isLoading)
{
    <div @key="@("loader")" style="display: flex; justify-content: center; align-items: center; min-height: 400px;">
        <LoaderComponent IsFullScreen="true" 
                        ShowLogo="false" 
                        Size="medium" 
                        LoadingText="Loading GRNs" 
                        SubText="Please wait..." />
    </div>
}
else
{
    <div class="admin-page-container fade-in" @key="@("content")">
        <div class="admin-header-tiered mb-6">
            <div class="d-flex align-center justify-space-between">
                <div>
                    <MudText Typo="Typo.h4" Class="admin-title">Goods Receipt Notes (GRN)</MudText>
                    <MudText Typo="Typo.body2" Class="admin-subtitle">Process incoming inventory shipments and reconcile physical stock with procurement orders.</MudText>
                </div>
                <div class="d-flex gap-2">
                    <MudButton Disabled="@_busy" Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.AddLink" OnClick="openpurchaseorder" Class="admin-register-btn">IMPORT FROM PO</MudButton>
                </div>
            </div>
        </div>

        <div class="admin-glass-card pa-6 mb-6">
            <MudGrid Spacing="3" Class="align-center">
                <MudItem xs="12" md="6">
                    <MudTextField @bind-Value="searchGrn" Placeholder="Search by GRN Number, Party or Reference..." Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" AdornmentColor="Color.Primary" Variant="Variant.Outlined" Margin="Margin.Dense" Clearable="true" Class="modern-input"></MudTextField>
                </MudItem>
                <MudItem xs="12" md="4">
                    <div class="d-flex align-center h-100 px-4 rounded-lg bg-light-surface border-subtle">
                        <MudCheckBox T="bool" Label="SHOW APPROVED ENTRIES" ValueChanged="((bool value)=>ApprovedChanged(value))" Value="@IsApproved" Color="Color.Primary" Dense="true" Class="fw-600" />
                    </div>
                </MudItem>
                <MudItem xs="12" md="2" Class="d-flex justify-end">
                    <div class="d-flex flex-column align-end">
                        <MudText Typo="Typo.caption" Class="admin-subtitle">TOTAL GRNS: @(collection?.Count ?? 0)</MudText>
                    </div>
                </MudItem>
            </MudGrid>
        </div>

        <div class="admin-glass-card overflow-hidden">
            <MudTable Items="@collection" Elevation="0" RowStyleFunc="TableRowStyle" Filter="new Func<InventoryGrnModel, bool>(search)" Hover="true" Breakpoint="Breakpoint.Sm" Class="modern-admin-table">
                <HeaderContent>
                    <MudTh><MudTableSortLabel SortBy="new Func<InventoryGrnModel, object>(x => x.GrnNo)" InitialDirection="SortDirection.Ascending"><span class="admin-header-text">GRN NO</span></MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<InventoryGrnModel, object>(x => x.EntryDate)"><span class="admin-header-text">RECEIPT DATE</span></MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<InventoryGrnModel, object>(x => x.PartyName)"><span class="admin-header-text">PARTY / SUPPLIER</span></MudTableSortLabel></MudTh>
                    <MudTh Style="text-align: right;"><span class="admin-header-text">ACTIONS</span></MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="GRN No">
                        <div class="d-flex flex-column">
                            <span class="admin-td-primary fw-600">@context.GrnNo</span>
                            @if (context.AuthLevelID == 100)
                            {
                                <span class="badge badge-error mt-1" style="width: fit-content; font-size: 10px;">REJECTED</span>
                            }
                            else if (context.AuthLevelID == 99)
                            {
                                <span class="badge badge-success mt-1" style="width: fit-content; font-size: 10px;">VERIFIED</span>
                            }
                        </div>
                    </MudTd>
                    <MudTd DataLabel="Date">
                        <div class="d-flex align-center opa-70">
                            <MudIcon Icon="@Icons.Material.Filled.Event" Size="Size.Small" Class="mr-1" />
                            <span>@context.EntryDate?.ToString("dd MMM yyyy")</span>
                        </div>
                    </MudTd>
                    <MudTd DataLabel="Party"><span class="fw-500">@context.PartyName</span></MudTd>
                    <MudTd DataLabel="Actions" Style="text-align: right;">
                        <div class="d-flex justify-end gap-1">
                            <MudTooltip Text="Detailed Inspection">
                                <MudIconButton OnClick="@(()=> OpenDialog(context,true,true))" Color="Color.Primary" Icon="@Icons.Material.Filled.GridView" Size="Size.Small" Variant="Variant.Text" />
                            </MudTooltip>
                            
                            @if (context.AuthLevelID == null)
                            {
                                <MudTooltip Text="Edit Draft">
                                    <MudIconButton OnClick="@(()=> OpenDialog(context,false,false))" Color="Color.Primary" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Variant="Variant.Text" />
                                </MudTooltip>
                                <MudTooltip Text="Discard Record">
                                    <MudIconButton OnClick="@(()=> Delete(context))" Color="Color.Error" Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Variant="Variant.Text" />
                                </MudTooltip>
                            }

                            @if (context.AuthLevelID == 99)
                            {
                                @if (context.IssuedQty == 0 && !context.Invoiced)
                                {
                                    <MudTooltip Text="Reverse Approval">
                                        <MudIconButton OnClick="@(()=> Reverse(context))" Color="Color.Error" Icon="@Icons.Material.Filled.SettingsBackupRestore" Size="Size.Small" Variant="Variant.Text" />
                                    </MudTooltip>
                                }
                            }
                            else if (context.AuthLevelID != 100)
                            {
                                <MudTooltip Text="Verify Entry">
                                    <MudIconButton OnClick="@(()=> OpenDialog(context,true,false))" Color="Color.Warning" Icon="@Icons.Material.Filled.VerifiedUser" Size="Size.Small" Variant="Variant.Text" />
                                </MudTooltip>
                            }
                        </div>
                    </MudTd>
                </RowTemplate>
                <PagerContent>
                    <div class="pa-4">
                        <MudTablePager PageSizeOptions="new int[] { 10, 20, 50, 100 }" />
                    </div>
                </PagerContent>
            </MudTable>
        </div>
    </div>
}



@code {

    private bool _isLoading = true;
    private DateTime _loadStartTime;

    private InventoryGrnModel model = new InventoryGrnModel();
    private List<InventoryGrnModel> collection = new List<InventoryGrnModel>();
    DialogOptions maxWidth = new DialogOptions() { MaxWidth = MaxWidth.Medium, FullWidth = true };
    private string searchGrn = "";
    public bool IsApproved { get; set; } = false;
    private bool _busy;

    [Parameter]
    public int? id { get; set; } = null;

    public bool HasPermissionInventoryGrnServiceDelete { get; set; } = false;
    public bool HasPermissionInventoryGrnServiceReverse { get; set; } = false;
    public int InventoryGrnDocTypeID = 16;

    #region SignaIR Notification

    private PushNotificationModel notificationMessage = new PushNotificationModel();
    #endregion

    protected override async Task OnInitializedAsync()
    {
        _loadStartTime = DateTime.Now;
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionInventoryGrnServiceDelete = await Irole.HasClaim(InventoryGrnDocTypeID.ToString(), "Delete", ctc.Token);
        HasPermissionInventoryGrnServiceReverse = await Irole.HasClaim(InventoryGrnDocTypeID.ToString(), "Reverse", ctc.Token);

        model = new();
        await GetAll(IsApproved);

        await Task.Delay(200);
        await signalRService.StartAsync();
        if (id != null && collection != null && collection.Any(g => g.GrnID == id))
        {
            await OpenDialog(collection.FirstOrDefault(s => s.GrnID == id), true,false);
        }
        await EnsureMinimumLoadTime();
        _isLoading = false;
    }

    private async Task EnsureMinimumLoadTime()
    {
        var elapsed = (DateTime.Now - _loadStartTime).TotalMilliseconds;
        if (elapsed < 100)
        {
            await Task.Delay(100 - (int)elapsed);
        }
    }

    async Task ApprovedChanged(bool value)
    {
        IsApproved = value;
        await GetAll(IsApproved);
    }

    private async Task GetAll(bool val)
    {
        var authprov = await auth.GetAuthenticationStateAsync();
        var brancIDString = authprov.User.Claims.First(x => x.Type == "BranchID").Value;
        int brancID = int.Parse(brancIDString);
        if (val)
        {
            collection = Iservice.SelectPending(brancID).Where(x => (x.AuthLevelID == 99 || x.AuthLevelID == 100) && x.UsedInventory == 0).ToList();
        }
        else
        {
            collection = Iservice.SelectPending(brancID).Where(x => (x.AuthLevelID != 99 && x.AuthLevelID != 100) && x.UsedInventory == 0).ToList();
        }
    }

    private async Task OpenDialog(InventoryGrnModel tds, bool ReadOnly, bool View)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        _busy = true;
        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;

        DialogOptions maxWidth = new DialogOptions() { MaxWidth = MaxWidth.Large, FullWidth = true };
        DialogParameters parms = new DialogParameters();
        parms.Add("model", tds.Clone());
        parms.Add("PageToRedirectLink", "/InventoryGrn");
        parms.Add("ReadOnly", ReadOnly);
        parms.Add("IsView", View);
        var dialog = await DialogService.ShowAsync<InventoryGrnDialog>(tds.GrnID == null ? "ADD" : "EDIT", parms, maxWidth);
        var result = await dialog.Result;

        var isCancelled = result.Canceled;
        if (!isCancelled)
        {
            var brancIDString = authprov.User.Claims.First(x => x.Type == "BranchID").Value;
            int brancID = int.Parse(brancIDString);
            var ReturnData = (InventoryGrnModel)result.Data;
            notificationMessage.InitiateBranch = new BranchModel() { BranchID = brancID };
            notificationMessage.ReceivedBranch = new BranchModel() { BranchID = brancID };
            notificationMessage.MessageTitle = IpushNotificationService.GetMessageTitle("Goods Receipt Note", ReturnData.GrnNo, "Level 1 Verification");
            notificationMessage.MessageBody = IpushNotificationService.GetMessageBody("Goods Receipt Note", ReturnData.GrnNo, "Level 1 Verification", ReturnData.EntryDate);
            notificationMessage.RedirectedTo = 0;
            notificationMessage.ExpiredBy = 7;
            notificationMessage.DocumentID = ReturnData.GrnID;
            notificationMessage.MessageGroupID = "PendingVerification";
            notificationMessage.PageToRedirectLink = "/InventoryGrn";
            notificationMessage.ClaimValue = "Verify 1";
            notificationMessage.DocumentTypeID = InventoryGrnDocTypeID;
            notificationMessage.MsgDate = DateTime.Now;
            await signalRService.Send(notificationMessage);
        }

        await GetAll(IsApproved);

        await Task.Delay(200);
        _busy = false;
    }

    public async void OpenDialogApproved(InventoryGrnModel p)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        _busy = true;
        DialogParameters parms = new DialogParameters();
        parms.Add("model", p.Clone());
        var dialog = await DialogService.ShowAsync<InventoryGrnApproveView>(p.GrnID == null ? "Approved Data" : "Approved Data", parms, maxWidth);
        await Task.Delay(200);
        _busy = false;
    }

    private async Task Delete(InventoryGrnModel model)
    {
        if (HasPermissionInventoryGrnServiceDelete)
        {
            bool? result = await DialogService.ShowMessageBoxAsync(
                "Warning !",
                "Are you sure, you want to delete - " + model.GrnNo + " ?");
            if (result == true)
            {
                var authprov = await auth.GetAuthenticationStateAsync();
                var user = authprov.User;
                Iservice.Delete(model.GrnID, user.Identity.Name);
                snackbar.Add("Deleted Successfully", Severity.Success);
                await GetAll(IsApproved);
            }
        }
        else
        {
            bool? result = await DialogService.ShowMessageBoxAsync(
                "Permission denied!",
                "You don't have any permission to delete InventoryGrn.");
        }
    }

    public async Task openpurchaseorder()
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        _busy = true;
        PurchaseOrderModel tds = new();
        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;
        DialogParameters parms = new DialogParameters();
        var dialog = await DialogService.ShowAsync<PurchaseOrderViewDialog>("Purchase Order", parms, maxWidth);
        var result = await dialog.Result;
        if (!result.Canceled)
        {
            await GetAll(IsApproved);
        }
        await GetAll(IsApproved);

        await Task.Delay(200);
        _busy = false;
    }

    private bool search(InventoryGrnModel tds)
    {
        if ((tds.GrnNo != null && tds.GrnNo.Contains(searchGrn, StringComparison.OrdinalIgnoreCase)) || tds.GrnNo == null)
        {
            return true;
        }
        else if (tds.PartyName != null && tds.PartyName.Contains(searchGrn, StringComparison.OrdinalIgnoreCase))
        {
            return true;
        }
        return false;
    }

    private string TableRowStyle(InventoryGrnModel IG, int index)
    {
        if (IG.AuthLevelID == 99)
        {
            return "background-color:#CCCCFF";
        }
        return string.Empty;
    }

    private async Task Reverse(InventoryGrnModel model)
    {
        if (HasPermissionInventoryGrnServiceReverse)
        {
            bool? result = await DialogService.ShowMessageBoxAsync(
               "Warning !",
               "Are you sure, you want to Reverse - " + model.GrnNo + " ?");
            if (result == true)
            {
                try{
                    var authprov = await auth.GetAuthenticationStateAsync();
                    var user = authprov.User;
                    Iservice.Reverse(DateTime.Now, model.GrnID.Value, user.Identity.Name);
                    snackbar.Add("Reversed Successfully", Severity.Success);
                }
                catch (Exception ex)
                {
                    snackbar.Add(ex.Message, Severity.Warning);
                }
            }
        }
        else
        {
            bool? result = await DialogService.ShowMessageBoxAsync(
                "Permission denied!",
                "You don't have any permission to Reverse InventoryGrn.");
        }
    }
}

