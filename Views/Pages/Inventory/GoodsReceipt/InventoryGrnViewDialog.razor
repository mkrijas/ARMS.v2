@using Views.Pages.Finance.Transactions.PurchaseAndPayment
@inject IInventoryGrnService Iservice
@inject IGstItemService gstitemIservice
@inject IPartyService partyIservice
@inject ITdsRateService tdsIService
@inject IBranchService branchIservice
@inject MudBlazor.ISnackbar snackbar
@inject IInventoryGroupService inventoryGroupIservice
@inject AuthenticationStateProvider auth
@attribute [Authorize]
@using System.Threading;
@inject IRoleService<RoleModel> Irole
@inject IDialogService DialogService

<MudDialog>
    <DialogContent>
        <MudGrid Spacing="4">
            <MudItem xs="12">
                <MudTable Items="@collection" Dense="true" Hover="true" Striped="true" Elevation="0" @bind-place="model">
                    <HeaderContent>
                        <MudTh><MudTableSortLabel SortBy="new Func<InventoryGrnModel, object>(x=> x.GrnNo)" InitialDirection="SortDirection.Ascending">GRN No</MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<InventoryGrnModel, object>(x=> x.EntryDate)" InitialDirection="SortDirection.Ascending">Entry Date</MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<InventoryGrnModel, object>(x=> x.PartyName)" InitialDirection="SortDirection.Ascending">Party</MudTableSortLabel></MudTh>
                        <MudTh>Actions</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="GrnNo">@context.GrnNo</MudTd>
                        <MudTd DataLabel="EntryDate">@context.EntryDate</MudTd>
                        <MudTd DataLabel="Party">@context.PartyName</MudTd>
                        <MudTd DataLabel="">
                            <MudTooltip Text="Reverse">
                                    <MudFab @onclick="@(()=> Reverse(context))" Color="Color.Error" StartIcon="@Icons.Material.Filled.ArrowBack" Size="Size.Small" IconSize="Size.Small" />
                            </MudTooltip>
                            <MudTooltip Text="View">
                                    <MudFab @onclick="@(()=> OpenDialog(context))" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Preview" Size="Size.Small" IconSize="Size.Small" />
                            </MudTooltip>
                            <MudTooltip Text="Convert to TaxPurchase">
                                <MudFab @onclick="@(()=> ToPurchase(context))" Color="Color.Success" StartIcon="@Icons.Material.Filled.ArrowForward" Size="Size.Small" IconSize="Size.Small" />
                            </MudTooltip>
                        </MudTd>
                    </RowTemplate>
                    <PagerContent>
                        <MudTablePager PageSizeOptions="new int[] { 10, 20, 50, 100 }" />
                    </PagerContent>
                </MudTable>
            </MudItem>
        </MudGrid>
    </DialogContent>
</MudDialog>

@code {

    private InventoryGrnModel model = new InventoryGrnModel();
    private List<InventoryGrnModel> collection = new List<InventoryGrnModel>();
    DialogOptions maxWidth = new DialogOptions() { MaxWidth = MaxWidth.Medium, FullWidth = true };
    [CascadingParameter] MudDialogInstance MudDialog { get; set; }
    private bool _busy;

    public bool HasPermissionInventoryGrnServiceReverse { get; set; } = false;
    int InventoryGrnDocTypeID = 16;

    int? BranchID;
    string UserID;

    protected override async Task OnInitializedAsync()
    {
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionInventoryGrnServiceReverse = await Irole.HasClaim(InventoryGrnDocTypeID.ToString(), "Reverse", ctc.Token);

        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;
        UserID = user.Identity.Name;       
        var brancIDString = authprov.User.Claims.First(x => x.Type == "BranchID").Value;
        BranchID = int.Parse(brancIDString);

        model = new();
        GetAll();
    }

    private void GetAll()
    {
        collection = Iservice.PendingToInvoice(BranchID.Value).ToList();
    }

    private async Task OpenDialog(InventoryGrnModel tds)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        _busy = true;
        DialogParameters parms = new DialogParameters();
        parms.Add("model", tds.Clone());
        parms.Add("ReadOnly", true);
        parms.Add("IsView", true);
        var dialog = DialogService.Show<InventoryGrnDialog>("GRN", parms, maxWidth);
        var result = await dialog.Result;
        if (!result.Canceled)
        {
            GetAll();
        }        
        await Task.Delay(200);
        _busy = false;
    }

    private async Task Reverse(InventoryGrnModel tds)
    {
        if (HasPermissionInventoryGrnServiceReverse)
        {
            var authprov = await auth.GetAuthenticationStateAsync();
            var user = authprov.User;
            model.UserInfo.UserID = user.Identity.Name;
            Iservice.Reverse(tds.GrnID.Value, model.UserInfo.UserID);
            MudDialog.Close(model);
        }
        else
        {
            bool? result = await DialogService.ShowMessageBox(
                "Permission denied!",
                "You dont have any permission to Reverse InventoryGrn.");
        }
    }

    private async Task ToPurchase(InventoryGrnModel grn)
    {
       

      
        model.UserInfo.UserID = UserID;
        TaxPurchaseModel tpm = new TaxPurchaseModel()
            {
                GRNID = grn.GrnID,
                PartyInfo = partyIservice.SelectByID(grn.PartyID),
                NonStoreInventory = false
            };

        // bool Local = false, IsTaxable = false;

        // if (grn.PartyID != null)
        // {           
        //     IsTaxable = tpm.PartyInfo.GstType == "Registered" || tpm.PartyInfo.GstType == "SEZ";
        //     Local = partyIservice.IsLocal(tpm.PartyInfo.PartyID, BranchID);
        // }
        // else { Local = false; }


        foreach (var item in Iservice.GetItemEntries(grn.GrnID.Value))
        {
            tpm.Items.Add(
                new TaxPurchaseItemModel()
                    {
                        ItemID = item.ItemID,
                        ItemRate = item.ItemRate,
                        ItemQty = item.ItemQty,
                        Amount = item.ItemRate * item.ItemQty,
                        CoaID = item.CoaID,
                        ItemDescription = item.ItemDescription,     
                        // CGST = IsTaxable ? (Local ? (item.ItemGstVal / 2) : 0) : 0,
                        // SGST = IsTaxable ? (Local ? (item.ItemGstVal / 2) : 0) : 0,
                        // IGST = IsTaxable ? (Local ? 0 : (item.ItemGstVal)) : 0,
                        IGST = item.ItemGstVal,
                    }
            );
        }
        tpm.TotalAmount = tpm.Items.Sum(x => x.Amount + x.IGST);
        DialogParameters parms = new DialogParameters();
        parms.Add("model", tpm.Clone());
        var dialog = DialogService.Show<TaxPurchaseDialog>(tpm.PID == null ? "ADD" : "EDIT", parms, maxWidth);
        var result = await dialog.Result;
        if (!result.Canceled)
        {
            GetAll();
        }
    }
}