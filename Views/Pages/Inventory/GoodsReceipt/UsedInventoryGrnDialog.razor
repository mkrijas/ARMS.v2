@using System.Threading;
@using Views.Pages.Finance.Transactions
@inject IInventoryGrnService Iservice
@inject ITruckService truckIservice
@inject IInventoryItemService itemIservice
@inject IStoreService storeIservice
@inject IPurchaseOrderService pIservice
@inject IGstItemService gstIservice
@inject MudBlazor.ISnackbar snackbar
@inject AuthenticationStateProvider auth
@inject IRoleService<RoleModel> Irole
@attribute [Authorize]
@inject IDialogService DialogService

<DialogForm @ref="@dialogForm" ReadOnly="@ReadOnly" Title="Used Goods Receipt Note" Subtitle="Record received used inventory items and update vehicle-specific stock levels." Icon="@Icons.Material.Filled.Build" AdminStyle="true" formID="formtdsRate" model="@model" _busy="_busy">
    <FormContent>
        <div class="dialog-content-wrapper">
            <EditForm id="formtdsRate" Model="@model" OnValidSubmit="OnValidSubmit">
                <ObjectGraphDataAnnotationsValidator />
                
                <div class="admin-glass-card pa-6 mb-6">
                    <div class="d-flex align-center mb-6">
                        <MudIcon Icon="@Icons.Material.Filled.Info" Color="Color.Primary" Class="mr-2" />
                        <span class="admin-section-label mb-0">General Information</span>
                    </div>
                    <MudGrid Spacing="3">
                        <MudItem xs="12">
                            <TruckSelector IsDisabled="ReadOnly" @bind-Value="truckinfo" BranchID="@(branchID ?? 0)" Filter="All" Class="admin-input-group"></TruckSelector>
                        </MudItem>
                        <MudItem xs="12" md="4">
                            <MudDatePicker ReadOnly="ReadOnly" Label="Entry Date" Variant="Variant.Outlined" Margin="Margin.Dense" DisableToolbar="true" Editable="true" @bind-Date="model.EntryDate" DateFormat="dd/MM/yyyy" Class="admin-input-group" />
                        </MudItem>
                        <MudItem xs="12" md="4">
                            <MudTextField ReadOnly="ReadOnly" @bind-Value="model.Reference" Label="Reference" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.Reference)" Class="admin-input-group"></MudTextField>
                        </MudItem>
                        <MudItem xs="12" md="4">
                            <StoreSelector IsDisabled="ReadOnly" @bind-Value="model.Store" VariantParameter="Variant.Outlined" MarginParameter="Margin.Dense" BranchID="@(branchID ?? 0)" Class="admin-input-group"></StoreSelector>
                        </MudItem>
                        <MudItem xs="12">
                            <MudTextField ReadOnly="ReadOnly" @bind-Value="model.Remarks" Label="Remarks / Description" Variant="Variant.Outlined" Margin="Margin.Dense" Lines="2" For="@(() => model.Remarks)" Class="admin-input-group"></MudTextField>
                        </MudItem>
                    </MudGrid>
                </div>
                <div class="admin-glass-card pa-0 overflow-hidden mb-6">
                    <div class="px-6 py-4 border-bottom-subtle d-flex align-center" style="background: rgba(255, 159, 67, 0.03); border-bottom: 1px solid rgba(255, 159, 67, 0.3);">
                        <MudIcon Icon="@Icons.Material.Filled.Inventory" Color="Color.Warning" Class="mr-2" />
                        <span class="admin-section-label mb-0">Items Received (Used)</span>
                    </div>
                    <div class="modern-admin-table">
                        <MudSimpleTable Style="width:100%" Hover="true" FixedHeader="true" Dense="true" Elevation="0">
                            <thead>
                                <tr>
                                    <th style="width: 50%">ITEM DETAILS</th>
                                    <th>QUANTITY</th>
                                    <th>RATE</th>
                                    <th style="width: 50px"></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in model.Entries)
                                {
                                    var itemInfo = itm.FirstOrDefault(x => x.InventoryItemID == item.ItemID);
                                    <tr>
                                        <td>
                                            <div class="d-flex flex-column">
                                                <MudText Typo="Typo.body2" Class="fw-bold">@itemInfo?.InventoryItemCode | @itemInfo?.ItemDescription</MudText>
                                                <MudText Typo="Typo.caption" Class="mud-text-secondary">@itemInfo?.ItemGroup?.ItemGroupDescription</MudText>
                                            </div>
                                        </td>
                                        <td>@item.ItemQty</td>
                                        <td>@item.ItemRate?.ToString("N2")</td>
                                        <td>
                                            @if (!ReadOnly)
                                            {
                                                <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small" OnClick="@(()=> Delete(@item))" />
                                            }
                                        </td>
                                    </tr>
                                }
                                @if (!ReadOnly && model.POID == null)
                                {
                                    <tr style="background: rgba(54, 117, 136, 0.05);">
                                        <td>
                                            <InventoryItemSelector Value="SelectedItems" ValueChanged="@((InventoryItemModel newValue) => getitemCode(newValue))" Class="admin-input-group" />
                                        </td>
                                        <td>
                                            <MudNumericField @bind-Value="Entrymodel.ItemQty" Variant="Variant.Outlined" Margin="Margin.Dense" Class="admin-input-group" HideSpinButtons />
                                        </td>
                                        <td>
                                            <MudNumericField @bind-Value="Entrymodel.ItemRate" Variant="Variant.Outlined" Margin="Margin.Dense" Class="admin-input-group" HideSpinButtons />
                                        </td>
                                        <td>
                                            <MudIconButton Icon="@Icons.Material.Filled.AddCircle" Color="Color.Primary" OnClick="AddItems" />
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </MudSimpleTable>
                    </div>
                    <div class="px-6 py-4 d-flex justify-end" style="background: rgba(0,0,0,0.02);">
                        <MudText Typo="Typo.h6" Class="fw-bold">TOTAL: <span class="mud-text-primary">@(model.TotalValue?.ToString("C") ?? "₹0.00")</span></MudText>
                    </div>
                </div>
            </EditForm>
        </div>
    </FormContent>
    <VerificationStatus>
        @if ((ReadOnly) && (!IsView))
        {
            <AutherizationStatusComponent CreatedBy="@model.UserInfo" DocTypeID="16" DocDate="@DocDate" DocType="@DocType" DocNumber="@DocNumber" PageToRedirectLink="@PageToRedirectLink" DocumentID="model.GrnID" OnApprove="IsApproveData"></AutherizationStatusComponent>
        }
    </VerificationStatus>
    <Actions>
        @if (!ReadOnly && model.POID != null && model.GrnID == null)
        {
            <MudButton Variant="Variant.Filled" Color="Color.Warning" OnClick="CancelOrder" Class="rounded-lg shadow-none mr-2">Cancel Order</MudButton>
        }
    </Actions>
</DialogForm>

@code {

    [Parameter]
    public InventoryGrnModel model { get; set; }
    [Parameter]
    public bool ReadOnly { get; set; }
    [Parameter]
    public bool IsView { get; set; }
    private List<StoreModel> store = new();
    private List<InventoryItemModel> itm = new();
    public TruckModel truckinfo = new();
    private int? branchID = null;
    private string UserID = null;
    private bool _busy;

    [Parameter]
    public string PageToRedirectLink { get; set; }
    public string DocNumber { get; set; }
    public DateTime? DocDate { get; set; }
    public string DocType { get; set; }

    public bool HasPermissionInventoryGrnServiceEdit { get; set; } = false;
    public bool HasPermissionInventoryGrnServiceApprove { get; set; } = false;
    public int InventoryGrnDocTypeID = 16;

    public bool HasPermissionPurchaseOrderServiceCancel { get; set; } = false;
    public int PurchaseOrderDocTypeID = 17;

    public InventoryItemModel SelectedItems = new();
    private InventoryItemEntryModel Entrymodel = new InventoryItemEntryModel();
    private DialogForm dialogForm;
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; }

    protected override async Task OnInitializedAsync()
    {
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionInventoryGrnServiceEdit = await Irole.HasClaim(InventoryGrnDocTypeID.ToString(), "Edit", ctc.Token);
        HasPermissionInventoryGrnServiceApprove = await Irole.HasClaim(InventoryGrnDocTypeID.ToString(), "Approve", ctc.Token);

        HasPermissionPurchaseOrderServiceCancel = await Irole.HasClaim(PurchaseOrderDocTypeID.ToString(), "Cancel", ctc.Token);

        var authprov = await auth.GetAuthenticationStateAsync();
        var brancIDString = authprov.User.Claims.First(x => x.Type == "BranchID").Value;
        branchID = int.Parse(brancIDString);
        var user = authprov.User;
        UserID = user.Identity.Name;
        store = storeIservice.SelectByBranch(branchID ?? 0).ToList();
        if (store.Any(s => s.StoreID == model.StoreID))
        {
            model.Store = store.FirstOrDefault(s => s.StoreID == model.StoreID);
        }
        itm = itemIservice.SearchByDescription(string.Empty).ToList();
        if (model.GrnID != null)
        {
            model.Entries = Iservice.GetItemEntries(model.GrnID.Value).ToList();
            truckinfo = truckIservice.SelectByID(model.TruckID);
            model.TruckID = truckinfo.TruckID;
        }
        else if (model.POID != null)
        {
            truckinfo = truckIservice.SelectByID(model.TruckID);
            model.TruckID = truckinfo.TruckID;
        }
        else
        {
            model.TotalValue = 0;
        }

        DocNumber = model.GrnNo;
        DocDate = model.EntryDate;
        DocType = "Used Goods Receipt Note";
    }

    private async Task OnValidSubmit(EditContext context)
    {
        if (HasPermissionInventoryGrnServiceEdit)
        {
            if (_busy)
            {
                snackbar.Add("Please wait while form is being submitted!", Severity.Warning);
                return;
            }
            if (model.Entries == null || (model.Entries != null && model.Entries.Count() == 0))
            {
                snackbar.Add("Add at least one Entry before Submitting", Severity.Error);
                return;
            }
            else
            {
                model.PartyID = 0;
                model.TruckID = truckinfo.TruckID;
                model.UsedInventory = 1;
                model.StoreID = model.Store?.StoreID ?? null;
                model.UserInfo.UserID = UserID;
                _busy = true;
                try
                {
                    Iservice.Update(model);
                    model = new();
                    snackbar.Add("Saved Successfully", Severity.Success);
                    model = new InventoryGrnModel();
                }
                catch (Exception ex)
                {
                    snackbar.Add(ex.Message, Severity.Warning);
                }
                MudDialog.Close(model);
                await Task.Delay(200);
                _busy = false;
            }
        }
        else
        {
            bool? result = await DialogService.ShowMessageBoxAsync(
                "Permission denied!",
                "You don't have any permission to Edit InventoryGrn.");
        }
    }

    protected async Task IsApproveData(DataApprovedStatus aprvd)
    {
        if (HasPermissionInventoryGrnServiceApprove)
        {
            if (aprvd.IsApprove)
            {
                try
                {
                    model.UserInfo.UserID = UserID;
                    if (model.GrnID != null)
                    {
                        Iservice.Approve(model.GrnID.Value, model.UserInfo.UserID, string.Empty);
                        snackbar.Add("Approved Successfully", Severity.Success);
                    }
                }
                catch (Exception ex)
                {
                    snackbar.Add(ex.Message, Severity.Error);
                }
            }
        }
        else
        {
            bool? result = await DialogService.ShowMessageBoxAsync(
                "Permission denied!",
                "You don't have any permission to Approve InventoryGrn.");
        }
    }

    private void Cancel()
    {
        MudDialog.Cancel();
    }

    private async Task CancelOrder()
    {
        if (HasPermissionPurchaseOrderServiceCancel)
        {
            if (model.POID != null)
            {
                pIservice.CancelOrder(model.POID.Value, UserID, string.Empty);
                MudDialog.Close(model);
            }
        }
        else
        {
            bool? result = await DialogService.ShowMessageBoxAsync(
                "Permission denied!",
                "You don't have any permission to Cancel PurchaseOrder.");
        }
    }

    private void Delete(InventoryItemEntryModel i)
    {
        decimal total = (((i.ItemQty) * (i.ItemRate ?? 0m)) + (i.ItemGstVal ?? 0m));
        model.TotalValue = (model.TotalValue ?? 0m) - total;
        int rowIndex = model.Entries.IndexOf(i);
        model.Entries.RemoveAt(rowIndex);
    }

    protected void getitemCode(InventoryItemModel item)
    {
        if (item != null)
        {
            if (SelectedItems != null && SelectedItems.InventoryItemID == null)
            {
                SelectedItems = item;
            }
            else
            {
                SelectedItems = new InventoryItemModel();
            }
        }
    }

    private void AddItems()
    {
        model.TruckID = truckinfo.TruckID;
        Entrymodel.ItemID = SelectedItems.InventoryItemID;
        if (Entrymodel.ItemID == null || Entrymodel.ItemQty == null)
        {
            snackbar.Add("Please fill in all Fields", Severity.Error);
            return;
        }
        model.Entries.Add(Entrymodel);
        decimal total = (Entrymodel.ItemQty) * (Entrymodel.ItemRate ?? 0m);
        model.TotalValue = (model.TotalValue ?? 0m) + total;
        Entrymodel = new();
        SelectedItems = null;
        SelectedItems = new();
    }
}

