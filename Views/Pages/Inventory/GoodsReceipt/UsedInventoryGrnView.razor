@page "/UsedInventoryGrn"
@page "/UsedInventoryGrn/{id:int}"
@using System.Threading;
@using PurchaseOrder
@attribute [Authorize]
@inject AuthenticationStateProvider auth
@inject IRoleService<RoleModel> Irole
@inject IDialogService DialogService
@inject IInventoryGrnService Iservice
@inject MudBlazor.ISnackbar snackbar
@inject SignalRService signalRService
@inject IPushNotificationService IpushNotificationService

@if (_isLoading)
{
    <div @key="@("loader")" style="display: flex; justify-content: center; align-items: center; min-height: 400px;">
        <LoaderComponent IsFullScreen="true" 
                        ShowLogo="false" 
                        Size="medium" 
                        LoadingText="Auditing Inventory Intake" 
                        SubText="Retrieving GRN ledger..." />
    </div>
}
else
{
    <div class="fade-in">
        <div class="admin-header-tiered mb-6">
            <div class="d-flex align-center justify-space-between">
                <div>
                    <MudText Typo="Typo.h4" Class="admin-title">Inventory Inflow | Recycled Asset Intake</MudText>
                    <MudText Typo="Typo.body2" Class="admin-subtitle">Goods Receipt Note (GRN) terminal for pre-owned inventory. Log refurbished equipment, verify technical conditions, and initiate inventory onboarding across the logistics network while ensuring full lifecycle traceability.</MudText>
                </div>
            </div>
        </div>

        <div class="admin-glass-card mb-6 pa-4">
            <div class="d-flex align-center gap-4 flex-wrap">
                <div style="flex-grow: 1; min-width: 300px;">
                    <MudTextField @bind-Value="searchGrn" Placeholder="Search GRN number..." Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" Variant="Variant.Outlined" Margin="Margin.Dense" Class="admin-input-group" Clearable="true" />
                </div>
                <div class="d-flex align-center gap-4">
                    <div class="admin-control-pill px-4 py-1">
                         <MudCheckBox T="bool" Label="SHOW APPROVED ENTRIES" ValueChanged="((bool value)=>ApprovedChanged(value))" Value="@IsApproved" Size="Size.Small" Color="Color.Primary" Class="fw-800 opa-70" />
                    </div>
                    <div class="admin-icon-square-vibrant small accent-indigo clickable" @onclick="@(()=> OpenDialog(new InventoryGrnModel(){UsedInventory=1},false,false))">
                        <MudIcon Icon="@Icons.Material.Filled.Add" Size="Size.Small" />
                    </div>
                </div>
            </div>
        </div>

        <div class="admin-glass-card pa-0 overflow-hidden shadow-sm">
            <MudTable Items="@collection" RowClassFunc="TableRowClass" Elevation="0" Class="modern-admin-table" Hover="true" T="InventoryGrnModel" Filter="new Func<InventoryGrnModel, bool>(search)">
                <HeaderContent>
                    <MudTh><MudTableSortLabel SortBy="new Func<InventoryGrnModel, object>(x=> x.GrnNo)"><span class="admin-header-text">GRN REFERENCE</span></MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<InventoryGrnModel, object>(x=> x.EntryDate)"><span class="admin-header-text">INTAKE DATE</span></MudTableSortLabel></MudTh>
                    <MudTh Style="text-align: right;"><span class="admin-header-text pr-4">OPERATIONAL ACTIONS</span></MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="GRN">
                         <div class="d-flex align-center gap-2">
                             <div class="admin-icon-square-vibrant tiny accent-indigo">
                                <MudIcon Icon="@Icons.Material.Filled.ReceiptLong" Size="Size.Small" />
                            </div>
                            <span class="fw-700 admin-td-primary">@context.GrnNo</span>
                        </div>
                    </MudTd>
                    <MudTd DataLabel="Date">
                        <span class="fw-600 opa-70">@context.EntryDate?.ToString("dd MMM yyyy")</span>
                    </MudTd>
                    <MudTd DataLabel="Actions" Style="text-align: right;">
                        <div class="d-flex justify-end gap-1 mb-1">
                               @if (@context.AuthLevelID != 99)
                                {
                                    <MudTooltip Text="Execute Verification">
                                        <MudIconButton OnClick="@(()=> OpenDialog(context,true,false))" Color="Color.Warning" Icon="@Icons.Material.Filled.GppGood" Size="Size.Small" Variant="Variant.Text" />
                                    </MudTooltip>
                                }

                                <MudTooltip Text="Inspect Details">
                                    <MudIconButton OnClick="@(()=> OpenDialog(context,true,true))" Color="Color.Info" Icon="@Icons.Material.Filled.Visibility" Size="Size.Small" Variant="Variant.Text" />
                                </MudTooltip>

                                @if (@context.AuthLevelID == null)
                                {
                                    <MudTooltip Text="Modify Entry">
                                        <MudIconButton OnClick="@(()=> OpenDialog(context,false,false))" Color="Color.Primary" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Variant="Variant.Text" />
                                    </MudTooltip>
                                    <MudTooltip Text="Purge Record">
                                        <MudIconButton OnClick="@(()=> Delete(context))" Color="Color.Error" Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Variant="Variant.Text" />
                                    </MudTooltip>
                                }
                        </div>
                    </MudTd>
                </RowTemplate>
                <PagerContent>
                    <div class="pa-4">
                        <MudTablePager PageSizeOptions="new int[] { 10, 20, 50, 100 }" />
                    </div>
                </PagerContent>
            </MudTable>
        </div>
    </div>
}

@code {

    private bool _isLoading = true;
    private DateTime _loadStartTime;

    private InventoryGrnModel model = new InventoryGrnModel();
    private List<InventoryGrnModel> collection = new List<InventoryGrnModel>();
    DialogOptions maxWidth = new DialogOptions() { MaxWidth = MaxWidth.Medium, FullWidth = true };
    private string searchGrn = "";
    public bool IsApproved { get; set; } = false;
    private bool _busy;

    [Parameter]
    public int? id { get; set; } = null;

    public bool HasPermissionInventoryGrnServiceDelete { get; set; } = false;
    public int InventoryGrnDocTypeID = 16;

    #region SignaIR Notification

    private PushNotificationModel notificationMessage = new PushNotificationModel();
    #endregion

    protected override async Task OnInitializedAsync()
    {
        _loadStartTime = DateTime.Now;
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionInventoryGrnServiceDelete = await Irole.HasClaim(InventoryGrnDocTypeID.ToString(), "Delete", ctc.Token);

        model = new();
        await GetAll(IsApproved);

        await EnsureMinimumLoadTime();
        _isLoading = false;

        await Task.Delay(200);
        await signalRService.StartAsync();
        if (id != null && collection != null && collection.Any(g => g.GrnID == id))
        {
            await OpenDialog(collection.FirstOrDefault(s => s.GrnID == id), true, false);
        }

    }

    private async Task EnsureMinimumLoadTime()
    {
        var elapsed = (DateTime.Now - _loadStartTime).TotalMilliseconds;
        if (elapsed < 100)
        {
            await Task.Delay(100 - (int)elapsed);
        }
    }

    async Task ApprovedChanged(bool value)
    {
        IsApproved = value;
        await GetAll(IsApproved);
    }

    private async Task GetAll(bool val)
    {
        var authprov = await auth.GetAuthenticationStateAsync();
        var brancIDString = authprov.User.Claims.First(x => x.Type == "BranchID").Value;
        int brancID = int.Parse(brancIDString);
        if (val)
        {
            collection = Iservice.SelectPending(brancID).Where(x => x.AuthLevelID == 99 && x.UsedInventory == 1).ToList();
        }
        else
        {
            collection = Iservice.SelectPending(brancID).Where(x => x.AuthLevelID != 99 && x.UsedInventory== 1).ToList();
        }
    }

    private async Task OpenDialog(InventoryGrnModel tds, bool ReadOnly, bool View)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        _busy = true;
        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;

        DialogParameters parms = new DialogParameters();
        parms.Add("model", tds.Clone());
        parms.Add("PageToRedirectLink", "/UsedInventoryGrn");
        parms.Add("ReadOnly", ReadOnly);
        parms.Add("IsView", View);
        var dialog = await DialogService.ShowAsync<UsedInventoryGrnDialog>(tds.GrnID == null ? "ADD" : "EDIT", parms, maxWidth);
        var result = await dialog.Result;

        var isCancelled = result.Canceled;
        if (!isCancelled)
        {
            var brancIDString = authprov.User.Claims.First(x => x.Type == "BranchID").Value;
            int brancID = int.Parse(brancIDString);
            var ReturnData = (InventoryGrnModel)result.Data;
            notificationMessage.InitiateBranch = new BranchModel() { BranchID = brancID };
            notificationMessage.ReceivedBranch = new BranchModel() { BranchID = brancID };
            notificationMessage.MessageTitle = IpushNotificationService.GetMessageTitle("Goods Receipt Note", ReturnData.GrnNo, "Level 1 Verification");
            notificationMessage.MessageBody = IpushNotificationService.GetMessageBody("Goods Receipt Note", ReturnData.GrnNo, "Level 1 Verification", ReturnData.EntryDate);
            notificationMessage.RedirectedTo = 0;
            notificationMessage.ExpiredBy = 7;
            notificationMessage.DocumentID = ReturnData.GrnID;
            notificationMessage.MessageGroupID = "PendingVerification";
            notificationMessage.PageToRedirectLink = "/UsedInventoryGrn";
            notificationMessage.ClaimValue = "Verify 1";
            notificationMessage.DocumentTypeID = InventoryGrnDocTypeID;
            notificationMessage.MsgDate = DateTime.Now;
            await signalRService.Send(notificationMessage);
        }

        await GetAll(IsApproved);

        await Task.Delay(200);
        _busy = false;
    }

    private async Task Delete(InventoryGrnModel model)
    {
        if (HasPermissionInventoryGrnServiceDelete)
        {
            bool? result = await DialogService.ShowMessageBoxAsync(
                "Warning !",
                "Are you sure, you want to delete - " + model.GrnNo + " ?");
            if (result == true)
            {
                var authprov = await auth.GetAuthenticationStateAsync();
                var user = authprov.User;
                Iservice.Delete(model.GrnID, user.Identity.Name);
                snackbar.Add("Deleted Successfully", Severity.Success);
                await GetAll(IsApproved);
            }
        }
        else
        {
            bool? result = await DialogService.ShowMessageBoxAsync(
                "Permission denied!",
                "You don't have any permission to delete InventoryGrn.");
        }
    }

    private bool search(InventoryGrnModel tds)
    {
        if (tds.GrnNo != null && tds.GrnNo.Contains(searchGrn, StringComparison.OrdinalIgnoreCase))
        {
            return true;
        }
        else if (tds.GrnNo == null)
            return true;
        return false;
    }

    private string TableRowClass(InventoryGrnModel IG, int index)
    {
        if (IG.AuthLevelID == 99)
        {
            return "bg-primary-light";
        }
        return string.Empty;
    }
}

