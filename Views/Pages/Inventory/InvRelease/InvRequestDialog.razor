@using ArmsModels.BaseModels.Finance.Transactions;
@using ArmsServices.DataServices.Finance.Transactions;
@using ArmsServices.DataServices.Inventory;
@attribute [Authorize]
@inject MudBlazor.ISnackbar snackbar
@inject AuthenticationStateProvider auth
@inject IInventoryRequestService Iservice
@inject IJobcardService IJobcardService
@inject IDialogService DialogService
@inject IInventoryItemService itemIservice
@using System.Threading;
@inject IRoleService<RoleModel> Irole

<DialogForm @ref="@dialogForm" ReadOnly="@ReadOnly" Title="Inventory Request" Subtitle="Submit requests for inventory items linked to specific job cards or vehicles." Icon="@Icons.Material.Filled.Assignment" AdminStyle="true" formID="inventoryRequestForm" model="@model" _busy="_busy">
    <FormContent>
        <div class="dialog-content-wrapper">
            <EditForm id="inventoryRequestForm" Model="@model" OnValidSubmit="OnValidSubmit">
                <ObjectGraphDataAnnotationsValidator />
                
                <div class="admin-glass-card pa-6 mb-6">
                    <div class="d-flex align-center mb-6">
                        <MudIcon Icon="@Icons.Material.Filled.Info" Color="Color.Primary" Class="mr-2" />
                        <span class="admin-section-label mb-0">Request Information</span>
                    </div>
                    <MudGrid Spacing="3">
                        <MudItem xs="12" md="4">
                            <MudTextField @bind-Value="model.RequestNumber" Label="Request Number" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.RequestNumber)" Disabled Class="admin-input-group"></MudTextField>
                         </MudItem>
                         <MudItem xs="12" md="4">
                             <MudDatePicker ReadOnly="ReadOnly" Label="Document Date" Variant="Variant.Outlined" Margin="Margin.Dense" DisableToolbar="true" Editable="true" @bind-Date="model.RequestDate" DateFormat="dd/MM/yyyy" Class="admin-input-group" />
                         </MudItem>
                         <MudItem xs="12" md="4">
                             <MudSelect Label="Job Card" T="JobcardModel" Value="model.Jobcard" ValueChanged="OnChangeJobcard" ToStringFunc="@(e => e == null ? null : $"{e.JobcardNumber}")" Variant="Variant.Outlined" Margin="Margin.Dense" Disabled="@SetIncomingVal" Class="admin-input-group">
                                 @foreach (var ditem in JobcardList)
                                {
                                    <MudSelectItem Value="@ditem">@ditem.JobcardNumber</MudSelectItem>
                                }
                            </MudSelect>
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <TruckSelector @bind-Value="@model.Truck" BranchID="@model.BranchID" IsDisabled="@SetIncomingVal" Filter="All" Class="admin-input-group"></TruckSelector>
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <StoreSelector @bind-Value="@model.Store" BranchID="@(model.BranchID??0)" Class="admin-input-group"></StoreSelector>
                        </MudItem>
                        <MudItem xs="12">
                            <MudTextField @bind-Value="model.Remarks" Label="Remarks / Special Instructions" Variant="Variant.Outlined" Margin="Margin.Dense" Lines="2" For="@(() => model.Remarks)" Class="admin-input-group"></MudTextField>
                        </MudItem>
                    </MudGrid>
                </div>

                <div class="admin-glass-card pa-0 overflow-hidden mb-6">
                    <div class="px-6 py-4 border-bottom-subtle d-flex align-center" style="background: rgba(255, 159, 67, 0.03); border-bottom: 1px solid rgba(255, 159, 67, 0.3);">
                        <MudIcon Icon="@Icons.Material.Filled.List" Color="Color.Warning" Class="mr-2" />
                        <span class="admin-section-label mb-0">Requested Items</span>
                    </div>
                    <div class="modern-admin-table">
                        <MudSimpleTable Style="width:100%" Hover="true" FixedHeader="true" Dense="true" Elevation="0">
                            <thead>
                                <tr>
                                    <th style="width: 60%">ITEM DESCRIPTION</th>
                                    <th>QUANTITY</th>
                                    <th style="width: 50px"></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in model.Items)
                                {
                                    <tr>
                                        <td>
                                            <MudText Typo="Typo.body2" Class="fw-bold">
                                                @(ItemList.FirstOrDefault(x => x.InventoryItemID == item.ItemID)?.ItemGroup.ItemGroupDescription) - @(ItemList.FirstOrDefault(x => x.InventoryItemID == item.ItemID)?.ItemDescription)
                                            </MudText>
                                        </td>
                                        <td>@item.ItemQty</td>
                                        <td>
                                            @if (!ReadOnly)
                                            {
                                                <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small" OnClick="@(()=> DeleteItem(@item))" />
                                            }
                                        </td>
                                    </tr>
                                }
                                @if (!ReadOnly)
                                {
                                    <tr style="background: rgba(54, 117, 136, 0.05);">
                                        <td>
                                            <InventoryItemSelector Value="SelectedItems" ValueChanged="@((InventoryItemModel newValue) => getitemCode(newValue))" Class="admin-input-group" />
                                        </td>
                                        <td>
                                            <MudNumericField @bind-Value="Entrymodel.ItemQty" Variant="Variant.Outlined" Margin="Margin.Dense" Class="admin-input-group" HideSpinButtons />
                                        </td>
                                        <td>
                                            <MudIconButton Icon="@Icons.Material.Filled.AddCircle" Color="Color.Primary" OnClick="AddSubList" />
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </MudSimpleTable>
                    </div>
                </div>
            </EditForm>
        </div>
    </FormContent>
    <VerificationStatus>
        @if (ReadOnly)
        {
            <AutherizationStatusComponent CreatedBy="@model.UserInfo" DocTypeID="@DocTypeID" DocDate="@DocDate" DocType="Inventory Request" DocNumber="@model.RequestNumber" DocumentID="model.RequestID" OnApprove="Approve"></AutherizationStatusComponent>
        }
    </VerificationStatus>
</DialogForm>

@code {

    [Parameter]
    public InventoryRequestModel model { get; set; }
    [Parameter]
    public bool ReadOnly { get; set; }
    private GstUsageCodeModel gstusge = new();
    public string Area { get; set; } = null;
    public bool Local { get; set; } = true;
    public DateTime? DocDate { get; set; }
    private string UserID = null;
    public int SubAssetModel { get; set; }
    private List<InventoryItemModel> ItemList = new();
    private List<JobcardModel> JobcardList = new();
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; }
    [Parameter]
    public bool SetIncomingVal { get; set; } = false;
    public InventoryItemModel SelectedItems = new();
    private InventoryItemEntryModel Entrymodel = new InventoryItemEntryModel();
    private EditContext editContext;
    DialogForm dialogForm;
    private bool _busy;

    public bool HasPermissionInventoryRequestEdit { get; set; } = false;
    public int DocTypeID = 67;

    protected override async Task OnInitializedAsync()
    {
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionInventoryRequestEdit = await Irole.HasClaim(DocTypeID.ToString(), "Edit", ctc.Token);

        var authprov = await auth.GetAuthenticationStateAsync();
        model.BranchID = int.Parse(authprov.User.Claims.First(x => x.Type == "BranchID").Value);
        var user = authprov.User;
        UserID = user.Identity.Name;
        if (model.UserInfo == null)
        {
            model.UserInfo = new();
        }
        model.UserInfo.UserID = UserID;
        if (model == null)
        {
            model = new()
                {
                    UserInfo = new() { UserID = UserID, },
                };
        }
        else
        {
            model.Items = Iservice.GetSub(model.RequestID).ToList();
        }
        ItemList = itemIservice.SearchByDescription(string.Empty).ToList();
        JobcardList = IJobcardService.SelectByBranch(model.BranchID, true).ToList();
        DocDate = model.RequestDate;
    }

    protected override void OnParametersSet()
    {
        editContext = new EditContext(model);
    }

    public void AddSubList()
    {
        Entrymodel.ItemID = SelectedItems.InventoryItemID;
        if (Entrymodel.ItemID == null || Entrymodel.ItemQty == null || Entrymodel.ItemQty == 0)
        {
            snackbar.Add("Please fill in all Fields", Severity.Success);
            return;
        }
        model.Items.Add(Entrymodel);
        Entrymodel = new();
        SelectedItems = null;
        SelectedItems = new();
    }

    protected void getitemCode(InventoryItemModel item)
    {
        if (item != null)
        {
            if (SelectedItems != null && SelectedItems.InventoryItemID == null)
            {
                SelectedItems = item;
            }
            else
            {
                SelectedItems = new InventoryItemModel();
            }
        }
    }

    public void OnChangeJobcard(JobcardModel obj)
    {
        model.Jobcard = obj;
    }

    public void OnChangeTruck(TruckModel obj)
    {
        model.Truck = obj;
    }

    public async void OnValidSubmit(EditContext context)
    {
        if (HasPermissionInventoryRequestEdit)
        {
            if (_busy)
            {
                snackbar.Add("Please wait while form is being submitted!", Severity.Warning);
                return;
            }
            try
            {
                if (model.Items.Count() == 0)
                {
                    snackbar.Add("Add at least one item.", Severity.Error);
                    return;
                }
                _busy = true;

                var result = Iservice.Update(model);
                model.RequestNumber = result.RequestNumber;
                model.RequestID = result.RequestID;
                snackbar.Add("Saved Successfully", Severity.Success);
                MudDialog.Close(model);
            }
            catch (Exception ex)
            {
                snackbar.Add(ex.Message, Severity.Error);
            }
            finally
            {
                await Task.Delay(200);
                _busy = false;
            }
        }
        else
        {
            bool? result = await DialogService.ShowMessageBoxAsync(
                "Permission denied!",
                "You don't have any permission to Edit InventoryRequest.");
        }
    }

    private void DeleteItem(InventoryItemEntryModel ItemDetails)
    {
        if (model.Items.Exists(x => x.ItemID == ItemDetails.ItemID))
        {
            int rowIndex = model.Items.IndexOf(ItemDetails);
            model.Items.RemoveAt(rowIndex);
        }
    }

    protected async Task Approve(DataApprovedStatus aprvd)
    {
        if (aprvd.IsApprove)
        {
            try
            {
                // Iservice.Approve(model.RequestID, UserID, aprvd.Remarks);
                snackbar.Add("Approved Successfully", Severity.Success);
            }
            catch (Exception ex)
            {
                snackbar.Add(ex.Message, Severity.Error);
            }
        }
    }

    private void Cancel()
    {
        MudDialog.Cancel();
    }
}

