@page "/InventoryRequestView"
@using ArmsModels.BaseModels.Finance.Transactions;
@using ArmsServices.DataServices.Finance.Transactions;
@using ArmsServices.DataServices.Inventory;
@using Microsoft.AspNetCore.Authorization;
@using Microsoft.AspNetCore.Components.Authorization;
@using MudBlazor;
@using Views.Pages.Finance.Transactions;
@attribute [Authorize]
@inject AuthenticationStateProvider auth
@inject MudBlazor.ISnackbar snackbar
@inject IDialogService DialogService
@inject IInventoryRequestService Iservice
@using System.Threading;
@inject IRoleService<RoleModel> Irole

@if (_isLoading)
{
    <div @key="@("loader")" class="d-flex justify-center align-center" style="min-height: 400px;">
        <LoaderComponent IsFullScreen="false" ShowLogo="false" Size="medium" LoadingText="Synchronizing Technical Requisitions" SubText="Retrieving latest workshop inventory requests..." />
    </div>
}
else
{
    <div class="admin-page-container fade-in" @key="@("content")">
        <div class="admin-header-tiered mb-6">
            <div class="d-flex align-center justify-space-between">
                <div>
                    <MudText Typo="Typo.h4" Class="admin-title">Spares Requisition Registry</MudText>
                    <MudText Typo="Typo.body2" Class="admin-subtitle">Oversight of technical item requests linked to active workshop jobcards and fleet assets.</MudText>
                </div>
                <MudButton Disabled="@_busy" Variant="Variant.Filled" Color="Color.Primary" OnClick="@(()=> OpenDialog(null))" Class="admin-register-btn" StartIcon="@Icons.Material.Filled.Add">INITIATE REQUEST</MudButton>
            </div>
        </div>

        <div class="admin-glass-card pa-6 mb-6">
            <MudGrid Spacing="3" Class="align-center">
                <MudItem xs="12" md="6">
                    <MudTextField @bind-Value="searchString" Placeholder="Filter by Request, Jobcard, or Asset..." Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" AdornmentColor="Color.Primary" Variant="Variant.Outlined" Margin="Margin.Dense" Clearable="true" Class="modern-input"></MudTextField>
                </MudItem>
            </MudGrid>
        </div>

        <div class="admin-glass-card overflow-hidden">
            <MudTable Items="@collection" Elevation="0" Hover="true" Breakpoint="Breakpoint.Sm" Class="modern-admin-table" Filter="new Func<InventoryRequestModel, bool>(FilterFunc)">
                <HeaderContent>
                    <MudTh><MudTableSortLabel SortBy="new Func<InventoryRequestModel, object>(x=> x.RequestDate)" InitialDirection="SortDirection.Descending"><span class="admin-header-text">CHRONOLOGY</span></MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<InventoryRequestModel, object>(x=> x.RequestNumber)"><span class="admin-header-text">IDENTIFIER</span></MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<InventoryRequestModel, object>(x=> x.Store.StoreName)"><span class="admin-header-text">WAREHOUSE</span></MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<InventoryRequestModel, object>(x=> x.Jobcard.JobcardNumber)"><span class="admin-header-text">JOBCARD</span></MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<InventoryRequestModel, object>(x=> x.Truck.RegNo)"><span class="admin-header-text">ASSET</span></MudTableSortLabel></MudTh>
                    <MudTh Style="text-align: right;"><span class="admin-header-text">ACTIONS</span></MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Chronology"><span class="admin-td-primary">@context.RequestDate?.ToString("dd MMM yyyy")</span></MudTd>
                    <MudTd DataLabel="Identifier"><span class="fw-700 opacity-80">@context.RequestNumber</span></MudTd>
                    <MudTd DataLabel="Warehouse">@context.Store.StoreName</MudTd>
                    <MudTd DataLabel="Jobcard">
                        <MudChip T="string" Size="Size.Small" Variant="Variant.Text" Color="Color.Primary" Class="fw-600">@context.Jobcard.JobcardNumber</MudChip>
                    </MudTd>
                    <MudTd DataLabel="Asset">
                        <div class="d-flex align-center">
                            <MudIcon Icon="@Icons.Material.Filled.LocalShipping" Size="Size.Small" Color="Color.Info" Class="mr-2" />
                            <span class="fw-600">@context.Truck.RegNo</span>
                        </div>
                    </MudTd>
                    <MudTd DataLabel="Actions" Style="text-align: right;">
                        <MudTooltip Text="Edit Request">
                            <MudIconButton OnClick="@(()=> OpenDialog(context))" Color="Color.Primary" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Variant="Variant.Text" />
                        </MudTooltip>
                        <MudTooltip Text="Delete Request">
                            <MudIconButton OnClick="@(()=> Delete(context))" Color="Color.Error" Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Variant="Variant.Text" />
                        </MudTooltip>
                    </MudTd>
                </RowTemplate>
                <PagerContent>
                    <div class="pa-4">
                        <MudTablePager PageSizeOptions="new int[] { 10, 20, 50, 100 }" />
                    </div>
                </PagerContent>
            </MudTable>
        </div>
    </div>
}



@code {

    private bool _isLoading = true;
    private DateTime _loadStartTime;

    public bool IsApproved { get; set; } = false;
    private List<InventoryRequestModel> collection = new List<InventoryRequestModel>();
    private string searchString = string.Empty;
    private bool _busy;

    public bool HasPermissionInventoryRequestDelete { get; set; } = false;
    public int DocTypeID = 67;

    protected override async Task OnInitializedAsync()
    {
        _loadStartTime = DateTime.Now;
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionInventoryRequestDelete = await Irole.HasClaim(DocTypeID.ToString(), "Delete", ctc.Token);

        GetAll();
        await EnsureMinimumLoadTime();
        _isLoading = false;
    }

    private async Task EnsureMinimumLoadTime()
    {
        var elapsed = (DateTime.Now - _loadStartTime).TotalMilliseconds;
        if (elapsed < 100)
        {
            await Task.Delay(100 - (int)elapsed);
        }
    }

    void ApprovedToggled(bool value)
    {
        IsApproved = value;
        GetAll();
    }

    private void GetAll()
    {
        collection = Iservice.Select().ToList();
    }

    private async Task Delete(InventoryRequestModel model)
    {
        if (HasPermissionInventoryRequestDelete)
        {
            try
            {
                bool? result = await DialogService.ShowMessageBoxAsync(
                    "Warning !",
                    "Are you sure, you want to delete - " + model.RequestDate + " : " + model.Store.StoreName + " (" + model.Jobcard.JobcardNumber + ") ? ");
                if (result == true)
                {
                    var authprov = await auth.GetAuthenticationStateAsync();
                    var user = authprov.User;
                    Iservice.Delete(model.RequestID, user.Identity.Name);
                    snackbar.Add("Deleted Successfully", Severity.Success);
                    GetAll();
                }
            }
            catch (Exception ex)
            {
                snackbar.Add(ex.Message, Severity.Error);
            }
        }
        else
        {
            bool? result = await DialogService.ShowMessageBoxAsync(
                "Permission denied!",
                "You don't have any permission to Delete InventoryRequest.");
        }
    }

    private async Task OpenDialog(InventoryRequestModel model)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        _busy = true;
        var authprov = await auth.GetAuthenticationStateAsync();
        var branchID = int.Parse(authprov.User.Claims.First(x => x.Type == "BranchID").Value);

        DialogOptions mediumWidth = new DialogOptions() { MaxWidth = MaxWidth.Medium, FullWidth = true };
        DialogParameters parms = new DialogParameters();
        parms.Add("model", model.Clone());
        parms.Add("branchID", branchID);
        var dialog = await DialogService.ShowAsync<InventoryReleaseDialog>(model == null ? "ADD" : "EDIT", parms, mediumWidth);
        var result = await dialog.Result;
        GetAll();
        await Task.Delay(200);
        _busy = false;
    }

    private bool FilterFunc(InventoryRequestModel model)
    {
        if (string.IsNullOrWhiteSpace(searchString)) return true;
        if (model.RequestNumber?.Contains(searchString, StringComparison.OrdinalIgnoreCase) == true) return true;
        if (model.Jobcard?.JobcardNumber?.Contains(searchString, StringComparison.OrdinalIgnoreCase) == true) return true;
        if (model.Truck?.RegNo?.Contains(searchString, StringComparison.OrdinalIgnoreCase) == true) return true;
        if (model.Store?.StoreName?.Contains(searchString, StringComparison.OrdinalIgnoreCase) == true) return true;
        return false;
    }
}

