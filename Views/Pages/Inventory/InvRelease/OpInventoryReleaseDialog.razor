@using ArmsModels.BaseModels.Finance.Transactions;
@using ArmsServices.DataServices.Finance.Transactions;
@using ArmsServices.DataServices.Inventory;
@using Core.BaseModels.Finance.Transactions;

@using Core.IDataServices.Finance.Transactions;
@using System.Threading;
@attribute [Authorize]
@inject MudBlazor.ISnackbar snackbar
@inject AuthenticationStateProvider auth
@inject IOpInventoryReleaseService Iservice
@inject IInventoryReleaseService Irservice
@inject IRoleService<RoleModel> Irole
@inject IDialogService DialogService
@inject IInventoryItemService itemIservice
@inject ITruckService Itruck

<DialogForm @ref="@dialogForm" ReadOnly="@ReadOnly" Title="Bulk Inventory Release" Subtitle="Authorize large-scale inventory issuance for operational requirements." Icon="@Icons.Material.Filled.Inventory" AdminStyle="true" formID="OpInventoryReleaseForm" DocumentDetails="@DocumentDetails" model="@model" TotalAmount="model.TotalAmount" _busy="_busy">
    <FormContent>
        <div class="dialog-content-wrapper">
            <EditForm id="OpInventoryReleaseForm" OnValidSubmit="OnValidSubmit" EditContext="editContext">
                <ObjectGraphDataAnnotationsValidator />
                <ValidationSummary />

                <div class="admin-glass-card pa-6 mb-6">
                    <div class="d-flex align-center mb-6">
                        <MudIcon Icon="@Icons.Material.Filled.Info" Color="Color.Primary" Class="mr-2" />
                        <span class="admin-section-label mb-0">General Information</span>
                    </div>
                    <MudGrid Spacing="3">
                        <MudItem xs="12" md="4">
                            <MudTextField ReadOnly="ReadOnly" @bind-Value="model.DocumentNumber" Label="Document Number" Variant="Variant.Outlined" Margin="Margin.Dense" Disabled Class="admin-input-group"></MudTextField>
                        </MudItem>
                        <MudItem xs="12" md="4">
                            <MudDatePicker Disabled Label="Document Date" Variant="Variant.Outlined" Margin="Margin.Dense" DisableToolbar="true" Editable="true" @bind-Date="model.DocumentDate" DateFormat="dd/MM/yyyy" Class="admin-input-group" />
                        </MudItem>
                        <MudItem xs="12" md="4">
                            <MudTextField ReadOnly="ReadOnly" @bind-Value="model.Reference" Label="Reference" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.Reference)" Class="admin-input-group"></MudTextField>
                        </MudItem>
                        <MudItem xs="12" md="8">
                            <InventoryItemSelector For="@(() => model.Item)" Value="model.Item" ValueChanged="@((InventoryItemModel newValue) => SetItem(newValue))" ReadOnly="@ReadOnly" Class="admin-input-group" />
                        </MudItem>
                        <MudItem xs="12" md="4" Class="d-flex align-center">
                            <MudCheckBox T="bool" ValueChanged="((bool e)=>SetUsedItem(e))" Value="model.IsUsedItem" ReadOnly="@ReadOnly" Label="Used Item" Color="Color.Primary" Class="ml-2"></MudCheckBox>
                        </MudItem>
                        <MudItem xs="12">
                            <MudTextField ReadOnly="ReadOnly" @bind-Value="model.Narration" Lines="2" Label="Narration" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.Narration)" Class="admin-input-group"></MudTextField>
                        </MudItem>
                        <MudItem xs="12">
                            <MudTextField @bind-Value="model.TotalQty" Label="Total Quantity" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.TotalQty)" Disabled Class="admin-input-group" Adornment="Adornment.End" AdornmentIcon="@Icons.Material.Filled.Numbers" AdornmentColor="Color.Primary"></MudTextField>
                        </MudItem>
                    </MudGrid>
                </div>

                <div class="admin-glass-card pa-0 overflow-hidden mb-6">
                    <div class="px-6 py-4 border-bottom-subtle d-flex align-center" style="background: rgba(255, 159, 67, 0.03); border-bottom: 1px solid rgba(255, 159, 67, 0.3);">
                        <MudIcon Icon="@Icons.Material.Filled.List" Color="Color.Warning" Class="mr-2" />
                        <span class="admin-section-label mb-0">Batch Release Specifications</span>
                    </div>
                    
                    <div class="modern-admin-table">
                        <MudSimpleTable Style="width:100%" Hover="true" FixedHeader="true" Dense="true" Elevation="0">
                            <thead>
                                <tr>
                                    <th>TRIP NO</th>
                                    <th>TRUCK NO</th>
                                    <th>COST CENTER</th>
                                    <th>DIMENSION</th>
                                    <th>QUANTITY</th>
                                    <th style="width: 50px"></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in model.Items)
                                {
                                    <tr>
                                        <td>@item.TripNo</td>
                                        <td>@item.TruckRegNo</td>
                                        <td>@item.CostCenterVal</td>
                                        <td>@item.DimensionVal</td>
                                        <td>@item.ItemQty</td>
                                        <td>
                                            @if (model.OpInventoryReleaseID == null && !ReadOnly)
                                            {
                                                <MudIconButton Title="Delete" Color="Color.Error" @onclick="@(()=> DeleteItem(@item))" Icon="@Icons.Material.Filled.Delete" Size="Size.Small" />
                                            }
                                        </td>
                                    </tr>
                                }
                                @if (model.OpInventoryReleaseID == null && !ReadOnly)
                                {
                                    <tr style="background: rgba(54, 117, 136, 0.05);">
                                        <td>
                                            <TripSelector For="@(() => SelectedTrip)" Value="SelectedTrip" BranchID="model.BranchID" ValueChanged="@((TripModel newValue) => SetTrip(newValue))" Class="admin-input-group" />
                                        </td>
                                        <td>
                                            <TruckSelector For="@(() => SelectedTruck)" @bind-Value="SelectedTruck" IsDisabled="@IsDisableTruck" Filter="All" Class="admin-input-group"></TruckSelector>
                                        </td>
                                        <td>
                                            <CostCenterSelector For="@(() => Entrymodel.CostCenter)" @bind-Value="Entrymodel.CostCenter" @bind-ValueText="Entrymodel.CostCenterVal" ReadOnly="@ReadOnly" Class="admin-input-group" />
                                        </td>
                                        <td>
                                            <DimensionSelector For="@(() => Entrymodel.Dimension)" @bind-Value="Entrymodel.Dimension" @bind-ValueText="Entrymodel.DimensionVal" ReadOnly="@ReadOnly" Class="admin-input-group" />
                                        </td>
                                        <td>
                                            <MudTextField @bind-Value="EnteredQty" Label="Qty" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => EnteredQty)" Class="admin-input-group" HideSpinButtons />
                                        </td>
                                        <td>
                                            <MudIconButton OnClick="AddSubList" Color="Color.Primary" Icon="@Icons.Material.Filled.AddCircle" Disabled="@disableAdd" />
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </MudSimpleTable>
                    </div>
                </div>
            </EditForm>
        </div>
    </FormContent>
    <VerificationStatus>
        <AutherizationStatusComponent CreatedBy="@model.UserInfo" DocTypeID="@OpInventoryReleaseDocTypeID" DocDate="@DocDate" DocType="@DocType" DocNumber="@DocNumber" PageToRedirectLink="@PageToRedirectLink" DocumentID="model.OpInventoryReleaseID" OnReject="OnReject" OnApprove="Approve"></AutherizationStatusComponent>
    </VerificationStatus>
</DialogForm>

@code {

    [Parameter]
    public OpInventoryReleaseModel model { get; set; }
    [Parameter]
    public bool ReadOnly { get; set; }
    [Parameter]
    public string PageToRedirectLink { get; set; }
    public string DocNumber { get; set; }
    public DateTime? DocDate { get; set; }
    public string DocType { get; set; }
    [Parameter]
    public int? branchID { get; set; }
    private string UserID = null;
    private List<InventoryItemModel> ItemList = new();
    private List<TruckModel> TruckList = new();
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; }
    [Parameter]
    public bool IsDisableEntries { get; set; } = false;
    public bool IsDisableTruck { get; set; } = false;
    public InventoryItemModel SelectedItems = new();
    public TripModel SelectedTrip = new();
    public TruckModel SelectedTruck = new();
    public decimal? EnteredQty = 0;
    private OpInventoryReleaseSubModel Entrymodel = new OpInventoryReleaseSubModel();
    public DocumentInfoModel DocumentDetails { get; set; } = new();
    private EditContext editContext;
    private bool _busy;
    string UserIDTemp;
    bool disableAdd = false;

    public bool HasPermissionOpInventoryReleaseServiceEdit { get; set; } = false;
    public bool HasPermissionOpInventoryReleaseServiceApprove { get; set; } = false;
    public int OpInventoryReleaseDocTypeID = 51;

    DialogForm dialogForm;

    protected override async Task OnInitializedAsync()
    {
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionOpInventoryReleaseServiceEdit = await Irole.HasClaim(OpInventoryReleaseDocTypeID.ToString(), "Edit", ctc.Token);
        HasPermissionOpInventoryReleaseServiceApprove = await Irole.HasClaim(OpInventoryReleaseDocTypeID.ToString(), "Approve", ctc.Token);

        var authprov = await auth.GetAuthenticationStateAsync();
        model.BranchID = int.Parse(authprov.User.Claims.First(x => x.Type == "BranchID").Value);
        var user = authprov.User;
        UserID = user.Identity.Name;
        // UserIDTemp = model.UserInfo.UserID;
        // if (model.UserInfo == null)
        // {
        //     model.UserInfo = new();
        // }
        // model.UserInfo.UserID = UserID;
        // if (model == null)
        // {
        //     model = new()
        //         {
        //             UserInfo = new() { UserID = UserID, },
        //         };
        // }
        if (model == null || model.OpInventoryReleaseID == null)
        {
            model.UserInfo = new();
            model.UserInfo.UserID = UserID;
        }
        else
        {
            UserIDTemp = model.UserInfo.UserID;
            model.Items = Iservice.GetSub(model.OpInventoryReleaseID).ToList();
            model.TotalQty = model?.Items?.Sum(s => s.ItemQty) ?? 0;
        }
        TruckList = Itruck.SelectByBranch(model.BranchID, "All", "Home").ToList();
        ItemList = itemIservice.SearchByDescription(string.Empty).ToList();

        DocNumber = model.DocumentNumber;
        DocDate = model.DocumentDate;
        DocType = model.NatureOfTransaction;
    }

    public void SetUsedItem(bool val)
    {
        model.IsUsedItem = val;
    }

    protected async Task Approve(DataApprovedStatus aprvd)
    {
        if (HasPermissionOpInventoryReleaseServiceApprove)
        {
            if (aprvd.IsApprove)
            {
                try
                {
                    model.UserInfo.UserID = UserID;
                    Iservice.Approve(model.OpInventoryReleaseID, model.UserInfo.UserID, aprvd.Remarks);
                    model.UserInfo.UserID = UserIDTemp;
                    snackbar.Add("Approved Successfully", Severity.Success);
                }
                catch (Exception ex)
                {
                    snackbar.Add(ex.Message, Severity.Error);
                }
            }
        }
        else
        {
            bool? result = await DialogService.ShowMessageBoxAsync(
                "Permission denied!",
                "You don't have any permission to Approve OpInventoryRelease.");
        }
    }

    protected void OnReject()
    {
        Irservice.Reject(model.OpInventoryReleaseID, "Bulk Release"); // Call service to reject the payment
    }

    protected override void OnParametersSet()
    {
        editContext = new EditContext(model);

        DocumentDetails.DocumentTypeID = OpInventoryReleaseDocTypeID;
        DocumentDetails.DocumentID = model.OpInventoryReleaseID;
    }

    public void AddSubList()
    {
        disableAdd = true;
        if (SelectedTruck != null && SelectedTruck.TruckID == null)
        {
            snackbar.Add("Please fill truck.", Severity.Error);
            return;
        }
        if (EnteredQty == 0)
        {
            snackbar.Add("Please fill quantity.", Severity.Error);
            return;
        }
        OpInventoryReleaseSubModel SubModelEntry = new()
            {
                TripID = SelectedTrip?.TripID ?? 0,
                TripNo = SelectedTrip != null ? (SelectedTrip.TripPrefix + SelectedTrip.TripNumber.ToString()) : "",
                TruckID = SelectedTruck.TruckID,
                TruckRegNo = SelectedTruck.RegNo,
                ItemQty = EnteredQty
            };
        model.Items.Add(SubModelEntry);
        model.TotalQty = model?.Items?.Sum(s => s.ItemQty) ?? 0;
        Entrymodel = new();
        SelectedTrip = new();
        SelectedTruck = new();
        EnteredQty = 0;        
        SelectedItems = new();
        IsDisableTruck = true;
        disableAdd = false;
        SetNarration();
    }

    protected void SetItem(InventoryItemModel item)
    {
        model.Item = item;
        if (item != null)
        {
            if (SelectedItems != null && SelectedItems.InventoryItemID == null)
            {
                SelectedItems = item;
            }
            else
            {
                SelectedItems = new InventoryItemModel();
            }
        }
        SetNarration();
    }

    void SetNarration()
    {
        model.Narration = (model.Item?.ItemGroup.ItemGroupDescription ?? "") + " - " + (model.Item?.ItemDescription ?? "") + " Issue " + (model.Items?.Count() ?? 0) + " against " + String.Join(", ", (model.Items?.Select(s => s.TripNo)?.ToList() ?? null));
    }

    void SetTrip(TripModel item)
    {
        SelectedTrip = item;
        if (item == null || item.TripID == null || item.TripID == 0)
        {
            IsDisableTruck = false;
        }
        else
        {
            SelectedTruck = TruckList.FirstOrDefault(s => s.TruckID == item.TruckID);
            IsDisableTruck = true;
        }
    }

    public async Task OnValidSubmit(EditContext context)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is being submitted!", Severity.Warning);
            return;
        }
        if (HasPermissionOpInventoryReleaseServiceEdit)
        {
            try
            {
                if (model.Items.Count() == 0)
                {
                    snackbar.Add("Add at least one item.", Severity.Error);
                    return;
                }
                _busy = true;
                model = Iservice.Update(model);
                snackbar.Add("Saved Successfully", Severity.Success);
                MudDialog.Close(model);
            }
            catch (Exception ex)
            {
                snackbar.Add(ex.Message, Severity.Error);
            }
            finally
            {
                await Task.Delay(200);
                _busy = false;
            }
        }
        else
        {
            bool? result = await DialogService.ShowMessageBoxAsync(
                "Permission denied!",
                "You don't have any permission to Edit OpInventoryRelease.");
        }
    }

    private void DeleteItem(OpInventoryReleaseSubModel ItemDetails)
    {
        if (model.Items.Exists(x => x.OpInventoryReleaseSubID == ItemDetails.OpInventoryReleaseSubID))
        {
            int rowIndex = model.Items.IndexOf(ItemDetails);
            model.Items.RemoveAt(rowIndex);
            model.TotalQty = model?.Items?.Sum(s => s.ItemQty) ?? 0;
            disableAdd = false;
            SetNarration();
        }
    }

    private void Cancel()
    {
        MudDialog.Cancel();
    }
}

