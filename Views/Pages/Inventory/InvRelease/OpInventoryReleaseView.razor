@page "/OpInventoryReleaseView"
@page "/OpInventoryReleaseView/{id:int}"
@using System.Threading;
@using ArmsModels.BaseModels.Finance.Transactions
@using Core.BaseModels.Finance.Transactions;
@using Core.IDataServices.Finance.Transactions;
@inject IOpInventoryReleaseService Iservice
@inject ICostCenterService costIservice
@inject IDimensionService dimensionIservice
@inject NavigationManager uriHelper;
@inject MudBlazor.ISnackbar snackbar
@inject AuthenticationStateProvider auth
@inject IRoleService<RoleModel> Irole
@attribute [Authorize]
@inject IDialogService DialogService
@inject SignalRService signalRService
@inject IPushNotificationService IpushNotificationService

<div class="admin-page-container fade-in">
    <div class="admin-header-tiered mb-6">
        <div class="d-flex align-center justify-space-between">
            <div>
                <MudText Typo="Typo.h4" Class="admin-title">Bulk Inventory Release</MudText>
                <MudText Typo="Typo.body2" Class="admin-subtitle">Manage large-scale inventory disbursements, operational allocations, and technical item releases.</MudText>
            </div>
            <MudButton Disabled="@_busy" Variant="Variant.Filled" Color="Color.Primary" OnClick="@(()=> OpenDialog(new OpInventoryReleaseModel(),false))" Class="admin-register-btn" StartIcon="@Icons.Material.Filled.Add">NEW DISBURSEMENT</MudButton>
        </div>
    </div>

    <div class="admin-glass-card pa-6 mb-6">
        <MudGrid Spacing="3" Class="align-end">
            <MudItem xs="12" md="5">
                <MudTextField @bind-Value="searchTerm" Placeholder="Search by Document or Item..." Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" AdornmentColor="Color.Primary" Variant="Variant.Outlined" Margin="Margin.Dense" Class="modern-input" @onkeyup="HandleSearchKeyUp"></MudTextField>
            </MudItem>
            <MudItem xs="12" md="2">
                <MudNumericField @bind-Value="@NumberOfRecords" Label="Display Limit" Variant="Variant.Outlined" Margin="Margin.Dense" Class="modern-input" HideSpinButtons />
            </MudItem>
            <MudItem xs="12" md="3" Class="d-flex align-center pb-1">
                <MudCheckBox T="bool" Label="Show Validated Entries Only" ValueChanged="((bool value)=>ApprovedChanged(value))" Value="@IsApproved" Size="Size.Medium" Color="Color.Primary" Class="fw-600 opacity-80" />
            </MudItem>
        </MudGrid>
    </div>

    <div class="admin-glass-card overflow-hidden">
        <MudTable Items="@collection" Elevation="0" Hover="true" Breakpoint="Breakpoint.Sm" Class="modern-admin-table">
            <HeaderContent>
                <MudTh><MudTableSortLabel SortBy="new Func<OpInventoryReleaseModel, object>(x=> x.DocumentDate)" InitialDirection="SortDirection.Descending"><span class="admin-header-text">DATE</span></MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<OpInventoryReleaseModel, object>(x=> x.DocumentNumber)"><span class="admin-header-text">REF NUMBER</span></MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<OpInventoryReleaseModel, object>(x=> x.Item.InventoryItemCode)"><span class="admin-header-text">RESOURCE SPECIFICATION</span></MudTableSortLabel></MudTh>
                <MudTh Style="text-align: right;"><span class="admin-header-text">STATUS & ACTIONS</span></MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Date"><span class="admin-td-primary">@context.DocumentDate?.ToString("dd MMM yyyy")</span></MudTd>
                <MudTd DataLabel="Ref Number"><span class="fw-700 opacity-80">@context.DocumentNumber</span></MudTd>
                <MudTd DataLabel="Resource">
                    <div class="d-flex flex-column">
                        <span class="fw-600 color-primary">@context.Item.InventoryItemCode</span>
                        <span class="small opacity-60">@context.Item.ItemGroup.ItemGroupDescription - @context.Item.ItemDescription</span>
                    </div>
                </MudTd>
                <MudTd DataLabel="Actions" Style="text-align: right;">
                    <div class="d-flex justify-end align-center gap-2">
                        @if (context.AuthLevelId == 99)
                        {
                            <EntryReversedComponent DocTypeID="OpInventoryReleaseDocTypeID" DocumentID="context.OpInventoryReleaseID" MID="context.MID" DocumentNumber="@context.DocumentNumber"></EntryReversedComponent>
                        }
                        else if (context.AuthLevelId != 100)
                        {
                            <MudTooltip Text="Verify Release">
                                <MudIconButton OnClick="@(()=> OpenDialog(context,true))" Color="Color.Warning" Icon="@Icons.Material.Filled.VerifiedUser" Size="Size.Small" Variant="Variant.Text" />
                            </MudTooltip>
                        }
                        
                        <MudTooltip Text="View Details">
                            <MudIconButton OnClick="@(()=> OpenDialog(context,true))" Color="Color.Info" Icon="@Icons.Material.Filled.Visibility" Size="Size.Small" Variant="Variant.Text" />
                        </MudTooltip>
                        
                        <MudTooltip Text="Edit Records">
                            <MudIconButton Disabled="@(context.AuthLevelId != null)" OnClick="@(()=> OpenDialog(context,false))" Color="Color.Primary" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Variant="Variant.Text" />
                        </MudTooltip>
                        
                        <MudTooltip Text="Purge Record">
                            <MudIconButton Disabled="@(context.AuthLevelId != null)" OnClick="@(()=> Delete(context))" Color="Color.Error" Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Variant="Variant.Text" />
                        </MudTooltip>
                    </div>
                </MudTd>
            </RowTemplate>
            <PagerContent>
                <div class="pa-4">
                    <MudTablePager PageSizeOptions="new int[] { 10, 20, 50, 100 }" />
                </div>
            </PagerContent>
        </MudTable>
    </div>
</div>

@code {

    public bool IsApproved { get; set; } = false;
    private List<OpInventoryReleaseModel> collection = new List<OpInventoryReleaseModel>();
    private int numberOfRecords = 100;
    private string searchTerm = "";
    private int? branchID = null;
    private bool _busy;

    public bool HasPermissionOpInventoryReleaseServiceDelete { get; set; } = false;
    public int OpInventoryReleaseDocTypeID = 51;

    [Parameter]
    public int? id { get; set; } = null;

    #region SignaIR Notification

    private PushNotificationModel notificationMessage = new PushNotificationModel();
    #endregion

    private int NumberOfRecords
    {
        get => numberOfRecords;
        set
        {
            if (numberOfRecords != value)
            {
                numberOfRecords = value;
                _ = ReloadTable();
            }
        }
    }

    private async Task HandleSearchKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await ReloadTable();
        }
    }

    private async Task ReloadTable()
    {
        GetAll(IsApproved, NumberOfRecords);
    }

    protected override async Task OnInitializedAsync()
    {
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionOpInventoryReleaseServiceDelete = await Irole.HasClaim(OpInventoryReleaseDocTypeID.ToString(), "Delete", ctc.Token);

        var authprov = await auth.GetAuthenticationStateAsync();
        branchID = int.Parse(authprov.User.Claims.First(x => x.Type == "BranchID").Value);
        GetAll(IsApproved, NumberOfRecords);

        await Task.Delay(200);
        await signalRService.StartAsync();
        if (id != null && collection != null && collection.Any(g => g.OpInventoryReleaseID == id))
        {
            await OpenDialog(collection.FirstOrDefault(s => s.OpInventoryReleaseID == id), true);
        }

    }

    private void GetAll(bool val, int numberOfRecords)
    {
        int NumberOfRecords = numberOfRecords;
        if (val)
        {
            collection = Iservice.SelectByApproved(branchID, NumberOfRecords, searchTerm).ToList();
        }
        else
        {
            collection = Iservice.SelectByUnapproved(branchID, NumberOfRecords, searchTerm).ToList();
        }
    }

    void ApprovedChanged(bool value)
    {
        IsApproved = value;
        GetAll(IsApproved, NumberOfRecords);
    }

    private async Task OpenDialog(OpInventoryReleaseModel RModel, bool ReadOnly)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        _busy = true;
        DialogOptions mediumWidth = new DialogOptions() { MaxWidth = MaxWidth.Medium, FullWidth = true };
        DialogParameters parms = new DialogParameters();
        parms.Add("model", RModel.Clone());
        parms.Add("PageToRedirectLink", "/OpInventoryReleaseView");
        parms.Add("ReadOnly", ReadOnly);
        var dialog = await DialogService.ShowAsync<OpInventoryReleaseDialog>(RModel.OpInventoryReleaseID == null ? "ADD" : "EDIT", parms, mediumWidth);
        var result = await dialog.Result;
        var isCancelled = result.Canceled;
        if (!isCancelled)
        {
            var ReturnData = (OpInventoryReleaseModel)result.Data;
            notificationMessage.InitiateBranch = new BranchModel() { BranchID = ReturnData.BranchID };
            notificationMessage.ReceivedBranch = new BranchModel() { BranchID = ReturnData.BranchID };
            notificationMessage.MessageTitle = IpushNotificationService.GetMessageTitle(ReturnData.NatureOfTransaction, ReturnData.DocumentNumber, "Level 1 Verification");
            notificationMessage.MessageBody = IpushNotificationService.GetMessageBody(ReturnData.NatureOfTransaction, ReturnData.DocumentNumber, "Level 1 Verification", ReturnData.DocumentDate);
            notificationMessage.RedirectedTo = 0;
            notificationMessage.ExpiredBy = 7;
            notificationMessage.DocumentID = ReturnData.OpInventoryReleaseID;
            notificationMessage.MessageGroupID = "PendingVerification";
            notificationMessage.PageToRedirectLink = "/OpInventoryReleaseView";
            notificationMessage.ClaimValue = "Verify 1";
            notificationMessage.DocumentTypeID = OpInventoryReleaseDocTypeID;
            notificationMessage.MsgDate = DateTime.Now;
            await signalRService.Send(notificationMessage);
        }
        GetAll(IsApproved, NumberOfRecords);
        await Task.Delay(200);
        _busy = false;
    }

    private async Task Delete(OpInventoryReleaseModel model)
    {
        if (HasPermissionOpInventoryReleaseServiceDelete)
        {
            bool? result = await DialogService.ShowMessageBoxAsync(
                "Warning !",
                "Are you sure, you want to delete - " + model.DocumentNumber + " (" + model.DocumentDate + ") ?");
            if (result == true)
            {
                var authprov = await auth.GetAuthenticationStateAsync();
                var user = authprov.User;
                Iservice.Delete(model.OpInventoryReleaseID, user.Identity.Name);
                snackbar.Add("Deleted Successfully", Severity.Success);
            }
            GetAll(IsApproved, NumberOfRecords);
        }
        else
        {
            bool? result = await DialogService.ShowMessageBoxAsync(
                "Permission denied!",
                "You don't have any permission to Delete OpInventoryRelease.");
        }
    }
}
