@page "/InventoryGrn"


@inject IInventoryGrnService Iservice
@inject MudBlazor.ISnackbar snackbar

@inject AuthenticationStateProvider auth
@attribute [Authorize]
@inject IDialogService DialogService

<MudGrid Spacing="4">
   <MudItem xs="12">
        <MudTable Items="@collection"  Dense="true" Hover="true"  Striped="true" Elevation="10" Filter="new Func<InventoryGrnModel, bool>(search)" @bind-place="model">
           

             <ToolBarContent>
                <MudText Typo="Typo.h6">GRN</MudText>
                <MudIconButton Icon="@Icons.Material.Filled.Add" Title="Add" @onclick="@(()=> OpenDialog(model))"  Color="Color.Dark" Size="Size.Small"></MudIconButton>
                 <MudButton @onclick="h"  Variant="Variant.Filled" Color="Color.Primary" >Purchase Order</MudButton>
                
                <MudSpacer></MudSpacer>
                <MudTextField @bind-Value="searchGrn" Placeholder="Search Grn... "
                              Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                              IconSize="Size.Medium" Class="mt-0"></MudTextField>
            </ToolBarContent>
            <HeaderContent>
                <MudTh><MudTableSortLabel SortBy="new Func<InventoryGrnModel, object>(x=> x.GrnNo)" InitialDirection="SortDirection.Ascending">GrnNo</MudTableSortLabel></MudTh>
             <MudTh><MudTableSortLabel SortBy="new Func<InventoryGrnModel, object>(x=> x.EntryDate)" InitialDirection="SortDirection.Ascending">EntryDate</MudTableSortLabel></MudTh>
               <MudTh><MudTableSortLabel SortBy="new Func<InventoryGrnModel, object>(x=> x.PartyBranchID)" InitialDirection="SortDirection.Ascending">PartyBranchID</MudTableSortLabel></MudTh>
                
                <MudTh>Actions</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="GrnNO">@context.GrnNo</MudTd>
                <MudTd DataLabel="EntryDate">@context.EntryDate</MudTd>
                <MudTd DataLabel="PartyBranchID">@context.PartyBranchID</MudTd>
                 
                <MudTd DataLabel="">
                    <MudFab @onclick="@(()=> OpenDialog(context))" Color="Color.Primary" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" IconSize="Size.Small" />
                    <MudFab @onclick="@(()=> Delete(context))" Color="Color.Error" Icon="@Icons.Material.Filled.Delete" Size="Size.Small" IconSize="Size.Small" />
                  
                    @if(@context.Approved==false)
                    {
                      <MudFab @onclick="@(()=> Approve(context))" Color="Color.Success" Icon="@Icons.Material.Filled.Approval" Size="Size.Small" IconSize="Size.Small" />
                        
                    }
              
                    </MudTd>
            </RowTemplate>
            <PagerContent>
                <MudTablePager PageSizeOptions="new int[] { 5, 10, 20, 50, 100 }" />
            </PagerContent>
        </MudTable>
    </MudItem>
    </MudGrid>



@code {


    private InventoryGrnModel model = new InventoryGrnModel();
    private List<InventoryGrnModel> collection = new List<InventoryGrnModel>();
    DialogOptions maxWidth = new DialogOptions() { MaxWidth = MaxWidth.Medium, FullWidth = true };


    private string searchGrn = "";

    protected override async Task OnInitializedAsync()
    {
        model = new();
        GetAll();
    }

    private  async Task GetAll()
    {
        var authprov = await auth.GetAuthenticationStateAsync();
        var brancIDString = authprov.User.Claims.First(x => x.Type == "BranchID").Value;
        int brancID = int.Parse(brancIDString);
        collection = new List<InventoryGrnModel>();
        foreach (var item in Iservice.SelectPending(brancID))
        {
            collection.Add(item);
        }


    }   

    private async Task OpenDialog(InventoryGrnModel tds)
    {
        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;

        DialogParameters parms = new DialogParameters();
        parms.Add("model",tds);
        var dialog =  DialogService.Show<InventoryGrnDialog>(tds.GrnID == null?"ADD":"EDIT",parms,maxWidth);
        var result = await dialog.Result;

        if(!result.Cancelled)
        {   
           
                GetAll();
            

        }
    }

    private void Delete(InventoryGrnModel tds)
    {
        Iservice.Delete(tds.GrnID, "Rijas");
        snackbar.Add("Deleted Successfully", Severity.Success);
        GetAll();
    }
    private async Task Approve(InventoryGrnModel tds)
    {

        var parameters = new DialogParameters();
        parameters.Add("ContentText", "Are you sure you want to Approve this Goods Reciept Note,GRN No:"+tds.GrnNo+"?");
        parameters.Add("ButtonText", "Confirm");
        parameters.Add("Color", Color.Success);
        var dialog=DialogService.Show<ConfirmDialog>("Confirm", parameters);
        var result = await dialog.Result;


        if (!result.Cancelled)
        {
            var authprov = await auth.GetAuthenticationStateAsync();
            var user = authprov.User;
            tds.UserInfo.UserID = user.Identity.Name;
            try
            {

                Iservice.Approve(tds.GrnID.Value,tds.UserInfo.UserID);

                snackbar.Add("Approved", Severity.Success);

                GetAll();
            }
            catch (Exception ex)
            {
                snackbar.Add(ex.Message, Severity.Warning);
            }
        }





    }
    public async Task  h()
    {
        PurchaseOrderModel tds = new();
        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;

        DialogParameters parms = new DialogParameters();
       
        var dialog =  DialogService.Show<PurchaseOrderViewDialog>("Purchase Order",parms,maxWidth);
        var result = await dialog.Result;
           if(!result.Cancelled)
        {   
           
                GetAll();
            

        }
    }

    private bool search(InventoryGrnModel tds)
    {
     if (tds.GrnNo != null && tds.GrnNo.Contains(searchGrn, StringComparison.OrdinalIgnoreCase))
        {
            return true;
        }
        else if (tds.GrnNo == null)
        return true;
        return false;
    }



}
