    }

    private bool search(InventoryGrnModel tds)
    {
     if (tds.GrnNo != null && tds.GrnNo.Contains(searchGrn, StringComparison.OrdinalIgnoreCase))
        {
            return true;
        }
        else if (tds.GrnNo == null)
        return true;
        return false;
    }

      private string TableRowStyle(InventoryGrnModel IG, int index)
    {
        if(IG.AuthLevelID == 99)
        {
            return "background-color:#CCCCFF";
        }
        return string.Empty;
    }

