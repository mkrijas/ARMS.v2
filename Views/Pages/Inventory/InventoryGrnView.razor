    public async Task  openpurchaseorder()
    {
        PurchaseOrderModel tds = new();
        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;

        DialogParameters parms = new DialogParameters();
       
        var dialog =  DialogService.Show<PurchaseOrderViewDialog>("Purchase Order",parms,maxWidth);
        var result = await dialog.Result;
           if(!result.Cancelled)
        {   
           
                GetAll(IsApproved);
            

        }
