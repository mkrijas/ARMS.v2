@page "/InventoryGrn"


@inject IInventoryGrnService Iservice
@inject MudBlazor.ISnackbar snackbar

@inject AuthenticationStateProvider auth
@attribute [Authorize]
@inject IDialogService DialogService

<MudGrid Spacing="4">
   <MudItem xs="12">
        <MudTable Items="@collection" RowStyleFunc="TableRowStyle"  Dense="true" Hover="true"  Striped="true" Elevation="10" Filter="new Func<InventoryGrnModel, bool>(search)" @bind-place="model">
           

             <ToolBarContent>
                <MudText Typo="Typo.h6">GRN</MudText>
                <MudTooltip Text="New Grn">
                <MudIconButton  Icon="@Icons.Material.Filled.Add" Title="Add" @onclick="@(()=> OpenDialog(model))"  Color="Color.Dark" Size="Size.Small"></MudIconButton>
                </MudTooltip>
                 <MudTooltip Text="Pending Purchase Order">
                <MudIconButton  Icon="@Icons.Material.Filled.AddLink"  @onclick="openpurchaseorder"  Color="Color.Dark" Size="Size.Small"></MudIconButton>
                </MudTooltip>
                 <MudTooltip Text="Approved Data">
                <MudIconButton Icon="@Icons.Material.Filled.TableView" Title="Approved Data" @onclick="@(()=> OpenDialogApproved(model))"  Color="Color.Dark" Size="Size.Small"></MudIconButton>
               </MudTooltip>
               <MudCheckBox Label="Approved Entries"  CheckedChanged="((bool value)=>ApprovedChanged(value))" Checked="@IsApproved" Size="Size.Medium" Color="Color.Primary"></MudCheckBox>

               @* <MudButton @onclick="openpurchaseorder"  Variant="Variant.Filled" Color="Color.Primary" >Purchase Order</MudButton>
               *@ 
                <MudSpacer></MudSpacer>
                <MudTextField @bind-Value="searchGrn" Placeholder="Search Grn... "
                              Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                              IconSize="Size.Medium" Class="mt-0"></MudTextField>
            </ToolBarContent>
            <HeaderContent>
                <MudTh><MudTableSortLabel SortBy="new Func<InventoryGrnModel, object>(x=> x.GrnNo)" InitialDirection="SortDirection.Ascending">GrnNo</MudTableSortLabel></MudTh>
             <MudTh><MudTableSortLabel SortBy="new Func<InventoryGrnModel, object>(x=> x.EntryDate)" InitialDirection="SortDirection.Ascending">EntryDate</MudTableSortLabel></MudTh>
               <MudTh><MudTableSortLabel SortBy="new Func<InventoryGrnModel, object>(x=> x.PartyName)" InitialDirection="SortDirection.Ascending">Party</MudTableSortLabel></MudTh>
                
                <MudTh>Actions</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="GrnNO">@context.GrnNo</MudTd>
                <MudTd DataLabel="EntryDate">@context.EntryDate?.ToShortDateString()</MudTd>
                <MudTd DataLabel="Party">@context.PartyName</MudTd>
                 
                <MudTd DataLabel="">
                   
                    @if(@context.AuthLevelID==null)
                    {
                     @* <MudFab @onclick="@(()=> Approve(context))" Color="Color.Success" title="Approve" Icon="@Icons.Material.Filled.Check" Size="Size.Small" IconSize="Size.Small" />
                     *@
                     <MudFab @onclick="@(()=> OpenDialog(context))" Color="Color.Primary" title="Edit" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" IconSize="Size.Small" />
                     <MudFab @onclick="@(()=> Delete(context))" Color="Color.Error" title="Delete" Icon="@Icons.Material.Filled.Delete" Size="Size.Small" IconSize="Size.Small" />
                  
                    }
                     @if (@context.AuthLevelID!= 99)
                    {
                    <MudFab @onclick="@(()=> OpenDialogVerify(context))" Color="Color.Warning" Icon="@Icons.Material.Filled.Verified" title="Verify" Size="Size.Small" IconSize="Size.Small" />
                        
                    }
                    <MudFab @onclick="@(()=> OpenDialogView(context))" Color="Color.Info" Icon="@Icons.Material.Filled.GridView" title="View" Size="Size.Small" IconSize="Size.Small" />
                   

              
                    </MudTd>
            </RowTemplate>
            <PagerContent>
                <MudTablePager PageSizeOptions="new int[] { 5, 10, 20, 50, 100 }" />
            </PagerContent>
        </MudTable>
    </MudItem>
    </MudGrid>



@code {


    private InventoryGrnModel model = new InventoryGrnModel();
    private List<InventoryGrnModel> collection = new List<InventoryGrnModel>();
    DialogOptions maxWidth = new DialogOptions() { MaxWidth = MaxWidth.Medium, FullWidth = true };


    private string searchGrn = "";
    public bool IsApproved { get; set; } = false;
    protected override async Task OnInitializedAsync()
    {
        model = new();
        GetAll(IsApproved);
    }
    async Task ApprovedChanged(bool value)
    {

        IsApproved = value;
        await GetAll(IsApproved);

    }
    private  async Task GetAll(bool val)
    {
        var authprov = await auth.GetAuthenticationStateAsync();
        var brancIDString = authprov.User.Claims.First(x => x.Type == "BranchID").Value;
        int brancID = int.Parse(brancIDString);
        
         if (val)
        {
            collection = Iservice.SelectPending(brancID).Where(x => x.AuthLevelID == 99).ToList();
            
        }
        else
        {
             collection = Iservice.SelectPending(brancID).Where(x => x.AuthLevelID != 99).ToList();
       
        }


    }   

    private async Task OpenDialog(InventoryGrnModel tds)
    {
        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;

        DialogParameters parms = new DialogParameters();
        parms.Add("model",tds);
         parms.Add("IsReadOnly",false);
        parms.Add("IsView",false);
        var dialog =  DialogService.Show<InventoryGrnDialog>(tds.GrnID == null?"ADD":"EDIT",parms,maxWidth);
        var result = await dialog.Result;

        
         GetAll(IsApproved);
    }
     private async Task OpenDialogVerify(InventoryGrnModel tds)
    {
        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;

        DialogParameters parms = new DialogParameters();
        parms.Add("model",tds);
         parms.Add("IsReadOnly",true);
        parms.Add("IsView",false);
        var dialog =  DialogService.Show<InventoryGrnDialog>(tds.GrnID == null?"ADD":"EDIT",parms,maxWidth);
        var result = await dialog.Result;

        
         GetAll(IsApproved);
    }
     private async Task OpenDialogView(InventoryGrnModel tds)
    {
        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;

        DialogParameters parms = new DialogParameters();
        parms.Add("model",tds);
         parms.Add("IsReadOnly",true);
        parms.Add("IsView",true);
        var dialog =  DialogService.Show<InventoryGrnDialog>(tds.GrnID == null?"ADD":"EDIT",parms,maxWidth);
        var result = await dialog.Result;

       
    }
    public void OpenDialogApproved(InventoryGrnModel p)
    {
        
        DialogParameters parms = new DialogParameters();
        parms.Add("model",p);
        var dialog =  DialogService.Show<InventoryGrnApproveView>(p.GrnID == null?"Approved Data":"Approved Data",parms,maxWidth);
      
    }

    private void Delete(InventoryGrnModel tds)
    {
        Iservice.Delete(tds.GrnID, "Rijas");
        snackbar.Add("Deleted Successfully", Severity.Success);
        GetAll(IsApproved);
    }
