@using Views.Pages.Finance.Transactions
@inject IInventoryGrnService Iservice
@inject IGstItemService gstitemIservice
@inject IPartyService partyIservice
@inject ITdsRateService tdsIService
@inject IBranchService branchIservice
@inject MudBlazor.ISnackbar snackbar
@inject IInventoryGroupService inventoryGroupIservice
@inject AuthenticationStateProvider auth
@attribute [Authorize]
@inject IDialogService DialogService


<MudDialog>
     <DialogContent>
         <MudGrid Spacing="4">
   <MudItem xs="12">
        <MudTable Items="@collection"  Dense="true" Hover="true"  Striped="true" Elevation="10"  @bind-place="model">
           

            
            <HeaderContent>
                <MudTh><MudTableSortLabel SortBy="new Func<InventoryGrnModel, object>(x=> x.GrnNo)" InitialDirection="SortDirection.Ascending">GrnNo</MudTableSortLabel></MudTh>
             <MudTh><MudTableSortLabel SortBy="new Func<InventoryGrnModel, object>(x=> x.EntryDate)" InitialDirection="SortDirection.Ascending">EntryDate</MudTableSortLabel></MudTh>
               <MudTh><MudTableSortLabel SortBy="new Func<InventoryGrnModel, object>(x=> x.PartyName)" InitialDirection="SortDirection.Ascending">Party</MudTableSortLabel></MudTh>
                
                
                <MudTh>Actions</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="GrnNo">@context.GrnNo</MudTd>
                <MudTd DataLabel="EntryDate">@context.EntryDate</MudTd>
                <MudTd DataLabel="Party">@context.PartyName</MudTd>
                
                 
                <MudTd DataLabel="">
                    <MudTooltip Text="Reverse">
                    <MudFab @onclick="@(()=> Reverse(context))" Color="Color.Error" Icon="@Icons.Material.Filled.ArrowBack" Size="Size.Small" IconSize="Size.Small" />
                    </MudTooltip>  
                    <MudTooltip Text="View">
                    <MudFab @onclick="@(()=> OpenDialog(context))" Color="Color.Primary" Icon="@Icons.Material.Filled.Preview" Size="Size.Small" IconSize="Size.Small" />
                   </MudTooltip>
                   <MudTooltip Text="Convert to TaxPurchase">
                    <MudFab @onclick="@(()=> Add(context))" Color="Color.Success" Icon="@Icons.Material.Filled.ArrowForward" Size="Size.Small" IconSize="Size.Small" />
                 </MudTooltip>
                    
              
                    </MudTd>
            </RowTemplate>
            <PagerContent>
                <MudTablePager PageSizeOptions="new int[] { 5, 10, 20, 50, 100 }" />
            </PagerContent>
        </MudTable>
    </MudItem>
    </MudGrid>
         </DialogContent>
    </MudDialog>


@code {

    private InventoryGrnModel model = new InventoryGrnModel();
    private List<InventoryGrnModel> collection = new List<InventoryGrnModel>();
    DialogOptions maxWidth = new DialogOptions() { MaxWidth = MaxWidth.Medium, FullWidth = true };
    [CascadingParameter] MudDialogInstance MudDialog { get; set; }
    private List<TaxPurchaseItemModel> TxItitems = new List<TaxPurchaseItemModel>();



    protected override async Task OnInitializedAsync()
    {
        model = new();
        await GetAll();
    }

    private  async Task GetAll()
    {
        var authprov = await auth.GetAuthenticationStateAsync();
        var brancIDString = authprov.User.Claims.First(x => x.Type == "BranchID").Value;
        int brancID = int.Parse(brancIDString);
        collection = new List<InventoryGrnModel>();
        foreach (var item in Iservice.PendingToInvoice(brancID))
        {
            collection.Add(item);
        }


    }   
    private async Task OpenDialog(InventoryGrnModel tds)
    {   
        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;

        DialogParameters parms = new DialogParameters();
        parms.Add("model",tds);
          parms.Add("IsReadOnly",true);
        parms.Add("IsView",true);
        var dialog=DialogService.Show<InventoryGrnDialog>("GRN",parms,maxWidth);
        var result = await dialog.Result;

        if(!result.Cancelled)
        {   
            await  GetAll();        
        }
        await GetAll();
    }
    private async Task Reverse(InventoryGrnModel tds)
    {
        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;
        model.UserInfo.UserID = user.Identity.Name;
        Iservice.Reverse(tds.GrnID.Value,model.UserInfo.UserID);
        MudDialog.Close(model);


    }

    private async Task Add(InventoryGrnModel tds)
    {
        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;
        model.UserInfo.UserID = user.Identity.Name;

        TaxPurchaseModel tpm = new TaxPurchaseModel();
        tpm.GRNID = tds.GrnID;
        tpm.TotalAmount = tds.TotalValue;
        tpm.PartyInfo = partyIservice.SelectByID(tds.PartyID.Value);

       
        DialogParameters parms = new DialogParameters();
        parms.Add("model",tpm);
      
       //var dialog=DialogService.Show<TaxPurchaseDialog>(tpm.GRNID == null?"ADD":"EDIT",parms,maxWidth);
       // var result = await dialog.Result;

       // if(!result.Cancelled)
       // {   
       //     await  GetAll();        
       // }
        await GetAll();
    }

    


        
            
        
    
}

