
@inject IInventoryItemService Iservice
@inject MudBlazor.ISnackbar snackbar
@inject IInventoryGroupService groupIservice
@inject AuthenticationStateProvider auth
@attribute [Authorize]
@inject IDialogService DialogService

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.Build" Class="mr-3 mb-n1" />
            Create Inventory Item
        </MudText>
    </TitleContent>
    <DialogContent>

         <MudContainer Style="min-height:300px;max-height: 800px;">
            <EditForm id="formtdsRate" Model="@model" OnValidSubmit="OnValidSubmit">
                <ObjectGraphDataAnnotationsValidator />
                <ValidationSummary />
                <MudGrid Spacing="2">
                     <MudItem xs="12" md="12">
                         
                        <MudTextField  @bind-Value="model.InventoryItemCode" Label="Item Code" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.InventoryItemCode)"></MudTextField>
                         
                    </MudItem>
                    <MudItem xs="12" md="12">
                      <MudSelect Label="Select Inventory Group" @bind-Value="model.InventoryGroupID" T="int?"  Variant="Variant.Outlined" Margin="Margin.Dense" OffsetY="true" Direction="Direction.Top" AdornmentColor="Color.Secondary">
                            @foreach (var ditem in ivgroup)
                            {
                                <MudSelectItem Value="@ditem.InventoryGroupID">@ditem.InventoryGroupName</MudSelectItem>
                            }
                        </MudSelect>
                        </MudItem>
                    <MudItem xs="12" md="12">
                         
                        <MudTextField  @bind-Value="model.ItemDecription" Label="Item Decription" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.ItemDecription)"></MudTextField>
                         
                    </MudItem>
                    <MudItem xs="12" md="12">
                         
                        <MudTextField  @bind-Value="model.HsnCode" Label="Item HsnCode" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.HsnCode)"></MudTextField>
                         
                    </MudItem>
                   
                   
                </MudGrid>
            </EditForm>
        </MudContainer>


   </DialogContent>
    <DialogActions>
     <MudButton OnClick="Cancel">Cancel</MudButton>
      <MudButton form="formtdsRate" Variant="Variant.Filled" Color="Color.Success" ButtonType="ButtonType.Submit">Submit</MudButton>
       

    </DialogActions>
</MudDialog>


@code {
    [Parameter]
    public InventoryItemModel model { get; set; }
    private List<InventoryGroupModel> ivgroup = new();
    [CascadingParameter] MudDialogInstance MudDialog { get; set; }
    protected override void OnInitialized()
    {
       
        ivgroup = groupIservice.SearchByName(string.Empty).ToList();
       
    }
     private void OnValidSubmit(EditContext context)
    {  
        if(model.InventoryGroupID==null)
        {
            snackbar.Add("Select InventoryGroup", Severity.Success);
            return;
        }
         MudDialog.Close(model);
    }
    private void Cancel()
    {
        MudDialog.Cancel();
    }
}
