@page "/InventoryItem"
@inject IInventoryItemService Iservice
@inject MudBlazor.ISnackbar snackbar
@inject IInventoryGroupService groupIservice
@inject AuthenticationStateProvider auth
@attribute [Authorize]
@inject IDialogService DialogService





<MudGrid Spacing="4">
   <MudItem xs="6">
        <MudTable Items="@collection"  Dense="true" Hover="true"  Striped="true" Elevation="10" Filter="new Func<InventoryItemModel, bool>(search)" @bind-place="model">
           

             <ToolBarContent>
                <MudText Typo="Typo.h6">Inventory Item</MudText>
                <MudIconButton Icon="@Icons.Material.Filled.Add" Title="Add" @onclick="@(()=> OpenDialog(model))"  Color="Color.Dark" Size="Size.Small"></MudIconButton>
                
                <MudSpacer></MudSpacer>
                <MudTextField @bind-Value="searchInventory" Placeholder="Search Inventory Group... "
                              Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                              IconSize="Size.Medium" Class="mt-0"></MudTextField>
            </ToolBarContent>
            <HeaderContent>
                <MudTh><MudTableSortLabel SortBy="new Func<InventoryItemModel, object>(x=> x.InventoryItemID)" InitialDirection="SortDirection.Ascending">ID</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<InventoryItemModel, object>(x=> x.InventoryItemCode)" InitialDirection="SortDirection.Ascending">ItemCode</MudTableSortLabel></MudTh>
                
                
                <MudTh>Actions</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="UsageID">@context.InventoryItemID</MudTd>
               
                <MudTd DataLabel="PeriodFrom">@context.InventoryItemCode</MudTd>
                
                  
                <MudTd DataLabel="">
                    <MudFab @onclick="@(()=> OpenDialog(context))" Color="Color.Primary" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" IconSize="Size.Small" />
                    <MudFab @onclick="@(()=> Delete(context))" Color="Color.Primary" Icon="@Icons.Material.Filled.Delete" Size="Size.Small" IconSize="Size.Small" />
                </MudTd>
            </RowTemplate>
            <PagerContent>
                <MudTablePager PageSizeOptions="new int[] { 5, 10, 20, 50, 100 }" />
            </PagerContent>
        </MudTable>
    </MudItem>

     <MudItem xs="6">
         <MudPaper Elevation="2" Class="pa-2">
     <MudGrid Spacing="2">
     <MudItem xs="12" md="12">
        
         <h4>Add Inventory Item</h4>
        
     </MudItem>
         </MudGrid>
         <MudContainer Style="min-height:300px;max-height: 800px;">
            <EditForm id="formtdsRate" Model="@model" OnValidSubmit="OnValidSubmit">
                <ObjectGraphDataAnnotationsValidator />
                <ValidationSummary />
                <MudGrid Spacing="2">
                     <MudItem xs="12" md="12">
                         
                        <MudTextField  @bind-Value="model.InventoryItemCode" Label="Item Code" Variant="Variant.Outlined" Margin="Margin.Normal" For="@(() => model.InventoryItemCode)"></MudTextField>
                         
                    </MudItem>
                    <MudItem xs="12" md="12">
                      <MudSelect Label="Select Inventory Group" @bind-Value="model.InventoryGroupID" T="int?"  Variant="Variant.Outlined" Margin="Margin.Normal" OffsetY="true" Direction="Direction.Top" AdornmentColor="Color.Secondary">
                            @foreach (var ditem in ivgroup)
                            {
                                <MudSelectItem Value="@ditem.InventoryGroupID">@ditem.InventoryGroupName</MudSelectItem>
                            }
                        </MudSelect>
                        </MudItem>
                    <MudItem xs="12" md="12">
                         
                        <MudTextField  @bind-Value="model.ItemDecription" Label="Item Decription" Variant="Variant.Outlined" Margin="Margin.Normal" For="@(() => model.ItemDecription)"></MudTextField>
                         
                    </MudItem>
                    <MudItem xs="12" md="12">
                         
                        <MudTextField  @bind-Value="model.HsnCode" Label="Item HsnCode" Variant="Variant.Outlined" Margin="Margin.Normal" For="@(() => model.HsnCode)"></MudTextField>
                         
                    </MudItem>
                   
                   
                </MudGrid>
            </EditForm>
        </MudContainer>
       
         <MudGrid Spacing="2">
        <MudButton OnClick="Cancel" Variant="Variant.Filled" Color="Color.Primary">Cancel</MudButton>
        <MudButton form="formtdsRate" Variant="Variant.Filled" Color="Color.Success" ButtonType="ButtonType.Submit">Submit</MudButton>
        </MudGrid>
       
        </MudPaper>
          </MudItem>



    </MudGrid>



@code {


    private InventoryItemModel model = new InventoryItemModel();
    private List<InventoryItemModel> collection = new List<InventoryItemModel>();
    private List<InventoryGroupModel> ivgroup = new();

    private string searchInventory = "";

    protected override async Task OnInitializedAsync()
    {
        model = new();
        ivgroup = groupIservice.SearchByName(string.Empty).ToList();
        GetAll();
    }

    private  void GetAll()
    {
        collection = new List<InventoryItemModel>();
        foreach (var item in Iservice.SearchByItemCode(string.Empty))
        {
            collection.Add(item);
        }


    }
    private async Task OnValidSubmit()
    {
        if(model.InventoryGroupID==null)
        {
            snackbar.Add("Select InventoryGroup", Severity.Success);
            return;
        }
        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;
        model.UserInfo.UserID = user.Identity.Name;
        Iservice.Update(model);
        model = new();
        GetAll();
    }
    private async Task OpenDialog(InventoryItemModel tds)
    {
         model = new();
        model=Iservice.SelectByID(tds.InventoryItemID);

    }

    private void Delete(InventoryItemModel tds)
    {
        Iservice.Delete(tds.InventoryItemID, "Rijas");
        snackbar.Add("Deleted Successfully", Severity.Success);
        GetAll();
    }

    private bool search(InventoryItemModel tds)
    {
        if (tds.InventoryItemCode != null && tds.InventoryItemCode.Contains(searchInventory, StringComparison.OrdinalIgnoreCase))
        {
            return true;
        }
        else if (tds.InventoryItemCode == null)
            return true;
        return false;
    }
    private void Cancel()
    {
        model = new();
    }


}
