@inject IInventoryGroupService groupIservice
@inject IChartOfAccountService accountService
@inject MudBlazor.ISnackbar snackbar

<MudDialog Class="admin-dialog-glass">
    <TitleContent>
        <div class="header-section mb-2 pt-4 px-4">
            <div class="d-flex align-center justify-space-between">
                <div class="d-flex align-center">
                    <div class="icon-badge primary-badge mr-4">
                        <div class="admin-header-icon-badge mb-3">
                            <MudIcon Icon="@Icons.Material.Filled.AccountTree" Color="Color.Secondary" Style="font-size: 3rem;" />
                        </div>
                    </div>
                    <div>
                        <MudText Typo="Typo.h5" Class="admin-title"><b>Inventory Taxonomy (Sub-Group)</b></MudText>
                        <MudText Typo="Typo.body2" Class="admin-subtitle">
                            Define secondary inventory classifications and establish hierarchical relationships for granular asset management.
                        </MudText>
                    </div>
                </div>
            </div>
            <div class="title-accent mt-4"></div>
        </div>
    </TitleContent>
    <DialogContent>
        <MudContainer Class="admin-dialog-container">
            <div class="dialog-content-wrapper pa-4">
                <EditForm id="formgroup2" Model="@model" OnValidSubmit="OnValidSubmit">
                    <ObjectGraphDataAnnotationsValidator />
                    
                    <div class="admin-glass-card pa-6 mb-6">
                        <div class="d-flex align-center mb-6">
                            <MudIcon Icon="@Icons.Material.Filled.AccountTree" Color="Color.Primary" Class="mr-2" />
                            <span class="admin-section-label mb-0">Hierarchical Classification Mapping</span>
                        </div>

                        <MudGrid Spacing="3">
                            <MudItem xs="12">
                                <MudSelect For="@(() => model.Group1ID)" Label="Parent Inventory Classification" @bind-Value="model.Group1ID" T="int?" Variant="Variant.Outlined" Margin="Margin.Normal" AdornmentColor="Color.Secondary" AnchorOrigin="Origin.BottomCenter" Class="modern-input" AdornmentIcon="@Icons.Material.Filled.CorporateFare">
                                    @foreach (var ditem in ivgroup)
                                    {
                                        <MudSelectItem Value="@ditem.InventoryGroupID">@ditem.InventoryGroupName</MudSelectItem>
                                    }
                                </MudSelect>
                            </MudItem>
                            <MudItem xs="12">
                                <MudTextField @bind-Value="model.GroupDescription" Label="Sub-Group Identity (Description)" Variant="Variant.Outlined" Margin="Margin.Normal" For="@(() => model.GroupDescription)" Class="modern-input" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Subtitles" />
                            </MudItem>
                        </MudGrid>
                    </div>

                    <div class="admin-glass-card pa-6 text-center shadow-none gray-bg" style="background: rgba(0,0,0,0.02);">
                        <MudIcon Icon="@Icons.Material.Filled.Verified" Color="Color.Success" Size="Size.Large" Class="mb-2" />
                        <MudText Typo="Typo.body2" Class="fw-500">
                            Sub-group definitions enable precise logistical tracking and multi-tier procurement auditing.
                        </MudText>
                    </div>
                </EditForm>
            </div>
        </MudContainer>
    </DialogContent>
    <DialogActions>
        <div class="d-flex w-100 flex-wrap pa-4 gap-3 align-center">
            <MudSpacer />
            <MudButton @onclick="Cancel" Variant="Variant.Outlined" Color="Color.Default" Style="border-radius: 12px; font-weight: 700; text-transform: none; border-color: rgba(0,0,0,0.15);">Discard</MudButton>
            <MudButton Disabled="@_busy" form="formgroup2" Variant="Variant.Filled" Color="Color.Success" ButtonType="ButtonType.Submit" Style="background: var(--mud-palette-success); color: white; font-weight: 800; border-radius: 12px; text-transform: none; white-space: nowrap; padding: 8px 24px;" StartIcon="@Icons.Material.Filled.DoneAll">Submit Sub-Group</MudButton>
        </div>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; }
    [Parameter]
    public InventoryGroup2Model model { get; set; }
    private List<InventoryGroupModel> ivgroup = new();
    private bool _busy;

    protected override async Task OnInitializedAsync()
    {
        ivgroup = groupIservice.SearchByName(string.Empty).ToList();
    }

    private async Task<IEnumerable<ChartOfAccountModel>> SearchAccounts(string searchString, CancellationToken token)
    {
        return await Task.FromResult(accountService.FilterSubLedgers(searchString));
    }

    private async Task OnValidSubmit(EditContext context)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is being submitted!", Severity.Warning);
            return;
        }
        _busy = true;
        model.GroupDescription = FontStyle.ConvertToCamelCase(model.GroupDescription);
        MudDialog.Close(DialogResult.Ok(model));

        await Task.Delay(200);
        _busy = false;
    }

    private void Cancel()
    {
        MudDialog.Cancel();
    }
}
