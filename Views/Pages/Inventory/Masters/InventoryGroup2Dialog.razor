@inject IInventoryGroup2Service Iservice
@inject IInventoryGroupService groupIservice
@inject MudBlazor.ISnackbar snackbar
@inject IChartOfAccountService accountService
@inject AuthenticationStateProvider auth
@attribute [Authorize]
@inject IDialogService DialogService

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.ProductionQuantityLimits" Class="mr-3 mb-n1" />
            Inventory Group 2
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudContainer Style="min-height:300px;max-height: 800px;">
            <EditForm id="formgroup2" Model="@model" OnValidSubmit="OnValidSubmit">
                <ObjectGraphDataAnnotationsValidator />
                <ValidationSummary />
                <MudGrid Spacing="2">
                    <MudItem xs="12" md="12">
                        <MudSelect Label="Select Inventory Group" @bind-Value="model.Group1ID" T="int?" Variant="Variant.Outlined" Margin="Margin.Dense"   AdornmentColor="Color.Secondary">
                            @foreach (var ditem in ivgroup)
                            {
                                <MudSelectItem Value="@ditem.InventoryGroupID">@ditem.InventoryGroupName</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12" md="12">
                        <MudTextField @bind-Value="model.GroupDescription" Label="Group 2 Name" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.GroupDescription)"></MudTextField>
                    </MudItem>
                </MudGrid>
            </EditForm>
        </MudContainer>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Disabled="@_busy" form="formgroup2" Variant="Variant.Filled" Color="Color.Success" ButtonType="ButtonType.Submit">Submit</MudButton>
    </DialogActions>
</MudDialog>

@code {

    [Parameter]
    public InventoryGroup2Model model { get; set; }
    private List<InventoryGroupModel> ivgroup = new();
    [CascadingParameter] MudDialogInstance MudDialog { get; set; }
    private bool _busy;

    protected override async Task OnInitializedAsync()
    {
        ivgroup = groupIservice.SearchByName(string.Empty).ToList();
    }

    private async Task<IEnumerable<ChartOfAccountModel>> SearchAccounts(string searchString)
    {
        return await Task.FromResult(accountService.FilterSubLedgers(searchString));
    }

    private async void OnValidSubmit(EditContext context)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is being submitted!", Severity.Warning);
            return;
        }
        _busy = true;
        model.GroupDescription = FontStyle.ConvertToCamelCase(model.GroupDescription);
        MudDialog.Close(model);

        await Task.Delay(200);
        _busy = false;
    }

    private void Cancel()
    {
        MudDialog.Cancel();
    }
}