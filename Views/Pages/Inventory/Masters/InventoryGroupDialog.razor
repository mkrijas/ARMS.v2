@inject IChartOfAccountService accountService
@inject MudBlazor.ISnackbar snackbar

<MudDialog Class="admin-dialog-glass">
    <TitleContent>
        <div class="header-section mb-2 pt-4 px-4">
            <div class="d-flex align-center justify-space-between">
                <div class="d-flex align-center">
                    <div class="icon-badge primary-badge mr-4">
                        <div class="admin-header-icon-badge mb-3">
                            <MudIcon Icon="@Icons.Material.Filled.AccountTree" Color="Color.Secondary" Style="font-size: 3rem;" />
                        </div>
                    </div>
                    <div>
                        <MudText Typo="Typo.h5" Class="admin-title"><b>Inventory Taxonomy (Primary)</b></MudText>
                        <MudText Typo="Typo.body2" Class="admin-subtitle">Establish high-level inventory classifications and operational status for global asset tracking.</MudText>
                    </div>
                </div>
            </div>
            <div class="title-accent mt-4"></div>
        </div>
    </TitleContent>
    <DialogContent>
        <MudContainer Class="admin-dialog-container">
            <div class="dialog-content-wrapper pa-4">
                <EditForm id="formtdsRate" Model="@Model.Group" OnValidSubmit="OnValidSubmit">
                    <ObjectGraphDataAnnotationsValidator />
                    
                    <div class="admin-glass-card pa-6 mb-6">
                        <div class="d-flex align-center mb-6">
                            <MudIcon Icon="@Icons.Material.Filled.Tune" Color="Color.Primary" Class="mr-2" />
                            <span class="admin-section-label mb-0">Primary Classification Metadata</span>
                        </div>

                        <MudGrid Spacing="3">
                            <MudItem xs="12">
                                <MudTextField @bind-Value="Model.Group.InventoryGroupName" Label="Classification Identity (Group Name)" Variant="Variant.Outlined" Margin="Margin.Normal" For="@(() => Model.Group.InventoryGroupName)" Class="modern-input" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Label" />
                            </MudItem>
                            <MudItem xs="12">
                                <div class="d-flex align-center pa-4 rounded-lg gray-bg" style="background: rgba(0,0,0,0.02);">
                                    <MudIcon Icon="@Icons.Material.Filled.PowerSettingsNew" Color="@(Model.Group.InventoryGroupStatus == 2 ? Color.Success : Color.Default)" Class="mr-3" />
                                    <div class="flex-grow-1">
                                        <MudText Typo="Typo.subtitle2" Class="fw-700">Operational Status</MudText>
                                        <MudText Typo="Typo.caption" Class="opacity-60">Designate the active lifecycle state for this classification.</MudText>
                                    </div>
                                    <MudRadioGroup T="int?" @bind-Value="Model.Group.InventoryGroupStatus" Class="d-flex gap-4">
                                        <MudRadio T="int?" Value="@(2)" Color="Color.Success">Active</MudRadio>
                                        <MudRadio T="int?" Value="@(3)" Color="Color.Error">Inactive</MudRadio>
                                    </MudRadioGroup>
                                </div>
                            </MudItem>
                        </MudGrid>
                    </div>

                    <div class="admin-glass-card pa-6 mb-6">
                        <div class="d-flex align-center mb-6">
                            <MudIcon Icon="@Icons.Material.Filled.AccountBalance" Color="Color.Primary" Class="mr-2" />
                            <span class="admin-section-label mb-0">Financial Account Mapping</span>
                        </div>

                        <MudGrid Spacing="3">
                            <MudItem xs="12">
                                <MudAutocomplete T="ChartOfAccountModel" Label="Mapped Purchase Head" @bind-Value="MappedPurchaseHead_at" ResetValueOnEmptyText="true" Variant="Variant.Outlined"
                                                 Margin="Margin.Normal" Class="modern-input" AdornmentIcon="@Icons.Material.Filled.AccountBalanceWallet" AdornmentColor="Color.Secondary" AnchorOrigin="Origin.BottomCenter" SearchFunc="SearchAccounts" ToStringFunc="@(e => (e == null) ? null : (string.IsNullOrEmpty(e.AccountName) ? "" : string.Format("{0} | {1}",e.AccountCode,e.AccountName)))"></MudAutocomplete>
                            </MudItem>
                            <MudItem xs="12">
                                <MudAutocomplete T="ChartOfAccountModel" Label="Mapped Consumption Head" @bind-Value="MappedConsumptionHead_at" ResetValueOnEmptyText="true" Variant="Variant.Outlined"
                                                 Margin="Margin.Normal" Class="modern-input" AdornmentIcon="@Icons.Material.Filled.TrendingDown" AdornmentColor="Color.Secondary" AnchorOrigin="Origin.BottomCenter" SearchFunc="SearchAccounts" ToStringFunc="@(e => (e == null) ? null : (string.IsNullOrEmpty(e.AccountName) ? "" : string.Format("{0} | {1}",e.AccountCode,e.AccountName)))"></MudAutocomplete>
                            </MudItem>
                            <MudItem xs="12">
                                <MudAutocomplete T="ChartOfAccountModel" Label="Mapped NonInventory Purchase Head" @bind-Value="MappedNonInventoryPurchaseHead_at" ResetValueOnEmptyText="true" Variant="Variant.Outlined"
                                                 Margin="Margin.Normal" Class="modern-input" AdornmentIcon="@Icons.Material.Filled.Receipt" AdornmentColor="Color.Secondary" AnchorOrigin="Origin.BottomCenter" SearchFunc="SearchAccounts" ToStringFunc="@(e => (e == null) ? null : (string.IsNullOrEmpty(e.AccountName) ? "" : string.Format("{0} | {1}",e.AccountCode,e.AccountName)))"></MudAutocomplete>
                            </MudItem>
                        </MudGrid>
                    </div>

                    <div class="admin-glass-card pa-6 text-center shadow-none gray-bg" style="background: rgba(0,0,0,0.02);">
                        <MudIcon Icon="@Icons.Material.Filled.Info" Color="Color.Info" Size="Size.Large" Class="mb-2" />
                        <MudText Typo="Typo.body2" Class="fw-500 opacity-70">
                            Primary taxonomy definitions and account mappings propagate across all downstream inventory and procurement modules.
                        </MudText>
                    </div>
                </EditForm>
            </div>
        </MudContainer>
    </DialogContent>
    <DialogActions>
        <div class="d-flex w-100 flex-wrap pa-4 gap-3 align-center">
            <MudSpacer />
            <MudButton @onclick="Cancel" Variant="Variant.Outlined" Color="Color.Default" Style="border-radius: 12px; font-weight: 700; text-transform: none; border-color: rgba(0,0,0,0.15);">Discard</MudButton>
            <MudButton Disabled="@_busy" form="formtdsRate" Variant="Variant.Filled" Color="Color.Success" ButtonType="ButtonType.Submit" Style="background: var(--mud-palette-success); color: white; font-weight: 800; border-radius: 12px; text-transform: none; white-space: nowrap; padding: 8px 24px;" StartIcon="@Icons.Material.Filled.DoneAll">Submit Classification</MudButton>
        </div>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; }
    [Parameter]
    public InventoryGroup2Model Model { get; set; }
    private ChartOfAccountModel MappedPurchaseHead_at = null;
    private ChartOfAccountModel MappedConsumptionHead_at = null;
    private ChartOfAccountModel MappedNonInventoryPurchaseHead_at = null;
    private bool _busy;

    protected override async Task OnInitializedAsync()
    {
        if (Model != null)
        {
            MappedPurchaseHead_at = accountService.SelectByID(Model.Group.MappedPurchaseHead);
            MappedConsumptionHead_at = accountService.SelectByID(Model.Group.MappedConsumptionHead);
            MappedNonInventoryPurchaseHead_at = accountService.SelectByID(Model.Group.MappedNonInventoryPurchaseHead);
        }
    }

    private async Task<IEnumerable<ChartOfAccountModel>> SearchAccounts(string searchString, CancellationToken token)
    {
        return await Task.FromResult(accountService.FilterSubLedgers(searchString));
    }

    private async Task OnValidSubmit(EditContext context)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is being submitted!", Severity.Warning);
            return;
        }
        if (MappedConsumptionHead_at == null)
        {
            snackbar.Add("Select MappedConsumptionHead", Severity.Success);
            return;
        }
        if (MappedPurchaseHead_at == null)
        {
            snackbar.Add("Select MappedPurchaseHead", Severity.Success);
            return;
        }
        if (MappedNonInventoryPurchaseHead_at == null)
        {
            snackbar.Add("Select MappedNonInventoryPurchaseHead", Severity.Success);
            return;
        }
        _busy = true;
        Model.Group.InventoryGroupName = FontStyle.ConvertToCamelCase(Model.Group.InventoryGroupName);
        Model.Group.MappedConsumptionHead = MappedConsumptionHead_at.CoaID;
        Model.Group.MappedPurchaseHead = MappedPurchaseHead_at.CoaID;
        Model.Group.MappedNonInventoryPurchaseHead = MappedNonInventoryPurchaseHead_at.CoaID;
        MudDialog.Close(DialogResult.Ok(Model));

        await Task.Delay(200);
        _busy = false;
    }

    private void Cancel()
    {
        MudDialog.Cancel();
    }
}
