@page "/InventoryGroupItem"
@inject IInventoryGroupService GIservice
@inject IInventoryItemService IIservice
@inject MudBlazor.ISnackbar snackbar
@inject IChartOfAccountService accountService
@inject AuthenticationStateProvider auth
@attribute [Authorize]
@inject IDialogService DialogService

<MudGrid>
    <MudItem xs="4" lg="4">
        <MudPaper Width="100%" Class="p-2">
            <MudList Clickable="true" SelectedItem="SelectedItem" SelectedItemChanged="SelectedItemChanged">
                <MudText Typo="Typo.h6">
                    Inventory Group
                    <MudIconButton Disabled="@_busy" Icon="@Icons.Material.Filled.Add" Title="Add" @onclick="@(()=> OpenDialogGroup(model))" Color="Color.Dark" Size="Size.Small"></MudIconButton>
                </MudText>
                @if (listOfItems?.Any() == true)
                {
                    @foreach (var item in listOfItems)
                    {
                        <ContextMenuTrigger MenuId="myMenu" Data="@item">
                            <MudListItem Value="item">
                                <MudText Typo=Typo.subtitle1> @item.InventoryGroupName.ToString() </MudText>
                            </MudListItem>
                        </ContextMenuTrigger>
                    }
                }
            </MudList>
        </MudPaper>
    </MudItem>
    <MudItem xs="8" lg="8">
        @if (SelectedItem != null)
        {
            <MudTable Items="@collection" Dense="true" Hover="true" Striped="true" Elevation="10" Filter="new Func<InventoryItemModel, bool>(search)" @bind-TruckType="model">
                <ToolBarContent>
                    <MudText Typo="Typo.h6">Inventory Item</MudText>
                    <MudSpacer></MudSpacer>
                    <MudTextField @bind-Value="SearchItemCode" Placeholder="Search Item.... " Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0"></MudTextField>
                </ToolBarContent>
                <HeaderContent>
                    <MudTh><MudTableSortLabel SortBy="new Func<InventoryItemModel, object>(x=> x.InventoryItemCode)" InitialDirection="SortDirection.Ascending">Item Code</MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<InventoryItemModel, object>(x=> x.ItemDescription)" InitialDirection="SortDirection.Ascending">Item Description</MudTableSortLabel></MudTh>
                    <MudTh>Actions</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="InventoryItemCode">@context.InventoryItemCode</MudTd>
                    <MudTd DataLabel="ItemDescription">@context.ItemDescription</MudTd>
                    <MudTd DataLabel="">
                        <MudTooltip Text="Edit">
                            <MudFab @onclick="@(()=> OpenDialog(context))" Color="Color.Primary" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" IconSize="Size.Small" />
                        </MudTooltip>
                        <MudTooltip Text="Delete">
                            <MudFab @onclick="@(()=> Delete(context))" Color="Color.Primary" Icon="@Icons.Material.Filled.Delete" Size="Size.Small" IconSize="Size.Small" />
                        </MudTooltip>
                        <MudTooltip Text="ReOrder Level">
                            <MudFab Disabled="@_busy" @onclick="@(()=> ReOrderLevel(context))" Color="Color.Primary" Icon="@Icons.Material.Filled.ProductionQuantityLimits" Size="Size.Small" IconSize="Size.Small" />
                        </MudTooltip>
                    </MudTd>
                </RowTemplate>
                <PagerContent>
                    <MudTablePager PageSizeOptions="new int[] { 5, 10, 20, 50, 100 }" />
                </PagerContent>
            </MudTable>
        }
    </MudItem>
</MudGrid>
<ContextMenu Id="myMenu" OnAppearing="OnAppearing">
    <Item OnClick="@ContextMenuOnClickadd" Id="addItem">Add Items</Item>
    <Item OnClick="@ContextMenuOnClickedit" Id="editGroup">Edit Group</Item>
</ContextMenu>

@code {

    private string SearchItemCode = "";
    InventoryGroupModel model = new InventoryGroupModel();
    private MudListItem SelectedItem;
    private List<InventoryGroupModel> listOfItems = new();
    private List<InventoryItemModel> collection = new List<InventoryItemModel>();
    private string UserID = string.Empty;
    private bool _busy;

    protected override async Task OnInitializedAsync()
    {
        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;
        UserID = user.Identity.Name;
        GetAll();
    }

    protected void SelectedItemChanged(object obj)
    {
        InventoryGroupModel SelectedModel = new();
        SelectedItem = (MudListItem)obj;
        SelectedModel = (InventoryGroupModel)SelectedItem.Value;
        GetInventoryItem(SelectedModel);
    }

    private void GetAll()
    {
        if (listOfItems != null)
        {
            listOfItems.Clear();
        }
        listOfItems = GIservice.SearchByName(string.Empty).ToList();
        StateHasChanged();
    }

    private void GetInventoryItem(InventoryGroupModel ig)
    {
        collection = new List<InventoryItemModel>();
        foreach (var item in IIservice.SelectByGroup(ig.InventoryGroupID))
        {
            collection.Add(item);
        }
        StateHasChanged();
    }

    private async Task OpenDialog(InventoryItemModel ii)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        _busy = true;
        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;

        DialogParameters parms = new DialogParameters();
        parms.Add("model", ii.Clone());
        var dialog = DialogService.Show<InventoryItemDialog>(ii.InventoryItemID == null ? "ADD" : "EDIT", parms);
        var result = await dialog.Result;
        if (!result.Canceled)
        {
            InventoryItemModel UpatedModel = (InventoryItemModel)result.Data;
            ii.UserInfo.UserID = user.Identity.Name;
            try
            {
                IIservice.Update(UpatedModel);
                snackbar.Add("Saved Successfully", Severity.Success);
                InventoryGroupModel igm = new InventoryGroupModel();
                igm.InventoryGroupID = UpatedModel.InventoryGroupID;
                GetInventoryItem(igm);
            }
            catch (Exception ex)
            {
                snackbar.Add(ex.Message, Severity.Warning);
            }
        }
        await Task.Delay(200);
        _busy = false;
    }

    private async Task Delete(InventoryItemModel model)
    {
        bool? result = await DialogService.ShowMessageBox(
            "Warning !",
            "Are you sure, you want to delete - " + model.InventoryItemCode + " (" + model.ItemDescription + ") ?");
        if (result == true)
        {
            IIservice.Delete(model.InventoryItemID, UserID);
            snackbar.Add("Deleted Successfully", Severity.Error);
            SelectedItemChanged(SelectedItem);
        }
    }

    private async Task OpenDialogGroup(InventoryGroupModel ig)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        _busy = true;
        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;

        DialogParameters parms = new DialogParameters();
        parms.Add("model", ig.Clone());
        var dialog = DialogService.Show<InventoryGroupDialog>(ig.InventoryGroupID == null ? "ADD" : "EDIT", parms);
        var result = await dialog.Result;
        if (!result.Canceled)
        {
            InventoryGroupModel UpdatedModel = (InventoryGroupModel)result.Data;
            ig.UserInfo.UserID = user.Identity.Name;
            try
            {
                GIservice.Update(UpdatedModel);
                snackbar.Add("Saved Successfully", Severity.Success);
                GetAll();
            }
            catch (Exception ex)
            {
                snackbar.Add(ex.Message, Severity.Warning);
            }
        }
        await Task.Delay(200);
        _busy = false;
    }

    void OnAppearing(MenuAppearingEventArgs e)
    {

    }

    protected async Task ContextMenuOnClickedit(ItemClickEventArgs e)
    {
        InventoryGroupModel ig = (InventoryGroupModel)((InventoryGroupModel)e.Data).Clone();
        await OpenDialogGroup(ig);
    }

    protected async Task ContextMenuOnClickadd(ItemClickEventArgs e)
    {
        InventoryGroupModel ig = (InventoryGroupModel)((InventoryGroupModel)e.Data).Clone();
        InventoryItemModel ii = new InventoryItemModel();
        ii.InventoryGroupID = ig.InventoryGroupID;
        await OpenDialog(ii);
    }

    private async void ReOrderLevel(InventoryItemModel ii)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        _busy = true;
        DialogParameters parms = new DialogParameters();
        parms.Add("iimodel", ii.Clone());
        var dialog = DialogService.Show<InventoryItemReorderLevelDialog>("Quantity Manage", parms, new DialogOptions() { MaxWidth = MaxWidth.Medium });
        await Task.Delay(200);
        _busy = false;
    }

    private bool search(InventoryItemModel ItemModel)
    {
        if (ItemModel.InventoryItemCode != null && ItemModel.InventoryItemCode.Contains(SearchItemCode, StringComparison.OrdinalIgnoreCase))
        {
            return true;
        }
        return false;
    }
}