@page "/InventoryGroupItem"
@inject IInventoryGroupService GIservice
@inject IInventoryGroup2Service G2Iservice
@inject IInventoryItemGroupService IGIservice
@inject IInventoryItemService IIservice
@inject MudBlazor.ISnackbar snackbar
@inject IChartOfAccountService accountService
@inject AuthenticationStateProvider auth
@attribute [Authorize]
@inject IDialogService DialogService
@using System.Threading;
@inject IRoleService<RoleModel> Irole

<MudGrid>
    <MudItem xs="4" lg="4">
        <MudPaper Width="100%" Class="p-2">
            <MudItem xs="12" md="12" Class="m-3">
                <MudText Typo="Typo.h6">
                    Inventory Group 2
                    <MudIconButton Disabled="@_busy" Icon="@Icons.Material.Filled.Add" Title="Add" @onclick="@(()=> OpenDialogGroup(model))" Color="Color.Dark" Size="Size.Small"></MudIconButton>
                </MudText>
            </MudItem>
            <MudDivider />
            <MudList T="InventoryGroup2Model" Clickable="true" SelectedItem="SelectedItem">
                @if (listOfItems?.Any() == true)
                {
                    @foreach (var item in listOfItems)
                    {
                        <ContextMenuTrigger MenuId="myMenu" Data="@item">
                            <MudListItem T="InventoryGroup2Model" Value="item" OnClick="@((e) => OnGroupClick(item))">
                                <MudText Typo=Typo.subtitle1>@item.Group.InventoryGroupName.ToString() - @item.GroupDescription.ToString() </MudText>
                            </MudListItem>
                        </ContextMenuTrigger>
                    }
                }
            </MudList>
        </MudPaper>
    </MudItem>
    <MudItem xs="8" lg="8">
        @if (ActiveGroup != null)
        {
            <MudTable Items="@collection" Dense="true" Hover="true" Striped="true" Elevation="10" Filter="new Func<InventoryItemGroupModel, bool>(search)" @bind-TruckType="model">
                <ToolBarContent>
                    <MudText Typo="Typo.h6">Inventory Item</MudText>
                    <MudSpacer></MudSpacer>
                    <MudTextField @bind-Value="SearchItemCode" Placeholder="Search Item.... " Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0"></MudTextField>
                </ToolBarContent>
                <HeaderContent>
                    <MudTh><MudTableSortLabel SortBy="new Func<InventoryItemGroupModel, object>(x=> x.ItemGroupDescription)" InitialDirection="SortDirection.Ascending">Item Group Description</MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<InventoryItemGroupModel, object>(x=> x.Makes)" InitialDirection="SortDirection.Ascending">Make</MudTableSortLabel></MudTh>
                    <MudTh>Actions</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="ItemGroupDescription">@context.ItemGroupDescription</MudTd>
                    <MudTd DataLabel="Makes">@context.Makes</MudTd>
                    <MudTd DataLabel="">
                        <MudTooltip Text="Edit">
                            <MudFab @onclick="@(()=> OpenDialog(context))" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Edit" Size="Size.Small" />
                        </MudTooltip>
                        <MudTooltip Text="Delete">
                            <MudFab @onclick="@(()=> Delete(context))" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Delete" Size="Size.Small" />
                        </MudTooltip>
                        @* <MudTooltip Text="ReOrder Level">
                    <MudFab @onclick="@(()=> ReOrderLevel(context))" Color="Color.Primary" StartIcon="@Icons.Material.Filled.ProductionQuantityLimits" Size="Size.Small" />
                    </MudTooltip> *@
                    </MudTd>
                </RowTemplate>
                <PagerContent>
                    <MudTablePager PageSizeOptions="new int[] { 10, 20, 50, 100 }" />
                </PagerContent>
            </MudTable>
        }
    </MudItem>
</MudGrid>
<ContextMenu Id="myMenu" OnAppearing="OnAppearing">
    <Item OnClick="@ContextMenuOnClickAdd" Id="addItem">Add Items</Item>
    <Item OnClick="@ContextMenuOnClickEdit" Id="editGroup">Edit Group</Item>
    <Item OnClick="@ContextMenuOnClickMappingEdit" Id="MappingEditGroup">Edit Account Mapping</Item>
</ContextMenu>

@code {

    private string SearchItemCode = "";
    InventoryGroup2Model model = new InventoryGroup2Model();
    private InventoryGroup2Model ActiveGroup;
    private MudListItem<InventoryGroup2Model> SelectedItem;
    private List<InventoryGroup2Model> listOfItems = new();
    private List<InventoryItemGroupModel> collection = new List<InventoryItemGroupModel>();
    private string UserID = string.Empty;
    private bool _busy;

    public bool HasPermissionInventoryItemServiceEdit { get; set; } = false;
    public bool HasPermissionInventoryItemServiceDelete { get; set; } = false;
    public int InventoryItemDocTypeID = 68;

    public bool HasPermissionInventoryGroupServiceEdit { get; set; } = false;
    public bool HasPermissionStoreServiceDelete { get; set; } = false;
    public int InventoryGroupDocTypeID = 70;

    protected override async Task OnInitializedAsync()
    {
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionInventoryItemServiceEdit = await Irole.HasClaim(InventoryItemDocTypeID.ToString(), "Edit", ctc.Token);
        HasPermissionInventoryItemServiceDelete = await Irole.HasClaim(InventoryItemDocTypeID.ToString(), "Delete", ctc.Token);

        HasPermissionInventoryGroupServiceEdit = await Irole.HasClaim(InventoryGroupDocTypeID.ToString(), "Edit", ctc.Token);

        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;
        UserID = user.Identity.Name;
        GetAll();
    }

    private void GetAll()
    {
        if (listOfItems != null)
        {
            listOfItems.Clear();
        }
        listOfItems = G2Iservice.SearchByName(string.Empty).ToList();
        StateHasChanged();
    }

    protected void OnGroupClick(InventoryGroup2Model item)
    {
        ActiveGroup = item;
        GetInventoryItem(ActiveGroup);
    }

    private void GetInventoryItem(InventoryGroup2Model ig)
    {
        collection = new List<InventoryItemGroupModel>();
        foreach (var itemGroup in IGIservice.SelectByGroup(ig.Group2ID))
        {
            // foreach (var item in IIservice.SelectByGroup(itemGroup.ItemGroupID))
            // {
            collection.Add(itemGroup);
            // }
        }
        StateHasChanged();
    }

    protected async Task ContextMenuOnClickAdd(ItemClickEventArgs e)
    {
        InventoryGroup2Model ig = (InventoryGroup2Model)((InventoryGroup2Model)e.Data).Clone();
        InventoryItemGroupModel ii = new InventoryItemGroupModel();
        ii.Group2ID = ig.Group2ID;
        await OpenDialog(ii);
    }

    protected async Task ContextMenuOnClickEdit(ItemClickEventArgs e)
    {
        InventoryGroup2Model ig = (InventoryGroup2Model)((InventoryGroup2Model)e.Data).Clone();
        await OpenDialogGroup(ig);
    }

    protected async Task ContextMenuOnClickMappingEdit(ItemClickEventArgs e)
    {
        InventoryGroup2Model ig = (InventoryGroup2Model)((InventoryGroup2Model)e.Data).Clone();
        await OpenDialogMappingEditGroup(ig);
    }

    private async Task OpenDialog(InventoryItemGroupModel ii)
    {
        if (HasPermissionInventoryItemServiceEdit)
        {
            if (_busy)
            {
                snackbar.Add("Please wait while form is closing!", Severity.Warning);
                return;
            }
            _busy = true;
            var authprov = await auth.GetAuthenticationStateAsync();
            var user = authprov.User;

            DialogParameters parms = new DialogParameters();
            parms.Add("model", ii.Clone());
            var dialog = DialogService.Show<InventoryItemgroupDialog>(ii.ItemGroupID == null ? "ADD" : "EDIT", parms);
            var result = await dialog.Result;
            if (!result.Canceled)
            {
                InventoryItemGroupModel UpdatedModel = (InventoryItemGroupModel)result.Data;
                if (UpdatedModel.ItemMake.Count == 0)
                {
                    bool? Message = await DialogService.ShowMessageBox(
                        "Oops",
                        "There should be atleast 1 ItemMake selected.");
                    _busy = false;
                    return;
                }
                UpdatedModel.UserInfo.UserID = user.Identity.Name;
                try
                {
                    IGIservice.Update(UpdatedModel);
                    snackbar.Add("Saved Successfully", Severity.Success);
                    InventoryGroup2Model igm = new InventoryGroup2Model();
                    igm.Group2ID = UpdatedModel.Group2ID;
                    GetInventoryItem(igm);
                }
                catch (Exception ex)
                {
                    snackbar.Add(ex.Message, Severity.Warning);
                }
            }
            await Task.Delay(200);
            _busy = false;
        }
        else
        {
            bool? result = await DialogService.ShowMessageBox(
                "Permission denied!",
                "You don't have any permission to Edit InventoryItem.");
        }
    }

    private async Task OpenDialogGroup(InventoryGroup2Model ig)
    {
        if (HasPermissionInventoryGroupServiceEdit)
        {
            if (_busy)
            {
                snackbar.Add("Please wait while form is closing!", Severity.Warning);
                return;
            }
            _busy = true;
            var authprov = await auth.GetAuthenticationStateAsync();
            var user = authprov.User;

            DialogParameters parms = new DialogParameters();
            parms.Add("model", ig.Clone());
            var dialog = DialogService.Show<InventoryGroup2Dialog>(ig.Group2ID == null ? "ADD" : "EDIT", parms);
            var result = await dialog.Result;
            if (!result.Canceled)
            {
                InventoryGroup2Model UpdatedModel = (InventoryGroup2Model)result.Data;
                UpdatedModel.UserInfo.UserID = user.Identity.Name;
                try
                {
                    G2Iservice.Update(UpdatedModel);
                    snackbar.Add("Saved Successfully", Severity.Success);
                    GetAll();
                }
                catch (Exception ex)
                {
                    snackbar.Add(ex.Message, Severity.Warning);
                }
            }
            await Task.Delay(200);
            _busy = false;
        }
        else
        {
            bool? result = await DialogService.ShowMessageBox(
                "Permission denied!",
                "You don't have any permission to Edit InventoryGroup.");
        }
    }

    private async Task OpenDialogMappingEditGroup(InventoryGroup2Model model)
    {
        if (HasPermissionInventoryGroupServiceEdit)
        {
            if (_busy)
            {
                snackbar.Add("Please wait while form is closing!", Severity.Warning);
                return;
            }
            _busy = true;
            var authprov = await auth.GetAuthenticationStateAsync();
            var user = authprov.User;

            DialogParameters parms = new DialogParameters();
            parms.Add("Model", model.Clone());
            var dialog = DialogService.Show<InventoryGroupDialog>(model.Group2ID == null ? "ADD" : "EDIT", parms);
            var result = await dialog.Result;
            if (!result.Canceled)
            {
                InventoryGroup2Model UpdatedModel = (InventoryGroup2Model)result.Data;
                UpdatedModel.Group.UserInfo.UserID = user.Identity.Name;
                try
                {
                    GIservice.Update(UpdatedModel.Group);
                    snackbar.Add("Saved Successfully", Severity.Success);
                    GetAll();
                }
                catch (Exception ex)
                {
                    snackbar.Add(ex.Message, Severity.Warning);
                }
            }
            await Task.Delay(200);
            _busy = false;
        }
        else
        {
            bool? result = await DialogService.ShowMessageBox(
                "Permission denied!",
                "You don't have any permission to Edit InventoryGroup.");
        }
    }

    private async Task Delete(InventoryItemGroupModel model)
    {
        if (HasPermissionInventoryItemServiceDelete)
        {
            bool? result = await DialogService.ShowMessageBox(
                "Warning !",
                "Are you sure, you want to delete - " + model.UoM + " (" + model.ItemGroupDescription + ") ?");
            if (result == true)
            {
                IGIservice.Delete(model.ItemGroupID, UserID);
                snackbar.Add("Deleted Successfully", Severity.Error);
                GetInventoryItem(ActiveGroup);
            }
        }
        else
        {
            bool? result = await DialogService.ShowMessageBox(
                "Permission denied!",
                "You don't have any permission to Delete InventoryItem.");
        }
    }

    void OnAppearing(MenuAppearingEventArgs e)
    {

    }

    // // private async void ReOrderLevel(InventoryItemModel ii)
    // // {
    // //     if (_busy)
    // //     {
    // //         snackbar.Add("Please wait while form is closing!", Severity.Warning);
    // //         return;
    // //     }
    // //     _busy = true;
    // //     DialogParameters parms = new DialogParameters();
    // //     parms.Add("iimodel", ii.Clone());
    // //     var dialog = DialogService.Show<InventoryItemReorderLevelDialog>("Quantity Manage", parms, new DialogOptions() { MaxWidth = MaxWidth.Medium });
    // //     await Task.Delay(200);
    // //     _busy = false;
    // // }

    private bool search(InventoryItemGroupModel ItemModel)
    {
        if (ItemModel.ItemGroupID != null && ItemModel.ItemGroupDescription.Contains(SearchItemCode, StringComparison.OrdinalIgnoreCase) || ItemModel.Makes.Contains(SearchItemCode, StringComparison.OrdinalIgnoreCase))
        {
            return true;
        }
        return false;
    }
}

