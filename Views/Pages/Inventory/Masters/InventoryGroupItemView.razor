@page "/InventoryGroupItem"
@inject IInventoryGroupService GIservice
@inject IInventoryGroup2Service G2Iservice
@inject IInventoryItemGroupService IGIservice
@inject IInventoryItemService IIservice
@inject MudBlazor.ISnackbar snackbar
@inject IChartOfAccountService accountService
@inject AuthenticationStateProvider auth
@attribute [Authorize]
@inject IDialogService DialogService
@using System.Threading;
@inject IRoleService<RoleModel> Irole

<div class="admin-page-container fade-in">
    <div class="admin-header-tiered mb-6">
        <div class="d-flex align-center justify-space-between">
            <div>
                <MudText Typo="Typo.h4" Class="admin-title">Resource Classification Engine</MudText>
                <MudText Typo="Typo.body2" Class="admin-subtitle">Manage technical inventory hierarchies, item groups, and resource account mappings.</MudText>
            </div>
        </div>
    </div>

    <MudGrid Spacing="3">
        <MudItem xs="12" lg="4">
            <div class="admin-glass-card pa-0 overflow-hidden h-100">
                <div class="px-6 py-4 border-bottom-subtle d-flex align-center justify-space-between" style="background: rgba(var(--mud-palette-primary-rgb), 0.05);">
                    <div class="d-flex align-center">
                        <div class="icon-badge primary-badge-soft mr-3">
                            <MudIcon Icon="@Icons.Material.Filled.AccountTree" Size="Size.Small" />
                        </div>
                        <MudText Typo="Typo.subtitle1" Class="fw-700">Item Stratification</MudText>
                    </div>
                    <MudIconButton Disabled="@_busy" Icon="@Icons.Material.Filled.Add" Color="Color.Primary" OnClick="@(()=> OpenDialogGroup(model))" Size="Size.Small" Variant="Variant.Filled" Class="rounded-circle shadow-none" />
                </div>
                
                <div class="pa-2">
                    <MudList T="InventoryGroup2Model" Clickable="true" SelectedItem="SelectedItem" Class="admin-nav-list">
                        @if (listOfItems?.Any() == true)
                        {
                            @foreach (var item in listOfItems)
                            {
                                <ContextMenuTrigger MenuId="myMenu" Data="@item">
                                    <MudListItem T="InventoryGroup2Model" Value="item" OnClick="@((e) => OnGroupClick(item))" Class="rounded-lg mb-1">
                                        <div class="d-flex flex-column">
                                            <span class="small opacity-50 fw-600">@item.Group.InventoryGroupName</span>
                                            <span class="fw-700">@item.GroupDescription</span>
                                        </div>
                                    </MudListItem>
                                </ContextMenuTrigger>
                            }
                        }
                    </MudList>
                </div>
            </div>
        </MudItem>

        <MudItem xs="12" lg="8">
            <div class="admin-glass-card pa-0 overflow-hidden h-100">
                @if (ActiveGroup != null)
                {
                    <div class="px-6 py-4 border-bottom-subtle d-flex align-center justify-space-between" style="background: rgba(var(--mud-palette-primary-rgb), 0.02);">
                         <div class="d-flex align-center">
                            <div class="icon-badge primary-badge-soft mr-3">
                                <MudIcon Icon="@Icons.Material.Filled.Inventory" Size="Size.Small" />
                            </div>
                            <MudText Typo="Typo.subtitle1" Class="fw-700">Constituent Items: @ActiveGroup.GroupDescription</MudText>
                        </div>
                        <MudTextField @bind-Value="SearchItemCode" Placeholder="Filter Items..." Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" AdornmentColor="Color.Primary" Variant="Variant.Outlined" Margin="Margin.Dense" Clearable="true" Class="modern-input" Style="max-width: 250px;"></MudTextField>
                    </div>

                    <MudTable Items="@collection" Elevation="0" Hover="true" Breakpoint="Breakpoint.Sm" Class="modern-admin-table" Filter="new Func<InventoryItemGroupModel, bool>(search)">
                        <HeaderContent>
                            <MudTh><MudTableSortLabel SortBy="new Func<InventoryItemGroupModel, object>(x=> x.ItemGroupDescription)" InitialDirection="SortDirection.Ascending"><span class="admin-header-text">ITEM SPECIFICATION</span></MudTableSortLabel></MudTh>
                            <MudTh><MudTableSortLabel SortBy="new Func<InventoryItemGroupModel, object>(x=> x.Makes)"><span class="admin-header-text">MANUFACTURER</span></MudTableSortLabel></MudTh>
                            <MudTh Style="text-align: right;"><span class="admin-header-text">ACTIONS</span></MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd DataLabel="Specification"><span class="admin-td-primary fw-600">@context.ItemGroupDescription</span></MudTd>
                            <MudTd DataLabel="Manufacturer">@context.Makes</MudTd>
                            <MudTd DataLabel="Actions" Style="text-align: right;">
                                <MudTooltip Text="Modify Specification">
                                    <MudIconButton OnClick="@(()=> OpenDialog(context))" Color="Color.Primary" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Variant="Variant.Text" />
                                </MudTooltip>
                                <MudTooltip Text="Remove Item">
                                    <MudIconButton OnClick="@(()=> Delete(context))" Color="Color.Error" Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Variant="Variant.Text" />
                                </MudTooltip>
                            </MudTd>
                        </RowTemplate>
                        <PagerContent>
                            <div class="pa-4">
                                <MudTablePager PageSizeOptions="new int[] { 10, 20, 50, 100 }" />
                            </div>
                        </PagerContent>
                    </MudTable>
                }
                else
                {
                    <div class="d-flex flex-column align-center justify-center pa-20 h-100 opacity-40">
                        <MudIcon Icon="@Icons.Material.Filled.AccountTree" Size="Size.Large" Class="mb-4" />
                        <MudText Typo="Typo.h6">Select a stratum to audit constituent inventory.</MudText>
                    </div>
                }
            </div>
        </MudItem>
    </MudGrid>
</div>
<ContextMenu Id="myMenu" OnAppearing="OnAppearing">
    <Item OnClick="@ContextMenuOnClickAdd" Id="addItem">Add Items</Item>
    <Item OnClick="@ContextMenuOnClickEdit" Id="editGroup">Edit Group</Item>
    <Item OnClick="@ContextMenuOnClickMappingEdit" Id="MappingEditGroup">Edit Account Mapping</Item>
</ContextMenu>

@code {

    private string SearchItemCode = "";
    InventoryGroup2Model model = new InventoryGroup2Model();
    private InventoryGroup2Model ActiveGroup;
    private MudListItem<InventoryGroup2Model> SelectedItem;
    private List<InventoryGroup2Model> listOfItems = new();
    private List<InventoryItemGroupModel> collection = new List<InventoryItemGroupModel>();
    private string UserID = string.Empty;
    private bool _busy;

    public bool HasPermissionInventoryItemServiceEdit { get; set; } = false;
    public bool HasPermissionInventoryItemServiceDelete { get; set; } = false;
    public int InventoryItemDocTypeID = 68;

    public bool HasPermissionInventoryGroupServiceEdit { get; set; } = false;
    public bool HasPermissionStoreServiceDelete { get; set; } = false;
    public int InventoryGroupDocTypeID = 70;

    protected override async Task OnInitializedAsync()
    {
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionInventoryItemServiceEdit = await Irole.HasClaim(InventoryItemDocTypeID.ToString(), "Edit", ctc.Token);
        HasPermissionInventoryItemServiceDelete = await Irole.HasClaim(InventoryItemDocTypeID.ToString(), "Delete", ctc.Token);

        HasPermissionInventoryGroupServiceEdit = await Irole.HasClaim(InventoryGroupDocTypeID.ToString(), "Edit", ctc.Token);

        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;
        UserID = user.Identity.Name;
        GetAll();
    }

    private void GetAll()
    {
        if (listOfItems != null)
        {
            listOfItems.Clear();
        }
        listOfItems = G2Iservice.SearchByName(string.Empty).ToList();
        StateHasChanged();
    }

    protected void OnGroupClick(InventoryGroup2Model item)
    {
        ActiveGroup = item;
        GetInventoryItem(ActiveGroup);
    }

    private void GetInventoryItem(InventoryGroup2Model ig)
    {
        collection = new List<InventoryItemGroupModel>();
        foreach (var itemGroup in IGIservice.SelectByGroup(ig.Group2ID))
        {
            // foreach (var item in IIservice.SelectByGroup(itemGroup.ItemGroupID))
            // {
            collection.Add(itemGroup);
            // }
        }
        StateHasChanged();
    }

    protected async Task ContextMenuOnClickAdd(ItemClickEventArgs e)
    {
        InventoryGroup2Model ig = (InventoryGroup2Model)((InventoryGroup2Model)e.Data).Clone();
        InventoryItemGroupModel ii = new InventoryItemGroupModel();
        ii.Group2ID = ig.Group2ID;
        await OpenDialog(ii);
    }

    protected async Task ContextMenuOnClickEdit(ItemClickEventArgs e)
    {
        InventoryGroup2Model ig = (InventoryGroup2Model)((InventoryGroup2Model)e.Data).Clone();
        await OpenDialogGroup(ig);
    }

    protected async Task ContextMenuOnClickMappingEdit(ItemClickEventArgs e)
    {
        InventoryGroup2Model ig = (InventoryGroup2Model)((InventoryGroup2Model)e.Data).Clone();
        await OpenDialogMappingEditGroup(ig);
    }

    private async Task OpenDialog(InventoryItemGroupModel ii)
    {
        if (HasPermissionInventoryItemServiceEdit)
        {
            if (_busy)
            {
                snackbar.Add("Please wait while form is closing!", Severity.Warning);
                return;
            }
            _busy = true;
            var authprov = await auth.GetAuthenticationStateAsync();
            var user = authprov.User;

            DialogParameters parms = new DialogParameters();
            parms.Add("model", ii.Clone());
            var dialog = await DialogService.ShowAsync<InventoryItemgroupDialog>(ii.ItemGroupID == null ? "ADD" : "EDIT", parms);
            var result = await dialog.Result;
            if (!result.Canceled)
            {
                InventoryItemGroupModel UpdatedModel = (InventoryItemGroupModel)result.Data;
                if (UpdatedModel.ItemMake.Count == 0)
                {
                    bool? Message = await DialogService.ShowMessageBoxAsync(
                        "Oops",
                        "There should be atleast 1 ItemMake selected.");
                    _busy = false;
                    return;
                }
                UpdatedModel.UserInfo.UserID = user.Identity.Name;
                try
                {
                    IGIservice.Update(UpdatedModel);
                    snackbar.Add("Saved Successfully", Severity.Success);
                    InventoryGroup2Model igm = new InventoryGroup2Model();
                    igm.Group2ID = UpdatedModel.Group2ID;
                    GetInventoryItem(igm);
                }
                catch (Exception ex)
                {
                    snackbar.Add(ex.Message, Severity.Warning);
                }
            }
            await Task.Delay(200);
            _busy = false;
        }
        else
        {
            bool? result = await DialogService.ShowMessageBoxAsync(
                "Permission denied!",
                "You don't have any permission to Edit InventoryItem.");
        }
    }

    private async Task OpenDialogGroup(InventoryGroup2Model ig)
    {
        if (HasPermissionInventoryGroupServiceEdit)
        {
            if (_busy)
            {
                snackbar.Add("Please wait while form is closing!", Severity.Warning);
                return;
            }
            _busy = true;
            var authprov = await auth.GetAuthenticationStateAsync();
            var user = authprov.User;

            DialogParameters parms = new DialogParameters();
            parms.Add("model", ig.Clone());
            var dialog = await DialogService.ShowAsync<InventoryGroup2Dialog>(ig.Group2ID == null ? "ADD" : "EDIT", parms);
            var result = await dialog.Result;
            if (!result.Canceled)
            {
                InventoryGroup2Model UpdatedModel = (InventoryGroup2Model)result.Data;
                UpdatedModel.UserInfo.UserID = user.Identity.Name;
                try
                {
                    G2Iservice.Update(UpdatedModel);
                    snackbar.Add("Saved Successfully", Severity.Success);
                    GetAll();
                }
                catch (Exception ex)
                {
                    snackbar.Add(ex.Message, Severity.Warning);
                }
            }
            await Task.Delay(200);
            _busy = false;
        }
        else
        {
            bool? result = await DialogService.ShowMessageBoxAsync(
                "Permission denied!",
                "You don't have any permission to Edit InventoryGroup.");
        }
    }

    private async Task OpenDialogMappingEditGroup(InventoryGroup2Model model)
    {
        if (HasPermissionInventoryGroupServiceEdit)
        {
            if (_busy)
            {
                snackbar.Add("Please wait while form is closing!", Severity.Warning);
                return;
            }
            _busy = true;
            var authprov = await auth.GetAuthenticationStateAsync();
            var user = authprov.User;

            DialogParameters parms = new DialogParameters();
            parms.Add("Model", model.Clone());
            var dialog = await DialogService.ShowAsync<InventoryGroupDialog>(model.Group2ID == null ? "ADD" : "EDIT", parms);
            var result = await dialog.Result;
            if (!result.Canceled)
            {
                InventoryGroup2Model UpdatedModel = (InventoryGroup2Model)result.Data;
                UpdatedModel.Group.UserInfo.UserID = user.Identity.Name;
                try
                {
                    GIservice.Update(UpdatedModel.Group);
                    snackbar.Add("Saved Successfully", Severity.Success);
                    GetAll();
                }
                catch (Exception ex)
                {
                    snackbar.Add(ex.Message, Severity.Warning);
                }
            }
            await Task.Delay(200);
            _busy = false;
        }
        else
        {
            bool? result = await DialogService.ShowMessageBoxAsync(
                "Permission denied!",
                "You don't have any permission to Edit InventoryGroup.");
        }
    }

    private async Task Delete(InventoryItemGroupModel model)
    {
        if (HasPermissionInventoryItemServiceDelete)
        {
            bool? result = await DialogService.ShowMessageBoxAsync(
                "Warning !",
                "Are you sure, you want to delete - " + model.UoM + " (" + model.ItemGroupDescription + ") ?");
            if (result == true)
            {
                IGIservice.Delete(model.ItemGroupID, UserID);
                snackbar.Add("Deleted Successfully", Severity.Error);
                GetInventoryItem(ActiveGroup);
            }
        }
        else
        {
            bool? result = await DialogService.ShowMessageBoxAsync(
                "Permission denied!",
                "You don't have any permission to Delete InventoryItem.");
        }
    }

    void OnAppearing(MenuAppearingEventArgs e)
    {

    }

    // // private async void ReOrderLevel(InventoryItemModel ii)
    // // {
    // //     if (_busy)
    // //     {
    // //         snackbar.Add("Please wait while form is closing!", Severity.Warning);
    // //         return;
    // //     }
    // //     _busy = true;
    // //     DialogParameters parms = new DialogParameters();
    // //     parms.Add("iimodel", ii.Clone());
    // //     var dialog = DialogService.Show<InventoryItemReorderLevelDialog>("Quantity Manage", parms, new DialogOptions() { MaxWidth = MaxWidth.Medium });
    // //     await Task.Delay(200);
    // //     _busy = false;
    // // }

    private bool search(InventoryItemGroupModel ItemModel)
    {
        if (ItemModel.ItemGroupID != null && ItemModel.ItemGroupDescription.Contains(SearchItemCode, StringComparison.OrdinalIgnoreCase) || ItemModel.Makes.Contains(SearchItemCode, StringComparison.OrdinalIgnoreCase))
        {
            return true;
        }
        return false;
    }
}

