@page "/InventoryItemLock"
@inject IInventoryItemLockService Iservice
@inject MudBlazor.ISnackbar snackbar
@inject AuthenticationStateProvider auth
@attribute [Authorize]
@using System.Threading;
@inject IRoleService<RoleModel> Irole
@inject IDialogService DialogService

<div class="admin-page-container fade-in">
    <div class="admin-header-tiered mb-6">
        <div class="d-flex align-center justify-space-between">
            <div>
                <MudText Typo="Typo.h4" Class="admin-title">Inventory Security Controls</MudText>
                <MudText Typo="Typo.body2" Class="admin-subtitle">Configure operational locks and temporal restrictions for critical workshop resources and technical items.</MudText>
            </div>
            <MudButton Disabled="@_busy" Variant="Variant.Filled" Color="Color.Primary" OnClick="@(()=> OpenDialog(new InventoryItemLockModel()))" Class="admin-register-btn" StartIcon="@Icons.Material.Filled.Add">CONFIGURE LOCK</MudButton>
        </div>
    </div>

    <div class="admin-glass-card pa-6 mb-6">
        <MudGrid Spacing="3" Class="align-center">
            <MudItem xs="12" md="6">
                <MudTextField @bind-Value="searchItem" Placeholder="Filter by Item Code, Group, or Description..." Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" AdornmentColor="Color.Primary" Variant="Variant.Outlined" Margin="Margin.Dense" Clearable="true" Class="modern-input"></MudTextField>
            </MudItem>
        </MudGrid>
    </div>

    <div class="admin-glass-card overflow-hidden">
        <MudTable Items="@collection" Elevation="0" Hover="true" Breakpoint="Breakpoint.Sm" Class="modern-admin-table" Filter="new Func<InventoryItemLockModel, bool>(search)">
            <HeaderContent>
                <MudTh><MudTableSortLabel SortBy="new Func<InventoryItemLockModel, object>(x=> x.ItemCode)" InitialDirection="SortDirection.Ascending"><span class="admin-header-text">RESOURCE IDENTIFIER</span></MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<InventoryItemLockModel, object>(x=> x.LockDays)"><span class="admin-header-text">TEMPORAL RESTRICTION</span></MudTableSortLabel></MudTh>
                <MudTh Style="text-align: right;"><span class="admin-header-text">ACTIONS</span></MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Resource">
                    <div class="d-flex flex-column">
                        <span class="admin-td-primary fw-600">@context.ItemCode</span>
                        <span class="small opacity-60">@context.ItemGroupDescription - @context.ItemDescription</span>
                    </div>
                </MudTd>
                <MudTd DataLabel="Temporal Restriction">
                    <div class="d-flex align-center">
                        <MudIcon Icon="@Icons.Material.Filled.AvTimer" Size="Size.Small" Color="Color.Warning" Class="mr-2" />
                        <span class="fw-700">@context.LockDays Days</span>
                    </div>
                </MudTd>
                <MudTd DataLabel="Actions" Style="text-align: right;">
                    <MudTooltip Text="Edit Lock Configuration">
                        <MudIconButton OnClick="@(()=> OpenDialog(context))" Color="Color.Primary" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Variant="Variant.Text" />
                    </MudTooltip>
                    <MudTooltip Text="Lift Restriction">
                        <MudIconButton OnClick="@(()=> Delete(context))" Color="Color.Error" Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Variant="Variant.Text" />
                    </MudTooltip>
                </MudTd>
            </RowTemplate>
            <PagerContent>
                <div class="pa-4">
                    <MudTablePager PageSizeOptions="new int[] { 10, 20, 50, 100 }" />
                </div>
            </PagerContent>
        </MudTable>
    </div>
</div>

@code {

    private InventoryItemLockModel model = new InventoryItemLockModel();
    private List<InventoryItemLockModel> collection = new List<InventoryItemLockModel>();
    private string searchItem = "";
    private bool _busy;

    // Lifecycle method called when the component is initialized
    protected override async Task OnInitializedAsync()
    {
        model = new();
        Getcollection();
    }

    // Method to open the dialog for adding or editing a GST item
    private async Task OpenDialog(InventoryItemLockModel tds)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        _busy = true;

        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;
        DialogOptions Width = new DialogOptions() { MaxWidth = MaxWidth.Medium, FullWidth = true };
        DialogParameters parms = new DialogParameters();
        parms.Add("model", tds.Clone());
        var dialog = await DialogService.ShowAsync<InventoryItemLockDialog>(tds.LockID == null ? "ADD" : "EDIT", parms, Width);
        var result = await dialog.Result;
        if (!result.Canceled)
        {                       
            model = new InventoryItemLockModel();
            Getcollection();            
        }
        await Task.Delay(200);
        _busy = false;
    }

    private async Task Delete(InventoryItemLockModel model)
    {        
        bool? result = await DialogService.ShowMessageBoxAsync(
            "Warning !",
            "Are you sure, you want to delete Lock days of - " + model.ItemCode + " (" + model.ItemGroupDescription + ") ?");
        if (result == true)
        {
            var authprov = await auth.GetAuthenticationStateAsync();
            var user = authprov.User;
            var value = Iservice.Delete(model.LockID.Value, user.Identity.Name); // Call service to delete the item
            if (value != -1)
            {
                snackbar.Add("Deleted Successfully", Severity.Success);
                Getcollection();
            }
        }        
    }

    private bool search(InventoryItemLockModel tds)
    {
        if (tds.ItemCode != null && tds.ItemCode.Contains(searchItem, StringComparison.OrdinalIgnoreCase)
                                 || tds.ItemGroupDescription.Contains(searchItem, StringComparison.OrdinalIgnoreCase)
                                 || tds.ItemDescription.Contains(searchItem, StringComparison.OrdinalIgnoreCase))
        {
            return true;
        }
        else if (tds.ItemCode == null)
            return true;
        return false;
    }

    private void Getcollection()
    {
        collection = Iservice.Select().ToList();
    }
}

