@inject IInventoryItemReOrderLevelService Iservice
@inject MudBlazor.ISnackbar snackbar
@inject AuthenticationStateProvider auth
@inject IRoleService<RoleModel> Irole
@inject IDialogService DialogService

<MudDialog Class="admin-dialog-glass">
    <TitleContent>
        <div class="header-section mb-2 pt-4 px-4">
            <div class="d-flex align-center justify-space-between">
                <div class="d-flex align-center">
                    <div class="icon-badge primary-badge mr-4">
                        <div class="admin-header-icon-badge mb-3">
                            <MudIcon Icon="@Icons.Material.Filled.ProductionQuantityLimits" Color="Color.Secondary" Style="font-size: 3rem;" />
                        </div>
                    </div>
                    <div>
                        <MudText Typo="Typo.h5" Class="admin-title"><b>Inventory Level Management</b></MudText>
                        <MudText Typo="Typo.body2" Class="admin-subtitle">
                           Configure safety stock, minimum quantities, and reorder triggers for: <span class="fw-700 color-primary">@iimodel.InventoryItemCode</span>
                        </MudText>
                    </div>
                </div>
            </div>
            <div class="title-accent mt-4"></div>
        </div>
    </TitleContent>
    <DialogContent>
        <MudContainer Class="admin-dialog-container">
            <div class="dialog-content-wrapper pa-4">
                <EditForm id="reorderlevelform" Model="@model" OnValidSubmit="OnValidSubmit">
                    <ObjectGraphDataAnnotationsValidator />
                    
                    <div class="admin-glass-card pa-0 overflow-hidden mb-6">
                        <div class="pa-6 border-b" style="border-bottom: 1px solid rgba(0,0,0,0.05); background: rgba(var(--mud-palette-primary-rgb), 0.02);">
                            <div class="d-flex align-center">
                                <MudIcon Icon="@Icons.Material.Filled.Warehouse" Color="Color.Primary" Class="mr-2" />
                                <span class="admin-section-label mb-0">Store-Wise Stock Parameters</span>
                            </div>
                        </div>

                        <div class="pa-6">
                            <MudGrid Spacing="3">
                                @foreach (var item in model.ReOrderLevelList)
                                {
                                    <MudItem xs="12">
                                        <div class="d-flex align-center pa-4 rounded-lg gray-bg mb-2" style="background: rgba(0,0,0,0.02); border: 1px solid rgba(0,0,0,0.05);">
                                            <div style="min-width: 150px;">
                                                <MudText Typo="Typo.subtitle2" Class="fw-700">@item.Store.StoreName</MudText>
                                                <MudText Typo="Typo.caption" Class="opacity-60 text-uppercase">Facility Source</MudText>
                                            </div>
                                            
                                            <MudGrid Spacing="2" Class="flex-grow-1 ml-4">
                                                <MudItem xs="4">
                                                    <MudNumericField T="decimal?" @bind-Value="item.InhandQty" Label="Current In-Hand" Variant="Variant.Text" Margin="Margin.Dense" ReadOnly Adornment="Adornment.End" AdornmentIcon="@Icons.Material.Filled.Inventory2" AdornmentColor="Color.Info" Class="modern-input" />
                                                </MudItem>
                                                <MudItem xs="4">
                                                    <MudNumericField T="decimal?" @bind-Value="item.MinQty" Label="Safe Minimum" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => item.MinQty)" Class="modern-input" HideSpinButtons="true" />
                                                </MudItem>
                                                <MudItem xs="4">
                                                    <MudNumericField T="decimal?" @bind-Value="item.ReOrderLevel" Label="Reorder Trigger" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => item.ReOrderLevel)" Class="modern-input" HideSpinButtons="true" />
                                                </MudItem>
                                            </MudGrid>
                                        </div>
                                    </MudItem>
                                }
                            </MudGrid>
                        </div>
                    </div>

                    <div class="admin-glass-card pa-6 text-center shadow-none gray-bg" style="background: rgba(0,0,0,0.02);">
                        <MudIcon Icon="@Icons.Material.Filled.Analytics" Color="Color.Info" Size="Size.Large" Class="mb-2 opacity-50" />
                        <MudText Typo="Typo.body2" Class="fw-500 opacity-70">
                            Reorder thresholds automate procurement signals when stock dips below defined technical minimums.
                        </MudText>
                    </div>
                </EditForm>
            </div>
        </MudContainer>
    </DialogContent>
    <DialogActions>
        <div class="d-flex w-100 flex-wrap pa-4 gap-3 align-center">
            <MudSpacer />
            <MudButton @onclick="Cancel" Variant="Variant.Outlined" Color="Color.Default" Style="border-radius: 12px; font-weight: 700; text-transform: none; border-color: rgba(0,0,0,0.15);">Discard</MudButton>
            <MudButton Disabled="@_busy" form="reorderlevelform" Variant="Variant.Filled" Color="Color.Success" ButtonType="ButtonType.Submit" Style="background: var(--mud-palette-success); color: white; font-weight: 800; border-radius: 12px; text-transform: none; white-space: nowrap; padding: 8px 24px;" StartIcon="@Icons.Material.Filled.Save">Update Stock Levels</MudButton>
        </div>
    </DialogActions>
</MudDialog>

@code {

    public InventoryItemReOrderLevelModel model { get; set; } = new();
    [Parameter]
    public InventoryItemModel iimodel { get; set; }
    [CascadingParameter]
    IMudDialogInstance MudDialog { get; set; }
    private int BranchID { get; set; } = 0;
    private string UserID { get; set; }
    private bool _busy;

    public bool HasPermissionInventoryItemReOrderLevelServiceEdit { get; set; } = false;
    public int DocTypeID = 69;

    protected override async Task OnInitializedAsync()
    {
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionInventoryItemReOrderLevelServiceEdit = await Irole.HasClaim(DocTypeID.ToString(), "Edit", ctc.Token);

        var authprov = await auth.GetAuthenticationStateAsync();
        var User = authprov.User;
        BranchID = int.Parse(User.Claims.First(x => x.Type == "BranchID").Value);
        UserID = User.Identity.Name;
        model.ReOrderLevelList = Iservice.SelectByItem(iimodel.InventoryItemID, BranchID).ToList();
    }

    private async Task OnValidSubmit(EditContext context)
    {
        if (HasPermissionInventoryItemReOrderLevelServiceEdit)
        {
            if (_busy)
            {
                snackbar.Add("Please wait while form is being submitted!", Severity.Warning);
                return;
            }
            _busy = true;
            var authprov = await auth.GetAuthenticationStateAsync();
            var user = authprov.User;
            model.UserInfo = new();
            model.UserInfo.UserID = user.Identity.Name;
            try
            {
                Iservice.Update(model);
                snackbar.Add("Saved Successfully", Severity.Success);
                MudDialog.Close(DialogResult.Ok(model));
            }
            catch (Exception ex)
            {
                snackbar.Add(ex.Message, Severity.Warning);
            }
            await Task.Delay(200);
            _busy = false;
        }
        else
        {
            await DialogService.ShowMessageBoxAsync(
                "Permission denied!",
                "You don't have any permission to Edit InventoryItemReOrderLevel.");
        }
    }

    private void Cancel()
    {
        MudDialog.Cancel();
    }
}
