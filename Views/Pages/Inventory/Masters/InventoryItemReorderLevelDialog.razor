@inject IInventoryItemReOrderLevelService Iservice
@inject MudBlazor.ISnackbar snackbar
@inject AuthenticationStateProvider auth
@attribute [Authorize]
@using System.Threading;
@inject IRoleService<RoleModel> Irole
@inject IDialogService DialogService

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.ProductionQuantityLimits" Class="mr-3 mb-n1" />
            @iimodel.InventoryItemCode
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudContainer Style="min-height:300px;max-height: 800px;">
            <EditForm id="reorderlevelform" Model="@model" OnValidSubmit="OnValidSubmit">
                <ObjectGraphDataAnnotationsValidator />
                <ValidationSummary />
                <MudGrid Spacing="2">
                    @foreach (var item in model.ReOrderLevelList)
                    {
                        <MudItem xs="2" md="2">
                            <MudText><p style="padding-top:12px">@item.Store.StoreName</p></MudText>
                        </MudItem>
                        <MudItem xs="3" md="3">
                            <MudTextField @bind-Value="item.InhandQty" Label="Inhand Qty" Variant="Variant.Text" MaxLength="8" Margin="Margin.Dense" For="@(() => item.InhandQty)" ReadOnly></MudTextField>
                         </MudItem>
                        <MudItem xs="3" md="3">
                            <MudTextField @bind-Value="item.MinQty" Label="Min Qty" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => item.MinQty)"></MudTextField>
                        </MudItem>
                        <MudItem xs="3" md="3">
                            <MudTextField @bind-Value="item.ReOrderLevel" Label="ReOrder Level Qty" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => item.ReOrderLevel)"></MudTextField>
                        </MudItem>
                    }
                </MudGrid>
            </EditForm>
        </MudContainer>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Disabled="@_busy" form="reorderlevelform" Variant="Variant.Filled" Color="Color.Success" ButtonType="ButtonType.Submit">Submit</MudButton>
    </DialogActions>
</MudDialog>

@code {

    public InventoryItemReOrderLevelModel model { get; set; } = new();
    [Parameter]
    public InventoryItemModel iimodel { get; set; }
    [CascadingParameter]
    MudDialogInstance MudDialog { get; set; }
    private int BranchID { get; set; } = 0;
    private string UserID;
    private bool _busy;

    public bool HasPermissionInventoryItemReOrderLevelServiceEdit { get; set; } = false;
    public int DocTypeID = 69;

    protected override async Task OnInitializedAsync()
    {
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionInventoryItemReOrderLevelServiceEdit = await Irole.HasClaim(DocTypeID.ToString(), "Edit", ctc.Token);

        var authprov = await auth.GetAuthenticationStateAsync();
        var User = authprov.User;
        BranchID = int.Parse(User.Claims.First(x => x.Type == "BranchID").Value);
        UserID = User.Identity.Name;
        model.ReOrderLevelList = Iservice.SelectByItem(iimodel.InventoryItemID, BranchID).ToList();
    }

    private async void OnValidSubmit(EditContext context)
    {
        if (HasPermissionInventoryItemReOrderLevelServiceEdit)
        {
            if (_busy)
            {
                snackbar.Add("Please wait while form is being submitted!", Severity.Warning);
                return;
            }
            _busy = true;
            var authprov = await auth.GetAuthenticationStateAsync();
            var user = authprov.User;
            model.UserInfo = new();
            model.UserInfo.UserID = user.Identity.Name;
            try
            {
                Iservice.Update(model);
                snackbar.Add("Saved Successfully", Severity.Success);
            }
            catch (Exception ex)
            {
                snackbar.Add(ex.Message, Severity.Warning);
            }
            MudDialog.Close(model);
            await Task.Delay(200);
            _busy = false;
        }
        else
        {
            bool? result = await DialogService.ShowMessageBox(
                "Permission denied!",
                "You dont have any permission to Delete InventoryItemReOrderLevel.");
        }
    }

    private void Cancel()
    {
        MudDialog.Cancel();
    }
}