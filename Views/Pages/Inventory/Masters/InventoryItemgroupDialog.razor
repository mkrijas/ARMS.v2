@inject IInventoryItemService Iservice
@inject IInventoryItemGroupService Igservice
@inject MudBlazor.ISnackbar snackbar
@inject IInventoryGroupService groupIservice
@inject IInventoryGroup2Service group2Iservice
@inject AuthenticationStateProvider auth
@attribute [Authorize]
@inject IDialogService DialogService

<DialogForm @ref="@dialogForm" Title="Inventory Asset Classification" Subtitle="Define and catalog high-precision inventory assets with multi-make specifications and part synchronization." Icon="@Icons.Material.Filled.Inventory" AdminStyle="true" formID="formtdsRate" model="@model" _busy="_busy">
    <FormContent>
        <div class="dialog-content-wrapper">
            <EditForm id="formtdsRate" Model="@model" OnValidSubmit="OnValidSubmit">
                <ObjectGraphDataAnnotationsValidator />
                
                <div class="admin-glass-card pa-6 mb-6">
                    <div class="d-flex align-center mb-6">
                        <MudIcon Icon="@Icons.Material.Filled.Category" Color="Color.Primary" Class="mr-2" />
                        <span class="admin-section-label mb-0">Canonical Asset Blueprint</span>
                    </div>

                    <MudGrid Spacing="3">
                        <MudItem xs="12" md="6">
                            <MudSelect Label="Product Taxonomy (Group 2)" @bind-Value="model.Group2ID" T="int?" Variant="Variant.Outlined" Margin="Margin.Normal" AdornmentColor="Color.Secondary" ReadOnly Class="modern-input" AdornmentIcon="@Icons.Material.Filled.AccountTree">
                                @foreach (var ditem in ivgroup)
                                {
                                    <MudSelectItem Value="@ditem.Group2ID">@ditem.GroupDescription</MudSelectItem>
                                }
                            </MudSelect>
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <MudTextField @bind-Value="model.ItemGroupDescription" Label="Asset Description" Variant="Variant.Outlined" Margin="Margin.Normal" For="@(() => model.ItemGroupDescription)" Class="modern-input" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Description" />
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <MudTextField @bind-Value="model.UoM" Label="Unit of Measurement (UoM)" Variant="Variant.Outlined" Margin="Margin.Normal" For="@(() => model.UoM)" Class="modern-input" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Scale" />
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <MudTextField @bind-Value="model.HsnCode" Label="Regulatory HSN/SAC Code" Variant="Variant.Outlined" MaxLength="8" Margin="Margin.Normal" For="@(() => model.HsnCode)" Class="modern-input" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Gavel" />
                        </MudItem>
                    </MudGrid>
                </div>

                <div class="admin-glass-card pa-0 overflow-hidden mb-6">
                    <div class="pa-6 border-b">
                        <div class="d-flex align-center">
                            <MudIcon Icon="@Icons.Material.Filled.FactCheck" Color="Color.Primary" Class="mr-2" />
                            <span class="admin-section-label mb-0">Multi-Make Specification Manifest</span>
                        </div>
                    </div>

                    <MudTable Items="@model.ItemMake" Dense="true" Hover="true" Elevation="0" Class="modern-table no-border-radius" HeaderClass="admin-table-header">
                        <HeaderContent>
                            <MudTh>Asset Code</MudTh>
                            <MudTh>Manufacturer (Make)</MudTh>
                            <MudTh>OEM Part Identifier</MudTh>
                            <MudTh Style="text-align: center">Operations</MudTh>
                        </HeaderContent>
                        <RowTemplate Context="item">
                            <MudTd DataLabel="Code"><span class="fw-700 color-primary">@item.InventoryItemCode</span></MudTd>
                            <MudTd DataLabel="Make">@item.ItemDescription</MudTd>
                            <MudTd DataLabel="Part #"><MudChip T="string" Color="Color.Secondary" Size="Size.Small" Variant="Variant.Text" Class="fw-600">@item.PartNumber</MudChip></MudTd>
                            <MudTd DataLabel="Actions" Style="text-align: center">
                                @if (!ReadOnly)
                                {
                                    <MudIconButton Color="Color.Error" @onclick="@(()=> Delete(@item))" Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Variant="Variant.Text" />
                                }
                            </MudTd>
                        </RowTemplate>
                        <NoRecordsContent>
                            <div class="pa-12 text-center color-muted gray-bg">
                                <MudIcon Icon="@Icons.Material.Filled.PlaylistRemove" Size="Size.Large" Class="mb-2 opacity-30" />
                                <MudText Typo="Typo.body2">No manufacturing variants documented for this asset group.</MudText>
                            </div>
                        </NoRecordsContent>
                    </MudTable>
                </div>

                @if (!ReadOnly)
                {
                    <div class="admin-glass-card pa-6 shadow-none" style="background: rgba(var(--mud-palette-primary-rgb), 0.03); border: 1px dashed var(--mud-palette-primary);">
                        <MudText Typo="Typo.subtitle2" Class="mb-4 fw-700">Append New Specification Variant</MudText>
                        <MudGrid Spacing="3" Class="align-end">
                            <MudItem xs="12" md="3">
                                <MudTextField @bind-Value="itemMakeModel.InventoryItemCode" Label="Internal Code" Variant="Variant.Outlined" Margin="Margin.Normal" Disabled Class="modern-input" />
                            </MudItem>
                            <MudItem xs="12" md="4">
                                <MudTextField @bind-Value="itemMakeModel.ItemDescription" Label="Manufacturer Make" Variant="Variant.Outlined" Margin="Margin.Normal" For="@(() => itemMakeModel.ItemDescription)" Class="modern-input" />
                            </MudItem>
                            <MudItem xs="12" md="3">
                                <MudTextField @bind-Value="itemMakeModel.PartNumber" Label="Part ID" Variant="Variant.Outlined" Margin="Margin.Normal" For="@(() => itemMakeModel.PartNumber)" Class="modern-input" />
                            </MudItem>
                            <MudItem xs="12" md="2" Class="d-flex justify-end">
                                <MudButton OnClick="AddItems" Color="Color.Primary" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.Add" Class="rounded-lg py-3 px-6 shadow-none full-width-mobile">Add Spec</MudButton>
                            </MudItem>
                        </MudGrid>
                    </div>
                }
            </EditForm>
        </div>
    </FormContent>
</DialogForm>

@code {
    DialogForm dialogForm;
    [Parameter]
    public InventoryItemGroupModel model { get; set; }
    [Parameter]
    public bool ReadOnly { get; set; }
    private List<InventoryGroup2Model> ivgroup = new();
    private InventoryItemModel itemMakeModel = new InventoryItemModel();
    private bool _busy;

    protected override void OnInitialized()
    {
        ivgroup = group2Iservice.SearchByName(string.Empty).ToList();
        if (model.ItemGroupID != null)
        {
            model.ItemMake = Iservice.SelectByItemGroup(model.ItemGroupID).ToList();
        }
    }

    private async void OnValidSubmit(EditContext context)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is being submitted!", Severity.Warning);
            return;
        }
        if (model.ItemMake == null)
        {
            snackbar.Add("Select InventoryItemGroup", Severity.Success);
            return;
        }
        _busy = true;
        model.ItemGroupDescription = FontStyle.ConvertToCamelCase(model.ItemGroupDescription);
        model.HsnCode = model.HsnCode.ToUpper();
        dialogForm.Close(model);
        await Task.Delay(200);
        _busy = false;
    }

    private void Delete(InventoryItemModel i)
    {
        int rowIndex = model.ItemMake.IndexOf(i);
        model.ItemMake.RemoveAt(rowIndex);
    }

    private void AddItems()
    {
        if (itemMakeModel.ItemDescription == null)
        {
            snackbar.Add("Please fill in all Fields", Severity.Error);
            return;
        }
        itemMakeModel.InventoryItemCode = null;
        model.ItemMake.Add(itemMakeModel);
        itemMakeModel = new();
    }

    private void Cancel()
    {
        dialogForm.Cancel();
    }
}

