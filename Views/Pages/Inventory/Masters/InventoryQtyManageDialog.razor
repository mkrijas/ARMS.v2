@inject IInventoryItemService Iservice
@inject IStoreService storeIservice
@inject MudBlazor.ISnackbar snackbar
@inject IInventoryGroupService groupIservice
@inject AuthenticationStateProvider auth
@attribute [Authorize]
@inject IDialogService DialogService

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.Build" Class="mr-3 mb-n1" />
            Quantity Manage
        </MudText>
    </TitleContent>
    <DialogContent>

        <MudContainer Style="min-height:300px;max-height: 800px;">
            <EditForm id="qtymangeform" Model="@model" OnValidSubmit="OnValidSubmit">
                <ObjectGraphDataAnnotationsValidator />
                <ValidationSummary />
                <MudGrid Spacing="2">

                     @foreach (var item in StoreList)
                     {
                         <MudItem xs="4" md="4">
                            <MudText>@item.StoreName</MudText>
                         </MudItem>
                        <MudItem xs="4" md="4">
                            <MudTextField @bind-Value="model.MinQty" Label="Min Qty" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.MinQty)"></MudTextField>
                        </MudItem>
                        <MudItem xs="4" md="4">
                            <MudTextField @bind-Value="model.ReOrderQty" Label="ReOrder Qty" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.ReOrderQty)"></MudTextField>
                        </MudItem>
                        <MudItem xs="12" md="12">
                            <MudTextField @bind-Value="model.InhandQty" Label="Inhand Qty" Variant="Variant.Outlined" MaxLength="8" Margin="Margin.Dense" For="@(() => model.InhandQty)"></MudTextField>
                        </MudItem>
                     }
                </MudGrid>
            </EditForm>
        </MudContainer>


    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton form="formtdsRate" Variant="Variant.Filled" Color="Color.Success" ButtonType="ButtonType.Submit">Submit</MudButton>


    </DialogActions>
</MudDialog>


@code {
    public InventoryQtyManageModel model { get; set; } = new();

    [Parameter]
    public int? InventoryItemID { get; set; }

    [CascadingParameter] 
    MudDialogInstance MudDialog { get; set; }

    private List<StoreModel> StoreList = new();
    private int BranchID { get; set; } = 0;
    private string UserID;

    protected override async Task OnInitializedAsync()
    {
        var authprov = await auth.GetAuthenticationStateAsync();
        var User = authprov.User;
        BranchID = int.Parse(User.Claims.First(x => x.Type == "BranchID").Value);
        UserID = User.Identity.Name;
        StoreList = storeIservice.SelectByBranch(BranchID).ToList();
    }

    private void OnValidSubmit(EditContext context)
    {
        
        MudDialog.Close(model);
    }
    private void Cancel()
    {
        MudDialog.Cancel();
    }
}
