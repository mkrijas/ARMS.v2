@inject IPurchaseOrderService Iservice

@inject MudBlazor.ISnackbar snackbar
@inject AuthenticationStateProvider auth
@attribute [Authorize]
@inject IDialogService DialogService


<MudDialog>
   
    <DialogContent>
        <MudContainer Style="min-height:300px;max-height: 450px;overflow-y: scroll">
     
<MudGrid Spacing="4">
   <MudItem xs="12">
        <MudTable Items="@collection"   Dense="true" Hover="true"  Striped="true" Elevation="10" Filter="new Func<PurchaseOrderModel, bool>(search)"  @bind-place="model">           
             <ToolBarContent>
                <MudText Typo="Typo.h6">Purchase Order</MudText>
                <MudSpacer></MudSpacer>
                 <MudTextField @bind-Value="searchPurchase" Placeholder="Search Purchase order... "
                              Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                              IconSize="Size.Medium" Class="mt-0"></MudTextField>
          
            </ToolBarContent>
            <HeaderContent>
                <MudTh><MudTableSortLabel SortBy="new Func<PurchaseOrderModel, object>(x=> x.PONo)" InitialDirection="SortDirection.Ascending">PO No</MudTableSortLabel></MudTh>
             <MudTh><MudTableSortLabel SortBy="new Func<PurchaseOrderModel, object>(x=> x.EntryDate)" InitialDirection="SortDirection.Ascending">Entry Date</MudTableSortLabel></MudTh>
               <MudTh><MudTableSortLabel SortBy="new Func<PurchaseOrderModel, object>(x=> x.PartyName)" InitialDirection="SortDirection.Ascending">Party</MudTableSortLabel></MudTh>
               
                <MudTh>Actions</MudTh>
            </HeaderContent>

            <RowTemplate>   
                <MudTd DataLabel="PONo">@context.PONo</MudTd>
                <MudTd DataLabel="EntryDate"  >@context.EntryDate?.ToShortDateString()</MudTd>
                <MudTd DataLabel="Party">@context.PartyName</MudTd>
                <MudTd DataLabel="">
                   
                      <MudFab @onclick="@(()=> View(context))" Color="Color.Success" Icon="@Icons.Material.Filled.GridView" title="View" Size="Size.Small" IconSize="Size.Small" />
                                          


                    </MudTd>
            </RowTemplate>
            <PagerContent>
                <MudTablePager PageSizeOptions="new int[] { 5, 10, 20, 50, 100 }" />
            </PagerContent>
        </MudTable>
    </MudItem>
    </MudGrid>
        </MudContainer>
        </DialogContent>
        </MudDialog>




@code {
    [Parameter]
    public PurchaseOrderModel model { get; set; }

    private List<PurchaseOrderModel> collection = new List<PurchaseOrderModel>();
    DialogOptions maxWidth = new DialogOptions() { MaxWidth = MaxWidth.Medium, FullWidth = true };
    private string searchPurchase = "";


    protected override async Task OnInitializedAsync()
    {
        model = new();
        await GetAll();
    }
    private  async Task GetAll()
    {
        var authprov = await auth.GetAuthenticationStateAsync();
        var brancIDString = authprov.User.Claims.First(x => x.Type == "BranchID").Value;
        int brancID = int.Parse(brancIDString);
        collection = new List<PurchaseOrderModel>();
        foreach (var item in Iservice.PendingForGrn(brancID))
        {

            collection.Add(item);
        }


    }
    public void View(PurchaseOrderModel pm)
    {
        DialogParameters parms = new DialogParameters();
        parms.Add("model",pm);
        var dialog =  DialogService.Show<PurchaseOrderDialog>(pm.POID == null?"ADD":"EDIT",parms,maxWidth);
        
    }
    private bool search(PurchaseOrderModel tds)
    {
        if (tds.PONo != null && tds.PONo.Contains(searchPurchase, StringComparison.OrdinalIgnoreCase))
        {
            return true;
        }
        else if (tds.PONo == null)
            return true;
        return false;
    }
}
