@using Views.Pages.Finance.Transactions
@using System.Threading;
@inject IPurchaseOrderService Iservice
@inject IPartyService partyIservice
@inject IGstUsageIDService testIservice
@inject IInventoryItemService itemIservice
@inject IStoreService storeIservice
@inject IGstItemService gstIservice
@inject MudBlazor.ISnackbar snackbar
@inject AuthenticationStateProvider auth
@inject IRoleService<RoleModel> Irole
@attribute [Authorize]
@inject IDialogService DialogService

<DialogForm @ref="@dialogForm" ReadOnly="@ReadOnly" Title="Procurement Order Dossier" Subtitle="Authorize official acquisition cycles for inventory assets." Icon="@Icons.Material.Filled.ShoppingBag" AdminStyle="true" formID="formtdsRate" model="@model" _busy="_busy">
    <FormContent>
        <div class="dialog-content-wrapper">
            <EditForm id="formtdsRate" Model="@model" OnValidSubmit="OnValidSubmit">
                <ObjectGraphDataAnnotationsValidator />
                
                <div class="admin-glass-card pa-6 mb-6">
                    <div class="d-flex align-center mb-6">
                        <MudIcon Icon="@Icons.Material.Filled.Info" Color="Color.Primary" Class="mr-2" />
                        <span class="admin-section-label mb-0">General Information</span>
                    </div>
                    <MudGrid Spacing="3">
                        <MudItem xs="12">
                            <PartySelector ReadOnly="ReadOnly" Value="partyinfo" ValueChanged="PartyChanged" NatureOfBusiness="Supplier" BranchID="branchID" IncludeSisterConcern Class="admin-input-group"></PartySelector>
                        </MudItem>
                        <MudItem xs="12" md="4">
                            <MudDatePicker ReadOnly="ReadOnly" Label="Entry Date" Variant="Variant.Outlined" Margin="Margin.Dense" DisableToolbar="true" Editable="true" @bind-Date="model.EntryDate" DateFormat="dd/MM/yyyy" Class="admin-input-group" />
                        </MudItem>
                        <MudItem xs="12" md="4">
                            <MudTextField ReadOnly="ReadOnly" @bind-Value="model.Reference" Label="Reference" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.Reference)" Class="admin-input-group"></MudTextField>
                        </MudItem>
                        <MudItem xs="12" md="4">
                            <StoreSelector IsDisabled="ReadOnly" @bind-Value="model.Store" VariantParameter="Variant.Outlined" MarginParameter="Margin.Dense" BranchID="@branchID" Class="admin-input-group"></StoreSelector>
                        </MudItem>
                        <MudItem xs="12">
                            <MudTextField ReadOnly="ReadOnly" @bind-Value="model.Remarks" Lines="2" Label="Remarks / Description" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.Remarks)" Class="admin-input-group"></MudTextField>
                        </MudItem>
                    </MudGrid>
                </div>

                <div class="admin-glass-card pa-0 overflow-hidden mb-6">
                    <div class="px-6 py-4 border-bottom-subtle d-flex align-center" style="background: rgba(54, 117, 136, 0.03); border-bottom: 1px solid rgba(54, 117, 136, 0.2);">
                        <MudIcon Icon="@Icons.Material.Filled.Inventory2" Color="Color.Primary" Class="mr-2" />
                        <span class="admin-section-label mb-0">Inventory Procurement Items</span>
                    </div>
                    <div class="modern-admin-table">
                        <MudSimpleTable Style="width:100%" Hover="true" FixedHeader="true" Dense="true" Elevation="0">
                            <thead>
                                <tr style="background: rgba(0,0,0,0.02)">
                                    <th style="width: 40%; padding: 12px 24px">SPECIFICATION DETAILS</th>
                                    <th style="padding: 12px 24px">QUANTITY</th>
                                    <th style="padding: 12px 24px">UNIT RATE</th>
                                    <th style="padding: 12px 24px">TAX (GST)</th>
                                    <th style="width: 60px"></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in model.Entries)
                                {
                                    var itemInfo = itm.FirstOrDefault(x => x.InventoryItemID == item.ItemID);
                                    <tr>
                                        <td style="padding: 12px 24px">
                                            <div class="d-flex flex-column">
                                                <MudText Typo="Typo.body2" Class="fw-bold" Color="Color.Primary">@itemInfo?.InventoryItemCode</MudText>
                                                <MudText Typo="Typo.caption" Style="color: #666">@itemInfo?.ItemDescription</MudText>
                                                <MudText Typo="Typo.caption" Class="mud-text-secondary">PN: @(string.IsNullOrEmpty(itemInfo?.PartNumber) ? "N/A" : itemInfo?.PartNumber)</MudText>
                                            </div>
                                        </td>
                                        <td style="padding: 12px 24px">
                                            <div class="d-flex align-center">
                                                <MudText Typo="Typo.body1"><b>@item.ItemQty</b></MudText>
                                                <MudChip T="string" Size="Size.Small" Variant="Variant.Text" Color="Color.Info" Class="ml-2">@item.UOM</MudChip>
                                            </div>
                                        </td>
                                        <td style="padding: 12px 24px">
                                            <MudText Typo="Typo.body2">@(item.ItemRate?.ToString("N2"))</MudText>
                                        </td>
                                        <td style="padding: 12px 24px">
                                            <MudText Typo="Typo.body2" Color="Color.Warning">@(item.ItemGstVal?.ToString("N2"))</MudText>
                                        </td>
                                        <td style="padding: 12px 24px">
                                            @if (!ReadOnly)
                                            {
                                                <MudIconButton Icon="@Icons.Material.Filled.RemoveCircleOutline" Color="Color.Error" Size="Size.Small" OnClick="@(()=> Delete(@item))" Style="background: rgba(244, 67, 54, 0.05)" />
                                            }
                                        </td>
                                    </tr>
                                }
                                @if (!ReadOnly)
                                {
                                    <tr style="background: rgba(54, 117, 136, 0.04);">
                                        <td style="padding: 16px 24px">
                                            <InventoryItemSelector Value="SelectedItem" ValueChanged="@((InventoryItemModel newValue) => ItemChanged(newValue))" Class="modern-input" />
                                        </td>
                                        <td style="padding: 16px 24px">
                                            <div class="d-flex align-center">
                                                <MudNumericField @bind-Value="Entrymodel.ItemQty" Variant="Variant.Outlined" Margin="Margin.Dense" Class="modern-input" Style="max-width: 100px; background: white;" HideSpinButtons />
                                                @if (!string.IsNullOrEmpty(UOM)) { <MudChip T="string" Size="Size.Small" Color="Color.Info" Class="ml-2">@UOM</MudChip> }
                                            </div>
                                        </td>
                                        <td style="padding: 16px 24px">
                                            <MudNumericField @bind-Value="Entrymodel.ItemRate" Variant="Variant.Outlined" Margin="Margin.Dense" Class="modern-input" Style="max-width: 100px; background: white;" HideSpinButtons />
                                        </td>
                                        <td style="padding: 16px 24px">
                                            <MudText Typo="Typo.caption" Color="Color.Secondary">Auto-Calc</MudText>
                                        </td>
                                        <td style="padding: 16px 24px">
                                            <MudIconButton Icon="@Icons.Material.Filled.Add" Color="Color.Primary" OnClick="AddItems" Style="background: rgba(54, 117, 136, 0.1)" />
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </MudSimpleTable>
                    </div>
                    <div class="px-8 py-6 d-flex justify-end align-center" style="background: rgba(54, 117, 136, 0.05); border-top: 1px solid rgba(54, 117, 136, 0.1);">
                        <MudText Typo="Typo.body1" Class="mr-4">Cumulative Valuation:</MudText>
                        <MudText Typo="Typo.h5" Style="color: var(--mud-palette-primary); font-weight: 800">@(model.TotalValue?.ToString("C", System.Globalization.CultureInfo.GetCultureInfo("en-IN")) ?? "₹0.00")</MudText>
                    </div>
                </div>
            </EditForm>
        </div>
    </FormContent>
    <VerificationStatus>
        @if ((ReadOnly) && (!IsView))
        {
            <AutherizationStatusComponent CreatedBy="@model.UserInfo" DocTypeID="17" DocDate="@DocDate" DocType="@DocType" DocNumber="@DocNumber" PageToRedirectLink="@PageToRedirectLink" DocumentID="model.POID" OnApprove="IsApproveData"></AutherizationStatusComponent>
        }
    </VerificationStatus>
</DialogForm>

@code {
    private DialogForm dialogForm;

    [Parameter]
    public PurchaseOrderModel model { get; set; }
    [Parameter]
    public bool ReadOnly { get; set; }
    [Parameter]
    public bool IsView { get; set; }
    private List<StoreModel> store = new();
    private List<InventoryItemModel> itm = new();
    public PartyModel partyinfo = new();
    private List<GstItemModel> gstitem = new();
    [Parameter]
    public string PageToRedirectLink { get; set; }
    public string DocNumber { get; set; }
    public DateTime? DocDate { get; set; }
    public string DocType { get; set; }
    private int branchID = 0;
    public InventoryItemModel SelectedItem = new();
    private InventoryItemEntryModel Entrymodel = new InventoryItemEntryModel();
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; }
    public string UOM { get; set; }

    private bool _busy;

    //protected bool Local;
    protected bool IsTaxable;

    public bool HasPermissionPurchaseOrderServiceApprove { get; set; } = false;
    public int DocTypeID = 17;

    protected override async Task OnInitializedAsync()
    {
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionPurchaseOrderServiceApprove = await Irole.HasClaim(DocTypeID.ToString(), "Approve", ctc.Token);

        var authprov = await auth.GetAuthenticationStateAsync();
        var brancIDString = authprov.User.Claims.First(x => x.Type == "BranchID").Value;
        branchID = int.Parse(brancIDString);
        store = storeIservice.SelectByBranch(branchID).ToList();
        if (store.Any(s => s.StoreID == model.StoreID))
        {
            model.Store = store.FirstOrDefault(s => s.StoreID == model.StoreID);
        }
        itm = itemIservice.SearchByDescription(string.Empty).ToList();
        if (model.POID != null)
        {
            model.Entries = Iservice.GetItemEntriesPO(model.POID.Value).ToList();
            partyinfo = partyIservice.SelectByID(model.PartyID);
            if (partyinfo != null)
            {
                IsTaxable = partyinfo.GstType == "Registered" || partyinfo.GstType == "SEZ";
            }
        }
        else
        {
            model.TotalValue = 0;
        }

        DocNumber = model.PONo;
        DocDate = model.EntryDate;
        DocType = "Purchase Order";
    }

    protected async Task IsApproveData(DataApprovedStatus aprvd)
    {
        if (HasPermissionPurchaseOrderServiceApprove)
        {
            if (aprvd.IsApprove)
            {
                try
                {
                    var authprov = await auth.GetAuthenticationStateAsync();
                    var user = authprov.User;
                    model.UserInfo.UserID = user.Identity.Name;
                    Iservice.Approve(model.POID.Value, model.UserInfo.UserID, string.Empty);
                    snackbar.Add("Approved Successfully", Severity.Success);
                }
                catch (Exception ex)
                {
                    snackbar.Add(ex.Message, Severity.Error);
                }
            }
        }
        else
        {
            bool? result = await DialogService.ShowMessageBoxAsync(
                "Permission denied!",
                "You don't have any permission to Approve PurchaseOrder.");
        }
    }

    private void Delete(InventoryItemEntryModel i)
    {
        int rowIndex = model.Entries.IndexOf(i);
        model.Entries.RemoveAt(rowIndex);
        SetTotal();
    }

    private async Task OnValidSubmit(EditContext context)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is being submitted!", Severity.Warning);
            return;
        }
        if (model.Entries == null || (model.Entries != null && model.Entries.Count() == 0))
        {
            snackbar.Add("Add at least one Entry before Submitting", Severity.Error);
            return;
        }
        if(partyinfo.PartyID == 0)
        {
            snackbar.Add("Please Select Party", Severity.Error);
            return;
        }
        else
        {
            _busy = true;
            model.PartyCode = partyinfo.PartyCode;
            model.PartyID = partyinfo.PartyID;
            model.PartyName = partyinfo.TradeName;
            model.StoreID = model.Store?.StoreID ?? null;
            MudDialog.Close(model);
        }
        await Task.Delay(200);
        _busy = false;
    }

    private void Cancel()
    {
        MudDialog.Cancel();
    }

    public decimal getgstrate(int itemID)
    {
        var itemGst = gstIservice.SelectByItem(itemID, (model.EntryDate ?? DateTime.Today));
        decimal? gstrate = itemGst.TaxRate;
        return gstrate ?? 0;
    }


    void PartyChanged(PartyModel party)
    {
        partyinfo = party;
        model.PartyID = party.PartyID;
        model.PartyCode = party.PartyCode;
        model.PartyName = party.TradeName;
        
        if (partyinfo != null)
        {
            IsTaxable = partyinfo.GstType == "Registered" || partyinfo.GstType == "SEZ";
        }
    }


    private void AddItems()
    {
        if (Entrymodel.ItemID == null || Entrymodel.ItemRate == null || Entrymodel.ItemQty == null)
        {
            snackbar.Add("Please fill in all Fields", Severity.Error);
            return;
        }
        decimal gstrt = 0;
        Entrymodel.ItemGstVal = 0;
        try
        {
            if (Entrymodel.ItemID != null)
            {
                gstrt = getgstrate(Entrymodel.ItemID.Value);
            }
        }
        catch { }

        if (gstrt != 0 && IsTaxable)
        {
            Entrymodel.ItemGstVal = (((Entrymodel.ItemRate ?? 0m) * Entrymodel.ItemQty) * gstrt) / 100;
        }
        Entrymodel.UOM = UOM;
        model.Entries.Add(Entrymodel);
        Entrymodel = new();
        SelectedItem = new();

        SetTotal();
    }

    void SetTotal()
    {
        model.TotalValue = model.Entries.Sum(x => (x.ItemQty * (x.ItemRate ?? 0m)) + (x.ItemGstVal ?? 0m));
    }

    protected void ItemChanged(InventoryItemModel item)
    {
        SelectedItem = item;
        Entrymodel.ItemID = item?.InventoryItemID;
        UOM = item?.UoM;
    }
}

