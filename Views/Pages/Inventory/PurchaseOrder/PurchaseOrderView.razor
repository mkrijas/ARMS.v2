@page "/PurchaseOrder"
@page "/PurchaseOrder/{id:int}"
@using System.Threading;
@inject IPurchaseOrderService Iservice
@inject MudBlazor.ISnackbar snackbar
@inject AuthenticationStateProvider auth
@inject IRoleService<RoleModel> Irole
@attribute [Authorize]
@inject IDialogService DialogService
@inject SignalRService signalRService
@inject IPushNotificationService IpushNotificationService


@if (_isLoading)
{
    <div style="display: flex; justify-content: center; align-items: center; min-height: 400px;">
        <LoaderComponent IsFullScreen="true" 
                        ShowLogo="false" 
                        Size="medium" 
                        LoadingText="Loading Purchase Orders" 
                        SubText="Please wait..." />
    </div>
}


    <div class="admin-page-container fade-in" @key="@("content")">
        <div class="admin-header-tiered mb-6">
            <div class="d-flex align-center justify-space-between">
                <div>
                    <MudText Typo="Typo.h4" Class="admin-title">Purchase Orders (PO)</MudText>
                    <MudText Typo="Typo.body2" Class="admin-subtitle">Manage procurement authorizations and track supplier order commitments.</MudText>
                </div>
                <MudButton Disabled="@_busy" Variant="Variant.Filled" Color="Color.Primary" OnClick="@(()=> OpenDialog(new PurchaseOrderModel(),false,false))" Class="admin-register-btn" StartIcon="@Icons.Material.Filled.Add">NEW PURCHASE ORDER</MudButton>
            </div>
        </div>

        <div class="admin-glass-card pa-6 mb-6">
            <MudGrid Spacing="3" Class="align-center">
                <MudItem xs="12" md="6">
                <MudTextField @bind-Value="searchPurchase"
                              Immediate="true"
                              DebounceInterval="400"
                              Placeholder="Search by PO Number, Vendor or Reference..."
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Filled.Search"
                              Clearable="true"
                              Variant="Variant.Outlined"
                              Class="modern-input"
                              OnKeyUp="OnSearchKeyUp" />
                </MudItem>
                <MudItem xs="12" md="4">
                    <div class="d-flex align-center h-100 px-4 rounded-lg bg-light-surface border-subtle">
                        <MudCheckBox T="bool" Label="SHOW COMPLETED ORDERS" ValueChanged="((bool value)=>ApprovedChanged(value))" Value="@IsApproved" Color="Color.Primary" Dense="true" Class="fw-600" />
                    </div>
                </MudItem>
                <MudItem xs="12" md="2" Class="d-flex justify-end">
                    <div class="d-flex flex-column align-end">
                    <MudText Typo="Typo.caption" Class="admin-subtitle">TOTAL ORDERS: @(TotalRecords)</MudText>
                    </div>
                </MudItem>
            </MudGrid>
        </div>

        <div class="admin-glass-card overflow-hidden">
            <MudTable T="PurchaseOrderModel"
                  ServerData="LoadServerData"
                   RowClassFunc="TableRowClass"
                  Dense="true"
                  Hover="true"
                  Striped="true"
                  Elevation="10"
                  @ref="_table">
                  <HeaderContent>
                    <MudTh><MudTableSortLabel SortBy="new Func<PurchaseOrderModel, object>(x=> x.PONo)"><span class="admin-header-text">PO NO</span></MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<PurchaseOrderModel, object>(x=> x.EntryDate)" InitialDirection="SortDirection.Descending"><span class="admin-header-text">ORDER DATE</span></MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<PurchaseOrderModel, object>(x=> x.PartyName)"><span class="admin-header-text">SUPPLIER</span></MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<PurchaseOrderModel, object>(x=> x.Status)"><span class="admin-header-text">STATUS</span></MudTableSortLabel></MudTh>
                    <MudTh Style="text-align: right;"><span class="admin-header-text">ACTIONS</span></MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="PO No">
                        <span class="admin-td-primary fw-600">@context.PONo</span>
                    </MudTd>
                    <MudTd DataLabel="Date">
                        <div class="d-flex align-center opa-70">
                            <MudIcon Icon="@Icons.Material.Filled.Event" Size="Size.Small" Class="mr-1" />
                            <span>@context.EntryDate?.ToString("dd MMM yyyy")</span>
                        </div>
                    </MudTd>
                    <MudTd DataLabel="Supplier"><span class="fw-500">@context.PartyName</span></MudTd>
                    <MudTd DataLabel="Status">
                        <MudChip T="string" Size="Size.Small" Color="@(context.Status == "Cancelled" ? Color.Error : context.AuthLevelID == 99 ? Color.Success : Color.Primary)" Variant="Variant.Text" Class="fw-600">@context.Status</MudChip>
                    </MudTd>
                    <MudTd DataLabel="Actions" Style="text-align: right;">
                        <div class="d-flex justify-end gap-1">
                            <MudTooltip Text="View Details">
                                <MudIconButton OnClick="@(()=> OpenDialog(context,true,true))" Color="Color.Primary" Icon="@Icons.Material.Filled.GridView" Size="Size.Small" Variant="Variant.Text" />
                            </MudTooltip>
                            
                            @if (context.AuthLevelID == null)
                            {
                                <MudTooltip Text="Edit Draft">
                                    <MudIconButton OnClick="@(()=> OpenDialog(context,false,false))" Color="Color.Primary" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Variant="Variant.Text" />
                                </MudTooltip>
                                <MudTooltip Text="Delete Order">
                                    <MudIconButton OnClick="@(()=> Delete(context))" Color="Color.Error" Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Variant="Variant.Text" />
                                </MudTooltip>
                            }

                            @if (context.AuthLevelID != 99 && context.AuthLevelID != 100)
                            {
                                <MudTooltip Text="Verify Order">
                                    <MudIconButton OnClick="@(()=> OpenDialog(context,true,false))" Color="Color.Warning" Icon="@Icons.Material.Filled.VerifiedUser" Size="Size.Small" Variant="Variant.Text" />
                                </MudTooltip>
                            }
                        </div>
                    </MudTd>
                </RowTemplate>
                <PagerContent>
                    <div class="pa-4">
                        <MudTablePager PageSizeOptions="new int[] { 10, 20, 50, 100 }" />
                    </div>
                </PagerContent>
            </MudTable>
        </div>
    </div>



@code {

    private bool _isLoading = true;  

    private PurchaseOrderModel model = new PurchaseOrderModel();
    private List<PurchaseOrderModel> collection = new List<PurchaseOrderModel>();

    private string searchPurchase = "";
    private bool _busy;
    [Parameter]
    public int? id { get; set; } = null;
    private MudTable<PurchaseOrderModel> _table;
    bool HasPermissionPurchaseOrderServiceEdit { get; set; } = false;
    bool HasPermissionPurchaseOrderServiceDelete { get; set; } = false;
    int DocTypeID = 17;
    bool IsApproved { get; set; } = false;
    int? TotalRecords = 0;

    #region SignaIR Notification

    private PushNotificationModel notificationMessage = new PushNotificationModel();
    #endregion

    protected override async Task OnInitializedAsync()
    {      

        CancellationTokenSource ctc = new CancellationTokenSource();

        HasPermissionPurchaseOrderServiceEdit = await Irole.HasClaim(DocTypeID.ToString(), "Edit", ctc.Token);

        HasPermissionPurchaseOrderServiceDelete =  await Irole.HasClaim(DocTypeID.ToString(), "Delete", ctc.Token);        

        //await signalRService.StartAsync();       

        _isLoading = false;
    }

    private async Task<TableData<PurchaseOrderModel>> LoadServerData( TableState state, CancellationToken token)
    {
        var authprov = await auth.GetAuthenticationStateAsync();
        var branchID = int.Parse(authprov.User.Claims.First(x => x.Type == "BranchID").Value);

        var list = Iservice.SelectAll( branchID, state.Page, state.PageSize, searchPurchase,IsApproved);

        collection = list.Items;
        TotalRecords = list.TotalRecords;

        StateHasChanged();        

        return new TableData<PurchaseOrderModel>
        {
            Items = collection,
            TotalItems = list.TotalRecords??0
        };        
    }   

    async Task ApprovedChanged(bool value)
    {
        IsApproved = value;
        await _table.ReloadServerData();
    }  

    private async Task OpenDialog(PurchaseOrderModel tds, bool ReadOnly, bool View)
    {
        if (HasPermissionPurchaseOrderServiceEdit)
        {
            if (_busy)
            {
                snackbar.Add("Please wait while form is closing!", Severity.Warning);
                return;
            }
            _busy = true;
            DialogOptions maxWidth = new DialogOptions() { MaxWidth = MaxWidth.Large, FullWidth = true };
            var authprov = await auth.GetAuthenticationStateAsync();
            var user = authprov.User;
            DialogParameters parms = new DialogParameters();
            parms.Add("model", tds.Clone());
            parms.Add("PageToRedirectLink", "/PurchaseOrder");
            parms.Add("ReadOnly", ReadOnly);
            parms.Add("IsView", View);
            var dialog = await DialogService.ShowAsync<PurchaseOrderDialog>(tds.POID == null ? "ADD" : "EDIT", parms, maxWidth);
            var result = await dialog.Result;
            if (!result.Canceled)
            {
                PurchaseOrderModel UpatedModel = (PurchaseOrderModel)result.Data;
                try
                {
                    UpatedModel.UserInfo.UserID = user.Identity.Name;
                    var ReturnData = Iservice.Update(UpatedModel);

                    var brancIDString = authprov.User.Claims.First(x => x.Type == "BranchID").Value;
                    int brancID = int.Parse(brancIDString);

                    notificationMessage.InitiateBranch = new BranchModel() { BranchID = brancID };
                    notificationMessage.ReceivedBranch = new BranchModel() { BranchID = brancID };
                    notificationMessage.MessageTitle = IpushNotificationService.GetMessageTitle("Purchase Order", ReturnData.PONo, "Level 1 Verification");
                    notificationMessage.MessageBody = IpushNotificationService.GetMessageBody("Purchase Order", ReturnData.PONo, "Level 1 Verification", ReturnData.EntryDate);
                    notificationMessage.RedirectedTo = 0;
                    notificationMessage.ExpiredBy = 7;
                    notificationMessage.DocumentID = ReturnData.POID;
                    notificationMessage.MessageGroupID = "PendingVerification";
                    notificationMessage.PageToRedirectLink = "/PurchaseOrder";
                    notificationMessage.ClaimValue = "Verify 1";
                    notificationMessage.DocumentTypeID = DocTypeID;
                    notificationMessage.MsgDate = DateTime.Now;
                    await signalRService.Send(notificationMessage);
                    model = new();
                    snackbar.Add("Saved Successfully", Severity.Success);
                    model = new PurchaseOrderModel();
                }
                catch (Exception ex)
                {
                    snackbar.Add(ex.Message, Severity.Warning);
                }
            }
            await _table.ReloadServerData();
            await Task.Delay(200);
            _busy = false;
        }
        else
        {
            bool? result = await DialogService.ShowMessageBoxAsync(
                "Permission denied!",
                "You don't have any permission to Edit PurchaseOrder.");
        }
    }

    private async Task Delete(PurchaseOrderModel tds)
    {
        if (HasPermissionPurchaseOrderServiceDelete)
        {
            bool? result = await DialogService.ShowMessageBoxAsync(
                "Warning !",
                "Are you sure, you want to delete - " + model.PONo + " ?");
            if (result == true)
            {
                var authprov = await auth.GetAuthenticationStateAsync();
                var user = authprov.User;
                Iservice.Delete(tds.POID, user.Identity.Name);
                snackbar.Add("Deleted Successfully", Severity.Success);
                await _table.ReloadServerData();
            }
        }
        else
        {
            bool? result = await DialogService.ShowMessageBoxAsync(
                "Permission denied!",
                "You don't have any permission to delete PurchaseOrder.");
        }
    }

  

    private async Task OnSearchKeyUp(KeyboardEventArgs args)
    {
        await _table.ReloadServerData();
    }

    private string TableRowClass(PurchaseOrderModel PO, int index)
    {
        if (PO.UserInfo.RecordStatus == 9)
        {
            return "bg-error-light";
        }
        if (PO.AuthLevelID == 99)
        {
            return "bg-primary-light";
        }
        return string.Empty;
    }
}

