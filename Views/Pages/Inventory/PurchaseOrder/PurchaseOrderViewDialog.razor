@using Inventory.GoodsReceipt
@attribute [Authorize]
@inject AuthenticationStateProvider auth
@inject IPurchaseOrderService Iservice
@inject MudBlazor.ISnackbar snackbar
@inject IDialogService DialogService

<MudDialog>
    <DialogContent>
        <MudGrid Spacing="4">
            <MudItem xs="12">
                <MudTable Items="@collection" Dense="true" Hover="true" Striped="true" Elevation="0" @bind-place="model">
                    <HeaderContent>
                        <MudTh><MudTableSortLabel SortBy="new Func<PurchaseOrderModel, object>(x=> x.PONo)" InitialDirection="SortDirection.Ascending">PO No</MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<PurchaseOrderModel, object>(x=> x.EntryDate)" InitialDirection="SortDirection.Ascending">Entry Date</MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<PurchaseOrderModel, object>(x=> x.PartyName)" InitialDirection="SortDirection.Ascending">Party</MudTableSortLabel></MudTh>
                        <MudTh>Actions</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="PONo">@context.PONo</MudTd>
                        <MudTd DataLabel="EntryDate">@context.EntryDate</MudTd>
                        <MudTd DataLabel="Party">@context.PartyName</MudTd>
                        <MudTd DataLabel="">
                            <MudTooltip Text="View">
                                <MudFab @onclick="@(()=> OpenDialog(context))" Color="Color.Primary" Icon="@Icons.Material.Filled.Preview" Size="Size.Small" IconSize="Size.Small" />
                            </MudTooltip><MudTooltip Text="Conver to Grn">
                                <MudFab @onclick="@(()=> Add(context))" Color="Color.Success" Icon="@Icons.Material.Filled.ArrowForward" Size="Size.Small" IconSize="Size.Small" />
                            </MudTooltip>
                        </MudTd>
                    </RowTemplate>
                    <FooterContent>

                    </FooterContent>
                    @*<PagerContent>
                        <MudTablePager PageSizeOptions="new int[] { 5, 10, 20, 50, 100 }" />
                    </PagerContent>*@
                </MudTable>
            </MudItem>
        </MudGrid>
    </DialogContent>
</MudDialog>

    @code {

    private PurchaseOrderModel model = new PurchaseOrderModel();
    private List<PurchaseOrderModel> collection = new List<PurchaseOrderModel>();
    DialogOptions maxWidth = new DialogOptions() { MaxWidth = MaxWidth.Medium, FullWidth = true };
    [CascadingParameter] MudDialogInstance MudDialog { get; set; }
    private string searchPurchase = "";
    private bool _busy;
    int? BranchID;

    protected override async Task OnInitializedAsync()
    {
        model = new();
        var authprov = await auth.GetAuthenticationStateAsync();
        var brancIDString = authprov.User.Claims.First(x => x.Type == "BranchID").Value;
        BranchID = int.Parse(brancIDString);
        GetAll();
    }

    private void GetAll()
    {
       
        collection = new List<PurchaseOrderModel>();
        foreach (var item in Iservice.PendingForGrn(BranchID.Value))
        {
            collection.Add(item);
        }
    }

    private async Task OpenDialog(PurchaseOrderModel tds)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        _busy = true;
        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;

        DialogParameters parms = new DialogParameters();
        parms.Add("model", tds.Clone());
        parms.Add("ReadOnly", true);
        parms.Add("IsView", true);
        var dialog = DialogService.Show<PurchaseOrderDialog>("Purchase Order", parms, maxWidth);
        var result = await dialog.Result;
        if (!result.Canceled)
        {
            GetAll();
        }
        GetAll();
        await Task.Delay(200);
        _busy = false;
    }
    List<InventoryItemEntryModel> PoItems = new();


    private async Task Add(PurchaseOrderModel po)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        _busy = true;
        po.Entries = Iservice.GetItemEntries(po.POID.Value).ToList();
        po.Entries.ForEach(x => PoItems.Add(x));

        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;
        InventoryGrnModel grn = new();
        grn.POID = po.POID;
        grn.EntryDate = po.EntryDate;
        grn.PartyID = po.PartyID;
        grn.TotalValue = po.TotalValue;
        grn.Reference = po.Reference;
        grn.Remarks = po.Remarks;
        grn.StoreID = po.StoreID;
        grn.Entries = po.Entries.Select(x => { x.RefID = x.ItemEntryID; x.ItemEntryID = null; return x; }).ToList();
        DialogParameters parms = new DialogParameters();
        DialogOptions maxWidth = new DialogOptions() { MaxWidth = MaxWidth.Large, FullWidth = true };
        parms.Add("model", grn.Clone());
        var dialog = DialogService.Show<InventoryGrnDialog>(grn.GrnID == null ? "ADD" : "EDIT", parms, maxWidth);
        var result = await dialog.Result;
        if (!result.Canceled)
        {
            GetAll();
        }
        GetAll();
        await Task.Delay(200);
        _busy = false;
    }
}