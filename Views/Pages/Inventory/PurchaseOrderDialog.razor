@code {
    [Parameter]
    public PurchaseOrderModel model { get; set; }
    private List<PurchaseOrderModel> collection = new List<PurchaseOrderModel>();
    DialogOptions maxWidth = new DialogOptions() { MaxWidth = MaxWidth.Medium, FullWidth = true };

    private List<GstRateModel> gstRate = new();
    private List<PartyModel> partyList = new();
    private List<StoreModel> store = new();
    private List<InventoryItemModel> itm = new();
    public static int edit = 0;
    private List<PartyBranchModel> partybranch = new();
    private PurchaseOrderModel tds = new();
    private InventoryItemEntryModel Entrymodel = new InventoryItemEntryModel();
    private List<InventoryItemEntryModel> items = new List<InventoryItemEntryModel>();

    [CascadingParameter] MudDialogInstance MudDialog { get; set; }


    private PartyModel SelectedParty = new();

    private async Task<IEnumerable<PartyModel>> SearchParty(string searchString)
    {
        return await Task.FromResult(partyList.Where(x => x.PartyName.Contains(searchString == null ? string.Empty : searchString, StringComparison.InvariantCultureIgnoreCase)));
    }
    private async Task<IEnumerable<InventoryItemModel>> SearchItems(string searchString)
    {
        return await Task.FromResult(itm.Where(x => x.InventoryItemCode.Contains(searchString == null ? string.Empty : searchString, StringComparison.InvariantCultureIgnoreCase)));
    }
    protected override async void OnInitialized()
    {
        gstRate = testIservice.GetGstRates().ToList();
        store = storeIservice.Select().ToList();
        itm = itemIservice.SearchByDescription(string.Empty).ToList();
        if(model.POID!=null)
        {
            items = Iservice.GetItemEntries(model.POID.Value).ToList();
        }


        await foreach (var party in partyIservice.Select(0))
        {
            partyList.Add(party);
        }
        PartyBranchModel selectedPBranch = partyBranchIservice.Select(model.PartyBranchID).FirstOrDefault();
        SelectedParty = await partyIservice.SelectByID(selectedPBranch.PartyID);
        partybranch = partyBranchIservice.SelectByParty(SelectedParty.PartyID).ToList();


        // asseesse = Iservice.SelectAssesseeTypes().ToList();
    }



    private void OnValidSubmit(EditContext context)
    {  


        model.Entries=items;  

        MudDialog.Close(model);

    }

    private void Cancel()
    {
        MudDialog.Cancel();
    }
    private void Delete(InventoryItemEntryModel i)
    {
        int rowIndex=items.IndexOf(i);
        items.RemoveAt(rowIndex);
    }
    private void AddItems()
    {

        InventoryItemEntryModel ientry= new();
        ientry.ItemID=Entrymodel.ItemID;
        ientry.ItemQty=Entrymodel.ItemQty;
        ientry.ItemRate=Entrymodel.ItemRate;
        ientry.ItemGstVal=Entrymodel.ItemGstVal;
        items.Add(ientry);

        decimal qty=(Entrymodel.ItemQty.Value)*(Entrymodel.ItemRate.Value);
        Entrymodel = new();

    }

    private void getBranch(PartyModel party)
    {
        // int values = int.Parse(e.Value.ToString());
        //SelectedParty = party;
        if(party!=null)
        {
            partybranch = partyBranchIservice.SelectByParty(party.PartyID).ToList();
        }
        else
        {
            partybranch = new();
        }
        // snackbar.Add("Saved Successfully", Severity.Success); 
    }
    private void getitemCode(InventoryItemModel item)
    {
        
        if(item!=null)
        {
            Entrymodel.ItemID = item.InventoryItemID;
        }
        else
        {
            Entrymodel.ItemID = null;
        }
       
    }

}
