@inject IPurchaseOrderService Iservice
@inject IGstUsageIDService testIservice
@inject IPartyService partyIservice
@inject IInventoryItemService itemIservice
@inject IPartyBranchService partyBranchIservice
@inject IStoreService storeIservice
@inject MudBlazor.ISnackbar snackbar
@inject AuthenticationStateProvider auth
@attribute [Authorize]
@inject IDialogService DialogService



<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.Build" Class="mr-3 mb-n1" />
            Create Purchase Order
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudContainer Style="min-height:300px;max-height: 800px;">
            <EditForm  id="formtdsRate" Model="@model" OnValidSubmit="OnValidSubmit">
                <ObjectGraphDataAnnotationsValidator />
                <ValidationSummary />
                <MudGrid Spacing="2">
                    
                 
                    <MudItem xs="12"md="4">

                        <MudSelect Label="Select Quotation" @bind-Value="model.QuoteID" T="int?"  Variant="Variant.Outlined" Margin="Margin.Dense" OffsetY="true" Direction="Direction.Top" AdornmentColor="Color.Secondary">
                            @foreach (var ditem in gstRate)
                            {
                                <MudSelectItem Value="@ditem.RID">@ditem.TaxRate</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                   
                    <MudItem xs="12" md="4">
                     <MudSelect Label="Select Vendor"   T="int?"  ValueChanged="getBranch"  Variant="Variant.Outlined" Margin="Margin.Dense" OffsetY="true" Direction="Direction.Top" AdornmentColor="Color.Secondary">
                            @foreach (var ditem in partyList)
                            {
                                <MudSelectItem Value="@ditem.PartyID">@ditem.PartyName</MudSelectItem>
                            }
                        </MudSelect>    
                    </MudItem>
                     <MudItem xs="12" md="4">
                     <MudSelect Label="Select Branch" @bind-Value="model.PartyBranchID" T="int?"  Variant="Variant.Outlined" Margin="Margin.Dense" OffsetY="true" Direction="Direction.Top" AdornmentColor="Color.Secondary">
                            @foreach (var ditem in partybranch)
                            {
                                <MudSelectItem Value="@ditem">@ditem.Party</MudSelectItem>
                            }
                        </MudSelect>    
                    </MudItem>
                       
                    <MudItem xs="12" md="4">
                        <MudDatePicker Label="Entry Date" Variant="Variant.Outlined" Margin="Margin.Dense" DisableToolbar="true" Editable="true" @bind-Date="model.EntryDate"  DateFormat="dd/MM/yyyy" />
                    </MudItem>
                    <MudItem xs="12" md="4">
                         <MudTextField @bind-Value="model.Reference" Label="Reference" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.Reference)"></MudTextField>

                    </MudItem>
                    <MudItem xs="12" md="4">
                         <MudTextField @bind-Value="model.Remarks" Label="Remarks" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.Remarks)"></MudTextField>

                    </MudItem>
                     <MudItem xs="12" md="12">
                     <MudSelect Label="Select Store" @bind-Value="model.StoreID" T="int?"  Variant="Variant.Outlined" Margin="Margin.Dense" OffsetY="true" Direction="Direction.Top" AdornmentColor="Color.Secondary">
                            @foreach (var ditem in store)
                            {
                                <MudSelectItem Value="@ditem.StoreID">@ditem.StoreName</MudSelectItem>
                            }
                        </MudSelect>    
                    </MudItem>
                    <MudItem xs="12" md="12">

          <MudTable Items="@items"  Dense="true" Hover="true"  Striped="true" Elevation="10" @bind-place="Entrymodel">
           

             
            <HeaderContent>
                <MudTh><MudTableSortLabel SortBy="new Func<InventoryItemEntryModel, object>(x=> x.ItemID)" InitialDirection="SortDirection.Ascending">Item</MudTableSortLabel></MudTh>
             <MudTh><MudTableSortLabel SortBy="new Func<InventoryItemEntryModel, object>(x=> x.ItemQty)" InitialDirection="SortDirection.Ascending">Quantity</MudTableSortLabel></MudTh>
               <MudTh><MudTableSortLabel SortBy="new Func<InventoryItemEntryModel, object>(x=> x.ItemRate)" InitialDirection="SortDirection.Ascending">Rate</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<InventoryItemEntryModel, object>(x=> x.ItemGstVal)" InitialDirection="SortDirection.Ascending">GST</MudTableSortLabel></MudTh>
                
                <MudTh>Actions</MudTh>
            </HeaderContent>
            <RowTemplate Context="entryContext">
                <MudTd DataLabel="Item">@entryContext.ItemID</MudTd>
                <MudTd DataLabel="Quantity">@entryContext.ItemQty</MudTd>
                <MudTd DataLabel="Rate">@entryContext.ItemRate</MudTd>
                 <MudTd DataLabel="GST">@entryContext.ItemGstVal</MudTd>
                 <MudTd><MudFab @onclick="@(()=> Delete(entryContext))" Color="Color.Error" Icon="@Icons.Material.Filled.Delete" Size="Size.Small" IconSize="Size.Small" /></MudTd>
                 
               
            </RowTemplate>
            <PagerContent>
                <MudTablePager PageSizeOptions="new int[] { 5, 10, 20, 50, 100 }" />
            </PagerContent>
        </MudTable>


                        </MudItem>
                         <MudItem xs="12" md="3">
                           <MudSelect Label="Select Items" @bind-Value="Entrymodel.ItemID" T="int?"  Variant="Variant.Outlined" Margin="Margin.Dense" OffsetY="true" Direction="Direction.Top" AdornmentColor="Color.Secondary">
                            @foreach (var ditem in itm)
                            {
                                <MudSelectItem Value="@ditem.InventoryItemID">@ditem.InventoryItemCode</MudSelectItem>
                            }
                        </MudSelect>
                          </MudItem>
                          <MudItem xs="12" md="3">
                         <MudTextField @bind-Value="Entrymodel.ItemQty" Label="Quatity" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => Entrymodel.ItemQty)"></MudTextField>

                              </MudItem>
                          <MudItem xs="12" md="3">
                         <MudTextField @bind-Value="Entrymodel.ItemRate" Label="Rate" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => Entrymodel.ItemRate)"></MudTextField>

                              </MudItem>

                            <MudItem xs="12" md="2">
                         <MudTextField @bind-Value="Entrymodel.ItemGstVal" Label="GST" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => Entrymodel.ItemGstVal)"></MudTextField>
                        </MudItem>
                         <MudItem xs="12" md="1">
                         <MudButton OnClick="AddItems" Variant="Variant.Filled" Color="Color.Primary">Add</MudButton>
                              </MudItem>

                </MudGrid>
            </EditForm>
        </MudContainer>
    </DialogContent>
    <DialogActions>
        @*   <MudButton OnClick="DeleteTaxRate">Delete Tax Rate</MudButton>
            <MudButton OnClick="AddTaxRate">Add More Tax Rate</MudButton>*@
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton OnClick="ItemEntry">Item Entry</MudButton>
        <MudButton form="formtdsRate" Variant="Variant.Filled" Color="Color.Success" ButtonType="ButtonType.Submit">Submit</MudButton>

    </DialogActions>
</MudDialog>



@code {
    [Parameter]
    public PurchaseOrderModel model { get; set; }
    private List<PurchaseOrderModel> collection = new List<PurchaseOrderModel>();
    DialogOptions maxWidth = new DialogOptions() { MaxWidth = MaxWidth.Medium, FullWidth = true };

    private List<GstRateModel> gstRate = new();
    private List<PartyModel> partyList = new();
    private List<StoreModel> store = new();
    private List<InventoryItemModel> itm = new();
    public static int edit = 0;
    private List<PartyBranchModel> partybranch = new();
    private PurchaseOrderModel tds = new();
    private InventoryItemEntryModel Entrymodel = new InventoryItemEntryModel();
    private List<InventoryItemEntryModel> items = new List<InventoryItemEntryModel>();

    [CascadingParameter] MudDialogInstance MudDialog { get; set; }



    protected override async void OnInitialized()
    {


        await foreach (var party in partyIservice.Select(0))
        {
            partyList.Add(party);
        }


        gstRate = testIservice.GetGstRates().ToList();
        store = storeIservice.Select().ToList();
        itm = itemIservice.SearchByDescription(string.Empty).ToList();

        // asseesse = Iservice.SelectAssesseeTypes().ToList();
    }



    private void OnValidSubmit(EditContext context)
    {  
        

        model.Entries=items;  

        MudDialog.Close(model);
        
    }

    private void Cancel()
    {
        MudDialog.Cancel();
    }
    private void Delete(InventoryItemEntryModel i)
    {
        int rowIndex=items.IndexOf(i);
        items.RemoveAt(rowIndex);
    }
    private void AddItems()
    {
        InventoryItemEntryModel ientry= new();
        ientry.ItemID=Entrymodel.ItemID;
        ientry.ItemQty=Entrymodel.ItemQty;
        ientry.ItemRate=Entrymodel.ItemRate;
        ientry.ItemGstVal=Entrymodel.ItemGstVal;
        items.Add(ientry);
        Entrymodel = new();

    }
     private void ItemEntry()
    {
       

      // DialogService.Show<PurchaseOrderItems>("options",maxWidth);
      
    }
    private void getBranch(int? id)
    {
       // int values = int.Parse(e.Value.ToString());
        partybranch = partyBranchIservice.SelectByParty(id).ToList();
        // snackbar.Add("Saved Successfully", Severity.Success); 
    }

}
