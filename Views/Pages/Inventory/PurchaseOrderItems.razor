 
@inject MudBlazor.ISnackbar snackbar
@inject AuthenticationStateProvider auth
@attribute [Authorize]
@inject IDialogService DialogService


<MudItem xs="12" md="12">
        <MudTable Items="@collection" @ref="_table" Elevation="10"  @bind-model="model">
            <ToolBarContent>
                <MudText Typo="Typo.h6">Purchase Items</MudText>
                <MudSpacer></MudSpacer>
               
            </ToolBarContent>
            <HeaderContent>
               
                <MudTh>Item</MudTh>
                 <MudTh>Quantity</MudTh>
                  <MudTh>Rate</MudTh>
                   <MudTh>Gst Value</MudTh>
                <MudTh>Actions</MudTh>
            </HeaderContent>
            <RowTemplate>
              

               <MudTd><MudTextField   Variant="Variant.Outlined" Margin="Margin.Normal" For="@(() => model.ItemID)"></MudTextField></MudTd>
               <MudTd><MudTextField  Variant="Variant.Outlined" Margin="Margin.Normal" For="@(() => model.ItemQty)"></MudTextField></MudTd>
               <MudTd><MudTextField   Variant="Variant.Outlined" Margin="Margin.Normal" For="@(() => model.ItemRate)"></MudTextField></MudTd>
               <MudTd><MudTextField  Variant="Variant.Outlined" Margin="Margin.Normal" For="@(() => model.ItemGstVal)"></MudTextField></MudTd>

                <MudTd DataLabel=""> </MudTd>
                @*  <MudButton OnClick="AddRow" Color="Color.Secondary" Variant="Variant.Filled" Style="position: absolute; left: 10px;">Add row</MudButton>   *@
                  <MudFab @onclick="@(()=> AddRow(context))" Color="Color.Primary" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" IconSize="Size.Small" />
                 @* <MudFab @onclick="@(()=> OpenDialog(context))" Color="Color.Primary" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" IconSize="Size.Small" />
                    <MudFab @onclick="@(()=> Delete(context.GstID))" Color="Color.Primary" Icon="@Icons.Material.Filled.Delete" Size="Size.Small" IconSize="Size.Small" />
              *@  
            
            </RowTemplate>
            <PagerContent>
                <MudTablePager PageSizeOptions="new int[] { 5, 10, 20, 50, 100 }" />
            </PagerContent>
        </MudTable>
    </MudItem>

