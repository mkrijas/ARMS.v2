@page "/PurchaseOrder"
@inject IPurchaseOrderService Iservice
@inject MudBlazor.ISnackbar snackbar

@inject AuthenticationStateProvider auth
@attribute [Authorize]
@inject IDialogService DialogService

<MudGrid Spacing="4">
   <MudItem xs="12">
        <MudTable Items="@collection" RowStyleFunc="TableRowStyle"  Dense="true" Hover="true"  Striped="true" Elevation="10" Filter="new Func<PurchaseOrderModel, bool>(search)" @bind-place="model">           
             <ToolBarContent>
                <MudText Typo="Typo.h6">Purchase Order</MudText>

                <MudIconButton Icon="@Icons.Material.Filled.Add" Title="Add" @onclick="@(()=> OpenDialog(model,false,false))"  Color="Color.Dark" Size="Size.Small"></MudIconButton>
                @* <MudIconButton Icon="@Icons.Material.Filled.TableView" Title="Approved Data" @onclick="@(()=> OpenDialogApproved(model))"  Color="Color.Dark" Size="Size.Small"></MudIconButton>
*@
                <MudSpacer></MudSpacer>
                <MudTextField @bind-Value="searchPurchase" Placeholder="Search Purchase order... "
                              Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                              IconSize="Size.Medium" Class="mt-0"></MudTextField>
               <MudCheckBox Label="Approved Entries"  CheckedChanged="((bool value)=>ApprovedChanged(value))" Checked="@IsApproved" Size="Size.Medium" Color="Color.Primary"></MudCheckBox>
           
                          </ToolBarContent>
            <HeaderContent>
                <MudTh><MudTableSortLabel SortBy="new Func<PurchaseOrderModel, object>(x=> x.PONo)" InitialDirection="SortDirection.Ascending">PONo</MudTableSortLabel></MudTh>
             <MudTh><MudTableSortLabel SortBy="new Func<PurchaseOrderModel, object>(x=> x.EntryDate)" InitialDirection="SortDirection.Ascending">EntryDate</MudTableSortLabel></MudTh>
               <MudTh><MudTableSortLabel SortBy="new Func<PurchaseOrderModel, object>(x=> x.PartyName)" InitialDirection="SortDirection.Ascending">Party</MudTableSortLabel></MudTh>
               
                <MudTh>Actions</MudTh>
            </HeaderContent>

            <RowTemplate>   
                <MudTd DataLabel="PONo">@context.PONo</MudTd>
                <MudTd DataLabel="EntryDate"  >@context.EntryDate?.ToShortDateString()</MudTd>
                <MudTd DataLabel="Party">@context.PartyName</MudTd>
                <MudTd DataLabel="">
                   
                     @if(@context.AuthLevelID==null)
                    {
                      <MudFab @onclick="@(()=> OpenDialog(context,false,false))" Color="Color.Primary" Icon="@Icons.Material.Filled.Edit" title="Edit" Size="Size.Small" IconSize="Size.Small" />
                     <MudFab @onclick="@(()=> Delete(context))" Color="Color.Error" Icon="@Icons.Material.Filled.Delete" title="Delete" Size="Size.Small" IconSize="Size.Small" />
                  
                    }
                    @if (@context.AuthLevelID!= 99)
                    {
                    <MudFab @onclick="@(()=> OpenDialog(context,true,false))" Color="Color.Warning" Icon="@Icons.Material.Filled.Verified" title="Verify" Size="Size.Small" IconSize="Size.Small" />
                        
                    }
                    <MudFab @onclick="@(()=> OpenDialog(context,true,true))" Color="Color.Info" Icon="@Icons.Material.Filled.GridView" title="View" Size="Size.Small" IconSize="Size.Small" />
                   


                    </MudTd>
            </RowTemplate>
            <PagerContent>
                <MudTablePager PageSizeOptions="new int[] { 5, 10, 20, 50, 100 }" />
            </PagerContent>
        </MudTable>
    </MudItem>
    </MudGrid>



@code {


    private PurchaseOrderModel model = new PurchaseOrderModel();
    private List<PurchaseOrderModel> collection = new List<PurchaseOrderModel>();
     public bool IsApproved { get; set; } = false;

    private string searchPurchase = "";

    protected override async Task OnInitializedAsync()
    {
        model = new();
        await GetAll(IsApproved); 
    }
    async Task ApprovedChanged(bool value)
    {

        IsApproved = value;
        await GetAll(IsApproved);

    }
    private  async Task GetAll(bool val)
    {
        var authprov = await auth.GetAuthenticationStateAsync();
        var brancIDString = authprov.User.Claims.First(x => x.Type == "BranchID").Value;
        int brancID = int.Parse(brancIDString);
       
       if (val)
        {
            collection = Iservice.SelectPending(brancID).Where(x => x.AuthLevelID == 99).ToList();
            
        }
        else
        {
             collection = Iservice.SelectPending(brancID).Where(x => x.AuthLevelID != 99).ToList();
       
        }


    }
    //public void OpenDialogApproved(PurchaseOrderModel p)
    //{
        
    //    DialogParameters parms = new DialogParameters();
    //    parms.Add("model",p);
    //    var dialog =  DialogService.Show<PurchaseOrderApprovedView>(p.POID == null?"Approved Data":"Approved Data",parms,maxWidth);
      
