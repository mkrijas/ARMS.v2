    private async Task Delete(PurchaseOrderModel tds)
    {
        Iservice.Delete(tds.POID, "Rijas");
        snackbar.Add("Deleted Successfully", Severity.Success);
        await GetAll(IsApproved);
    }
    
    

    private bool search(PurchaseOrderModel tds)
    {
        if (tds.PONo != null && tds.PONo.Contains(searchPurchase, StringComparison.OrdinalIgnoreCase))
        {
            return true;
        }
        else if (tds.PONo == null)
            return true;
        return false;
    }

    private string TableRowStyle(PurchaseOrderModel PO, int index)
    {
        if(PO.AuthLevelID == 99)
        {
            return "background-color:#CCCCFF";
        }
        return string.Empty;
    }

