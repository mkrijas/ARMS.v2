@page "/PurchaseOrder"
@inject IPurchaseOrderService Iservice
@inject MudBlazor.ISnackbar snackbar

@inject AuthenticationStateProvider auth
@attribute [Authorize]
@inject IDialogService DialogService

<MudGrid Spacing="4">
   <MudItem xs="12">
        <MudTable Items="@collection" RowStyleFunc="TableRowStyle"  Dense="true" Hover="true"  Striped="true" Elevation="10" Filter="new Func<PurchaseOrderModel, bool>(search)" @bind-place="model">           
             <ToolBarContent>
                <MudText Typo="Typo.h6">Purchase Order</MudText>
                <MudIconButton Icon="@Icons.Material.Filled.Add" Title="Add" @onclick="@(()=> OpenDialog(model))"  Color="Color.Dark" Size="Size.Small"></MudIconButton>
                 <MudIconButton Icon="@Icons.Material.Filled.TableView" Title="Approved Data" @onclick="@(()=> OpenDialogApproved(model))"  Color="Color.Dark" Size="Size.Small"></MudIconButton>
               
                <MudSpacer></MudSpacer>
                <MudTextField @bind-Value="searchPurchase" Placeholder="Search Purchase order... "
                              Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                              IconSize="Size.Medium" Class="mt-0"></MudTextField>
            </ToolBarContent>
            <HeaderContent>
                <MudTh><MudTableSortLabel SortBy="new Func<PurchaseOrderModel, object>(x=> x.PONo)" InitialDirection="SortDirection.Ascending">PONo</MudTableSortLabel></MudTh>
             <MudTh><MudTableSortLabel SortBy="new Func<PurchaseOrderModel, object>(x=> x.EntryDate)" InitialDirection="SortDirection.Ascending">EntryDate</MudTableSortLabel></MudTh>
               <MudTh><MudTableSortLabel SortBy="new Func<PurchaseOrderModel, object>(x=> x.PartyName)" InitialDirection="SortDirection.Ascending">Party</MudTableSortLabel></MudTh>
               
                <MudTh>Actions</MudTh>
            </HeaderContent>

            <RowTemplate>   
                <MudTd DataLabel="PONo">@context.PONo</MudTd>
                <MudTd DataLabel="EntryDate"  >@context.EntryDate?.ToShortDateString()</MudTd>
                <MudTd DataLabel="Party">@context.PartyName</MudTd>
                <MudTd DataLabel="">
                   
                     @if(@context.AuthLevelID==null)
                    {
                    //  <MudFab @onclick="@(()=> Approve(context))" Color="Color.Success" Icon="@Icons.Material.Filled.Check" title="Approve" Size="Size.Small" IconSize="Size.Small" />
                      <MudFab @onclick="@(()=> OpenDialog(context))" Color="Color.Primary" Icon="@Icons.Material.Filled.Edit" title="Edit" Size="Size.Small" IconSize="Size.Small" />
                     <MudFab @onclick="@(()=> Delete(context))" Color="Color.Error" Icon="@Icons.Material.Filled.Delete" title="Delete" Size="Size.Small" IconSize="Size.Small" />
                  
                    }
                    @if (@context.AuthLevelID!= 99)
                    {
                    <MudFab @onclick="@(()=> OpenDialogVerify(context))" Color="Color.Warning" Icon="@Icons.Material.Filled.Verified" title="Verify" Size="Size.Small" IconSize="Size.Small" />
                        
                    }
                    <MudFab @onclick="@(()=> OpenDialogView(context))" Color="Color.Info" Icon="@Icons.Material.Filled.GridView" title="View" Size="Size.Small" IconSize="Size.Small" />
                   


                    </MudTd>
            </RowTemplate>
            <PagerContent>
                <MudTablePager PageSizeOptions="new int[] { 5, 10, 20, 50, 100 }" />
            </PagerContent>
        </MudTable>
    </MudItem>
    </MudGrid>



@code {


    private PurchaseOrderModel model = new PurchaseOrderModel();
    private List<PurchaseOrderModel> collection = new List<PurchaseOrderModel>();
    DialogOptions maxWidth = new DialogOptions() { MaxWidth = MaxWidth.Medium, FullWidth = true };


    private string searchPurchase = "";

    protected override async Task OnInitializedAsync()
    {
        model = new();
        GetAll(); //View only Unapproved
    }

    private  async Task GetAll()
    {
        var authprov = await auth.GetAuthenticationStateAsync();
        var brancIDString = authprov.User.Claims.First(x => x.Type == "BranchID").Value;
        int brancID = int.Parse(brancIDString);
        collection = Iservice.SelectPending(brancID).ToList();
       


    }
    public void OpenDialogApproved(PurchaseOrderModel p)
    {
        
        DialogParameters parms = new DialogParameters();
        parms.Add("model",p);
        var dialog =  DialogService.Show<PurchaseOrderApprovedView>(p.POID == null?"Approved Data":"Approved Data",parms,maxWidth);
      
    }

    private async Task OpenDialog(PurchaseOrderModel tds)
    {
        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;

        DialogParameters parms = new DialogParameters();
        parms.Add("model",tds);
         parms.Add("IsReadOnly",false);
        parms.Add("IsView",false);
        var dialog =  DialogService.Show<PurchaseOrderDialog>(tds.POID == null?"ADD":"EDIT",parms,maxWidth);
        var result = await dialog.Result;

        if(!result.Cancelled)
        {   
            PurchaseOrderModel UpatedModel = (PurchaseOrderModel)result.Data;            
            model.UserInfo.UserID = user.Identity.Name;

            try
            {

                Iservice.Update(UpatedModel);
                model = new();
                snackbar.Add("Saved Successfully", Severity.Success);
                model = new PurchaseOrderModel();
                GetAll();
            }
            catch (Exception ex)
            {
                snackbar.Add(ex.Message, Severity.Warning);
            }

        }
    }


     private async Task OpenDialogVerify(PurchaseOrderModel tds)
    {
        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;

        DialogParameters parms = new DialogParameters();
        parms.Add("model",tds);
        parms.Add("IsReadOnly",true);
        parms.Add("IsView",false);
        var dialog =  DialogService.Show<PurchaseOrderDialog>(tds.POID == null?"ADD":"EDIT",parms,maxWidth);
        var result = await dialog.Result;

        if(!result.Cancelled)
        {   
           
            GetAll();
        }
    }
     private async Task OpenDialogView(PurchaseOrderModel tds)
    {
        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;

        DialogParameters parms = new DialogParameters();
        parms.Add("model",tds);
         parms.Add("IsReadOnly",true);
        parms.Add("IsView",true);
        var dialog =  DialogService.Show<PurchaseOrderDialog>(tds.POID == null?"ADD":"EDIT",parms,maxWidth);
        var result = await dialog.Result;

        if(!result.Cancelled)
        {   
           
            GetAll();
        }
    }

    private void Delete(PurchaseOrderModel tds)
    {
        Iservice.Delete(tds.POID, "Rijas");
        snackbar.Add("Deleted Successfully", Severity.Success);
        GetAll();
    }
    
    private async Task Approve(PurchaseOrderModel tds)
    {

        var parameters = new DialogParameters();
        parameters.Add("ContentText", "Are you sure you want to Approve this Purchase Order,Order No:"+tds.PONo+"?");
        parameters.Add("ButtonText", "Confirm");
        parameters.Add("Color", Color.Success);
        var dialog=DialogService.Show<ConfirmDialog>("Confirm", parameters);
        var result = await dialog.Result;


        if (!result.Cancelled)
        {
            var authprov = await auth.GetAuthenticationStateAsync();
            var user = authprov.User;
            tds.UserInfo.UserID = user.Identity.Name;
            try
            {

                Iservice.Approve(tds.POID.Value,tds.UserInfo.UserID,string.Empty);

                snackbar.Add("Approved", Severity.Success);

                GetAll();
            }
            catch (Exception ex)
            {
                snackbar.Add(ex.Message, Severity.Warning);
            }
        }





    }

    private bool search(PurchaseOrderModel tds)
    {
        if (tds.PONo != null && tds.PONo.Contains(searchPurchase, StringComparison.OrdinalIgnoreCase))
        {
            return true;
        }
        else if (tds.PONo == null)
            return true;
        return false;
    }

    private string TableRowStyle(PurchaseOrderModel PO, int index)
    {
        if(PO.ApprovedInfo.RecordStatus == 2)
        {
            return "background-color:#CCCCFF";
        }
        return string.Empty;
    }

}
