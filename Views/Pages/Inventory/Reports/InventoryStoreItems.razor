@page "/InventorySummaryReport"
@using Microsoft.JSInterop
@using Microsoft.AspNetCore.Components
@using Views.Data;
@using System.Text;
@using System.Net;
@inject IStoreService storeIservice
@inject AuthenticationStateProvider auth
@inject ISnackbar Snackbar

<div class="fade-in">
    <div class="admin-header-tiered mb-6">
        <div class="d-flex align-center justify-space-between">
            <div>
                <MudText Typo="Typo.h4" Class="admin-title">Inventory Summary Report</MudText>
                <MudText Typo="Typo.body2" Class="admin-subtitle">Consolidated audit of warehouse stock levels, item movements, and store-specific inventory status across the organization.</MudText>
            </div>
        </div>
    </div>

    <div class="admin-glass-card mb-6 pa-6">
        <MudGrid Spacing="4" Class="align-center">
            <MudItem xs="12" sm="4">
                <StoreSelector @bind-Value="@Store" BranchID="@branchID.Value" Class="admin-input-group" />
            </MudItem>
            <MudItem xs="12" sm="2">
                <MudDatePicker Label="From Date" @bind-Date="@StartDate" Variant="Variant.Outlined" Margin="Margin.Dense" Class="admin-input-group" />
            </MudItem>
            <MudItem xs="12" sm="2">
                <MudDatePicker Label="To Date" @bind-Date="@EndDate" Variant="Variant.Outlined" Margin="Margin.Dense" Class="admin-input-group" />
            </MudItem>
            <MudItem xs="12" sm="4" Class="d-flex align-center gap-2">
                <MudButton FullWidth="true" Variant="Variant.Filled" Color="Color.Primary" OnClick="RenderReportViewer" Class="admin-register-btn">VIEW REPORT</MudButton>
            </MudItem>
        </MudGrid>
    </div>

    <div class="admin-glass-card pa-0 overflow-hidden shadow-sm @(ShowReport ? "" : "d-none")">
        <ReportViewer ReportName="@ReportName" Parameters=@ReportParameters SpName="rptInventoryStoreItems" @ref="@report"></ReportViewer>
    </div>
</div>

@code {

    ReportViewer report;
    public Dictionary<string, string> ReportParameters { get; set; } = new();
    public DateTime? StartDate { get; set; } = DateTime.Now;
    public DateTime? EndDate { get; set; } = DateTime.Now;
    public StoreModel Store { get; set; }
    public InventoryItemModel Item { get; set; }
    public int? branchID { get; set; } = 0;
    public string branchName { get; set; }
    public bool ShowReport { get; set; } = false;
    public string ReportName { get; set; }
    private List<StoreModel> StoreList = new();

    protected override async Task OnInitializedAsync()
    {
        var authprov = await auth.GetAuthenticationStateAsync();
        var User = authprov.User;
        var claimID = authprov.User.Claims.FirstOrDefault(x => x.Type == "BranchID");
        var claimName = authprov.User.Claims.FirstOrDefault(x => x.Type == "BranchName");

        if (claimID != null && claimName != null)
        {
             branchID = int.Parse(claimID.Value);
             branchName = claimName.Value;
             StoreList = storeIservice.SelectByBranch(branchID.Value).ToList();
        }
    }

    public async Task RenderReportViewer()
    {
        if (Store == null && branchID == 7)
        {
            Store = new StoreModel();
            Store.StoreID = 0;    
        }

        if (Item == null)
        {
            Item = new InventoryItemModel();
            Item.InventoryItemID = 0;
        }

        if (Store == null || Store.StoreID == null)
        {
            Snackbar.Add("Please select store.", Severity.Error);
            return;
        }
        if (StartDate == null)
        {
            Snackbar.Add("Please select start date.", Severity.Error);
            return;
        }
        if (EndDate == null)
        {
            Snackbar.Add("Please select end date.", Severity.Error);
            return;
        }

        ShowReport = true;
        ReportName = "InventorySummaryReport";
        ReportParameters.Clear();
        ReportParameters.Add("StoreID", Store.StoreID.ToString());
        ReportParameters.Add("StartDate", StartDate.Value.ToString("yyyy-MM-dd"));
        ReportParameters.Add("EndDate", EndDate.Value.ToString("yyyy-MM-dd"));
        ReportParameters.Add("BranchName", branchName);
        await report.RenderReport(ReportName);
    }
}
