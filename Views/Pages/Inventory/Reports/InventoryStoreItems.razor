@page "/InventoryStoreItems"
@using Microsoft.JSInterop
@using Microsoft.AspNetCore.Components
@using Views.Data;
@using System.Text;
@using System.Net;
@inject IStoreService storeIservice
@inject AuthenticationStateProvider auth
@inject ISnackbar Snackbar

<MudGrid Spacing="4">
    <MudItem xs="12">
        <MudPaper Class="mb-5 p-4">
            <MudItem xs="12" md="12">
                <StoreSelector @bind-Value="@Store" BranchID="@branchID.Value"></StoreSelector>
            </MudItem>
            <MudGrid>
                <MudItem xs="5" md="5">
                    <MudDatePicker Label="Start Date" @bind-Date="@(StartDate)" />
                </MudItem>
                <MudItem xs="5" md="5">
                    <MudDatePicker Label="End Date" @bind-Date="@(EndDate)" />
                </MudItem>
                <MudItem xs="2" md="2">
                    <MudButton Style="margin-top:9%;" Variant="Variant.Filled" Color="Color.Success" OnClick="RenderReportViewer">View Report</MudButton>
                </MudItem>
            </MudGrid>
        </MudPaper>
    </MudItem>
</MudGrid>
<MudGrid Style="@(ShowReport?"":"Display:none")">
    <MudItem xs="12">
        <ReportViewer ReportName="@ReportName" Parameters=@ReportParameters  @ref="@report"></ReportViewer>
    </MudItem>
</MudGrid>

@code {
    ReportViewer report;
    public Dictionary<string, string> ReportParameters { get; set; } = new();
    public DateTime? StartDate { get; set; } = DateTime.Now;
    public DateTime? EndDate { get; set; } = DateTime.Now;
    public StoreModel Store { get; set; }
    public int? branchID { get; set; } = 0;
    public string branchName { get; set; }
    public bool ShowReport { get; set; } = false;
    public string ReportName { get; set; }
    private List<StoreModel> StoreList = new();

    protected override async Task OnInitializedAsync()
    {
        var authprov = await auth.GetAuthenticationStateAsync();
        var User = authprov.User;
        branchID = int.Parse(authprov.User.Claims.First(x => x.Type == "BranchID").Value);
        branchName = User.Claims.First(x => x.Type == "BranchName").Value;
        StoreList = storeIservice.SelectByBranch(branchID.Value).ToList();
    }

    public async Task RenderReportViewer()
    {

        if (Store == null || Store.StoreID == null)
        {
            Snackbar.Add("Please select store.", Severity.Error);
            return;
        }
        if (StartDate == null)
        {
            Snackbar.Add("Please select start date.", Severity.Error);
            return;
        }
        if (EndDate == null)
        {
            Snackbar.Add("Please select end date.", Severity.Error);
            return;
        }

        ShowReport = true;
        ReportName = "InventorySummaryReport";
        ReportParameters.Clear();
        ReportParameters.Add("StoreID", Store.StoreID.ToString());
        ReportParameters.Add("StartDate", StartDate.Value.ToString("yyyy/MM/dd"));
        ReportParameters.Add("EndDate", EndDate.Value.ToString("yyyy/MM/dd"));
        ReportParameters.Add("BranchName", branchName);
        await report.RenderReport();
    }
}