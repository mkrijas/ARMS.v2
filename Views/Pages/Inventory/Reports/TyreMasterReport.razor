@page "/TyreMasterReport"
@attribute [Authorize]
@inject AuthenticationStateProvider auth
@inherits ReportComponentBase
@inject ISnackbar Snackbar
@inject ITyreService Iservice

<MudGrid Spacing="4">
    <MudItem xs="12">
        <MudPaper Class="mb-5 p-4">
            <MudToolBar Style="padding-left: 0px; margin-top: -22px;">
                <MudText Typo="Typo.h5" Style="font-weight:500;">Tyre Master Report</MudText>
            </MudToolBar>
            <MudDivider />
            <MudGrid Style="padding-top: 22px;">
                <MudItem xs="3">
                    <MudAutocomplete Label="Select Tyre" @bind-Value="SelectedTyre" SearchFunc="SearchTyres" T="TyreModel" Variant="Variant.Outlined" Margin="Margin.Dense" AdornmentColor="Color.Secondary"  ToStringFunc="@(e => e == null ? null : string.Format("{0}",e.TyreSerialNumber))">
                    </MudAutocomplete>
                </MudItem>
                <MudItem xs="3">
                    <MudDatePicker Label="From Date" @bind-Date="@(FromDate)" Variant="Variant.Outlined" Margin="Margin.Dense" />
                </MudItem>
                <MudItem xs="3">
                    <MudDatePicker Label="To Date" @bind-Date="@(ToDate)" Variant="Variant.Outlined" Margin="Margin.Dense" />
                </MudItem>
                <MudItem xs="3" Style="display: flex; align-items: center;">
                    <MudIconButton Style="margin-right: 8px;" Title="Select Branches" Icon="@Icons.Material.Filled.List" Variant="Variant.Filled" Color="Color.Success" OnClick="SelectBranches"></MudIconButton>
                    <MudButton Style="width: -webkit-fill-available;" Variant="Variant.Filled" Color="Color.Success" OnClick="RenderReportViewer">View Report</MudButton>
                </MudItem>
            </MudGrid>
        </MudPaper>
    </MudItem>
</MudGrid>
<MudGrid Style="@(ShowReport?"":"Display:none")">
    <MudItem xs="12">
        <ReportViewer ReportName="@ReportName" Parameters=@ReportParameters @ref="@report"></ReportViewer>
    </MudItem>
</MudGrid>

@code {

    ReportViewer report;
    public Dictionary<string, string> ReportParameters { get; set; } = new();
    public TyreModel SelectedTyre { get; set; }
    public DateTime? FromDate { get; set; } = null;
    public DateTime? ToDate { get; set; } = null;
    public BranchModel CurrentBranch { get; set; } = new();
    private List<TyreModel> TyreList = new List<TyreModel>();

    public bool ShowReport { get; set; } = false;
    public string ReportName { get; set; }

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();
        var authprov = await auth.GetAuthenticationStateAsync();
        var User = authprov.User;
        string BranchIDString = User.Claims.First(x => x.Type == "BranchID").Value;
        CurrentBranch.BranchName = User.Claims.First(x => x.Type == "BranchName").Value;
        TyreList = Iservice.SelectByBranch(BranchID).ToList();
    }

    private async Task<IEnumerable<TyreModel>> SearchTyres(string searchString)
    {
        if (string.IsNullOrEmpty(searchString))
            return TyreList;

        return await Task.FromResult(TyreList.Where(x => x.TyreSerialNumber.Contains(searchString, StringComparison.InvariantCultureIgnoreCase)));
    }

    private void OnTyreSelected(TyreModel model)
    {
        SelectedTyre = model;
    }

    public async Task RenderReportViewer()
    {
        if (!SelectedBranches.Any())
        {
            snackbar.Add("Please select branch.", Severity.Error);
            return;
        }
        if(SelectedTyre == null)
        {
            if (FromDate == null)
            {
                Snackbar.Add("Please select From Date.", Severity.Error);
                return;
            }
            if (ToDate == null)
            {
                Snackbar.Add("Please select To Date.", Severity.Error);
                return;
            }    
        }


        ShowReport = true;
        ReportName = "TyreMasterReport";
        ReportParameters.Clear();
        ReportParameters.Add("BranchIDS", String.Join(',', SelectedBranches));
        ReportParameters.Add("BranchName", CurrentBranch.BranchName);
        ReportParameters.Add("TyreID", SelectedTyre?.TyreID.ToString() ?? "0");
        ReportParameters.Add("FromDate", FromDate.Value.ToString("yyyy/MM/dd") ?? null);
        ReportParameters.Add("ToDate", ToDate.Value.ToString("yyyy/MM/dd") ?? null);
        await report.RenderReport();
    }
}