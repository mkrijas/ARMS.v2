@page "/TyreMasterReport"
@attribute [Authorize]
@inject AuthenticationStateProvider auth
@inherits ReportComponentBase
@inject ISnackbar Snackbar
@inject ITyreService Iservice
@using System.Threading;

<div class="fade-in">
    <div class="admin-header-tiered mb-6">
        <div class="d-flex align-center justify-space-between">
            <div>
                <MudText Typo="Typo.h4" Class="admin-title">Tyre Master Report</MudText>
                <MudText Typo="Typo.body2" Class="admin-subtitle">Master technical audit of individual tyre assets. Track procurement history, lifecycle movements, and maintenance trails by serial number.</MudText>
            </div>
        </div>
    </div>

    <div class="admin-glass-card mb-6 pa-6">
        <MudGrid Spacing="4" Class="align-center">
            <MudItem xs="12" sm="3">
                <MudAutocomplete Label="Select Tyre" @bind-Value="SelectedTyre" SearchFunc="SearchTyres" T="TyreModel" Variant="Variant.Outlined" Margin="Margin.Dense" Class="admin-input-group" AdornmentColor="Color.Secondary" ToStringFunc="@(e => e == null ? null : string.Format("{0}",e.TyreSerialNumber))" />
            </MudItem>
            <MudItem xs="12" sm="3">
                <MudDatePicker Label="From Date" @bind-Date="@FromDate" Variant="Variant.Outlined" Margin="Margin.Dense" Class="admin-input-group" />
            </MudItem>
            <MudItem xs="12" sm="3">
                <MudDatePicker Label="To Date" @bind-Date="@ToDate" Variant="Variant.Outlined" Margin="Margin.Dense" Class="admin-input-group" />
            </MudItem>
            <MudItem xs="12" sm="3" Class="d-flex align-center gap-2">
                <MudTooltip Text="Select Branches">
                    <MudIconButton Icon="@Icons.Material.Filled.List" Variant="Variant.Filled" Color="Color.Success" OnClick="SelectBranches" Class="rounded-lg" />
                </MudTooltip>
                <MudButton FullWidth="true" Variant="Variant.Filled" Color="Color.Primary" OnClick="RenderReportViewer" Class="admin-register-btn">VIEW REPORT</MudButton>
            </MudItem>
        </MudGrid>
    </div>

    <div class="admin-glass-card pa-0 overflow-hidden shadow-sm @(ShowReport ? "" : "d-none")">
        <ReportViewer ReportName="@ReportName" Parameters=@ReportParameters SpName="rptTyreMaster" @ref="@report"></ReportViewer>
    </div>
</div>

@code {

    ReportViewer report;
    public Dictionary<string, string> ReportParameters { get; set; } = new();
    public TyreModel SelectedTyre { get; set; }
    public DateTime? FromDate { get; set; } = null;
    public DateTime? ToDate { get; set; } = null;
    public BranchModel CurrentBranch { get; set; } = new();
    private List<TyreModel> TyreList = new List<TyreModel>();

    public bool ShowReport { get; set; } = false;
    public string ReportName { get; set; }

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();
        var authprov = await auth.GetAuthenticationStateAsync();
        var User = authprov.User;
        string BranchIDString = User.Claims.First(x => x.Type == "BranchID").Value;
        CurrentBranch.BranchName = User.Claims.First(x => x.Type == "BranchName").Value;
        TyreList = Iservice.SelectByBranch(BranchID).ToList();
    }

    private async Task<IEnumerable<TyreModel>> SearchTyres(string searchString, CancellationToken token)
    {
        if (string.IsNullOrEmpty(searchString))
            return TyreList;

        return await Task.FromResult(TyreList.Where(x => x.TyreSerialNumber.Contains(searchString, StringComparison.InvariantCultureIgnoreCase)));
    }

    private void OnTyreSelected(TyreModel model)
    {
        SelectedTyre = model;
    }

    public async Task RenderReportViewer()
    {
        if (!SelectedBranches.Any())
        {
            snackbar.Add("Please select branch.", Severity.Error);
            return;
        }
        if (SelectedTyre == null && (FromDate == null || ToDate == null))
        {
            Snackbar.Add("Please select both From Date and To Date.", Severity.Error);
            return;
        }


        ShowReport = true;
        ReportName = "TyreMasterReport";
        ReportParameters.Clear();
        ReportParameters.Add("BranchIDS", String.Join(',', SelectedBranches));
        ReportParameters.Add("BranchName", CurrentBranch.BranchName);
        ReportParameters.Add("TyreID", SelectedTyre?.TyreID.ToString() ?? "0");
        ReportParameters.Add("FromDate", FromDate?.ToString("yyyy-MM-dd") ?? string.Empty);
        ReportParameters.Add("ToDate", ToDate?.ToString("yyyy-MM-dd") ?? string.Empty);
        await report.RenderReport(ReportName);
    }
}
