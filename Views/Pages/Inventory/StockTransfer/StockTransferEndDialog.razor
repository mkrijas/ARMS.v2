@inject AuthenticationStateProvider auth
@inject IStockTransferService IService
@inject MudBlazor.ISnackbar snackbar
@inject IDialogService DialogService
@inject IRoleService<RoleModel> Irole

@using ArmsServices.DataServices.Finance.Transactions;
@using Core.BaseModels.Inventory;
@using Views.Pages.Finance.Transactions
@using System.Threading;

<DialogForm @ref="@dialogForm" ReadOnly="@ReadOnly" Title="Accept Stock-Transfer" Subtitle="Acknowledge and reconcile incoming inventory transfers from other nodes." Icon="@Icons.Material.Filled.MoveToInbox" AdminStyle="true" formID="stockTransferEndForm" model="@Model" _busy="_busy">
    <FormContent>
        <div class="dialog-content-wrapper">
            <EditForm id="stockTransferEndForm" Model="@Model" OnValidSubmit="OnValidSubmit">
                <div class="admin-glass-card pa-6 mb-6">
                    <DataAnnotationsValidator />
                    <ValidationSummary />
                    
                    <div class="d-flex align-center mb-6">
                        <MudIcon Icon="@Icons.Material.Filled.Info" Color="Color.Primary" Class="mr-2" />
                        <span class="admin-section-label mb-0">Reconciliation Details</span>
                    </div>

                    <MudGrid Spacing="3" Class="align-center">
                        <MudItem xs="12" md="5">
                            <div class="admin-input-group">
                                <label class="mud-typography mud-typography-caption mud-text-secondary ml-1">Origin Branch</label>
                                <MudTextField T="string" ReadOnly Value="@Model.OtherBranchName" Variant="Variant.Outlined" Margin="Margin.Dense" Class="fw-bold" />
                            </div>
                        </MudItem>

                        <MudItem xs="12" md="2" Class="d-flex flex-column align-center justify-center">
                            <MudIcon Icon="@Icons.Material.Filled.MoveToInbox" Color="Color.Primary" Size="Size.Large" Class="opacity-50" />
                            <MudText Typo="Typo.caption" Class="mud-text-secondary">Arrival</MudText>
                        </MudItem>

                        <MudItem xs="12" md="5">
                            <div class="admin-input-group">
                                <label class="mud-typography mud-typography-caption mud-text-secondary ml-1">Destination Store</label>
                                 <StoreSelector For="@(() => Model.Store)" @bind-Value="@Model.Store" BranchID="@(branchID ?? 0)" VariantParameter="Variant.Outlined" MarginParameter="Margin.Dense"></StoreSelector>
                            </div>
                        </MudItem>

                        @if (shown)
                        {
                            <MudItem xs="12" md="6">
                                 <CostCenterSelector For="@(() => Model.CostCenter)" @bind-Value="@Model.CostCenter" ReadOnly="@ReadOnly" Class="admin-input-group" />
                            </MudItem>
                            <MudItem xs="12" md="6">
                                 <DimensionSelector For="@(() => Model.Dimension)" @bind-Value="@Model.Dimension" ReadOnly="@ReadOnly" Class="admin-input-group" />
                            </MudItem>
                        }
                        
                        <MudItem xs="12">
                            <MudTextField @bind-Value="@Model.Narration" Label="Operational Remarks / Reconciliation Notes" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => Model.Narration)" Disabled="ReadOnly" Lines="2" Class="admin-input-group"></MudTextField>
                        </MudItem>
                    </MudGrid>
                </div>
                        @if (shown)
                        {
                            <div class="admin-glass-card pa-0 overflow-hidden mb-6">
                                <div class="px-6 py-4 border-bottom-subtle d-flex align-center" style="background: rgba(255, 159, 67, 0.03); border-bottom: 1px solid rgba(255, 159, 67, 0.3);">
                                    <MudIcon Icon="@Icons.Material.Filled.Inventory" Color="Color.Warning" Class="mr-2" />
                                    <span class="admin-section-label mb-0">Transfer Manifest Items</span>
                                </div>
                                
                                <div class="modern-admin-table">
                                    <MudSimpleTable Style="width:100%" Hover="true" FixedHeader="true" Dense="true" Elevation="0">
                                        <thead>
                                            <tr>
                                                <th style="width: 50%">ITEM IDENTITY</th>
                                                <th>QUANTITY</th>
                                                <th>UNIT RATE</th>
                                                <th>GST %</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var item in Model.ItemsList)
                                            {
                                                <tr>
                                                    <td>
                                                        <div class="d-flex flex-column">
                                                            <MudText Typo="Typo.body2" Class="fw-bold">@item.ItemGroupDescription | @item.ItemDescription</MudText>
                                                        </div>
                                                    </td>
                                                    <td>
                                                       <div class="d-flex align-center">
                                                            <span class="fw-bold">@item.ItemQty</span>
                                                            <MudChip T="string" Size="Size.Small" Variant="Variant.Text" Color="Color.Surface" Class="ml-2">@item.UOM</MudChip>
                                                        </div>
                                                    </td>
                                                    <td>@item.ItemRate?.ToString("N2")</td>
                                                    <td>
                                                        @if (IsTaxable)
                                                        {
                                                            <MudChip T="decimal?" Size="Size.Small" Color="Color.Info" Variant="Variant.Outlined">@item.ItemGstVal%</MudChip>
                                                        }
                                                        else
                                                        {
                                                            <span class="mud-text-secondary opacity-50">-</span>
                                                        }
                                                    </td>
                                                </tr>
                                            }
                                        </tbody>
                                    </MudSimpleTable>
                                </div>
                                <div class="px-6 py-4 d-flex justify-end" style="background: rgba(0,0,0,0.02);">
                                    <MudText Typo="Typo.h6" Class="fw-bold">TOTAL MANIFEST VALUE: <span class="mud-text-primary">@(Model.TotalAmount?.ToString("C") ?? "₹0.00")</span></MudText>
                                </div>
                            </div>
                        }
            </EditForm>
        </div>
    </FormContent>
    <VerificationStatus>
        @*   <AutherizationStatusComponent CreatedBy="@Model.UserInfo" DocTypeID="@DocTypeID" DocDate="@Model.DocumentDate" DocType="@DocType" DocNumber="@InitiationModel.DocumentNumber" PageToRedirectLink="@PageToRedirectLink" DocumentID="InitiationModel.StockTransferID" OnApprove="Approve"></AutherizationStatusComponent>
        *@
    </VerificationStatus>
</DialogForm>




@code {

    [Parameter]
    public bool ReadOnly { get; set; }

    [Parameter]
    public StockTransferEndModel Model { get; set; }
    [Parameter]
    public bool IsTaxable { get; set; }

    // [Parameter]
    // public StockTransferInitiationModel InitiationModel { get; set; } = new();

    [CascadingParameter]
    IMudDialogInstance MudDialog { get; set; }


    DialogForm dialogForm;
    bool _busy;


    int? branchID;
    string UserID;


    bool HasPermissionStockTransferServiceEdit = false;
    bool HasPermissionStockTransferServiceAccept = false;
    int DocTypeID = 66;
    string DocType;
    string PageToRedirectLink;

    bool shown = true;
    private void SomeFunction()//bool shownval
    {
        shown = true;
    }

    protected override async Task OnInitializedAsync()
    {
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionStockTransferServiceEdit = await Irole.HasClaim(DocTypeID.ToString(), "Edit", ctc.Token);
        HasPermissionStockTransferServiceAccept = await Irole.HasClaim(DocTypeID.ToString(), "Accept", ctc.Token);

        var authprov = await auth.GetAuthenticationStateAsync();
        branchID = int.Parse(authprov.User.Claims.First(x => x.Type == "BranchID").Value);
        UserID = authprov.User.Identity.Name;

        Model.ItemsList = IService.SelectItemsList(Model.StockTransferID).ToList();
        Model.TotalAmount = GetTotal();

    }


    public async Task OnValidSubmit()
    {       
        if (_busy)
        {
            snackbar.Add("Please wait while form is being submitted!", Severity.Warning);
            return;
        }
        _busy = true;
        try
        {
            Model.UserInfo.UserID = UserID;
            if (HasPermissionStockTransferServiceAccept)
            {
                IService.UpdateDelivery(Model);                
                snackbar.Add("Stock Accepted Successfully", Severity.Success);
                MudDialog.Close(Model);
            }
            else
            {
                bool? result = await DialogService.ShowMessageBoxAsync(
                        "Permission denied!",
                        "You don't have any permission to Accept Transfered Stock.");
            }
        }
        catch (Exception ex)
        {
            snackbar.Add(ex.Message, Severity.Warning);
        }
        await Task.Delay(200);
        _busy = false;
    }

    decimal? GetTotal()
    { 
        var totamt = Model.ItemsList.Sum(s => (s.ItemQty * (s.ItemRate ?? 0m)));
        decimal? gstVal = 0;

        if (IsTaxable)
        {
            gstVal = Model.ItemsList.Sum(s => (s.ItemQty * s.ItemRate) * (s.ItemGstVal / 100));
        }
        return totamt + gstVal;        
    }

