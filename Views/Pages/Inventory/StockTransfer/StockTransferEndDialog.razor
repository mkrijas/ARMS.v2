    //     catch (Exception ex)
    //     {
    //         bool? result = await DialogService.ShowMessageBoxAsync("Permission denied!", ex.Message);
    //     }
    // }
    
    private void CloseDialog()
    {
        MudDialog.Close();
    }

    
}
