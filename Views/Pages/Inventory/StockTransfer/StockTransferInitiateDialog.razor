@inject AuthenticationStateProvider auth
@inject IInventoryReleaseService inventoryReleaseService
@inject IBranchService branchservice
@inject IInventoryItemService itemIservice
@inject IGstItemService Igst
@inject IStockTransferService IService
@inject MudBlazor.ISnackbar snackbar
@inject IRoleService<RoleModel> Irole
@inject IDialogService DialogService
@using ArmsServices.DataServices.Finance.Transactions;
@using Core.BaseModels.Inventory;
@using Views.Pages.Finance.Transactions
@using System.Threading;

<DialogForm @ref="@dialogForm" ReadOnly="@ReadOnly" Title="Initiate Stock Transfer" Subtitle="Request and document internal movement of inventory between branches." Icon="@Icons.Material.Filled.MoveUp" AdminStyle="true" formID="stockTransferForm" model="@InitiationModel" _busy="_busy">
    <FormContent>
        <div class="dialog-content-wrapper">
            <EditForm id="stockTransferForm" Model="@InitiationModel" OnValidSubmit="OnValidSubmit">
                <DataAnnotationsValidator />
                <ValidationSummary />

                <div class="admin-glass-card pa-6 mb-6">
                    <div class="d-flex align-center justify-space-between mb-6">
                        <div class="d-flex align-center">
                            <MudIcon Icon="@Icons.Material.Filled.Info" Color="Color.Primary" Class="mr-2" />
                            <span class="admin-section-label mb-0">General Information</span>
                        </div>
                        <div class="d-flex gap-4">
                            <MudChip T="string" Color="@(InitiationModel.IsLocal ? Color.Success : Color.Primary)" Variant="Variant.Text" Size="Size.Small" Icon="@(InitiationModel.IsLocal ? Icons.Material.Filled.LocationOn : Icons.Material.Filled.Public)">@(InitiationModel.IsLocal ? "Local Transfer" : "Inter-State Transfer")</MudChip>
                            <MudChip T="string" Color="@(InitiationModel.IsTaxable ? Color.Warning : Color.Info)" Variant="Variant.Text" Size="Size.Small" Icon="@Icons.Material.Filled.Receipt">@(InitiationModel.IsTaxable ? "Taxable" : "Non-Taxable")</MudChip>
                        </div>
                    </div>

                    <MudGrid Spacing="3" Class="align-center">
                        <MudItem xs="12" md="5">
                            <div class="admin-input-group">
                                <label class="mud-typography mud-typography-caption mud-text-secondary ml-1">Source Store</label>
                                 <StoreSelector For="@(() => InitiationModel.Store)" IsDisabled="@(ReadOnly)" @bind-Value="@InitiationModel.Store" BranchID="@(branchID ?? 0)" VariantParameter="Variant.Outlined" MarginParameter="Margin.Dense"></StoreSelector>
                                @if (!string.IsNullOrEmpty(HomeGst))
                                {
                                    <MudText Typo="Typo.caption" Class="mt-1 ml-1 mud-text-secondary">GSTIN: <span class="fw-bold">@HomeGst</span></MudText>
                                }
                            </div>
                        </MudItem>

                        <MudItem xs="12" md="2" Class="d-flex flex-column align-center justify-center">
                            <MudIcon Icon="@Icons.Material.Filled.SwapHoriz" Color="Color.Primary" Size="Size.Large" Class="opacity-50" />
                            <MudText Typo="Typo.caption" Class="mud-text-secondary">Movement</MudText>
                        </MudItem>

                        <MudItem xs="12" md="5">
                            <div class="admin-input-group">
                                <label class="mud-typography mud-typography-caption mud-text-secondary ml-1">Destination Branch</label>
                                 <BranchSelector For="@(() => SelectedBranch)" LabelName="Select Branch" ValueChanged="@BranchSelected" Value="@SelectedBranch" IsDisabled="@ReadOnly"></BranchSelector>
                                @if (!string.IsNullOrEmpty(TargetGst))
                                {
                                    <MudText Typo="Typo.caption" Class="mt-1 ml-1 mud-text-secondary">GSTIN: <span class="fw-bold">@TargetGst</span></MudText>
                                }
                            </div>
                        </MudItem>

                        <MudItem xs="12" md="4">
                             <CostCenterSelector For="@(() => InitiationModel.CostCenter)" @bind-Value="InitiationModel.CostCenter" ReadOnly="@ReadOnly" Class="admin-input-group" />
                        </MudItem>

                        <MudItem xs="12" md="4">
                             <DimensionSelector For="@(() => InitiationModel.Dimension)" @bind-Value="InitiationModel.Dimension" ReadOnly="@ReadOnly" Class="admin-input-group" />
                        </MudItem>

                        <MudItem xs="12" md="4">
                            <MudTextField @bind-Value="@InitiationModel.Narration" Label="Narration / Reference" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => InitiationModel.Narration)" Disabled="ReadOnly" Class="admin-input-group"></MudTextField>
                        </MudItem>
                    </MudGrid>
                </div>
                    <br />
                <div class="admin-glass-card pa-0 overflow-hidden mb-6">
                    <div class="px-6 py-4 border-bottom-subtle d-flex align-center" style="background: rgba(255, 159, 67, 0.03); border-bottom: 1px solid rgba(255, 159, 67, 0.3);">
                        <MudIcon Icon="@Icons.Material.Filled.Inventory" Color="Color.Warning" Class="mr-2" />
                        <span class="admin-section-label mb-0">Items to Transfer</span>
                    </div>

                    <div class="modern-admin-table">
                        <MudSimpleTable Style="width:100%" Hover="true" FixedHeader="true" Dense="true" Elevation="0">
                            <thead>
                                <tr>
                                    <th style="width: 45%">ITEM DETAILS</th>
                                    <th>QUANTITY</th>
                                    <th>RATE</th>
                                    <th>TAX %</th>
                                    @if (!ReadOnly)
                                    {
                                        <th style="width: 50px"></th>
                                    }
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in InitiationModel.ItemsList)
                                {
                                    <tr>
                                        <td>
                                            <div class="d-flex flex-column">
                                                <MudText Typo="Typo.body2" Class="fw-bold">@item.ItemGroupDescription | @item.ItemDescription</MudText>
                                            </div>
                                        </td>
                                        <td>
                                            <div class="d-flex align-center">
                                                <span>@item.ItemQty</span>
                                                <MudChip T="string" Size="Size.Small" Variant="Variant.Text" Color="Color.Surface" Class="ml-2">@item.UOM</MudChip>
                                            </div>
                                        </td>
                                        <td>@item.ItemRate?.ToString("N2")</td>
                                        <td>
                                            @if (InitiationModel.IsTaxable)
                                            {
                                                <MudChip T="decimal?" Size="Size.Small" Color="Color.Info" Variant="Variant.Outlined">@item.ItemGstVal%</MudChip>
                                            }
                                            else
                                            {
                                                <span class="mud-text-secondary opacity-50">-</span>
                                            }
                                        </td>
                                        @if (!ReadOnly)
                                        {
                                            <td>
                                                <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small" OnClick="@(()=> Delete(item))" />
                                            </td>
                                        }
                                    </tr>
                                }
                                @if (!ReadOnly)
                                {
                                    <tr style="background: rgba(54, 117, 136, 0.05);">
                                        <td>
                                             <InventoryItemSelector For="@(() => SelectedItem)" Value="SelectedItem" ValueChanged="@((InventoryItemModel newValue) => ItemSelected(newValue))" Class="admin-input-group" />
                                        </td>
                                        <td>
                                            <MudNumericField @bind-Value="ItemsModel.ItemQty" Adornment="Adornment.End" AdornmentText="@UOM" Variant="Variant.Outlined" Margin="Margin.Dense" Class="admin-input-group" HideSpinButtons />
                                        </td>
                                        <td colspan="2">
                                            <MudNumericField @bind-Value="ItemsModel.ItemRate" Variant="Variant.Outlined" Margin="Margin.Dense" Class="admin-input-group" HideSpinButtons />
                                        </td>
                                        <td>
                                            <MudIconButton Icon="@Icons.Material.Filled.AddCircle" Color="Color.Primary" OnClick="AddItems" />
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </MudSimpleTable>
                    </div>
                    <div class="px-6 py-4 d-flex justify-end" style="background: rgba(0,0,0,0.02);">
                        <MudText Typo="Typo.h6" Class="fw-bold">ESTIMATED TOTAL: <span class="mud-text-primary">@(InitiationModel.TotalAmount?.ToString("C") ?? "₹0.00")</span></MudText>
                    </div>
                </div>
            </EditForm>
        </div>
    </FormContent>
    <VerificationStatus>
        <AutherizationStatusComponent CreatedBy="@InitiationModel.UserInfo" DocTypeID="@DocTypeID" DocDate="@InitiationModel.DocumentDate" DocType="@DocType" DocNumber="@InitiationModel.DocumentNumber" PageToRedirectLink="@PageToRedirectLink" DocumentID="InitiationModel.StockTransferID" OnApprove="Approve"></AutherizationStatusComponent>
    </VerificationStatus>
</DialogForm>

@code {

    [Parameter]
    public bool ReadOnly { get; set; }
    [Parameter]
    public StockTransferInitiationModel InitiationModel { get; set; } = new();
    [CascadingParameter]
    IMudDialogInstance MudDialog { get; set; }
    DialogForm dialogForm;
    bool _busy;
    InventoryItemEntryModel ItemsModel { get; set; } = new();
    int? branchID; string UserID;
    BranchModel SelectedBranch;
    List<InventoryItemEntryModel> EnteredItems = new();
    InventoryItemModel SelectedItem = new();
    string PageToRedirectLink;
    string HomeGst, TargetGst;
    public string UOM { get; set; }

    bool HasPermissionStockTransferServiceEdit = false;
    bool HasPermissionStockTransferServiceAccept = false;
    int DocTypeID = 66;
    string DocType;

    protected override async Task OnInitializedAsync()
    {
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionStockTransferServiceEdit = await Irole.HasClaim(DocTypeID.ToString(), "Edit", ctc.Token);
        HasPermissionStockTransferServiceAccept = await Irole.HasClaim(DocTypeID.ToString(), "Accept", ctc.Token);

        var authprov = await auth.GetAuthenticationStateAsync();
        branchID = int.Parse(authprov.User.Claims.First(x => x.Type == "BranchID").Value);
        UserID = authprov.User.Identity.Name;
        HomeGst = branchservice.GetGstNo(branchID);

        if (InitiationModel.StockTransferID != null)
        {
            InitiationModel.ItemsList = IService.SelectItemsList(InitiationModel?.StockTransferID).ToList();
            SelectedBranch = branchservice.SelectByID(InitiationModel.OtherBranchID);
            InitiationModel.TotalAmount = GetTotal();
        }
        else
        {
            InitiationModel.NatureOfTransaction = "StockTransferOut";
            InitiationModel.BranchID = branchID;
        }
    }

    void BranchSelected(BranchModel e)
    {
        SelectedBranch = e;
        InitiationModel.OtherBranchID = e?.BranchID;
        TargetGst = branchservice.GetGstNo(e?.BranchID);
        InitiationModel.IsLocal = HomeGst.Substring(0, 2) == TargetGst.Substring(0, 2);
        InitiationModel.IsTaxable = HomeGst != TargetGst;
        InitiationModel.TotalAmount = GetTotal();
    }

    public async Task OnValidSubmit()
    {
        if (InitiationModel.ItemsList == null)
        {
            snackbar.Add("Add at least one Entry before Submitting", Severity.Success);
            return;
        }
        else
        {
            if (_busy)
            {
                snackbar.Add("Please wait while form is being submitted!", Severity.Warning);
                return;
            }
            _busy = true;

            InitiationModel.UserInfo.UserID = UserID;
            try
            {
                if (HasPermissionStockTransferServiceEdit)
                {
                    IService.Initiate(InitiationModel);
                    InitiationModel = new();
                    snackbar.Add("Saved Successfully", Severity.Success);
                    MudDialog.Close(InitiationModel);
                }
                else
                {
                    bool? result = await DialogService.ShowMessageBoxAsync(
                        "Permission denied!",
                        "You don't have any permission to Transfer Stock.");
                }
            }
            catch (Exception ex)
            {
                snackbar.Add(ex.Message, Severity.Warning);
            }
            await Task.Delay(200);
            _busy = false;
        }
    }

    protected async Task Approve(DataApprovedStatus aprvd)
    {
        try
        {
            if (HasPermissionStockTransferServiceEdit)
            {
                if (aprvd.IsApprove)
                {
                    IService.Approve(InitiationModel.StockTransferID, UserID, branchID);
                    snackbar.Add("Approved Successfully", Severity.Success);
                    MudDialog.Close();
                }
            }
            else
            {
                bool? result = await DialogService.ShowMessageBoxAsync(
                        "Permission denied!",
                        "You don't have any permission to Transfer Stock.");
            }
        }
        catch (Exception ex)
        {
            snackbar.Add(ex.Message, Severity.Warning);
        }
    }

    private void AddItems()
    {
        if (ItemsModel.ItemID == null || ItemsModel.ItemRate == null || ItemsModel.ItemQty == null)
        {
            snackbar.Add("Please fill in all Fields", Severity.Error);
            return;
        }
        ItemsModel.ItemGstVal = Igst.SelectByItem(ItemsModel.ItemID ?? 0, InitiationModel.DocumentDate).TaxRate;
        ItemsModel.UOM = UOM;
        InitiationModel.ItemsList.Add(ItemsModel);
        InitiationModel.TotalAmount = GetTotal();
        ItemsModel = new();
        SelectedItem = null;
    }


    decimal? GetTotal()
    {
        var totamt = InitiationModel.ItemsList.Sum(s => (s.ItemQty * (s.ItemRate ?? 0m)));
        decimal? gstVal = 0;

        if (InitiationModel.IsTaxable)
        {
            gstVal = InitiationModel.ItemsList.Sum(s => (s.ItemQty * s.ItemRate) * (s.ItemGstVal / 100));
        }
        return totamt + gstVal;
    }

    private void Delete(InventoryItemEntryModel i)
    {
        int rowIndex = InitiationModel.ItemsList.IndexOf(i);
        InitiationModel.ItemsList.RemoveAt(rowIndex);
        InitiationModel.TotalAmount = GetTotal();
    }

    private void CloseDialog()
    {
        MudDialog.Close();
    }

    protected void ItemSelected(InventoryItemModel item)
    {
        SelectedItem = item;
        ItemsModel.ItemID = item?.InventoryItemID;
        ItemsModel.ItemDescription = item?.ItemDescription;
        UOM = item?.UoM;
    }
}

