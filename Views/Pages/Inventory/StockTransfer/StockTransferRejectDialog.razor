@inject AuthenticationStateProvider auth
@inject MudBlazor.ISnackbar snackbar
@inject IDialogService DialogService
@inject IStockTransferService IStockTransferService
@using Core.BaseModels.Inventory;

<DialogForm @ref="@dialogForm" Title="Internal Transfer Denegation" Subtitle="Formal rejection of cross-branch inventory movement requests." Icon="@Icons.Material.Filled.TransferWithinAStation" AdminStyle="true" formID="formStockTransferReject" model="@Model" TotalAmount="Model.TotalAmount" _busy="_busy">
    <FormContent>
        <div class="dialog-content-wrapper">
            <div class="admin-glass-card pa-6 mb-6" style="border-left: 4px solid var(--mud-palette-error);">
                <div class="d-flex align-center">
                    <MudIcon Icon="@Icons.Material.Filled.Warning" Color="Color.Error" Class="mr-3" Size="Size.Large" />
                    <div>
                        <MudText Typo="Typo.subtitle1" Class="fw-bold fw-600 color-error">Rejection Authorization</MudText>
                        <MudText Typo="Typo.body2">
                            You are about to reject the stock transfer from <b>@Model.OtherBranchName</b>.
                        </MudText>
                    </div>
                </div>
            </div>

            <EditForm id="formStockTransferReject" Model="@Model" OnValidSubmit="OnValidSubmit">
                <DataAnnotationsValidator />
                
                <div class="admin-glass-card pa-6">
                    <div class="d-flex align-center mb-6">
                        <MudIcon Icon="@Icons.Material.Filled.Comment" Color="Color.Primary" Class="mr-2" />
                        <span class="admin-section-label mb-0">Rejection Justification</span>
                    </div>
                    
                    <MudGrid Spacing="3">
                        <MudItem xs="12">
                            <MudTextField Value="@Model.OtherBranchName" Label="Originating Branch (Reference)" Variant="Variant.Outlined" Margin="Margin.Normal" ReadOnly Class="modern-input" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.AccountTree" Style="background: rgba(0,0,0,0.02);"></MudTextField>
                        </MudItem>
                        <MudItem xs="12">
                            <MudTextField @bind-Value="@Model.Narration" Label="Formal Rejection Narration" Variant="Variant.Outlined" Margin="Margin.Normal" For="@(() => Model.Narration)" Class="modern-input" Lines="4" Placeholder="Provide detailed reasoning for the transfer rejection..."></MudTextField>
                        </MudItem>
                    </MudGrid>
                </div>
            </EditForm>
        </div>
    </FormContent>
    <Actions>
        <MudButton Disabled="@_busy" Variant="Variant.Filled" Color="Color.Error" OnClick="(() => OnValidSubmit(null))" StartIcon="@Icons.Material.Filled.Block" Class="px-12 rounded-pill py-3 shadow-none">Finalize Rejection</MudButton>
    </Actions>
</DialogForm>

@code {

    [Parameter]
    public bool ReadOnly { get; set; }
    [Parameter]
    public StockTransferInitiationModel Model { get; set; }
    DialogForm dialogForm;
    bool _busy;
    int? branchID;
    string UserID;

    protected override async Task OnInitializedAsync()
    {
        var authprov = await auth.GetAuthenticationStateAsync();
        branchID = int.Parse(authprov.User.Claims.First(x => x.Type == "BranchID").Value);
        UserID = authprov.User.Identity.Name;
    }

    public async Task OnValidSubmit(EditContext context)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is being submitted!", Severity.Warning);
            return;
        }
        _busy = true;
        try
        {
            //var authprov = await auth.GetAuthenticationStateAsync();
            //var user = authprov.User;
            Model.UserInfo.UserID = UserID;
            //Model.BranchID = branchID;
            //Model.Narration = Model.Narration;
            //Model.Store = Model.Store;
            //Model.CostCenter = Model.CostCenter;
            //Model.Dimension = Model.Dimension;
            //model.BranchID = branchID;
            //Model.ItemsList = IStockTransferService.SelectItemsList(Model?.StockTransferID).ToList();
            IStockTransferService.RejectOrder(Model);
            snackbar.Add("Order Rejected Successfully", Severity.Success);
            dialogForm.Close(Model);
        }
        catch (Exception ex)
        {
            bool? result = await DialogService.ShowMessageBoxAsync(
                    "Exception!",
                   ex.Message);
        }
        await Task.Delay(200);
        _busy = false;
    }

    private void CloseDialog()
    {
        dialogForm.Cancel();
    }
}
