@page "/StockTransferItem"
@using Core.BaseModels.Inventory;
@using MudBlazor

@using System.Threading;
@attribute [Authorize]
@inject AuthenticationStateProvider auth
@inject IDialogService DialogService
@inject MudBlazor.ISnackbar snackbar
@inject IStockTransferService IStockTransferService
@inject IRoleService<RoleModel> Irole

@if (_isLoading)
{
    <div @key="@("loader")" style="display: flex; justify-content: center; align-items: center; min-height: 400px;">
        <LoaderComponent IsFullScreen="true" 
                        ShowLogo="false" 
                        Size="medium" 
                        LoadingText="Loading Stock Transfers" 
                        SubText="Please wait..." />
    </div>
}
else
{
    <div class="admin-page-container fade-in" @key="@("content")">
        <div class="admin-header-tiered mb-6">
            <div class="d-flex align-center justify-space-between">
                <div>
                    <MudText Typo="Typo.h4" Class="admin-title">Stock Logistics & Transfers</MudText>
                    <MudText Typo="Typo.body2" Class="admin-subtitle">Monitor and manage inter-branch inventory movements and shipment reconciliation.</MudText>
                </div>
                @if (!IsOutComplete)
                {
                    <MudButton Disabled="@_busy" Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.LocalShipping" OnClick="@(()=> EditOutGoing(new StockTransferInitiationModel()))" Class="admin-register-btn">INITIATE TRANSFER</MudButton>
                }
            </div>
        </div>

        <div class="admin-glass-card pa-0 overflow-hidden">
            <MudTabs Elevation="0" Rounded="false" ApplyEffectsToContainer="true" PanelClass="pa-0" Centered="false" Class="modern-tabs">
                <MudTabPanel Text="OUTGOING SHIPMENTS" BadgeData="@(collectionOutGoing?.Count > 0 ? collectionOutGoing.Count : null)" BadgeColor="Color.Primary">
                    <div class="pa-6 border-bottom-subtle bg-light-surface">
                        <MudGrid Spacing="3" Class="align-center">
                            <MudItem xs="12" md="6">
                                <MudTextField @bind-Value="searchvalue" Placeholder="Search by Document Number or Destination..." Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" AdornmentColor="Color.Primary" Variant="Variant.Outlined" Margin="Margin.Dense" Clearable="true" Class="modern-input"></MudTextField>
                            </MudItem>
                            <MudItem xs="12" md="4">
                                <div class="d-flex align-center h-100 px-4 rounded-lg border-subtle bg-white">
                                    <MudCheckBox T="bool" Label="SHOW COMPLETED TRANSFERS" ValueChanged="((bool value)=>CompletedOutgoing(value))" Value="@IsOutComplete" Color="Color.Primary" Dense="true" Class="fw-600" />
                                </div>
                            </MudItem>
                        </MudGrid>
                    </div>

                    <MudTable Items="@collectionOutGoing" Elevation="0" Filter="new Func<StockTransferInitiationModel, bool>(search)" Hover="true" Breakpoint="Breakpoint.Sm" Class="modern-admin-table">
                        <HeaderContent>
                            <MudTh><MudTableSortLabel SortBy="new Func<StockTransferInitiationModel, object>(x=> x.DocumentNumber)" InitialDirection="SortDirection.Descending"><span class="admin-header-text">DOC NO</span></MudTableSortLabel></MudTh>
                            <MudTh><MudTableSortLabel SortBy="new Func<StockTransferInitiationModel, object>(x=> x.OtherBranchName)"><span class="admin-header-text">DESTINATION</span></MudTableSortLabel></MudTh>
                            <MudTh><MudTableSortLabel SortBy="new Func<StockTransferInitiationModel, object>(x=> x.DocumentDate)"><span class="admin-header-text">INITIATED</span></MudTableSortLabel></MudTh>
                            <MudTh><MudTableSortLabel SortBy="new Func<StockTransferInitiationModel, object>(x=> x?.DisplayStatus)"><span class="admin-header-text">STATUS</span></MudTableSortLabel></MudTh>
                            <MudTh Style="text-align: right;"><span class="admin-header-text">ACTIONS</span></MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd DataLabel="Doc No"><span class="admin-td-primary fw-600">@context.DocumentNumber</span></MudTd>
                            <MudTd DataLabel="Destination"><span class="fw-500">@context.OtherBranchName</span></MudTd>
                            <MudTd DataLabel="Date">
                                <div class="d-flex flex-column">
                                    <span class="fw-500">@context.DocumentDate?.ToString("dd MMM yyyy")</span>
                                    @if (IsOutComplete) { <span class="small opa-50">Ended: @context.TransferEndDate?.ToString("dd MMM")</span> }
                                </div>
                            </MudTd>
                            <MudTd DataLabel="Status">
                                <MudChip T="string" Size="Size.Small" Color="@(IsOutComplete ? Color.Success : Color.Info)" Variant="Variant.Text" Class="fw-600">@(IsOutComplete ? context.DisplayCompleteStatus : context.DisplayStatus)</MudChip>
                            </MudTd>
                            <MudTd DataLabel="Actions" Style="text-align: right;">
                                <div class="d-flex justify-end gap-1">
                                    <MudTooltip Text="View Details">
                                        <MudIconButton OnClick="@(()=> Initiate(context,true))" Color="Color.Primary" Icon="@Icons.Material.Filled.GridView" Size="Size.Small" Variant="Variant.Text" />
                                    </MudTooltip>
                                    @if (context.Status is null && !IsOutComplete)
                                    {
                                        <MudTooltip Text="Cancel Transfer">
                                            <MudIconButton Disabled="@(context.MID != null)" OnClick="@(()=> DeleteOutGoing(context))" Color="Color.Error" Icon="@Icons.Material.Filled.Close" Size="Size.Small" Variant="Variant.Text" />
                                        </MudTooltip>
                                    }
                                    <MudTooltip Text="Verify Stock">
                                        <MudIconButton Disabled="@(context.MID != null)" OnClick="@(()=> Initiate(context,true))" Color="Color.Warning" Icon="@Icons.Material.Filled.VerifiedUser" Size="Size.Small" Variant="Variant.Text" />
                                    </MudTooltip>
                                    <MudTooltip Text="Print Documentation">
                                        <MudIconButton OnClick="@(()=> Print(context.StockTransferID,(context.AuthLevelId == 99) ? "TAX INVOICE" : "PROFORMA INVOICE"))" Color="Color.Secondary" Icon="@Icons.Material.Filled.Print" Size="Size.Small" Variant="Variant.Text" />
                                    </MudTooltip>
                                </div>
                            </MudTd>
                        </RowTemplate>
                        <PagerContent><div class="pa-4"><MudTablePager /></div></PagerContent>
                    </MudTable>
                </MudTabPanel>

                <MudTabPanel Text="INCOMING SHIPMENTS" BadgeData="@(collectionInComing?.Count > 0 ? collectionInComing.Count : null)" BadgeColor="Color.Secondary">
                    <div class="pa-6 border-bottom-subtle bg-light-surface">
                        <MudGrid Spacing="3" Class="align-center">
                            <MudItem xs="12" md="6">
                                <MudTextField @bind-Value="searchvalue" Placeholder="Search incoming logistics..." Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" AdornmentColor="Color.Primary" Variant="Variant.Outlined" Margin="Margin.Dense" Clearable="true" Class="modern-input"></MudTextField>
                            </MudItem>
                            <MudItem xs="12" md="4">
                                <div class="d-flex align-center h-100 px-4 rounded-lg border-subtle bg-white">
                                    <MudCheckBox T="bool" Label="SHOW RECEIVED SHIPMENTS" ValueChanged="((bool value)=>CompletedIncoming(value))" Value="@IsIncomingComplete" Color="Color.Primary" Dense="true" Class="fw-600" />
                                </div>
                            </MudItem>
                        </MudGrid>
                    </div>

                    <MudTable Items="@collectionInComing" Elevation="0" Filter="new Func<StockTransferInitiationModel, bool>(search)" Hover="true" Breakpoint="Breakpoint.Sm" Class="modern-admin-table">
                        <HeaderContent>
                            <MudTh><MudTableSortLabel SortBy="new Func<StockTransferInitiationModel, object>(x=> x.OtherBranchName)"><span class="admin-header-text">ORIGIN</span></MudTableSortLabel></MudTh>
                            <MudTh><MudTableSortLabel SortBy="new Func<StockTransferInitiationModel, object>(x=> x.DocumentNumber)"><span class="admin-header-text">DOC NO</span></MudTableSortLabel></MudTh>
                            <MudTh><MudTableSortLabel SortBy="new Func<StockTransferInitiationModel, object>(x=> x.DocumentDate)"><span class="admin-header-text">DISPATCHED</span></MudTableSortLabel></MudTh>
                            <MudTh><MudTableSortLabel SortBy="new Func<StockTransferInitiationModel, object>(x=> x?.DisplayStatus)"><span class="admin-header-text">STATUS</span></MudTableSortLabel></MudTh>
                            <MudTh Style="text-align: right;"><span class="admin-header-text">ACTIONS</span></MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd DataLabel="Origin"><span class="fw-600">@context.OtherBranchName</span></MudTd>
                            <MudTd DataLabel="Doc No"><span class="admin-td-primary fw-600">@context.DocumentNumber</span></MudTd>
                            <MudTd DataLabel="Date">
                                <div class="d-flex flex-column">
                                    <span class="fw-500">@context.DocumentDate?.ToString("dd MMM yyyy")</span>
                                    @if (IsIncomingComplete) { <span class="small opa-50">Received: @context.TransferEndDate?.ToString("dd MMM")</span> }
                                </div>
                            </MudTd>
                            <MudTd DataLabel="Status">
                                <MudChip T="string" Size="Size.Small" Color="@(IsIncomingComplete ? Color.Success : Color.Warning)" Variant="Variant.Text" Class="fw-600">@(IsIncomingComplete ? context.DisplayCompleteStatus : context.DisplayStatus)</MudChip>
                            </MudTd>
                            <MudTd DataLabel="Actions" Style="text-align: right;">
                                <div class="d-flex justify-end gap-1">
                                    @if (IsIncomingComplete)
                                    {
                                        <MudTooltip Text="View Received Items">
                                            <MudIconButton OnClick="@(()=> Initiate(context,true))" Color="Color.Primary" Icon="@Icons.Material.Filled.GridView" Size="Size.Small" Variant="Variant.Text" />
                                        </MudTooltip>
                                    }
                                    else
                                    {
                                        <MudTooltip Text="Accept Delivery">
                                            <MudIconButton OnClick="@(()=> Deliver(context,false))" Color="Color.Success" Icon="@Icons.Material.Filled.CheckCircle" Size="Size.Small" Variant="Variant.Text" />
                                        </MudTooltip>
                                        @if (context.Status != 3 && context.DisplayStatus != "Cancelled")
                                        {
                                            <MudTooltip Text="Reject Shipment">
                                                <MudIconButton OnClick="@(()=> Reject(context))" Color="Color.Error" Icon="@Icons.Material.Filled.Cancel" Size="Size.Small" Variant="Variant.Text" />
                                            </MudTooltip>
                                        }
                                    }
                                    <MudTooltip Text="Print Invoice">
                                        <MudIconButton OnClick="@(()=> Print(context.StockTransferID,(context.AuthLevelId == 99) ? "TAX INVOICE" : "PROFORMA INVOICE"))" Color="Color.Secondary" Icon="@Icons.Material.Filled.Print" Size="Size.Small" Variant="Variant.Text" />
                                    </MudTooltip>
                                </div>
                            </MudTd>
                        </RowTemplate>
                        <PagerContent><div class="pa-4"><MudTablePager /></div></PagerContent>
                    </MudTable>
                </MudTabPanel>
            </MudTabs>
        </div>
    </div>
}



@code {

    private bool _isLoading = true;
    private DateTime _loadStartTime;

    private List<StockTransferInitiationModel> collectionOutGoing = new();
    private List<StockTransferInitiationModel> CompleteOutgoing = new();
    private StockTransferInitiationModel model = new StockTransferInitiationModel();
    public bool IsOutComplete { get; set; } = false;
    public bool IsIncomingComplete { get; set; } = false;
    public int? branchID { get; set; }
    private bool _busy;
    private string searchvalue = "";

    public bool HasPermissionStockTransferServiceCancel { get; set; } = false;
    public bool HasPermissionStockTransferServiceReject { get; set; } = false;
    public int DocTypeID = 66;

    protected override async Task OnInitializedAsync()
    {
        _loadStartTime = DateTime.Now;
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionStockTransferServiceCancel = await Irole.HasClaim(DocTypeID.ToString(), "Cancel", ctc.Token);
        HasPermissionStockTransferServiceReject = await Irole.HasClaim(DocTypeID.ToString(), "Reject", ctc.Token);

        var authprov = await auth.GetAuthenticationStateAsync();
        branchID = int.Parse(authprov.User.Claims.First(x => x.Type == "BranchID").Value);
        model = new();

        await GetAll();
        await EnsureMinimumLoadTime();
        _isLoading = false;
    }

    private async Task EnsureMinimumLoadTime()
    {
        var elapsed = (DateTime.Now - _loadStartTime).TotalMilliseconds;
        if (elapsed < 100)
        {
            await Task.Delay(100 - (int)elapsed);
        }
    }

    private async Task GetAll()
    {
        collectionOutGoing = IStockTransferService.SelectOutGoing(branchID).ToList();
        collectionInComing = IStockTransferService.SelectIncoming(branchID).ToList();
    }

    async Task CompletedOutgoing(bool value)
    {
        IsOutComplete = value;
        @if (IsOutComplete)
        {
            collectionOutGoing = IStockTransferService.SelectCompletedOutGoing(branchID).ToList();
        }
        else
        {
            collectionOutGoing = IStockTransferService.SelectOutGoing(branchID).ToList();
        }
    }

    async Task CompletedIncoming(bool value)
    {
        IsIncomingComplete = value;
        @if (IsIncomingComplete)
        {
            collectionInComing = IStockTransferService.SelectCompletedIncoming(branchID).ToList();
        }
        else
        {
            collectionInComing = IStockTransferService.SelectIncoming(branchID).ToList();
        }
    }

    //================== CollectionOutGoing Functions ==================//

    private async Task EditOutGoing(StockTransferInitiationModel model)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        _busy = true;
        DialogParameters parms = new DialogParameters();
        parms.Add("InitiationModel", model.Clone());
        parms.Add("ReadOnly", false);
        //parms.Add("IsEdit", Edit);
        DialogOptions maxWidth = new DialogOptions() { MaxWidth = MaxWidth.Large, FullWidth = true };
        var dialog = await DialogService.ShowAsync<StockTransferInitiateDialog>(model.InvTranID == null ? "ADD" : "EDIT", parms, maxWidth);
        var result = await dialog.Result;
        if (!result.Canceled)
        {
            StockTransferInitiationModel UpatedModel = (StockTransferInitiationModel)result.Data;
            //model.UserInfo.UserID = user.Identity.Name;
            try
            {
                //Iservice.Update(UpatedModel);
                model = new();
                snackbar.Add("Saved Successfully", Severity.Success);
                model = new StockTransferInitiationModel();
            }
            catch (Exception ex)
            {
                snackbar.Add(ex.Message, Severity.Warning);
            }
        }
        await GetAll();
        await Task.Delay(200);
        _busy = false;
    }

    private async Task DeleteOutGoing(StockTransferInitiationModel model)
    {
        if (HasPermissionStockTransferServiceCancel)
        {
            bool? result = await DialogService.ShowMessageBoxAsync(
                "Warning !",
                "Are you sure you want to Cancel this StockTransfer to " + model.OtherBranchName + "?");
            @if (result == true)
            {
                var authprov = await auth.GetAuthenticationStateAsync();
                var user = authprov.User;
                IStockTransferService.TransferCancel(model.StockTransferID, user.Identity.Name);
                snackbar.Add("Deleted Successfully", Severity.Success);
            }
            await GetAll();
        }
        else
        {
            bool? result = await DialogService.ShowMessageBoxAsync(
                "Permission denied!",
                "You don't have any permission to Cancel StockTransfer.");
        }
    }

    //==================================================================//

    private List<StockTransferInitiationModel> collectionInComing = new();
    private List<StockTransferInitiationModel> CompleteIncoming = new();
    public StoreModel SelectedStore { get; set; } = new();

    private void StoreChanged(StoreModel obj)
    {
        SelectedStore = obj;
    }

    private async Task Initiate(StockTransferInitiationModel model, bool ReadOnly)
    {
        DialogParameters parms = new DialogParameters();
        parms.Add("InitiationModel", model.Clone());
        parms.Add("ReadOnly", ReadOnly);
        DialogOptions maxWidth = new DialogOptions() { MaxWidth = MaxWidth.Large, FullWidth = true };
        var dialog = await DialogService.ShowAsync<StockTransferInitiateDialog>("Stock-Transfer", parms, maxWidth);
        var result = await dialog.Result;
        if (!result.Canceled)
        {
            await GetAll();
        }
    }

    private async Task Deliver(StockTransferInitiationModel model, bool ReadOnly)
    {
        DialogParameters parms = new DialogParameters();
        var endModel = new StockTransferEndModel()
            {
                StockTransferID = model.StockTransferID,
                BranchID = branchID,
                OtherBranchName = model.OtherBranchName,
                OtherBranchID = model.OtherBranchID,
                NatureOfTransaction = "StockTransferIN",
                DocumentNumber = model.DocumentNumber
            };

        parms.Add("ReadOnly", ReadOnly);
        parms.Add("IsTaxable", model.IsTaxable);
        parms.Add("Model", endModel);
        DialogOptions maxWidth = new DialogOptions() { MaxWidth = MaxWidth.ExtraLarge, FullWidth = true };
        var dialog = await DialogService.ShowAsync<StockTransferEndDialog>("Stock-Transfer", parms, maxWidth);
        var result = await dialog.Result;
        if (!result.Canceled)
        {
            await GetAll();
        }
    }

    //================== CollectionInComing Functions ==================//

    // private async Task Accept(StockTransferInitiationModel StockTransferEndModel)
    // {

    // }

    private async Task Reject(StockTransferInitiationModel model)
    {
        if (HasPermissionStockTransferServiceReject)
        {
            bool? result = await DialogService.ShowMessageBoxAsync(
                "Warning !",
                "Are you sure you want to Reject this Order ?");
            @if (result == true)
            {
                DialogParameters parms = new DialogParameters();
                var endModel = new StockTransferInitiationModel()
                    {
                        StockTransferID = model.StockTransferID,
                        BranchID = branchID,
                        OtherBranchName = model.OtherBranchName,
                        OtherBranchID = model.OtherBranchID,
                        NatureOfTransaction = "StockTransferOut",
                        DocumentNumber = model.DocumentNumber,
                        CostCenter = model.CostCenter,
                        Dimension = model.Dimension,
                        ItemsList = IStockTransferService.SelectItemsList(model?.StockTransferID).ToList(),
                        InvTranID = model.InvTranID,
                        Store = model.Store,
                        MID = model.MID,
                        UserInfo = model.UserInfo
                    };
                parms.Add("Model", endModel);
                var dialog = await DialogService.ShowAsync<StockTransferRejectDialog>("Stock-Transfer", parms);
                var result1 = await dialog.Result;
                if (!result1.Canceled)
                {
                    await GetAll();
                }
            }
            await GetAll();
        }
        else
        {
            bool? result = await DialogService.ShowMessageBoxAsync(
                "Permission denied!",
                "You don't have any permission to Reject StockTransfer.");
        }
    }

    //==================================================================//

    public Dictionary<string, string> ReportParameters { get; set; } = new();

    private async Task Print(int? StockTransferID, string Title)
    {
        ReportParameters.Clear();
        ReportParameters.Add("StockTransferID", StockTransferID.ToString());
        var parameters = new DialogParameters();
        parameters.Add("Parameters", ReportParameters); // Add the dictionary as a parameter
        parameters.Add("ReportName", "PrintStockTransferInvoice");

        DialogOptions maxWidth = new DialogOptions() { MaxWidth = MaxWidth.Medium, FullWidth = true };
        var result = await DialogService.ShowAsync<PrintDialog>("PRINT", parameters, maxWidth);
    }

    private bool search(StockTransferInitiationModel model)
    {
        if (model.DocumentNumber != null && model.DocumentNumber.Contains(searchvalue, StringComparison.OrdinalIgnoreCase))
        {
            return true;
        }
        return false;
    }
}

