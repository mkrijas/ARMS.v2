@page "/StockTransferItem"

@using Core.BaseModels.Inventory;
@inject IDialogService DialogService
@inject MudBlazor.ISnackbar snackbar



<MudGrid Spacing="4">
    <MudItem xs="12">
        <MudTabs Elevation="2" Rounded="true" ApplyEffectsToContainer="true" PanelClass="pa-6">

            <MudTabPanel Text="Stock Transfer Outgoing">
                <MudTable Items="@collectionOutGoing" Dense="true" Hover="true" Striped="true" Elevation="0">
                    <ToolBarContent>
                        <MudText Typo="Typo.h6">Initiate Stock Transfer</MudText>
                        <MudTooltip Text="New Stock Transfer">
                            <MudIconButton Icon="@Icons.Material.Filled.Add" @onclick="@(()=> OpenDialogEditOutGoing(model))" Title="Add" Color="Color.Dark" Size="Size.Small"></MudIconButton>
                        </MudTooltip>
                        <MudSpacer></MudSpacer>
                    </ToolBarContent>
                    <HeaderContent>
                        <MudTh>Destination Branch</MudTh>
                        <MudTh>Initiated Date</MudTh>
                        <MudTh>Status</MudTh>
                        <MudTh>Actions</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="Destination Branch">@context</MudTd>
                        <MudTd DataLabel="Initiated Date">@context</MudTd>
                        <MudTd DataLabel="Status">@context</MudTd>
                        <MudTd DataLabel="Actions">
                            <MudTooltip Text="Edit">
                                <MudIconButton @onclick="@(()=> OpenDialogEditOutGoing(context))" Color="Color.Primary" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" IconSize="Size.Small" />
                            </MudTooltip>
                            <MudTooltip Text="Remove">
                                <MudIconButton @onclick="@(()=> OpenDialogDeleteOutGoing(context))" Color="Color.Primary" Icon="@Icons.Material.Filled.Remove" Size="Size.Small" IconSize="Size.Small" />
                            </MudTooltip>
                        </MudTd>
                    </RowTemplate>
                    <PagerContent>
                        <MudTablePager PageSizeOptions="new int[] { 5, 10, 20, 50, 100 }" />
                    </PagerContent>
                </MudTable>
            </MudTabPanel>


            <MudTabPanel Text="Stock Transfer Incoming">
                <MudTable Items="@collectionInComing" Dense="true" Hover="true" Striped="true" Elevation="0">
                    <HeaderContent>
                        <MudTh>Item</MudTh>
                        <MudTh>Initiated Store</MudTh>
                        <MudTh>Initiated Date</MudTh>
                        <MudTh>Quantity</MudTh>
                        <MudTh>Amount</MudTh>
                        <MudTh>Actions</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="Item">@context</MudTd>
                        <MudTd DataLabel="Initiated Store">@context</MudTd>
                        <MudTd DataLabel="Initiated Date">@context</MudTd>
                        <MudTd DataLabel="Quantity">@context</MudTd>
                        <MudTd DataLabel="Amount">@context</MudTd>
                        <MudTd DataLabel="Actions">
                            <MudTooltip Text="Edit">
                                <MudIconButton @onclick="@(()=> OpenDialogEditIncoming(context))" Color="Color.Primary" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" IconSize="Size.Small" />
                            </MudTooltip>
                        </MudTd>
                    </RowTemplate>
                    <PagerContent>
                        <MudTablePager PageSizeOptions="new int[] { 5, 10, 20, 50, 100 }" />
                    </PagerContent>
                </MudTable>
            </MudTabPanel>

        </MudTabs>
    </MudItem>
</MudGrid>


