@page "/StockTransferItem"
@using Core.BaseModels.Inventory;
@using MudBlazor

@using System.Threading;
@attribute [Authorize]
@inject AuthenticationStateProvider auth
@inject IDialogService DialogService
@inject MudBlazor.ISnackbar snackbar
@inject IStockTransferService IStockTransferService
@inject IRoleService<RoleModel> Irole

<MudGrid Spacing="4">
    <MudItem xs="12">
        <MudTabs Elevation="2" Rounded="true" ApplyEffectsToContainer="true" PanelClass="px-4 py-6">
            <MudTabPanel Style="min-width: 200px;" Text="Outgoing Stock" BadgeData="@(collectionOutGoing?.Count > 0 ? collectionOutGoing.Count : null)" BadgeColor="Color.Info" Visible="@(collectionOutGoing?.Count > 0)">
                <MudTable Items="@collectionOutGoing" Dense="true" Hover="true" Striped="true" Elevation="0" Filter="new Func<StockTransferInitiationModel, bool>(search)">
                    <ToolBarContent>
                        @if (!IsOutComplete)
                        {
                            <MudText Typo="Typo.h6">Initiate Stock Transfer</MudText>
                            <MudTooltip Text="New Stock Transfer">
                                <MudIconButton Disabled="@_busy" Icon="@Icons.Material.Filled.Add" @onclick="@(()=> EditOutGoing(new StockTransferInitiationModel()))" Title="Add" Color="Color.Dark" Size="Size.Small"></MudIconButton>
                            </MudTooltip>
                        }
                        else
                        {
                            <MudText Typo="Typo.h6">Completed Transfer</MudText>
                        }
                        <MudSpacer></MudSpacer>
                        <MudTextField @bind-Value="searchvalue" Placeholder="Search... " Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0"></MudTextField>
                        <MudCheckBox T="bool" Style="margin-right: 16px;" Label="Completed Transfers" ValueChanged="((bool value)=>CompletedOutgoing(value))" Value="@IsOutComplete"></MudCheckBox>
                    </ToolBarContent>
                    <HeaderContent>
                        <MudTh><MudTableSortLabel SortBy="new Func<StockTransferInitiationModel, object>(x=> x.DocumentNumber)" InitialDirection="SortDirection.Descending">Document Number</MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<StockTransferInitiationModel, object>(x=> x.OtherBranchName)" InitialDirection="SortDirection.Descending">Destination Branch</MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<StockTransferInitiationModel, object>(x=> x.DocumentDate)" InitialDirection="SortDirection.Descending">Initiated Date</MudTableSortLabel></MudTh>
                        @if (IsOutComplete)
                        {
                            <MudTh><MudTableSortLabel SortBy="new Func<StockTransferInitiationModel, object>(x=> x.TransferEndDate)" InitialDirection="SortDirection.Descending">TransferEnd Date</MudTableSortLabel></MudTh>
                        }
                        <MudTh><MudTableSortLabel SortBy="new Func<StockTransferInitiationModel, object>(x=> x?.DisplayStatus)" InitialDirection="SortDirection.Descending">Status</MudTableSortLabel></MudTh>
                        <MudTh>Actions</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="Document Number">@context.DocumentNumber</MudTd>
                        <MudTd DataLabel="Destination Branch">@context.OtherBranchName</MudTd>
                        <MudTd DataLabel="Initiated Date">@context.DocumentDate</MudTd>
                        @if (IsOutComplete)
                        {
                            <MudTd DataLabel="TransferEnd Date">@context.TransferEndDate</MudTd>
                            <MudTd DataLabel="Status">@context.DisplayCompleteStatus</MudTd>
                        }
                        else if (!IsOutComplete)
                        {
                            <MudTd DataLabel="Status">@context?.DisplayStatus</MudTd>
                        }
                        <MudTd DataLabel="Actions">
                            <MudIconButton @onclick="@(()=> Initiate(context,true))" Color="Color.Primary" Icon="@Icons.Material.Filled.GridView" Title="View" Size="Size.Small" Variant="Variant.Filled" />
                            @if (context.Status is null && !IsOutComplete)
                            {
                                @* <MudTooltip Text="Edit">
                            <MudFab @onclick="@(()=> EditOutGoing(context))" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Edit" Size="Size.Small" />
                            </MudTooltip> *@
                                <MudIconButton Disabled="@(context.MID != null)" @onclick="@(()=> DeleteOutGoing(context))" Color="Color.Error" Icon="@Icons.Material.Filled.Remove" Title="Remove" Size="Size.Small" Variant="Variant.Filled" />
                            }
                            <MudIconButton Disabled="@(context.MID != null)" OnClick="@(()=> Initiate(context,true))" Color="Color.Warning" Icon="@Icons.Material.Filled.Verified" Title="Verify" Size="Size.Small" Variant="Variant.Filled" />
                            <MudIconButton OnClick="@(()=> Print(context.StockTransferID,(context.AuthLevelId == 99) ? "TAX INVOICE" : "PROFORMA INVOICE"))" Color="Color.Tertiary" Title="Print Performa Invoice" Class="ml-2" Icon="@Icons.Material.Filled.Print" Size="Size.Small" Variant="Variant.Filled" />
                        </MudTd>
                    </RowTemplate>
                    <PagerContent>
                        <MudTablePager PageSizeOptions="new int[] { 10, 20, 50, 100 }" />
                    </PagerContent>
                </MudTable>
            </MudTabPanel>
            <MudTabPanel Style="min-width: 200px;" Text="Incoming Stock" BadgeData="@(collectionInComing?.Count > 0 ? collectionInComing.Count : null)" BadgeColor="Color.Info" Visible="@(collectionInComing?.Count > 0)">
                <MudTable Items="@collectionInComing" Dense="true" Hover="true" Striped="true" Elevation="0" Filter="new Func<StockTransferInitiationModel, bool>(search)">
                    <ToolBarContent>
                        @if (!IsIncomingComplete)
                        {
                            <MudText Typo="Typo.h6">Incoming Transfer</MudText>
                        }
                        else
                        {
                            <MudText Typo="Typo.h6">Received Stock Transfer</MudText>
                        }
                        <MudSpacer></MudSpacer>
                        <MudTextField @bind-Value="searchvalue" Placeholder="Search... " Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0"></MudTextField>
                        <MudCheckBox T="bool" Style="margin-right: 16px;" Label="Received Transfers" ValueChanged="((bool value)=>CompletedIncoming(value))" Value="@IsIncomingComplete"></MudCheckBox>
                    </ToolBarContent>

                    <HeaderContent>
                        <MudTh><MudTableSortLabel SortBy="new Func<StockTransferInitiationModel, object>(x=> x.OtherBranchName)" InitialDirection="SortDirection.Descending">Initiated Branch</MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<StockTransferInitiationModel, object>(x=> x.DocumentDate)" InitialDirection="SortDirection.Descending">Initiated Date</MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<StockTransferInitiationModel, object>(x=> x.DocumentNumber)" InitialDirection="SortDirection.Descending">Document Number</MudTableSortLabel></MudTh>
                        @if (IsIncomingComplete)
                        {
                            <MudTh><MudTableSortLabel SortBy="new Func<StockTransferInitiationModel, object>(x=> x.TransferEndDate)" InitialDirection="SortDirection.Descending">TransferEnd Date</MudTableSortLabel></MudTh>
                        }
                        <MudTh><MudTableSortLabel SortBy="new Func<StockTransferInitiationModel, object>(x=> x.TransferEndDate)" InitialDirection="SortDirection.Descending">TransferEnd Date</MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<StockTransferInitiationModel, object>(x=> x?.DisplayStatus)" InitialDirection="SortDirection.Descending">Status</MudTableSortLabel></MudTh>
                        <MudTh>Actions</MudTh>
                    </HeaderContent>

                    <RowTemplate>
                        <MudTd DataLabel="Initiated Branch">@context.OtherBranchName</MudTd>
                        <MudTd DataLabel="Initiated Date">@context.DocumentDate</MudTd>
                        <MudTd DataLabel="Document Number">@context.DocumentNumber</MudTd>
                        @if (IsIncomingComplete)
                        {
                            <MudTd DataLabel="TransferEnd Date">@context.TransferEndDate</MudTd>
                            <MudTd DataLabel="Status">@context.DisplayCompleteStatus</MudTd>
                        }
                        else if (!IsIncomingComplete)
                        {
                            <MudTd DataLabel="Status">@context?.DisplayStatus</MudTd>
                        }
                        <MudTd DataLabel="Actions">
                            @if (IsIncomingComplete)
                            {
                                <MudTooltip Text="View Items">
                                    <MudFab @onclick="@(()=> Initiate(context,true))" Color="Color.Primary" StartIcon="@Icons.Material.Filled.GridView" Size="Size.Small" />
                                </MudTooltip>
                            }
                            else
                            {
                                <MudTooltip Text="View and Accept">
                                    <MudIconButton @onclick="@(()=> Deliver(context,false))" Color="Color.Primary" Icon="@Icons.Material.Outlined.Check" Size="Size.Small" IconSize="Size.Small" />
                                </MudTooltip>
                                @if (context.Status != 3)  @*|| context.EndModel.TransferStatus == 3 || context.EndModel.TransferStatus == 0)*@
                                {
                                    if (context.DisplayStatus != "Cancelled")
                                    {
                                        @* <MudTooltip Text="Edit">
                            <MudFab @onclick="@(()=> Accept(context))" Color="Color.Success" StartIcon="@Icons.Material.Filled.Check" Size="Size.Small" />
                            </MudTooltip> *@
                                        <MudTooltip Text="Cancel Incoming">
                                            <MudIconButton @onclick="@(()=> Reject(context))" Color="Color.Error" Icon="@Icons.Material.Filled.Close" Size="Size.Small" IconSize="Size.Small" />
                                        </MudTooltip>
                                    }
                                }
                            }
                            <MudIconButton OnClick="@(()=> Print(context.StockTransferID,(context.AuthLevelId == 99) ? "TAX INVOICE" : "PROFORMA INVOICE"))" Color="Color.Tertiary" Title="Print Performa Invoice" Class="ml-2" Icon="@Icons.Material.Filled.Print" Size="Size.Small" Variant="Variant.Filled" />
                        </MudTd>
                    </RowTemplate>
                    <PagerContent>
                        <MudTablePager PageSizeOptions="new int[] { 10, 20, 50, 100 }" />
                    </PagerContent>
                </MudTable>
            </MudTabPanel>
        </MudTabs>
    </MudItem>
</MudGrid>

@code {

    private List<StockTransferInitiationModel> collectionOutGoing = new();
    private List<StockTransferInitiationModel> CompleteOutgoing = new();
    private StockTransferInitiationModel model = new StockTransferInitiationModel();
    public bool IsOutComplete { get; set; } = false;
    public bool IsIncomingComplete { get; set; } = false;
    public int? branchID { get; set; }
    private bool _busy;
    private string searchvalue = "";

    public bool HasPermissionStockTransferServiceCancel { get; set; } = false;
    public bool HasPermissionStockTransferServiceReject { get; set; } = false;
    public int DocTypeID = 66;

    protected override async Task OnInitializedAsync()
    {
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionStockTransferServiceCancel = await Irole.HasClaim(DocTypeID.ToString(), "Cancel", ctc.Token);
        HasPermissionStockTransferServiceReject = await Irole.HasClaim(DocTypeID.ToString(), "Reject", ctc.Token);

        var authprov = await auth.GetAuthenticationStateAsync();
        branchID = int.Parse(authprov.User.Claims.First(x => x.Type == "BranchID").Value);
        model = new();

        await GetAll();
    }

    private async Task GetAll()
    {
        collectionOutGoing = IStockTransferService.SelectOutGoing(branchID).ToList();
        collectionInComing = IStockTransferService.SelectIncoming(branchID).ToList();
    }

    async Task CompletedOutgoing(bool value)
    {
        IsOutComplete = value;
        @if (IsOutComplete)
        {
            collectionOutGoing = IStockTransferService.SelectCompletedOutGoing(branchID).ToList();
        }
        else
        {
            collectionOutGoing = IStockTransferService.SelectOutGoing(branchID).ToList();
        }
    }

    async Task CompletedIncoming(bool value)
    {
        IsIncomingComplete = value;
        @if (IsIncomingComplete)
        {
            collectionInComing = IStockTransferService.SelectCompletedIncoming(branchID).ToList();
        }
        else
        {
            collectionInComing = IStockTransferService.SelectIncoming(branchID).ToList();
        }
    }

    //================== CollectionOutGoing Functions ==================//

    private async Task EditOutGoing(StockTransferInitiationModel model)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        _busy = true;
        DialogParameters parms = new DialogParameters();
        parms.Add("InitiationModel", model.Clone());
        parms.Add("ReadOnly", false);
        //parms.Add("IsEdit", Edit);
        var dialog = DialogService.Show<StockTransferInitiateDialog>(model.InvTranID == null ? "ADD" : "EDIT", parms);
        var result = await dialog.Result;
        if (!result.Canceled)
        {
            StockTransferInitiationModel UpatedModel = (StockTransferInitiationModel)result.Data;
            //model.UserInfo.UserID = user.Identity.Name;
            try
            {
                //Iservice.Update(UpatedModel);
                model = new();
                snackbar.Add("Saved Successfully", Severity.Success);
                model = new StockTransferInitiationModel();
            }
            catch (Exception ex)
            {
                snackbar.Add(ex.Message, Severity.Warning);
            }
        }
        await GetAll();
        await Task.Delay(200);
        _busy = false;
    }

    private async Task DeleteOutGoing(StockTransferInitiationModel model)
    {
        if (HasPermissionStockTransferServiceCancel)
        {
            bool? result = await DialogService.ShowMessageBox(
                "Warning !",
                "Are you sure you want to Cancel this StockTransfer to " + model.OtherBranchName + "?");
            @if (result == true)
            {
                var authprov = await auth.GetAuthenticationStateAsync();
                var user = authprov.User;
                IStockTransferService.TransferCancel(model.StockTransferID, user.Identity.Name);
                snackbar.Add("Deleted Successfully", Severity.Success);
            }
            await GetAll();
        }
        else
        {
            bool? result = await DialogService.ShowMessageBox(
                "Permission denied!",
                "You don't have any permission to Cancel StockTransfer.");
        }
    }

    //==================================================================//

    private List<StockTransferInitiationModel> collectionInComing = new();
    private List<StockTransferInitiationModel> CompleteIncoming = new();
    public StoreModel SelectedStore { get; set; } = new();

    private void StoreChanged(StoreModel obj)
    {
        SelectedStore = obj;
    }

    private async Task Initiate(StockTransferInitiationModel model, bool ReadOnly)
    {
        DialogParameters parms = new DialogParameters();
        parms.Add("InitiationModel", model.Clone());
        parms.Add("ReadOnly", ReadOnly);
        var dialog = DialogService.Show<StockTransferInitiateDialog>("Stock-Transfer", parms);
        var result = await dialog.Result;
        if (!result.Canceled)
        {
            await GetAll();
        }
    }

    private async Task Deliver(StockTransferInitiationModel model, bool ReadOnly)
    {
        DialogParameters parms = new DialogParameters();
        var endModel = new StockTransferEndModel()
            {
                StockTransferID = model.StockTransferID,
                BranchID = branchID,
                OtherBranchName = model.OtherBranchName,
                OtherBranchID = model.OtherBranchID,
                NatureOfTransaction = "StockTransferIN",
                DocumentNumber = model.DocumentNumber
            };

        parms.Add("ReadOnly", ReadOnly);
        parms.Add("IsTaxable", model.IsTaxable);
        parms.Add("Model", endModel);
        var dialog = DialogService.Show<StockTransferEndDialog>("Stock-Transfer", parms);
        var result = await dialog.Result;
        if (!result.Canceled)
        {
            await GetAll();
        }
    }

    //================== CollectionInComing Functions ==================//

    // private async Task Accept(StockTransferInitiationModel StockTransferEndModel)
    // {

    // }

    private async Task Reject(StockTransferInitiationModel model)
    {
        if (HasPermissionStockTransferServiceReject)
        {
            bool? result = await DialogService.ShowMessageBox(
                "Warning !",
                "Are you sure you want to Reject this Order ?");
            @if (result == true)
            {
                DialogParameters parms = new DialogParameters();
                var endModel = new StockTransferInitiationModel()
                    {
                        StockTransferID = model.StockTransferID,
                        BranchID = branchID,
                        OtherBranchName = model.OtherBranchName,
                        OtherBranchID = model.OtherBranchID,
                        NatureOfTransaction = "StockTransferOut",
                        DocumentNumber = model.DocumentNumber,
                        CostCenter = model.CostCenter,
                        Dimension = model.Dimension,
                        ItemsList = IStockTransferService.SelectItemsList(model?.StockTransferID).ToList(),
                        InvTranID = model.InvTranID,
                        Store = model.Store,
                        MID = model.MID,
                        UserInfo = model.UserInfo
                    };
                parms.Add("Model", endModel);
                var dialog = DialogService.Show<StockTransferRejectDialog>("Stock-Transfer", parms);
                var result1 = await dialog.Result;
                if (!result1.Canceled)
                {
                    await GetAll();
                }
            }
            await GetAll();
        }
        else
        {
            bool? result = await DialogService.ShowMessageBox(
                "Permission denied!",
                "You don't have any permission to Reject StockTransfer.");
        }
    }

    //==================================================================//

    public Dictionary<string, string> ReportParameters { get; set; } = new();

    private async Task Print(int? StockTransferID, string Title)
    {
        ReportParameters.Clear();
        ReportParameters.Add("StockTransferID", StockTransferID.ToString());
        var parameters = new DialogParameters();
        parameters.Add("Parameters", ReportParameters); // Add the dictionary as a parameter
        parameters.Add("ReportName", "PrintStockTransferInvoice");

        DialogOptions maxWidth = new DialogOptions() { MaxWidth = MaxWidth.Medium, FullWidth = true };
        var result = DialogService.Show<PrintDialog>("PRINT", parameters, maxWidth);
    }

    private bool search(StockTransferInitiationModel model)
    {
        if (model.DocumentNumber != null && model.DocumentNumber.Contains(searchvalue, StringComparison.OrdinalIgnoreCase))
        {
            return true;
        }
        return false;
    }
}

