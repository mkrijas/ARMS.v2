@page "/StockTransferItem"

@using Core.BaseModels.Inventory;
@using MudBlazor
@using MudBlazor.Services

@attribute [Authorize]
@inject IDialogService DialogService
@inject MudBlazor.ISnackbar snackbar
@inject AuthenticationStateProvider auth
@inject IStockTransferService IStockTransferService

<MudGrid Spacing="4">
    <MudItem xs="12">
        <MudTabs Elevation="2" Rounded="true" ApplyEffectsToContainer="true" PanelClass="px-4 py-6">
            <MudTabPanel Style="min-width: 200px;" Text="Outgoing Stock" BadgeData="@(collectionOutGoing?.Count > 0 ? collectionOutGoing.Count : null)" BadgeColor="Color.Info" Visible="@(collectionOutGoing?.Count > 0)">
                <MudTable Items="@collectionOutGoing" Dense="true" Hover="true" Striped="true" Elevation="0">
                    <ToolBarContent>
                        <MudText Typo="Typo.h6">Initiate Stock Transfer</MudText>
                        <MudTooltip Text="New Stock Transfer">
                            <MudIconButton Icon="@Icons.Material.Filled.Add" @onclick="@(()=> EditOutGoing(new StockTransferInitiationModel()))" Title="Add" Color="Color.Dark" Size="Size.Small"></MudIconButton>
                        </MudTooltip>
                        <MudSpacer></MudSpacer>
                    </ToolBarContent>
                    <HeaderContent>
                        <MudTh>Destination Branch</MudTh>
                        <MudTh>Initiated Date</MudTh>
                        <MudTh>Status</MudTh>
                        <MudTh>Actions</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="Destination Branch">@context.Branch.BranchName</MudTd>
                        <MudTd DataLabel="Initiated Date">@context.InitiatedDate</MudTd>
                        <MudTd DataLabel="Status">@context.EndModel.DisplayTransferStatus</MudTd>
                        <MudTd DataLabel="Actions">
                            <MudTooltip Text="View Items">
                                <MudFab @onclick="@(()=> View(context,true,false))" Color="Color.Primary" StartIcon="@Icons.Material.Filled.GridView" Size="Size.Small" IconSize="Size.Small" />
                            </MudTooltip>
                            @if (context.Status != 3) @*|| context.EndModel.TransferStatus == 3 || context.EndModel.TransferStatus == 0)*@
                            {
                                @* <MudTooltip Text="Edit">
                                <MudFab @onclick="@(()=> EditOutGoing(context))" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Edit" Size="Size.Small" IconSize="Size.Small" />
                                </MudTooltip> *@
                                <MudTooltip Text="Remove">
                                    <MudFab @onclick="@(()=> DeleteOutGoing(context))" Color="Color.Error" StartIcon="@Icons.Material.Filled.Remove" Size="Size.Small" IconSize="Size.Small" />
                                </MudTooltip>
                            }
                        </MudTd>
                    </RowTemplate>
                    <PagerContent>
                        <MudTablePager PageSizeOptions="new int[] { 5, 10, 20, 50, 100 }" />
                    </PagerContent>
                </MudTable>
            </MudTabPanel>
            <MudTabPanel Style="min-width: 200px;" Text="Incoming Stock" BadgeData="@(collectionInComing?.Count > 0 ? collectionInComing.Count : null)" BadgeColor="Color.Info" Visible="@(collectionInComing?.Count > 0)">
                <MudTable Items="@collectionInComing" Dense="true" Hover="true" Striped="true" Elevation="0">
                    <HeaderContent>
                        <MudTh>Initiated Branch</MudTh>
                        <MudTh>Initiated Date</MudTh>
                        <MudTh>Status</MudTh>
                        <MudTh>Actions</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="Initiated Branch">@context.Branch.BranchName</MudTd>
                        <MudTd DataLabel="Initiated Date">@context.InitiatedDate</MudTd>
                        <MudTd DataLabel="Status">@context.EndModel.DisplayTransferStatus</MudTd>
                        <MudTd DataLabel="Actions">
                            <MudTooltip Text="View Items">
                                <MudFab @onclick="@(()=> View(context,true,true))" Color="Color.Primary" StartIcon="@Icons.Material.Filled.GridView" Size="Size.Small" IconSize="Size.Small" />
                            </MudTooltip>
                            @if (context.Status == 3)  @*|| context.EndModel.TransferStatus == 3 || context.EndModel.TransferStatus == 0)*@
                            {
                                @* <MudTooltip Text="Edit">
                                    <MudFab @onclick="@(()=> Accept(context))" Color="Color.Success" StartIcon="@Icons.Material.Filled.Check" Size="Size.Small" IconSize="Size.Small" />
                                    </MudTooltip> *@
                                <MudTooltip Text="Cancel Incoming">
                                    <MudFab @onclick="@(()=> Reject(context))" Color="Color.Error" StartIcon="@Icons.Material.Filled.Close" Size="Size.Small" IconSize="Size.Small" />
                                </MudTooltip>
                            }
                        </MudTd>
                    </RowTemplate>
                    <PagerContent>
                        <MudTablePager PageSizeOptions="new int[] { 5, 10, 20, 50, 100 }" />
                    </PagerContent>
                </MudTable>
            </MudTabPanel>

        </MudTabs>
    </MudItem>
</MudGrid>

@code {

    private List<StockTransferInitiationModel> collectionOutGoing = new();
    private StockTransferInitiationModel model = new StockTransferInitiationModel();
    public int? branchID { get; set; }

    protected override async Task OnInitializedAsync()
    {
        var authprov = await auth.GetAuthenticationStateAsync();
        branchID = int.Parse(authprov.User.Claims.First(x => x.Type == "BranchID").Value);
        model = new();

        await GetAll();
    }

    private async Task GetAll()
    {
        collectionOutGoing = IStockTransferService.SelectOutGoing(branchID).ToList();
        collectionInComing = IStockTransferService.SelectIncoming(branchID).ToList();
    }

    //================== CollectionOutGoing Functions ==================//

    private async Task EditOutGoing(StockTransferInitiationModel model)
    {
        DialogParameters parms = new DialogParameters();
        parms.Add("InitiationModel", model);
        //parms.Add("IsView", View);
        //parms.Add("IsEdit", Edit);
        var dialog = DialogService.Show<StockTransferInitiateDialog>(model.InvTranID == null ? "ADD" : "EDIT", parms);
        var result = await dialog.Result;
        if (!result.Canceled)
        {
            StockTransferInitiationModel UpatedModel = (StockTransferInitiationModel)result.Data;
            //model.UserInfo.UserID = user.Identity.Name;
            try
            {
                //Iservice.Update(UpatedModel);
                model = new();
                snackbar.Add("Saved Successfully", Severity.Success);
                model = new StockTransferInitiationModel();
            }
            catch (Exception ex)
            {
                snackbar.Add(ex.Message, Severity.Warning);
            }
        }
        await GetAll();
    }

    private async Task DeleteOutGoing(StockTransferInitiationModel model)
    {
        bool? result = await DialogService.ShowMessageBox(
            "Warning !",
            "Are you sure you want to Cancel this StockTransfer to " + model.Branch.BranchName + "?");
        @if (result == true)
        {
            var authprov = await auth.GetAuthenticationStateAsync();
            var user = authprov.User;
            IStockTransferService.TransferCancel(model.InvTranID, user.Identity.Name);
            snackbar.Add("Deleted Successfully", Severity.Success);
        }
        await GetAll();
    }

    //==================================================================//

    private List<StockTransferInitiationModel> collectionInComing = new();
    public StoreModel SelectedStore { get; set; } = new();

    private void StoreChanged(StoreModel obj)
    {
        SelectedStore = obj;
    }

    private async Task View(StockTransferInitiationModel model, bool View, bool Acpt)
    {
        DialogParameters parms = new DialogParameters();
        parms.Add("InitiationModel", model);
        parms.Add("IsView", View);
        parms.Add("Acpt", Acpt);
        var dialog = DialogService.Show<StockTransferInitiateDialog>(Acpt == true ? "ACCEPT ITEMS" : "VIEW", parms);
        var result = await dialog.Result;
        await GetAll();
    }

    //================== CollectionInComing Functions ==================//

    // private async Task Accept(StockTransferInitiationModel StockTransferEndModel)
    // {

    // }

    private async Task Reject(StockTransferInitiationModel model)
    {
        bool? result = await DialogService.ShowMessageBox(
            "Warning !",
            "Are you sure you want to Reject this Order ?");
        @if (result == true)
        {
            var authprov = await auth.GetAuthenticationStateAsync();
            var user = authprov.User;
            model.UserInfo.UserID = user.Identity.Name;
            IStockTransferService.RejectOrder(model);
            snackbar.Add("Order Rejected Successfully", Severity.Success);
        }
        await GetAll();
    }
}