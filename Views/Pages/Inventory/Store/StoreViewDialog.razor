@inject IStoreService Iservice
@inject MudBlazor.ISnackbar snackbar
@inject IBranchService branchIservice
@inject AuthenticationStateProvider auth
@attribute [Authorize]
@inject IDialogService DialogService

<DialogForm @ref="@dialogForm" Title="Logistics Hub Provisioning" Subtitle="Register and configure strategic warehouse nodes and distribution centers within the corporate branch architecture." Icon="@Icons.Material.Filled.HomeWork" AdminStyle="true" formID="formtdsRate" model="@model" _busy="_busy">
    <FormContent>
        <div class="dialog-content-wrapper">
            <EditForm id="formtdsRate" Model="@model" OnValidSubmit="OnValidSubmit">
                <ObjectGraphDataAnnotationsValidator />
                
                <div class="admin-glass-card pa-6 mb-6">
                    <div class="d-flex align-center mb-6">
                        <MudIcon Icon="@Icons.Material.Filled.Storefront" Color="Color.Primary" Class="mr-2" />
                        <span class="admin-section-label mb-0">Warehouse Node Configuration</span>
                    </div>

                    <MudGrid Spacing="3">
                        <MudItem xs="12">
                            <MudTextField @bind-Value="model.StoreName" Label="Operational Hub Name (Store)" Variant="Variant.Outlined" Margin="Margin.Normal" For="@(() => model.StoreName)" Class="modern-input" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Label" />
                        </MudItem>
                        <MudItem xs="12">
                            <MudSelect Label="Designated Branch Jurisdiction" @bind-Value="model.BranchID" T="int?" Variant="Variant.Outlined" Margin="Margin.Normal" AdornmentColor="Color.Secondary" Class="modern-input" AdornmentIcon="@Icons.Material.Filled.Business">
                                @foreach (var ditem in branches)
                                {
                                    <MudSelectItem Value="@ditem.BranchID">@ditem.BranchName</MudSelectItem>
                                }
                            </MudSelect>
                        </MudItem>
                    </MudGrid>
                </div>

                <div class="admin-glass-card pa-6 text-center shadow-none gray-bg">
                    <MudIcon Icon="@Icons.Material.Filled.Security" Color="Color.Info" Size="Size.Large" Class="mb-2" />
                    <MudText Typo="Typo.body2" Class="fw-500 opacity-70">
                        Logistics hub registration enables regional inventory synchronization and multi-branch resource auditing.
                    </MudText>
                </div>
            </EditForm>
        </div>
    </FormContent>
</DialogForm>

@code {
    DialogForm dialogForm;
    [Parameter]
    public StoreModel model { get; set; }
    private List<BranchModel> branches = new();
    private bool _busy;
    protected override async Task OnInitializedAsync()
    {
        branches = branchIservice.Select().ToList();
    }

    private async Task OnValidSubmit(EditContext context)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is being submitted!", Severity.Warning);
            return;
        }

        if (model.BranchID == null)
        {
            snackbar.Add("Select Branch", Severity.Success);
            return;
        }
        _busy = true;

        dialogForm.Close(model);

        await Task.Delay(200);
        _busy = false;
    }

    private void Cancel()
    {
        dialogForm.Cancel();
    }
}
