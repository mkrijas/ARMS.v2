@inject IBranchService branchIservice
@inject MudBlazor.ISnackbar snackbar
@inject IDialogService DialogService

<MudDialog Class="admin-dialog-glass">
    <TitleContent>
        <div class="header-section mb-2 pt-4 px-4">
            <div class="d-flex align-center justify-space-between">
                <div class="d-flex align-center">
                    <div class="icon-badge primary-badge mr-4">
                        <div class="admin-header-icon-badge mb-3">
                            <MudIcon Icon="@Icons.Material.Filled.HomeWork" Color="Color.Secondary" Style="font-size: 3rem;" />
                        </div>
                    </div>
                    <div>
                        <MudText Typo="Typo.h5" Class="admin-title"><b>Logistics Hub Provisioning</b></MudText>
                        <MudText Typo="Typo.body2" Class="admin-subtitle">Register and configure strategic warehouse nodes and distribution centers within the corporate branch architecture.</MudText>
                    </div>
                </div>
            </div>
            <div class="title-accent mt-4"></div>
        </div>
    </TitleContent>
    <DialogContent>
        <MudContainer Class="admin-dialog-container">
            <div class="dialog-content-wrapper pa-4">
                <EditForm id="formtdsRate" Model="@model" OnValidSubmit="OnValidSubmit">
                    <ObjectGraphDataAnnotationsValidator />
                    
                    <div class="admin-glass-card pa-6 mb-6">
                        <div class="d-flex align-center mb-6">
                            <MudIcon Icon="@Icons.Material.Filled.Storefront" Color="Color.Primary" Class="mr-2" />
                            <span class="admin-section-label mb-0">Warehouse Node Configuration</span>
                        </div>

                        <MudGrid Spacing="3">
                            <MudItem xs="12">
                                <MudTextField @bind-Value="model.StoreName" Label="Operational Hub Name (Store)" Variant="Variant.Outlined" Margin="Margin.Normal" For="@(() => model.StoreName)" Class="modern-input" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Label" />
                            </MudItem>
                            <MudItem xs="12">
                                <MudSelect For="@(() => model.BranchID)" Label="Designated Branch Jurisdiction" @bind-Value="model.BranchID" T="int?" Variant="Variant.Outlined" Margin="Margin.Normal" AdornmentColor="Color.Secondary" Class="modern-input" AdornmentIcon="@Icons.Material.Filled.Business">
                                    @foreach (var ditem in branches)
                                    {
                                        <MudSelectItem Value="@ditem.BranchID">@ditem.BranchName</MudSelectItem>
                                    }
                                </MudSelect>
                            </MudItem>
                        </MudGrid>
                    </div>

                    <div class="admin-glass-card pa-6 text-center shadow-none gray-bg" style="background: rgba(0,0,0,0.02);">
                        <MudIcon Icon="@Icons.Material.Filled.Security" Color="Color.Info" Size="Size.Large" Class="mb-2 opacity-50" />
                        <MudText Typo="Typo.body2" Class="fw-500 opacity-70">
                            Logistics hub registration enables regional inventory synchronization and multi-branch resource auditing.
                        </MudText>
                    </div>
                </EditForm>
            </div>
        </MudContainer>
    </DialogContent>
    <DialogActions>
        <div class="d-flex w-100 flex-wrap pa-4 gap-3 align-center">
            <MudSpacer />
            <MudButton @onclick="Cancel" Variant="Variant.Outlined" Color="Color.Default" Style="border-radius: 12px; font-weight: 700; text-transform: none; border-color: rgba(0,0,0,0.15);">Discard</MudButton>
            <MudButton Disabled="@_busy" form="formtdsRate" Variant="Variant.Filled" Color="Color.Success" ButtonType="ButtonType.Submit" Style="background: var(--mud-palette-success); color: white; font-weight: 800; border-radius: 12px; text-transform: none; white-space: nowrap; padding: 8px 24px;" StartIcon="@Icons.Material.Filled.Save">Provision Hub</MudButton>
        </div>
    </DialogActions>
</MudDialog>

@code {

    [CascadingParameter] IMudDialogInstance MudDialog { get; set; }
    [Parameter]
    public StoreModel model { get; set; }
    private List<BranchModel> branches = new();
    private bool _busy;
    protected override async Task OnInitializedAsync()
    {
        branches = branchIservice.Select().ToList();
    }

    private async Task OnValidSubmit(EditContext context)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is being submitted!", Severity.Warning);
            return;
        }

        if (model.BranchID == null)
        {
            snackbar.Add("Select Branch", Severity.Warning);
            return;
        }
        _busy = true;

        MudDialog.Close(DialogResult.Ok(model));

        await Task.Delay(200);
        _busy = false;
    }

    private void Cancel()
    {
        MudDialog.Cancel();
    }
}
