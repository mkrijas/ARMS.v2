@page "/Store"
@inject IStoreService Iservice
@inject MudBlazor.ISnackbar snackbar
@inject AuthenticationStateProvider auth
@attribute [Authorize]
@using System.Threading;
@inject IRoleService<RoleModel> Irole
@inject IDialogService DialogService

<div class="admin-page-container fade-in">
    <div class="admin-header-tiered mb-6">
        <div class="d-flex align-center justify-space-between">
            <div>
                <MudText Typo="Typo.h4" Class="admin-title">Store Registry</MudText>
                <MudText Typo="Typo.body2" Class="admin-subtitle">Administrative oversight of physical storage facilities, warehouse allocations, and branch linkages.</MudText>
            </div>
            <MudButton Disabled="@_busy" Variant="Variant.Filled" Color="Color.Primary" OnClick="@(()=> OpenDialog(new StoreModel()))" Class="admin-register-btn" StartIcon="@Icons.Material.Filled.Add">REGISTER STORE</MudButton>
        </div>
    </div>

    <div class="admin-glass-card pa-6 mb-6">
        <MudGrid Spacing="3" Class="align-center">
            <MudItem xs="12" md="6">
                <MudTextField @bind-Value="searchstore" Placeholder="Search by Store or Branch..." Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" AdornmentColor="Color.Primary" Variant="Variant.Outlined" Margin="Margin.Dense" Clearable="true" Class="modern-input"></MudTextField>
            </MudItem>
        </MudGrid>
    </div>

    <div class="admin-glass-card overflow-hidden">
        <MudTable Items="@collection" Elevation="0" Hover="true" Breakpoint="Breakpoint.Sm" Class="modern-admin-table" Filter="new Func<StoreModel, bool>(search)">
            <HeaderContent>
                <MudTh><MudTableSortLabel SortBy="new Func<StoreModel, object>(x=> x.StoreName)" InitialDirection="SortDirection.Ascending"><span class="admin-header-text">STORE DESIGNATION</span></MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<StoreModel, object>(x=> x.BranchName)"><span class="admin-header-text">OPERATIONAL BRANCH</span></MudTableSortLabel></MudTh>
                <MudTh Style="text-align: right;"><span class="admin-header-text">ACTIONS</span></MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Designation"><span class="admin-td-primary fw-600">@context.StoreName</span></MudTd>
                <MudTd DataLabel="Branch">
                    <div class="d-flex align-center">
                        <MudIcon Icon="@Icons.Material.Filled.AccountTree" Size="Size.Small" Color="Color.Info" Class="mr-2" />
                        <span>@context.BranchName</span>
                    </div>
                </MudTd>
                <MudTd DataLabel="Actions" Style="text-align: right;">
                    <MudTooltip Text="Modify Configuration">
                        <MudIconButton OnClick="@(()=> OpenDialog(context))" Color="Color.Primary" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Variant="Variant.Text" />
                    </MudTooltip>
                    <MudTooltip Text="Delete Store">
                        <MudIconButton OnClick="@(()=> Delete(context))" Color="Color.Error" Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Variant="Variant.Text" />
                    </MudTooltip>
                </MudTd>
            </RowTemplate>
            <PagerContent>
                <div class="pa-4">
                    <MudTablePager PageSizeOptions="new int[] { 10, 20, 50, 100 }" />
                </div>
            </PagerContent>
        </MudTable>
    </div>
</div>

@code {
    private bool _busy = false;
    private StoreModel model = new StoreModel();
    private List<StoreModel> collection = new List<StoreModel>();
    string UserID = string.Empty;

    private string searchstore = "";

    public bool HasPermissionStoreServiceEdit { get; set; } = false;
    public bool HasPermissionStoreServiceDelete { get; set; } = false;
    public int DocTypeID = 65;

    protected override async Task OnInitializedAsync()
    {
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionStoreServiceEdit = await Irole.HasClaim(DocTypeID.ToString(), "Edit", ctc.Token);
        HasPermissionStoreServiceDelete = await Irole.HasClaim(DocTypeID.ToString(), "Delete", ctc.Token);

        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;
        UserID = user.Identity.Name;
        model = new();
        GetAll();
    }

    private void GetAll()
    {
        collection = new List<StoreModel>();
        foreach (var item in Iservice.Select())
        {
            collection.Add(item);
        }
    }

    private async Task OpenDialog(StoreModel st)
    {
        if (HasPermissionStoreServiceEdit)
        {
            var authprov = await auth.GetAuthenticationStateAsync();
            var user = authprov.User;

            DialogParameters parms = new DialogParameters();
            parms.Add("model", st.Clone());
            var dialog = await DialogService.ShowAsync<StoreViewDialog>(st.StoreID == null ? "ADD" : "EDIT", parms);
            var result = await dialog.Result;

            if (!result.Canceled)
            {
                StoreModel UpatedModel = (StoreModel)result.Data;
                UpatedModel.UserInfo.UserID = user.Identity.Name;
                try
                {
                    _busy = true;
                    Iservice.Update(UpatedModel);
                    model = new();
                    snackbar.Add("Saved Successfully", Severity.Success);
                    model = new StoreModel();
                    GetAll();
                }
                catch (Exception ex)
                {
                    snackbar.Add(ex.Message, Severity.Warning);
                }
                finally
                {
                    _busy = false;
                }
            }
        }
        else
        {
            bool? result = await DialogService.ShowMessageBoxAsync(
                "Permission denied!",
                "You don't have any permission to Edit Store.");
        }
    }

    private async Task Delete(StoreModel model)
    {
        if (HasPermissionStoreServiceDelete)
        {
            bool? result = await DialogService.ShowMessageBoxAsync(
                "Warning !",
                "Are you sure, you want to delete - " + model.StoreName + " (" + model.BranchName + ") ?");
            if (result == true)
            {
                _busy = true;
                try
                {
                Iservice.Delete(model.StoreID, UserID);
                snackbar.Add("Deleted Successfully", Severity.Error);
                }
                catch (Exception ex)
                {
                    snackbar.Add(ex.Message, Severity.Warning);
                }
                finally
                {
                    _busy = false;
                }
            }
            GetAll();
        }
        else
        {
            bool? result = await DialogService.ShowMessageBoxAsync(
                "Permission denied!",
                "You don't have any permission to Delete Store.");
        }
    }

    private bool search(StoreModel tds)
    {
        if (tds.StoreName != null && tds.StoreName.Contains(searchstore, StringComparison.OrdinalIgnoreCase))
        {
            return true;
        }
        else if (tds.StoreName == null)
            return true;
        return false;
    }
}

