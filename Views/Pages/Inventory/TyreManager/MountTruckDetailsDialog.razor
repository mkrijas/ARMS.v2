@inject ITyreService Iservice
@inject IDialogService DialogService

<MudDialog Class="admin-dialog-glass">
    <TitleContent>
        <div class="header-section mb-2 pt-4 px-4">
            <div class="d-flex align-center justify-space-between">
                <div class="d-flex align-center">
                    <div class="icon-badge primary-badge mr-4">
                        <div class="admin-header-icon-badge mb-3">
                            <MudIcon Icon="@Icons.Material.Filled.Dns" Color="Color.Secondary" Style="font-size: 3rem;" />
                        </div>
                    </div>
                    <div>
                        <MudText Typo="Typo.h5" Class="admin-title"><b>Internal Asset Configuration</b></MudText>
                        <MudText Typo="Typo.body2" Class="admin-subtitle">High-precision telemetry and axial mapping for current vehicle deployment.</MudText>
                    </div>
                </div>
            </div>
            <div class="title-accent mt-4"></div>
        </div>
    </TitleContent>
    <DialogContent>
        <MudContainer Class="admin-dialog-container">
            <div class="dialog-content-wrapper fade-in pa-4">
                <div class="admin-glass-card pa-0 overflow-hidden mb-6">
                    <div class="pa-6 border-b gray-bg" style="border-bottom: 1px solid rgba(0,0,0,0.05); background: rgba(var(--mud-palette-primary-rgb), 0.02);">
                        <div class="d-flex align-center justify-space-between">
                            <div class="d-flex align-center">
                                <div class="icon-badge primary-badge-soft mr-3">
                                    <MudIcon Icon="@Icons.Material.Filled.LocalShipping" Size="Size.Small" />
                                </div>
                                <MudText Typo="Typo.h6" Class="fw-800">@SelectedTruck.RegNo</MudText>
                            </div>
                            @if (TruckMountedTyreList == null || !TruckMountedTyreList.Any())
                            {
                                <MudChip T="string" Color="Color.Error" Variant="Variant.Text" Class="fw-700" Icon="@Icons.Material.Filled.Warning">NO TYRES MOUNTED</MudChip>
                            }
                            else
                            {
                                <MudChip T="string" Color="Color.Success" Variant="Variant.Text" Class="fw-700" Icon="@Icons.Material.Filled.CheckCircle">@TruckMountedTyreList.Count() ASSETS MOUNTED</MudChip>
                            }
                        </div>
                    </div>

                    <MudTable Items="@TruckMountedTyreList" Dense="true" Hover="true" Elevation="0" Class="modern-table no-border-radius" HeaderClass="admin-table-header">
                        <HeaderContent>
                            <MudTh><span class="admin-header-text">ASSET SERIAL</span></MudTh>
                            <MudTh><span class="admin-header-text">AXIAL POSITION</span></MudTh>
                            <MudTh><span class="admin-header-text">DEPLOYMENT DATE</span></MudTh>
                            <MudTh Style="text-align: right;"><span class="admin-header-text">INITIAL KM</span></MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd DataLabel="Tyre No"><span class="fw-800 color-primary">@context.TyreNo</span></MudTd>
                            <MudTd DataLabel="Position">
                                <MudChip T="string" Size="Size.Small" Color="Color.Secondary" Variant="Variant.Text" Icon="@Icons.Material.Filled.LocationOn" Class="fw-600">@context.PositionName</MudChip>
                            </MudTd>
                            <MudTd DataLabel="Mounted On">@context.MountedOn?.ToString("dd MMM yyyy")</MudTd>
                            <MudTd DataLabel="Mounted KM" Style="text-align: right;">
                                <span class="fw-700">@context.MountedKM?.ToString("N0")</span>
                                <span class="ml-1 opacity-50 small">KM</span>
                            </MudTd>
                        </RowTemplate>
                        <NoRecordsContent>
                            <div class="pa-12 text-center color-muted border-dashed m-4 rounded-lg">
                                <MudIcon Icon="@Icons.Material.Filled.Inbox" Size="Size.Large" Class="mb-2 opacity-30" />
                                <MudText Typo="Typo.body2">No telemetry data available for this vehicle configuration.</MudText>
                            </div>
                        </NoRecordsContent>
                    </MudTable>
                </div>
            </div>
        </MudContainer>
    </DialogContent>
    <DialogActions>
        <div class="d-flex w-100 px-4 pb-4 align-center gap-3">
            <MudSpacer></MudSpacer>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="@(()=> OpenSwap(SelectedTruck.TruckID))" StartIcon="@Icons.Material.Filled.SwapHoriz" Style="border-radius: 12px; font-weight: 700; text-transform: none; padding: 8px 24px;">Swap Positions</MudButton>
            <MudButton Variant="Variant.Outlined" OnClick="Cancel" Color="Color.Default" Style="border-radius: 12px; font-weight: 700; text-transform: none; border-color: rgba(0,0,0,0.15);">Close Matrix</MudButton>
        </div>
    </DialogActions>
</MudDialog>

@code {

    [CascadingParameter] IMudDialogInstance MudDialog { get; set; }
    [Parameter]
    public TyreMountedModel model { get; set; } = new();
    [Parameter]
    public TruckModel SelectedTruck { get; set; } = new();
    [Required]
    public TyrePositionModel SelectedTyrePosition { get; set; } = new();
    [Required]
    public bool IsTruckDisabled { get; set; } = false;
    public bool IsTyreDisabled { get; set; } = false;
    List<TyreMountedModel> TruckMountedTyreList = new();

    protected override void OnInitialized()
    {
        if (SelectedTruck != null && SelectedTruck.TruckID != null && SelectedTruck.TruckID != 0)
        {
            TruckMountedTyreList = Iservice.SelectMountedTyresByID(SelectedTruck?.TruckID ?? 0).ToList();
            IsTruckDisabled = true;
        }
        else
        {
            IsTruckDisabled = false;
        }
        if (SelectedTruck != null && SelectedTruck.TruckTypeID != 0)
        {
            model.TruckID = SelectedTruck.TruckID;
        }
    }

    private void OnValueChanged(TruckModel obj)
    {
        SelectedTruck = obj;
        if (SelectedTruck != null && SelectedTruck.TruckTypeID != 0)
        {
            if (SelectedTruck.TruckID != null)
            {
                model.TruckID = SelectedTruck.TruckID;
            }
        }
    }

    private async Task OpenSwap(int? id)
    {
        model = new();
        DialogOptions options = new DialogOptions()
            {
                MaxWidth = MaxWidth.Medium,
            };
        DialogParameters parms = new();
        parms.Add("SelectedTruck", SelectedTruck.Clone());
         var dialog = await DialogService.ShowAsync<TyreSwapDialog>("Tyre Swap", parms, options);
        var result = await dialog.Result;
        if (!result.Canceled)
        {
            TruckMountedTyreList = Iservice.SelectMountedTyresByID(SelectedTruck?.TruckID ?? 0).ToList();
            StateHasChanged();
        }
    }

    protected override void OnParametersSet()
    {

    }

    void Cancel()
    {
        MudDialog.Cancel();
    }
}
