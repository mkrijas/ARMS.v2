@inject ITyreService Iservice
@inject IGstUsageIDService IusageService
@inject ITdsRateService tdsService
@inject IRoleService<RoleModel> Irole
@inject AuthenticationStateProvider auth
@inject ISnackbar snackbar
@inject IDialogService DialogService

<MudDialog Class="admin-dialog-glass">
    <TitleContent>
        <div class="header-section mb-2 pt-4 px-4">
            <div class="d-flex align-center justify-space-between">
                <div class="d-flex align-center">
                    <div class="icon-badge primary-badge mr-4">
                        <div class="admin-header-icon-badge mb-3">
                            <MudIcon Icon="@Icons.Material.Filled.FactCheck" Color="Color.Secondary" Style="font-size: 3rem;" />
                        </div>
                    </div>
                    <div>
                        <MudText Typo="Typo.h5" Class="admin-title"><b>Resole Technical Delivery</b></MudText>
                        <MudText Typo="Typo.body2" Class="admin-subtitle">Confirm incoming assets and validate service vendor invoice parameters.</MudText>
                    </div>
                </div>
            </div>
            <div class="title-accent mt-4"></div>
        </div>
    </TitleContent>
    <DialogContent>
        <MudContainer Class="admin-dialog-container">
            <div class="dialog-content-wrapper pa-4">
                <EditForm id="ResoleDeliveryID" Model="@model" OnValidSubmit="Submit">
                    <DataAnnotationsValidator />
                    
                    @if (ValidationMessage != null)
                    {
                        <div class="admin-alert error pa-3 mb-4 rounded-lg d-flex align-center">
                            <MudIcon Icon="@Icons.Material.Filled.Error" Class="mr-2" />
                            <span class="fw-500">@ValidationMessage</span>
                        </div>
                    }

                    <div class="admin-glass-card pa-6 mb-6">
                        <div class="d-flex align-center mb-6">
                            <div class="icon-badge primary-badge-soft mr-3">
                                <MudIcon Icon="@Icons.Material.Filled.Summarize" Size="Size.Small" />
                            </div>
                            <span class="admin-section-label mb-0">Invoice Context</span>
                        </div>

                        <MudGrid Spacing="3">
                            <MudItem xs="12" md="6">
                                <MudTextField Variant="Variant.Outlined" Margin="Margin.Dense" Label="Service Vendor" Value="@model.Party?.TradeName" Disabled Class="modern-input" />
                            </MudItem>
                            <MudItem xs="12" md="6">
                                <MudDatePicker Variant="Variant.Outlined" Margin="Margin.Dense" Label="Terminal Delivery Date" @bind-Date="@model.DeliveryDate" Class="modern-input" />
                            </MudItem>
                            <MudItem xs="12" md="4">
                                <MudTextField Variant="Variant.Outlined" Margin="Margin.Dense" Label="Vendor Invoice No" @bind-Value="@model.InvoiceNo" Class="modern-input" />
                            </MudItem>
                            <MudItem xs="12" md="4">
                                <MudDatePicker Variant="Variant.Outlined" Margin="Margin.Dense" Label="Invoice Issuance Date" @bind-Date="@model.InvoiceDate" Class="modern-input" />
                            </MudItem>
                            <MudItem xs="12" md="4">
                                 <UsageCodeSelector LabelName="Usage Code" For="@(() => CurrentUsageCode)" Value="CurrentUsageCode" ValueChanged="UsageCodeChanged" Class="modern-selector" />
                            </MudItem>
                            <MudItem xs="12">
                                <div class="d-flex align-center pa-3 rounded-lg bg-light-surface border-subtle">
                                    <MudCheckBox T="bool" Value="@model.TaxIncluded" ValueChanged="((bool val) => IsTaxIncludedChanged(val))" Label="Technical Service Charges Inclusive of Taxation" Color="Color.Primary" Dense="true" />
                                    <MudSpacer />
                                    <MudIcon Icon="@Icons.Material.Filled.HistoryEdu" Size="Size.Small" Class="opacity-40" />
                                </div>
                            </MudItem>
                        </MudGrid>
                    </div>

                    <div class="admin-glass-card pa-6">
                        <div class="d-flex align-center mb-6">
                            <div class="icon-badge secondary-badge-soft mr-3">
                                <MudIcon Icon="@Icons.Material.Filled.TireRepair" Size="Size.Small" />
                            </div>
                            <span class="admin-section-label mb-0">Itemized Asset Validation</span>
                        </div>

                        <div class="resole-items-grid">
                            @foreach (ResoleDeliveryTyreModel item in @model.ResoleDeliveryTyreList)
                            {
                                if (item.Tyre != null)
                                {
                                    <div class="resole-item-entry pa-4 mb-3 rounded-lg border-subtle-hover transition-all">
                                        <MudGrid Spacing="2" Class="align-center">
                                            <MudItem xs="12" md="2">
                                                <MudTextField @bind-Value="@item.Tyre.TyreSerialNumber" Label="Asset ID" Variant="Variant.Outlined" Margin="Margin.Dense" Disabled Class="modern-input font-mono" />
                                            </MudItem>
                                            <MudItem xs="12" md="2">
                                                <MudSelect For="@(() => item.Status)" Label="Inspection Status" Value="@item.Status" ValueChanged="@((e) => OnChangeStatus(e,item))" T="int?" Variant="Variant.Outlined" Margin="Margin.Dense" Class="modern-input">
                                                    <MudSelectItem T="int?" Value="1">Resoled Success</MudSelectItem>
                                                    <MudSelectItem T="int?" Value="0">Pending/Review</MudSelectItem>
                                                    <MudSelectItem T="int?" Value="99">Scrapped/Defective</MudSelectItem>
                                                </MudSelect>
                                            </MudItem>
                                            <MudItem xs="12" md="2">
                                                <MudNumericField HideSpinButtons="true" Disabled="@(item.Status != 1)" Value="@item.Amount" T="decimal?" ValueChanged="@((e) => OnChangeAmount(e, item))" Label="Service Charge" Variant="Variant.Outlined" Margin="Margin.Dense" Class="modern-input" />
                                            </MudItem>  
                                            <MudItem xs="12" md="2">
                                                <MudNumericField HideSpinButtons="true" Disabled="@(item.Status != 1)" Value="@item.Tax" T="decimal?" ValueChanged="@((e)=> OnChangeTax(e,item))" Label="Applicable Tax" Variant="Variant.Outlined" Margin="Margin.Dense"  Class="modern-input" />
                                            </MudItem>
                                            <MudItem xs="12" md="2">
                                                <MudNumericField HideSpinButtons="true" Disabled="@(item.Status != 1)" @bind-Value="@item.TDS" Label="TDS Deduction" Variant="Variant.Outlined" Margin="Margin.Dense" Class="modern-input" />
                                            </MudItem>
                                            <MudItem xs="12" md="2">
                                                <MudTextField Value="@item.TotalAmount" Label="Net Payable" Variant="Variant.Outlined" Margin="Margin.Dense" Disabled Class="modern-input fw-700 text-primary" />
                                            </MudItem>
                                        </MudGrid>
                                    </div>
                                }
                            }
                        </div>
                    </div>
                </EditForm>
            </div>
        </MudContainer>
    </DialogContent>
    <DialogActions>
        <div class="d-flex w-100 flex-wrap pa-4 gap-3 align-center">
            
         
                <MudText Typo="Typo.caption"
                         Class="admin-subtitle"
                         Style="font-weight: 700; text-transform: uppercase; letter-spacing: 1px;">
                    Total Amount
                </MudText>
                <MudText Typo="Typo.h5" Style="font-weight: 900; color: #FF9F43;">
                    ₹ @(model.ResoleDeliveryTyreList.Sum(x => x.TotalAmount)?.ToString("N2"))
                </MudText>
            
            <MudSpacer />
            <MudButton @onclick="Cancel" Variant="Variant.Outlined" Color="Color.Default" Style="border-radius: 12px; font-weight: 700; text-transform: none; border-color: rgba(0,0,0,0.15);">Discard</MudButton>
            <MudButton Disabled="@_busy" form="ResoleDeliveryID" Variant="Variant.Filled" Color="Color.Success" ButtonType="ButtonType.Submit" Style="background: var(--mud-palette-success); color: white; font-weight: 800; border-radius: 12px; text-transform: none; white-space: nowrap; padding: 8px 24px;" StartIcon="@Icons.Material.Filled.Save">Post Delivery Audit</MudButton>
        </div>
    </DialogActions>
</MudDialog>

@code {

    [CascadingParameter] IMudDialogInstance MudDialog { get; set; }
    [Parameter]
    public ResoleDeliveryModel model { get; set; } = new();
    [Parameter]
    public GstUsageCodeModel CurrentUsageCode { get; set; } = new();
    public TyreModel SelectedTyre { get; set; }
    List<TyreModel> TyreList = new();
    public string ValidationMessage = null;
    private bool _busy;

    public bool HasPermissionTyreServiceEdit { get; set; } = false;
    public int DocTypeID = 63;

    protected override async Task OnInitializedAsync()
    {
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionTyreServiceEdit = await Irole.HasClaim(DocTypeID.ToString(), "Edit", ctc.Token);

        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;
        var brancIDString = authprov.User.Claims.First(x => x.Type == "BranchID").Value;
        var BranchID = int.Parse(brancIDString);
        List<TyreModel> TyreListCollection = Iservice.SelectByBranch(BranchID).ToList();

        if (model.ResoleDeliveryTyreList == null)
        {
            model.ResoleDeliveryTyreList = new();
        }
        if (model.ID == null || model.ID == 0)
        {
            model.PID = 0;
        }
        List<ResoleDeliveryTyreModel> ResoleDeliveryTyreList = Iservice.SelectResoleDeliveryTyresList(model.ResoleID, model.ID).ToList();
        if (ResoleDeliveryTyreList != null && ResoleDeliveryTyreList.Count() != 0)
        {
            model.ResoleDeliveryTyreList = ResoleDeliveryTyreList;
        }

        var matchedTyres = TyreListCollection.Where(t => model.ResoleDeliveryTyreList.Any(r => r.TyreID == t.TyreID)).ToList();
        List<GstUsageCodeModel> usageList = IusageService.SelectByArea(null, System.DateTime.Now).ToList();
        if (usageList != null && usageList.Count() != 0)
        {
            if (usageList.Any(d => d.UsageCode == model.UsageCode))
            {
                CurrentUsageCode = usageList.First(d => d.UsageCode == model.UsageCode);
            }
        }
        model.UsageCode = CurrentUsageCode?.UsageCode ?? null;

        if (matchedTyres != null && matchedTyres.Count() != 0)
        {
            foreach (var item in model.ResoleDeliveryTyreList)
            {
                if (matchedTyres.Any(s => s.TyreID == item.TyreID))
                {
                    item.Tyre = matchedTyres.First(s => s.TyreID == item.TyreID);
                }
                else
                {
                    item.Tyre = new();
                }
            }
        }
    }

    public void OnChangeStatus(int? _status, ResoleDeliveryTyreModel _alteredItem)
    {
        _alteredItem.Status = _status;        
        if (_status != 1)
        {
            _alteredItem.Amount = 0;
            _alteredItem.Tax = 0;                     
        }
        int index = model.ResoleDeliveryTyreList.FindIndex(s => s.TyreID == _alteredItem.TyreID);
        model.ResoleDeliveryTyreList[index] = _alteredItem;
        ValidationMessage = null;
    }

    public void OnChangeAmount(decimal? _amount, ResoleDeliveryTyreModel _alteredItem)
    {                
        if (_alteredItem.Status == 1)       
        {
            _alteredItem .Amount = _amount;            
            if (model.TaxIncluded)
            {               
                _alteredItem.Tax = (CurrentUsageCode.TaxRate != -100) ? (_alteredItem.Amount - (_alteredItem.Amount * (100 / (CurrentUsageCode.TaxRate + 100)))) : 0;                
            }
            else
            {
                _alteredItem.Tax = (_alteredItem.Amount * (CurrentUsageCode.TaxRate / 100));                
            }
            decimal tdsRate = tdsService.GetTdsRate(model.Party.PartyID, CurrentUsageCode.CoaID); // Get TDS rate
            _alteredItem.TDS = Math.Round((_alteredItem.Amount.Value * tdsRate) / 100, MidpointRounding.AwayFromZero);

            int index = model.ResoleDeliveryTyreList.FindIndex(s => s.TyreID == _alteredItem.TyreID);   
            model.ResoleDeliveryTyreList[index] = _alteredItem;
        }
        ValidationMessage = null;
    }

    public void OnChangeTax(decimal? _tax, ResoleDeliveryTyreModel _alteredItem)
    {
        if (_alteredItem.Status == 1)       
        {
            _alteredItem.Tax = _tax; 
            int index = model.ResoleDeliveryTyreList.FindIndex(s => s.TyreID == _alteredItem.TyreID);   
            model.ResoleDeliveryTyreList[index] = _alteredItem;
        }
        ValidationMessage = null;
    }


    public void UsageCodeChanged(GstUsageCodeModel UsageCode)
    {
        CurrentUsageCode = UsageCode;
        model.UsageCode = CurrentUsageCode?.UsageCode ?? null;
        if (CurrentUsageCode != null)
        {
            foreach (ResoleDeliveryTyreModel item in @model.ResoleDeliveryTyreList)
            {
                if (model.TaxIncluded)
                {
                    item.Tax = (CurrentUsageCode.TaxRate != -100) ? (item.Amount - (item.Amount * (100 / (CurrentUsageCode.TaxRate + 100)))) : 0;                    
                }
                else
                {
                    item.Tax = (item.Amount * (CurrentUsageCode.TaxRate / 100));                    
                }              

            }
        }
        else
        {
            foreach (ResoleDeliveryTyreModel item in @model.ResoleDeliveryTyreList)
            {
                item.Tax = 0;                
            }
        }
    }

    public void IsTaxIncludedChanged(bool IsChecked)
    {
        model.TaxIncluded = IsChecked;

        foreach (ResoleDeliveryTyreModel item in @model.ResoleDeliveryTyreList)
        {
            if (model.TaxIncluded)
            {
                item.Tax = (CurrentUsageCode.TaxRate != -100) ? (item.Amount - (item.Amount * (100 / (CurrentUsageCode.TaxRate + 100)))) : 0;
                item.TaxIncluded = IsChecked;
            }
            else
            {
                item.Tax = (item.Amount * (CurrentUsageCode.TaxRate / 100)) ?? 0;     
                item.TaxIncluded = IsChecked;
            }
        }
    }

    protected override void OnParametersSet()
    {

    }

    void Cancel()
    {
        MudDialog.Cancel();
    }

    public async Task Submit()
    {
        if (HasPermissionTyreServiceEdit)
        {
            if (_busy)
            {
                snackbar.Add("Please wait while form is being submitted!", Severity.Warning);
                return;
            }
            var authprov = await auth.GetAuthenticationStateAsync();
            var user = authprov.User;
            var brancIDString = authprov.User.Claims.First(x => x.Type == "BranchID").Value;
            model.UsageCode = CurrentUsageCode.UsageCode;
            if (model.DeliveryDate < model.RequestedDate)
            {

                ValidationMessage = "Delivery date should be greater than requested date. \n";
                return;
            }
            if (model.ResoleDeliveryTyreList == null || model.ResoleDeliveryTyreList.Count() == 0)
            {
                ValidationMessage = "Need at lest one item to submit \n";
                return;
            }
            if (model.ResoleDeliveryTyreList.Any(s => s.Status == 1 && s.Amount == null))
            {
                if (model.ResoleDeliveryTyreList.Any(s => s.Status == 1 && s.Amount == null))
                {
                    ValidationMessage = "Amount should not be empty \n";
                }

                return;
            }
            _busy = true;
            ValidationMessage = null;
            if (model != null)
            {
                model.UserInfo.UserID = user.Identity.Name;
                model.BranchID = int.Parse(brancIDString);
                try
                {
                    int ReturnValue = Iservice.ResoleDeliveryUpdate(model);
                }
                catch (Exception ex)
                {
                    snackbar.Add(ex.Message, Severity.Error);
                }
            
            }
            MudDialog.Close(DialogResult.Ok(true));
            await Task.Delay(200);
            _busy = false;
        }
        else
        {
            bool? result = await DialogService.ShowMessageBoxAsync(
                "Permission denied!",
                "You don't have any permission to Edit Tyre.");
        }

    }
}
