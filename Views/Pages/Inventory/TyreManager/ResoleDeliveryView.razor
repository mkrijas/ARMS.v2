@page "/ResoleDeliveryView"
@using ArmsModels.BaseModels.General
@using ArmsServices.DataServices.Operations
@inject ITyreService ITyreservice
@inject MudBlazor.ISnackbar snackbar
@inject IPartyService partyIservice
@inject AuthenticationStateProvider auth
@attribute [Authorize]
@using System.Threading;
@inject IRoleService<RoleModel> Irole
@inject IDialogService DialogService

    <div class="admin-page-container fade-in" @key="@("content")">
        <div class="admin-header-tiered mb-6">
            <div class="d-flex align-center justify-space-between">
                <div>
                    <MudText Typo="Typo.h4" Class="admin-title">Resole Logistics View</MudText>
                    <MudText Typo="Typo.body2" Class="admin-subtitle">Monitor external resole processing cycles and coordinate delivery schedules with technical vendors.</MudText>
                </div>
            </div>
        </div>

        <div class="admin-glass-card overflow-hidden">
            <MudTable Items="@collection" Elevation="0" Hover="true" Breakpoint="Breakpoint.Sm" Class="modern-admin-table">
                <HeaderContent>
                    <MudTh><MudTableSortLabel SortBy="new Func<ResoleDeliveryModel, object>(x=> x.Party.TradeName)" InitialDirection="SortDirection.Ascending"><span class="admin-header-text">SERVICE VENDOR</span></MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<ResoleDeliveryModel, object>(x=> x.RequestedDate)"><span class="admin-header-text">CYCLE START</span></MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<ResoleDeliveryModel, object>(x=> x.Tyres.Count())"><span class="admin-header-text">ASSET COUNT</span></MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<ResoleDeliveryModel, object>(x=> x.ID)"><span class="admin-header-text">PROCESS STATUS</span></MudTableSortLabel></MudTh>
                    <MudTh Style="text-align: right;"><span class="admin-header-text">ACTIONS</span></MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Vendor"><span class="admin-td-primary fw-600">@context.Party.TradeName</span></MudTd>
                    <MudTd DataLabel="Date"><span class="opacity-70">@context.RequestedDate?.ToString("dd MMM yyyy")</span></MudTd>
                    <MudTd DataLabel="Count">
                        <MudChip T="string" Color="Color.Info" Variant="Variant.Text" Size="Size.Small" Class="fw-600">@(context?.Tyres?.Count() ?? 0) ITEMS</MudChip>
                    </MudTd>
                    <MudTd DataLabel="Status">
                        @if (context.ID == null || context.ID == 0)
                        {
                            <MudChip T="string" Color="Color.Warning" Size="Size.Small" Variant="Variant.Text" Class="fw-600" Icon="@Icons.Material.Filled.HourglassEmpty">In-Process</MudChip>
                        }
                        else
                        {
                            <MudChip T="string" Color="Color.Success" Size="Size.Small" Variant="Variant.Text" Class="fw-600" Icon="@Icons.Material.Filled.CheckCircle">Delivered</MudChip>
                        }
                    </MudTd>
                    <MudTd DataLabel="Actions" Style="text-align: right;">
                        @if (context.ID != null && context.ID != 0)
                        {
                            <MudTooltip Text="Revert Delivery Status">
                                <MudIconButton OnClick="@(()=> OpenDialogCancel(context))" Color="Color.Primary" Icon="@Icons.Material.Filled.History" Size="Size.Small" Variant="Variant.Text" />
                            </MudTooltip>
                        }
                        else
                        {
                            <MudTooltip Text="Confirm Technical Delivery">
                                <MudIconButton OnClick="@(()=> OpenDialogEdit(context))" Color="Color.Warning" Icon="@Icons.Material.Filled.LocalShipping" Size="Size.Small" Variant="Variant.Text" />
                            </MudTooltip>
                        }
                    </MudTd>
                </RowTemplate>
                <PagerContent>
                    <div class="pa-4">
                        <MudTablePager PageSizeOptions="new int[] { 10, 20, 50, 100 }" />
                    </div>
                </PagerContent>
            </MudTable>
        </div>
    </div>

@code {

    private List<ResoleDeliveryModel> collection = new();
    string UserID;
    List<PartyModel> partyList = new List<PartyModel>();
    private bool _busy;

    public bool HasPermissionTyreServiceCancel { get; set; } = false;
    public int DocTypeID = 63;

    protected async override Task OnInitializedAsync()
    {
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionTyreServiceCancel = await Irole.HasClaim(DocTypeID.ToString(), "Cancel", ctc.Token);

        partyList = partyIservice.Select(0).ToList();
        await GetAll();
    }

    private async Task GetAll()
    {
        collection = new();
        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;
        UserID = user.Identity.Name;
        var BranchID = int.Parse(authprov.User.Claims.First(x => x.Type == "BranchID").Value);
        collection = ITyreservice.SelectResoleDeliveryListByBranch(BranchID).ToList();
        if (partyList != null && partyList.Count() != 0)
        {
            foreach (var item in collection)
            {
                if (item.Party != null && item.Party.PartyID != null && partyList.Any(s => s.PartyID == item.Party.PartyID))
                {
                    item.Party = partyList.First(s => s.PartyID == item.Party.PartyID);
                    var TyresList = ITyreservice.ResoleTyresByResoleId(item.ResoleID);
                    if (TyresList != null && TyresList.Count() != 0)
                    {
                        item.Tyres = TyresList.ToList();
                    }
                    else
                    {
                        item.Tyres = new();
                    }
                }
            }
        }
    }

    private async Task OpenDialogEdit(ResoleDeliveryModel ResoleDelivery)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        _busy = true;
        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;
        ResoleDelivery.UserInfo = new();
        if (ResoleDelivery.UserInfo != null)
        {
            ResoleDelivery.UserInfo.UserID = user.Identity.Name;
        }
        var param = new DialogParameters { ["model"] = ResoleDelivery.Clone() };
        var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Large };
        var dialog = await DialogService.ShowAsync<ResoleDeliveryDialog>("ADD RESOLE DELIVERY", param, options);
        var result = await dialog.Result;

        // you can check if the modal was cancelled
        var isCancelled = result.Canceled;
        if (!isCancelled)
        {
            await GetAll();
        }
        await Task.Delay(200);
        _busy = false;
    }

    private async Task OpenDialogCancel(ResoleDeliveryModel ResoleDelivery)
    {
        if (HasPermissionTyreServiceCancel)
        {
            bool? result = await DialogService.ShowMessageBoxAsync(
                "Warning",
                "Are you sure you want to undo this entry?",
                yesText: "Delete!", cancelText: "Cancel");
            if (result != null)
            {
                try
                {
                    var authprov = await auth.GetAuthenticationStateAsync();
                    var user = authprov.User;
                    ResoleDelivery.UserInfo = new();
                    if (ResoleDelivery.UserInfo != null)
                    {
                        ResoleDelivery.UserInfo.UserID = user.Identity.Name;
                        ITyreservice.UndoResoleDelivery(ResoleDelivery.ID, ResoleDelivery.UserInfo.UserID);
                    }
                    await GetAll();
                    snackbar.Add("Cancelled Successfully", Severity.Success);
                }
                catch (Exception ex)
                {
                    snackbar.Add(ex.Message, Severity.Error);
                }
            }
        }
        else
        {
            bool? result = await DialogService.ShowMessageBoxAsync(
                "Permission denied!",
                "You don't have any permission to Cancel Tyre.");
        }
    }
}

