@using ArmsModels.BaseModels.General
@using ArmsServices.DataServices.General
@inject AuthenticationStateProvider auth
@inject ITyreService Iservice
@inject IInventoryItemService IInventoryservice
@inject IStoreService IStoreservice
@inject IConfigTable IconfigTable
@inject MudBlazor.ISnackbar snackbar
@using System.Threading;
@inject IRoleService<RoleModel> Irole
@inject IDialogService DialogService

<MudDialog Class="admin-dialog-glass">
    <DialogContent>
        <div class="header-section mb-6">
            <div class="d-flex align-center">
                <div class="icon-badge primary-badge mr-4">
                    <MudIcon Icon="@(model.TyreID == null || model.TyreID == 0 ? Icons.Material.Filled.AddBox : Icons.Material.Filled.Edit)" Size="Size.Large" />
                </div>
                <div>
                    <MudText Typo="Typo.h5" Class="admin-title"><b>@(model.TyreID == null || model.TyreID == 0 ? "Add New Item" : "Edit Item Details")</b></MudText>
                    <MudText Typo="Typo.body2" Class="admin-subtitle">
                        Manage inventory items and their specifications.
                    </MudText>
                </div>
            </div>
            <div class="title-accent mt-4"></div>
        </div>

        <div class="admin-glass-card pa-6">
            <EditForm id="formTyre" Model="@model" OnValidSubmit="Submit">
                <ObjectGraphDataAnnotationsValidator />
                <ValidationSummary />
                <MudGrid Spacing="3">
                    <MudItem xs="12">
                        <MudText Typo="Typo.subtitle2" Class="mb-2" Style="font-weight: 700; color: #141A46;">ITEM TYPE</MudText>
                        <MudRadioGroup T="string" Value="ItemType" ValueChanged="ItemTypeChanged" Class="d-flex flex-wrap gap-4">
                            <MudRadio Value="@("Tyre")" Color="Color.Primary" Dense="true">Tyre</MudRadio>
                            <MudRadio Value="@("Battery")" Color="Color.Secondary" Dense="true">Battery</MudRadio>
                            <MudRadio Value="@("Jack")" Color="Color.Info" Dense="true">Jack</MudRadio>
                            <MudRadio Value="@("Tarpaulin")" Color="Color.Warning" Dense="true">Tarpaulin</MudRadio>
                            <MudRadio Value="@("Tool")" Color="Color.Default" Dense="true">Tool</MudRadio>
                        </MudRadioGroup>
                    </MudItem>

                    @if (model.ItemType != null)
                    {
                        <MudItem xs="12" md="6">
                            <MudTextField Disabled="@(model.TyreID != null)" @bind-Value="model.TyreSerialNumber" 
                                         Label="Serial Number" Variant="Variant.Outlined" Margin="Margin.Normal" 
                                         Placeholder="Enter unique ID" Adornment="Adornment.Start" 
                                         AdornmentIcon="@Icons.Material.Filled.QrCode" Class="modern-input"
                                         For="@(() => model.TyreSerialNumber)"></MudTextField>
                        </MudItem>
                        <MudItem xs="12" md="6">
                            @if (model.ItemType == "Tyre" || model.ItemType == "Battery")
                            {
                                <MudSelect Disabled="@model.IsMounted" T="string" Variant="Variant.Outlined" Margin="Margin.Normal" 
                                          Label="Make" @bind-Value="@model.Make" 
                                          AdornmentIcon="@Icons.Material.Filled.BrandingWatermark" Class="modern-input">
                                    @foreach (var make in Makes)
                                    {
                                        <MudSelectItem Value="@make">@make</MudSelectItem>
                                    }
                                </MudSelect>
                            }
                            else
                            {
                                <MudTextField Disabled="@model.IsMounted" @bind-Value="model.Make" 
                                             Label="Make" Variant="Variant.Outlined" Margin="Margin.Normal" 
                                             Placeholder="Brand/Manufacturer" Adornment="Adornment.Start" 
                                             AdornmentIcon="@Icons.Material.Filled.BrandingWatermark" Class="modern-input"
                                             For="@(() => model.Make)"></MudTextField>
                            }
                        </MudItem>

                        <MudItem xs="12" md="6">
                            <InventoryItemSelector ReadOnly="@model.IsMounted" Value="SelectedInvetoryItem" 
                                                  LabelName="Inventory Item" Class="modern-input"
                                                  ValueChanged="@((InventoryItemModel newValue) => getitemCode(newValue))" 
                                                  ItemGroup="@ItemGroup"></InventoryItemSelector>
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <MudSelect Disabled="@model.IsMounted" T="LinkableBatchModel" Label="Batch Info" 
                                      ToStringFunc="@converter" Value="@SelectedBatch" 
                                      ValueChanged="((e)=>SetBatch(e))" Variant="Variant.Outlined" 
                                      Margin="Margin.Normal" Required="true" 
                                      AdornmentIcon="@Icons.Material.Filled.BatchPrediction" Class="modern-input">
                                @foreach (var Batch in BatchList)
                                {
                                    <MudSelectItem Value="@Batch">@Batch.GrnNo</MudSelectItem>
                                }
                            </MudSelect>
                        </MudItem>

                        @if (model.ItemType == "Tyre")
                        {
                            <MudItem xs="12" md="6">
                                <MudSelect Disabled="@model.IsMounted" T="string" Variant="Variant.Outlined" Margin="Margin.Normal" 
                                          Label="Tyre Positioning" @bind-Value="@model.TyreType" Class="modern-input">
                                    @foreach (var TyreType in TyreTypeList)
                                    {
                                        <MudSelectItem Value="@TyreType">@TyreType</MudSelectItem>
                                    }
                                </MudSelect>
                            </MudItem>
                            <MudItem xs="12" md="6">
                                <MudSelect Disabled="@model.IsMounted" T="string" Variant="Variant.Outlined" Margin="Margin.Normal" 
                                          Label="Tyre Dimensions" @bind-Value="@model.TyreSize" Class="modern-input">
                                    @foreach (var size in TyreSize)
                                    {
                                        <MudSelectItem Value="@size">@size</MudSelectItem>
                                    }
                                </MudSelect>
                            </MudItem>
                            <MudItem xs="12" md="6">
                                <MudSelect T="int?" Disabled="@model.IsMounted" @bind-Value="@model.TyreStatus" 
                                          Label="Item Status" Variant="Variant.Outlined" Margin="Margin.Normal" 
                                          Class="modern-input">
                                    <MudSelectItem T="int?" Value="@(0)">New</MudSelectItem>
                                    <MudSelectItem T="int?" Value="@(1)">1st Resole</MudSelectItem>
                                    <MudSelectItem T="int?" Value="@(2)">2nd Resole</MudSelectItem>
                                    <MudSelectItem T="int?" Value="@(3)">3rd Resole</MudSelectItem>
                                    <MudSelectItem T="int?" Value="@(99)">Scrap</MudSelectItem>
                                </MudSelect>
                            </MudItem>
                            <MudItem xs="12" md="6">
                                <MudNumericField HideSpinButtons="true" Disabled="@model.IsMounted" @bind-Value="model.TotalExpectedLife" 
                                               Label="Target Life (KM)" Variant="Variant.Outlined" Margin="Margin.Normal" 
                                               Placeholder="Estimated durability" Class="modern-input"
                                               For="@(() => model.TotalExpectedLife)"></MudNumericField>
                            </MudItem>
                            <MudItem xs="12" md="6">
                                <MudCheckBox T="bool" Disabled="@model.IsMounted" @bind-Checked="@model.Tubeless" 
                                            Label="Tubeless Configuration" Color="Color.Primary" />
                            </MudItem>
                        }                    
                        <MudItem xs="12" md="6" Class="d-flex align-center">
                            @if (!string.IsNullOrEmpty(model.WarrantyCard))
                            {
                                <a href="@model.WarrantyCard" download="WarrantyCard" style="text-decoration: none;">
                                    <div class="d-flex align-center pa-2 rounded-lg" style="background: rgba(54, 117, 136, 0.05); border: 1px dashed #367588;">
                                        <MudIcon Icon="@Icons.Material.Filled.Description" Color="Color.Primary" Class="mr-2" />
                                        <MudText Typo="Typo.body2" Color="Color.Primary"><b>View Warranty Card</b></MudText>
                                        <MudIcon Icon="@Icons.Material.Filled.Download" Size="Size.Small" Color="Color.Primary" Class="ml-2" />
                                    </div>
                                </a>
                            }
                        </MudItem>   
                    }
                </MudGrid>
            </EditForm>
        </div>
    </DialogContent>
    <DialogActions>
        <div class="d-flex gap-4 pa-4 w-100 align-center">
            @if (model.ItemType != "Tyre")
            {
                <MudTooltip Text="Upload Warranty Card">
                    <MyFileUpload FolderName="WarrantyCard" FileName="@Guid.NewGuid().ToString()" Label="Upload Document" @bind-FilePath="model.WarrantyCard"></MyFileUpload>
                </MudTooltip>
            }
            <MudSpacer />
            <MudButton OnClick="Cancel" Variant="Variant.Text" Color="Color.Default" Class="px-8">Cancel</MudButton>
            <MudButton Disabled="@_busy" form="formTyre" Variant="Variant.Filled" 
                       Color="Color.Primary" ButtonType="ButtonType.Submit" 
                       Class="action-btn-primary px-12"
                       Style="background: #367588 !important; color: white !important;">
                Save Item
            </MudButton>
        </div>
    </DialogActions>
</MudDialog>

@code {

    [CascadingParameter] IMudDialogInstance MudDialog { get; set; }
    [Parameter]
    public TyreModel model { get; set; } = new();
    List<string> Makes = new List<string>();
    List<string> TyreSize = new List<string>();
    List<string> TyreTypeList = new List<string>()
    {
        "Front",
        "Back",
        "All-Position"
    };
    public int? ItemGroup { get; set; } = 0;
    List<InventoryItemModel> InvetoryItemList = new();
    InventoryItemModel SelectedInvetoryItem = new();
    LinkableBatchModel SelectedBatch = new();
    List<LinkableBatchModel> BatchList = new();
    string ItemType { get; set; }
    private bool _busy;

    Func<LinkableBatchModel, string> converter = p => p?.GrnNo;

    public bool HasPermissionTyreServiceEdit { get; set; } = false;
    public int DocTypeID = 63;


    protected override async Task OnInitializedAsync()
    {
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionTyreServiceEdit = await Irole.HasClaim(DocTypeID.ToString(), "Edit", ctc.Token);

        InvetoryItemList = IInventoryservice.SelectListByID(null).ToList();
        if (model != null && model.InventoryItemID != null)
        {
            ItemType = model.ItemType;
            SelectedInvetoryItem = InvetoryItemList.FirstOrDefault(x => x.InventoryItemID == model.InventoryItemID);
            SelectedBatch = IStoreservice.GetBatchDetails(model.InventoryBatchID);
        }

    }

    void ItemTypeChanged(string name)
    {
        ItemType = name;
        SelectedInvetoryItem = null;
        model.ItemType = ItemType;
        model.Make = null;
        model.TyreSize = null;
        if (model.ItemType == "Tyre")
        {
            ItemGroup = Int32.Parse(IconfigTable.GetByInventoryTyreGroupID().ValueString);   
            model.Tubeless = false;
            Makes = new List<string> { "JK", "Micheline", "Ceat", "Apollo", "Bridgestone", "Continental", "MRF","Ecomiles" };
            TyreSize = new List<string> { "10.00*20", "8.25*20", "11.00*20" };
           
        }
        else
        {
            ItemGroup = Int32.Parse(IconfigTable.GetByInventorySpareGroupID().ValueString);
            model.Tubeless = null;
        }

        if (model.ItemType == "Battery")
        {
            Makes = new List<string> { "Amaron", "Exide", "SF Sonic", "Champion", "Dynex" };
        }
        StateHasChanged();
    }

    private void SetBatch(LinkableBatchModel obj)
    {
        SelectedBatch = obj;
        model.InventoryBatchID = obj.BatchID;
    }

    protected override void OnParametersSet()
    {

    }

    void Cancel()
    {
        MudDialog.Cancel();
    }

    public async Task Submit()
    {
        if (HasPermissionTyreServiceEdit)
        {
            if (_busy)
            {
                snackbar.Add("Please wait while form is being submitted!", Severity.Warning);
                return;
            }
            _busy = true;
            var authprov = await auth.GetAuthenticationStateAsync();
            var user = authprov.User;
            var brancIDString = authprov.User.Claims.First(x => x.Type == "BranchID").Value;
            if (model != null)
            {
                model.BranchID = int.Parse(brancIDString);
                model.UserInfo.UserID = user.Identity.Name;
                if (SelectedBatch != null && SelectedBatch.BatchID != 0)
                {
                    model.InventoryBatchID = SelectedBatch.BatchID;
                }
                TyreModel result = Iservice.Update(model);
                MudDialog.Close(result);
            }
            await Task.Delay(200);
            _busy = false;
        }
        else
        {
            bool? result = await DialogService.ShowMessageBox(
                "Permission denied!",
                "You don't have any permission to Edit Tyre.");
        }
    }

    protected async Task getitemCode(InventoryItemModel item)
    {
       
            SelectedBatch = null;
            model.InventoryBatchID = null;
            SelectedInvetoryItem = item;

            // if (SelectedInvetoryItem != null && SelectedInvetoryItem.InventoryItemID == null)
            // {
            //     SelectedInvetoryItem = item;
            // }
            // else
            // {
            //     SelectedInvetoryItem = new InventoryItemModel();
            // }

            if (SelectedInvetoryItem is not null)
            {
                model.InventoryItemID = SelectedInvetoryItem.InventoryItemID;
                var authprov = await auth.GetAuthenticationStateAsync();
                var user = authprov.User;
                var brancIDString = authprov.User.Claims.First(x => x.Type == "BranchID").Value;
                int BranchID = int.Parse(brancIDString);
                if (BatchList == null)
                {
                    BatchList = new();
                }
                if (BatchList != null && BatchList.Count() != 0)
                {
                    BatchList.Clear();
                }
                if (SelectedInvetoryItem.InventoryItemID != null)
                {
                    BatchList = Iservice.GetNonLinkedTyreBatches(BranchID, (int)SelectedInvetoryItem.InventoryItemID).ToList();
                }
            }
        
    }
}
