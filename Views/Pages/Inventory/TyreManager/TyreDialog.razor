@using ArmsModels.BaseModels.General
@using ArmsServices.DataServices.General
@inject AuthenticationStateProvider auth
@inject ITyreService Iservice
@inject IInventoryItemService IInventoryservice
@inject IStoreService IStoreservice
@inject IConfigTable IconfigTable
@inject MudBlazor.ISnackbar snackbar
@using System.Threading;
@inject IRoleService<RoleModel> Irole
@inject IDialogService DialogService

<DialogForm @ref="@dialogForm" Title="@(model.TyreID == null || model.TyreID == 0 ? "Register New Asset" : "Update Asset Specifications")" Subtitle="Manage lifecycle parameters and technical specifications for fleet assets." Icon="@Icons.Material.Filled.Inventory" AdminStyle="true" formID="formTyre" model="@model" _busy="_busy">
    <FormContent>
        <div class="dialog-content-wrapper fade-in">
            <EditForm id="formTyre" Model="@model" OnValidSubmit="Submit">
                <ObjectGraphDataAnnotationsValidator />
                
                <div class="admin-glass-card pa-6 mb-6">
                    <div class="d-flex align-center mb-6">
                        <div class="icon-badge primary-badge-soft mr-3">
                            <MudIcon Icon="@Icons.Material.Filled.Category" Size="Size.Small" />
                        </div>
                        <span class="admin-section-label mb-0">Asset Classification</span>
                    </div>

                    <MudRadioGroup T="string" Value="ItemType" ValueChanged="ItemTypeChanged" Class="d-flex flex-wrap gap-4 bg-light-surface pa-3 rounded-lg border-subtle">
                        <MudRadio Value="@("Tyre")" Color="Color.Primary" UnCheckedColor="Color.Default" Class="fw-600">Tyre</MudRadio>
                        <MudRadio Value="@("Battery")" Color="Color.Primary" UnCheckedColor="Color.Default" Class="fw-600">Battery</MudRadio>
                        <MudRadio Value="@("Jack")" Color="Color.Primary" UnCheckedColor="Color.Default" Class="fw-600">Jack</MudRadio>
                        <MudRadio Value="@("Tarpaulin")" Color="Color.Primary" UnCheckedColor="Color.Default" Class="fw-600">Tarpaulin</MudRadio>
                        <MudRadio Value="@("Tool")" Color="Color.Primary" UnCheckedColor="Color.Default" Class="fw-600">Tool</MudRadio>
                    </MudRadioGroup>
                </div>

                @if (!string.IsNullOrEmpty(model.ItemType))
                {
                    <div class="admin-glass-card pa-6 mb-6">
                        <div class="d-flex align-center mb-6">
                            <div class="icon-badge secondary-badge-soft mr-3">
                                <MudIcon Icon="@Icons.Material.Filled.Settings" Size="Size.Small" />
                            </div>
                            <span class="admin-section-label mb-0">Technical Data</span>
                        </div>

                        <MudGrid Spacing="3">
                            <MudItem xs="12" md="6">
                                <MudTextField Disabled="@(model.TyreID != null && model.TyreID != 0)" @bind-Value="model.TyreSerialNumber" Label="Serial Number" Variant="Variant.Outlined" Margin="Margin.Dense" Placeholder="Unique ID" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.QrCode" Class="modern-input" For="@(() => model.TyreSerialNumber)" />
                            </MudItem>
                            <MudItem xs="12" md="6">
                                @if (model.ItemType == "Tyre" || model.ItemType == "Battery")
                                {
                                    <MudSelect For="@(() => model.Make)" Disabled="@model.IsMounted" T="string" Variant="Variant.Outlined" Margin="Margin.Dense" Label="Make/Manufacturer" @bind-Value="@model.Make" AdornmentIcon="@Icons.Material.Filled.BrandingWatermark" Class="modern-input">
                                        @foreach (var make in Makes)
                                        {
                                            <MudSelectItem Value="@make">@make</MudSelectItem>
                                        }
                                    </MudSelect>
                                }
                                else
                                {
                                    <MudTextField Disabled="@model.IsMounted" @bind-Value="model.Make" Label="Make/Manufacturer" Variant="Variant.Outlined" Margin="Margin.Dense" Placeholder="Brand" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.BrandingWatermark" Class="modern-input" For="@(() => model.Make)" />
                                }
                            </MudItem>

                            <MudItem xs="12" md="6">
                                 <InventoryItemSelector For="@(() => SelectedInvetoryItem)" ReadOnly="@model.IsMounted" Value="SelectedInvetoryItem" LabelName="Linked Inventory Item" Class="modern-selector" ValueChanged="@((InventoryItemModel newValue) => getitemCode(newValue))" ItemGroup="@ItemGroup" />
                            </MudItem>
                            <MudItem xs="12" md="6">
                                <MudSelect For="@(() => SelectedBatch)" Disabled="@model.IsMounted" T="LinkableBatchModel" Label="Procurement Batch" ToStringFunc="@converter" Value="@SelectedBatch" ValueChanged="((e)=>SetBatch(e))" Variant="Variant.Outlined" Margin="Margin.Dense" Required="true" AdornmentIcon="@Icons.Material.Filled.BatchPrediction" Class="modern-input">
                                    @foreach (var Batch in BatchList)
                                    {
                                        <MudSelectItem Value="@Batch">@Batch.GrnNo</MudSelectItem>
                                    }
                                </MudSelect>
                            </MudItem>

                            @if (model.ItemType == "Tyre")
                            {
                                <MudItem xs="12" md="6">
                                    <MudSelect For="@(() => model.TyreType)" Disabled="@model.IsMounted" T="string" Variant="Variant.Outlined" Margin="Margin.Dense" Label="Axial Position Filter" @bind-Value="@model.TyreType" Class="modern-input">
                                        @foreach (var TyreType in TyreTypeList)
                                        {
                                            <MudSelectItem Value="@TyreType">@TyreType</MudSelectItem>
                                        }
                                    </MudSelect>
                                </MudItem>
                                <MudItem xs="12" md="6">
                                    <MudSelect For="@(() => model.TyreSize)" Disabled="@model.IsMounted" T="string" Variant="Variant.Outlined" Margin="Margin.Dense" Label="Dimensional Size" @bind-Value="@model.TyreSize" Class="modern-input">
                                        @foreach (var size in TyreSize)
                                        {
                                            <MudSelectItem Value="@size">@size</MudSelectItem>
                                        }
                                    </MudSelect>
                                </MudItem>
                                <MudItem xs="12" md="6">
                                    <MudSelect For="@(() => model.TyreStatus)" T="int?" Disabled="@model.IsMounted" @bind-Value="@model.TyreStatus" Label="Operational Status" Variant="Variant.Outlined" Margin="Margin.Dense" Class="modern-input">
                                        <MudSelectItem T="int?" Value="@(0)">Factory New</MudSelectItem>
                                        <MudSelectItem T="int?" Value="@(1)">1st Resole (Retread)</MudSelectItem>
                                        <MudSelectItem T="int?" Value="@(2)">2nd Resole (Retread)</MudSelectItem>
                                        <MudSelectItem T="int?" Value="@(3)">3rd Resole (Retread)</MudSelectItem>
                                        <MudSelectItem T="int?" Value="@(99)">Decommissioned/Scrap</MudSelectItem>
                                    </MudSelect>
                                </MudItem>
                                <MudItem xs="12" md="6">
                                    <MudNumericField HideSpinButtons="true" Disabled="@model.IsMounted" @bind-Value="model.TotalExpectedLife" Label="Target Service Life" Variant="Variant.Outlined" Margin="Margin.Dense" Placeholder="KM" Class="modern-input" Adornment="Adornment.End" AdornmentText="KM" For="@(() => model.TotalExpectedLife)" />
                                </MudItem>
                                <MudItem xs="12">
                                    <div class="d-flex align-center gap-2">
                                        <MudCheckBox T="bool" Disabled="@model.IsMounted" @bind-Checked="@model.Tubeless" Label="Tubeless Configuration" Color="Color.Primary" Dense="true" />
                                        <MudText Typo="Typo.caption" Class="opacity-60 ml-4">(Advanced safety and weight optimized tires)</MudText>
                                    </div>
                                </MudItem>
                            }
                        </MudGrid>
                    </div>
                }

                <div class="admin-glass-card pa-6">
                    <div class="d-flex align-center justify-space-between mb-4">
                        <div class="d-flex align-center">
                            <div class="icon-badge info-badge-soft mr-3">
                                <MudIcon Icon="@Icons.Material.Filled.Description" Size="Size.Small" />
                            </div>
                            <span class="admin-section-label mb-0">Documents & Warranty</span>
                        </div>
                        <MyFileUpload FolderName="WarrantyCard" FileName="@Guid.NewGuid().ToString()" Label="Upload Warranty" @bind-FilePath="model.WarrantyCard"></MyFileUpload>
                    </div>

                    @if (!string.IsNullOrEmpty(model.WarrantyCard))
                    {
                        <div class="d-flex align-center justify-space-between pa-3 rounded-lg bg-light-info border-subtle-info mt-2">
                            <div class="d-flex align-center">
                                <MudIcon Icon="@Icons.Material.Filled.Assignment" Color="Color.Info" Class="mr-2" />
                                <MudText Typo="Typo.body2" Class="fw-600 text-info">Warranty Card Document Linked</MudText>
                            </div>
                            <MudIconButton Icon="@Icons.Material.Filled.Download" Color="Color.Info" Size="Size.Small" Href="@model.WarrantyCard" Target="_blank" />
                        </div>
                    }
                </div>
            </EditForm>
        </div>
    </FormContent>
</DialogForm>

@code {

    private DialogForm dialogForm;
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; }
    [Parameter]
    public TyreModel model { get; set; } = new();
    List<string> Makes = new List<string>();
    List<string> TyreSize = new List<string>();
    List<string> TyreTypeList = new List<string>()
    {
        "Front",
        "Back",
        "All-Position"
    };
    public int? ItemGroup { get; set; } = 0;
    List<InventoryItemModel> InvetoryItemList = new();
    InventoryItemModel SelectedInvetoryItem = new();
    LinkableBatchModel SelectedBatch = new();
    List<LinkableBatchModel> BatchList = new();
    string ItemType { get; set; }
    private bool _busy;

    Func<LinkableBatchModel, string> converter = p => p?.GrnNo;

    public bool HasPermissionTyreServiceEdit { get; set; } = false;
    public int DocTypeID = 63;


    protected override async Task OnInitializedAsync()
    {
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionTyreServiceEdit = await Irole.HasClaim(DocTypeID.ToString(), "Edit", ctc.Token);

        InvetoryItemList = IInventoryservice.SelectListByID(null).ToList();
        if (model != null && model.InventoryItemID != null)
        {
            ItemType = model.ItemType;
            SelectedInvetoryItem = InvetoryItemList.FirstOrDefault(x => x.InventoryItemID == model.InventoryItemID);
            SelectedBatch = IStoreservice.GetBatchDetails(model.InventoryBatchID);
        }

    }

    void ItemTypeChanged(string name)
    {
        ItemType = name;
        SelectedInvetoryItem = null;
        model.ItemType = ItemType;
        model.Make = null;
        model.TyreSize = null;
        if (model.ItemType == "Tyre")
        {
            ItemGroup = Int32.Parse(IconfigTable.GetByInventoryTyreGroupID().ValueString);   
            model.Tubeless = false;
            Makes = new List<string> { "JK", "Micheline", "Ceat", "Apollo", "Bridgestone", "Continental", "MRF", "Ecomiles", "Liba Tyres", "Santkrupa Tyre" };
            TyreSize = new List<string> { "10.00*20", "8.25*20", "11.00*20" };
           
        }
        else
        {
            ItemGroup = Int32.Parse(IconfigTable.GetByInventorySpareGroupID().ValueString);
            model.Tubeless = null;
        }

        if (model.ItemType == "Battery")
        {
            Makes = new List<string> { "Amaron", "Exide", "SF Sonic", "Champion", "Dynex" };
        }
        StateHasChanged();
    }

    private void SetBatch(LinkableBatchModel obj)
    {
        SelectedBatch = obj;
        model.InventoryBatchID = obj.BatchID;
    }

    protected override void OnParametersSet()
    {

    }

    void Cancel()
    {
        MudDialog.Cancel();
    }

    public async Task Submit()
    {
        if (HasPermissionTyreServiceEdit)
        {
            if (_busy)
            {
                snackbar.Add("Please wait while form is being submitted!", Severity.Warning);
                return;
            }
            _busy = true;
            var authprov = await auth.GetAuthenticationStateAsync();
            var user = authprov.User;
            var brancIDString = authprov.User.Claims.First(x => x.Type == "BranchID").Value;
            if (model != null)
            {
                model.BranchID = int.Parse(brancIDString);
                model.UserInfo.UserID = user.Identity.Name;
                if (SelectedBatch != null && SelectedBatch.BatchID != 0)
                {
                    model.InventoryBatchID = SelectedBatch.BatchID;
                }
                TyreModel result = Iservice.Update(model);
                MudDialog.Close(result);
            }
            await Task.Delay(200);
            _busy = false;
        }
        else
        {
            bool? result = await DialogService.ShowMessageBoxAsync(
                "Permission denied!",
                "You don't have any permission to Edit Tyre.");
        }
    }

    protected async Task getitemCode(InventoryItemModel item)
    {
       
            SelectedBatch = null;
            model.InventoryBatchID = null;
            SelectedInvetoryItem = item;

            // if (SelectedInvetoryItem != null && SelectedInvetoryItem.InventoryItemID == null)
            // {
            //     SelectedInvetoryItem = item;
            // }
            // else
            // {
            //     SelectedInvetoryItem = new InventoryItemModel();
            // }

            if (SelectedInvetoryItem is not null)
            {
                model.InventoryItemID = SelectedInvetoryItem.InventoryItemID;
                var authprov = await auth.GetAuthenticationStateAsync();
                var user = authprov.User;
                var brancIDString = authprov.User.Claims.First(x => x.Type == "BranchID").Value;
                int BranchID = int.Parse(brancIDString);
                if (BatchList == null)
                {
                    BatchList = new();
                }
                if (BatchList != null && BatchList.Count() != 0)
                {
                    BatchList.Clear();
                }
                if (SelectedInvetoryItem.InventoryItemID != null)
                {
                    BatchList = Iservice.GetNonLinkedTyreBatches(BranchID, (int)SelectedInvetoryItem.InventoryItemID).ToList();
                }
            }
        
    }
}
