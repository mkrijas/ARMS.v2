@using ArmsModels.BaseModels.General
@using ArmsServices.DataServices.General
@inject AuthenticationStateProvider auth
@inject ITyreService Iservice
@inject IInventoryItemService IInventoryservice
@inject IStoreService IStoreservice
@inject IConfigTable IconfigTable
@inject MudBlazor.ISnackbar snackbar
@using System.Threading;
@inject IRoleService<RoleModel> Irole
@inject IDialogService DialogService

<MudDialog>
    <TitleContent>
        @if (model.TyreID == null || model.TyreID == 0)
        {
            <MudText Typo="Typo.h6">
                <MudIcon Icon="@Icons.Material.Filled.Edit" Class="mr-3" /> Add Tyre
            </MudText>
        }
        else
        {
            <MudText Typo="Typo.h6">
                <MudIcon Icon="@Icons.Material.Filled.Edit" Class="mr-3" /> Edit Tyre
            </MudText>
        }
    </TitleContent>
    <DialogContent>
        <MudContainer Style="max-height: 400px; overflow-y: scroll; margin-left:20px">
            <EditForm id="formTyre" Model="@model" OnValidSubmit="Submit">
                <ObjectGraphDataAnnotationsValidator />
                <ValidationSummary />
                <MudGrid>
                    <MudItem xs="12" md="6">
                        <MudTextField @bind-Value="model.TyreSerialNumber" Label="Tyre Serial Number" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.TyreSerialNumber)"></MudTextField>
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudTextField @bind-Value="model.Make" Label="Make" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.Make)"></MudTextField>
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <InventoryItemSelector Value="SelectedInvetoryItem" LabelName="Inventory Item" ValueChanged="@((InventoryItemModel newValue) => getitemCode(newValue))" ItemGroup="ItemGroup"></InventoryItemSelector>
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudSelect T="LinkableBatchModel" Label="Batch" ToStringFunc="@converter" Value="@SelectedBatch" ValueChanged="((e)=>SetBatch(e))" Variant="Variant.Outlined" Margin="Margin.Dense" Required="true">
                            @foreach (var Batch in BatchList)
                            {
                                <MudSelectItem Value="@Batch">@Batch.GrnNo</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudSelect T="string" Variant="Variant.Outlined" Margin="Margin.Dense" Label="Tyre Type" @bind-Value="@model.TyreType">
                            @foreach (var TyreType in TyreTypeList)
                            {
                                <MudSelectItem Value="@TyreType">@TyreType</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudTextField @bind-Value="model.TyreSize" Label="Tyre Size" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.TyreSize)"></MudTextField>
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudSelect T="byte?" @bind-Value="@model.TyreStatus" Label="Select Status" Variant="Variant.Outlined" Margin="Margin.Dense" Placeholder="Please Select">
                            <MudSelectItem T="byte?" Value="@(0)">New</MudSelectItem>
                            <MudSelectItem T="byte?" Value="@(1)">1st Resole</MudSelectItem>
                            <MudSelectItem T="byte?" Value="@(2)">2nd Resole</MudSelectItem>
                            <MudSelectItem T="byte?" Value="@(3)">3rd Resole</MudSelectItem>
                            <MudSelectItem T="byte?" Value="@(99)">Scrap</MudSelectItem>
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudCheckBox @bind-Checked="@model.Tubeless" Label="Tubeless"></MudCheckBox>
                    </MudItem>
                </MudGrid>
            </EditForm>
        </MudContainer>
    </DialogContent>
    <DialogActions>
        <MudButton Disabled="@_busy" form="formTyre" Variant="Variant.Filled" Color="Color.Primary" ButtonType="ButtonType.Submit" Class="px-12">Submit</MudButton>
    </DialogActions>
</MudDialog>

@code {

    [CascadingParameter] MudDialogInstance MudDialog { get; set; }
    [Parameter]
    public TyreModel model { get; set; } = new();
    List<string> TyreTypeList = new List<string>()
    {
        "Front",
        "Back",
        "All-Position"
    };
    public int? ItemGroup { get; set; } = 0;
    List<InventoryItemModel> InvetoryItemList = new();
    InventoryItemModel SelectedInvetoryItem = new();
    LinkableBatchModel SelectedBatch = new();
    List<LinkableBatchModel> BatchList = new();
    private bool _busy;

    Func<LinkableBatchModel, string> converter = p => p?.GrnNo;

    public bool HasPermissionTyreServiceEdit { get; set; } = false;
    public int DocTypeID = 63;


    protected override async Task OnInitializedAsync()
    {
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionTyreServiceEdit = await Irole.HasClaim(DocTypeID.ToString(), "Edit", ctc.Token);

        InvetoryItemList = IInventoryservice.SelectListByID(null).ToList();
        if (model != null && model.InventoryItemID != null)
        {
            SelectedInvetoryItem = InvetoryItemList.FirstOrDefault(x => x.InventoryItemID == model.InventoryItemID);
            SelectedBatch = IStoreservice.GetBatchDetails(model.InventoryBatchID);
        }
        ItemGroup = Int32.Parse(IconfigTable.GetByInventoryTyreGroupID().ValueString);
    }

    private void SetBatch(LinkableBatchModel obj)
    {
        SelectedBatch = obj;
        model.InventoryBatchID = obj.BatchID;
    }

    protected override void OnParametersSet()
    {

    }

    void Cancel()
    {
        MudDialog.Cancel();
    }

    public async Task Submit()
    {
        if (HasPermissionTyreServiceEdit)
        {
            if (_busy)
            {
                snackbar.Add("Please wait while form is being submitted!", Severity.Warning);
                return;
            }
            _busy = true;
            var authprov = await auth.GetAuthenticationStateAsync();
            var user = authprov.User;
            var brancIDString = authprov.User.Claims.First(x => x.Type == "BranchID").Value;
            if (model != null)
            {
                model.BranchID = int.Parse(brancIDString);
                model.UserInfo.UserID = user.Identity.Name;
                if (SelectedBatch != null && SelectedBatch.BatchID != 0)
                {
                    model.InventoryBatchID = SelectedBatch.BatchID;
                }
                TyreModel result = Iservice.Update(model);
                MudDialog.Close(result);
            }
            await Task.Delay(200);
            _busy = false;
        }
        else
        {
            bool? result = await DialogService.ShowMessageBox(
                "Permission denied!",
                "You don't have any permission to Edit Tyre.");
        }
    }

    protected async Task getitemCode(InventoryItemModel item)
    {
        if (item != null)
        {
            if (SelectedInvetoryItem != null && SelectedInvetoryItem.InventoryItemID == null)
            {
                SelectedInvetoryItem = item;
            }
            else
            {
                SelectedInvetoryItem = new InventoryItemModel();
            }
            model.InventoryItemID = SelectedInvetoryItem.InventoryItemID;
            var authprov = await auth.GetAuthenticationStateAsync();
            var user = authprov.User;
            var brancIDString = authprov.User.Claims.First(x => x.Type == "BranchID").Value;
            int BranchID = int.Parse(brancIDString);
            if (BatchList == null)
            {
                BatchList = new();
            }
            if (BatchList != null && BatchList.Count() != 0)
            {
                BatchList.Clear();
            }
            if (SelectedInvetoryItem.InventoryItemID != null)
            {
                BatchList = Iservice.GetNonLinkedTyreBatches(BranchID, (int)SelectedInvetoryItem.InventoryItemID).ToList();
            }
        }
    }
}