@using ArmsModels.BaseModels.General
@inject AuthenticationStateProvider auth
@inject MudBlazor.ISnackbar snackbar
@inject ITyreService IServices

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.SwapHoriz" Class="mr-3" />Usage of Tyre  @TyreSerial
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudContainer Style="max-height: 400px; overflow-y: scroll; margin-left:20px; margin-bottom:20px;">
            <MudTable Items="@list" Dense="true" Hover="true" Striped="true">              
                <HeaderContent>
                    <MudTh>Title</MudTh>
                    <MudTh>Info</MudTh>
                    <MudTh>Position</MudTh>
                    <MudTh>From Date</MudTh>
                    <MudTh>To Date</MudTh>
                    <MudTh>Km From</MudTh>
                    <MudTh>Km To</MudTh>                                   
                    <MudTh>Run KM</MudTh>                                   
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Title">@context.Title</MudTd>
                    <MudTd DataLabel="Info">@context.Info</MudTd>
                    <MudTd DataLabel="Position">@context.Position</MudTd>
                    <MudTd DataLabel="DateFrom">@context.DateFrom</MudTd>
                    <MudTd DataLabel="DateTo">@context.DateTo</MudTd>
                    <MudTd DataLabel="KmFrom">@context.KmFrom</MudTd>
                    <MudTd DataLabel="KmTo">@context.KmTo</MudTd>   
                    <MudTd DataLabel="RunKM">@context.RunKM</MudTd>
                </RowTemplate>
                <FooterContent>
                    <MudTd></MudTd>
                    <MudTd></MudTd>
                    <MudTd></MudTd>
                    <MudTd></MudTd>
                    <MudTd></MudTd>
                    <MudTd></MudTd>
                    <MudTd><strong>Totals:</strong></MudTd>
                    <MudTd><strong>@list.Sum(x => x.RunKM)</strong></MudTd>
                </FooterContent>
            </MudTable>            
        </MudContainer>
    </DialogContent>    
</MudDialog>

@code {

    [CascadingParameter] IMudDialogInstance MudDialog { get; set; }

    [Parameter]
    public int? TyreID { get; set; } = 0;   
    
    [Parameter]
    public string TyreSerial { get; set; }

    List<TyreHistoryModel> list = new();

    protected override void OnInitialized()
    {
        list = IServices.GetTyreHistory(TyreID).ToList();
    }

   }
