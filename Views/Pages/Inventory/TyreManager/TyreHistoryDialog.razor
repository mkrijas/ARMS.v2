@inject ITyreService Iservice

<MudDialog Class="admin-dialog-glass">
    <TitleContent>
        <div class="header-section mb-2 pt-4 px-4">
            <div class="d-flex align-center justify-space-between">
                <div class="d-flex align-center">
                    <div class="icon-badge primary-badge mr-4">
                        <div class="admin-header-icon-badge mb-3">
                            <MudIcon Icon="@Icons.Material.Filled.HistoryEdu" Color="Color.Secondary" Style="font-size: 3rem;" />
                        </div>
                    </div>
                    <div>
                        <MudText Typo="Typo.h5" Class="admin-title"><b>Asset Utilization History</b></MudText>
                        <MudText Typo="Typo.body2" Class="admin-subtitle">Detailed audit trail of operational deployment, axial transitions, and cumulative mileage for the designated asset.</MudText>
                    </div>
                </div>
                <div class="admin-badge secondary px-4 py-2 rounded-pill shadow-sm">
                    <MudIcon Icon="@Icons.Material.Filled.QrCode" Size="Size.Small" Class="mr-2" />
                    <span class="fw-800">SERIAL: @TyreSerial</span>
                </div>
            </div>
            <div class="title-accent mt-4"></div>
        </div>
    </TitleContent>
    <DialogContent>
        <MudContainer Class="admin-dialog-container">
            <div class="dialog-content-wrapper pa-4">
                <div class="admin-glass-card pa-0 overflow-hidden mb-6">
                    <div class="pa-6 border-b" style="border-bottom: 1px solid rgba(0,0,0,0.05); background: rgba(var(--mud-palette-primary-rgb), 0.02);">
                        <div class="d-flex align-center">
                            <MudIcon Icon="@Icons.Material.Filled.Timeline" Color="Color.Primary" Class="mr-2" />
                            <span class="admin-section-label mb-0">Operational Lifecycle Feed</span>
                        </div>
                    </div>

                    <MudTable Items="@list" Dense="true" Hover="true" Elevation="0" Class="modern-table no-border-radius" HeaderClass="admin-table-header">
                        <HeaderContent>
                            <MudTh>Activity Event</MudTh>
                            <MudTh>Axial Loc.</MudTh>
                            <MudTh>Deployment Window</MudTh>
                            <MudTh Style="text-align: right">Odometer Cycle</MudTh>
                            <MudTh Style="text-align: right">Interval KM</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd DataLabel="Event">
                                <div class="d-flex flex-column">
                                    <span class="fw-700 color-primary">@context.Title</span>
                                    <span class="small opacity-60">@context.Info</span>
                                </div>
                            </MudTd>
                            <MudTd DataLabel="Position">
                                @if (!string.IsNullOrEmpty(context.Position))
                                {
                                    <MudChip T="string" Color="Color.Secondary" Size="Size.Small" Variant="Variant.Text" Icon="@Icons.Material.Filled.LocationOn" Class="fw-600">@context.Position</MudChip>
                                }
                                else
                                {
                                    <span class="opacity-30">—</span>
                                }
                            </MudTd>
                            <MudTd DataLabel="Window">
                                <div class="d-flex flex-column">
                                    <div class="d-flex align-center mb-1">
                                        <MudIcon Icon="@Icons.Material.Filled.PlayArrow" Size="Size.Small" Color="Color.Success" Class="mr-1" />
                                        <span class="small fw-600">@context.DateFrom?.ToString("dd MMM yyyy")</span>
                                    </div>
                                    @if (context.DateTo.HasValue)
                                    {
                                        <div class="d-flex align-center">
                                            <MudIcon Icon="@Icons.Material.Filled.Stop" Size="Size.Small" Color="Color.Error" Class="mr-1" />
                                            <span class="small fw-600">@context.DateTo?.ToString("dd MMM yyyy")</span>
                                        </div>
                                    }
                                </div>
                            </MudTd>
                            <MudTd DataLabel="Odometer" Style="text-align: right">
                                <div class="d-flex flex-column">
                                    <span class="small">F: <span class="fw-700">@context.KmFrom?.ToString("N0")</span></span>
                                    <span class="small">T: <span class="fw-700">@context.KmTo?.ToString("N0")</span></span>
                                </div>
                            </MudTd>
                            <MudTd DataLabel="Run KM" Style="text-align: right">
                                <span class="fw-800 color-success">@context.RunKM?.ToString("N0")</span>
                            </MudTd>
                        </RowTemplate>
                        <FooterContent>
                            <MudTd colspan="4" Style="text-align: right; background: rgba(0,0,0,0.02);">
                                <span class="fw-700 uppercase opacity-60 mr-4">Total Aggregate Distance:</span>
                            </MudTd>
                            <MudTd Style="text-align: right; background: rgba(0,0,0,0.02);">
                                <div class="admin-badge primary px-4 py-2 rounded-lg shadow-sm">
                                    <span class="fw-900 h6 mb-0">@list.Sum(x => x.RunKM)?.ToString("N0") KM</span>
                                </div>
                            </MudTd>
                        </FooterContent>
                        <NoRecordsContent>
                            <div class="pa-12 text-center color-muted gray-bg">
                                <MudIcon Icon="@Icons.Material.Filled.History" Size="Size.Large" Class="mb-2 opacity-30" />
                                <MudText Typo="Typo.body2">No historical utilization records available for this asset.</MudText>
                            </div>
                        </NoRecordsContent>
                    </MudTable>
                </div>
            </div>
        </MudContainer>
    </DialogContent>
    <DialogActions>
        <div class="d-flex w-100 flex-wrap pa-4 gap-3 align-center">
            <MudSpacer />
            <MudButton @onclick="Cancel" Variant="Variant.Filled" Color="Color.Default" Style="border-radius: 12px; font-weight: 700; text-transform: none; background: rgba(0,0,0,0.05);">Close Matrix</MudButton>
        </div>
    </DialogActions>
</MudDialog>

@code {

    [CascadingParameter] IMudDialogInstance MudDialog { get; set; }
    [Parameter]
    public int? TyreID { get; set; } = 0;   
    
    [Parameter]
    public string TyreSerial { get; set; }

    List<TyreHistoryModel> list = new();

    protected override void OnInitialized()
    {
        list = Iservice.GetTyreHistory(TyreID).ToList();
    }

    void Cancel()
    {
        MudDialog.Cancel();
    }
}
