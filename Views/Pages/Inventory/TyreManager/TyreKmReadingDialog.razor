@using ArmsModels.BaseModels.General
@using ArmsServices.DataServices.General
@inject AuthenticationStateProvider auth
@inject ITyreService Iservice
@inject IConfigTable IconfigTable
@inject MudBlazor.ISnackbar snackbar
@using System.Threading;
@inject IRoleService<RoleModel> Irole
@inject IDialogService DialogService

<DialogForm @ref="@dialogForm" Title="Lifecycle Odometer Audit" Subtitle="Comprehensive logging and verification of tyre mileage across operational maintenance phases." Icon="@Icons.Material.Filled.Speed" AdminStyle="true" model="@model" _busy="_busy">
    <FormContent>
        <div class="dialog-content-wrapper">
            <div class="admin-glass-card pa-0 mb-6 overflow-hidden">
                <div class="pa-6 border-b">
                    <div class="d-flex align-center">
                        <MudIcon Icon="@Icons.Material.Filled.History" Color="Color.Primary" Class="mr-2" />
                        <span class="admin-section-label mb-0">Telemetry History</span>
                    </div>
                </div>

                <MudTable Items="@KmReadings" Dense="true" Hover="true" Elevation="0" Class="modern-table no-border-radius" HeaderClass="admin-table-header">
                    <HeaderContent>
                        <MudTh>Maintenance Phase</MudTh>
                        <MudTh Style="text-align: right">Cumulative KM</MudTh>
                        <MudTh Style="text-align: center">Operations</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="Phase">
                            <div class="d-flex align-center">
                                <MudIcon Icon="@Icons.Material.Filled.Label" Size="Size.Small" Color="Color.Primary" Class="mr-2 opacity-50" />
                                <span class="fw-600">@context.Title</span>
                            </div>
                        </MudTd>
                        <MudTd DataLabel="KM" Style="text-align: right">
                            <span class="fw-700 color-primary">@context.KmReading?.ToString("N0")</span>
                            <span class="ml-1 opacity-50 small">KM</span>
                        </MudTd>
                        <MudTd DataLabel="Actions" Style="text-align: center">
                            <MudIconButton Disabled="@(context.NotificationID != null)" Color="Color.Error" Title="Purge Record" @onclick="@(()=> Delete(@context))" Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Variant="Variant.Text" />
                        </MudTd>
                    </RowTemplate>
                    <NoRecordsContent>
                        <div class="pa-12 text-center color-muted gray-bg">
                            <MudIcon Icon="@Icons.Material.Filled.QueryStats" Size="Size.Large" Class="mb-2 opacity-30" />
                            <MudText Typo="Typo.body2">No odometer telemetry recorded for this asset.</MudText>
                        </div>
                    </NoRecordsContent>
                </MudTable>
            </div>

            <div class="admin-glass-card pa-6">
                <div class="d-flex align-center mb-6">
                    <MudIcon Icon="@Icons.Material.Filled.AddModerator" Color="Color.Primary" Class="mr-2" />
                    <span class="admin-section-label mb-0">Append Telemetry Data</span>
                </div>

                <MudGrid Spacing="3" Class="align-end">
                    <MudItem xs="12" md="5">
                        <MudSelect T="string" @bind-Value="@model.Title" Label="Designate Phase" Variant="Variant.Outlined" Margin="Margin.Normal" Placeholder="Select phase..." Class="modern-input" AdornmentIcon="@Icons.Material.Filled.Category">
                            <MudSelectItem Value="@("1st Resole")">1st Resole</MudSelectItem>
                            <MudSelectItem Value="@("2nd Resole")">2nd Resole</MudSelectItem>
                            <MudSelectItem Value="@("3rd Resole")">3rd Resole</MudSelectItem>
                            <MudSelectItem Value="@("Scrap")">Scrap</MudSelectItem>
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12" md="5">
                        <MudTextField @bind-Value="model.KmReading" Label="Capture Odometer (KM)" Variant="Variant.Outlined" Margin="Margin.Normal" For="@(() => model.KmReading)" Class="modern-input" Adornment="Adornment.End" AdornmentIcon="@Icons.Material.Filled.SettingsEthernet" />
                    </MudItem>
                    <MudItem xs="12" md="2" Class="d-flex justify-end">
                        <MudButton OnClick="Update" Color="Color.Primary" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.Add" Class="rounded-lg py-3 px-6 shadow-none full-width-mobile">Capture</MudButton>
                    </MudItem>
                </MudGrid>
            </div>
        </div>
    </FormContent>
</DialogForm>

@code {
    DialogForm dialogForm;
    private bool _busy;
    [Parameter]
    public TyreKmReadingModel model { get; set; } = new();
    [Parameter]
    public TyreModel SelectedTyre { get; set; } = new();
    private List<TyreKmReadingModel> KmReadings = new();

    protected override async Task OnInitializedAsync()
    {
        KmReadings = Iservice.SelectKmReadingByTyreID(SelectedTyre.TyreID).ToList();
        model.Tyre.TyreID = SelectedTyre.TyreID;
    }

    private async Task Delete(TyreKmReadingModel item)
    {
        bool? result = await DialogService.ShowMessageBoxAsync(
                "Warning",
                "Are you sure you want to delete this entry?",
                yesText: "Delete!", cancelText: "Cancel");
        if (result != null)
        {
            try
            {
                var authprov = await auth.GetAuthenticationStateAsync();
                var user = authprov.User;
                item.UserInfo = new();
                if (item.UserInfo != null)
                {
                    item.UserInfo.UserID = user.Identity.Name;
                    int resultDelete = Iservice.DeleteKmReading(item.ID, item.UserInfo.UserID);
                    if (resultDelete != -1)
                    {
                        if (KmReadings != null && KmReadings.Any(s => s.ID == item.ID))
                        {
                            KmReadings.Remove(KmReadings.FirstOrDefault(s => s.ID == item.ID));
                            snackbar.Add("Deleted Successfully", Severity.Success);
                        }
                    }
                }
            }
            catch (Exception ex)
            {
                snackbar.Add(ex.Message, Severity.Error);
            }
        }
    }

    private async Task Update()
    {
        if (model.Title == null || model.KmReading == null)
        {
            snackbar.Add("Please fill in all Fields", Severity.Error);
            return;
        }
        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;
        var brancIDString = authprov.User.Claims.First(x => x.Type == "BranchID").Value;
        model.Tyre.TyreID = SelectedTyre.TyreID;
        model.UserInfo.UserID = user.Identity.Name;
        try
        {
            Iservice.UpdateKmReading(model);
            snackbar.Add("Updated Successfully", Severity.Success);
            KmReadings.Add(model);
            model = new();
        }
        catch (Exception ex)
        {
            snackbar.Add(ex.Message, Severity.Error);
        }
    }

    void Cancel()
    {
        dialogForm.Cancel();
    }

}
