@using ArmsModels.BaseModels.General
@using System.ComponentModel.DataAnnotations
@inject MudBlazor.ISnackbar snackbar
@inject AuthenticationStateProvider auth
@inject ITyreService IServices

<MudDialog>
    <TitleContent>

            <MudText Typo="Typo.h6">
                <MudIcon Icon="@Icons.Material.Filled.Edit" Class="mr-3" />Mount Tyre
            </MudText>

    </TitleContent>
    <DialogContent>

        <MudContainer Style="max-height: 400px; overflow-y: scroll; margin-left:20px">
            <EditForm id="formMount" Model="@model" OnValidSubmit="Mount">
                <DataAnnotationsValidator />
                <ValidationSummary />

                <MudItem xs="11" md="11" Class="mb-6">
                    <MudSelect T="TyreModel" Variant="Variant.Outlined" Disabled="IsTyreDisabled" Margin="Margin.Dense" Label="Tyre" ToStringFunc="@(e => e == null ? null : $"{e.TyreSerialNumber}")" Value="@SelectedTyre" ValueChanged="OnTyreChanged">
                        @foreach (TyreModel Tyre in TyreList)
                        {
                            <MudSelectItem Value="@Tyre">@Tyre.TyreSerialNumber</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="11" md="11" Class="mb-6">
                    <TruckSelector Value="SelectedTruck" ValueChanged="OnValueChanged" IsDisabled="IsTruckDisabled"></TruckSelector>
                </MudItem>
                <MudItem xs="11" md="11" Class="mb-6">
                    <MudSelect T="TyrePositionModel" Variant="Variant.Outlined" Margin="Margin.Dense" ToStringFunc="@(e => e== null ? null : $"{e.Description}")" Label="Tyre Position" Value="@SelectedTyrePosition" ValueChanged="OnTyrePositionChanged">
                        @foreach (TyrePositionModel TyrePosition in TyrePositionListForMountAndUnMount)
                        {
                            <MudSelectItem Value="@TyrePosition">@TyrePosition.Description</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="11" md="11" Class="mb-6">
                    <MudTextField @bind-Value="@model.MountedKM" Label="Mount KM" Variant="Variant.Outlined" Margin="Margin.Dense"></MudTextField>
                </MudItem>
                @*<MudItem xs="11" md="11" Class="mb-6">
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Mount" Class="px-12">Mount</MudButton>
                </MudItem>*@
            </EditForm>
        </MudContainer>

    </DialogContent>
    <DialogActions>
        <MudButton form="formMount" Variant="Variant.Filled" Color="Color.Primary" ButtonType="ButtonType.Submit" Class="px-12">Mount</MudButton>
    </DialogActions>
</MudDialog>

@code {

    [CascadingParameter] MudDialogInstance MudDialog { get; set; }

    [Parameter]
    public TyreMountedModel model { get; set; } = new();
    [Parameter]
    public TruckModel SelectedTruck { get; set; } = new();
    [Required]
    [Parameter]
    public TyreModel SelectedTyre { get; set; } = new();
    [Required]
    public TyrePositionModel SelectedTyrePosition { get; set; } = new();

    public bool IsTruckDisabled { get; set; } = false;

    public bool IsTyreDisabled { get; set; } = false;

    List<TyreModel> TyreList = new();
    List<TyrePositionModel> TyrePositionListForMountAndUnMount = new();

    protected override void OnInitialized()
    {
        var Tyres = IServices.SelectUnmontedTyresByID(0);
        if (Tyres != null && Tyres.Count() != 0)
        {
            TyreList = Tyres.ToList();

        }
        if (SelectedTruck != null && SelectedTruck.TruckID != null && SelectedTruck.TruckID != 0)
        {
            IsTruckDisabled = true;
        }
        else
        {
            IsTruckDisabled = false;
        }

        if (SelectedTyre != null && SelectedTyre.TyreID != null && SelectedTyre.TyreID != 0)
        {
            IsTyreDisabled = true;
        }
        else
        {
            IsTyreDisabled = false;
        }

        if (SelectedTruck != null && SelectedTruck.TruckTypeID != 0 || SelectedTyre != null && SelectedTyre.TyreID != 0)
        {
            model.TruckID = SelectedTruck.TruckID;
            TyrePositionListForMountAndUnMount = IServices.GetTyrePositionListUsingTruckTypeId(SelectedTruck.TruckTypeID).ToList();

        }
    }
    private void OnValueChanged(TruckModel obj)
    {
        SelectedTruck = obj;
        if (SelectedTruck != null && SelectedTruck.TruckTypeID != 0)
        {
            if (SelectedTruck.TruckID != null)
            {
                model.TruckID = SelectedTruck.TruckID;
            }
            if(TyrePositionListForMountAndUnMount != null && TyrePositionListForMountAndUnMount.Count() != 0)
            {
                TyrePositionListForMountAndUnMount.Clear();
            }
            TyrePositionListForMountAndUnMount = IServices.GetTyrePositionListUsingTruckTypeId(SelectedTruck.TruckTypeID).ToList();

        }
    }

    protected override void OnParametersSet()
    {
        model.TyreID = SelectedTyre.TyreID;
        model.MountedOn = DateTime.Now;
    }
    private void OnTyreChanged(TyreModel obj)
    {
        SelectedTyre = obj;
        model.TyreID = obj?.TyreID ?? null;
    }
    private void OnTyrePositionChanged(TyrePositionModel obj)
    {
        SelectedTyrePosition = obj;
        model.PositionID = obj?.PositionID ?? null;
    }
    void Cancel()
    {
        MudDialog.Cancel();
    }


    public async Task Mount()
    {
        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;
        var brancIDString = authprov.User.Claims.First(x => x.Type == "BranchID").Value;
        if (model != null)
        {
            model.TruckID = SelectedTruck.TruckID;
            model.TyreID = SelectedTyre.TyreID;
            model.PositionID = SelectedTyrePosition.PositionID;
            model.MountedOn = DateTime.Now;
            model.UserInfo.UserID = user.Identity.Name;
            try
            {
                IServices.Mount(model);

            }
            catch(Exception ex)
            {
              snackbar.Add(ex.Message, Severity.Error);  
            }
        }

        MudDialog.Close(DialogResult.Ok(true));
    }

}
