@using ArmsModels.BaseModels.General;
@using ArmsServices.DataServices.Inventory;
@using System.ComponentModel.DataAnnotations;
@inject MudBlazor.ISnackbar snackbar
@inject AuthenticationStateProvider auth
@inject ITyreService IServices
@inject IInventoryRequestService IInventoryRequestservice
@inject IStoreService IStoreservice
@inject MudBlazor.ISnackbar snackbar
@using System.Threading;
@inject IRoleService<RoleModel> Irole
@inject IDialogService DialogService

<MudDialog Class="admin-dialog-glass">
    <TitleContent>
        <div class="header-section mb-2 pt-4 px-4">
            <div class="d-flex align-center justify-space-between">
                <div class="d-flex align-center">
                    <div class="icon-badge primary-badge mr-4">
                        <div class="admin-header-icon-badge mb-3">
                            <MudIcon Icon="@Icons.Material.Filled.VerticalAlignBottom" Color="Color.Secondary" Style="font-size: 3rem;" />
                        </div>
                    </div>
                    <div>
                        <MudText Typo="Typo.h5" Class="admin-title"><b>Asset Deployment (Mounting)</b></MudText>
                        <MudText Typo="Typo.body2" Class="admin-subtitle">
                            Initiate high-precision asset deployment and axial synchronization for the selected fleet unit.
                        </MudText>
                    </div>
                </div>
            </div>
            <div class="title-accent mt-4"></div>
        </div>
    </TitleContent>
    <DialogContent>
        <MudContainer Class="admin-dialog-container">
            <div class="dialog-content-wrapper">
                <EditForm id="formMount" Model="@model" OnValidSubmit="Mount">
                    <DataAnnotationsValidator />
                    
                    <div class="admin-glass-card pa-6 mb-6">
                        <div class="d-flex align-center mb-6">
                            <MudIcon Icon="@Icons.Material.Filled.Storage" Color="Color.Primary" Class="mr-2" />
                            <span class="admin-section-label mb-0">Core Deployment Identity</span>
                        </div>

                        <MudGrid Spacing="3">
                            <MudItem xs="12" md="6">
                                <MudSelect T="TyreModel" Variant="Variant.Outlined" Disabled="IsTyreDisabled" Margin="Margin.Normal" Label="Designated Asset (Tyre)" ToStringFunc="@(e => e == null ? null : $"{e.TyreSerialNumber}")" Value="@SelectedTyre" ValueChanged="OnTyreChanged" Class="modern-input" AdornmentIcon="@Icons.Material.Filled.Lens">
                                    @foreach (TyreModel Tyre in TyreList)
                                    {
                                        <MudSelectItem Value="@Tyre">@Tyre.TyreSerialNumber</MudSelectItem>
                                    }
                                </MudSelect>
                            </MudItem>
                            <MudItem xs="12" md="6">
                                <MudSelect For="@(() => SelectInventoryRequest)" Label="Linked Procurement Request" T="InventoryRequestModel" Value="SelectInventoryRequest" ValueChanged="OnChangeSelectedInventoryRequest" ToStringFunc="@(e => e == null ? null : $"{e.RequestNumber}")" Variant="Variant.Outlined" Margin="Margin.Normal" AdornmentColor="Color.Secondary" Class="modern-input" AdornmentIcon="@Icons.Material.Filled.AssignmentInd">
                                    @foreach (var ditem in InventoryRequestList)
                                    {
                                        <MudSelectItem Value="@ditem">@ditem.RequestNumber</MudSelectItem>
                                    }
                                </MudSelect>
                            </MudItem>
                            <MudItem xs="12">
                                <TruckSelector For="@(() => SelectedTruck)" Value="SelectedTruck" ValueChanged="OnValueChanged" IsDisabled="IsTruckDisabled" Filter="All" Class="modern-selector"></TruckSelector>
                            </MudItem>
                        </MudGrid>
                    </div>

                    <div class="admin-glass-card pa-6 mb-6">
                        <div class="d-flex align-center mb-6">
                            <MudIcon Icon="@Icons.Material.Filled.Construction" Color="Color.Primary" Class="mr-2" />
                            <span class="admin-section-label mb-0">Technical Mounting Specifications</span>
                        </div>

                        <MudGrid Spacing="3">
                            @if(SelectedTyre.ItemType == "Tyre")
                            {
                                <MudItem xs="12" md="6">
                                    <MudSelect T="TyrePositionModel" Variant="Variant.Outlined" Margin="Margin.Normal" ToStringFunc="@(e => e== null ? null : $"{e.Description}")" Label="Assigned Axial Position" Required="true" RequiredError="Axial position is mandatory" Value="@SelectedTyrePosition" ValueChanged="OnTyrePositionChanged" Class="modern-input" AdornmentIcon="@Icons.Material.Filled.LocationSearching">
                                        @foreach (TyrePositionModel TyrePosition in TyrePositionListForMountAndUnMount)
                                        {
                                            <MudSelectItem Value="@TyrePosition">@TyrePosition.Description</MudSelectItem>
                                        }
                                    </MudSelect>
                                </MudItem>
                            }
                            <MudItem xs="12" md="6">
                                <MudTextField @bind-Value="@model.MountedKM" Label="Current Odometer (Mount KM)" Variant="Variant.Outlined" Margin="Margin.Normal" Class="modern-input" Adornment="Adornment.End" AdornmentText="KM" />
                            </MudItem>
                        </MudGrid>
                    </div>

                    <div class="admin-glass-card pa-6">
                        <div class="d-flex align-center mb-6">
                            <MudIcon Icon="@Icons.Material.Filled.Balance" Color="Color.Primary" Class="mr-2" />
                            <span class="admin-section-label mb-0">Financial & Resource Allocation</span>
                        </div>

                        <MudGrid Spacing="3">
                            <MudItem xs="12" md="6">
                                <CostCenterSelector For="@(() => model.CostCenter)" @bind-Value="model.CostCenter" Class="modern-selector" />
                            </MudItem>
                            <MudItem xs="12" md="6">
                                <DimensionSelector For="@(() => model.Dimension)" @bind-Value="model.Dimension" Class="modern-selector" />
                            </MudItem>
                        </MudGrid>
                    </div>
                </EditForm>
            </div>
        </MudContainer>
    </DialogContent>
    <DialogActions>
        <div class="d-flex w-100 px-4 pb-4 align-center gap-3">
            <MudSpacer></MudSpacer>
            <MudButton @onclick="Cancel" Variant="Variant.Outlined" Color="Color.Default" Style="border-radius: 12px; font-weight: 700; text-transform: none; border-color: rgba(0,0,0,0.15);">Cancel</MudButton>
            <MudButton Disabled="@_busy" form="formMount" Variant="Variant.Filled" ButtonType="ButtonType.Submit" Color="Color.Success" Style="background: var(--mud-palette-success); color: white; font-weight: 800; border-radius: 12px; text-transform: none; white-space: nowrap; padding: 8px 24px;" StartIcon="@Icons.Material.Filled.DoneAll">Submit</MudButton>
        </div>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; }
    [Parameter]
    public TyreMountedModel model { get; set; } = new();
    [Parameter]
    public TruckModel SelectedTruck { get; set; } = new();
    [Required]
    [Parameter]
    public TyreModel SelectedTyre { get; set; } = new();
    [Required]
    public TyrePositionModel SelectedTyrePosition { get; set; } = new();
    List<TyreModel> TyreList = new();
    List<TyrePositionModel> TyrePositionListForMountAndUnMount = new();
    private List<InventoryRequestModel> InventoryRequestList = new List<InventoryRequestModel>();
    private List<InventoryItemEntryModel> InventoryRequestSubList = new List<InventoryItemEntryModel>();
    public InventoryRequestModel SelectInventoryRequest { get; set; }
    public bool IsTruckDisabled { get; set; } = false;
    public bool IsTyreDisabled { get; set; } = false;
    private bool _busy;
    public LinkableBatchModel Store { get; set; } = new();
    public int? StoreID;
    public int? BranchID;

    public bool HasPermissionTyreServiceEdit { get; set; } = false;
    public int DocTypeID = 63;

    protected override async Task OnInitializedAsync()
    {
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionTyreServiceEdit = await Irole.HasClaim(DocTypeID.ToString(), "Edit", ctc.Token);

        var Tyres = IServices.SelectUnmontedTyresByID(0);
        if (Tyres != null && Tyres.Count() != 0)
        {
            TyreList = Tyres.ToList();
        }
        if (SelectedTruck != null && SelectedTruck.TruckID != null && SelectedTruck.TruckID != 0)
        {
            IsTruckDisabled = true;
        }
        else
        {
            IsTruckDisabled = false;
        }
        if (SelectedTyre != null && SelectedTyre.TyreID != null && SelectedTyre.TyreID != 0)
        {
            IsTyreDisabled = true;
        }
        else
        {
            IsTyreDisabled = false;
        }
        if (SelectedTruck != null && SelectedTruck.TruckTypeID != 0 && SelectedTyre != null && SelectedTyre.TyreID != 0)
        {
            model.TruckID = SelectedTruck.TruckID;
            //TyrePositionListForMountAndUnMount = IServices.GetTyrePositionListUsingTruckTypeId(SelectedTruck.TruckTypeID).ToList();
        }
        else
        {
            TyrePositionListForMountAndUnMount = IServices.GetTyrePositionList().ToList();
        }
        Store = IStoreservice.GetBatchDetails(SelectedTyre.InventoryBatchID);
        StoreID = Store?.StoreID;
        BranchID = SelectedTyre.BranchID;
        InventoryRequestList = IInventoryRequestservice.SelectByStore(StoreID ?? null, BranchID).Where(d => !((((d.IsCompletelyReleased != null && d.IsCompletelyReleased.Value) || d.IsClosed) && d.RequestID != model.RequestID))).ToList();
    }

    private void OnValueChanged(TruckModel obj)
    {
        SelectedTruck = obj;
        if (SelectedTruck != null && SelectedTruck.TruckTypeID != 0)
        {
            if (SelectedTruck.TruckID != null)
            {
                model.TruckID = SelectedTruck.TruckID;
            }
            if (TyrePositionListForMountAndUnMount != null && TyrePositionListForMountAndUnMount.Count() != 0)
            {
                TyrePositionListForMountAndUnMount.Clear();
            }
            TyrePositionListForMountAndUnMount = IServices.GetTyrePositionListUsingTruckTypeId(SelectedTruck.TruckTypeID).ToList();
        }
    }

    public void OnChangeSelectedInventoryRequest(InventoryRequestModel obj)
    {
        SelectInventoryRequest = obj;
        model.RequestID = obj?.RequestID ?? null;
        if (obj != null)
        {
            SelectedTruck.TruckID = obj.Truck.TruckID;
            model.TruckID = SelectedTruck.TruckID;
            IsTruckDisabled = true;
        }
        InventoryRequestSubList = IInventoryRequestservice.GetSub(model.RequestID).ToList();
        TyrePositionListForMountAndUnMount = IServices.GetTyrePositionListUsingTruckTypeId(obj.Truck.TruckTypeID).ToList();
    }

    protected override void OnParametersSet()
    {
        model.TyreID = SelectedTyre.TyreID;
        model.MountedOn = DateTime.Now;
    }

    private void OnTyreChanged(TyreModel obj)
    {
        SelectedTyre = obj;
        model.TyreID = obj?.TyreID ?? null;
    }

    private void OnTyrePositionChanged(TyrePositionModel obj)
    {
        SelectedTyrePosition = obj;
        model.PositionID = obj?.PositionID ?? null;
    }

    void Cancel()
    {
        MudDialog.Cancel();
    }

    public async Task Mount()
    {
        if (HasPermissionTyreServiceEdit)
        {
            if (_busy)
            {
                snackbar.Add("Please wait while form is being submitted!", Severity.Warning);
                return;
            }
            bool itemExists = InventoryRequestSubList.Any(item => item.ItemID == SelectedTyre.InventoryItemID);
            if (SelectInventoryRequest != null)
            {
                if(!itemExists)
                {
                    snackbar.Add("Selected request doesn't have any appropriate items!", Severity.Warning);
                    return;
                }
            }
            var authprov = await auth.GetAuthenticationStateAsync();
            var user = authprov.User;
            var brancIDString = authprov.User.Claims.First(x => x.Type == "BranchID").Value;
            if (model != null)
            {
                _busy = true;
                model.TruckID = SelectedTruck.TruckID;
                model.TyreID = SelectedTyre.TyreID;
                model.PositionID = SelectedTyrePosition.PositionID;
                model.MountedOn = DateTime.Now;
                model.UserInfo.UserID = user.Identity.Name;
                if(SelectedTyre.ItemType == "Tyre")
                {
                    if(model.PositionID == null)
                    {
                        snackbar.Add("Position required", Severity.Warning);
                        _busy = false;
                        return;
                    }
                }
                try
                {
                    IServices.Mount(model);
                    snackbar.Add("Mounted Successfully", Severity.Success);
                    MudDialog.Close(DialogResult.Ok(true));
                }
                catch (Exception ex)
                {
                    snackbar.Add(ex.Message, Severity.Error);
                }
                _busy = false;
            }
            await Task.Delay(200);
        }
        else
        {
            bool? result = await DialogService.ShowMessageBoxAsync(
                "Permission denied!",
                "You don't have any permission to Edit Tyre.");
        }
    }
}
