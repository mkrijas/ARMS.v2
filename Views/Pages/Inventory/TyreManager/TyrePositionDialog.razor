@using System.Threading;
@inject AuthenticationStateProvider auth
@inject ITyreService Iservice
@inject IRoleService<RoleModel> Irole
@inject IDialogService DialogService
@inject MudBlazor.ISnackbar snackbar

<DialogForm @ref="@dialogForm" Title="Axle Configuration Manager" Subtitle="Spatial mapping and validation of operational tyre positions for diversified asset types." Icon="@Icons.Material.Filled.SettingsInputComponent" AdminStyle="true" model="@TypeModel" _busy="_busy">
    <FormContent>
        <div class="dialog-content-wrapper">
            <div class="admin-glass-card pa-6 mb-6">
                <div class="d-flex align-center mb-6">
                    <MudIcon Icon="@Icons.Material.Filled.DirectionsTransit" Color="Color.Primary" Class="mr-2" />
                    <span class="admin-section-label mb-0">Vehicle Chassis Layout</span>
                </div>
                
                <div class="chassis-legend d-flex justify-center gap-4 mb-4 pa-2 rounded-lg" style="background: rgba(0,0,0,0.02);">
                    <div class="d-flex align-center"><div class="legend-dot mr-2" style="background: var(--mud-palette-primary);"></div><MudText Typo="Typo.caption" Class="fw-600 uppercase">Outer Position</MudText></div>
                    <div class="d-flex align-center"><div class="legend-dot mr-2" style="background: var(--mud-palette-secondary);"></div><MudText Typo="Typo.caption" Class="fw-600 uppercase">Inner Position</MudText></div>
                </div>

                <div class="position-grid-container pa-4 rounded-xl shadow-inner" style="background: #f8f9fa; border: 1px inset rgba(0,0,0,0.05);">
                    <MudGrid Spacing="1" Justify="Justify.Center">
                        <MudItem xs="3" Class="text-center pa-1"><MudText Typo="Typo.caption" Class="fw-700 color-muted uppercase">Outer L</MudText></MudItem>
                        <MudItem xs="3" Class="text-center pa-1"><MudText Typo="Typo.caption" Class="fw-700 color-muted uppercase">Inner L</MudText></MudItem>
                        <MudItem xs="3" Class="text-center pa-1"><MudText Typo="Typo.caption" Class="fw-700 color-muted uppercase">Inner R</MudText></MudItem>
                        <MudItem xs="3" Class="text-center pa-1"><MudText Typo="Typo.caption" Class="fw-700 color-muted uppercase">Outer R</MudText></MudItem>

                        @for (var mr = 1; mr <= MaxRow; mr++)
                        {
                            for (var mc = 1; mc <= MaxColumn; mc++)
                            {
                                if (TyrePositionList.Any(s => s.SColumn == mc && s.SRow == mr))
                                {
                                    foreach (TyrePositionModel item in @TyrePositionList.Where(s => s.SColumn == mc && s.SRow == mr))
                                    {
                                        <MudItem xs="3" Class="d-flex justify-center align-center pa-2">
                                            <div class="modern-position-checkbox @(item.IsChecked ? "active" : "")">
                                                <MudTooltip Text="@item.Description" Arrow="true" Placement="Placement.Top">
                                                    <MudCheckBox T="bool" @bind-Checked="@item.IsChecked" Color="@((mc == 1 || mc == 4) ? Color.Primary : Color.Secondary)"  Class="m-0 pa-0" />
                                                </MudTooltip>
                                            </div>
                                        </MudItem>
                                    }
                                }
                                else
                                {
                                    <MudItem xs="3" Class="pa-2"></MudItem>
                                }
                            }
                            @if (mr < MaxRow)
                            {
                                <MudItem xs="12" Class="pa-1"><div class="axle-separator"></div></MudItem>
                            }
                        }
                    </MudGrid>
                </div>
            </div>
            
            <div class="admin-glass-card pa-4 text-center">
                <MudText Typo="Typo.caption" Class="color-muted italic">
                    Select the active positions configured for the @TypeModel.TruckType chassis architecture.
                </MudText>
            </div>
        </div>
    </FormContent>
    <Actions>
        <MudButton Disabled="@_busy" Variant="Variant.Filled" Color="Color.Primary" OnClick="Submit" StartIcon="@Icons.Material.Filled.Save" Class="px-12 rounded-pill py-3 shadow-none">Commit Configuration</MudButton>
    </Actions>
</DialogForm>

@code {
    DialogForm dialogForm;
    [Parameter]
    public TruckTypeModel TypeModel { get; set; } = new();
    List<TyrePositionModel> TyrePositionList = new();
    int MaxColumn = 0;
    int MaxRow = 0;
    bool IsChecked = false;
    TyreTypeAndPositionMappingModel TyreMappingModel = new();
    private bool _busy;

    public bool HasPermissionTyreServiceEdit { get; set; } = true;
    public int DocTypeID = 63;

    protected override async Task OnInitializedAsync()
    {
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionTyreServiceEdit = await Irole.HasClaim(DocTypeID.ToString(), "Edit", ctc.Token);

        var tempTyrePositionList = Iservice.GetTyrePositionList(0);
        if (tempTyrePositionList != null && tempTyrePositionList.Count() != 0)
        {
            TyrePositionList = tempTyrePositionList.ToList();
            int result = 0;
            if (TyrePositionList.Select(s => s.SRow).Distinct().Max() != null && TyrePositionList.Select(s => s.SColumn).Distinct().Max() != null)
            {
                MaxRow = (int)(TyrePositionList.Select(s => s.SRow)).Distinct().Max();
                MaxColumn = (int)(TyrePositionList.Select(s => s.SColumn)).Distinct().Max();
            }
        }
        if (TypeModel != null && TypeModel.TruckTypeID != 0)
        {
            var result = Iservice.SelectMappingTyrePositionAndType(TypeModel.TruckTypeID);
            if (result != null && result.Count() != 0)
            {
                TyreMappingModel = result.First();
            }
        }
        if (TyreMappingModel != null && TyreMappingModel.PositionIDs != null)
        {
            int valueItem = 0;
            foreach (var item in TyreMappingModel.PositionIDs.Split(","))
            {
                if (Int32.TryParse(item, out valueItem) && TyrePositionList.Any(d => (int)d.PositionID == Convert.ToInt32(item)))
                {
                    foreach (var elements in TyrePositionList.Where(d => (int)d.PositionID == Convert.ToInt32(item)))
                    {
                        elements.IsChecked = true;
                    }
                }
            }
        }
    }

    protected override void OnParametersSet()
    {

    }

    void Cancel()
    {
        dialogForm.Cancel();
    }

    public async Task Submit()
    {
        if (HasPermissionTyreServiceEdit)
        {
            if (_busy)
            {
                snackbar.Add("Please wait while form is being submitted!", Severity.Warning);
                return;
            }
            _busy = true;
            var authprov = await auth.GetAuthenticationStateAsync();
            var user = authprov.User;
            TyreTypeAndPositionMappingModel Result = new();
            if (TypeModel != null)
            {
                Result.UserInfo = new();
                Result.UserInfo.UserID = user.Identity.Name;
                Result.TruckTypeID = TypeModel.TruckTypeID;
                Result.ID = TyreMappingModel.ID;
                if (TyrePositionList != null && TyrePositionList.Any(s => s.IsChecked))
                {
                    Result.PositionIDs = String.Join(",", TyrePositionList.Where(s => s.IsChecked).Select(s => s.PositionID));
                }
                else
                {
                    Result.PositionIDs = "";
                }
                Iservice.UpdateMappingTyrePositionAndType(Result);
            }
            dialogForm.Close(DialogResult.Ok(true));
            await Task.Delay(200);
            _busy = false;
        }
        else
        {
            bool? result = await DialogService.ShowMessageBoxAsync(
                "Permission denied!",
                "You don't have any permission to Edit Tyre.");
        }
    }
}
