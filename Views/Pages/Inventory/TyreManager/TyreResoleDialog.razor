@using ArmsModels.BaseModels.General
@inject AuthenticationStateProvider auth
@inject ITyreService Iservice
@inject IInventoryItemService IInventoryservice
@inject IStoreService IStoreservice
@inject MudBlazor.ISnackbar snackbar
@using System.Threading;
@inject IRoleService<RoleModel> Irole
@inject IDialogService DialogService

<DialogForm @ref="@dialogForm" Title="Tyre Lifecycle Maintenance" Subtitle="Authorize and document high-precision tyre resoling procedures for asset longevity." Icon="@Icons.Material.Filled.Autorenew" AdminStyle="true" formID="TyreResolrDilaoge" model="@model" _busy="_busy">
    <FormContent>
        <div class="dialog-content-wrapper">
            <EditForm id="TyreResolrDilaoge" Model="@model" OnValidSubmit="Submit">
                <DataAnnotationsValidator />
                
                <div class="admin-glass-card pa-6 mb-6">
                    <div class="d-flex align-center mb-6">
                        <MudIcon Icon="@Icons.Material.Filled.Business" Color="Color.Primary" Class="mr-2" />
                        <span class="admin-section-label mb-0">Service Provider & Timeline</span>
                    </div>
                    
                    <MudGrid Spacing="3">
                        <MudItem xs="12" md="6">
                            <PartySelector For="@(() => model.Party)" Value="model.Party" ValueChanged="OnPartyChanged" NatureOfBusiness="Supplier" BranchID="BranchID"></PartySelector>
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <MudDatePicker Variant="Variant.Outlined" Margin="Margin.Normal" Label="Maintenance Commencement Date" @bind-Date="@(model.RequestedDate)" Class="modern-input" AdornmentIcon="@Icons.Material.Filled.CalendarToday" />
                        </MudItem>
                    </MudGrid>
                </div>

                <div class="admin-glass-card pa-6">
                    <div class="d-flex align-center mb-6">
                        <MudIcon Icon="@Icons.Material.Filled.RvHookup" Color="Color.Primary" Class="mr-2" />
                        <span class="admin-section-label mb-0">Asset Selection Manifest</span>
                    </div>

                    <div class="selected-assets-container mb-6">
                        @if (PassedListTyres != null && PassedListTyres.Any())
                        {
                            <div class="d-flex flex-wrap gap-3">
                                @foreach (var item in PassedListTyres)
                                {
                                    <div class="modern-asset-chip">
                                        <MudIcon Icon="@Icons.Material.Filled.Lens" Size="Size.Small" Color="Color.Primary" Class="mr-2" />
                                        <span class="fw-600 mr-2">@item.TyreSerialNumber</span>
                                        <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small" Color="Color.Error" OnClick="(() => DeleteTyres((item.TyreID != null ? (int)item.TyreID:0)))" Class="pa-1" />
                                    </div>
                                }
                            </div>
                        }
                        else
                        {
                            <div class="pa-8 text-center color-muted border-dashed rounded-lg">
                                <MudIcon Icon="@Icons.Material.Filled.Inventory2" Size="Size.Large" Class="mb-2 opacity-30" />
                                <MudText Typo="Typo.body2">No tyres selected for resoling protocol.</MudText>
                            </div>
                        }
                    </div>

                    <TyreSelector For="@(() => SelectedTyre)" @bind-Value="SelectedTyre" SetTyres="SetTyres" PassedListTyres="PassedListTyres" Class="modern-selector">
                    </TyreSelector>
                </div>
            </EditForm>
        </div>
    </FormContent>
</DialogForm>

@code {
    DialogForm dialogForm;
    [Parameter]
    public TyreResoleModel model { get; set; } = new();
    public TyreModel SelectedTyre { get; set; }
    public List<TyreModel> PassedListTyres { get; set; }
    TyreModel SelectedBatch = new();
    List<TyreModel> TyreList = new();
    Func<LinkableBatchModel, string> converter = p => p?.GrnNo;
    private bool _busy;

    int BranchID;

    public bool HasPermissionTyreServiceEdit { get; set; } = false;
    public int DocTypeID = 63;

    protected override async Task OnInitializedAsync()
    {
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionTyreServiceEdit = await Irole.HasClaim(DocTypeID.ToString(), "Edit", ctc.Token);

        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;
        var brancIDString = authprov.User.Claims.First(x => x.Type == "BranchID").Value;
        BranchID = int.Parse(brancIDString);
        List<TyreModel> TyreListCollection = Iservice.SelectByBranch(BranchID).ToList();
        model.Tyres = Iservice.ResoleTyresByResoleId(model.ID).ToList();
        if (PassedListTyres == null)
        {
            PassedListTyres = new List<TyreModel>();
        }
        if (model != null && model.Tyres != null && model.Tyres.Count() != 0)
        {
            if (TyreListCollection != null && TyreListCollection.Count() != 0)
            {
                foreach (var item in TyreListCollection)
                {
                    if (model.Tyres.Contains(item.TyreID))
                    {
                        PassedListTyres.Add(item);
                    }
                }
            }
        }
        model.PartyID = model?.Party?.PartyID ?? null;
    }

    public void SetTyres()
    {
        if (PassedListTyres == null)
        {
            PassedListTyres = new List<TyreModel>();
        }
        if (SelectedTyre != null && SelectedTyre.TyreID != 0 && (!PassedListTyres.Any(s => s.TyreID == SelectedTyre.TyreID)))
        {
            PassedListTyres.Add(SelectedTyre);
            SelectedTyre = null;
            if (model.Tyres != null)
            {
                model.Tyres.Clear();
                model.Tyres = null;
            }
            model.Tyres = PassedListTyres.Select(s => s.TyreID).ToList();
        }
    }

    public void RemoveTyres()
    {
        SelectedTyre = null;
        if (model.Tyres != null)
        {
            model.Tyres.Clear();
            model.Tyres = null;
        }
        if (PassedListTyres != null && PassedListTyres.Count() != 0)
        {
            model.Tyres = PassedListTyres.Select(s => s.TyreID).ToList();
        }
        else
        {
            if (model.Tyres != null)
            {
                model.Tyres.Clear();

            }
        }
    }

    public void OnPartyChanged(PartyModel obj)
    {
        model.Party = obj;
        model.PartyID = obj?.PartyID ?? null;
    }

    public void DeleteTyres(int TyreId = 0)
    {
        if (TyreId != 0)
        {
            if (PassedListTyres != null && PassedListTyres.Where(s => s.TyreID == TyreId).Count() != 0)
            {
                if (PassedListTyres.Any(s => s.TyreID != TyreId))
                {
                    var itemToRemove = PassedListTyres.First(r => r.TyreID == TyreId);
                    PassedListTyres.Remove(itemToRemove);
                }
                else
                {
                    PassedListTyres.Clear();
                }
            }
        }
        if (model.Tyres != null)
        {
            model.Tyres.Clear();
            model.Tyres = null;
        }
        if (PassedListTyres != null && PassedListTyres.Count() != 0)
        {
            model.Tyres = PassedListTyres.Select(s => s.TyreID).ToList();
        }
        else
        {
            if (model.Tyres != null)
            {
                model.Tyres.Clear();

            }
        }
    }

    protected override void OnParametersSet()
    {

    }

    void Cancel()
    {
        dialogForm.Cancel();
    }

    public async Task Submit()
    {
        if (HasPermissionTyreServiceEdit)
        {
            if (_busy)
            {
                snackbar.Add("Please wait while form is being submitted!", Severity.Warning);
                return;
            }
            _busy = true;
            var authprov = await auth.GetAuthenticationStateAsync();
            var user = authprov.User;
            var brancIDString = authprov.User.Claims.First(x => x.Type == "BranchID").Value;
            var BranchID = int.Parse(brancIDString);
            if (model != null)
            {
                model.UserInfo.UserID = user.Identity.Name;
                model.BranchID = BranchID;
                try
                {
                    model.Tyres = PassedListTyres.Select(s => s.TyreID).ToList();
                    Iservice.ResoleBegin(model);
                }
                catch (Exception ex)
                {
                    snackbar.Add(ex.Message, Severity.Error);
                }
            }
            dialogForm.Close(DialogResult.Ok(true));

            await Task.Delay(200);
            _busy = false;
        }
        else
        {
            bool? result = await DialogService.ShowMessageBoxAsync(
                "Permission denied!",
                "You don't have any permission to Edit Tyre.");
        }
    }
}
