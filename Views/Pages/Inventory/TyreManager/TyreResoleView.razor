@page "/TyreResoleView"
@using ArmsModels.BaseModels.General
@using ArmsServices.DataServices.Operations
@inject ITyreService ITyreservice
@inject MudBlazor.ISnackbar snackbar
@inject IPartyService partyIservice
@inject AuthenticationStateProvider auth
@attribute [Authorize]
@using System.Threading;
@inject IRoleService<RoleModel> Irole
@inject IDialogService DialogService

<div class="admin-page-container fade-in">
    <div class="admin-header-tiered mb-6">
        <div class="d-flex align-center justify-space-between">
            <div>
                <MudText Typo="Typo.h4" Class="admin-title">Tyre Resole</MudText>
                <MudText Typo="Typo.body2" Class="admin-subtitle">Track and manage the retreading process for vehicle tyres with external parties.</MudText>
            </div>
            <MudButton Disabled="@_busy" Variant="Variant.Filled" Color="Color.Primary" OnClick="@(()=> OpenDialogEdit(new TyreResoleModel()))" Class="admin-register-btn" StartIcon="@Icons.Material.Filled.Add">INITIATE RESOLE</MudButton>
        </div>
    </div>

    <div class="admin-glass-card overflow-hidden">
        <MudTable Items="@collection" Elevation="0" Hover="true" Breakpoint="Breakpoint.Sm" Class="modern-admin-table">
            <HeaderContent>
                <MudTh><MudTableSortLabel SortBy="new Func<TyreResoleModel, object>(x=> x.Party.TradeName)" InitialDirection="SortDirection.Ascending"><span class="admin-header-text">PARTY</span></MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<TyreResoleModel, object>(x=> x.RequestedDate)" InitialDirection="SortDirection.Ascending"><span class="admin-header-text">REQUESTED DATE</span></MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<TyreResoleModel, object>(x=> x.NoOfTyres)" InitialDirection="SortDirection.Ascending"><span class="admin-header-text">NO. OF TYRES</span></MudTableSortLabel></MudTh>
                <MudTh Style="text-align: right;"><span class="admin-header-text">ACTIONS</span></MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Party"><span class="admin-td-primary fw-600">@context.Party?.TradeName</span></MudTd>
                <MudTd DataLabel="Requested Date">@context.RequestedDate?.ToString("dd MMM yyyy")</MudTd>
                <MudTd DataLabel="No Of Tyres">
                    <MudChip T="string" Size="Size.Small" Color="Color.Secondary" Variant="Variant.Text" Class="fw-700">@context.NoOfTyres Units</MudChip>
                </MudTd>
                <MudTd DataLabel="Actions" Style="text-align: right;">
                    <MudTooltip Text="Edit Resole Order">
                        <MudIconButton OnClick="@(()=> OpenDialogEdit(context))" Color="Color.Primary" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Variant="Variant.Text" />
                    </MudTooltip>
                    <MudTooltip Text="Cancel Order">
                        <MudIconButton OnClick="@(()=> OpenDialogCancel(context))" Color="Color.Error" Icon="@Icons.Material.Filled.Cancel" Size="Size.Small" Variant="Variant.Text" />
                    </MudTooltip>
                </MudTd>
            </RowTemplate>
            <PagerContent>
                <div class="pa-4">
                    <MudTablePager PageSizeOptions="new int[] { 10, 20, 50, 100 }" />
                </div>
            </PagerContent>
        </MudTable>
    </div>
</div>

@code {

    private List<TyreResoleModel> collection = new();
    string UserID;
    List<PartyModel> partyList = new List<PartyModel>();
    private bool _busy;

    public bool HasPermissionTyreServiceCancel { get; set; } = false;
    public int DocTypeID = 63;

    protected async override Task OnInitializedAsync()
    {
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionTyreServiceCancel = await Irole.HasClaim(DocTypeID.ToString(), "Cancel", ctc.Token);

        partyList = partyIservice.Select(0).ToList();
        await GetAll();
    }

    private async Task GetAll()
    {
        collection = new();
        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;
        UserID = user.Identity.Name;
        var BranchID = int.Parse(authprov.User.Claims.First(x => x.Type == "BranchID").Value);
        collection = ITyreservice.SelectTyreResoleListByBranchId(BranchID).ToList();
        if (partyList != null && partyList.Count() != 0)
        {
            foreach (var item in collection)
            {
                if (item.Party != null && item.Party.PartyID != null && partyList.Any(s => s.PartyID == item.Party.PartyID))
                {
                    item.Party = partyList.First(s => s.PartyID == item.Party.PartyID);
                }
            }
        }
    }

    private async Task OpenDialogEdit(TyreResoleModel TyreResole)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        _busy = true;
        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;
        TyreResole.UserInfo = new();
        if (TyreResole.UserInfo != null)
        {
            TyreResole.UserInfo.UserID = user.Identity.Name;
        }
        var param = new DialogParameters { ["model"] = TyreResole.Clone() };
        var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Medium };
        var dialog = await DialogService.ShowAsync<TyreResoleDialog>("ADD/EDIT", param, options);
        var result = await dialog.Result;

        // you can check if the modal was cancelled
        var isCancelled = result.Canceled;
        if (!isCancelled)
        {
            await GetAll();
        }
        await Task.Delay(200);
        _busy = false;
    }

    private async Task OpenDialogCancel(TyreResoleModel TyreResole)
    {
        if (HasPermissionTyreServiceCancel)
        {
            bool? result = await DialogService.ShowMessageBoxAsync(
                "Warning",
                "Are you sure you want to cancel this entry?",
                yesText: "Delete!", cancelText: "Cancel");
            if (result != null)
            {
                try
                {
                    var authprov = await auth.GetAuthenticationStateAsync();
                    var user = authprov.User;
                    TyreResole.UserInfo = new();
                    if (TyreResole.UserInfo != null)
                    {
                        TyreResole.UserInfo.UserID = user.Identity.Name;
                        ITyreservice.ResoleCancel(TyreResole.ID, TyreResole.UserInfo.UserID);
                    }
                    await GetAll();
                    snackbar.Add("Cancelled Successfully", Severity.Success);
                }
                catch (Exception ex)
                {
                    snackbar.Add(ex.Message, Severity.Error);
                }
            }
        }
        else
        {
            bool? result = await DialogService.ShowMessageBoxAsync(
                "Permission denied!",
                "You don't have any permission to Cancel Tyre.");
        }
    }

    private async Task OpenDialog()
    {
        TyreResoleModel TyreResole = new();
        var model = new DialogParameters { ["model"] = TyreResole };
        var options = new DialogOptions { CloseOnEscapeKey = true };
        await DialogService.ShowAsync<TyreDialog>("Simple Dialog", model, options);
    }
}

