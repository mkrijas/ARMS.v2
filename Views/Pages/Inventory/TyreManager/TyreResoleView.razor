@page "/TyreResoleView"
@using ArmsModels.BaseModels.General
@using ArmsServices.DataServices.Operations

@inject ITyreService ITyreservice
@inject MudBlazor.ISnackbar snackbar
@inject IPartyService partyIservice

@inject AuthenticationStateProvider auth
@attribute [Authorize]
@inject IDialogService DialogService


<MudGrid Spacing="4">
    <MudItem xs="12">
        <MudTable Items="@collection" Dense="true" Hover="true" Striped="true" Elevation="10">
            <ToolBarContent>
                <MudText Typo="Typo.h6">Tyre Resole</MudText>
                <MudTooltip Text="New Tyre Resole">
                    <MudIconButton Icon="@Icons.Material.Filled.Add" Title="Add" @onclick="@(()=> OpenDialogEdit(new TyreResoleModel()))" Color="Color.Dark" Size="Size.Small"></MudIconButton>
                </MudTooltip>
                <MudSpacer></MudSpacer>

            </ToolBarContent>
            <HeaderContent>
                <MudTh><MudTableSortLabel SortBy="new Func<TyreResoleModel, object>(x=> x.Party.TradeName)" InitialDirection="SortDirection.Ascending">Party</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<TyreResoleModel, object>(x=> x.RequestedDate)" InitialDirection="SortDirection.Ascending">Requested Date</MudTableSortLabel></MudTh>
                <MudTh>Actions</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Tyre">@context.Party.TradeName</MudTd>
                <MudTd DataLabel="Make">@context.RequestedDate</MudTd>
                <MudTd DataLabel="Actions">
                    <MudTooltip Text="Edit">
                        <MudIconButton @onclick="@(()=> OpenDialogEdit(context))" Color="Color.Primary" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" />
                    </MudTooltip>
                    <MudTooltip Text="Cancel">
                        <MudIconButton @onclick="@(()=> OpenDialogCancel(context))" Color="Color.Primary" Icon="@Icons.Material.Filled.Cancel" Size="Size.Small" />
                    </MudTooltip>
                </MudTd>
            </RowTemplate>

            <PagerContent>
                <MudTablePager PageSizeOptions="new int[] { 5, 10, 20, 50, 100 }" />
            </PagerContent>
        </MudTable>
    </MudItem>
</MudGrid>
@code {


    private List<TyreResoleModel> collection = new();
    string UserID;
    List<PartyModel> partyList = new List<PartyModel>();
    private async Task OpenDialogEdit(TyreResoleModel TyreResole)
    {
        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;

        TyreResole.UserInfo = new();
        if (TyreResole.UserInfo != null)
        {
            TyreResole.UserInfo.UserID = user.Identity.Name;
        }

        var param = new DialogParameters { ["model"] = TyreResole };
        var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Medium };
        var dialog = DialogService.Show<TyreResoleDialog>("ADD/EDIT", param, options);

        var result = await dialog.Result;

        // you can check if the modal was cancelled
        var isCancelled = result.Canceled;
        if (!isCancelled)
        {
            await GetAll();
        }
    }
    private async Task OpenDialogCancel(TyreResoleModel TyreResole)
    {

        bool? result = await DialogService.ShowMessageBox(
            "Warning",
            "Are you sure you want to cancel this entry?",
            yesText: "Delete!", cancelText: "Cancel");

        if (result != null)
        {
            try
            {
                var authprov = await auth.GetAuthenticationStateAsync();
                var user = authprov.User;
                TyreResole.UserInfo = new();
                if (TyreResole.UserInfo != null)
                {
                    TyreResole.UserInfo.UserID = user.Identity.Name;
                    ITyreservice.ResoleCancel(TyreResole.ID, TyreResole.UserInfo.UserID);
                }
                await GetAll();
                snackbar.Add("Cancelled Successfully", Severity.Success);
            }
            catch (Exception ex)
            {
                snackbar.Add(ex.Message, Severity.Error);
            }

        }

    }

    protected async override Task OnInitializedAsync()
    {
        //model = new();

        partyList = partyIservice.Select(0).ToList();
        await GetAll();
    }

    private async Task GetAll()
    {

        collection = new();

        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;
        UserID = user.Identity.Name;
        var BranchID = int.Parse(authprov.User.Claims.First(x => x.Type == "BranchID").Value);
        collection = ITyreservice.SelectTyreResoleList(0).ToList();
        if (partyList != null && partyList.Count() != 0)
        {

            foreach (var item in collection)
            {
                if (item.Party != null && item.Party.PartyID != null && partyList.Any(s => s.PartyID == item.Party.PartyID))
                {
                    item.Party = partyList.First(s => s.PartyID == item.Party.PartyID);

                }
            }
        }
    }

    private void OpenDialog()
    {
        TyreResoleModel TyreResole = new();

        var model = new DialogParameters { ["model"] = TyreResole };

        var options = new DialogOptions { CloseOnEscapeKey = true };
        DialogService.Show<TyreDialog>("Simple Dialog", model, options);
    }

}