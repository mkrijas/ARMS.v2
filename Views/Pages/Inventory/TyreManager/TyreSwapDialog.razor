@using ArmsModels.BaseModels.General
@using System.ComponentModel.DataAnnotations
@inject AuthenticationStateProvider auth
@inject MudBlazor.ISnackbar snackbar
@inject ITyreService IServices

<DialogForm @ref="@dialogForm" Title="Asset Exchange Protocol" Subtitle="High-precision tyre position swapping and axial recalibration for the designated vehicle." Icon="@Icons.Material.Filled.SwapHoriz" AdminStyle="true" formID="formSwap" model="@model" _busy="_busy">
    <FormContent>
        <div class="dialog-content-wrapper">
            <EditForm id="formSwap" Model="@model" OnValidSubmit="Swap">
                <DataAnnotationsValidator />
                
                <div class="admin-glass-card pa-6">
                    <div class="d-flex align-center mb-6">
                        <MudIcon Icon="@Icons.Material.Filled.MultipleStop" Color="Color.Primary" Class="mr-2" />
                        <span class="admin-section-label mb-0">Exchange Specification</span>
                    </div>

                    <MudGrid Spacing="3">
                        <MudItem xs="12" md="6">
                            <div class="swap-unit pa-4 rounded-lg" style="background: rgba(0,0,0,0.02); border: 1px solid rgba(0,0,0,0.05);">
                                <MudText Typo="Typo.caption" Class="fw-700 color-primary uppercase mb-2 d-block">Source Asset (Tyre A)</MudText>
                                <MudSelect T="TyreMountedModel" Variant="Variant.Outlined" Margin="Margin.Normal" Label="Select Mounted Tyre" ToStringFunc="@(e => e == null ? null : $"{e.TyreNo}")" Value="@SelectedTyreA" ValueChanged="OnTyreAChanged" Class="modern-input" AdornmentIcon="@Icons.Material.Filled.Lens">
                                    @foreach (TyreMountedModel TyreMount in TruckMountedTyreList)
                                    {
                                        <MudSelectItem Value="@TyreMount">@TyreMount.TyreNo</MudSelectItem>
                                    }
                                </MudSelect>
                                <MudTextField ReadOnly @bind-Value="SelectedTyreA.PositionName" Label="Current Axial Position" Variant="Variant.Outlined" Margin="Margin.Normal" Class="modern-input" Style="background: white;"></MudTextField>
                            </div>
                        </MudItem>

                        <MudItem xs="12" md="6">
                            <div class="swap-unit pa-4 rounded-lg" style="background: rgba(0,0,0,0.02); border: 1px solid rgba(0,0,0,0.05);">
                                <MudText Typo="Typo.caption" Class="fw-700 color-secondary uppercase mb-2 d-block">Target Asset (Tyre B)</MudText>
                                <MudSelect T="TyreMountedModel" Variant="Variant.Outlined" Margin="Margin.Normal" Label="Select Mounted Tyre" ToStringFunc="@(e => e == null ? null : $"{e.TyreNo}")" Value="@SelectedTyreB" ValueChanged="OnTyreBChanged" Class="modern-input" AdornmentIcon="@Icons.Material.Filled.Lens">
                                    @foreach (TyreMountedModel TyreMount in TruckMountedTyreList)
                                    {
                                        <MudSelectItem Value="@TyreMount">@TyreMount.TyreNo</MudSelectItem>
                                    }
                                </MudSelect>
                                <MudTextField ReadOnly @bind-Value="SelectedTyreB.PositionName" Label="Current Axial Position" Variant="Variant.Outlined" Margin="Margin.Normal" Class="modern-input" Style="background: white;"></MudTextField>
                            </div>
                        </MudItem>
                    </MudGrid>
                </div>
            </EditForm>
        </div>
    </FormContent>
    <Actions>
        <MudButton Disabled="@_busy" Variant="Variant.Filled" Color="Color.Primary" OnClick="Swap" StartIcon="@Icons.Material.Filled.SwapCalls" Class="px-12 rounded-pill py-3 shadow-none">Execute Exchange</MudButton>
    </Actions>
</DialogForm>

@code {

    DialogForm dialogForm;
    private bool _busy;
    [Parameter]
    public TyreSwapModel model { get; set; } = new();
    [Parameter]
    public TruckModel SelectedTruck { get; set; } = new();
    [Required]
    public TyrePositionModel SelectedTyreAPosition { get; set; } = new();
    [Required]
    private TyreMountedModel SelectedTyreA { get; set; } = new();
    [Required]
    public TyrePositionModel SelectedTyreBPosition { get; set; } = new();
    [Required]
    private TyreMountedModel SelectedTyreB { get; set; } = new();
    List<TyreMountedModel> TruckMountedTyreList = new();
    List<TyrePositionModel> TyrePositionListForMountAndUnMount = new();

    protected override void OnInitialized()
    {
        if (SelectedTruck != null && SelectedTruck.TruckID != null && SelectedTruck.TruckID != 0)
        {
            TruckMountedTyreList = IServices.SelectMountedTyresByID(SelectedTruck?.TruckID ?? 0).ToList();
            TyrePositionListForMountAndUnMount = IServices.GetTyrePositionList().ToList();
            model.TruckID = SelectedTruck.TruckID;
        }
    }

    private void OnTyreAChanged(TyreMountedModel obj)
    {
        SelectedTyreA = obj;
        model.TyreA = obj?.TyreID ?? null;
        model.TyreBTargetPosition = obj?.PositionID ?? null;
        SelectedTyreA.PositionName = obj?.PositionName ?? null;
    }

    private void OnTyreBChanged(TyreMountedModel obj)
    {
        SelectedTyreB = obj;
        model.TyreB = obj?.TyreID ?? null;
        model.TyreATargetPosition = obj?.PositionID ?? null;
        SelectedTyreB.PositionName = obj?.PositionName ?? null;
    }

    public async Task Swap()
    {
        if(model.TyreA == model.TyreB)
        {
            snackbar.Add("Select diffrent tyres", Severity.Warning);
            return;
        }
        
        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;
        var brancIDString = authprov.User.Claims.First(x => x.Type == "BranchID").Value;
        if (model != null)
        {
            model.UserInfo.UserID = user.Identity.Name;
            try
            {
                IServices.Swap(model);
                snackbar.Add("Tyre Swaped Successfully", Severity.Success);
                dialogForm.Close(DialogResult.Ok(true));
            }
            catch (Exception ex)
            {
                snackbar.Add(ex.Message, Severity.Error);
            }
        }
    }

    void Cancel()
    {
        dialogForm.Cancel();
    }
}
