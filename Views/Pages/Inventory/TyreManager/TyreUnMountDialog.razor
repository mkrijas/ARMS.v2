@using ArmsModels.BaseModels.General
@using System.ComponentModel.DataAnnotations
@inject AuthenticationStateProvider auth
@inject MudBlazor.ISnackbar snackbar
@inject ITyreService IServices
@using System.Threading;
@inject IRoleService<RoleModel> Irole
@inject IDialogService DialogService

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.Edit" Class="mr-3" />Unmount @SelectedTyre.ItemType
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudContainer Style="max-height: 400px; overflow-y: scroll; margin-left:20px">
            <EditForm id="formUnMount" Model="@SubmitModel" OnValidSubmit="UnMount">
                <ObjectGraphDataAnnotationsValidator />
                <ValidationSummary />
                <MudGrid Spacing="2">
                    <MudItem xs="12" md="12" Class="mb-6">
                        <MudSelect T="TyreModel" Variant="Variant.Outlined" Disabled="IsTyreDisabled" Margin="Margin.Dense" Label="Tyre" @bind-Value="@SubmitModel.Tyre" ToStringFunc="@(e => e== null ? null : $"{e.TyreSerialNumber}")">
                            @foreach (TyreModel Tyre in TyreList)
                            {
                                <MudSelectItem Value="@Tyre">@Tyre.TyreSerialNumber</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudTextField @bind-Value="@SubmitModel.UnmountedKM" Label="UnMounted KM" Variant="Variant.Outlined" Margin="Margin.Dense"></MudTextField>
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <StoreSelector @bind-Value="SubmitModel.Store" VariantParameter="Variant.Outlined" MarginParameter="Margin.Dense" BranchID="@branchID.Value"></StoreSelector>
                    </MudItem>
                </MudGrid>
            </EditForm>
        </MudContainer>
    </DialogContent>
    <DialogActions>
        <MudButton Disabled="@_busy" form="formUnMount" Variant="Variant.Filled" Color="Color.Primary" ButtonType="ButtonType.Submit" Class="px-12">UnMount</MudButton>
    </DialogActions>
</MudDialog>

@code {

    [CascadingParameter] MudDialogInstance MudDialog { get; set; }
    [Parameter]
    public TyreMountedModel model { get; set; } = new();
    [Parameter]
    public TruckModel SelectedTruck { get; set; } = new();
    [Parameter]
    public TyreModel SelectedTyre { get; set; } = new();
    public TyreUnMountedModel SubmitModel { get; set; } = new();
    List<TyreModel> TyreList = new();
    List<TyrePositionModel> TyrePositionListForMountAndUnMount = new();
    public bool IsTruckDisabled { get; set; } = false;
    public bool IsTyreDisabled { get; set; } = false;
    private bool _busy;
    private int? branchID = null;

    public bool HasPermissionTyreServiceUnmount { get; set; } = false;
    public int DocTypeID = 63;

    protected override async Task OnInitializedAsync()
    {
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionTyreServiceUnmount = await Irole.HasClaim(DocTypeID.ToString(), "Unmount", ctc.Token);
        var authprov = await auth.GetAuthenticationStateAsync();
        var brancIDString = authprov.User.Claims.First(x => x.Type == "BranchID").Value;
        branchID = int.Parse(brancIDString);
        var Tyres = IServices.SelectUnmontedTyresByID(0);
        if (Tyres != null && Tyres.Count() != 0)
        {
            TyreList = Tyres.ToList();
        }
        if (SelectedTruck != null && SelectedTruck.TruckID != null && SelectedTruck.TruckID != 0)
        {
            IsTruckDisabled = true;
        }
        else
        {
            IsTruckDisabled = false;
        }

        if (SelectedTyre != null && SelectedTyre.TyreID != null && SelectedTyre.TyreID != 0)
        {
            IsTyreDisabled = true;
        }
        else
        {
            IsTyreDisabled = false;
        }

        if (SelectedTruck != null && SelectedTruck.TruckTypeID != 0 || SelectedTyre != null && SelectedTyre.TyreID != 0)
        {
            model.TruckID = SelectedTruck.TruckID;
            TyrePositionListForMountAndUnMount = IServices.GetTyrePositionListUsingTruckTypeId(SelectedTruck.TruckTypeID).ToList();
        }
    }

    protected override void OnParametersSet()
    {
        SubmitModel.Tyre = SelectedTyre;
    }

    void Cancel()
    {
        MudDialog.Cancel();
    }

    public async Task UnMount()
    {
        if (HasPermissionTyreServiceUnmount)
        {
            if (_busy)
            {
                snackbar.Add("Please wait while form is being submitted!", Severity.Warning);
                return;
            }
            _busy = true;
            var authprov = await auth.GetAuthenticationStateAsync();
            var user = authprov.User;
            var brancIDString = authprov.User.Claims.First(x => x.Type == "BranchID").Value;
            if (model != null)
            {
                model.UserInfo.UserID = user.Identity.Name;
                IServices.Unmount(SubmitModel.Tyre.TyreID, DateTime.Now, SubmitModel.UnmountedKM, SubmitModel.Store, model.UserInfo.UserID);
                snackbar.Add("Unmounted Successfully", Severity.Success);
            }
            MudDialog.Close(DialogResult.Ok(true));
            await Task.Delay(200);
            _busy = false;
        }
        else
        {
            bool? result = await DialogService.ShowMessageBox(
                "Permission denied!",
                "You don't have any permission to Delete Tyre.");
        }
    }
}