@using ArmsModels.BaseModels.General
@using System.ComponentModel.DataAnnotations
@inject AuthenticationStateProvider auth
@inject MudBlazor.ISnackbar snackbar
@inject ITyreService IServices
@using System.Threading;
@inject IRoleService<RoleModel> Irole
@inject IDialogService DialogService

<DialogForm @ref="@dialogForm" Title="Asset Decommissioning (Unmount)" Subtitle="Securely decommission assets from active service and synchronize warehouse inventories." Icon="@Icons.Material.Filled.VerticalAlignTop" AdminStyle="true" formID="formUnMount" model="@SubmitModel" _busy="_busy">
    <FormContent>
        <div class="dialog-content-wrapper">
            <EditForm id="formUnMount" Model="@SubmitModel" OnValidSubmit="UnMount">
                <ObjectGraphDataAnnotationsValidator />
                
                <div class="admin-glass-card pa-6 mb-6">
                    <div class="d-flex align-center mb-6">
                        <MudIcon Icon="@Icons.Material.Filled.Info" Color="Color.Primary" Class="mr-2" />
                        <span class="admin-section-label mb-0">Decommissioning Blueprint</span>
                    </div>

                    <MudGrid Spacing="3">
                        <MudItem xs="12">
                            <MudSelect T="TyreModel" Variant="Variant.Outlined" Disabled="IsTyreDisabled" Margin="Margin.Normal" Label="Target Asset for Unmounting" @bind-Value="@SubmitModel.Tyre" ToStringFunc="@(e => e== null ? null : $"{e.TyreSerialNumber}")" Class="modern-input" AdornmentIcon="@Icons.Material.Filled.Lens">
                                @foreach (TyreModel Tyre in TyreList)
                                {
                                    <MudSelectItem Value="@Tyre">@Tyre.TyreSerialNumber</MudSelectItem>
                                }
                            </MudSelect>
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <MudTextField @bind-Value="@SubmitModel.UnmountedKM" Label="Current Odometer (Unmount KM)" Variant="Variant.Outlined" Margin="Margin.Normal" Class="modern-input" Adornment="Adornment.End" AdornmentText="KM" />
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <StoreSelector @bind-Value="SubmitModel.Store" VariantParameter="Variant.Outlined" MarginParameter="Margin.Normal" BranchID="@branchID.Value" Class="modern-selector"></StoreSelector>
                        </MudItem>
                    </MudGrid>
                </div>

                <div class="admin-glass-card pa-6 text-center shadow-none gray-bg">
                    <MudIcon Icon="@Icons.Material.Filled.Warning" Color="Color.Warning" Size="Size.Large" Class="mb-2" />
                    <MudText Typo="Typo.body2" Class="fw-500">
                        Ensure all logistical data is validated before finalizing the decommissioning protocol.
                    </MudText>
                </div>
            </EditForm>
        </div>
    </FormContent>
</DialogForm>

@code {
    DialogForm dialogForm;
    [Parameter]
    public TyreMountedModel model { get; set; } = new();
    [Parameter]
    public TruckModel SelectedTruck { get; set; } = new();
    [Parameter]
    public TyreModel SelectedTyre { get; set; } = new();
    public TyreUnMountedModel SubmitModel { get; set; } = new();
    List<TyreModel> TyreList = new();
    List<TyrePositionModel> TyrePositionListForMountAndUnMount = new();
    public bool IsTruckDisabled { get; set; } = false;
    public bool IsTyreDisabled { get; set; } = false;
    private bool _busy;
    private int? branchID = null;

    public bool HasPermissionTyreServiceUnmount { get; set; } = false;
    public int DocTypeID = 63;

    protected override async Task OnInitializedAsync()
    {
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionTyreServiceUnmount = await Irole.HasClaim(DocTypeID.ToString(), "Unmount", ctc.Token);
        var authprov = await auth.GetAuthenticationStateAsync();
        var brancIDString = authprov.User.Claims.First(x => x.Type == "BranchID").Value;
        branchID = int.Parse(brancIDString);
        var Tyres = IServices.SelectUnmontedTyresByID(0);
        if (Tyres != null && Tyres.Count() != 0)
        {
            TyreList = Tyres.ToList();
        }
        if (SelectedTruck != null && SelectedTruck.TruckID != null && SelectedTruck.TruckID != 0)
        {
            IsTruckDisabled = true;
        }
        else
        {
            IsTruckDisabled = false;
        }

        if (SelectedTyre != null && SelectedTyre.TyreID != null && SelectedTyre.TyreID != 0)
        {
            IsTyreDisabled = true;
        }
        else
        {
            IsTyreDisabled = false;
        }

        if (SelectedTruck != null && SelectedTruck.TruckTypeID != 0 || SelectedTyre != null && SelectedTyre.TyreID != 0)
        {
            model.TruckID = SelectedTruck.TruckID;
            TyrePositionListForMountAndUnMount = IServices.GetTyrePositionListUsingTruckTypeId(SelectedTruck.TruckTypeID).ToList();
        }
    }

    protected override void OnParametersSet()
    {
        SubmitModel.Tyre = SelectedTyre;
    }

    void Cancel()
    {
        dialogForm.Cancel();
    }

    public async Task UnMount()
    {
        if (HasPermissionTyreServiceUnmount)
        {
            if (_busy)
            {
                snackbar.Add("Please wait while form is being submitted!", Severity.Warning);
                return;
            }
            _busy = true;
            var authprov = await auth.GetAuthenticationStateAsync();
            var user = authprov.User;
            var brancIDString = authprov.User.Claims.First(x => x.Type == "BranchID").Value;
            if (model != null)
            {
                model.UserInfo.UserID = user.Identity.Name;
                IServices.Unmount(SubmitModel.Tyre.TyreID, DateTime.Now, SubmitModel.UnmountedKM, SubmitModel.Store, model.UserInfo.UserID);
                snackbar.Add("Unmounted Successfully", Severity.Success);
            }
            dialogForm.Close(DialogResult.Ok(true));
            await Task.Delay(200);
            _busy = false;
        }
        else
        {
            bool? result = await DialogService.ShowMessageBoxAsync(
                "Permission denied!",
                "You don't have any permission to Unmount Tyre.");
        }
    }
}
