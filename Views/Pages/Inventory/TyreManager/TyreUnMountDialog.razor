@using ArmsModels.BaseModels.General
@using System.ComponentModel.DataAnnotations
@inject AuthenticationStateProvider auth
@inject MudBlazor.ISnackbar snackbar
@inject ITyreService IServices
@using System.Threading;
@inject IRoleService<RoleModel> Irole
@inject IDialogService DialogService

<MudDialog Class="admin-dialog-glass">
    <TitleContent>
        <div class="header-section mb-2 pt-4 px-4">
            <div class="d-flex align-center justify-space-between">
                <div class="d-flex align-center">
                    <div class="icon-badge primary-badge mr-4">
                        <div class="admin-header-icon-badge mb-3">
                            <MudIcon Icon="@Icons.Material.Filled.VerticalAlignTop" Color="Color.Secondary" Style="font-size: 3rem;" />
                        </div>
                    </div>
                    <div>
                        <MudText Typo="Typo.h5" Class="admin-title"><b>Asset Decommissioning (Unmount)</b></MudText>
                        <MudText Typo="Typo.body2" Class="admin-subtitle">Securely decommission assets from active service and synchronize warehouse inventories.</MudText>
                    </div>
                </div>
            </div>
            <div class="title-accent mt-4"></div>
        </div>
    </TitleContent>
    <DialogContent>
        <MudContainer Class="admin-dialog-container">
            <div class="dialog-content-wrapper pa-4">
                <EditForm id="formUnMount" Model="@SubmitModel" OnValidSubmit="UnMount">
                    <ObjectGraphDataAnnotationsValidator />
                    
                    <div class="admin-glass-card pa-6 mb-6">
                        <div class="d-flex align-center mb-6">
                            <MudIcon Icon="@Icons.Material.Filled.Info" Color="Color.Primary" Class="mr-2" />
                            <span class="admin-section-label mb-0">Decommissioning Blueprint</span>
                        </div>

                        <MudGrid Spacing="3">
                            <MudItem xs="12">
                                <MudTextField Disabled @bind-Value="@SubmitModel?.Tyre?.TyreSerialNumber" Label="Target Asset for Unmounting" Variant="Variant.Outlined" Margin="Margin.Normal" Class="modern-input" />
                               @*  <MudSelect For="@(() => SubmitModel.Tyre)" T="TyreModel" Variant="Variant.Outlined" Disabled="IsTyreDisabled" Margin="Margin.Normal" Label="Target Asset for Unmounting" @bind-Value="@SubmitModel.Tyre" ToStringFunc="@(e => e== null ? null : $"{e.TyreSerialNumber}")" Class="modern-input" AdornmentIcon="@Icons.Material.Filled.Lens">
                                    @foreach (TyreModel Tyre in TyreList)
                                    {
                                        <MudSelectItem Value="@Tyre">@Tyre.TyreSerialNumber</MudSelectItem>
                                    }
                                </MudSelect> *@
                            </MudItem>
                            <MudItem xs="12" md="6">
                                <MudTextField @bind-Value="@SubmitModel.UnmountedKM" Label="Current Odometer (Unmount KM)" Variant="Variant.Outlined" Margin="Margin.Normal" Class="modern-input" Adornment="Adornment.End" AdornmentText="KM" />
                            </MudItem>
                            <MudItem xs="12" md="6">
                                 <StoreSelector For="@(() => SubmitModel.Store)" @bind-Value="SubmitModel.Store" VariantParameter="Variant.Outlined" MarginParameter="Margin.Normal" BranchID="@branchID.Value" Class="modern-selector"></StoreSelector>
                            </MudItem>
                        </MudGrid>
                    </div>

                    <div class="admin-glass-card pa-6 text-center shadow-none gray-bg">
                        <MudIcon Icon="@Icons.Material.Filled.Warning" Color="Color.Warning" Size="Size.Large" Class="mb-2" />
                        <MudText Typo="Typo.body2" Class="fw-500">
                            Ensure all logistical data is validated before finalizing the decommissioning protocol.
                        </MudText>
                    </div>
                </EditForm>
            </div>
        </MudContainer>
    </DialogContent>
    <DialogActions>
        <div class="d-flex w-100 flex-wrap pa-4 gap-3 align-center">
            <MudSpacer />
            <MudButton @onclick="Cancel" Variant="Variant.Outlined" Color="Color.Default" Style="border-radius: 12px; font-weight: 700; text-transform: none; border-color: rgba(0,0,0,0.15);">Discard</MudButton>
            <MudButton Disabled="@_busy" form="formUnMount" Variant="Variant.Filled" ButtonType="ButtonType.Submit" Color="Color.Success" Style="background: var(--mud-palette-success); color: white; font-weight: 800; border-radius: 12px; text-transform: none; white-space: nowrap; padding: 8px 24px;" StartIcon="@Icons.Material.Filled.DoneAll">Submit</MudButton>
        </div>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; }
    [Parameter]
    public TyreMountedModel model { get; set; } = new();
    [Parameter]
    public TruckModel SelectedTruck { get; set; } = new();
    [Parameter]
    public TyreModel SelectedTyre { get; set; } = new();

    public TyreUnMountedModel SubmitModel { get; set; } = new();
    List<TyreModel> TyreList = new();
    List<TyrePositionModel> TyrePositionListForMountAndUnMount = new();
    public bool IsTruckDisabled { get; set; } = false;
    public bool IsTyreDisabled { get; set; } = false;
    private bool _busy;
    private int? branchID = null;

    public bool HasPermissionTyreServiceUnmount { get; set; } = false;
    public int DocTypeID = 63;

    protected override async Task OnInitializedAsync()
    {
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionTyreServiceUnmount = await Irole.HasClaim(DocTypeID.ToString(), "Unmount", ctc.Token);
        var authprov = await auth.GetAuthenticationStateAsync();
        var brancIDString = authprov.User.Claims.First(x => x.Type == "BranchID").Value;
        branchID = int.Parse(brancIDString);

        if (SelectedTyre is null)
        {
            SelectedTyre = IServices.SelectUnmontedTyresByID(model.TyreID).FirstOrDefault();
        }
        SubmitModel.Tyre = SelectedTyre; 
        //var Tyres = IServices.SelectUnmontedTyresByID(0);
        // if (Tyres != null && Tyres.Count() != 0)
        // {
        //     TyreList = Tyres.ToList();
        // }


        IsTruckDisabled = (SelectedTruck != null && SelectedTruck.TruckID != null && SelectedTruck.TruckID != 0);
        IsTyreDisabled = (SelectedTyre != null && SelectedTyre.TyreID != null && SelectedTyre.TyreID != 0);    


        if (SelectedTruck != null && SelectedTruck.TruckTypeID != 0 || SelectedTyre != null && SelectedTyre.TyreID != 0)
        {
            model.TruckID = SelectedTruck.TruckID;
            TyrePositionListForMountAndUnMount = IServices.GetTyrePositionListUsingTruckTypeId(SelectedTruck.TruckTypeID).ToList();
        }
    }
   

    void Cancel()
    {
        MudDialog.Cancel();
    }

    public async Task UnMount()
    {
        if (HasPermissionTyreServiceUnmount)
        {
            if (_busy)
            {
                snackbar.Add("Please wait while form is being submitted!", Severity.Warning);
                return;
            }
            _busy = true;
            var authprov = await auth.GetAuthenticationStateAsync();
            var user = authprov.User;
            var brancIDString = authprov.User.Claims.First(x => x.Type == "BranchID").Value;
            if (model != null)
            {
                model.UserInfo.UserID = user.Identity.Name;
                IServices.Unmount(SubmitModel.Tyre.TyreID, DateTime.Now, SubmitModel.UnmountedKM, SubmitModel.Store, model.UserInfo.UserID);
                snackbar.Add("Unmounted Successfully", Severity.Success);
            }
            MudDialog.Close(DialogResult.Ok(true));
            await Task.Delay(200);
            _busy = false;
        }
        else
        {
            bool? result = await DialogService.ShowMessageBoxAsync(
                "Permission denied!",
                "You don't have any permission to Unmount Tyre.");
        }
    }
}
