@page "/TyreMasterView"
@using ArmsModels.BaseModels.General
@using ArmsServices.DataServices.Operations
@using System.Threading;
@using System.Globalization
@using OfficeOpenXml
@using System.IO
@using OfficeOpenXml.Style
@inject ITyreService ITyreservice
@inject MudBlazor.ISnackbar snackbar
@inject AuthenticationStateProvider auth
@attribute [Authorize]
@using System.Threading;
@inject IRoleService<RoleModel> Irole
@inject IDialogService DialogService
@inject IJSRuntime JSRuntime

<MudGrid Spacing="4">
    <MudItem xs="12">
        <MudTable Items="@collection" Dense="true" Hover="true" Striped="true" Elevation="10" Filter="new Func<TyreModel,bool>(search)">
            <ToolBarContent>
                <MudText Typo="Typo.h6">Tyre/Accessories</MudText>
                <MudTooltip Text="New Tyre">
                    <MudIconButton Disabled="@_busy" Icon="@Icons.Material.Filled.Add" Title="Add" @onclick="@(()=> OpenDialogEdit(new TyreModel()))" Color="Color.Dark" Size="Size.Small"></MudIconButton>
                </MudTooltip>
                <MudSpacer></MudSpacer>
                <MudRadioGroup Value="@selectedOption" T="string" Style="padding-top: 8px;" ValueChanged="OnSelectedOptionChanged">
                    <MudRadio Value="@("All")" Color="Color.Primary">All</MudRadio>
                    <MudRadio Value="@("Mounted")" Color="Color.Primary">Mounted</MudRadio>
                    <MudRadio Value="@("UnMounted")" Color="Color.Primary">Un Mounted</MudRadio>
                </MudRadioGroup>
                <MudSpacer></MudSpacer>
                <MudTextField @bind-Value="searchTerm" Placeholder="Search tyre..." Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0"></MudTextField>
            </ToolBarContent>
            <HeaderContent>
                <MudTh><MudTableSortLabel SortBy="new Func<TyreModel, object>(x=> x.TyreSerialNumber)" InitialDirection="SortDirection.Ascending">Serial Number</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<TyreModel, object>(x=> x.Make)" InitialDirection="SortDirection.Ascending">Make</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<TyreModel, object>(x=> x.Make)" InitialDirection="SortDirection.Ascending">Item Type</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<TyreModel, object>(x=> x.TyreType)" InitialDirection="SortDirection.Ascending">Tyre Type</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<TyreModel, object>(x=> x.TyreSize)" InitialDirection="SortDirection.Ascending">Tyre Size</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<TyreModel, object>(x=> x.Status)" InitialDirection="SortDirection.Ascending">Status</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<TyreModel, object>(x=> x.TotalExpectedLife)" InitialDirection="SortDirection.Ascending">Expected Life</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<TyreModel, object>(x=> x.TyrePosition)" InitialDirection="SortDirection.Ascending">Mounted Truck</MudTableSortLabel></MudTh>
                @* <MudTh><MudTableSortLabel SortBy="new Func<TyreModel, object>(x=> x.Tubeless)" > Tubeless </MudTableSortLabel></MudTh> *@
                <MudTh>Actions</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Tyre">@context.TyreSerialNumber</MudTd>
                <MudTd DataLabel="Make">@context.Make</MudTd>
                <MudTd DataLabel="ItemType">@context.ItemType - @context.ItemCode</MudTd>
                <MudTd DataLabel="TyreType">@context.TyreType</MudTd>
                <MudTd DataLabel="TyreSize">@context.TyreSize</MudTd>
                <MudTd DataLabel="Status">@context.Status</MudTd>
                <MudTd DataLabel="TotalExpectedLife">@context.TotalExpectedLife</MudTd>
                <MudTd DataLabel="TyreSize">@context.TyrePosition</MudTd>
                @* <MudTd DataLabel="Tubeless">@context.Tubeless</MudTd> *@
                <MudTd DataLabel="Actions">
                    @if (string.IsNullOrEmpty(context.LockText))
                    {                         
                            string txt = context.IsMounted ? "UnMount" : "Mount";
                            string icon = context.IsMounted ? Icons.Material.Filled.Download : Icons.Material.Filled.Upload;
                            Color iconColor = context.IsMounted ? Color.Warning : Color.Success;
                        
                        <MudTooltip Text="Edit">
                            <MudIconButton @onclick="@(()=> OpenDialogEdit(context))" Color="Color.Primary" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" />
                        </MudTooltip>
                        
                        <MudTooltip Text="Remove">
                            <MudIconButton Disabled="@(context.IsMounted)" @onclick="@(()=> OpenDialogDelete(context))" Color="Color.Error" Icon="@Icons.Material.Filled.Remove" Size="Size.Small" />
                        </MudTooltip>
                        @* <MudTooltip Text="Km Reading">
                            <MudIconButton Disabled="@(context.ItemType != "Tyre")" @onclick="@(()=> OpenKmReading(context))" Color="Color.Primary" Icon="@Icons.Material.Filled.AvTimer" Size="Size.Small" />
                        </MudTooltip> *@
                       
                        <MudTooltip Text="@txt">
                            <MudIconButton @onclick="@(()=> TyreMountOrUnmount(context))" Color="@iconColor" Icon="@icon" Size="Size.Small" />
                        </MudTooltip>

                        <MudTooltip Text="View History">
                            <MudIconButton @onclick="@(()=> ViewHistory(context))" Color="Color.Primary" Icon="@Icons.Material.Filled.History" Size="Size.Small" />
                        </MudTooltip>
                    }
                    else
                    {
                        <MudText Typo="Typo.h6" >@context.LockText</MudText>
                    }
                </MudTd>
            </RowTemplate>
            <PagerContent>
                <MudTablePager PageSizeOptions="new int[] { 10, 20, 50, 100 }" />
            </PagerContent>
        </MudTable>
    </MudItem>
</MudGrid>

@code {

    private List<TyreModel> collection = new();
    string UserID;
    private bool _busy;
    private string searchTerm = "";
    private string selectedOption = "All";
    private int? BranchID;

    public bool HasPermissionTyreServiceDelete { get; set; } = false;
    public int DocTypeID = 63;

    protected async override Task OnInitializedAsync()
    {
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionTyreServiceDelete = await Irole.HasClaim(DocTypeID.ToString(), "Delete", ctc.Token);

        await GetAll();
    }

    private async Task GetAll()
    {
        collection = new();
        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;
        UserID = user.Identity.Name;
        BranchID = int.Parse(authprov.User.Claims.First(x => x.Type == "BranchID").Value);
        OnSelectedOptionChanged(selectedOption);
    }

    public void OnSelectedOptionChanged(string value)
    {
        selectedOption = value;
        switch (value)
        {
            case "Mounted":
                collection = ITyreservice.SelectByBranch(BranchID).Where(x => x.IsMounted).ToList();
                break;
            case "UnMounted":
                collection = ITyreservice.SelectByBranch(BranchID).Where(x => !x.IsMounted).ToList();                
                break;
            default:
                collection = ITyreservice.SelectByBranch(BranchID).ToList();
                break;
        }
    }

    private bool search(TyreModel model)
    {
        if ((model.TyreID != null && model.TyreSerialNumber.Contains(searchTerm, StringComparison.OrdinalIgnoreCase)) || (model.ItemType.Contains(searchTerm, StringComparison.OrdinalIgnoreCase)))
        {
            return true;
        }
        return false;
    }

    private async Task OpenDialogEdit(TyreModel TyreMaster)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        _busy = true;
        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;
        TyreMaster.UserInfo = new();
        if (TyreMaster.UserInfo != null)
        {
            TyreMaster.UserInfo.UserID = user.Identity.Name;
        }
        var param = new DialogParameters { ["model"] = TyreMaster };
        var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Medium };
        var dialog = DialogService.Show<TyreDialog>("ADD/EDIT", param, options);
        var result = await dialog.Result;

        // you can check if the modal was cancelled
        var isCancelled = result.Canceled;
        if (!isCancelled)
        {
            TyreModel UpatedModel = (TyreModel)result.Data;
            if (UpatedModel != null)
            {
                if (collection.Exists(x => x.TyreID == UpatedModel.TyreID))
                {
                    collection[collection.FindIndex(x => x.TyreID == UpatedModel.TyreID)] = UpatedModel;
                }
                else
                {
                    collection.Add(UpatedModel);
                }
                UpatedModel = new();
            }
        }
        await Task.Delay(200);
        _busy = false;
    }

    private async Task OpenDialogDelete(TyreModel TyreMaster)
    {
        if (HasPermissionTyreServiceDelete)
        {
            bool? result = await DialogService.ShowMessageBox(
                "Warning",
                "Are you sure you want to delete this entry?",
                yesText: "Delete!", cancelText: "Cancel");
            if (result != null)
            {
                try
                {
                    var authprov = await auth.GetAuthenticationStateAsync();
                    var user = authprov.User;
                    TyreMaster.UserInfo = new();
                    if (TyreMaster.UserInfo != null)
                    {
                        TyreMaster.UserInfo.UserID = user.Identity.Name;
                        int resultDelete = ITyreservice.Delete(TyreMaster.TyreID, TyreMaster.UserInfo.UserID);
                        if (resultDelete != -1)
                        {
                            if (collection != null && collection.Any(s => s.TyreID == TyreMaster.TyreID))
                            {
                                collection.Remove(collection.FirstOrDefault(s => s.TyreID == TyreMaster.TyreID));
                                snackbar.Add("Deleted Successfully", Severity.Success);
                            }
                        }
                    }
                }
                catch (Exception ex)
                {
                    snackbar.Add(ex.Message, Severity.Error);
                }
            }
        }
        else
        {
            bool? result = await DialogService.ShowMessageBox(
                "Permission denied!",
                "You don't have any permission to Delete Tyre.");
        }
    }

    private async Task TyreMountOrUnmount(TyreModel model)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        _busy = true;
        DialogOptions options = new DialogOptions()
            {
                MaxWidth = MaxWidth.Large,
            };
        bool IsMounted = model.TyrePosition != null;
        model.UserInfo.UserID = UserID;
        if (IsMounted)
        {
            DialogParameters parms = new();
            parms.Add("SelectedTyre", model);
            var dialog = DialogService.Show<TyreUnMountDialog>("UnMount", parms, options);
            var result = await dialog.Result;

            // you can check if the modal was cancelled
            var isCancelled = result.Canceled;
            if (!isCancelled)
            {
                await GetAll();
            }
        }
        else
        {
            DialogParameters parms = new();
            parms.Add("SelectedTyre", model);
            var dialog = DialogService.Show<TyreMountDialog>("Mount", parms, options);
            var result = await dialog.Result;

            // you can check if the modal was cancelled
            var isCancelled = result.Canceled;
            if (!isCancelled)
            {
                await GetAll();
            }
        }
        await Task.Delay(200);
        _busy = false;
    }

    private void OpenDialog()
    {
        TyreModel TyreMaster = new();
        var model = new DialogParameters { ["model"] = TyreMaster };
        var options = new DialogOptions { CloseOnEscapeKey = true };
        DialogService.Show<TyreDialog>("Simple Dialog", model, options);
    }

    private async Task OpenKmReading(TyreModel model)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        _busy = true;
        DialogOptions options = new DialogOptions()
            {
                MaxWidth = MaxWidth.Medium,
            };
        model.UserInfo.UserID = UserID;
        DialogParameters parms = new();
        parms.Add("SelectedTyre", model);
        var dialog = DialogService.Show<TyreKmReadingDialog>("Km Readings", parms, options);
        var result = await dialog.Result;       
        await Task.Delay(200);
        _busy = false;
    }

    private async Task ViewHistory(TyreModel model)
    {        
        DialogOptions options = new DialogOptions()
            {
                MaxWidth = MaxWidth.Large,
            };
      
            DialogParameters parms = new();
            parms.Add("TyreID", model.TyreID);
            parms.Add("TyreSerial", model.TyreSerialNumber);
            var dialog = DialogService.Show<TyreHistoryDialog>("Tyre History", parms, options); 
            await dialog.Result;            
    }
       
}
