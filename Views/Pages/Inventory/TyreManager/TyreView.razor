@page "/TyreMasterView"
@using ArmsModels.BaseModels.General
@using ArmsServices.DataServices.Operations
@using System.Threading;
@using System.Globalization
@using OfficeOpenXml
@using System.IO
@using OfficeOpenXml.Style
@inject ITyreService ITyreservice
@inject MudBlazor.ISnackbar snackbar
@inject AuthenticationStateProvider auth
@attribute [Authorize]
@using System.Threading;
@inject IRoleService<RoleModel> Irole
@inject IDialogService DialogService
@inject IJSRuntime JSRuntime

@if (_isLoading)
{
    <div @key="@("loader")" class="d-flex justify-center align-center" style="min-height: 400px;">
        <LoaderComponent IsFullScreen="false" ShowLogo="false" Size="medium" LoadingText="Synchronizing Tyre Inventory" SubText="Retrieving latest tyre and accessory records..." />
    </div>
}
else
{
    <div class="admin-page-container fade-in" @key="@("content")">
        <div class="admin-header-tiered mb-6">
            <div class="d-flex align-center justify-space-between">
                <div>
                    <MudText Typo="Typo.h4" Class="admin-title">Tyre & Accessories</MudText>
                    <MudText Typo="Typo.body2" Class="admin-subtitle">Manage vehicle tyre inventory, tracking, and mounting status across the fleet.</MudText>
                </div>
                <MudButton Disabled="@_busy" Variant="Variant.Filled" Color="Color.Primary" OnClick="@(()=> OpenDialogEdit(new TyreModel()))" Class="admin-register-btn" StartIcon="@Icons.Material.Filled.Add">REGISTER TYRE</MudButton>
            </div>
        </div>

        <div class="admin-glass-card pa-6 mb-6">
            <MudGrid Spacing="3" Class="align-center">
                <MudItem xs="12" lg="4">
                    <MudTextField @bind-Value="searchTerm" Placeholder="Search by Serial Number or Item Type..." Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" AdornmentColor="Color.Primary" Variant="Variant.Outlined" Margin="Margin.Dense" Clearable="true" Class="modern-input"></MudTextField>
                </MudItem>
                <MudItem xs="12" lg="8" Class="d-flex justify-end">
                    <div class="d-flex align-center gap-4 bg-light-surface pa-2 rounded-lg border-subtle">
                        <MudText Typo="Typo.caption" Class="fw-700 opacity-60 ml-2">VIEW FILTER:</MudText>
                        <MudRadioGroup Value="@selectedOption" T="string" ValueChanged="OnSelectedOptionChanged">
                            <MudRadio Value="@("All")" Color="Color.Primary" UnCheckedColor="Color.Default" Class="fw-600">All</MudRadio>
                            <MudRadio Value="@("Mounted")" Color="Color.Primary" UnCheckedColor="Color.Default" Class="fw-600">Mounted</MudRadio>
                            <MudRadio Value="@("UnMounted")" Color="Color.Primary" UnCheckedColor="Color.Default" Class="fw-600">Un-Mounted</MudRadio>
                        </MudRadioGroup>
                    </div>
                </MudItem>
            </MudGrid>
        </div>

        <div class="admin-glass-card overflow-hidden">
            <MudTable Items="@collection" Elevation="0" Filter="new Func<TyreModel,bool>(search)" Hover="true" Breakpoint="Breakpoint.Sm" Class="modern-admin-table">
                <HeaderContent>
                    <MudTh><MudTableSortLabel SortBy="new Func<TyreModel, object>(x=> x.TyreSerialNumber)" InitialDirection="SortDirection.Ascending"><span class="admin-header-text">SERIAL NUMBER</span></MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<TyreModel, object>(x=> x.Make)"><span class="admin-header-text">MAKE</span></MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<TyreModel, object>(x=> x.ItemType)"><span class="admin-header-text">ITEM TYPE</span></MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<TyreModel, object>(x=> x.TyreType)"><span class="admin-header-text">TYRE TYPE</span></MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<TyreModel, object>(x=> x.TyreSize)"><span class="admin-header-text">SIZE</span></MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<TyreModel, object>(x=> x.Status)"><span class="admin-header-text">STATUS</span></MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<TyreModel, object>(x=> x.TotalExpectedLife)"><span class="admin-header-text">EXPECTED LIFE</span></MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<TyreModel, object>(x=> x.TyrePosition)"><span class="admin-header-text">MOUNTED TRUCK</span></MudTableSortLabel></MudTh>
                    <MudTh Style="text-align: right;"><span class="admin-header-text">ACTIONS</span></MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Serial">
                        <span class="admin-td-primary fw-600">@context.TyreSerialNumber</span>
                    </MudTd>
                    <MudTd DataLabel="Make"><span class="fw-500">@context.Make</span></MudTd>
                    <MudTd DataLabel="ItemType">
                        <div class="d-flex flex-column">
                            <MudText Typo="Typo.body2" Class="fw-600">@context.ItemType</MudText>
                            <MudText Typo="Typo.caption" Class="opacity-60">@context.ItemCode</MudText>
                        </div>
                    </MudTd>
                    <MudTd DataLabel="TyreType">@context.TyreType</MudTd>
                    <MudTd DataLabel="Size">@context.TyreSize</MudTd>
                    <MudTd DataLabel="Status">
                        <MudChip T="string" Size="Size.Small" Color="@(context.Status == "Active" ? Color.Success : Color.Warning)" Variant="Variant.Text" Class="fw-600">@context.Status</MudChip>
                    </MudTd>
                    <MudTd DataLabel="Life">
                        <div class="d-flex align-center">
                            <MudText Typo="Typo.body2">@context.TotalExpectedLife</MudText>
                            <MudText Typo="Typo.caption" Class="ml-1 opacity-50">km</MudText>
                        </div>
                    </MudTd>
                    <MudTd DataLabel="Position">
                        @if (!string.IsNullOrEmpty(context.TyrePosition))
                        {
                            <div class="d-flex align-center bg-light-secondary pa-1 px-2 rounded-lg border-subtle">
                                <MudIcon Icon="@Icons.Material.Filled.LocalShipping" Size="Size.Small" Color="Color.Secondary" Class="mr-2" />
                                <MudText Typo="Typo.caption" Class="fw-700 text-secondary">@context.TyrePosition</MudText>
                            </div>
                        }
                        else
                        {
                            <span class="opacity-40">-</span>
                        }
                    </MudTd>
                    <MudTd DataLabel="Actions" Style="text-align: right;">
                        @if (string.IsNullOrEmpty(context.LockText))
                        {
                            string txt = context.IsMounted ? "UnMount" : "Mount";
                            string icon = context.IsMounted ? Icons.Material.Filled.Download : Icons.Material.Filled.Upload;
                            Color iconColor = context.IsMounted ? Color.Warning : Color.Success;

                            <MudTooltip Text="Edit">
                                <MudIconButton OnClick="@(()=> OpenDialogEdit(context))" Color="Color.Primary" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Variant="Variant.Text" />
                            </MudTooltip>
                            
                            <MudTooltip Text="@txt">
                                <MudIconButton OnClick="@(()=> TyreMountOrUnmount(context))" Color="@iconColor" Icon="@icon" Size="Size.Small" Variant="Variant.Text" />
                            </MudTooltip>

                            <MudTooltip Text="View History">
                                <MudIconButton OnClick="@(()=> ViewHistory(context))" Color="Color.Info" Icon="@Icons.Material.Filled.History" Size="Size.Small" Variant="Variant.Text" />
                            </MudTooltip>

                            <MudTooltip Text="Delete">
                                <MudIconButton Disabled="@(context.IsMounted)" OnClick="@(()=> OpenDialogDelete(context))" Color="Color.Error" Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Variant="Variant.Text" />
                            </MudTooltip>
                        }
                        else
                        {
                            <MudBadge Content="@context.LockText" Color="Color.Error" Overlap="true" Class="mr-2">
                                <MudIcon Icon="@Icons.Material.Filled.Lock" Size="Size.Small" Color="Color.Default" />
                            </MudBadge>
                        }
                    </MudTd>
                </RowTemplate>
                <PagerContent>
                    <div class="pa-4">
                        <MudTablePager PageSizeOptions="new int[] { 10, 20, 50, 100 }" />
                    </div>
                </PagerContent>
            </MudTable>
        </div>
    </div>
}



@code {

    private bool _isLoading = true;
    private DateTime _loadStartTime;

    private List<TyreModel> collection = new();
    string UserID;
    private bool _busy;
    private string searchTerm = "";
    private string selectedOption = "All";
    private int? BranchID;

    public bool HasPermissionTyreServiceDelete { get; set; } = false;
    public int DocTypeID = 63;

    protected async override Task OnInitializedAsync()
    {
        _loadStartTime = DateTime.Now;
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionTyreServiceDelete = await Irole.HasClaim(DocTypeID.ToString(), "Delete", ctc.Token);

        await GetAll();
        await EnsureMinimumLoadTime();
        _isLoading = false;
    }

    private async Task EnsureMinimumLoadTime()
    {
        var elapsed = (DateTime.Now - _loadStartTime).TotalMilliseconds;
        if (elapsed < 100)
        {
            await Task.Delay(100 - (int)elapsed);
        }
    }

    private async Task GetAll()
    {
        collection = new();
        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;
        UserID = user.Identity.Name;
        BranchID = int.Parse(authprov.User.Claims.First(x => x.Type == "BranchID").Value);
        OnSelectedOptionChanged(selectedOption);
    }

    public void OnSelectedOptionChanged(string value)
    {
        selectedOption = value;
        switch (value)
        {
            case "Mounted":
                collection = ITyreservice.SelectByBranch(BranchID).Where(x => x.IsMounted).ToList();
                break;
            case "UnMounted":
                collection = ITyreservice.SelectByBranch(BranchID).Where(x => !x.IsMounted).ToList();                
                break;
            default:
                collection = ITyreservice.SelectByBranch(BranchID).ToList();
                break;
        }
    }

    private bool search(TyreModel model)
    {
        if ((model.TyreID != null && model.TyreSerialNumber.Contains(searchTerm, StringComparison.OrdinalIgnoreCase)) || (model.ItemType.Contains(searchTerm, StringComparison.OrdinalIgnoreCase)))
        {
            return true;
        }
        return false;
    }

    private async Task OpenDialogEdit(TyreModel TyreMaster)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        _busy = true;
        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;
        TyreMaster.UserInfo = new();
        if (TyreMaster.UserInfo != null)
        {
            TyreMaster.UserInfo.UserID = user.Identity.Name;
        }
        var param = new DialogParameters { ["model"] = TyreMaster };
        var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Medium };
        var dialog = await DialogService.ShowAsync<TyreDialog>("ADD/EDIT", param, options);
        var result = await dialog.Result;

        // you can check if the modal was cancelled
        var isCancelled = result.Canceled;
        if (!isCancelled)
        {
            TyreModel UpatedModel = (TyreModel)result.Data;
            if (UpatedModel != null)
            {
                if (collection.Exists(x => x.TyreID == UpatedModel.TyreID))
                {
                    collection[collection.FindIndex(x => x.TyreID == UpatedModel.TyreID)] = UpatedModel;
                }
                else
                {
                    collection.Add(UpatedModel);
                }
                UpatedModel = new();
            }
        }
        await Task.Delay(200);
        _busy = false;
    }

    private async Task OpenDialogDelete(TyreModel TyreMaster)
    {
        if (HasPermissionTyreServiceDelete)
        {
            bool? result = await DialogService.ShowMessageBoxAsync(
                "Warning",
                "Are you sure you want to delete this entry?",
                yesText: "Delete!", cancelText: "Cancel");
            if (result != null)
            {
                try
                {
                    var authprov = await auth.GetAuthenticationStateAsync();
                    var user = authprov.User;
                    TyreMaster.UserInfo = new();
                    if (TyreMaster.UserInfo != null)
                    {
                        TyreMaster.UserInfo.UserID = user.Identity.Name;
                        int resultDelete = ITyreservice.Delete(TyreMaster.TyreID, TyreMaster.UserInfo.UserID);
                        if (resultDelete != -1)
                        {
                            if (collection != null && collection.Any(s => s.TyreID == TyreMaster.TyreID))
                            {
                                collection.Remove(collection.FirstOrDefault(s => s.TyreID == TyreMaster.TyreID));
                                snackbar.Add("Deleted Successfully", Severity.Success);
                            }
                        }
                    }
                }
                catch (Exception ex)
                {
                    snackbar.Add(ex.Message, Severity.Error);
                }
            }
        }
        else
        {
            bool? result = await DialogService.ShowMessageBoxAsync(
                "Permission denied!",
                "You don't have any permission to Delete Tyre.");
        }
    }

    private async Task TyreMountOrUnmount(TyreModel model)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        _busy = true;
        DialogOptions options = new DialogOptions()
            {
                MaxWidth = MaxWidth.Large,
            };
        bool IsMounted = model.TyrePosition != null;
        model.UserInfo.UserID = UserID;
        if (IsMounted)
        {
            DialogParameters parms = new();
            parms.Add("SelectedTyre", model);
            var dialog = await DialogService.ShowAsync<TyreUnMountDialog>("UnMount", parms, options);
            var result = await dialog.Result;

            // you can check if the modal was cancelled
            var isCancelled = result.Canceled;
            if (!isCancelled)
            {
                await GetAll();
            }
        }
        else
        {
            DialogParameters parms = new();
            parms.Add("SelectedTyre", model);
            var dialog = await DialogService.ShowAsync<TyreMountDialog>("Mount", parms, options);
            var result = await dialog.Result;

            // you can check if the modal was cancelled
            var isCancelled = result.Canceled;
            if (!isCancelled)
            {
                await GetAll();
            }
        }
        await Task.Delay(200);
        _busy = false;
    }

    private async Task OpenDialog()
    {
        TyreModel TyreMaster = new();
        var model = new DialogParameters { ["model"] = TyreMaster };
        var options = new DialogOptions { CloseOnEscapeKey = true };
        await DialogService.ShowAsync<TyreDialog>("Simple Dialog", model, options);
    }

    private async Task OpenKmReading(TyreModel model)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        _busy = true;
        DialogOptions options = new DialogOptions()
            {
                MaxWidth = MaxWidth.Medium,
            };
        model.UserInfo.UserID = UserID;
        DialogParameters parms = new();
        parms.Add("SelectedTyre", model);
        var dialog = await DialogService.ShowAsync<TyreKmReadingDialog>("Km Readings", parms, options);
        var result = await dialog.Result;       
        await Task.Delay(200);
        _busy = false;
    }

    private async Task ViewHistory(TyreModel model)
    {        
        DialogOptions options = new DialogOptions()
            {
                MaxWidth = MaxWidth.Large,
            };
      
            DialogParameters parms = new();
            parms.Add("TyreID", model.TyreID);
            parms.Add("TyreSerial", model.TyreSerialNumber);
            var dialog = await DialogService.ShowAsync<TyreHistoryDialog>("Tyre History", parms, options); 
            await dialog.Result;            
    }
       
}
