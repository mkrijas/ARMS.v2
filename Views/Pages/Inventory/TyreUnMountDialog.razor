@using ArmsModels.BaseModels.General
@using System.ComponentModel.DataAnnotations
@inject AuthenticationStateProvider auth
@inject ITyreService IServices

<MudDialog>
    <TitleContent>

        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.Edit" Class="mr-3" />Unmount Tyre.
        </MudText>

    </TitleContent>
    <DialogContent>

        <MudContainer Style="max-height: 400px; overflow-y: scroll; margin-left:20px">
            <EditForm id="formDriver" Model="@model">
                <ObjectGraphDataAnnotationsValidator />
                <ValidationSummary />

                <MudItem xs="11" md="11" Class="mb-6">
                    <MudSelect T="string?" Variant="Variant.Outlined" Disabled="IsTyreDisabled" Margin="Margin.Dense" Label="Tyre" @bind-Value="@SelectedTyre.TyreSerialNumber">
                        @foreach (TyreModel Tyre in TyreList)
                        {
                            <MudSelectItem Value="@Tyre.TyreSerialNumber">@Tyre.TyreSerialNumber</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="11" md="11" Class="mb-6">
                    <MudTextField @bind-Value="@SelectedTyre.TyrePosition.Side" Label="Tyre position" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => @SelectedTyre.TyrePosition.Side)"></MudTextField>
                </MudItem>
                <MudItem xs="11" md="11" Class="mb-6">
                    <MudTextField @bind-Value="@UnMountedKM" Label="Un Mounted KM" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => @UnMountedKM)"></MudTextField>
                </MudItem>
            </EditForm>
        </MudContainer>

    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="UnMount" Class="px-12">UnMount</MudButton>
    </DialogActions>
</MudDialog>

@code {

    [CascadingParameter] MudDialogInstance MudDialog { get; set; }

    [Parameter]
    public TyreMountedModel model { get; set; } = new();
    [Parameter]
    public TruckModel SelectedTruck { get; set; } = new();
    [Required]
    [Parameter]
    public TyreModel SelectedTyre { get; set; } = new();
    [Required]
    public TyrePositionModel SelectedTyrePosition { get; set; } = new();
    [Required]
    public int? UnMountedKM { get; set; }

    public bool IsTruckDisabled { get; set; } = false;

    public bool IsTyreDisabled { get; set; } = false;

    List<TyreModel> TyreList = new();
    List<TyrePositionModel> TyrePositionListForMountAndUnMount = new();

    protected override void OnInitialized()
    {
        var Tyres = IServices.SelectUnmontedTyresByID(0);
        if (Tyres != null && Tyres.Count() != 0)
        {
            TyreList = Tyres.ToList();

        }
        if (SelectedTruck != null && SelectedTruck.TruckID != null && SelectedTruck.TruckID != 0)
        {
            IsTruckDisabled = true;
        }
        else
        {
            IsTruckDisabled = false;
        }

        if (SelectedTyre != null && SelectedTyre.TyreID != null && SelectedTyre.TyreID != 0)
        {
            List<TyreMountedModel> MountedTyreList = IServices.SelectMountedTyresByTyreID(SelectedTyre.TyreID).ToList();
            if (MountedTyreList != null && MountedTyreList.Count != 0)
            {
                if (SelectedTyre.TyrePosition == null)
                {
                    SelectedTyre.TyrePosition = new();
                }
                SelectedTyre.TyrePosition.PositionID = MountedTyreList.First().PositionID;
                SelectedTyre.TyrePosition.Side = MountedTyreList.First().PositionName;
            }
            IsTyreDisabled = true;
        }
        else
        {
            IsTyreDisabled = false;
        }

        if (SelectedTruck != null && SelectedTruck.TruckTypeID != 0 || SelectedTyre != null && SelectedTyre.TyreID != 0)
        {
            model.TruckID = SelectedTruck.TruckID;
            TyrePositionListForMountAndUnMount = IServices.GetTyrePositionListUsingTruckTypeId(SelectedTruck.TruckTypeID).ToList();

        }
    }

    protected override void OnParametersSet()
    {
    }
    void Cancel()
    {
        MudDialog.Cancel();
    }


    public async Task UnMount()
    {
        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;
        var brancIDString = authprov.User.Claims.First(x => x.Type == "BranchID").Value;
        if (model != null)
        {
            //model.BranchID = int.Parse(brancIDString);
            model.UserInfo.UserID = user.Identity.Name;

            IServices.Unmount(SelectedTyre.TyreID, DateTime.Now, UnMountedKM, model.UserInfo.UserID);
        }

        MudDialog.Close(DialogResult.Ok(true));
    }


}
