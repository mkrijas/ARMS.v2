@page "/TyreMasterView"
@using ArmsModels.BaseModels.General
@using ArmsServices.DataServices.Operations

<h3>Tyre Master View</h3>

@inject ITyreService ITyreservice
@inject MudBlazor.ISnackbar snackbar

@inject AuthenticationStateProvider auth
@attribute [Authorize]
@inject IDialogService DialogService


<MudGrid Spacing="4">
    <MudItem xs="12">
        <MudTable Items="@collection" Dense="true" Hover="true" Striped="true" Elevation="10" >
            <ToolBarContent>
                <MudText Typo="Typo.h6">Add New Tyre</MudText>
                <MudTooltip Text="New Tyre">
                    <MudIconButton Icon="@Icons.Material.Filled.Add" Title="Add" @onclick="@(()=> OpenDialogEdit(new TyreModel()))" Color="Color.Dark" Size="Size.Small"></MudIconButton>
                </MudTooltip>
                <MudSpacer></MudSpacer>

            </ToolBarContent>
            <HeaderContent>
                <MudTh><MudTableSortLabel SortBy="new Func<TyreModel, object>(x=> x.TyreSerialNumber)" InitialDirection="SortDirection.Ascending">Tyre Serial Number</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<TyreModel, object>(x=> x.Make)" InitialDirection="SortDirection.Ascending">Make</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<TyreModel, object>(x=> x.TyreType)" InitialDirection="SortDirection.Ascending">Tyre Type</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<TyreModel, object>(x=> x.TyreSize)" InitialDirection="SortDirection.Ascending">Tyre Size</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<TyreModel, object>(x=> x.TyrePosition)" InitialDirection="SortDirection.Ascending">Mounted Truck</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<TyreModel, object>(x=> x.Tubeless)" InitialDirection="SortDirection.Ascending">Tubeless</MudTableSortLabel></MudTh>
                <MudTh>Actions</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Tyre">@context.TyreSerialNumber</MudTd>
                <MudTd DataLabel="Make">@context.Make</MudTd>
                <MudTd DataLabel="TyreType">@context.TyreType</MudTd>
                <MudTd DataLabel="TyreSize">@context.TyreSize</MudTd>
                <MudTd DataLabel="TyreSize">@context.TyrePosition</MudTd>
                <MudTd DataLabel="Tubeless">@context.Tubeless</MudTd>
                <MudTd DataLabel="Actions">
                    <MudTooltip Text="Edit">
                        <MudIconButton @onclick="@(()=> OpenDialogEdit(context))" Color="Color.Primary" Icon="@Icons.Material.Filled.Edit" Size="Size.Small"/>
                    </MudTooltip>
                    <MudTooltip Text="Remove">
                        <MudIconButton @onclick="@(()=> OpenDialogDelete(context))" Color="Color.Primary" Icon="@Icons.Material.Filled.Remove" Size="Size.Small" />
                    </MudTooltip>
                    @{
                        var Ismounted = context.TyrePosition != null; 
                        string txt = Ismounted ? "UnMount" : "Mount";
                        string icon  = Ismounted ? Icons.Material.Filled.Download :Icons.Material.Filled.Upload  ;
                    }

                    <MudTooltip Text="@txt">
                        <MudIconButton @onclick="@(()=> TyreMountOrUnmount(context))" Color="Color.Primary" Icon="@icon" Size="Size.Small" />
                    </MudTooltip>
                </MudTd>
            </RowTemplate>

            <PagerContent>
                <MudTablePager PageSizeOptions="new int[] { 5, 10, 20, 50, 100 }" />
            </PagerContent>
        </MudTable>
    </MudItem>
</MudGrid>
