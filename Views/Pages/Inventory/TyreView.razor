@page "/TyreMasterView"
@using ArmsModels.BaseModels.General
@using ArmsServices.DataServices.Operations

<h3>Tyre Master View</h3>

@inject ITyreService ITyreservice
@inject MudBlazor.ISnackbar snackbar

@inject AuthenticationStateProvider auth
@attribute [Authorize]
@inject IDialogService DialogService


<MudGrid Spacing="4">
    <MudItem xs="12">
        <MudTable Items="@collection" Dense="true" Hover="true" Striped="true" Elevation="10" @bind-place="model">
            <ToolBarContent>
                <MudText Typo="Typo.h6">Add New Tyre.</MudText>
                <MudTooltip Text="New Tyre">
                    <MudIconButton Icon="@Icons.Material.Filled.Add" Title="Add" @onclick="@(()=> OpenDialogAddNew())" Color="Color.Dark" Size="Size.Small"></MudIconButton>
                </MudTooltip>
                <MudSpacer></MudSpacer>

            </ToolBarContent>
            <HeaderContent>
                <MudTh><MudTableSortLabel SortBy="new Func<TyreModel, object>(x=> x.TyreSerialNumber)" InitialDirection="SortDirection.Ascending">Tyre Serial Number</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<TyreModel, object>(x=> x.Make)" InitialDirection="SortDirection.Ascending">Make</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<TyreModel, object>(x=> x.TyreType)" InitialDirection="SortDirection.Ascending">Tyre Type</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<TyreModel, object>(x=> x.TyreSize)" InitialDirection="SortDirection.Ascending">Tyre Size</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<TyreModel, object>(x=> x.Tubeless)" InitialDirection="SortDirection.Ascending">Tubeless</MudTableSortLabel></MudTh>
                <MudTh>Actions</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Tyre">@context.TyreSerialNumber</MudTd>
                <MudTd DataLabel="Make">@context.Make</MudTd>
                <MudTd DataLabel="TyreType">@context.TyreType</MudTd>
                <MudTd DataLabel="TyreSize">@context.TyreSize</MudTd>
                <MudTd DataLabel="Tubeless">@context.Tubeless</MudTd>
                <MudTd DataLabel="Actions">
                    <MudTooltip Text="Edit">
                        <MudIconButton @onclick="@(()=> OpenDialogEdit(context))" Color="Color.Primary" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" IconSize="Size.Small" />
                    </MudTooltip>
                    <MudTooltip Text="Remove">
                        <MudIconButton @onclick="@(()=> OpenDialogDelete(context))" Color="Color.Primary" Icon="@Icons.Material.Filled.Remove" Size="Size.Small" IconSize="Size.Small" />
                    </MudTooltip>
                    <MudTooltip Text="Mount Or Unmount">
                        <MudFab @onclick="@(()=> TyreMountOrUnmount(context.TyreID))" Color="Color.Primary" Icon="@Icons.Material.Filled.TableView" Size="Size.Small" IconSize="Size.Small" />
                    </MudTooltip>
                </MudTd>
            </RowTemplate>

            <PagerContent>
                <MudTablePager PageSizeOptions="new int[] { 5, 10, 20, 50, 100 }" />
            </PagerContent>
        </MudTable>
    </MudItem>
</MudGrid>
@code {


    private TyreModel model = new();

    private List<TyreModel> collection = new();

    string state = "Message box hasn't been opened yet";

    private async Task OpenDialogAddNew()
    {
        TyreModel TyreMaster = new();

        TyreMaster.UserInfo = new();
        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;
        if (TyreMaster.UserInfo != null)
        {
            TyreMaster.UserInfo.UserID = user.Identity.Name;

        }
        var model = new DialogParameters { ["model"] = TyreMaster };
        var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Medium };
        var dialog = DialogService.Show<TyreDialog>("Simple Dialog", model, options);


        var result = await dialog.Result;

        var isCancelled = result.Canceled;
        if (!isCancelled)
        {
            await GetAll();
        }
    }
    private async Task OpenDialogEdit(TyreModel TyreMaster)
    {
        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;

        TyreMaster.UserInfo = new();
        if (TyreMaster.UserInfo != null)
        {
            TyreMaster.UserInfo.UserID = user.Identity.Name;
        }

        var model = new DialogParameters { ["model"] = TyreMaster };

        var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Medium };
        var dialog = DialogService.Show<TyreDialog>("Simple Dialog", model, options);

        var result = await dialog.Result;

        // you can check if the modal was cancelled
        var isCancelled = result.Canceled;
        if (!isCancelled)
        {
            await GetAll();
        }
    }
    private async Task OpenDialogDelete(TyreModel TyreMaster)
    {

        bool? result = await DialogService.ShowMessageBox(
            "Warning",
            "Are you sure you want to delete this entry?",
            yesText: "Delete!", cancelText: "Cancel");
        state = result == null ? "Cancelled" : "Deleted!";
        if (state == "Deleted!")
        {

            var authprov = await auth.GetAuthenticationStateAsync();
            var user = authprov.User;
            TyreMaster.UserInfo = new();
            if (TyreMaster.UserInfo != null)
            {
                TyreMaster.UserInfo.UserID = user.Identity.Name;
                ITyreservice.Delete(TyreMaster.TyreID, TyreMaster.UserInfo.UserID);
            }
            await GetAll();
        }

    }


    private void TyreMountOrUnmount(int? TyreID)
    {
        model = new();
        DialogOptions options = new DialogOptions()
            {
                MaxWidth = MaxWidth.Large,
            };
        if (TyreID != null)
        {
            model = ITyreservice.SelectByID(TyreID);
        }
        List<TyreMountedModel> MountedTyreList = ITyreservice.SelectMountedTyresByTyreID(TyreID).ToList();
        if (MountedTyreList != null && MountedTyreList.Count() != 0)
        {

            DialogParameters parms = new();
            parms.Add("SelectedTyre", model);
            DialogService.Show<TyreUnMountDialog>("ADD/EDIT", parms, options);
        }
        else
        {

            DialogParameters parms = new();
            parms.Add("SelectedTyre", model);
            DialogService.Show<TyreMountDialog>("ADD/EDIT", parms, options);
        }

    }

    protected async override Task OnInitializedAsync()
    {
        //model = new();
        await GetAll();
    }

    private async Task GetAll()
    {

        collection = new();

        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;

        model.UserInfo = new();
        var brancIDString = authprov.User.Claims.First(x => x.Type == "BranchID").Value;
        if (model.UserInfo != null)
        {
            model.UserInfo.UserID = user.Identity.Name;
        }
        model.BranchID = int.Parse(brancIDString);
        collection = ITyreservice.SelectByBranch(model.BranchID).ToList();
    }

    private void OpenDialog()
    {
        TyreModel TyreMaster = new();

        var model = new DialogParameters { ["model"] = TyreMaster };

        var options = new DialogOptions { CloseOnEscapeKey = true };
        DialogService.Show<TyreDialog>("Simple Dialog", model, options);
    }

}