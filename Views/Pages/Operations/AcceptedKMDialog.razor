@using Views.Pages.Operations.Gc
@inject IDialogService DialogService
@inject MudBlazor.ISnackbar snackbar
@attribute [Authorize]
@inject AuthenticationStateProvider auth
@inject NavigationManager UriHelper

<MudDialog>
    <DialogContent>
        <MudTextField @bind-Value="AcceptedKM" InputType="InputType.Number" Label="AcceptedKM" Variant="Variant.Outlined" Margin="Margin.Dense"></MudTextField>
    </DialogContent>
    <DialogActions>
        <MudButton Disabled="@_busy" Variant="Variant.Filled" @onclick="UpdateAcceptedKM" Color="Color.Success">Update AcceptedKM</MudButton>
    </DialogActions>
</MudDialog>

@code {
    public int AcceptedKM { get; set; }
    [CascadingParameter] MudDialogInstance MudDialog { get; set; }
    private bool _busy;

    public async void UpdateAcceptedKM()
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is being submitted!", Severity.Warning);
            return;
        }
        _busy = true;
        MudDialog.Close(AcceptedKM);
        await Task.Delay(2000);
        _busy = false;
    }
}