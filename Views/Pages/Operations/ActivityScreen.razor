@page "/operations"
@using ArmsModels.BaseModels.FMS;
@using ArmsServices.DataServices.FMS;
@using ArmsServices.DataServices.Operations;
@using Pages.Operations.Truck
@using Pages.Operations.Gc
@using Pages.FMS.Breakdown
@using Pages.FMS.RoutineCheckList
@using Pages.Finance.Transactions
@using System.Threading;
@using System.Transactions;
@inject IBranchService Ibranch
@inject ITruckService Itruck
@inject IDriverService Idriver
@inject ITripService Itrip
@inject IEventService Ievent
@inject IGcService Igc
@inject IPlaceService Iplace
@inject IAssetDocumentService idocument
@inject IRoutineCheckListMasterService IserviceRoutineMaster
@inject IRoutineCheckListService IroutineCheckListService
@inject MudBlazor.ISnackbar snackbar
@attribute [Authorize]
@inject AuthenticationStateProvider auth
@inject IDialogService DialogService
@inject IBranchSettingsService branchSettingsService
@inject IRoleService<RoleModel> Irole

<div class="admin-page-container">
    <div class="admin-header-tiered mb-6">
        <div class="d-flex align-center justify-space-between">
            <div>
                <MudText Typo="Typo.h4" Class="admin-title">Operational Control Center</MudText>
                <div class="title-accent"></div>
                <MudText Typo="Typo.body2" Class="admin-subtitle mt-2">Live deployment monitor, vehicle tracking, and real-time mission management console.</MudText>
            </div>
            <div class="d-flex align-center gap-3 bg-glass rounded-pill px-4 py-2">
                <MudIcon Icon="@Icons.Material.Filled.AccessTime" Size="Size.Small" Class="opa-50" />
                <MudText Typo="Typo.caption" Class="fw-700 opa-70">@DateTime.Now.ToString("dd MMM yyyy HH:mm")</MudText>
            </div>
        </div>
    </div>

    <MudGrid Spacing="4">
        <!-- Truck Selection Section -->
        <MudItem xs="12">
            <div class="admin-glass-card pa-4">
                <MudGrid AlignItems="AlignItems.Center">
                    <MudItem xs="12" md="6" lg="4">
                        <MudText Typo="Typo.caption" Class="fw-700 mb-2 opa-50 uppercase ml-1">VEHICLE ASSIGNMENT</MudText>
                        <TruckSelector Class="modern-input" Value="SelectedTruck" BranchID="BranchID" ValueChanged="OnTruckSelectedAsync" Filter="AvailableForBranch" HomeOrOperation="Operation" />
                    </MudItem>
                </MudGrid>
            </div>
        </MudItem>

        @if (SelectedTruck != null)
        {
            <!-- Operational Details Section -->
            <!-- Operational Cockpit Section -->
            <MudItem xs="12">
                <div class="premium-card pa-0 rounded-xl overflow-visible fade-in">
                    <!-- Cockpit Header -->
                    <div class="pa-4 border-b border-solid border-white-10 bg-white-5">
                       <MudText Typo="Typo.subtitle1" Class="fw-900 admin-header-text label-caps" Style="color:var(--mud-palette-primary);">DEPLOYMENT DYNAMICS</MudText>
                    </div>

                    <div class="px-6 py-6">
                        <MudGrid Spacing="4">
                            <!-- Section: Trip Intelligence -->
                            <MudItem xs="12" md="4" Class="border-r border-solid border-white-10">
                                <MudText Typo="Typo.caption" Class="label-caps mb-4 d-block">TRIP INTELLIGENCE</MudText>
                                @if (CurrentTrip != null)
                                {
                                    <div class="d-flex align-start gap-4">
                                        <div class="pa-4 rounded-xl sub-panel shadow-sm">
                                            <MudIcon Icon="@Icons.Material.Filled.Route" Color="Color.Primary" Size="Size.Large" Class="opa-80" />
                                        </div>
                                        <div class="flex-grow-1">
                                            <MudText Typo="Typo.caption" Class="label-caps opa-60">MISSION REFERENCE</MudText>
                                            <MudText Typo="Typo.h5" Class="fw-900 mission-id-ref text-design mb-4">@CurrentTrip.TripNumberDisplay</MudText>
                                            
                                            <!-- Elegant Path Indicator -->
                                            <div class="mt-2 pl-2">
                                                <div class="d-flex align-center gap-3">
                                                    <div class="rounded-circle bg-success shadow-sm" style="width:10px; height:10px; border:2px solid white;"></div>
                                                    <MudText Typo="Typo.body2" Class="fw-800 opa-80">@CurrentEvent?.OriginName</MudText>
                                                </div>
                                                <div class="path-line my-1" style="height:20px; border-radius:2px;"></div>
                                                <div class="d-flex align-center gap-3">
                                                    <div class="rounded-circle bg-error shadow-sm" style="width:10px; height:10px; border:2px solid white;"></div>
                                                    <MudText Typo="Typo.body2" Class="fw-800 opa-80">@(CurrentEvent?.DestinationName ?? "PENDING")</MudText>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                }
                                else
                                {
                                    <div class="pa-8 sub-panel d-flex flex-column align-center justify-center border-dashed border-2">
                                        <MudIcon Icon="@Icons.Material.Filled.Block" Class="opa-20 mb-2" Size="Size.Large" />
                                        <MudText Typo="Typo.caption" Class="label-caps">SYSTEM IDLE</MudText>
                                    </div>
                                }
                            </MudItem>

                            <!-- Section: Personnel Duty -->
                            <MudItem xs="12" md="3" Class="border-r border-solid border-white-10">
                                <MudText Typo="Typo.caption" Class="label-caps mb-4 d-block">PERSONNEL ON DUTY</MudText>
                                @if (AssignedDriver != null)
                                {
                                    <div class="d-flex align-center gap-4 pa-2">
                                        <MudAvatar Color="Color.Primary" Variant="Variant.Filled" Size="Size.Large" Class="fw-900 avatar-halo" Style="width:64px; height:64px; font-size:1.5rem;">
                                            @AssignedDriver.DriverName?.Substring(0, 1).ToUpper()
                                        </MudAvatar>
                                        <div>
                                            <MudText Typo="Typo.h6" Class="fw-900 admin-td-primary text-design">@AssignedDriver.DriverName</MudText>
                                            <div class="d-flex align-center mt-2 pa-1 px-3 rounded-pill sub-panel">
                                                <MudIcon Icon="@Icons.Material.Filled.Phone" Size="Size.Small" Class="mr-2 opa-60" />
                                                <MudText Typo="Typo.caption" Class="fw-800">@AssignedDriver.Mobile</MudText>
                                            </div>
                                        </div>
                                    </div>
                                    @if (!AssignedDriver.HasValidLicense)
                                    {
                                        <div class="mt-4 pa-3 rounded-xl bg-error-light border-solid border-1 border-error d-flex align-center gap-2">
                                            <MudIcon Icon="@Icons.Material.Filled.GppBad" Color="Color.Error" Size="Size.Small" />
                                            <MudText Typo="Typo.caption" Color="Color.Error" Class="fw-900">CREDENTIAL FAILURE</MudText>
                                        </div>
                                    }
                                }
                                else
                                {
                                    <div class="pa-6 rounded-xl sub-panel border-solid border-1 border-error-light">
                                        <MudText Typo="Typo.body2" Color="Color.Error" Class="fw-900 uppercase">UNASSIGNED</MudText>
                                        <MudText Typo="Typo.caption" Class="opa-60 fw-600 mt-1 d-block">Awaiting commander assignment...</MudText>
                                    </div>
                                }
                            </MudItem>

                            <!-- Section: Status Telemetry -->
                            <MudItem xs="12" md="5">
                                <MudText Typo="Typo.caption" Class="label-caps mb-4 d-block">LIVE STATUS TELEMETRY</MudText>
                                <div class="pa-6 rounded-xl @(HideControls ? "bg-error-light border-error" : "bg-success-light border-success") border-solid border-1 shadow-sm relative overflow-hidden">
                                    <div class="absolute" style="right: -20px; top: -20px; opacity: 0.05;">
                                        <MudIcon Icon="@Icons.Material.Filled.Analytics" Style="font-size: 150px;" />
                                    </div>
                                    
                                    <div class="d-flex align-center justify-space-between relative">
                                        <div>
                                            <MudText Typo="Typo.caption" Class="label-caps opa-70 mb-2 d-block">Current Unit State</MudText>
                                            <MudText Typo="Typo.h3" Class="@($"fw-900 {(HideControls ? "admin-td-error" : "admin-td-primary")}")" Style="letter-spacing:-2px;">
                                                @(EventType?.EventStatusText ?? "STANDBY")
                                            </MudText>
                                        </div>
                                        <div class="d-flex flex-column align-end">
                                            @if (ShouldShowDualLocation)
                                            {
                                                <div class="d-flex align-center gap-2 pa-2 px-4 rounded-xl bg-white-70 shadow-sm border border-solid border-white-10">
                                                    <MudIcon Icon="@Icons.Material.Filled.DepartureBoard" Color="@(HideControls ? Color.Error : Color.Success)" Size="Size.Small" Class="opa-80" />
                                                    <MudText Typo="Typo.body2" Class="fw-900 opa-90">@CurrentEvent.OriginName</MudText>
                                                    <MudIcon Icon="@Icons.Material.Filled.ArrowForward" Size="Size.Small" Class="opa-50 mx-1" />
                                                    <MudIcon Icon="@Icons.Material.Filled.Place" Color="Color.Error" Size="Size.Small" Class="opa-80" />
                                                    <MudText Typo="Typo.body2" Class="fw-900 opa-90">@DisplayDestinationName</MudText>
                                                </div>
                                            }
                                            else
                                            {
                                                <div class="d-flex align-center gap-3 pa-2 px-4 rounded-xl bg-white-70 shadow-sm border border-solid border-white-10">
                                                    <MudIcon Icon="@Icons.Material.Filled.MyLocation" Color="@(HideControls ? Color.Error : Color.Success)" Class="opa-80" />
                                                    <MudText Typo="Typo.body2" Class="fw-900 opa-90">@(CurrentEvent?.OriginName ?? "UNKNOWN")</MudText>
                                                </div>
                                            }
                                        </div>
                                    </div>
                                </div>
                            </MudItem>
                        </MudGrid>
                    </div>

                    <!-- Action Interface -->
                    @if (!HideControls)
                    {
                        <div class="pa-4 bg-white-10 d-flex align-center gap-4 flex-wrap border-t border-solid border-white-10 rounded-b-xl">
                            <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Bolt"
                                       Disabled="@(AssignedDriver == null ||(AssignDriver != null && !AssignedDriver.HasValidLicense))"
                                       OnClick="UpdateEvent" Class="fw-900 px-10 rounded-pill shadow-highlight py-3 h-100">
                                @EventButtonLabel
                            </MudButton>

                            @if (CurrentEvent?.EventTypeID == 2)
                            {
                                <MudButton Variant="Variant.Text" Color="Color.Primary" StartIcon="@Icons.Material.Filled.CloudUpload" OnClick="AddConsignment" Class="fw-800 hover-scale">LOAD CONSIGNMENT</MudButton>
                            }

                            <MudButton Variant="Variant.Text" Color="Color.Default" StartIcon="@Icons.Material.Filled.SwitchAccount" OnClick="AssignDriver" Class="fw-800 hover-scale">@AssignDriverLabel</MudButton>

                            <MudSpacer />

                            <div class="d-flex align-center gap-4">
                                <MudMenu EndIcon="@Icons.Material.Filled.MoreVert" Label="OPTIONS" Variant="Variant.Outlined" 
                                         Color="Color.Default" AnchorOrigin="Origin.TopRight" TransformOrigin="Origin.BottomRight" 
                                         Dense="true" Class="rounded-pill fw-900 px-4" MaxHeight="300" PopoverClass="premium-card">
                                    <MudMenuItem Icon="@Icons.Material.Filled.Assignment" OnClick="OpenCheckList" Class="fw-800">Routine Checklist</MudMenuItem>
                                    @if (CurrentTrip != null)
                                    {
                                        <MudMenuItem Icon="@Icons.Material.Filled.Launch" OnClick="OpenTripCard" Class="fw-800">View Mission Details</MudMenuItem>
                                        @if(!CurrentTrip.Closed)
                                        {
                                            <MudMenuItem Icon="@Icons.Material.Filled.AccountBalanceWallet" OnClick="OpenTripAdvance" Class="fw-800">Provision Advance</MudMenuItem>
                                            <MudDivider Class="my-2" />
                                            <MudMenuItem Icon="@Icons.Material.Filled.HighlightOff" OnClick="CancelTrip" Class="admin-td-error fw-900">ABORT MISSION</MudMenuItem>
                                        }
                                    }
                                </MudMenu>

                                @if (ShowReportBreakdownButton)
                                {
                                    <MudButton Variant="Variant.Filled" Color="Color.Error" StartIcon="@Icons.Material.Filled.GppBad" OnClick="ReportBreakDown" Class="rounded-pill px-8 fw-900 py-3 shadow-highlight">REPORT INCIDENT</MudButton>
                                }
                            </div>
                        </div>
                    }
                </div>
            </MudItem>
        }

        @if (SelectedTruck != null)
        {
            <MudItem xs="12">
                <div class="admin-glass-card mt-2 pa-0 overflow-hidden fade-in">
                    <TripViewComponent Trip="CurrentTrip" OnTripStatusUpdated="@TripStatusUpdated" @ref="@TripViewRef" @key="CurrentTrip?.TripID"></TripViewComponent>
                </div>
            </MudItem>
        }
    </MudGrid>
</div>
@code {

    [Parameter]
    public TruckModel SelectedTruck { get; set; }

    TripViewComponent TripViewRef;
    private int BranchID;
    private string UserID = null;
    private DriverModel AssignedDriver { get; set; }
    private EventModel CurrentEvent { get; set; }
    private EventTypeModel EventType { get; set; }
    private TripModel CurrentTrip { get; set; }
    private string TripDestinationName;
    private string DisplayDestinationName => (CurrentEvent != null && !string.IsNullOrEmpty(CurrentEvent.DestinationName) && CurrentEvent.OriginName != CurrentEvent.DestinationName) ? CurrentEvent.DestinationName : TripDestinationName;
    private bool ShouldShowDualLocation => CurrentEvent != null && !string.IsNullOrEmpty(DisplayDestinationName) && CurrentEvent.OriginName != DisplayDestinationName;
    private GstUsageCodeModel UsageCodeModel { get; set; }
    string TruckStatus;
    string EventButtonLabel;
    string AssignDriverLabel;
    private bool HideControls { get; set; } = true;
    public bool HideStatus { get; set; } = true;
    private bool DisableEventButton { get; set; } = false;
    private bool DisableCancelButton { get; set; } = true;
    private bool ShowReportBreakdownButton { get; set; } = true;
    private bool _busy;
    public bool HasPermissionTripServiceEdit { get; set; } = false;
    public int DocTypeID = 39;

    protected override async Task OnInitializedAsync()
    {
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionTripServiceEdit = await Irole.HasClaim(DocTypeID.ToString(), "Edit", ctc.Token);
        var authprov = await auth.GetAuthenticationStateAsync();
        var claim = authprov.User.Claims.FirstOrDefault(x => x.Type == "BranchID");
        if (claim != null)
        {
            BranchID = int.Parse(claim.Value);
        }
        else
        {
            return;
        }
        var user = authprov.User;
        UserID = user.Identity.Name;
        // OnTruckSelected(SelectedTruck);
    }

    private void GetTruckInfo()
    {

    }

    private async void OpenTripCard()
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        _busy = true;
        var parameters = new DialogParameters();
        parameters.Add("Trip", CurrentTrip);
        var result = await DialogService.ShowAsync<TripDetailsCard>(CurrentTrip.TripNumberDisplay.ToString() + " Details", parameters, new DialogOptions { MaxWidth = MaxWidth.Large });
        await Task.Delay(200);
        _busy = false;
    }

    private async void OpenTripAdvance()
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        _busy = true;
        var parameters = new DialogParameters();
        parameters.Add("Trip", CurrentTrip);
        parameters.Add("Truck", SelectedTruck);
        parameters.Add("AssignedDriver", AssignedDriver);
        var Advancedialog = await DialogService.ShowAsync<TripAdvanceDialog>(CurrentTrip.TripNumberDisplay.ToString() + " Details", parameters, new DialogOptions { MaxWidth = MaxWidth.Large });
        var Advanceresult = await Advancedialog.Result;
        await Task.Delay(200);
        _busy = false;
    }

    private async Task UpdateEvent()
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        if (!IsFit())
        {
            return;
        }
        _busy = true;
        var parameters = new DialogParameters();
        parameters.Add("Truck", SelectedTruck);
        parameters.Add("AssignedDriver", AssignedDriver);
        if (EventButtonLabel == "Start New Trip")
        {
            bool IsbranchSetting = branchSettingsService.IsEnabled(BranchID, 1);
            if (IsbranchSetting)
            {
                var ResultList = IserviceRoutineMaster.SelectItemByBranch(BranchID).Where(item => !item.IsDisabled).ToList();
                var TruckListTempSub = IroutineCheckListService.GetLastRoutineCheckListDetailsUsingTruckId(SelectedTruck.TruckID);
                if (TruckListTempSub != null)
                {
                    List<RoutineCheckListModel> TruckListTemp = new();
                    TruckListTemp = TruckListTempSub.ToList();
                    foreach (var item in TruckListTemp.OrderBy(s => s.CreatedDate))
                    {
                        if (ResultList != null && ResultList.Count() != 0 && ResultList.Any(s => s.ItemID == item.ItemID))
                        {
                            foreach (RoutineCheckListMasterModel Values in ResultList.Where(s => (int)s.ItemID == item.ItemID))
                            {
                                Values.CurrentTruckLastUpdatedDate = item.CreatedDate;
                                if (item.CreatedDate != null && Values != null)
                                {
                                    Values.IsExpired = ((DateTime.Now - item.CreatedDate.Value).TotalDays > Values.ValidDays);
                                    //Values.IsChecked = true;
                                    //Values.DetailDescription = item.Description;
                                }
                            }
                        }
                    }
                }
                if (ResultList != null && ResultList.Count() != 0 && ResultList.Any(s => s.IsExpired))
                {
                    var expiredItems = ResultList.Where(s => !s.IsDisabled && s.IsExpired)
                                    .Select(s => s.ItemName + " (" + (s.CurrentTruckLastUpdatedDate?.ToString("dd/MM/yyyy") ?? "") + ")")
                                    .ToList();

                    string resultString = string.Join(",", expiredItems);
                    string message = "Some of the checklist item(s) " + resultString + " is expired.";
                    bool? result1 = await DialogService.ShowMessageBoxAsync("Expired", message);

                    _busy = false;
                    return;
                }
            }

            var dialog = await DialogService.ShowAsync<NewTripView>("Start Trip", parameters, new DialogOptions() { MaxWidth = MaxWidth.Medium });
            var result = await dialog.Result;
            if (!result.Canceled)
            {
                CurrentTrip = (TripModel)result.Data;
                await RefreshTripDestinationName();
                truckStatusUpdated(Ievent.GetCurrentEvent(SelectedTruck.TruckID));
                TripViewRef.LoadGcs();
                TripViewRef.LoadAllUsingCurrentTrip(CurrentTrip);
            }
        }
        else
        {
            parameters.Add("CurrentTrip", CurrentTrip);
            var dialog = await DialogService.ShowAsync<UpdateEventView>("Update Event", parameters, new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true });
            var result = await dialog.Result;
            if (!result.Canceled)
            {
                CurrentEvent = (EventModel)result.Data;
                truckStatusUpdated(CurrentEvent);
                TripViewRef.LoadGcs();
                TripViewRef.LoadAllUsingCurrentTrip(CurrentTrip);
            }
        }
        await Task.Delay(200);
        _busy = false;
    }

    private async Task CancelTrip()
    {
        if (HasPermissionTripServiceEdit)
        {
            int pendingGcs = Igc.SelectPending(CurrentTrip?.TripID).Count();
            string txt = "";
            if (pendingGcs != 0)
            {
                txt = pendingGcs + " Unfinished GCs found.Do you want to Remove those GCs from this Truck";
            }
            else
            {
                txt = "Do you confirm the cancellation?";
            }
            bool? yesno = await DialogService.ShowMessageBoxAsync(
                "Cancel Trip",
                txt,
                yesText: "Cancel Trip!", cancelText: "Don't Cancel");
            if (yesno == null)
            {
                return;
            }
            var authState = await auth.GetAuthenticationStateAsync();
            Itrip.Cancel(CurrentTrip.TripID, authState.User.Identity.Name);
            CurrentTrip.UserInfo.RecordStatus = 4;
            TripViewRef.LoadAll();
            StateHasChanged();
        }
        else
        {
            bool? ResultModel = await DialogService.ShowMessageBoxAsync(
                "Permission denied!",
                "You don't have any permission to Add or Edit Trip.");
        }
    }

    private async Task ReportBreakDown()
    {
        bool? yesno = false;
        //var eventTypeid = Ievent.GetCurrentEvent(SelectedTruck.TruckID).EventTypeID;
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        int pendingGcs = Igc.SelectPending(CurrentTrip?.TripID).Count();
        if (pendingGcs != 0)
        {
            yesno = await DialogService.ShowMessageBoxAsync(
           "Work Order",
           pendingGcs + " Unfinished GCs found.Do you want to Remove those GCs from this Truck",
           yesText: "Yes!", noText: "No");
            if (yesno == null)
            {
                return;
            }
        }
        _busy = true;
        var parameters = new DialogParameters();
        parameters.Add("Truck", SelectedTruck);
        parameters.Add("CurrentTrip", CurrentTrip);
        parameters.Add("PendingGcs", pendingGcs);
        parameters.Add("IsGcRemoved", yesno);
        var result = await DialogService.ShowAsync<BreakdownDialog>(null, parameters);
        var Data = await result.Result;
        var ev = Data.Data;
        if (!Data.Canceled)
        {
            truckStatusUpdated(Ievent.GetCurrentEvent(SelectedTruck.TruckID));
        }
        await Task.Delay(200);
        _busy = false;
    }

    private async Task AssignDriver()
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        _busy = true;
        var parameters = new DialogParameters();
        parameters.Add("Truck", SelectedTruck);
        parameters.Add("AssignedDriver", AssignedDriver);
        var result = await DialogService.ShowAsync<AssignDriverView>(AssignDriverLabel, parameters);
        var Data = await result.Result;
        var ev = Data.Data;
        if (!Data.Canceled)
        {
            AssignedDriver = (DriverModel)ev;
            AssignDriverLabel = AssignedDriver == null ? "Assign Driver" : "Replace Driver";
        }
        await Task.Delay(200);
        _busy = false;
    }

    private async Task AddConsignment()
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        _busy = true;
        var parameters = new DialogParameters();
        parameters.Add("Truck", SelectedTruck);
        parameters.Add("TripID", CurrentTrip.TripID);
        DialogOptions maxWidth = new DialogOptions() { MaxWidth = MaxWidth.Large, FullWidth = true };
        var result = await DialogService.ShowAsync<GcSelectDialog>("Load Consignment", parameters, maxWidth);
        var Data = await result.Result;
        var ev = Data.Data;
        TripViewRef.LoadGcs();
        await Task.Delay(200);
        _busy = false;
    }

    private async void OnTruckSelectedAsync(TruckModel model)
    {
        SelectedTruck = model;
        if (model != null)
        {
            CurrentTrip = Itrip.Select(Itruck.GetCurrentTrip(model.TruckID));
            await RefreshTripDestinationName();
            CurrentEvent = Ievent.GetCurrentEvent(model.TruckID);
            truckStatusUpdated(CurrentEvent);
            ShowReportBreakdownButton = BranchID == (model.CurrentBranchID ?? BranchID);
        }
        else
        {
            CurrentTrip = null;
            TripDestinationName = null;
            truckStatusUpdated(null);
        }
        StateHasChanged();
    }

    private async Task RefreshTripDestinationName()
    {
        if (CurrentTrip != null)
        {
            CurrentTrip.Closed = Itrip.IsClosed(CurrentTrip.TripID);
            if (CurrentTrip.DestinationID.HasValue)
            {
                var dest = await Iplace.SelectByID(CurrentTrip.DestinationID.Value);
                TripDestinationName = dest?.PlaceName;
            }
            else
            {
                TripDestinationName = null;
            }
        }
        else
        {
            TripDestinationName = null;
        }
    }

    private bool IsFit()
    {
        var doc = idocument.SelectByAsset(SelectedTruck.AssetID, false);
        foreach (var item in doc.Where(x => x.IsFitParameter is true))
        {
            if (item.ExtendedEndDate == null)
            {
                if (item.EndDate < DateTime.Today)
                {
                    string[] doctTyps = doc.Where(x => x.EndDate < DateTime.Today).Select(y => y.DocumentType.DocumentTypeName).ToArray();
                    snackbar.Add(String.Join(",", doctTyps) + " Expired", Severity.Error);
                    return false;
                }
            }
            else
            {
                if (item.ExtendedEndDate < DateTime.Today)
                {
                    string[] doctTyps = doc.Where(x => x.ExtendedEndDate < DateTime.Today).Select(y => y.DocumentType.DocumentTypeName).ToArray();
                    snackbar.Add(String.Join(",", doctTyps) + " Expired", Severity.Error);
                    return false;
                }
            }
        }

        return true;
    }

    protected void TripStatusUpdated(EventModel em)
    {
        // truckStatusUpdated(em);
    }

    private void truckStatusUpdated(EventModel ev)
    {
        HideControls = true; HideStatus = true; EventType = null;

        if (SelectedTruck != null)
        {
            int truckID = SelectedTruck?.TruckID ?? 0;
            int? DriverID = Itruck.GetAssignedDriver(truckID);

            if (DriverID == null)
            {
                AssignedDriver = null;
                AssignDriverLabel = "Assign Driver";
            }
            else
            {
                AssignedDriver = Idriver.SelectByID(DriverID.Value);
                AssignDriverLabel = "Replace Driver";
            }

            // Set text to show
            if (ev != null)
            {
                HideStatus = false;
                EventType = Ievent.GetEventType(ev.EventTypeID);
                //CurrentTrip = Itrip.Select(LastEvent.TripID);
                string TruckStatusAppend;
                if (!EventType.IsStationary)
                {
                    TruckStatusAppend = " From " + ev.OriginName + " To " + ev.DestinationName;
                }
                else
                {
                    TruckStatusAppend = " At " + ev.OriginName;
                }
                TruckStatus = string.Format("{0} On {1}{2} (Reported by {3}", EventType?.EventStatusText, ev?.EventTime, TruckStatusAppend, Ibranch.GetBranchName(ev.BranchID));
            }

            //Hide-Show Controls
            if (EventType != null && EventType.IsBlocking)
            {
                HideControls = true;
            }
            else if (EventType == null || EventType.EventTypeID == 6 || EventType.EventTypeID == 11)
            {
                HideControls = false; HideStatus = true;
                EventButtonLabel = "Start New Trip";
            }
            else
            {
                HideControls = false; HideStatus = false;
                EventButtonLabel = "Update Status";
            }
        }
    }

    private async void OpenCheckList()
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        _busy = true;
        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;
        var brancIDString = authprov.User.Claims.First(x => x.Type == "BranchID").Value;

        RoutineCheckListModel checkListModel = new()
        {
            Truck = SelectedTruck,
            TruckID = SelectedTruck.TruckID,
            BranchID = int.Parse(brancIDString),
        };

        DialogParameters parms = new DialogParameters();
        parms.Add("model", checkListModel);
        var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Large };
        var dialog = await DialogService.ShowAsync<RoutineCheckListDialog>("Simple Dialog", parms, options);
        var result = await dialog.Result;

        // you can check if the modal was cancelled
        var isCancelled = result.Canceled;
        await Task.Delay(200);
        _busy = false;
    }
}
