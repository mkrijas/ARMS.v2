@page "/operations"
@using ArmsModels.BaseModels.FMS;
@using ArmsServices.DataServices.FMS;
@using ArmsServices.DataServices.Operations;
@using Pages.Operations.Truck
@using Pages.Operations.Gc
@using Pages.FMS.Breakdown
@using Pages.FMS.RoutineCheckList
@using Pages.Finance.Transactions
@using System.Threading;
@inject IBranchService Ibranch
@inject ITruckService Itruck
@inject IDriverService Idriver
@inject ITripService Itrip
@inject IEventService Ievent
@inject IGcService Igc
@inject IPlaceService Iplace
@inject IAssetDocumentService idocument
@inject IRoutineCheckListMasterService IserviceRoutineMaster
@inject IRoutineCheckListService IroutineCheckListService
@inject ITripAdvanceService Iadvance
@inject MudBlazor.ISnackbar snackbar
@attribute [Authorize]
@inject AuthenticationStateProvider auth
@inject IDialogService DialogService
@inject IBranchSettingsService branchSettingsService
@inject IRoleService<RoleModel> Irole
@inject IConfigTable config
@inject IGstUsageIDService usage

<MudGrid Spacing="4">
    <MudItem xs="12">
        <TruckSelector Class="bg-white" Value="SelectedTruck" BranchID="BranchID" ValueChanged="OnTruckSelected" Filter="AvailableForBranch" HomeOrOperation="Operation" />
       
    </MudItem>
    <MudItem xs="12" Class="d-flex">
        @if (CurrentTrip != null)
        {
            <MudText hidden="@HideStatus" Typo="Typo.h4" Class="mr-5"><MudIcon Icon="@Icons.Material.Filled.ModeOfTravel" Title="Trip Number" Color="Color.Primary" /> @(CurrentTrip?.TripNumberDisplay)</MudText>
        }
        @if (SelectedTruck != null && AssignedDriver == null)
        {
            <MudText Typo="Typo.h4" Color="Color.Error"><MudIcon Icon="@Icons.Material.Outlined.AirlineSeatReclineNormal" Title="Driver" /> UNASSAIGNED</MudText>
        }
        else if (SelectedTruck != null && AssignedDriver != null)
        {
            <MudText Typo="Typo.h4" Color="Color.Success">
                <MudIcon Icon="@Icons.Material.Filled.AirlineSeatReclineNormal" Title="Driver" /> @AssignedDriver.DriverName
            </MudText>
            @if (!AssignedDriver.HasValidLicense)
            {
                <MudText Typo="Typo.caption" Color="Color.Error"> (Invalid Licence)</MudText>
            }
        }
        <MudSpacer></MudSpacer>
        @if (HideControls && SelectedTruck != null)
        {
            <MudText Typo="Typo.h4" Color="Color.Error">@EventType?.EventStatusText</MudText>
        }
        else if (!HideControls)
        {
            <MudText Typo="Typo.h4" Color="Color.Primary"> @CurrentEvent?.OriginName - @CurrentEvent?.DestinationName</MudText>
        }
    </MudItem>
    @if (!HideControls)
    {
        <MudItem xs="12" md="12">
            <MudButtonGroup Color="Color.Surface" Variant="Variant.Filled">
                <MudButton StartIcon="@Icons.Material.Filled.AddTask" Disabled="@(AssignedDriver == null ||(AssignDriver != null && !AssignedDriver.HasValidLicense))" OnClick="UpdateEvent" IconColor="Color.Default">@EventButtonLabel</MudButton>
                @if (CurrentEvent?.EventTypeID == 2)
                {
                    <MudButton StartIcon="@Icons.Material.Outlined.AddTask" OnClick="AddConsignment" IconColor="Color.Tertiary">Load Consignment</MudButton>
                }
                <MudButton StartIcon="@Icons.Material.Outlined.PersonAddAlt1" OnClick="AssignDriver" IconColor="Color.Primary">@AssignDriverLabel</MudButton>
                @if (ShowReportBreakdownButton)
                {
                    <MudButton StartIcon="@Icons.Material.Filled.ReportProblem" OnClick="ReportBreakDown" IconColor="Color.Secondary">Breakdown/Accident</MudButton>

                }
                @if (CurrentTrip != null && !CurrentTrip.Closed)
                {                   
                        <MudButton StartIcon="@Icons.Material.Outlined.Cancel" OnClick="CancelTrip" IconColor="Color.Error">Cancel Trip</MudButton>
                }
                @if (CurrentTrip != null)
                {
                    <MudButton StartIcon="@Icons.Material.Filled.Money" OnClick="OpenTripAdvance" IconColor="Color.Success">Trip Advance</MudButton>
                    <MudButton StartIcon="@Icons.Material.Outlined.Details" OnClick="OpenTripCard" IconColor="Color.Primary">View Details</MudButton>
                }
                <MudButton StartIcon="@Icons.Material.Filled.Checklist" OnClick="OpenCheckList" IconColor="Color.Primary">Routine Check List</MudButton>
            </MudButtonGroup>
        </MudItem>
    }
</MudGrid>
@if (SelectedTruck != null)
{
    <TripViewComponent Trip="CurrentTrip" OnTripStatusUpdated="@TripStatusUpdated" @ref="@TripViewRef"></TripViewComponent>
}


@code {

    [Parameter]
    public TruckModel SelectedTruck { get; set; }
    TripViewComponent TripViewRef;
    private int BranchID;
    private string UserID = null;
    private DriverModel AssignedDriver { get; set; }
    private EventModel CurrentEvent { get; set; }
    private EventTypeModel EventType { get; set; }
    private TripModel CurrentTrip { get; set; }
    private GstUsageCodeModel UsageCodeModel { get; set; }
    string TruckStatus;
    string EventButtonLabel;
    string AssignDriverLabel;
    private bool HideControls { get; set; } = true;
    public bool HideStatus { get; set; } = true;
    private bool DisableEventButton { get; set; } = false;
    private bool DisableCancelButton { get; set; } = true;
    private bool ShowReportBreakdownButton { get; set; } = true;
    private bool _busy;
    public bool HasPermissionTripServiceEdit { get; set; } = false;
    public int DocTypeID = 39;

    protected override async Task OnInitializedAsync()
    {
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionTripServiceEdit = await Irole.HasClaim(DocTypeID.ToString(), "Edit", ctc.Token);
        var authprov = await auth.GetAuthenticationStateAsync();
        var brancIDString = authprov.User.Claims.First(x => x.Type == "BranchID").Value;
        BranchID = int.Parse(brancIDString);
        var user = authprov.User;
        UserID = user.Identity.Name;        
        // OnTruckSelected(SelectedTruck);
    }

    private void GetTruckInfo()
    {

    }

    private async void OpenTripCard()
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        _busy = true;
        var parameters = new DialogParameters();
        parameters.Add("Trip", CurrentTrip);
        var result = DialogService.Show<TripDetailsCard>(CurrentTrip.TripNumberDisplay.ToString() + " Details", parameters, new DialogOptions { MaxWidth = MaxWidth.Large });
        await Task.Delay(200);
        _busy = false;
    }

    private async void OpenTripAdvance()
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        _busy = true;
        var parameters = new DialogParameters();
        parameters.Add("Trip", CurrentTrip);
        parameters.Add("Truck", SelectedTruck);
        parameters.Add("AssignedDriver", AssignedDriver);
        var Advancedialog = DialogService.Show<TripAdvanceDialog>(CurrentTrip.TripNumberDisplay.ToString() + " Details", parameters);
        var Advanceresult = await Advancedialog.Result;
        if (!Advanceresult.Canceled)
        {
            var advanceEntry = (SundryPaymentEntryModel)Advanceresult.Data;
            ConfigModel cModel = config.GetTripAdvanceUsageCode();
            UsageCodeModel = usage.SelectByCode(cModel.ValueString);

            advanceEntry.UsageCode = (cModel.ValueString);
            advanceEntry.UsageCodeDescription = UsageCodeModel.Description;
            advanceEntry.CoaID = UsageCodeModel.CoaID;
            advanceEntry.Reference = CurrentTrip.TripNumberDisplay.ToString() + " Advance";
            advanceEntry.BranchID = BranchID;

            SundryPaymentModel spModel = new()
                {
                    BranchID = BranchID,
                    PayeeName = AssignedDriver.DriverName,
                    PayeeContactNo = AssignedDriver.Mobile,
                    Reference = CurrentTrip.TripNumberDisplay.ToString() + " Advance",
                    Narration = string.Format("Advance given against Trip Number : {0}, Truck : {1} , Driver : {2}", CurrentTrip.TripNumberDisplay, SelectedTruck.RegNo, AssignedDriver.DriverName),
                    NatureOfTransaction = "Trip Advance",
                    UserInfo = new() { UserID = UserID, },
                    Entries = new List<SundryPaymentEntryModel>() { advanceEntry }
                };

            var parametersForSp = new DialogParameters();
            parametersForSp.Add("model", spModel);
            var Sundrydialog = DialogService.Show<SundryPaymentDialog>(null, parametersForSp, new DialogOptions { MaxWidth = MaxWidth.Large });
            var Sundryresult = await Sundrydialog.Result;
            if (!Sundryresult.Canceled)
            {
                var sundryPayment = (SundryPaymentModel)Sundryresult.Data;
                int SundryPaymentDocTypeID = 11;

                advanceEntry.Amount = sundryPayment.Entries.First(x => x.UsageCode == advanceEntry.UsageCode).Amount;

                TripAdvanceModel advanceModel = new()
                    {
                        BranchID = BranchID,
                        TripID = CurrentTrip.TripID,
                        DriverID = AssignedDriver.DriverID,
                        Amount = advanceEntry.Amount,
                        CoaID = advanceEntry.CoaID,
                        UsageCode = advanceEntry.UsageCode,
                        DocumentTypeID = SundryPaymentDocTypeID,
                        DocumentID = sundryPayment.SundryPaymentID,
                        DocType = "Trip"
                    };
                Iadvance.Update(advanceModel);
            }

        }
        await Task.Delay(200);
        _busy = false;
    }

    private async Task UpdateEvent()
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        if (!IsFit())
        {
            return;
        }
        _busy = true;
        var parameters = new DialogParameters();
        parameters.Add("Truck", SelectedTruck);
        parameters.Add("AssignedDriver", AssignedDriver);
        if (EventButtonLabel == "Start New Trip")
        {           
            bool IsbranchSetting = branchSettingsService.IsEnabled(BranchID, 1);
            if (IsbranchSetting)
            {
                var ResultList = IserviceRoutineMaster.SelectItemByBranch(BranchID).Where(item => !item.IsDisabled).ToList();
                var TruckListTempSub = IroutineCheckListService.GetLastRoutineCheckListDetailsUsingTruckId(SelectedTruck.TruckID);
                if (TruckListTempSub != null)
                {
                    List<RoutineCheckListModel> TruckListTemp = new();
                    TruckListTemp = TruckListTempSub.ToList();
                    foreach (var item in TruckListTemp.OrderBy(s => s.CreatedDate))
                    {
                        if (ResultList != null && ResultList.Count() != 0 && ResultList.Any(s => s.ItemID == item.ItemID))
                        {
                            foreach (RoutineCheckListMasterModel Values in ResultList.Where(s => (int)s.ItemID == item.ItemID))
                            {
                                Values.CurrentTruckLastUpdatedDate = item.CreatedDate;
                                if (item.CreatedDate != null && Values != null)
                                {
                                    Values.IsExpired = ((DateTime.Now - item.CreatedDate.Value).TotalDays > Values.ValidDays);
                                    //Values.IsChecked = true;
                                    //Values.DetailDescription = item.Description;
                                }
                            }
                        }
                    }
                }
                if (ResultList != null && ResultList.Count() != 0 && ResultList.Any(s => s.IsExpired))
                {
                    var expiredItems = ResultList.Where(s => !s.IsDisabled && s.IsExpired)
                                    .Select(s => s.ItemName + " (" + (s.CurrentTruckLastUpdatedDate?.ToString("dd/MM/yyyy") ?? "") + ")")
                                    .ToList();

                    string resultString = string.Join(",", expiredItems);
                    string message = "Some of the checklist item(s) " + resultString + " is expired.";
                    bool? result1 = await DialogService.ShowMessageBox("Expired", message);

                    _busy = false;
                    return;
                }
            }

            var dialog = DialogService.Show<NewTripView>("Start Trip", parameters,new DialogOptions(){MaxWidth= MaxWidth.Medium });
            var result = await dialog.Result;
            if (!result.Canceled)
            {
                CurrentTrip = (TripModel)result.Data;               
                truckStatusUpdated(Ievent.GetCurrentEvent(SelectedTruck.TruckID));
                TripViewRef.LoadGcs();
                TripViewRef.LoadAllUsingCurrentTrip(CurrentTrip);
            }
        }
        else
        {
            parameters.Add("CurrentTrip", CurrentTrip);
            var dialog = DialogService.Show<UpdateEventView>("Update Event", parameters);
            var result = await dialog.Result;
            if (!result.Canceled)
            {
                CurrentEvent = (EventModel)result.Data;               
                truckStatusUpdated(CurrentEvent);
                TripViewRef.LoadGcs();
                TripViewRef.LoadAllUsingCurrentTrip(CurrentTrip);
            }
        }
        await Task.Delay(200);
        _busy = false;
    }

    private async Task CancelTrip()
    {
        if (HasPermissionTripServiceEdit)
        {
            int pendingGcs = Igc.SelectPending(CurrentTrip?.TripID).Count();
            string txt = "";
            if (pendingGcs != 0)
            {
                txt = pendingGcs + " Unfinished GCs found.Do you want to Remove those GCs from this Truck";
            }
            else
            {
                txt = "Do you confirm the cancellation?";
            }
            bool? yesno = await DialogService.ShowMessageBox(
                "Cancel Trip",
                txt,
                yesText: "Cancel Trip!", cancelText: "Don't Cancel");
            if (yesno == null)
            {
                return;
            }
            var authState = await auth.GetAuthenticationStateAsync();
            Itrip.Cancel(CurrentTrip.TripID, authState.User.Identity.Name);
            TripViewRef.LoadAll();
            StateHasChanged();
        }
        else
        {
            bool? ResultModel = await DialogService.ShowMessageBox(
                "Permission denied!",
                "You dont have any permission to Add or Edit Trip.");
        }
    }

    private async Task ReportBreakDown()
    {
        bool? yesno = false;
        //var eventTypeid = Ievent.GetCurrentEvent(SelectedTruck.TruckID).EventTypeID;
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        int pendingGcs = Igc.SelectPending(CurrentTrip?.TripID).Count();
        if (pendingGcs != 0)
        {
            yesno = await DialogService.ShowMessageBox(
           "Breakdown",
           pendingGcs + " Unfinished GCs found.Do you want to Remove those GCs from this Truck",
           yesText: "Yes!", noText: "No");
            if (yesno == null)
            {
                return;
            }
        }
        _busy = true;
        var parameters = new DialogParameters();
        parameters.Add("Truck", SelectedTruck);
        parameters.Add("CurrentTrip", CurrentTrip);
        parameters.Add("PendingGcs", pendingGcs);
        parameters.Add("IsGcRemoved", yesno);
        var result = DialogService.Show<BreakdownDialog>(null, parameters);
        var Data = await result.Result;
        var ev = Data.Data;
        if (!Data.Canceled)
        {
            truckStatusUpdated(Ievent.GetCurrentEvent(SelectedTruck.TruckID));
        }
        await Task.Delay(200);
        _busy = false;
    }

    private async Task AssignDriver()
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        _busy = true;
        var parameters = new DialogParameters();
        parameters.Add("Truck", SelectedTruck);
        parameters.Add("AssignedDriver", AssignedDriver);
        var result = DialogService.Show<AssignDriverView>(AssignDriverLabel, parameters);
        var Data = await result.Result;
        var ev = Data.Data;
        if (!Data.Canceled)
        {
            AssignedDriver = (DriverModel)ev;
            AssignDriverLabel = AssignedDriver == null ? "Assign Driver" : "Replace Driver";
        }
        await Task.Delay(200);
        _busy = false;
    }

    private async Task AddConsignment()
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        _busy = true;
        var parameters = new DialogParameters();
        parameters.Add("Truck", SelectedTruck);
        parameters.Add("TripID", CurrentTrip.TripID);
        DialogOptions maxWidth = new DialogOptions() { MaxWidth = MaxWidth.Large, FullWidth = true };
        var result = DialogService.Show<GcSelectDialog>("Load Consignment", parameters, maxWidth);
        var Data = await result.Result;
        var ev = Data.Data;
        TripViewRef.LoadGcs();
        await Task.Delay(200);
        _busy = false;
    }

    private void OnTruckSelected(TruckModel model)
    {
        SelectedTruck = model;
        if (model != null)
        {
            CurrentTrip = Itrip.Select(Itruck.GetCurrentTrip(model.TruckID));
            if (CurrentTrip != null)
            {
                CurrentTrip.Closed = Itrip.IsClosed(CurrentTrip.TripID);          
            }          
                truckStatusUpdated(Ievent.GetCurrentEvent(model.TruckID));  
                ShowReportBreakdownButton = BranchID == (model.CurrentBranchID??BranchID);            
        }
        else
        {
            CurrentTrip = null;
            truckStatusUpdated(null);
        }
    }

    private bool IsFit()
    {
        var doc = idocument.SelectByAsset(SelectedTruck.AssetID);
        foreach (var item in doc.Where( x=> x.IsFitParameter is true ))
        {
            if (item.ExtendedEndDate == null)
            {
                if (item.EndDate < DateTime.Today)
                {
                    string[] doctTyps = doc.Where(x => x.EndDate < DateTime.Today).Select(y => y.DocumentType.DocumentTypeName).ToArray();
                    snackbar.Add(String.Join(",", doctTyps) + " Expired", Severity.Error);
                    return false;
                }
            }
            else
            {
                if (item.ExtendedEndDate < DateTime.Today)
                {
                    string[] doctTyps = doc.Where(x => x.ExtendedEndDate < DateTime.Today).Select(y => y.DocumentType.DocumentTypeName).ToArray();
                    snackbar.Add(String.Join(",", doctTyps) + " Expired", Severity.Error);
                    return false;
                }
            }
        }

        // if (doc.Any(x => x.EndDate < DateTime.Today))
        // {
        //     string[] doctTyps = doc.Where(x => x.EndDate < DateTime.Today).Select(y => y.DocumentType.DocumentTypeName).ToArray();
        //     snackbar.Add(String.Join(",", doctTyps) + " Expired", Severity.Error);
        //     return false;
        // }
        return true;
    }

    protected void TripStatusUpdated(EventModel em)
    {
        // truckStatusUpdated(em);
    }

    private void truckStatusUpdated(EventModel ev)
    {
        HideControls = true;HideStatus = true;EventType = null;

        CurrentEvent = ev;

        if (SelectedTruck != null)
        {
            int? DriverID = Itruck.GetAssignedDriver(SelectedTruck.TruckID);
            AssignedDriver = DriverID == null ? null : Idriver.SelectByID(DriverID.Value);
            AssignDriverLabel = AssignedDriver == null ? "Assign Driver" : "Replace Driver";

            // Set text to show
            if (ev != null)
            {
                HideStatus = false;
                EventType = Ievent.GetEventType(ev.EventTypeID);
                //CurrentTrip = Itrip.Select(LastEvent.TripID);
                string TruckStatusAppend;
                if (!EventType.IsStationary)
                {
                    TruckStatusAppend = " From " + ev.OriginName + " To " + ev.DestinationName;
                }
                else
                {
                    TruckStatusAppend = " At " + ev.OriginName;
                }
                TruckStatus = string.Format("{0} On {1}{2} (Reported by {3}", EventType?.EventStatusText ,ev?.EventTime , TruckStatusAppend , Ibranch.GetBranchName(ev.BranchID) );
            }

            //Hide-Show Controls
            if (EventType != null && EventType.IsBlocking)
            {
                HideControls = true;
            }
            else if (EventType == null || EventType.EventStatusText == "UnAssigned")
            {
                HideControls = false; HideStatus = true;
                EventButtonLabel = "Start New Trip";
            }
            else
            {
                HideControls = false;  HideStatus = false;
                EventButtonLabel = "Update Status";
            }
        }
    }

    private async void OpenCheckList()
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        _busy = true;
        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;
        var brancIDString = authprov.User.Claims.First(x => x.Type == "BranchID").Value;



        RoutineCheckListModel checkListModel = new()
            {
                Truck = SelectedTruck,
                TruckID = SelectedTruck.TruckID,
                BranchID = int.Parse(brancIDString),
            };

        DialogParameters parms = new DialogParameters();
        parms.Add("model", checkListModel);
        var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Large };
        var dialog = DialogService.Show<RoutineCheckListDialog>("Simple Dialog", parms, options);
        var result = await dialog.Result;

        // you can check if the modal was cancelled
        var isCancelled = result.Cancelled;
        await Task.Delay(200);
        _busy = false;
    }
}