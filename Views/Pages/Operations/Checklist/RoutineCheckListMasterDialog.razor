@using System.Threading;
@using ArmsModels.BaseModels.General
@using ArmsServices.DataServices.Operations
@inject AuthenticationStateProvider auth
@inject IRoutineCheckListMasterService Iservice
@inject IAssetDocumentService IDocumentService
@inject MudBlazor.ISnackbar snackbar
@inject IRoleService<RoleModel> Irole
@inject IDialogService DialogService

<MudDialog>
    <TitleContent>
        @if (model.ItemID == null || model.ItemID == 0)
        {
            <MudText Typo="Typo.h6">
                <MudIcon Icon="@Icons.Material.Filled.Edit" Class="mr-3" /> Add Routine Check List
            </MudText>
        }
        else
        {
            <MudText Typo="Typo.h6">
                <MudIcon Icon="@Icons.Material.Filled.Edit" Class="mr-3" /> Edit Routine Check List
            </MudText>
        }
    </TitleContent>
    <DialogContent>
        <MudContainer Style="max-height: 400px; overflow-y: scroll; margin-left:20px">
            <EditForm id="formRoutineCheckList" Model="@model" OnValidSubmit="Submit">
                <ObjectGraphDataAnnotationsValidator />
                <ValidationSummary />
                <MudItem xs="11" md="11" Class="mb-6">
                    <MudTextField @bind-Value="model.ItemName" Label="Routine Check List Name" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.ItemName)"></MudTextField>
                </MudItem>
                <MudItem xs="11" md="11" Class="mb-6">
                    <MudTextField @bind-Value="model.Description" Label="Description" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.Description)"></MudTextField>
                </MudItem>
                <MudItem xs="11" md="11" Class="mb-6">
                    <MudTextField @bind-Value="model.ValidDays" Label="Valid Days" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.ValidDays)"></MudTextField>
                </MudItem>
                <MudItem xs="11" md="11">
                    <MudCheckBox @bind-Checked="@model.IsDisabled" Label="Disable"></MudCheckBox>
                </MudItem>
            </EditForm>
        </MudContainer>
    </DialogContent>
    <DialogActions>
        <MudButton Disabled="@_busy" form="formRoutineCheckList" Variant="Variant.Filled" Color="Color.Primary" ButtonType="ButtonType.Submit" Class="px-12">Submit</MudButton>
    </DialogActions>
</MudDialog>

@code {

    [CascadingParameter] MudDialogInstance MudDialog { get; set; }
    [Parameter]
    public RoutineCheckListMasterModel model { get; set; } = new();
    [Parameter]
    public List<string> ItemsNamesLists { get; set; } = null;
    private bool _busy;

    public bool HasPermissionRoutineCheckListMasterServiceEdit { get; set; } = false;
    public int DocTypeID = 42;

    List<AssetDocumentTypeModel> DocumentTypes = new();

    protected override async Task OnInitializedAsync()
    {
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionRoutineCheckListMasterServiceEdit = await Irole.HasClaim(DocTypeID.ToString(), "Edit", ctc.Token);
    }

    protected override void OnParametersSet()
    {
        DocumentTypes = IDocumentService.GetDocumentTypes().ToList();
    }

    void Cancel()
    {
        MudDialog.Cancel();
    }

    public async Task Submit()
    {
        if (model.ItemName != null && ItemsNamesLists != null && ItemsNamesLists.Any(s => s != null && (s.ToLower().Trim() == model.ItemName.ToLower().Trim())))
        {
            snackbar.Add("Item name already exist", Severity.Error);
            return;
        }
        if (_busy)
        {
            snackbar.Add("Please wait while form is being submitted!", Severity.Warning);
            return;
        }
        if (HasPermissionRoutineCheckListMasterServiceEdit)
        {
            var authprov = await auth.GetAuthenticationStateAsync();
            var user = authprov.User;
            if (model != null)
            {
                _busy = true;
                model.UserInfo.UserID = user.Identity.Name;
                try
                {
                    Iservice.Update(model);
                }
                catch (Exception ex)
                {
                    snackbar.Add(ex.Message, Severity.Error);
                }
            }
            MudDialog.Close(DialogResult.Ok(true));
            await Task.Delay(200);
            _busy = false;
        }
        else
        {
            bool? ResultModel = await DialogService.ShowMessageBox(
                "Permission denied!",
                "You don't have any permission to Add or Edit RoutineCheckListMaster.");
        }
    }
}