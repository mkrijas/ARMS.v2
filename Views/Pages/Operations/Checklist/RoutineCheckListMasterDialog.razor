@using System.Threading;
@using ArmsModels.BaseModels.General
@using ArmsServices.DataServices.Operations
@inject AuthenticationStateProvider auth
@inject IRoutineCheckListMasterService Iservice
@inject IAssetDocumentService IDocumentService
@inject MudBlazor.ISnackbar snackbar
@inject IRoleService<RoleModel> Irole
@inject IDialogService DialogService

<MudDialog Class="admin-dialog-glass">
    <TitleContent>
        <div class="header-section mb-2 pt-4 px-4">
            <div class="d-flex align-center justify-space-between">
                <div class="d-flex align-center">
                    <div class="icon-badge primary-badge mr-4">
                        <div class="admin-header-icon-badge mb-3">
                            <MudIcon Icon="@Icons.Material.Filled.FactCheck" Color="Color.Secondary" Style="font-size: 3rem;" />
                        </div>
                    </div>
                    <div>
                        <MudText Typo="Typo.h5" Class="admin-title"><b>Checklist Master Specification</b></MudText>
                        <MudText Typo="Typo.body2" Class="admin-subtitle">Define and configure standardized operational protocols for routine asset assessments.</MudText>
                    </div>
                </div>
            </div>
            <div class="title-accent mt-4"></div>
        </div>
    </TitleContent>
    <DialogContent>
        <MudContainer Class="admin-dialog-container">
            <div class="dialog-content-wrapper pa-4">
                <EditForm id="formRoutineCheckList" Model="@model" OnValidSubmit="Submit">
                    <ObjectGraphDataAnnotationsValidator />
                    
                    <div class="admin-glass-card pa-6">
                        <div class="d-flex align-center mb-6">
                            <MudIcon Icon="@Icons.Material.Filled.SettingsSuggest" Color="Color.Primary" Class="mr-2" />
                            <span class="admin-section-label mb-0">Protocol Configuration</span>
                        </div>
                        
                        <MudGrid Spacing="3">
                            <MudItem xs="12">
                                <MudTextField @bind-Value="model.ItemName" Label="Routine Protocol Designation" Variant="Variant.Outlined" Margin="Margin.Normal" For="@(() => model.ItemName)" Class="modern-input" Placeholder="Enter unique checklist name..."></MudTextField>
                            </MudItem>
                            
                            <MudItem xs="12">
                                <MudTextField @bind-Value="model.Description" Label="Operational Scope / Description" Variant="Variant.Outlined" Margin="Margin.Normal" For="@(() => model.Description)" Class="modern-input" Lines="3" Placeholder="Describe the purpose and steps of this checklist..."></MudTextField>
                            </MudItem>
                            
                            <MudItem xs="12" md="6">
                                <MudTextField @bind-Value="model.ValidDays" Label="Temporal Validity (Days)" Variant="Variant.Outlined" Margin="Margin.Normal" For="@(() => model.ValidDays)" Class="modern-input" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.History" InputType="InputType.Number"></MudTextField>
                            </MudItem>
                            
                            <MudItem xs="12" md="6">
                                <div class="modern-checkbox-container mt-2">
                                    <MudCheckBox T="bool" @bind-Value="@model.IsDisabled" Label="Suspend Lifecycle" Color="Color.Error" Dense="true" UncheckedColor="Color.Default"></MudCheckBox>
                                </div>
                            </MudItem>
                        </MudGrid>
                    </div>
                </EditForm>
            </div>
        </MudContainer>
    </DialogContent>
    <DialogActions>
        <div class="d-flex w-100 flex-wrap pa-4 gap-3 align-center">
            <MudSpacer />
            <MudButton Variant="Variant.Outlined" Color="Color.Default" OnClick="Cancel" Style="border-radius: 12px; font-weight: 700; text-transform: none; border-color: rgba(0,0,0,0.15);">Discard</MudButton>
            <MudButton Disabled="@_busy" form="formRoutineCheckList" Variant="Variant.Filled" Color="Color.Primary" ButtonType="ButtonType.Submit" Style="background: var(--mud-palette-primary); color: white; font-weight: 800; border-radius: 12px; text-transform: none; white-space: nowrap; padding: 8px 32px;" StartIcon="@Icons.Material.Filled.DoneAll">Registry Protocol</MudButton>
        </div>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialogInstance { get; set; }
    [Parameter]
    public RoutineCheckListMasterModel model { get; set; } = new();
    [Parameter]
    public List<string> ItemsNamesLists { get; set; } = null;
    private bool _busy;

    public bool HasPermissionRoutineCheckListMasterServiceEdit { get; set; } = false;
    public int DocTypeID = 42;

    List<AssetDocumentTypeModel> DocumentTypes = new();

    // Lifecycle method called when the component is initialized
    protected override async Task OnInitializedAsync()
    {
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionRoutineCheckListMasterServiceEdit = await Irole.HasClaim(DocTypeID.ToString(), "Edit", ctc.Token);
    }

    // Lifecycle method called when parameters are setc
    protected override void OnParametersSet()
    {
        // Retrieve the list of document types from the service
        DocumentTypes = IDocumentService.GetDocumentTypes().ToList();
    }

    void Cancel()
    {
        MudDialogInstance.Cancel();
    }

    // Method to submit the form 
    public async Task Submit()
    {
        if (model.ItemName != null && ItemsNamesLists != null && ItemsNamesLists.Any(s => s != null && (s.ToLower().Trim() == model.ItemName.ToLower().Trim())))
        {
            snackbar.Add("Item name already exist", Severity.Error);
            return;
        }
        if (_busy)
        {
            snackbar.Add("Please wait while form is being submitted!", Severity.Warning);
            return;
        }
        if (HasPermissionRoutineCheckListMasterServiceEdit)
        {
            var authprov = await auth.GetAuthenticationStateAsync();
            var user = authprov.User;
            if (model != null)
            {
                _busy = true;
                model.UserInfo.UserID = user.Identity.Name;
                try
                {
                    Iservice.Update(model); // Update the model using the service
                }
                catch (Exception ex)
                {
                    snackbar.Add(ex.Message, Severity.Error);
                }
            }
            MudDialogInstance.Close(DialogResult.Ok(true));
            await Task.Delay(200);
            _busy = false;
        }
        else
        {
            bool? ResultModel = await DialogService.ShowMessageBoxAsync(
                "Permission denied!",
                "You don't have any permission to Add or Edit RoutineCheckListMaster.");
        }
    }
}
