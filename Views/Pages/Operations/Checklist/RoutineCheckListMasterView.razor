@page "/RoutineCheckListMasterView"
@using System.Threading;
@using ArmsModels.BaseModels.General
@using ArmsServices.DataServices.Operations
@attribute [Authorize]
@inject AuthenticationStateProvider auth
@inject IRoutineCheckListMasterService Iservice
@inject IDialogService DialogService
@inject IRoleService<RoleModel> Irole
@inject MudBlazor.ISnackbar snackbar

@if (_isLoading)
{
    <div @key="@("loader")" style="display: flex; justify-content: center; align-items: center; min-height: 400px;">
        <LoaderComponent IsFullScreen="true" 
                        ShowLogo="false" 
                        Size="medium" 
                        LoadingText="Mapping Maintenance Schemas" 
                        SubText="Structuring operational protocols..." />
    </div>
}
else
{
    <div class="fade-in">
        <div class="admin-header-tiered mb-6">
            <div class="d-flex align-center justify-space-between">
                <div>
                    <MudText Typo="Typo.h4" Class="admin-title">Operations | Maintenance Blueprint</MudText>
                    <MudText Typo="Typo.body2" Class="admin-subtitle">Master registry for routine operational checklists. Define protocol schemas, configure inspection parameters, and manage preventive maintenance blueprints across all asset categories for operational excellence.</MudText>
                </div>
            </div>
        </div>

        <div class="admin-glass-card mb-6 pa-4">
            <div class="d-flex align-center justify-end gap-4">
                <div class="admin-icon-square-vibrant small accent-indigo clickable" @onclick="@(()=> OpenDialogEdit(new RoutineCheckListMasterModel()))">
                    <MudIcon Icon="@Icons.Material.Filled.Add" Size="Size.Small" />
                </div>
            </div>
        </div>

        <div class="admin-glass-card pa-0 overflow-hidden shadow-sm">
            <MudTable Items="@collection" Elevation="0" Class="modern-admin-table" Hover="true" T="RoutineCheckListMasterModel">
                <HeaderContent>
                    <MudTh><MudTableSortLabel SortBy="new Func<RoutineCheckListMasterModel, object>(x=> x.ItemName)"><span class="admin-header-text">BLUEPRINT IDENTITY</span></MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<RoutineCheckListMasterModel, object>(x=> x.CreatedDate)"><span class="admin-header-text">ESTABLISHED</span></MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<RoutineCheckListMasterModel, object>(x=> x.Description)"><span class="admin-header-text">SCOPE/PURPOSE</span></MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<RoutineCheckListMasterModel, object>(x=> x.ValidDays)"><span class="admin-header-text">INTERVAL (DAYS)</span></MudTableSortLabel></MudTh>
                    <MudTh Style="text-align: right;"><span class="admin-header-text pr-4">PROTOCOLS</span></MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Name">
                         <div class="d-flex align-center gap-2">
                             <div class="admin-icon-square-vibrant tiny accent-indigo">
                                <MudIcon Icon="@Icons.Material.Filled.FactCheck" Size="Size.Small" />
                            </div>
                            <span class="fw-700 admin-td-primary">@context.ItemName</span>
                        </div>
                    </MudTd>
                    <MudTd DataLabel="Created">
                        <span class="fw-600 opa-70">@Convert.ToDateTime(@context.CreatedDate).ToString("dd MMM yyyy")</span>
                    </MudTd>
                    <MudTd DataLabel="Description">
                        <span class="fw-500 opa-60 small">@context.Description</span>
                    </MudTd>
                    <MudTd DataLabel="ValidDays">
                        <MudChip T="string" Color="Color.Info" Size="Size.Small" Variant="Variant.Text" Class="fw-800">@context.ValidDays D</MudChip>
                    </MudTd>
                    <MudTd DataLabel="Actions" Style="text-align: right;">
                        <div class="d-flex justify-end gap-1 mb-1">
                                <MudTooltip Text="Refine Schema">
                                    <MudIconButton OnClick="@(()=> OpenDialogEdit(context))" Color="Color.Primary" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Variant="Variant.Text" />
                                </MudTooltip>

                                <MudTooltip Text="Terminate Sequence">
                                    <MudIconButton OnClick="@(()=> OpenDialogDelete(context))" Color="Color.Error" Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Variant="Variant.Text" />
                                </MudTooltip>
                        </div>
                    </MudTd>
                </RowTemplate>
                <PagerContent>
                    <div class="pa-4">
                        <MudTablePager PageSizeOptions="new int[] { 10, 20, 50, 100 }" />
                    </div>
                </PagerContent>
            </MudTable>
        </div>
    </div>
}

@code {

    private bool _isLoading = true;
    private DateTime _loadStartTime;

    private RoutineCheckListMasterModel model = new();
    private List<RoutineCheckListMasterModel> collection = new();
    string state = "Message box hasn't been opened yet";
    private bool _busy;
    public bool HasPermissionRoutineCheckListMasterServiceEdit { get; set; } = false;
    public bool HasPermissionRoutineCheckListMasterServiceDelete { get; set; } = false;
    public int DocTypeID = 42;

    // Lifecycle method called when the component is initialized
    protected override async Task OnInitializedAsync()
    {
        _loadStartTime = DateTime.Now;
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionRoutineCheckListMasterServiceEdit = await Irole.HasClaim(DocTypeID.ToString(), "Edit", ctc.Token);
        HasPermissionRoutineCheckListMasterServiceDelete = await Irole.HasClaim(DocTypeID.ToString(), "Delete", ctc.Token);

        await GetAll();
        await EnsureMinimumLoadTime();
        _isLoading = false;
    }

    private async Task EnsureMinimumLoadTime()
    {
        var elapsed = (DateTime.Now - _loadStartTime).TotalMilliseconds;
        if (elapsed < 100)
        {
            await Task.Delay(100 - (int)elapsed);
        }
    }

    // Method to retrieve all routine checklist items
    private async Task GetAll()
    {
        collection = new();
        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;
        var brancIDString = authprov.User.Claims.First(x => x.Type == "BranchID").Value;
        model.UserInfo = new();
        if (model.UserInfo != null)
        {
            model.UserInfo.UserID = user.Identity.Name;
        }
        model.BranchID = int.Parse(brancIDString);

        // Retrieve items for the specified branch
        collection = Iservice.SelectItemByBranch(model.BranchID).ToList();
    }

    // Method to open the edit dialog for a specific checklist item
    private async Task OpenDialogEdit(RoutineCheckListMasterModel model)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        _busy = true;
        if (HasPermissionRoutineCheckListMasterServiceEdit)
        {
            var authprov = await auth.GetAuthenticationStateAsync();
            var user = authprov.User;
            var brancIDString = authprov.User.Claims.First(x => x.Type == "BranchID").Value;
            model.UserInfo = new();
            if (model.UserInfo != null)
            {
                model.UserInfo.UserID = user.Identity.Name;
            }
            model.BranchID = int.Parse(brancIDString);
            List<string> ItemNamesList = new();
            ItemNamesList = collection.Where(d => model == null
                || (model != null && model.ItemID == null)
                || (model != null && model.ItemName != null && d.ItemName.ToLower().Trim() != model.ItemName.ToLower().Trim()))
                .Select(s => s.ItemName).ToList();
            var para = new DialogParameters
                {
                    ["model"] = model.Clone(),
                    ["ItemsNamesLists"] = ItemNamesList
                };
            var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Medium };
            var dialog = await DialogService.ShowAsync<RoutineCheckListMasterDialog>("Simple Dialog", para, options);
            var result = await dialog.Result;

            // you can check if the modal was cancelled
            var isCancelled = result.Canceled;
            if (!isCancelled)
            {
                await GetAll();
            }
        }
        else
        {
            bool? ResultModel = await DialogService.ShowMessageBoxAsync(
                "Permission denied!",
                "You don't have any permission to Add or Edit RoutineCheckListMaster.");
        }
        await Task.Delay(200);
        _busy = false;
    }

    private async Task OpenDialogDelete(RoutineCheckListMasterModel ItemMaster)
    {
        if (HasPermissionRoutineCheckListMasterServiceDelete)
        {
            bool? result = await DialogService.ShowMessageBoxAsync(
                "Warning",
                "Are you sure you want to delete this entry?",
                yesText: "Delete!", cancelText: "Cancel");
            state = result == null ? "Cancelled" : "Deleted!";
            if (state == "Deleted!")
            {
                var authprov = await auth.GetAuthenticationStateAsync();
                var user = authprov.User;
                ItemMaster.UserInfo = new();
                if (ItemMaster.UserInfo != null)
                {
                    ItemMaster.UserInfo.UserID = user.Identity.Name;
                    Iservice.Delete(ItemMaster.ItemID, ItemMaster.UserInfo.UserID);
                }
                await GetAll();
            }
        }
        else
        {
            bool? result = await DialogService.ShowMessageBoxAsync(
                "Permission denied!",
                "You don't have any permission to Delete RoutineCheckListMaster.");
        }
    }
}
