@page "/RoutineCheckListMasterView"
@using System.Threading;
@using ArmsModels.BaseModels.General
@using ArmsServices.DataServices.Operations
@attribute [Authorize]
@inject AuthenticationStateProvider auth
@inject IRoutineCheckListMasterService Iservice
@inject IDialogService DialogService
@inject IRoleService<RoleModel> Irole
@inject MudBlazor.ISnackbar snackbar

<MudGrid Spacing="4">
    <MudItem xs="12">
        <MudTable Items="@collection" Dense="true" Hover="true" Striped="true" Elevation="10" @bind-place="model">
            <ToolBarContent>
                <MudText Typo="Typo.h6">Routine Check List</MudText>
                <MudTooltip Text="New Routine Check List">
                    <MudIconButton Icon="@Icons.Material.Filled.Add" Title="Add" @onclick="@(()=> OpenDialogAddNew())" Color="Color.Dark" Size="Size.Small"></MudIconButton>
                </MudTooltip>
                <MudSpacer></MudSpacer>
            </ToolBarContent>
            <HeaderContent>
                <MudTh><MudTableSortLabel SortBy="new Func<RoutineCheckListMasterModel, object>(x=> x.ItemName)" InitialDirection="SortDirection.Ascending">Routine Check List Name</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<RoutineCheckListMasterModel, object>(x=> x.CreatedDate)" InitialDirection="SortDirection.Ascending">Created Date</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<RoutineCheckListMasterModel, object>(x=> x.Description)" InitialDirection="SortDirection.Ascending">Description</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<RoutineCheckListMasterModel, object>(x=> x.ValidDays)" InitialDirection="SortDirection.Ascending">Valid Days</MudTableSortLabel></MudTh>
                <MudTh>Actions</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Routine Check List">@context.ItemName</MudTd>
                <MudTd DataLabel="CreatedDate">@Convert.ToDateTime(@context.CreatedDate).ToString("dd/MM/yyyy hh:mm")</MudTd>
                <MudTd DataLabel="Description">@context.Description</MudTd>
                <MudTd DataLabel="Description">@context.ValidDays</MudTd>
                <MudTd DataLabel="Actions">
                    <MudTooltip Text="Edit">
                        <MudIconButton @onclick="@(()=> OpenDialogEdit(context))" Color="Color.Primary" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" IconSize="Size.Small" />
                    </MudTooltip>
                    <MudTooltip Text="Remove">
                        <MudIconButton @onclick="@(()=> OpenDialogDelete(context))" Color="Color.Primary" Icon="@Icons.Material.Filled.Remove" Size="Size.Small" IconSize="Size.Small" />
                    </MudTooltip>
                </MudTd>
            </RowTemplate>
            <PagerContent>
                <MudTablePager PageSizeOptions="new int[] { 5, 10, 20, 50, 100 }" />
            </PagerContent>
        </MudTable>
    </MudItem>
</MudGrid>

@code {

    private RoutineCheckListMasterModel model = new();
    private List<RoutineCheckListMasterModel> collection = new();
    string state = "Message box hasn't been opened yet";

    public bool HasPermissionRoutineCheckListMasterServiceEdit { get; set; } = false;
    public bool HasPermissionRoutineCheckListMasterServiceDelete { get; set; } = false;
    public int DocTypeID = 42;

    private async Task OpenDialogAddNew()
    {
        if (HasPermissionRoutineCheckListMasterServiceEdit)
        {
            RoutineCheckListMasterModel ItemMaster = new();
            ItemMaster.UserInfo = new();
            var authprov = await auth.GetAuthenticationStateAsync();
            var user = authprov.User;
            var brancIDString = authprov.User.Claims.First(x => x.Type == "BranchID").Value;
            if (ItemMaster.UserInfo != null)
            {
                ItemMaster.UserInfo.UserID = user.Identity.Name;
            }
            ItemMaster.BranchID = int.Parse(brancIDString);
            List<string> ItemsNamesLists = new();
            ItemsNamesLists = collection.Select(s => s.ItemName).ToList();
            var model = new DialogParameters { ["model"] = ItemMaster, ["ItemsNamesLists"] = ItemsNamesLists };
            var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Medium };
            var dialog = DialogService.Show<RoutineCheckListMasterDialog>("Simple Dialog", model, options);
            var result = await dialog.Result;

            // you can check if the modal was cancelled
            var isCancelled = result.Canceled;
            if (!isCancelled)
            {
                await GetAll();
            }
        }
        else
        {
            bool? ResultModel = await DialogService.ShowMessageBox(
                "Permission denied!",
                "You dont have any permission to Add or Edit RoutineCheckListMaster.");
        }
    }

    private async Task OpenDialogEdit(RoutineCheckListMasterModel ItemMaster)
    {
        if (HasPermissionRoutineCheckListMasterServiceEdit)
        {
            var authprov = await auth.GetAuthenticationStateAsync();
            var user = authprov.User;
            var brancIDString = authprov.User.Claims.First(x => x.Type == "BranchID").Value;
            ItemMaster.UserInfo = new();
            if (ItemMaster.UserInfo != null)
            {
                ItemMaster.UserInfo.UserID = user.Identity.Name;
            }
            ItemMaster.BranchID = int.Parse(brancIDString);
            var model = new DialogParameters { ["model"] = ItemMaster };
            var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Medium };
            var dialog = DialogService.Show<RoutineCheckListMasterDialog>("Simple Dialog", model, options);
            var result = await dialog.Result;

            // you can check if the modal was cancelled
            var isCancelled = result.Canceled;
            if (!isCancelled)
            {
                await GetAll();
            }
        }
        else
        {
            bool? ResultModel = await DialogService.ShowMessageBox(
                "Permission denied!",
                "You dont have any permission to Add or Edit RoutineCheckListMaster.");
        }
    }

    private async Task OpenDialogDelete(RoutineCheckListMasterModel ItemMaster)
    {
        if (HasPermissionRoutineCheckListMasterServiceDelete)
        {
            bool? result = await DialogService.ShowMessageBox(
                "Warning",
                "Are you sure you want to delete this entry?",
                yesText: "Delete!", cancelText: "Cancel");
            state = result == null ? "Cancelled" : "Deleted!";
            if (state == "Deleted!")
            {
                var authprov = await auth.GetAuthenticationStateAsync();
                var user = authprov.User;
                ItemMaster.UserInfo = new();
                if (ItemMaster.UserInfo != null)
                {
                    ItemMaster.UserInfo.UserID = user.Identity.Name;
                    Iservice.Delete(ItemMaster.ItemID, ItemMaster.UserInfo.UserID);
                }
                await GetAll();
            }
        }
        else
        {
            bool? result = await DialogService.ShowMessageBox(
                "Permission denied!",
                "You dont have any permission to Delete RoutineCheckListMaster.");
        }
    }

    protected override async Task OnInitializedAsync()
    {
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionRoutineCheckListMasterServiceEdit = await Irole.HasClaim(DocTypeID.ToString(), "Edit", ctc.Token);
        HasPermissionRoutineCheckListMasterServiceDelete = await Irole.HasClaim(DocTypeID.ToString(), "Delete", ctc.Token);

        await GetAll();
    }

    private async Task GetAll()
    {
        collection = new();
        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;
        var brancIDString = authprov.User.Claims.First(x => x.Type == "BranchID").Value;
        model.UserInfo = new();
        if (model.UserInfo != null)
        {
            model.UserInfo.UserID = user.Identity.Name;
        }
        model.BranchID = int.Parse(brancIDString);
        collection = Iservice.SelectItemByBranch(model.BranchID).ToList();
    }
}