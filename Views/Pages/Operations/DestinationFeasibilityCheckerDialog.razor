@using System.Threading;
@using Core.BaseModels.Operations
@attribute [Authorize]
@inject AuthenticationStateProvider auth
@inject IDestinationFeasibilityCheckerService Iservice
@inject IContentService Icontent
@inject ITruckTypeService Itrucktype
@inject MudBlazor.ISnackbar snackbar
@inject IRoleService<RoleModel> Irole
@inject IDialogService DialogService

<MudDialog Class="admin-dialog-glass">
    <TitleContent>
        <div class="header-section mb-2 pt-4 px-4">
            <div class="d-flex align-center justify-space-between">
                <div class="d-flex align-center">
                    <div class="icon-badge primary-badge mr-4">
                        <div class="admin-header-icon-badge mb-3">
                            <MudIcon Icon="@Icons.Material.Filled.Calculate" Color="Color.Secondary" Style="font-size: 3rem;" />
                        </div>
                    </div>
                    <div>
                        <MudText Typo="Typo.h5" Class="admin-title"><b>Logistical Feasibility Analysis</b></MudText>
                        <MudText Typo="Typo.body2" Class="admin-subtitle">Predictive modeling for route profitability and operational resource allocation.</MudText>
                    </div>
                </div>
                @if (model.ID != null)
                {
                    <div class="d-flex align-center">
                        <MudIconButton OnClick="@(()=> PrintInvoice(model.ID))" Color="Color.Tertiary" title="Print Analysis" Icon="@Icons.Material.Filled.Print" Size="Size.Medium" Variant="Variant.Filled" Class="rounded-pill shadow-sm" />
                    </div>
                }
            </div>
            <div class="title-accent mt-4"></div>
        </div>
    </TitleContent>
    <DialogContent>
        <MudContainer Class="admin-dialog-container">
            <div class="dialog-content-wrapper pa-4">
                <EditForm id="formDestinationFeasibility" Model="@model" OnValidSubmit="Submit">
                    <div class="admin-glass-card pa-6 mb-6">
                        <div class="d-flex align-center mb-6">
                            <MudIcon Icon="@Icons.Material.Filled.Assignment" Color="Color.Primary" Class="mr-2" />
                            <span class="admin-section-label mb-0">Core Operational Parameters</span>
                        </div>
                        
                        <MudGrid Spacing="3">
                            <MudItem xs="12" md="6">
                                <MudAutocomplete Clearable="true" Variant="Variant.Outlined" Margin="Margin.Normal" T="ContentModel" Label="Logistical Content / Load Type" ResetValueOnEmptyText="true" ValueChanged="ContentChanged" Value="@(model.Content ?? new ContentModel())"
                                                 SearchFunc="SearchRoutes" ToStringFunc="@(e => e == null ? null : $"{e.ContentName}")" Class="modern-input" AdornmentIcon="@Icons.Material.Filled.Inventory2" AdornmentColor="Color.Primary"></MudAutocomplete>
                            </MudItem>
                            <MudItem xs="12" md="6">
                                <MudSelect For="@(() => model.BodyType)" Margin="Margin.Normal" Variant="Variant.Outlined" Label="Vehicle Body Specification" @bind-Value="model.BodyType" AdornmentColor="Color.Secondary" Class="modern-input" AdornmentIcon="@Icons.Material.Filled.VerticalSplit">
                                    <MudSelectItem Value="@("Bulker")">Bulker Fleet</MudSelectItem>
                                    <MudSelectItem Value="@("Open")">Open Fleet</MudSelectItem>
                                </MudSelect>
                            </MudItem>
                            <MudItem xs="12" md="4">
                                <MudAutocomplete Clearable="true" Variant="Variant.Outlined" Margin="Margin.Normal" T="TruckTypeModel" Label="Strategic Asset Class" ResetValueOnEmptyText="true" ValueChanged="TruckTypeChanged" Value="@(model.TruckType ?? new TruckTypeModel())"
                                                 SearchFunc="SearchTruckType" ToStringFunc="@(e=> e == null ? null : $"{e.TruckType}")" Class="modern-input" AdornmentIcon="@Icons.Material.Filled.LocalShipping"></MudAutocomplete>
                            </MudItem>
                            <MudItem xs="12" md="4">
                                <MudTextField Value="@((model.TruckType ?? new TruckTypeModel()).BSType)" Label="Emission Standard (BS)" Variant="Variant.Outlined" Margin="Margin.Normal" ReadOnly Class="modern-input" Style="background: rgba(0,0,0,0.02);"></MudTextField>
                            </MudItem>
                            <MudItem xs="12" md="4">
                                <MudNumericField HideSpinButtons Value="@((model.TruckType ?? new TruckTypeModel()).wheels)" Label="Axle/Wheel Configuration" Variant="Variant.Outlined" Margin="Margin.Normal" ReadOnly Class="modern-input" Style="background: rgba(0,0,0,0.02);"></MudNumericField>
                            </MudItem>
                        </MudGrid>
                    </div>

                    <div class="admin-glass-card pa-6 mb-6">
                        <div class="d-flex align-center mb-6">
                            <MudIcon Icon="@Icons.Material.Filled.Route" Color="Color.Primary" Class="mr-2" />
                            <span class="admin-section-label mb-0">Route & Performance Telemetry</span>
                        </div>

                        <MudGrid Spacing="3">
                            <MudItem xs="12" md="4">
                                <MudNumericField HideSpinButtons Label="One-Side System KM" @bind-Value="model.SystemKM" Variant="Variant.Outlined" Margin="Margin.Normal" Class="modern-input" Adornment="Adornment.End" AdornmentText="KM"></MudNumericField>
                            </MudItem>
                            <MudItem xs="12" md="4">
                                <MudNumericField HideSpinButtons Label="Standard Operational Days" @bind-Value="model.StandardDays" Variant="Variant.Outlined" Margin="Margin.Normal" Class="modern-input" Adornment="Adornment.End" AdornmentText="Days"></MudNumericField>
                            </MudItem>
                            <MudItem xs="12" md="4">
                                <MudNumericField HideSpinButtons Label="Target Fuel Efficiency" @bind-Value="model.StandardMileage" Variant="Variant.Outlined" Margin="Margin.Normal" Class="modern-input" Adornment="Adornment.End" AdornmentText="KMPL"></MudNumericField>
                            </MudItem>
                            <MudItem xs="12" md="6">
                                <MudNumericField HideSpinButtons Label="Net Payload Capacity" @bind-Value="model.MetricTonn" Variant="Variant.Outlined" Margin="Margin.Normal" Class="modern-input" Adornment="Adornment.End" AdornmentText="MT"></MudNumericField>
                            </MudItem>
                            <MudItem xs="12" md="6">
                                <MudNumericField HideSpinButtons Label="Base Freight Rate (per MT)" @bind-Value="model.FreightRate" Variant="Variant.Outlined" Margin="Margin.Normal" Class="modern-input" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.CurrencyRupee"></MudNumericField>
                            </MudItem>
                        </MudGrid>
                    </div>

                    <div class="admin-glass-card pa-6 mb-6">
                        <div class="d-flex align-center mb-6">
                            <MudIcon Icon="@Icons.Material.Filled.AccountBalanceWallet" Color="Color.Primary" Class="mr-2" />
                            <span class="admin-section-label mb-0">Operational Expenditures (Variable)</span>
                        </div>

                        <MudGrid Spacing="3">
                            <MudItem xs="12" md="4">
                                <MudNumericField HideSpinButtons Label="Market Fuel Rate" @bind-Value="model.FuelRate" Variant="Variant.Outlined" Margin="Margin.Normal" Class="modern-input" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.LocalGasStation"></MudNumericField>
                            </MudItem>
                            <MudItem xs="12" md="4">
                                <MudNumericField HideSpinButtons Label="Operational Incentive" @bind-Value="model.Incentive" Variant="Variant.Outlined" Margin="Margin.Normal" Class="modern-input" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.AddModerator"></MudNumericField>
                            </MudItem>
                            <MudItem xs="12" md="4">
                                <MudNumericField HideSpinButtons Label="Designated Driver Wages" @bind-Value="model.DriverWages" Variant="Variant.Outlined" Margin="Margin.Normal" Class="modern-input" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Payments"></MudNumericField>
                            </MudItem>
                            <MudItem xs="12" md="4">
                                <MudNumericField HideSpinButtons Label="Integrated Toll Fees" @bind-Value="model.TollExpenses" Variant="Variant.Outlined" Margin="Margin.Normal" Class="modern-input" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.RvHookup"></MudNumericField>
                            </MudItem>
                            <MudItem xs="12" md="4">
                                <MudNumericField HideSpinButtons Label="Tagging/Administrative Fees" @bind-Value="model.TaggingExpenses" Variant="Variant.Outlined" Margin="Margin.Normal" Class="modern-input" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Tag"></MudNumericField>
                            </MudItem>
                            <MudItem xs="12" md="4">
                                <MudNumericField HideSpinButtons Label="Auxiliary Route Expenses" @bind-Value="model.TripOtherExpenses" Variant="Variant.Outlined" Margin="Margin.Normal" Class="modern-input" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.AttachMoney"></MudNumericField>
                            </MudItem>
                            <MudItem xs="12" md="6">
                                <MudNumericField HideSpinButtons Label="Terminal Loading Charges" @bind-Value="model.LoadingCharges" Variant="Variant.Outlined" Margin="Margin.Normal" Class="modern-input" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.UploadFile"></MudNumericField>
                            </MudItem>
                            <MudItem xs="12" md="6">
                                <MudNumericField HideSpinButtons Label="Terminal Unloading Charges" @bind-Value="model.UnloadingCharges" Variant="Variant.Outlined" Margin="Margin.Normal" Class="modern-input" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.FileDownload"></MudNumericField>
                            </MudItem>
                        </MudGrid>
                    </div>

                    @if (HasPermissionDfcServiceAccess)
                    {
                        <div class="admin-glass-card pa-6" style="border-top: 4px solid var(--mud-palette-info);">
                            <div class="d-flex align-center mb-6">
                                <MudIcon Icon="@Icons.Material.Filled.Business" Color="Color.Info" Class="mr-2" />
                                <span class="admin-section-label mb-0 color-info">Institutional & Fixed Cost Projections</span>
                            </div>

                            <MudGrid Spacing="3">
                                <MudItem xs="12" md="4">
                                    <MudTextField Value="@(model.BranchAdminCost?.ToString("C2"))" Label="Branch Administrative Overhead" Variant="Variant.Outlined" Margin="Margin.Normal" ReadOnly Class="modern-input-info"></MudTextField>
                                </MudItem>
                                <MudItem xs="12" md="4">
                                    <MudTextField Value="@(model.MaintenanceCost?.ToString("C2"))" Label="Preventative Maintenance Alloc." Variant="Variant.Outlined" Margin="Margin.Normal" ReadOnly Class="modern-input-info"></MudTextField>
                                </MudItem>
                                <MudItem xs="12" md="4">
                                    <MudTextField Value="@(model.TyreCost?.ToString("C2"))" Label="Tyre Lifecycle Sinking Fund" Variant="Variant.Outlined" Margin="Margin.Normal" ReadOnly Class="modern-input-info"></MudTextField>
                                </MudItem>
                                <MudItem xs="12" md="4">
                                    <MudTextField Value="@(model.TaxAndInsurance?.ToString("C2"))" Label="Statutory Tax & Insurance" Variant="Variant.Outlined" Margin="Margin.Normal" ReadOnly Class="modern-input-info"></MudTextField>
                                </MudItem>
                                <MudItem xs="12" md="4">
                                    <MudTextField Value="@(model.FcMaintenance?.ToString("C2"))" Label="Facility/Fixed Maintenance" Variant="Variant.Outlined" Margin="Margin.Normal" ReadOnly Class="modern-input-info"></MudTextField>
                                </MudItem>
                                <MudItem xs="12" md="4">
                                    <MudTextField Value="@(model.HOAdminCost?.ToString("C2"))" Label="Corporate Office Allocation" Variant="Variant.Outlined" Margin="Margin.Normal" ReadOnly Class="modern-input-info"></MudTextField>
                                </MudItem>
                            </MudGrid>
                        </div>
                    }
                </EditForm>
            </div>
        </MudContainer>
    </DialogContent>
    <DialogActions>
        <div class="d-flex w-100 flex-wrap pa-4 gap-3 align-center">
            @if (model.ID == null)
            {
                <MudSpacer />
                <MudButton Variant="Variant.Outlined" Color="Color.Secondary" OnClick="ResetForm" Style="border-radius: 12px; font-weight: 700; text-transform: none;">Reset Simulation</MudButton>
                <MudButton Disabled="@_busy" form="formDestinationFeasibility" Variant="Variant.Filled" Color="Color.Success" ButtonType="ButtonType.Submit" Style="background: var(--mud-palette-success); color: white; font-weight: 800; border-radius: 12px; text-transform: none; white-space: nowrap; padding: 8px 32px;" StartIcon="@Icons.Material.Filled.Timeline">Commit Analysis</MudButton>
            }
            else
            {
                <MudSpacer />
                <MudButton Variant="Variant.Outlined" Color="Color.Default" OnClick="Cancel" Style="border-radius: 12px; font-weight: 700; text-transform: none;">Close Analysis</MudButton>
            }
        </div>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; }
    [Parameter] public DestinationFeasibilityCheckerModel model { get; set; } = new();
    private List<ContentModel> contents = new List<ContentModel>();
    private List<TruckTypeModel> TruckTypes = new List<TruckTypeModel>();
    private DestinationFeasibilityCheckerRatesModel CalculationRates;
    public bool HasPermissionDfcServiceEdit { get; set; } = false;
    public bool HasPermissionDfcServiceAccess { get; set; } = false;
    public int DocTypeID = 144;
    private bool _busy;

    protected override async Task OnInitializedAsync()
    {
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionDfcServiceEdit = await Irole.HasClaim(DocTypeID.ToString(), "Edit", ctc.Token);
        HasPermissionDfcServiceAccess = await Irole.HasClaim(DocTypeID.ToString(), "Access", ctc.Token);

        if (model.UserInfo == null)
        {
            model.UserInfo = new ArmsModels.SharedModels.UserInfoModel();
        }
        // Fetch all content items
        await foreach (var item in Icontent.Select(0))
        {
            contents.Add(item);
        }
        TruckTypes = Itrucktype.Select(0).ToList();

        var authprov = await auth.GetAuthenticationStateAsync();
        model.BranchID = int.Parse(authprov.User.Claims.First(x => x.Type == "BranchID").Value);

        if (model.ID == null)
        {
            var user = authprov.User;
            if (user?.Identity != null)
            {
                model.UserInfo.UserID = user.Identity.Name;
            }
        }
    }

    // Method to search for contents based on the search string
    private async Task<IEnumerable<ContentModel>> SearchRoutes(string searchString, CancellationToken token)
    {
        return await Task.FromResult(contents.Where(x => x.ContentName.Contains(searchString == null ? string.Empty : searchString, StringComparison.InvariantCultureIgnoreCase)));
    }

    // Method to set the content object
    private void ContentChanged(ContentModel obj)
    {
        model.Content = obj;
    }

    public async Task<IEnumerable<TruckTypeModel>> SearchTruckType(string searchString, CancellationToken token)
    {
        return await Task.FromResult(TruckTypes.Where(x => x.TruckType.Contains(searchString == null ? string.Empty : searchString, StringComparison.InvariantCultureIgnoreCase)));
    }

    private void TruckTypeChanged(TruckTypeModel TruckType)
    {
        if (TruckType == null || TruckType.TruckTypeID == null)
        {
            model.TruckType = null;
            CalculationRates = null;
            return;
        }

        model.TruckType = TruckType;
        CalculationRates = Iservice.SelectRates(TruckType.TruckTypeID);
    }

    private async Task Submit(EditContext context)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is being submitted!", Severity.Warning);
            return;
        }
        if (HasPermissionDfcServiceEdit)
        {

            _busy = true;

            // Initialize necessary objects
            model.Content ??= new ContentModel();
            model.TruckType ??= new TruckTypeModel();
            model.SystemKM ??= 0;
            model.StandardDays ??= 0;
            model.StandardMileage ??= 0;
            model.MetricTonn ??= 0;
            model.FreightRate ??= 0;
            model.Incentive ??= 0;
            model.DriverWages ??= 0;
            model.TollExpenses ??= 0;
            model.TaggingExpenses ??= 0;
            model.LoadingCharges ??= 0;
            model.UnloadingCharges ??= 0;
            model.TripOtherExpenses ??= 0;
            model.FuelRate ??= 0;

            model.RunKM = model.SystemKM * 2;

            // Perform calculations
            if (model.StandardMileage != 0)
            {
                model.FuelLitre = model.RunKM / model.StandardMileage;
            }
            else
            {
                // Handle division by zero
                model.FuelLitre = 0;
            }

            model.PrimaryFreight = (model.FreightRate + model.Incentive) * model.MetricTonn;

            if (model.SystemKM != 0)
            {
                model.PTPK = (model.PrimaryFreight / model.MetricTonn) / model.SystemKM;
            }
            else
            {
                // Handle division by zero
                model.PTPK = 0;
            }

            model.FuelExpenses = model.FuelLitre * model.FuelRate;

            if (model.FuelExpenses.HasValue && model.PrimaryFreight.HasValue && model.PrimaryFreight.Value != 0)
            {
                model.FuelPercentage = Math.Round((model.FuelExpenses.Value / model.PrimaryFreight.Value) * 100, 0);
            }
            else
            {
                model.FuelPercentage = 0; 
            }

            model.AdBlueCost = (model.FuelLitre / 100) * CalculationRates.AdBlueRatio * 40;
            model.DriversSalary = (10000 / 30) * model.StandardDays;
            model.TripDirectExpenses = model.AdBlueCost + model.DriverWages + model.TollExpenses + model.TaggingExpenses + model.DriversSalary + model.LoadingCharges + model.UnloadingCharges + model.TripOtherExpenses;

            if (model.TripDirectExpenses.HasValue && model.PrimaryFreight.HasValue && model.PrimaryFreight.Value != 0)
            {
                model.TripPercentage = Math.Round((model.TripDirectExpenses.Value / model.PrimaryFreight.Value) * 100, 0);
            }
            else
            {
                // Handle division by zero
                model.TripPercentage = 0;
            }

            model.BranchAdminCost = 35 * model.MetricTonn;
            model.MaintenanceCost = CalculationRates.MaintenanceRate * model.RunKM;
            model.TyreCost = CalculationRates.TyreRate * model.RunKM;
            model.TaxAndInsurance = CalculationRates.AverageTaxAndInsurance * model.StandardDays;
            model.FcMaintenance = 90 * model.StandardDays;
            model.HOAdminCost = 40 * model.MetricTonn;
            model.OtherThanTripExpenses = model.BranchAdminCost + model.MaintenanceCost + model.TyreCost + model.TaxAndInsurance + model.FcMaintenance + model.HOAdminCost;

            if (model.OtherThanTripExpenses.HasValue && model.PrimaryFreight.HasValue && model.PrimaryFreight != 0)
            {
                model.OtherThanTripPercentage = Math.Round((model.OtherThanTripExpenses.Value / model.PrimaryFreight.Value) * 100, 0);
            }
            else
            {
                // Handle division by zero
                model.OtherThanTripPercentage = 0;
            }

            model.TotalExpense = model.TripDirectExpenses + model.OtherThanTripExpenses + model.FuelExpenses;
            model.Profit = model.PrimaryFreight - model.TotalExpense;

            if (model.TotalExpense.HasValue && model.Profit.HasValue && model.PrimaryFreight.HasValue && model.PrimaryFreight != 0)
            {
                model.ExpensePercentage = Math.Round((model.TotalExpense.Value / model.PrimaryFreight.Value) * 100, 0);
                model.ProfitPercentage = Math.Round((model.Profit.Value / model.PrimaryFreight.Value) * 100, 0);
            }
            else
            {
                // Handle division by zero
                model.ExpensePercentage = 0;
                model.Profit = 0;
            }

            // Save the model
            model = await Iservice.Update(model);
            snackbar.Add("Saved successfully!", Severity.Success);

            StateHasChanged();

            MudDialog.Close(DialogResult.Ok(model));
        }
        else
        {
            bool? ResultModel = await DialogService.ShowMessageBoxAsync(
                "Permission denied!",
                "You don't have any permission to Add or Edit.");
        }
    }

    private void Cancel()
    {
        MudDialog.Cancel();
    }

    private void ResetForm()
    {
        // Reset model properties to their default values
        model = new DestinationFeasibilityCheckerModel();
        _busy = false;
    }

    public Dictionary<string, string> ReportParameters { get; set; } = new();

    private async Task PrintInvoice(int? ID)
    {
        ReportParameters.Clear();
        ReportParameters.Add("ID", ID.ToString());
        var parameters = new DialogParameters();
        parameters.Add("Parameters", ReportParameters); // Add the dictionary as a parameter
        parameters.Add("ReportName", "PrintDestinationFeasibilityChecker");

        DialogOptions maxWidth = new DialogOptions() { MaxWidth = MaxWidth.Medium, FullWidth = true };
        var result = await DialogService.ShowAsync<PrintDialog>("PRINT", parameters, maxWidth);
    }
}
