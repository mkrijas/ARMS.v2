@page "/dfc"
@using Core.BaseModels.Operations
@inject IDestinationFeasibilityCheckerService Iservice
@inject MudBlazor.ISnackbar snackbar
@inject AuthenticationStateProvider auth
@attribute [Authorize]
@inject IDialogService DialogService
@using System.Threading;
@using Microsoft.Data.SqlClient;
@inject IRoleService<RoleModel> Irole

<div class="admin-page-container">
    <div class="admin-header-tiered mb-6">
        <div class="d-flex align-center justify-space-between">
            <div>
                <MudText Typo="Typo.h4" Class="admin-title">Destination Feasibility Checker</MudText>
                <MudText Typo="Typo.body2" Class="admin-subtitle">Analyze route viability and vehicle-to-cargo compatibility for optimized logistical planning.</MudText>
            </div>
            <MudButton StartIcon="@Icons.Material.Filled.Add" Variant="Variant.Filled" Color="Color.Primary" Class="admin-register-btn" OnClick="@(()=> OpenDialog(new DestinationFeasibilityCheckerModel()))" Disabled="@_busy">NEW ASSESSMENT</MudButton>
        </div>
    </div>

    <div class="admin-glass-card mb-6 pa-4">
        <div class="d-flex align-center gap-4">
            <div style="flex-grow: 1;">
                <MudTextField @bind-Value="searchDfc" Placeholder="Search by content name or specification..." Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" Variant="Variant.Outlined" Margin="Margin.Dense" Class="admin-input-group" Clearable="true" />
            </div>
        </div>
    </div>

    <div class="admin-glass-card pa-0 overflow-hidden">
        <MudTable Items="@collection" Elevation="0" Filter="new Func<DestinationFeasibilityCheckerModel, bool>(search)" Class="modern-admin-table" Hover="true">
            <HeaderContent>
                <MudTh><MudTableSortLabel SortBy="new Func<DestinationFeasibilityCheckerModel, object>(x=> x.Content.ContentName)" InitialDirection="SortDirection.Ascending"><span class="admin-header-text">CARGO CONTENT</span></MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<DestinationFeasibilityCheckerModel, object>(x=> x.TruckType.TruckType)" InitialDirection="SortDirection.Ascending"><span class="admin-header-text">VEHICLE CLASSIFICATION</span></MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<DestinationFeasibilityCheckerModel, object>(x=> x.UserInfo.UserID)" InitialDirection="SortDirection.Ascending"><span class="admin-header-text">AUDIT BY</span></MudTableSortLabel></MudTh>
                <MudTh Style="text-align: right;"><span class="admin-header-text">ACTIONS</span></MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Content"><span class="admin-td-primary fw-600">@context.Content.ContentName</span></MudTd>
                <MudTd DataLabel="Truck Type">
                    <div class="d-flex flex-column">
                        <span class="fw-500">@context.TruckType.TruckType</span>
                        <MudText Typo="Typo.caption" Alpha="0.6">@context.TruckType.BSType • @context.TruckType.wheels Wheels</MudText>
                    </div>
                </MudTd>
                <MudTd DataLabel="Created By">@context.UserInfo.UserID</MudTd>
                <MudTd DataLabel="Actions" Style="text-align: right;">
                    <div class="d-flex justify-end gap-1">
                        <MudTooltip Text="Inspect Details">
                            <MudIconButton OnClick="@(()=> OpenDialog(context))" Color="Color.Primary" Icon="@Icons.Material.Filled.GridView" Size="Size.Small" Variant="Variant.Text" />
                        </MudTooltip>
                        @if (HasPermissionDfcServiceAccess)
                        {
                            <MudTooltip Text="Generate Report">
                                <MudIconButton OnClick="@(()=> PrintInvoice(context.ID))" Color="Color.Info" Icon="@Icons.Material.Filled.Print" Size="Size.Small" Variant="Variant.Text" />
                            </MudTooltip>
                        }
                    </div>
                </MudTd>
            </RowTemplate>
            <PagerContent>
                <div class="pa-4">
                    <MudTablePager PageSizeOptions="new int[] { 10, 20, 50, 100 }" />
                </div>
            </PagerContent>
        </MudTable>
    </div>
</div>

    @code {

    private DestinationFeasibilityCheckerModel model = new DestinationFeasibilityCheckerModel();
    public List<DestinationFeasibilityCheckerModel> collection = new List<DestinationFeasibilityCheckerModel>();
    public bool HasPermissionDfcServiceView { get; set; } = false;
    public bool HasPermissionDfcServiceAccess { get; set; } = false;
    public int DocTypeID = 144;
    private string searchDfc= "";
    private bool _busy;
    private int? BranchID = null;

    protected override async Task OnInitializedAsync()
    {
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionDfcServiceView = await Irole.HasClaim(DocTypeID.ToString(), "View", ctc.Token);
        HasPermissionDfcServiceAccess = await Irole.HasClaim(DocTypeID.ToString(), "Access", ctc.Token);

        var authprov = await auth.GetAuthenticationStateAsync();
        BranchID = int.Parse(authprov.User.Claims.First(x => x.Type == "BranchID").Value);

        await GetAll();
    }

    private async Task GetAll()
    {
        collection = Iservice.Select(0, BranchID).ToList();
    }

    private bool search(DestinationFeasibilityCheckerModel model)
    {
        if (model.Content.ContentName != null && model.Content.ContentName.Contains(searchDfc, StringComparison.OrdinalIgnoreCase))
        {
            return true;
        }
        return false;
    }

    private async Task OpenDialog(DestinationFeasibilityCheckerModel model)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        _busy = true;

        if (HasPermissionDfcServiceView)
        {
            DialogParameters parms = new DialogParameters();
            parms.Add("model", model.Clone());
            var dialog = await DialogService.ShowAsync<DestinationFeasibilityCheckerDialog>("Destination Feasibility Checker", parms, new DialogOptions() { MaxWidth = MaxWidth.Large });
            var result = await dialog.Result;
            if (!result.Canceled)
            {
                var ReturnData = (DestinationFeasibilityCheckerModel)result.Data;
                await PrintInvoice(ReturnData.ID);
            }
        }
        else
        {
            bool? ResultModel = await DialogService.ShowMessageBoxAsync(
                "Permission denied!",
                "You don't have any permission to view.");
        }
        await GetAll();
        await Task.Delay(200);
        _busy = false;
    }

    public Dictionary<string, string> ReportParameters { get; set; } = new();

    private async Task PrintInvoice(int? ID)
    {
        ReportParameters.Clear();
        ReportParameters.Add("ID", ID.ToString());
        var parameters = new DialogParameters();
        parameters.Add("Parameters", ReportParameters); // Add the dictionary as a parameter
        parameters.Add("ReportName", "PrintDestinationFeasibilityChecker");

        DialogOptions maxWidth = new DialogOptions() { MaxWidth = MaxWidth.Medium, FullWidth = true };
        var result = await DialogService.ShowAsync<PrintDialog>("PRINT", parameters, maxWidth);
    }
}

