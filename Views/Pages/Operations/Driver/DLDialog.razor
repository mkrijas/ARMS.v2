@inject IRoleService<RoleModel> Irole
@inject AuthenticationStateProvider auth
@inject IDriverLicenceService Iservice
@inject MudBlazor.ISnackbar snackbar
@inject IDialogService DialogService

<MudDialog Class="admin-dialog-glass">
    <TitleContent>
        <div class="header-section mb-2 pt-4 px-4">
            <div class="d-flex align-center justify-space-between">
                <div class="d-flex align-center">
                    <div class="icon-badge primary-badge mr-4">
                        <div class="admin-header-icon-badge mb-3">
                            <MudIcon Icon="@Icons.Material.Filled.CreditCard" Color="Color.Secondary" Style="font-size: 3rem;" />
                        </div>
                    </div>
                    <div>
                        <MudText Typo="Typo.h5" Class="admin-title"><b>Driving Licence Dossier</b></MudText>
                        <MudText Typo="Typo.body2" Class="admin-subtitle">Official authentication and endorsement records for vehicle operation.</MudText>
                    </div>
                </div>
            </div>
            <div class="title-accent mt-4"></div>
        </div>
    </TitleContent>
    <DialogContent>
        <MudContainer Class="admin-dialog-container">
            <div class="dialog-content-wrapper pa-4">
                <EditForm id="dlSubmit" Model="@model" OnValidSubmit="OnValidSubmit">
                    <div class="admin-glass-card pa-6">
                        <DataAnnotationsValidator />
                        <MudValidationSummary />
                        <MudGrid Spacing="4">
                            <MudItem xs="12" md="6">
                                <MudSelect @bind-Value="@model.LicenceType" Label="Licence Classification" Variant="Variant.Outlined" Margin="Margin.Normal" For="@(() => model.LicenceType)" AdornmentColor="Color.Primary" Class="modern-input">
                                    <MudSelectItem Value="@("Heavy")">Heavy Transport (HTV)</MudSelectItem>
                                    <MudSelectItem Value="@("Light")">Light Vehicle (LMV)</MudSelectItem>
                                    <MudSelectItem Value="@("TwoWheeler")">Two-Wheeler (MCWG)</MudSelectItem>
                                </MudSelect>
                            </MudItem>
                            <MudItem xs="12" md="6">
                                <MudTextField @bind-Value="@model.LicenceNo" Label="Official Licence Identification" Variant="Variant.Outlined" Margin="Margin.Normal" For="@(() => model.LicenceNo)" MaxLength="16" HelperText="Standard Format: KL1120230001111" OnBlur="ValidateLicenceNo" Class="modern-input" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Fingerprint"></MudTextField>
                            </MudItem>
                            <MudItem xs="12" md="6">
                                <MudDatePicker PickerVariant="PickerVariant.Dialog" @bind-Date="@model.DLExpiryDate" Label="Authorization Expiry" Variant="Variant.Outlined" Margin="Margin.Normal" For="@(() => model.DLExpiryDate)" Editable="true" Class="modern-input"></MudDatePicker>
                            </MudItem>
                            <MudItem xs="12" md="6">
                                <MudTextField @bind-Value="@model.BadgeNo" Label="Special Endorsement (Badge) No" Variant="Variant.Outlined" Margin="Margin.Normal" For="@(() => model.BadgeNo)" Class="modern-input" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Verified"></MudTextField>
                            </MudItem>
                            <MudItem xs="12" md="6">
                                <MudDatePicker PickerVariant="PickerVariant.Dialog" @bind-Date="@model.BadgeExpiryDate" Label="Badge Validity Expiry" Variant="Variant.Outlined" Margin="Margin.Normal" For="@(() => model.BadgeExpiryDate)" Editable="true" Class="modern-input"></MudDatePicker>
                            </MudItem>
                        </MudGrid>
                    </div>
                </EditForm>
            </div>
        </MudContainer>
    </DialogContent>
    <DialogActions>
        <div class="d-flex w-100 flex-wrap pa-4 gap-3 align-center">
            <MudSpacer />
            <MudButton @onclick="Cancel" Variant="Variant.Outlined" Color="Color.Default" Style="border-radius: 12px; font-weight: 700; text-transform: none; border-color: rgba(0,0,0,0.15);">Discard</MudButton>
            <MudButton Disabled="@_busy" form="dlSubmit" Variant="Variant.Filled" Color="Color.Success" ButtonType="ButtonType.Submit" Style="background: var(--mud-palette-success); color: white; font-weight: 800; border-radius: 12px; text-transform: none; white-space: nowrap; padding: 8px 32px;" StartIcon="@Icons.Material.Filled.VerifiedUser">Authorize Credentials</MudButton>
        </div>
    </DialogActions>
</MudDialog>

@code {

    [CascadingParameter] IMudDialogInstance MudDialog { get; set; }
    [Parameter]
    public DriverLicenceModel model { get; set; }
    public EditContext Result { get; set; }
    private bool _busy;

    public bool HasPermissionDriverLicenceServiceEdit { get; set; } = false;
    public int DocTypeID = 52;
    private string licenceNoError;

    // Lifecycle method called when the component is initialized
    protected override async Task OnInitializedAsync()
    {
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionDriverLicenceServiceEdit = await Irole.HasClaim(DocTypeID.ToString(), "Edit", ctc.Token);

        if (model == null)
        {
            model = new();
        }
    }

    // Method to cancel the dialog
    private void Cancel()
    {
        MudDialog.Cancel();
    }

    // Method to validate the license number
    private void ValidateLicenceNo()
    {
        if (!string.IsNullOrEmpty(model.LicenceNo) && model.LicenceNo.Length < 15)
        {
            licenceNoError = "Licence number must be at least 15 characters long.";
        }
        else
        {
            licenceNoError = null;
        }
    }

    // Method called when the form is submitted and valid
    private async Task OnValidSubmit(EditContext context)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is being submitted!", Severity.Warning);
            return;
        }
        if (HasPermissionDriverLicenceServiceEdit)
        {
            _busy = true;
            var authprov = await auth.GetAuthenticationStateAsync();
            var user = authprov.User;
            model.BranchID = int.Parse(user.Claims.First(x => x.Type == "BranchID").Value);
            model.UserInfo.UserID = user.Identity.Name;
            try
            {
                // Update the model using the service
                model = Iservice.Update(model);
                snackbar.Add("Saved Successfully", Severity.Success);
                MudDialog.Close(DialogResult.Ok(model));
            }
            catch (Exception ex)
            {
                snackbar.Add(ex.Message, Severity.Warning);
            }
            finally
            {
                await Task.Delay(200);
                _busy = false;
                StateHasChanged();
            }
        }
        else
        {
            await DialogService.ShowMessageBoxAsync(
                "Permission denied!",
                "You don't have any permission to Add or Edit DriverLicence.");
        }
    }
}
