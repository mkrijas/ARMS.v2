@using ArmsModels.BaseModels
@using Microsoft.AspNetCore.Components.Forms
@using MudBlazor
@inject IDriverLicenceService Iservice

@inject MudBlazor.ISnackbar snackbar
@attribute [Authorize]
@inject AuthenticationStateProvider auth

@using System.Threading;
@inject IRoleService<RoleModel> Irole
@inject IDialogService DialogService

<MudDialog>
    <TitleContent>
        <br />
        <MudText Typo="Typo.h6">
            <MudText Typo="Typo.h6">Driving Licence</MudText>
        </MudText>
    </TitleContent>
    <DialogContent>

        <MudContainer Style="max-height: 600px; overflow-y: scroll; margin-left:20px">
            <EditForm id="dlSubmit" Model="@model" OnValidSubmit="OnValidSubmit">
                <DataAnnotationsValidator />
                <ValidationSummary />
                <MudGrid>
                    <MudItem xs="12" md="12" xl="12">
                    </MudItem>
                    <MudItem xs="12" md="6" xl="6">
                        <MudSelect @bind-Value="@model.LicenceType" Label="Type" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.LicenceType)" OffsetY="true" AdornmentColor="Color.Secondary">
                            <MudSelectItem Value="@("Heavy")">Heavy</MudSelectItem>
                            <MudSelectItem Value="@("Light")">Light</MudSelectItem>
                            <MudSelectItem Value="@("TwoWheeler")">TwoWheeler</MudSelectItem>
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12" md="6" xl="6">
                        <MudTextField @bind-Value="@model.LicenceNo" Label="DL No" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.LicenceNo)" Mask="@(new PatternMask("aa0000000000000"))"></MudTextField>
                    </MudItem>
                    <MudItem xs="12" md="6" xl="6">
                        <MudDatePicker PickerVariant="PickerVariant.Dialog" @bind-Date="@model.DLExpiryDate" Label="DL Expiry Date" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.DLExpiryDate)" Editable="true"></MudDatePicker>
                    </MudItem>
                    <MudItem xs="12" md="6" xl="6">
                        <MudTextField @bind-Value="@model.BadgeNo" Label="Badge No" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.BadgeNo)"></MudTextField>
                    </MudItem>
                    <MudItem xs="12" md="6" xl="6">
                        <MudDatePicker PickerVariant="PickerVariant.Dialog" @bind-Date="@model.BadgeExpiryDate" Label="Badge Expiry Date" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.BadgeExpiryDate)" Editable="true"></MudDatePicker>
                    </MudItem>
                    <MudItem xs="12" md="12" xl="12">
                    </MudItem>
                </MudGrid>
            </EditForm>
        </MudContainer>
    </DialogContent>
    <DialogActions>
        <MudButton form="dlSubmit" Variant="Variant.Filled" Color="Color.Primary" ButtonType="ButtonType.Submit" Class="px-12">Submit</MudButton>
    </DialogActions>
</MudDialog>
@code {

    [CascadingParameter] MudDialogInstance MudDialog { get; set; }

    [Parameter]
    public DriverLicenceModel model { get; set; }

    public EditContext Result { get; set; }

    public bool HasPermissionDriverLicenceServiceEdit { get; set; } = false;
    public int DocTypeID = 52;

    protected override async Task OnInitializedAsync()
    {
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionDriverLicenceServiceEdit = await Irole.HasClaim(DocTypeID.ToString(), "Edit", ctc.Token);

        if (model == null)
        {
            model = new();
        }
    }


    private async void OnValidSubmit(EditContext context)
    {
        if (HasPermissionDriverLicenceServiceEdit)
        {
            var authprov = await auth.GetAuthenticationStateAsync();
            var user = authprov.User;
            model.BranchID = int.Parse(user.Claims.First(x => x.Type == "BranchID").Value);
            model.UserInfo.UserID = user.Identity.Name;

            try
            {
                model = Iservice.Update(model);

                snackbar.Add("Saved Successfully", Severity.Success);

                model = new();
                MudDialog.Close(DialogResult.Ok(true));
            }
            catch (Exception ex)
            {
                snackbar.Add(ex.Message, Severity.Warning);
            }
        }
        else
        {
            bool? ResultModel = await DialogService.ShowMessageBox(
               "Permission denied!",
               "You dont have any permission to Add or Edit DriverLicence.");
        }
    }
}