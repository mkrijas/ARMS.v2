@page "/dl/{DriverID:int}"
@using System.Threading;
@attribute [Authorize]
@inject AuthenticationStateProvider auth
@inject IDriverLicenceService Iservice
@inject IDriverService Idriver
@inject IDialogService DialogService
@inject IRoleService<RoleModel> Irole
@inject MudBlazor.ISnackbar snackbar


<MudBreadcrumbs Items="_crumbs"></MudBreadcrumbs>
    @code {
    private List<BreadcrumbItem> _crumbs = new List<BreadcrumbItem>
    {
    new BreadcrumbItem("Operation", href: null,disabled:true),
    new BreadcrumbItem("Manage Drivers", href: "/Driver"),
    new BreadcrumbItem("Driving Licence", href: null , disabled:true),
    };
    }
<MudPaper Class="p-2 my-5 d-flex justify-center">   
    <MudText Typo="Typo.h5">@Driver.DriverName</MudText>
    <MudTooltip Text="New Licence">
        <MudIconButton Disabled="@_busy" Icon="@Icons.Material.Filled.Add" Title="Add" @onclick="@(()=> OpenDialogAddNew(new DriverLicenceModel()))" Color="Color.Dark" Size="Size.Small"></MudIconButton>
    </MudTooltip>
</MudPaper>
<MudGrid Spacing="2">
    @foreach (var item in collection)
    {
        <MudItem xs="4">
            <MudCard>
                <iframe class="mt-1 mr-1 ml-1" src="@item.DLImage" height="500" alt="@item.DLImage" />
                <MudCardContent>
                    <MudText Typo="Typo.h5">@item.LicenceNo</MudText>
                    <MudText Typo="Typo.body2">Type:  @item.LicenceType</MudText>
                    <MudText Typo="Typo.body2">Expire On:  @item.DLExpiryDate?.ToShortDateString())</MudText>
                    <MudText Typo="Typo.body2">Badge No:  @item.BadgeNo - @item.BadgeExpiryDate?.ToShortDateString()</MudText>
                </MudCardContent>
                <MudCardActions>
                    <MudButton Variant="Variant.Text" Color="Color.Primary" OnClick="(()=>OpenDialogAddNew(item))">Edit</MudButton>
                    <MudButton Variant="Variant.Filled" Color="Color.Error" OnClick="(()=> Delete(item))">Delete</MudButton>
                    <MyFileUpload FileName="@Guid.NewGuid().ToString()" FolderName="DrivingLicence" Label="Upload File" FilePathChanged="((e)=>FileUploaded(e,item.LicenceID))"></MyFileUpload>
                </MudCardActions>
            </MudCard>
        </MudItem>
    }
</MudGrid>

@code {

    [Parameter] public int? DriverID { get; set; }
    private DriverModel Driver { get; set; }
    private DriverLicenceModel model = new();
    private List<DriverLicenceModel> collection = new();
    private IBrowserFile DLImage;
    private bool _busy;
    public bool HasPermissionDriverLicenceServiceEdit { get; set; } = false;
    public bool HasPermissionDriverLicenceServiceDelete { get; set; } = false;
    public int DocTypeID = 52;

    protected override async Task OnInitializedAsync()
    {
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionDriverLicenceServiceEdit = await Irole.HasClaim(DocTypeID.ToString(), "Edit", ctc.Token);
        HasPermissionDriverLicenceServiceDelete = await Irole.HasClaim(DocTypeID.ToString(), "Delete", ctc.Token);
        Driver = Idriver.SelectByID(DriverID);

        GetAll();
    }

    private void GetAll()
    {
        collection = Iservice.Select(DriverID).ToList();
    }

    private async Task OpenDialogAddNew(DriverLicenceModel Drivermodel)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        _busy = true;
        if (HasPermissionDriverLicenceServiceEdit)
        {
            var parameters = new DialogParameters();
            Drivermodel.DriverID = DriverID;
            parameters.Add("model", Drivermodel.Clone());
            DialogOptions maxWidth = new DialogOptions() { MaxWidth = MaxWidth.Medium, FullWidth = true };
            var dialog = DialogService.Show<DLDialog>("model", parameters, maxWidth);
            var result = await dialog.Result;

            // you can check if the modal was cancelled
            var isCancelled = result.Cancelled;
            if (!isCancelled)
            {
                GetAll();
            }
        }
        else
        {
            bool? ResultModel = await DialogService.ShowMessageBox(
                "Permission denied!",
                "You dont have any permission to Add or Edit DriverLicence.");
        }
        await Task.Delay(200);
        _busy = false;
    }

    private async Task Delete(DriverLicenceModel model)
    {
        if (HasPermissionDriverLicenceServiceDelete)
        {
            bool? result = await DialogService.ShowMessageBox(
                "Warning !",
                "Are you sure, you want to delete LicenceNo : " + model.LicenceNo + " ?");
            if (result == true)
            {
                var authprov = await auth.GetAuthenticationStateAsync();
                var user = authprov.User;
                Iservice.Delete(model.LicenceID, user.Identity.Name);
                snackbar.Add("Deleted Successfully", Severity.Success);
            }
            GetAll();
        }
        else
        {
            bool? result = await DialogService.ShowMessageBox(
                "Permission denied!",
                "You dont have any permission to Delete DriverLicence.");
        }
    }

    private async Task FileUploaded(string filePath, int? ID)
    {
        if (HasPermissionDriverLicenceServiceEdit)
        {
            int e = Iservice.SaveFilePath(filePath, ID);
            GetAll();
        }
        else
        {
            bool? ResultModel = await DialogService.ShowMessageBox(
                "Permission denied!",
                "You dont have any permission to Add or Edit DriverLicence.");
        }
    }
}