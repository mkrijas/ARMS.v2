@code {


    [Parameter] public int? DriverID { get; set; }

    private DriverModel Driver { get; set; }

    private DriverLicenceModel model = new();

    private List<DriverLicenceModel> collection = new();

    private IBrowserFile DLImage;

    protected override async Task OnInitializedAsync()
    {
        Driver = Idriver.SelectByID(DriverID);
        GetAll();
    }

    private void GetAll()
    {
        collection = Iservice.Select(DriverID).ToList();
    }

    private async Task OpenDialogAddNew(DriverLicenceModel Drivermodel)
    {
        var parameters = new DialogParameters();
        Drivermodel.DriverID = DriverID;

        parameters.Add("model", Drivermodel);
        DialogOptions maxWidth = new DialogOptions() { MaxWidth = MaxWidth.Medium, FullWidth = true };
        var dialog = DialogService.Show<DLDialog>("model", parameters, maxWidth);


        var result = await dialog.Result;

        // you can check if the modal was cancelled
        var isCancelled = result.Cancelled;
        if (!isCancelled)
        {
            GetAll();
        }
    }
    private async void OnValidSubmit(EditContext context)
    {
        //try
        //{
        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;
        model.BranchID = int.Parse(user.Claims.First(x => x.Type == "BranchID").Value);
        model.UserInfo.UserID = user.Identity.Name;
        model.DriverID = Driver.DriverID;

        try
        {
            model = Iservice.Update(model);

            snackbar.Add("Saved Successfully", Severity.Success);

            GetAll();
            model = new();
        }
        catch (Exception ex)
        {
            snackbar.Add(ex.Message, Severity.Warning);
        }
    }



    private void Edit(int? id)
    {
        model = collection.First(x => x.LicenceID == id);
    }


    private void Delete(int? id)
    {
        Iservice.Delete(id, "Rijas");
        snackbar.Add("Deleted Successfully", Severity.Success);
        GetAll();
    }


    private void FileUploaded(string filePath, int? ID)
    {
        int e = Iservice.SaveFilePath(filePath, ID);
        GetAll();
    }

}

