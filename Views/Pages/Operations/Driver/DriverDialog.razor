@using System.Threading;
@attribute [Authorize]
@inject AuthenticationStateProvider auth
@inject IPartyService Iparty
@inject IDriverService Iservice
@inject IBranchService Ibranchservice
@inject IAddressService Iaddress
@inject IBankAccountService IbankAccount
@inject IContactService Icontact
@inject IDialogService DialogService
@inject MudBlazor.ISnackbar snackbar
@inject IRoleService<RoleModel> Irole

<MudDialog Class="admin-dialog-glass">
    <TitleContent>
        <div class="header-section mb-2 pt-4 px-4">
            <div class="d-flex align-center justify-space-between">
                <div class="d-flex align-center">
                    <div class="icon-badge primary-badge mr-4">
                        <div class="admin-header-icon-badge mb-3">
                            <MudIcon Icon="@Icons.Material.Filled.Badge" Color="Color.Secondary" Style="font-size: 3rem;" />
                        </div>
                    </div>
                    <div>
                        <MudText Typo="Typo.h5" Class="admin-title"><b>Driver Identity Management</b></MudText>
                        <MudText Typo="Typo.body2" Class="admin-subtitle">
                            Profile configuration and authentication details for personnel.
                        </MudText>
                    </div>
                </div>
            </div>
            <div class="title-accent mt-4"></div>
        </div>
    </TitleContent>
    <DialogContent>
        <MudContainer Class="admin-dialog-container">
            <div class="dialog-content-wrapper">
                <EditForm id="formDriver" Model="@model" OnValidSubmit="OnValidSubmit" OnInvalidSubmit="OnInvalidSubmit">
                  <ObjectGraphDataAnnotationsValidator />
                  <MudValidationSummary />
                  <MudTabs Elevation="0" Rounded="true" ApplyEffectsToInnerViews="true" Class="premium-tabs" PanelClass="pa-0">
                    <MudTabPanel Text="Profile Dossier" Icon="@Icons.Material.Filled.FactCheck">
                        <div class="pa-6">
                                <div class="admin-glass-card pa-6">
                                    <MudValidationSummary />
                                    <MudGrid Spacing="4">
                                        <MudItem xs="12" md="4">
                                            <div class="profile-image-container pa-2 rounded-xl" style="background: rgba(54, 117, 136, 0.05); border: 2px dashed rgba(54, 117, 136, 0.3); min-height: 200px; display: flex; align-items: center; justify-content: center;">
                                                <MudImage Fluid ObjectFit="ObjectFit.Cover" 
                                                         Src="@(string.IsNullOrEmpty(model.DriverImage) ? "/ArmsStaticFiles/Drivers/defaultImage.png" : model.DriverImage)" 
                                                         Alt="PERSONNEL PHOTO" Class="rounded-lg shadow-sm" Style="max-height: 180px;" />
                                            </div>
                                        </MudItem>
                                        <MudItem xs="12" md="8">
                                            <MudGrid Spacing="2">
                                                <MudItem xs="12" md="6">
                                                    <MudTextField @bind-Value="model.DriverName" Label="Full Legal Name" 
                                                                 Variant="Variant.Outlined" Margin="Margin.Normal" 
                                                                 Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Person"
                                                                 Class="modern-input" For="@(() => model.DriverName)"></MudTextField>
                                                </MudItem>
                                                <MudItem xs="12" md="6">
                                                    <MudDatePicker Label="Birth Registry Date" Variant="Variant.Outlined" 
                                                                  DisableToolbar="true" Margin="Margin.Normal" Editable="true" 
                                                                  @bind-Date="model.DateOfBirth" DateFormat="dd/MM/yyyy" 
                                                                  Class="modern-input" For="@(() => model.DateOfBirth)" />
                                                </MudItem>
                                                <MudItem xs="12" md="6">
                                                    <MudNumericField HideSpinButtons MaxLength="12" @bind-Value="model.AdhaarNo" 
                                                                   Label="National ID (Aadhaar)" Variant="Variant.Outlined" 
                                                                   Margin="Margin.Normal" Adornment="Adornment.Start" 
                                                                   AdornmentIcon="@Icons.Material.Filled.Fingerprint"
                                                                   Class="modern-input" For="@(() => model.AdhaarNo)"></MudNumericField>
                                                 </MudItem>
                                                 <MudItem xs="12" md="6">
                                                     <PartySelector @bind-Value="model.DriverAgent" 
                                                                   label="Contracting Authority" 
                                                                   NatureOfBusiness="Supplier" 
                                                                   BranchID="@BranchID" Class="modern-input"></PartySelector>
                                                 </MudItem>
                                            </MudGrid>
                                        </MudItem>
                                        <MudItem xs="12" md="6">
                                             <MudTextField Label="Strategic Reference" @bind-Value="model.AdditionalInfo" 
                                                          Variant="Variant.Outlined" Margin="Margin.Normal" 
                                                          Class="modern-input" For="@(() => model.AdditionalInfo)"></MudTextField>
                                         </MudItem>
                                         <MudItem xs="12" md="6">
                                             <MudNumericField HideSpinButtons MaxLength="10" Label="Primary Mobile" 
                                                            @bind-Value="model.Mobile" Variant="Variant.Outlined" 
                                                            Margin="Margin.Normal" Adornment="Adornment.Start" 
                                                            AdornmentIcon="@Icons.Material.Filled.PhoneAndroid"
                                                            Class="modern-input" For="@(() => model.Mobile)"></MudNumericField>
                                         </MudItem>
                                         <MudItem xs="12" md="6">
                                             <MudTextField Label="Digital Mailbox" @bind-Value="model.Email" 
                                                          InputMode="InputMode.email" Variant="Variant.Outlined" 
                                                          Margin="Margin.Normal" InputType="InputType.Email" 
                                                          Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.AlternateEmail"
                                                          Class="modern-input" For="@(() => model.Email)"></MudTextField>
                                         </MudItem>
                                         <MudItem xs="12" md="6" Class="d-flex align-center justify-end">
                                             @if (!string.IsNullOrEmpty(model.AdhaarImage))
                                             {
                                                 <a href="@model.AdhaarImage" download="Adhaar" style="text-decoration: none;">
                                                     <div class="d-flex align-center pa-2 px-6 rounded-pill" style="background: rgba(54, 117, 136, 0.08); border: 1px solid rgba(54, 117, 136, 0.5);">
                                                         <MudIcon Icon="@Icons.Material.Filled.DocumentScanner" Color="Color.Primary" Class="mr-2" />
                                                         <MudText Typo="Typo.body2" Color="Color.Primary"><b>Access ID Credentials</b></MudText>
                                                     </div>
                                                 </a>
                                             }
                                         </MudItem>
                                    </MudGrid>
                                </div>
                        </div>
                    </MudTabPanel>
                    <MudTabPanel Text="Home Address" Icon="@Icons.Material.Filled.Home">
                        <div class="pa-6">
                            <div class="admin-glass-card pa-6">
                                <AddressView Address="model.Address" Label="@(null)"></AddressView>
                            </div>
                        </div>
                    </MudTabPanel>
                    <MudTabPanel Text="Banking & Payroll" Icon="@Icons.Material.Filled.AccountBalance">
                        <div class="pa-6">
                            <div class="admin-glass-card pa-6">
                                <BankDetailsView BankAccount="model.BankAccount"></BankDetailsView>
                            </div>
                        </div>
                    </MudTabPanel>
                    @foreach (var item in model.Contacts.Select((value, i) => new { i, value }))
                    {
                        <MudTabPanel ID="item.i" Text="@("Contact "+(item.i+1))" Icon="@Icons.Material.Filled.ContactPhone">
                            <div class="pa-6">
                                <div class="admin-glass-card pa-6">
                                    <ContactView Index="null" Model="item.value"></ContactView>
                                    <div class="d-flex justify-end mt-4">
                                        @if (item.value.ContactID == null)
                                        {
                                            <MudButton StartIcon="@Icons.Material.Filled.Delete" Color="Color.Error" 
                                                       Variant="Variant.Text" OnClick="() => RemoveContact(item.i)">Remove Entry</MudButton>
                                        }
                                    </div>
                                </div>
                            </div>
                        </MudTabPanel>
                    }
                </MudTabs>
              </EditForm>
            </div>
        </MudContainer>
    </DialogContent>
    <DialogActions>
        <div class="d-flex flex-wrap pa-4 gap-3 w-100 align-center">
            <div class="d-flex gap-2">
                <MyFileUpload FolderName="Drivers/Adhaar" FileName="@Guid.NewGuid().ToString()" Label="Upload ID" @bind-FilePath="model.AdhaarImage"></MyFileUpload>
                <MyFileUpload FolderName="Drivers/Photos" FileName="@Guid.NewGuid().ToString()" Label="Upload Photo" @bind-FilePath="model.DriverImage"></MyFileUpload>
            </div>
            <MudSpacer />
            <MudButton Variant="Variant.Outlined" Color="Color.Primary" OnClick="AddContact" Class="rounded-pill px-6" StartIcon="@Icons.Material.Filled.Add">Add Contact</MudButton>
            <MudButton OnClick="Cancel" Variant="Variant.Text" Class="px-6">Discard</MudButton>
            <MudButton Disabled="@_busy" form="formDriver" Variant="Variant.Filled" 
                       Color="Color.Primary" ButtonType="ButtonType.Submit" 
                       Class="action-btn-primary px-10 rounded-pill"
                       Style="background: var(--mud-palette-primary) !important; color: white !important;">
                Synchronize Records
            </MudButton>
        </div>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialogInstance { get; set; }
    [Parameter]
    public DriverModel model { get; set; }
    private List<PartyModel> parties = new List<PartyModel>();
    DriverModel existingDriver;

    public bool HasPermissionDriverServiceEdit { get; set; } = false;
    public int DriverServiceDocTypeID = 50;
    public bool HasPermissionContactServiceServiceEdit { get; set; } = false;
    public int ContactServiceDocTypeID = 71;
    private bool _busy;
    int BranchID;
    string UserID;

    // Lifecycle method called when the component is initialized
    protected override async Task OnInitializedAsync()
    {
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionDriverServiceEdit = await Irole.HasClaim(DriverServiceDocTypeID.ToString(), "Edit", ctc.Token);
        HasPermissionContactServiceServiceEdit = await Irole.HasClaim(ContactServiceDocTypeID.ToString(), "Edit", ctc.Token);

        if (model.DriverAgentID != null && model.DriverAgentID != 0)
        {
            model.DriverAgent = Iparty.SelectByID(model.DriverAgentID); // Load driver agent
        }
        if (model.AddressID != null && model.AddressID != 0)
        {
            model.Address = Iaddress.SelectByID(model.AddressID); // Load address
        }
        if (model.BankAccountID != null && model.BankAccountID != 0)
        {
            model.BankAccount = IbankAccount.SelectByID(model.BankAccountID ?? 0); // Load bank account
        } 
        else
        {
            model.BankAccount = new();
        }

        // Load contacts associated with the driver
        model.Contacts = Icontact.Select(model.DriverID, "Driver").ToList();

        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;
        BranchID = int.Parse(user.Claims.FirstOrDefault(x => x.Type == "BranchID")?.Value);
        UserID = user.Identity.Name;
    }

    // Method to cancel the dialog
    private void Cancel()
    {
        MudDialogInstance.Cancel();
    }

    // Method to add a new contact to the driver's contact list
    private void AddContact()
    {
        model.Contacts.Add(new ContactModel()
            {
                RefTable = "Driver",
            });
    }

    // Method to remove a contact from the driver's contact list
    private void RemoveContact(int index)
    {
        model.Contacts.RemoveAt(index);
    }

    // Method called when the form is submitted and valid
    private async Task OnValidSubmit(EditContext context)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is being submitted!", Severity.Warning);
            return;
        }
        if (HasPermissionDriverServiceEdit)
        {
            // Check for existing driver with the same Aadhaar number
            existingDriver = (Iservice.GetDriverByAdhaarNo(model.AdhaarNo)).FirstOrDefault();

            if (existingDriver != null && existingDriver.DriverID != model.DriverID)
            {
                // Display the existing driver information
                string branchName = Ibranchservice.GetBranchName(existingDriver.HomeBranchID);
                string workPeriod = Iservice.GetWorkPeriod(existingDriver.DriverID);
                bool isBlackListed = existingDriver.UserInfo.RecordStatus == 9;
                snackbar.Add("A driver with the same Aadhaar number already exists.", Severity.Warning);

                string blacklistMessage = isBlackListed
                    ? "<br /><span style='color:red;'><b>This driver is blacklisted.</b></span>"
                    : "";

                bool? result = await DialogService.ShowMessageBoxAsync(
                    "Warning",
                    (MarkupString)$"A driver with the same Aadhaar number already exists <br /> <b>Name:</b> {existingDriver.DriverName} <br /> <b>Branch:</b> {branchName} <br /> <b>Work Period:</b> {workPeriod}{blacklistMessage}",
                    yesText: "OK");
                return;
            }

            _busy = true;
            model.DriverAgentID = model.DriverAgent.PartyID;
            model.Address.AddresseeName = model.DriverName = FontStyle.ConvertToCamelCase(model.DriverName);
            
            model.HomeBranchID = BranchID;
            model.UserInfo.UserID = UserID ;


            try
            {
                var contacts = model.Contacts;
                model = Iservice.Update(model); // Update the driver information
                snackbar.Add("Saved Successfully", Severity.Success);
                foreach (var item in contacts)
                {
                    item.RefKey = model.DriverID;
                    item.UserInfo = model.UserInfo;
                    Icontact.Update(item); // Update the contact in the service
                }
                MudDialogInstance.Close(DialogResult.Ok(model));
            }
            catch (Exception ex)
            {
                snackbar.Add(ex.Message, Severity.Error);
            }
            await Task.Delay(200);
            _busy = false;
        }
        else
        {
            bool? ResultModel = await DialogService.ShowMessageBoxAsync(
                "Permission denied!",
                "You don't have any permission to Add or Edit Driver.");
        }
    }

    private void OnInvalidSubmit(EditContext context)
    {
        var messages = context.GetValidationMessages();
        snackbar.Add($"Validation Failed: {string.Join(", ", messages.Take(3))}{(messages.Count() > 3 ? "..." : "")}", Severity.Warning);
    }
}

