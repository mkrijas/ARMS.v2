@inject AuthenticationStateProvider auth
@inject IDriverFaultService Iservice
@inject IDriverService Idriverservice
@inject ITruckService Itruckservice
@inject ITripService Itripservice
@inject IBranchService Ibranchservice
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<MudDialog>
    <TitleContent>
        @if (model.FaultID == null || model.FaultID == 0)
        {
            <MudText Typo="Typo.h6">
                <MudIcon Icon="@Icons.Material.Filled.Edit" Class="mr-3" /> Driver Fault.
            </MudText>
        }
        else
        {
            <MudText Typo="Typo.h6">
                <MudIcon Icon="@Icons.Material.Filled.Edit" Class="mr-3" /> Edit Driver Fault.
            </MudText>
        }
    </TitleContent>
    <DialogContent>

        <MudContainer Style="max-height: 400px; overflow-y: scroll; margin-left:20px">
            <EditForm id="formDriver" Model="@model" OnValidSubmit="Submit">
                <ObjectGraphDataAnnotationsValidator />
                <ValidationSummary />
                <MudGrid>
                    <MudItem xs="12" md="12">
                        <MudTextField Value="model.Driver.DriverName" Label="Name" Variant="Variant.Outlined" Margin="Margin.Dense"></MudTextField>
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudSelect Label="Severity" Variant="Variant.Outlined" Margin="Margin.Dense" @bind-Value="model.Severity" AnchorOrigin="Origin.TopCenter" TransformOrigin="Origin.TopCenter" AdornmentColor="Color.Secondary" Required>
                            <MudSelectItem T="byte?" Value="1">Warning</MudSelectItem>
                            <MudSelectItem T="byte?" Value="9">Blacklisted</MudSelectItem>

                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudDatePicker Label="Date" Variant="Variant.Outlined" Margin="Margin.Dense" DisableToolbar="true" Editable="true" @bind-Date="model.FaultDate" DateFormat="dd/MM/yyyy" />
                    </MudItem>
                    <MudItem xs="12" md="12">
                        <MudTextField @bind-Value="model.Detail" Label="Details" Variant="Variant.Outlined" Lines="3" Margin="Margin.Dense" Required></MudTextField>
                    </MudItem>
                </MudGrid>

            </EditForm>
        </MudContainer>

    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Submit" Class="px-12">Submit</MudButton>
    </DialogActions>
</MudDialog>

@code {

    [CascadingParameter] MudDialogInstance MudDialog { get; set; }

    [Parameter]
    public DriverFaultModel model { get; set; } = new();
    [Parameter]
    public int? DriverID { get; set; }


    protected override async Task OnInitializedAsync()
    {
        var authprov = await auth.GetAuthenticationStateAsync();
        var User = authprov.User;
        if (model.BranchID == null)
        {
            model.BranchID = new();
            model.BranchID = int.Parse(User.Claims.First(x => x.Type == "BranchID").Value);
        }
    }


    void Cancel()
    {
        MudDialog.Cancel();
    }

    public async Task Submit()
    {
        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;
        var brancIDString = authprov.User.Claims.First(x => x.Type == "BranchID").Value;

        if (model.Driver == null || model.Driver.DriverID == 0)
        {
            bool? result = await DialogService.ShowMessageBox(
                "Warning",
                "Please, Select Driver.",
                yesText: "OK");
            return;
        }

        // Check if the selected driver is assigned to a truck
        int? assignedTruckID = Idriverservice.GetAssignedTruck(model.Driver?.DriverID);
        if (assignedTruckID != null)
        {
            // Check if the assigned truck is on a trip
            long? currentTripID = Itruckservice.GetCurrentTrip(assignedTruckID);
            if (currentTripID != null)
            {
                // Check if the current trip is completed
                bool isTripClosed = Itripservice.IsClosed(currentTripID);
                if (!isTripClosed)
                {
                    bool? result = await DialogService.ShowMessageBox(
                       "Warning",
                       "The Driver is currently on a trip.",
                       yesText: "OK");
                    return;
                    // Trip is completed, remove the driver from the truck
                }

            }
            // Assigned truck is not on a trip, remove the driver from the truck
            try
            {
                TruckModel truck = Itruckservice.SelectByID(assignedTruckID);
                Itruckservice.UpdateDriver(assignedTruckID, model.Driver.DriverID, false, user.Identity.Name);
                Snackbar.Add($"Driver removed from the truck {truck.RegNo}.", Severity.Warning);
            }
            catch (Exception ex)
            {
                Snackbar.Add(ex.Message, Severity.Error);
                return;
            }

        }

        try
        {
            model.BranchID = int.Parse(brancIDString);
            model.UserInfo.UserID = user.Identity.Name;
            Iservice.Update(model);
            Snackbar.Add("Success", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }

        MudDialog.Close(model);
    }


    private async Task DriverSelected(DriverModel obj)
    {
        model.Driver = obj;
    }

}

