@inject AuthenticationStateProvider auth
@inject IDriverFaultService Iservice
@inject IDriverService Idriverservice
@inject ITruckService Itruckservice
@inject ITripService Itripservice
@inject IBranchService Ibranchservice
@inject IDialogService DialogService
@inject ISnackbar Snackbar

@using System.Threading;
@inject IRoleService<RoleModel> Irole

<MudDialog>
    <TitleContent>
        @if (model.FaultID == null || model.FaultID == 0)
        {
            <MudText Typo="Typo.h6">
                <MudIcon Icon="@Icons.Material.Filled.Edit" Class="mr-3" /> Driver Fault.
            </MudText>
        }
        else
        {
            <MudText Typo="Typo.h6">
                <MudIcon Icon="@Icons.Material.Filled.Edit" Class="mr-3" /> Edit Driver Fault.
            </MudText>
        }
    </TitleContent>
    <DialogContent>

        <MudContainer Style="max-height: 400px; overflow-y: scroll; margin-left:20px">
            <EditForm id="formDriver" Model="@model" OnValidSubmit="Submit">
                <ObjectGraphDataAnnotationsValidator />
                <ValidationSummary />
                <MudGrid>
                    <MudItem xs="12" md="12">
                        <MudTextField Value="model.Driver.DriverName" Label="Name" Variant="Variant.Outlined" Margin="Margin.Dense"></MudTextField>
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudSelect Label="Severity" Variant="Variant.Outlined" Margin="Margin.Dense" @bind-Value="model.Severity" AnchorOrigin="Origin.TopCenter" TransformOrigin="Origin.TopCenter" AdornmentColor="Color.Secondary" Required>
                            <MudSelectItem T="byte?" Value="1">Warning</MudSelectItem>
                            <MudSelectItem T="byte?" Value="9">Blacklisted</MudSelectItem>

                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudDatePicker Label="Date" Variant="Variant.Outlined" Margin="Margin.Dense" DisableToolbar="true" Editable="true" @bind-Date="model.FaultDate" DateFormat="dd/MM/yyyy" />
                    </MudItem>
                    <MudItem xs="12" md="12">
                        <MudTextField @bind-Value="model.Detail" Label="Details" Variant="Variant.Outlined" Lines="3" Margin="Margin.Dense" Required></MudTextField>
                    </MudItem>
                </MudGrid>

            </EditForm>
        </MudContainer>

    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Submit" Class="px-12">Submit</MudButton>
    </DialogActions>
</MudDialog>

@code {

    [CascadingParameter] MudDialogInstance MudDialog { get; set; }

    [Parameter]
    public DriverFaultModel model { get; set; } = new();
    [Parameter]
    public int? DriverID { get; set; }

    public bool HasPermissionDriverFaultServiceEditDriver { get; set; } = false;
    public int DocTypeID = 53;

    protected override async Task OnInitializedAsync()
    {
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionDriverFaultServiceEditDriver = await Irole.HasClaim(DocTypeID.ToString(), "RemoveDriver", ctc.Token);

        var authprov = await auth.GetAuthenticationStateAsync();
        var User = authprov.User;
        if (model.BranchID == null)
        {
            model.BranchID = new();
            model.BranchID = int.Parse(User.Claims.First(x => x.Type == "BranchID").Value);
        }
    }


    void Cancel()
    {
        MudDialog.Cancel();
    }


    public async Task Submit()
    {
        if (HasPermissionDriverFaultServiceEditDriver)
        {
            var authprov = await auth.GetAuthenticationStateAsync();
            var user = authprov.User;
            var brancIDString = authprov.User.Claims.First(x => x.Type == "BranchID").Value;

            if (model.Driver == null || model.Driver.DriverID == 0)
            {
                bool? result = await DialogService.ShowMessageBox(
                    "Warning",
                    "Please, Select Driver.",
                    yesText: "OK");
                return;
            }

            string removedFromTruck = Idriverservice.RemoveDriverFromTruck(model.Driver?.DriverID, user.Identity.Name);

            if (removedFromTruck == "OnTrip")
            {
                await DialogService.ShowMessageBox("Warning", "The Driver is currently on a trip.", yesText: "OK");
                return;
            }
            else if (removedFromTruck == "DriverRemoved")
            {
                Snackbar.Add("Driver removed from the truck", Severity.Warning);
            }
            else
            {
                Snackbar.Add(removedFromTruck, Severity.Error);

            }
            if (removedFromTruck == "NoAssignedTruck" || removedFromTruck == "DriverRemoved")
            {

                try
                {
                    model.BranchID = int.Parse(brancIDString);
                    model.UserInfo.UserID = user.Identity.Name;
                    Iservice.Update(model);
                    Snackbar.Add("Success", Severity.Success);
                }
                catch (Exception ex)
                {
                    Snackbar.Add(ex.Message, Severity.Error);
                }
            }
            MudDialog.Close(model);
        }
        else
        {
            bool? result = await DialogService.ShowMessageBox(
               "Permission denied!",
               "You dont have any permission to Edit DriverFault.");
        }
    }


    private async Task DriverSelected(DriverModel obj)
    {
        model.Driver = obj;
    }

}

