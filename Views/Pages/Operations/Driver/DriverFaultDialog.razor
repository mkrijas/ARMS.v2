@inject IRoleService<RoleModel> Irole
@inject AuthenticationStateProvider auth
@inject IDriverFaultService Iservice
@inject IDriverService Idriverservice
@inject MudBlazor.ISnackbar Snackbar
@inject IDialogService DialogService

<MudDialog Class="admin-dialog-glass">
    <TitleContent>
        <div class="header-section mb-2 pt-4 px-4">
            <div class="d-flex align-center justify-space-between">
                <div class="d-flex align-center">
                    <div class="icon-badge primary-badge mr-4">
                        <div class="admin-header-icon-badge mb-3">
                            <MudIcon Icon="@Icons.Material.Filled.Gavel" Color="Color.Secondary" Style="font-size: 3rem;" />
                        </div>
                    </div>
                    <div>
                        <MudText Typo="Typo.h5" Class="admin-title"><b>Driver Compliance Manager</b></MudText>
                        <MudText Typo="Typo.body2" Class="admin-subtitle">Monitor driver performance and document operational infractions or blacklisting status.</MudText>
                    </div>
                </div>
            </div>
            <div class="title-accent mt-4"></div>
        </div>
    </TitleContent>
    <DialogContent>
        <MudContainer Class="admin-dialog-container">
            <div class="dialog-content-wrapper">
                <MudTabs @bind-ActivePanelIndex="_activeTabIndex" Elevation="0" Rounded="true" ApplyEffectsToInnerViews="true" Class="premium-tabs pa-4" PanelClass="pa-0" Style="background: transparent;">
                    <MudTabPanel Text="Violation History" Icon="@Icons.Material.Filled.History">
                        <div class="pa-4">
                            @if (model.Driver != null)
                            {
                                <div class="admin-glass-card pa-4 mb-4 d-flex align-center" style="background: rgba(var(--mud-palette-primary-rgb), 0.05); border-left: 4px solid var(--mud-palette-primary); border-radius: 12px;">
                                    <MudIcon Icon="@Icons.Material.Filled.Person" Color="Color.Primary" Class="mr-4" Style="font-size: 2rem;" />
                                    <div>
                                        <MudText Typo="Typo.h6" Class="fw-700">@model.Driver.DriverName</MudText>
                                        <MudText Typo="Typo.caption" Class="admin-subtitle opacity-70">Employee Code: <span class="fw-700">@model.Driver.DriverCode</span></MudText>
                                    </div>
                                </div>
                            }
                            <div class="admin-glass-card overflow-hidden">
                                <div class="modern-admin-table">
                                    <MudTable Items="@driverFaultList" Hover="true" Dense="true" Elevation="0" FixedHeader="true" Height="300px">
                                        <HeaderContent>
                                            <MudTh>SEVERITY</MudTh>
                                            <MudTh>REGISTRY DATE</MudTh>
                                            <MudTh>PENALTY (AMT)</MudTh>
                                            <MudTh>INFRACTION DETAILS</MudTh>
                                        </HeaderContent>
                                        <RowTemplate>
                                            <MudTd DataLabel="Severity">
                                                @if (context.Severity == 1)
                                                {
                                                    <span class="status-badge warning-badge" style="background: rgba(var(--mud-palette-warning-rgb), 0.1); color: var(--mud-palette-warning-darken); padding: 4px 12px; border-radius: 6px; font-weight: 700; font-size: 0.75rem;">WARNING</span>
                                                }
                                                else if (context.Severity == 9)
                                                {
                                                    <span class="status-badge error-badge" style="background: rgba(var(--mud-palette-error-rgb), 0.1); color: var(--mud-palette-error-darken); padding: 4px 12px; border-radius: 6px; font-weight: 700; font-size: 0.75rem;">BLACKLISTED</span>
                                                }
                                                else
                                                {
                                                    <span class="status-badge neutral-badge" style="background: rgba(0,0,0,0.05); color: #666; padding: 4px 12px; border-radius: 6px; font-weight: 700; font-size: 0.75rem;">N/A</span>
                                                }
                                            </MudTd>
                                            <MudTd DataLabel="Date">@context.FaultDate?.ToString("dd MMM yyyy")</MudTd>
                                            <MudTd DataLabel="Penalty"><span class="fw-800" style="color: var(--mud-palette-primary);">₹ @context.Amount?.ToString("N0")</span></MudTd>
                                            <MudTd DataLabel="Details" Class="text-truncate" Style="max-width: 250px;">@context.Detail</MudTd>
                                        </RowTemplate>
                                        <NoRecordsContent>
                                            <div class="pa-8 text-center opacity-50">
                                                <MudIcon Icon="@Icons.Material.Filled.History" Style="font-size: 3rem;" />
                                                <MudText Typo="Typo.body2" Class="mt-2">No violation history recorded for this driver.</MudText>
                                            </div>
                                        </NoRecordsContent>
                                    </MudTable>
                                </div>
                            </div>
                        </div>
                    </MudTabPanel>

                    <MudTabPanel Text="Register New Fault" Icon="@Icons.Material.Filled.AddModerator">
                        <div class="pa-4">
                            <EditForm id="formDefault" Model="@model" OnValidSubmit="Submit">
                                <div class="admin-glass-card pa-6">
                                    <ObjectGraphDataAnnotationsValidator />
                                    <MudValidationSummary />
                                    <MudGrid Spacing="3">
                                        <MudItem xs="12" md="6">
                                            <MudAutocomplete T="DriverModel"
                                                             ReadOnly="true"
                                                             Label="Subject Driver"
                                                             @bind-Value="model.Driver"
                                                             ResetValueOnEmptyText="true"
                                                             Variant="Variant.Outlined"
                                                             Margin="Margin.Normal"
                                                             SearchFunc="SearchDriver"
                                                             ToStringFunc="@(e => e == null ? null : $"{e.DriverCode} | {e.DriverName}")"
                                                             Class="modern-input"
                                                             Adornment="Adornment.Start"
                                                             AdornmentIcon="@Icons.Material.Filled.PersonSearch" />
                                        </MudItem>

                                        <MudItem xs="12" md="6">
                                            <MudDatePicker Label="Incident Date"
                                                           Variant="Variant.Outlined"
                                                           Margin="Margin.Normal"
                                                           DisableToolbar="true"
                                                           Editable="true"
                                                           @bind-Date="model.FaultDate"
                                                           DateFormat="dd/MM/yyyy"
                                                           Class="modern-input" />
                                        </MudItem>

                                        <MudItem xs="12" md="6">
                                            <MudSelect For="@(() => model.Severity)" Label="Compliance Severity"
                                                       Variant="Variant.Outlined"
                                                       Margin="Margin.Normal"
                                                       @bind-Value="model.Severity"
                                                       Class="modern-input">
                                                <MudSelectItem T="byte?" Value="1">Level 1: Warning Notice</MudSelectItem>
                                                <MudSelectItem T="byte?" Value="9">Level 9: Immediate Blacklist</MudSelectItem>
                                            </MudSelect>
                                        </MudItem>

                                        <MudItem xs="12" md="6">
                                            <MudNumericField HideSpinButtons
                                                             Label="Penalty Amount"
                                                             @bind-Value="model.Amount"
                                                             Variant="Variant.Outlined"
                                                             Margin="Margin.Normal"
                                                             Class="modern-input"
                                                             Adornment="Adornment.Start"
                                                             AdornmentIcon="@Icons.Material.Filled.CurrencyRupee" />
                                        </MudItem>

                                        <MudItem xs="12">
                                            <MudTextField @bind-Value="model.Detail"
                                                          Label="Operational Details / Incident Description"
                                                          Variant="Variant.Outlined"
                                                          Lines="3"
                                                          Margin="Margin.Normal"
                                                          Class="modern-input" />
                                        </MudItem>
                                    </MudGrid>
                                </div>
                            </EditForm>
                        </div>
                    </MudTabPanel>
                </MudTabs>
            </div>
        </MudContainer>
    </DialogContent>
    <DialogActions>
        <div class="d-flex w-100 flex-wrap pa-4 gap-3 align-center">
            <MudSpacer />
            <MudButton Variant="Variant.Outlined" OnClick="Cancel" Style="border-radius: 12px; font-weight: 700; text-transform: none; border-color: rgba(0,0,0,0.15);">Exit</MudButton>
            @if (_activeTabIndex == 1)
            {
                <MudButton Disabled="@_busy" form="formDefault" Variant="Variant.Filled" Color="Color.Primary" ButtonType="ButtonType.Submit" Style="background: var(--mud-palette-primary); color: white; font-weight: 800; border-radius: 12px; text-transform: none; white-space: nowrap; padding: 8px 32px;" StartIcon="@Icons.Material.Filled.ReportProblem">Record Violation</MudButton>
            }
        </div>
    </DialogActions>
</MudDialog>

@code {

    [CascadingParameter] IMudDialogInstance MudDialog { get; set; }
    [Parameter]
    public DriverFaultModel model { get; set; } = new();
    [Parameter]
    public int? DriverID { get; set; }
    private int _activeTabIndex = 0;

    int? BranchID { get; set; }
    private List<DriverModel> Driverlist = new();
    private DriverModel SelectedDriver = null;
    private List<DriverFaultModel> driverFaultList = new();

    public bool HasPermissionDriverFaultServiceEditDriver { get; set; } = false;
    public int DocTypeID = 53;
    private bool _busy;

    // Lifecycle method called when the component is initialized
    protected override async Task OnInitializedAsync()
    {
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionDriverFaultServiceEditDriver = await Irole.HasClaim(DocTypeID.ToString(), "Edit", ctc.Token);

        var authprov = await auth.GetAuthenticationStateAsync();
        var User = authprov.User;
        if (model.BranchID == null)
        {
            model.BranchID = new();
            model.BranchID = int.Parse(User.Claims.First(x => x.Type == "BranchID").Value);

            // Retrieve the list of drivers associated with the branch
            Driverlist = Idriverservice.SelectByBranch(model?.BranchID ?? 0).ToList();
        }
        if (model.Driver != null)
        {
            driverFaultList = Iservice.Select(model.Driver.DriverID).ToList();
        }
    }

    // Method to search for drivers based on a search string
    private async Task<IEnumerable<DriverModel>> SearchDriver(string searchString, CancellationToken token)
    {
        await Task.Delay(3, token);
        return await Task.FromResult(Driverlist.Where(x => x.DriverName.Contains(searchString == null ? string.Empty : searchString, StringComparison.InvariantCultureIgnoreCase)
                                                    || (x.DriverCode.Contains(searchString == null ? string.Empty : searchString, StringComparison.InvariantCultureIgnoreCase))));
    }

    // Method to cancel the dialog
    void Cancel()
    {
        MudDialog.Cancel();
    }

    // Method to submit the driver fault information
    public async Task Submit()
    {
        if (_busy)
        {
            Snackbar.Add("Please wait while form is being submitted!", Severity.Warning);
            return;
        }
        if (HasPermissionDriverFaultServiceEditDriver)
        {
            DriverFaultModel newmodel = new();
            var authprov = await auth.GetAuthenticationStateAsync();
            var user = authprov.User;
            var brancIDString = authprov.User.Claims.First(x => x.Type == "BranchID").Value;
            if (model.Driver == null || model.Driver.DriverID == 0)
            {
                await DialogService.ShowMessageBoxAsync(
                    "Warning",
                    "Please, Select Driver.",
                    yesText: "OK");
                return;
            }
            if (model.Driver.DriverID == null)
            {
                Snackbar.Add("Please select Driver.", Severity.Warning);
                return;
            }
            if (model.Severity == null)
            {
                Snackbar.Add("Please select Severity.", Severity.Warning);
                return;
            }
            if (model.Severity == 9)
            {
                string removedFromTruck = Idriverservice.RemoveDriverFromTruck(model.Driver?.DriverID, user.Identity.Name);
                if (removedFromTruck == "OnTrip")
                {
                    await DialogService.ShowMessageBoxAsync("Warning", "The Driver is currently on a trip.", yesText: "OK");
                    return;
                }
                else if (removedFromTruck == "DriverRemoved")
                {
                    Snackbar.Add("Driver removed from the truck", Severity.Warning);
                }
                else if (removedFromTruck != "NoAssignedTruck")
                {
                    Snackbar.Add(removedFromTruck, Severity.Error);
                }
                
                if (removedFromTruck == "NoAssignedTruck" || removedFromTruck == "DriverRemoved")
                {
                    _busy = true;
                    try
                    {
                        model.BranchID = int.Parse(brancIDString);
                        model.UserInfo.UserID = user.Identity.Name;
                        newmodel = Iservice.Update(model); //update
                        Snackbar.Add("Successfull Added.", Severity.Success);
                        MudDialog.Close(DialogResult.Ok(newmodel));
                    }
                    catch (Exception ex)
                    {
                        Snackbar.Add(ex.Message, Severity.Error);
                    }
                    finally
                    {
                        await Task.Delay(200);
                        _busy = false;
                    }
                }
            }
            else
            {
                _busy = true;
                try
                {
                    model.BranchID = int.Parse(brancIDString);
                    model.UserInfo.UserID = user.Identity.Name;
                    newmodel  = Iservice.Update(model);
                    Snackbar.Add("Driver Fault Successfully Added.", Severity.Success);
                    MudDialog.Close(DialogResult.Ok(newmodel));
                }
                catch (Exception ex)
                {
                    Snackbar.Add(ex.Message, Severity.Error);
                }
                finally
                {
                    await Task.Delay(200);
                    _busy = false;
                }
            }
        }
        else
        {
            await DialogService.ShowMessageBoxAsync(
                "Permission denied!",
                "You don't have any permission to Edit DriverFault.");
        }
    }

    //method to select driver
    private async Task DriverSelected(DriverModel obj)
    {
        model.Driver = obj;
    }
}
