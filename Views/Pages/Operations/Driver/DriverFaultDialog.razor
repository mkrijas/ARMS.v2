@using System.Threading;
@inject AuthenticationStateProvider auth
@inject IDriverFaultService Iservice
@inject IDriverService Idriverservice
@inject ITruckService Itruckservice
@inject ITripService Itripservice
@inject IBranchService Ibranchservice
@inject IDialogService DialogService
@inject IDriverService IDriverService
@inject ISnackbar Snackbar
@inject IRoleService<RoleModel> Irole

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.Edit" Class="mr-3" /> Driver Fault Management
        </MudText>
    </TitleContent>

    <DialogContent>
        <MudTabs @bind-ActivePanelIndex="_activeTabIndex">
            <MudTabPanel Text="Fault">
                <MudContainer Class="p-3" Style="max-height:400px; overflow-y:auto;">
                    @if (model.Driver != null)
                    {
                        <MudText Typo="Typo.subtitle1" Class="mb-2">
                            @model.Driver.DriverCode | @model.Driver.DriverName
                        </MudText>
                    }
                    <MudTable Items="@driverFaultList" Hover="true" Dense="true" Bordered="true">
                        <HeaderContent>
                            <MudTh>Severity</MudTh>
                            <MudTh>Date</MudTh>
                            <MudTh>Amount</MudTh>
                            <MudTh>Details</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd>@(context.Severity == 1 ? "Warning" : context.Severity == 9 ? "Blacklisted" : "N/A")</MudTd>
                            <MudTd>@context.FaultDate?.ToString("dd/MM/yyyy")</MudTd>
                            <MudTd>@context.Amount</MudTd>
                            <MudTd>@context.Detail</MudTd>
                        </RowTemplate>
                    </MudTable>
                </MudContainer>
            </MudTabPanel>

            <MudTabPanel Text="Add Fault">
                <MudContainer Class="p-3" Style="max-height:400px; overflow-y:auto;">
                    <EditForm id="formDefault" Model="@model" OnValidSubmit="Submit">
                        <ObjectGraphDataAnnotationsValidator />
                        <ValidationSummary />

                        <MudGrid>
                            <MudItem xs="12" md="6">
                                <MudAutocomplete T="DriverModel"
                                                 ReadOnly="true"
                                                 Label="Select Driver"
                                                 @bind-Value="model.Driver"
                                                 ResetValueOnEmptyText="true"
                                                 Variant="Variant.Outlined"
                                                 Margin="Margin.Dense"
                                                 SearchFunc="SearchDriver"
                                                 ToStringFunc="@(e => e == null ? null : $"{e.DriverCode} | {e.DriverName}")" />
                            </MudItem>

                            <MudItem xs="12" md="6">
                                <MudDatePicker Label="Date"
                                               Variant="Variant.Outlined"
                                               Margin="Margin.Dense"
                                               DisableToolbar="true"
                                               Editable="true"
                                               @bind-Date="model.FaultDate"
                                               DateFormat="dd/MM/yyyy" />
                            </MudItem>

                            <MudItem xs="12" md="6">
                                <MudSelect Label="Severity"
                                           Variant="Variant.Outlined"
                                           Margin="Margin.Dense"
                                           @bind-Value="model.Severity">
                                    <MudSelectItem T="byte?" Value="1">Warning</MudSelectItem>
                                    <MudSelectItem T="byte?" Value="9">Blacklisted</MudSelectItem>
                                </MudSelect>
                            </MudItem>

                            <MudItem xs="12" md="6">
                                <MudNumericField HideSpinButtons
                                                 Label="Amount"
                                                 @bind-Value="model.Amount"
                                                 Variant="Variant.Outlined"
                                                 Margin="Margin.Dense" />
                            </MudItem>

                            <MudItem xs="12">
                                <MudTextField @bind-Value="model.Detail"
                                              Label="Details"
                                              Variant="Variant.Outlined"
                                              Lines="3"
                                              Margin="Margin.Dense" />
                            </MudItem>

                        </MudGrid>
                    </EditForm>
                </MudContainer>
            </MudTabPanel>
        </MudTabs>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Close</MudButton>
        @if (_activeTabIndex == 1)
        {
            <MudButton Disabled="@_busy" form="formDefault" Variant="Variant.Filled" Color="Color.Primary" OnClick="Submit" Class="px-12">Submit</MudButton>
        }
    </DialogActions>
</MudDialog>


@code {

    [CascadingParameter] IMudDialogInstance MudDialog { get; set; }
    [Parameter]
    public DriverFaultModel model { get; set; } = new();
    [Parameter]
    public int? DriverID { get; set; }
    private int _activeTabIndex = 0;

    int? BranchID { get; set; }
    private List<DriverModel> Driverlist = new();
    private DriverModel SelectedDriver = null;
    private List<DriverFaultModel> driverFaultList = new();

    public bool HasPermissionDriverFaultServiceEditDriver { get; set; } = false;
    public int DocTypeID = 53;
    private bool _busy;

    // Lifecycle method called when the component is initialized
    protected override async Task OnInitializedAsync()
    {
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionDriverFaultServiceEditDriver = await Irole.HasClaim(DocTypeID.ToString(), "Edit", ctc.Token);

        var authprov = await auth.GetAuthenticationStateAsync();
        var User = authprov.User;
        if (model.BranchID == null)
        {
            model.BranchID = new();
            model.BranchID = int.Parse(User.Claims.First(x => x.Type == "BranchID").Value);

            // Retrieve the list of drivers associated with the branch
            Driverlist = IDriverService.SelectByBranch(model?.BranchID ?? 0).ToList();
        }
        driverFaultList = Iservice.Select(model.Driver.DriverID).ToList();
    }

    // Method to search for drivers based on a search string
    private async Task<IEnumerable<DriverModel>> SearchDriver(string searchString, CancellationToken token)
    {
        await Task.Delay(3, token);
        return await Task.FromResult(Driverlist.Where(x => x.DriverName.Contains(searchString == null ? string.Empty : searchString, StringComparison.InvariantCultureIgnoreCase)
                                                    || (x.DriverCode.Contains(searchString == null ? string.Empty : searchString, StringComparison.InvariantCultureIgnoreCase))));
    }

    // Method to cancel the dialog
    void Cancel()
    {
        MudDialog.Cancel();
    }

    // Method to submit the driver fault information
    public async Task Submit()
    {
        if (_busy)
        {
            Snackbar.Add("Please wait while form is being submitted!", Severity.Warning);
            return;
        }
        if (HasPermissionDriverFaultServiceEditDriver)
        {
            DriverFaultModel newmodel = new();
            var authprov = await auth.GetAuthenticationStateAsync();
            var user = authprov.User;
            var brancIDString = authprov.User.Claims.First(x => x.Type == "BranchID").Value;
            if (model.Driver == null || model.Driver.DriverID == 0)
            {
                bool? result = await DialogService.ShowMessageBox(
                    "Warning",
                    "Please, Select Driver.",
                    yesText: "OK");
                return;
            }
            if (model.Driver.DriverID == null)
            {
                Snackbar.Add("Please select Driver.", Severity.Warning);
                return;
            }
            if (model.Severity == null)
            {
                Snackbar.Add("Please select Severity.", Severity.Warning);
                return;
            }
            if (model.Severity == 9)
            {
                string removedFromTruck = Idriverservice.RemoveDriverFromTruck(model.Driver?.DriverID, user.Identity.Name);
                if (removedFromTruck == "OnTrip")
                {
                    await DialogService.ShowMessageBox("Warning", "The Driver is currently on a trip.", yesText: "OK");
                    return;
                }
                else if (removedFromTruck == "DriverRemoved")
                {
                    Snackbar.Add("Driver removed from the truck", Severity.Warning);
                }
                else
                {
                    Snackbar.Add(removedFromTruck, Severity.Error);
                }
                if (removedFromTruck == "NoAssignedTruck" || removedFromTruck == "DriverRemoved")
                {
                    _busy = true;
                    try
                    {
                        model.BranchID = int.Parse(brancIDString);
                        model.UserInfo.UserID = user.Identity.Name;
                        Iservice.Update(model); //update
                        Snackbar.Add("Successfull Added.", Severity.Success);
                    }
                    catch (Exception ex)
                    {
                        Snackbar.Add(ex.Message, Severity.Error);
                    }
                }
            }
            else
            {
                _busy = true;
                try
                {
                    model.BranchID = int.Parse(brancIDString);
                    model.UserInfo.UserID = user.Identity.Name;
                    newmodel  = Iservice.Update(model);
                    Snackbar.Add("Driver Fault Successfully Added.", Severity.Success);
                }
                catch (Exception ex)
                {
                    Snackbar.Add(ex.Message, Severity.Error);
                }
            }
            MudDialog.Close(newmodel);
            await Task.Delay(200);
            _busy = false;
        }
        else
        {
            bool? result = await DialogService.ShowMessageBox(
                "Permission denied!",
                "You don't have any permission to Edit DriverFault.");
        }
    }

    //method to select driver
    private async Task DriverSelected(DriverModel obj)
    {
        model.Driver = obj;
    }
}
