@inject IRoleService<RoleModel> Irole
@inject AuthenticationStateProvider auth
@inject IDriverService Iservice
@inject MudBlazor.ISnackbar Snackbar
@inject IDialogService DialogService

<MudDialog Class="admin-dialog-glass">
    <TitleContent>
        <div class="header-section mb-2 pt-4 px-4">
            <div class="d-flex align-center justify-space-between">
                <div class="d-flex align-center">
                    <div class="icon-badge primary-badge mr-4">
                        <div class="admin-header-icon-badge mb-3">
                            <MudIcon Icon="@Icons.Material.Filled.EventBusy" Color="Color.Secondary" Style="font-size: 3rem;" />
                        </div>
                    </div>
                    <div>
                        <MudText Typo="Typo.h5" Class="admin-title"><b>Personnel Absence Scheduling</b></MudText>
                        <MudText Typo="Typo.body2" Class="admin-subtitle">Authorize and document driver leave requests with contractual return commitments.</MudText>
                    </div>
                </div>
            </div>
            <div class="title-accent mt-4"></div>
        </div>
    </TitleContent>
    <DialogContent>
        <MudContainer Class="admin-dialog-container">
            <div class="dialog-content-wrapper pa-4">
                <div class="admin-glass-card pa-6 mb-6" style="border-left: 4px solid var(--mud-palette-error); background: rgba(var(--mud-palette-error-rgb), 0.05);">
                    <div class="d-flex align-center">
                        <MudIcon Icon="@Icons.Material.Filled.WarningAmber" Color="Color.Error" Class="mr-3" Size="Size.Large" />
                        <div>
                            <MudText Typo="Typo.subtitle1" Class="fw-700 color-error" Style="color: var(--mud-palette-error-darken);">Critical Confirmation Required</MudText>
                            <MudText Typo="Typo.body2">
                                <b>@(model.Driver?.DriverName ?? "Staff Member")</b> will be marked as <b>Inactive/On-Leave</b> effective <b>@DateTime.Today.ToString("dd MMM yyyy")</b>.
                            </MudText>
                        </div>
                    </div>
                </div>

                <EditForm id="formDriverLeave" Model="@model" OnValidSubmit="Submit">
                    <ObjectGraphDataAnnotationsValidator />
                    
                    <div class="admin-glass-card pa-6">
                        <div class="d-flex align-center mb-6">
                            <MudIcon Icon="@Icons.Material.Filled.History" Color="Color.Primary" Class="mr-2" />
                            <span class="admin-section-label mb-0">Leave Parameters</span>
                        </div>
                        
                        <MudGrid Spacing="3">
                            <MudItem xs="12">
                                <MudDatePicker Label="Scheduled Return Commitment" Variant="Variant.Outlined" Margin="Margin.Normal" DisableToolbar="true" Editable="true" @bind-Date="model.ExpectedReturn" DateFormat="dd/MM/yyyy" Class="modern-input" AdornmentIcon="@Icons.Material.Filled.EventAvailable" AdornmentColor="Color.Primary" Placeholder="Select return date..." />
                            </MudItem>
                            <MudItem xs="12">
                                <MudTextField @bind-Value="model.Reason" Label="Logistical Remarks / Justification" Variant="Variant.Outlined" Lines="4" Margin="Margin.Normal" For="@(() => model.Reason)" Class="modern-input" Placeholder="Provide detailed reason for absence..."></MudTextField>
                            </MudItem>
                        </MudGrid>
                    </div>
                </EditForm>
            </div>
        </MudContainer>
    </DialogContent>
    <DialogActions>
        <div class="d-flex w-100 flex-wrap pa-4 gap-3 align-center">
            <MudSpacer />
            <MudButton @onclick="Cancel" Variant="Variant.Outlined" Color="Color.Default" Style="border-radius: 12px; font-weight: 700; text-transform: none; border-color: rgba(0,0,0,0.15);">Discard</MudButton>
            <MudButton Disabled="@_busy" form="formDriverLeave" Variant="Variant.Filled" Color="Color.Success" ButtonType="ButtonType.Submit" Style="background: var(--mud-palette-success); color: white; font-weight: 800; border-radius: 12px; text-transform: none; white-space: nowrap; padding: 8px 32px;" StartIcon="@Icons.Material.Filled.Timer">Authorize Absence</MudButton>
        </div>
    </DialogActions>
</MudDialog>

@code {

    [CascadingParameter] IMudDialogInstance MudDialog { get; set; }
    [Parameter]
    public DriverLeaveModel model { get; set; } = new();
    [Parameter]
    public int? DriverID { get; set; }
    private bool _busy;

    public bool HasPermissionDriverServiceAllotLeave { get; set; } = false;
    public int DocTypeID = 50;

    // Lifecycle method called when the component is initialized
    protected override async Task OnInitializedAsync()
    {
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionDriverServiceAllotLeave = await Irole.HasClaim(DocTypeID.ToString(), "AllotLeave", ctc.Token);

        var authprov = await auth.GetAuthenticationStateAsync();
        var User = authprov.User;
        if (model.BranchID == null)
        {
            model.BranchID = new();
            model.BranchID = int.Parse(User.Claims.First(x => x.Type == "BranchID").Value);
        }
    }

    void Cancel()
    {
        MudDialog.Cancel();
    }

    // Method to submit the leave request for the driver
    public async Task Submit()
    {
        if (_busy)
        {
            Snackbar.Add("Please wait while form is being submitted!", Severity.Warning);
            return;
        }
        if (HasPermissionDriverServiceAllotLeave)
        {
            var authprov = await auth.GetAuthenticationStateAsync();
            var user = authprov.User;

            // Attempt to remove the driver from the truck
            string removedFromTruck = Iservice.RemoveDriverFromTruck(model.Driver?.DriverID, user.Identity.Name);
            if (removedFromTruck == "OnTrip")
            {
                await DialogService.ShowMessageBoxAsync("Warning", "The Driver is currently on a trip.", yesText: "OK");
                return;
            }
            else if (removedFromTruck == "DriverRemoved")
            {
                Snackbar.Add("Driver removed from the truck", Severity.Warning);
            }
            else if (removedFromTruck != "NoAssignedTruck")
            {
                Snackbar.Add(removedFromTruck, Severity.Error);
            }

            if (removedFromTruck == "NoAssignedTruck" || removedFromTruck == "DriverRemoved")
            {
                _busy = true;
                try
                {
                    model.UserInfo.UserID = user.Identity.Name;
                    Iservice.BeginLeave(model); // Begin the leave process for the driver
                    Snackbar.Add("Driver On Leave", Severity.Success);
                    MudDialog.Close(DialogResult.Ok(model));
                }
                catch (Exception ex)
                {
                    Snackbar.Add(ex.Message, Severity.Error);
                }
                finally
                {
                    await Task.Delay(200);
                    _busy = false;
                }
            }
        }
        else
        {
            await DialogService.ShowMessageBoxAsync(
                "Permission denied!",
                "You don't have any permission to AllotLeave to Driver.");
        }
    }
}
