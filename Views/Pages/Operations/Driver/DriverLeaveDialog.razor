@using System.Threading;
@inject AuthenticationStateProvider auth
@inject IDriverService Iservice
@inject ITruckService Itruckservice
@inject ITripService Itripservice
@inject IBranchService Ibranchservice
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject IRoleService<RoleModel> Irole

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.Edit" Class="mr-3" /> Driver Leave Application
        </MudText>
    </TitleContent>
    <DialogContent>
        <b>@model.Driver.DriverName</b> will enter leave as on <b>@DateTime.Today.ToLocalTime()</b>. Please Confirm<br /><br />
        <MudContainer Style="max-height: 400px; overflow-y: scroll; margin-left:20px">
            <EditForm id="formDriver" Model="@model" OnValidSubmit="Submit">
                <ObjectGraphDataAnnotationsValidator />
                <ValidationSummary />
                <MudGrid>
                    <MudItem xs="12" md="6">
                        <MudDatePicker Label="Expected Return Date" Variant="Variant.Outlined" Margin="Margin.Dense" DisableToolbar="true" Editable="true" @bind-Date="model.ExpectedReturn" DateFormat="dd/MM/yyyy" />
                    </MudItem>
                    <MudItem xs="12" md="12">
                        <MudTextField @bind-Value="model.Reason" Label="Remarks" Variant="Variant.Outlined" Lines="3" Margin="Margin.Dense" For="@(() => model.Reason)"></MudTextField>
                    </MudItem>
                </MudGrid>
            </EditForm>
        </MudContainer>
    </DialogContent>
    <DialogActions>
        <MudButton Disabled="@_busy" Variant="Variant.Filled" Color="Color.Error" OnClick="Submit" Class="px-12">On Leave</MudButton>
    </DialogActions>
</MudDialog>

@code {

    [CascadingParameter] MudDialogInstance MudDialog { get; set; }
    [Parameter]
    public DriverLeaveModel model { get; set; } = new();
    [Parameter]
    public int? DriverID { get; set; }
    private bool _busy;

    public bool HasPermissionDriverServiceAllotLeave { get; set; } = false;
    public int DocTypeID = 50;

    protected override async Task OnInitializedAsync()
    {
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionDriverServiceAllotLeave = await Irole.HasClaim(DocTypeID.ToString(), "AllotLeave", ctc.Token);

        var authprov = await auth.GetAuthenticationStateAsync();
        var User = authprov.User;
        if (model.BranchID == null)
        {
            model.BranchID = new();
            model.BranchID = int.Parse(User.Claims.First(x => x.Type == "BranchID").Value);
        }
    }

    void Cancel()
    {
        MudDialog.Cancel();
    }

    public async Task Submit()
    {
        if (_busy)
        {
            Snackbar.Add("Please wait while form is being submitted!", Severity.Warning);
            return;
        }
        if (HasPermissionDriverServiceAllotLeave)
        {
            var authprov = await auth.GetAuthenticationStateAsync();
            var user = authprov.User;
            string removedFromTruck = Iservice.RemoveDriverFromTruck(model.Driver?.DriverID, user.Identity.Name);
            if (removedFromTruck == "OnTrip")
            {
                await DialogService.ShowMessageBox("Warning", "The Driver is currently on a trip.", yesText: "OK");
                return;
            }
            else if (removedFromTruck == "DriverRemoved")
            {
                Snackbar.Add("Driver removed from the truck", Severity.Warning);
            }
            if (removedFromTruck == "NoAssignedTruck" || removedFromTruck == "DriverRemoved")
            {
                _busy = true;
                try
                {
                    model.UserInfo.UserID = user.Identity.Name;
                    Iservice.BeginLeave(model);
                    Snackbar.Add("Driver On Leave", Severity.Success);
                }
                catch (Exception ex)
                {
                    Snackbar.Add(ex.Message, Severity.Error);
                }
            }
            MudDialog.Close(model);
            await Task.Delay(2000);
            _busy = false;
        }
        else
        {
            bool? result = await DialogService.ShowMessageBox(
                "Permission denied!",
                "You dont have any permission to AllotLeave to Driver.");
        }
    }
}