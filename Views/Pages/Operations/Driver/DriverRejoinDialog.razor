@using System.Threading;
@inject AuthenticationStateProvider auth
@inject IDriverService Iservice
@inject IBranchService Ibranchservice
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<DialogForm @ref="@dialogForm" Title="Staff Reinstatement Protocol" Subtitle="Formalize the return of previous driving personnel to active operational duty." Icon="@Icons.Material.Filled.PersonAddAlt1" AdminStyle="true" formID="formDriverRejoin" model="@model" _busy="_busy">
    <FormContent>
        <div class="dialog-content-wrapper">
            <div class="admin-glass-card pa-6 mb-6">
                <div class="d-flex align-center">
                    <MudAvatar Color="Color.Primary" Variant="Variant.Filled" Size="Size.Large" Class="mr-4 shadow-sm">
                        <MudIcon Icon="@Icons.Material.Filled.Person" />
                    </MudAvatar>
                    <div>
                        <MudText Typo="Typo.h6" Class="fw-600 mb-0">@model.DriverName</MudText>
                        <MudText Typo="Typo.body2" Class="color-muted font-italic">Verification pending for personnel reinstatement</MudText>
                    </div>
                </div>
            </div>

            <EditForm id="formDriverRejoin" Model="@model" OnValidSubmit="Submit">
                <ObjectGraphDataAnnotationsValidator />
                
                <div class="admin-glass-card pa-6">
                    <div class="d-flex align-center mb-6">
                        <MudIcon Icon="@Icons.Material.Filled.AccountBalance" Color="Color.Primary" Class="mr-2" />
                        <span class="admin-section-label mb-0">Deployment Specifications</span>
                    </div>
                    
                    <MudGrid Spacing="3">
                        <MudItem xs="12">
                            <MudSelect For="@(() => BranchID)" Label="Designated Operational Branch" @bind-Value="BranchID" T="int?" Variant="Variant.Outlined" Margin="Margin.Normal" AdornmentColor="Color.Secondary" Class="modern-input" Placeholder="Select assigning branch..." AdornmentIcon="@Icons.Material.Filled.Store" Required="true">
                                @foreach (var ditem in branches)
                                {
                                    <MudSelectItem Value="@ditem.BranchID">@ditem.BranchName</MudSelectItem>
                                }
                            </MudSelect>
                        </MudItem>
                    </MudGrid>
                </div>
            </EditForm>
        </div>
    </FormContent>
    <Actions>
        <MudButton Disabled="@_busy" Variant="Variant.Filled" Color="Color.Success" OnClick="Submit" Class="px-12 rounded-pill py-3 shadow-none">Authorize Reinstatement</MudButton>
    </Actions>
</DialogForm>

@code {
    DialogForm dialogForm;
    private bool _busy;
    [Parameter]
    public DriverModel model { get; set; } = new();
    private List<BranchModel> branches = new();
    private string UserID;
    private int? BranchID;

    // Lifecycle method called when the component is initialized
    protected override async Task OnInitializedAsync()
    {
        var authprov = await auth.GetAuthenticationStateAsync();
        var User = authprov.User;

        // Retrieve the list of branches from the branch service
        branches = Ibranchservice.Select().ToList();
    }

    void Cancel()
    {
        dialogForm.Cancel();
    }

    // Method to submit the rejoining request for the driver
    public async Task Submit()
    {
        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;

        if(BranchID == null)
        {
            Snackbar.Add("Select Rejoining Branch", Severity.Warning);
            return;
        }
        try
        {
            UserID = user.Identity.Name;
            Iservice.ReJoin(model.DriverID, UserID, BranchID); // Call the service to rejoin the driver
            Snackbar.Add("Driver Rejoined Successfully", Severity.Success);

        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }

        dialogForm.Close(model);        
    }
}
