@inject AuthenticationStateProvider auth
@inject IBranchService Ibranchservice
@inject IDriverService Iservice
@inject MudBlazor.ISnackbar Snackbar

<MudDialog Class="admin-dialog-glass">
    <TitleContent>
        <div class="header-section mb-2 pt-4 px-4">
            <div class="d-flex align-center justify-space-between">
                <div class="d-flex align-center">
                    <div class="icon-badge primary-badge mr-4">
                        <div class="admin-header-icon-badge mb-3">
                            <MudIcon Icon="@Icons.Material.Filled.PersonAddAlt1" Color="Color.Secondary" Style="font-size: 3rem;" />
                        </div>
                    </div>
                    <div>
                        <MudText Typo="Typo.h5" Class="admin-title"><b>Staff Reinstatement Protocol</b></MudText>
                        <MudText Typo="Typo.body2" Class="admin-subtitle">Formalize the return of previous driving personnel to active operational duty.</MudText>
                    </div>
                </div>
            </div>
            <div class="title-accent mt-4"></div>
        </div>
    </TitleContent>
    <DialogContent>
        <MudContainer Class="admin-dialog-container">
            <div class="dialog-content-wrapper pa-4">
                <div class="admin-glass-card pa-6 mb-6" style="background: rgba(var(--mud-palette-primary-rgb), 0.05);">
                    <div class="d-flex align-center">
                        <MudAvatar Color="Color.Primary" Variant="Variant.Filled" Size="Size.Large" Class="mr-4 shadow-sm">
                            <MudIcon Icon="@Icons.Material.Filled.Person" />
                        </MudAvatar>
                        <div>
                            <MudText Typo="Typo.h6" Class="fw-700 mb-0">@(model?.DriverName ?? "Staff Member")</MudText>
                            <MudText Typo="Typo.body2" Class="color-muted opacity-70 font-italic">Verification pending for personnel reinstatement</MudText>
                        </div>
                    </div>
                </div>

                <EditForm id="formDriverRejoin" Model="@model" OnValidSubmit="Submit">
                    <ObjectGraphDataAnnotationsValidator />
                    
                    <div class="admin-glass-card pa-6">
                        <div class="d-flex align-center mb-6">
                            <MudIcon Icon="@Icons.Material.Filled.AccountBalance" Color="Color.Primary" Class="mr-2" />
                            <span class="admin-section-label mb-0">Deployment Specifications</span>
                        </div>
                        
                        <MudGrid Spacing="3">
                            <MudItem xs="12">
                                <MudSelect For="@(() => BranchID)" Label="Designated Operational Branch" @bind-Value="BranchID" T="int?" Variant="Variant.Outlined" Margin="Margin.Normal" AdornmentColor="Color.Secondary" Class="modern-input" Placeholder="Select assigning branch..." AdornmentIcon="@Icons.Material.Filled.Store" Required="true">
                                    @foreach (var ditem in branches)
                                    {
                                        <MudSelectItem Value="@ditem.BranchID">@ditem.BranchName</MudSelectItem>
                                    }
                                </MudSelect>
                            </MudItem>
                        </MudGrid>
                    </div>
                </EditForm>
            </div>
        </MudContainer>
    </DialogContent>
    <DialogActions>
        <div class="d-flex w-100 flex-wrap pa-4 gap-3 align-center">
            <MudSpacer />
            <MudButton @onclick="Cancel" Variant="Variant.Outlined" Color="Color.Default" Style="border-radius: 12px; font-weight: 700; text-transform: none; border-color: rgba(0,0,0,0.15);">Discard</MudButton>
            <MudButton Disabled="@_busy" form="formDriverRejoin" Variant="Variant.Filled" Color="Color.Success" ButtonType="ButtonType.Submit" Style="background: var(--mud-palette-success); color: white; font-weight: 800; border-radius: 12px; text-transform: none; white-space: nowrap; padding: 8px 32px;" StartIcon="@Icons.Material.Filled.CheckCircle">Authorize Reinstatement</MudButton>
        </div>
    </DialogActions>
</MudDialog>

@code {

    [CascadingParameter] IMudDialogInstance MudDialog { get; set; }
    private bool _busy;
    [Parameter]
    public DriverModel model { get; set; } = new();
    private List<BranchModel> branches = new();
    private string UserID;
    private int? BranchID;

    // Lifecycle method called when the component is initialized
    protected override async Task OnInitializedAsync()
    {
        var authprov = await auth.GetAuthenticationStateAsync();
        var User = authprov.User;

        // Retrieve the list of branches from the branch service
        branches = Ibranchservice.Select().ToList();
    }

    void Cancel()
    {
        MudDialog.Cancel();
    }

    // Method to submit the rejoining request for the driver
    public async Task Submit()
    {
        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;

        if(BranchID == null)
        {
            Snackbar.Add("Select Rejoining Branch", Severity.Warning);
            return;
        }
        try
        {
            _busy = true;
            UserID = user.Identity.Name;
            Iservice.ReJoin(model.DriverID, UserID, BranchID); // Call the service to rejoin the driver
            Snackbar.Add("Driver Rejoined Successfully", Severity.Success);
            MudDialog.Close(DialogResult.Ok(model));
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally
        {
            await Task.Delay(200);
            _busy = false;
        }
    }
}
