@using System.Threading;
@inject AuthenticationStateProvider auth
@inject IDriverService Iservice
@inject ITruckService Itruckservice
@inject ITripService Itripservice
@inject IBranchService Ibranchservice
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject IRoleService<RoleModel> Irole

<DialogForm @ref="@dialogForm" Title="Personnel Resignation Processing" Subtitle="Formal documentation and system-level decommissioning of active driving staff." Icon="@Icons.Material.Filled.PersonRemove" AdminStyle="true" formID="formDriverResign" model="@model" _busy="_busy">
    <FormContent>
        <div class="dialog-content-wrapper">
            <div class="admin-glass-card pa-6 mb-6" style="border-left: 4px solid var(--mud-palette-warning);">
                <div class="d-flex align-center">
                    <MudIcon Icon="@Icons.Material.Filled.Warning" Color="Color.Warning" Class="mr-3" Size="Size.Large" />
                    <div>
                        <MudText Typo="Typo.subtitle1" Class="fw-bold fw-600 color-warning">Deactivation Warning</MudText>
                        <MudText Typo="Typo.body2">
                            Initiating resignation for <b>@model.Driver.DriverName</b>. This will permanently revoke active status.
                        </MudText>
                    </div>
                </div>
            </div>

            <EditForm id="formDriverResign" Model="@model" OnValidSubmit="Submit">
                <ObjectGraphDataAnnotationsValidator />
                
                <div class="admin-glass-card pa-6">
                    <div class="d-flex align-center mb-6">
                        <MudIcon Icon="@Icons.Material.Filled.Description" Color="Color.Primary" Class="mr-2" />
                        <span class="admin-section-label mb-0">Resignation Documentation</span>
                    </div>
                    
                    <MudGrid Spacing="3">
                        <MudItem xs="12">
                            <MudTextField Value="model.Driver.DriverName" Label="Personnel Member (Locked)" Variant="Variant.Outlined" Margin="Margin.Normal" Disabled="true" Class="modern-input" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.AccountCircle"></MudTextField>
                        </MudItem>
                        <MudItem xs="12">
                            <MudTextField @bind-Value="model.Remarks" Label="Exit Interview / Clearance Remarks" Variant="Variant.Outlined" Lines="4" Margin="Margin.Normal" For="@(() => model.Remarks)" Class="modern-input" Placeholder="Document the reasons for resignation and any handover notes..."></MudTextField>
                        </MudItem>
                    </MudGrid>
                </div>
            </EditForm>
        </div>
    </FormContent>
    <Actions>
        <MudButton Disabled="@_busy" Variant="Variant.Filled" Color="Color.Error" OnClick="Submit" Class="px-12 rounded-pill py-3 shadow-none">Finalize Resignation</MudButton>
    </Actions>
</DialogForm>

@code {
    DialogForm dialogForm;
    [Parameter]
    public DriverResignModel model { get; set; } = new();
    [Parameter]
    public int? DriverID { get; set; }
    private bool _busy;

    public bool HasPermissionDriverServiceRemoveDriver { get; set; } = false;
    public bool HasPermissionDriverServiceResign { get; set; } = false;
    public int DocTypeID = 50;

    // Lifecycle method called when the component is initialized
    protected override async Task OnInitializedAsync()
    {
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionDriverServiceRemoveDriver = await Irole.HasClaim(DocTypeID.ToString(), "RemoveDriver", ctc.Token);
        HasPermissionDriverServiceResign = await Irole.HasClaim(DocTypeID.ToString(), "Resign", ctc.Token);
    }

    void Cancel()
    {
        dialogForm.Cancel();
    }

    // Method to submit the resignation
    public async Task Submit()
    {
        if (_busy)
        {
            Snackbar.Add("Please wait while form is being submitted!", Severity.Warning);
            return;
        }
        if (HasPermissionDriverServiceResign)
        {
            var authprov = await auth.GetAuthenticationStateAsync();
            var user = authprov.User;

            // Attempt to remove the driver from the truck
            string removedFromTruck = Iservice.RemoveDriverFromTruck(model.Driver?.DriverID, user.Identity.Name);
            if (removedFromTruck == "OnTrip")
            {
                await DialogService.ShowMessageBoxAsync("Warning", "The Driver is currently on a trip.", yesText: "OK");
                return;
            }
            else if (removedFromTruck == "DriverRemoved")
            {
                Snackbar.Add("Driver removed from the truck", Severity.Warning);
            }
            else
            {
                Snackbar.Add(removedFromTruck, Severity.Error);
            }
            if (removedFromTruck == "NoAssignedTruck" || removedFromTruck == "DriverRemoved")
            {
                _busy = true;
                try
                {
                    // Call the service to process the resignation
                    Iservice.Resign(DriverID, model.Remarks, user.Identity.Name);
                    Snackbar.Add("Driver Resigned successfully", Severity.Success);
                }
                catch (Exception ex)
                {
                    Snackbar.Add(ex.Message, Severity.Error);
                }
            }
            dialogForm.Close(model);
            await Task.Delay(200);
            _busy = false;
        }
        else
        {
            bool? result = await DialogService.ShowMessageBoxAsync(
                "Permission denied!",
                "You don't have any permission to Resign Driver.");
        }
    }
}
