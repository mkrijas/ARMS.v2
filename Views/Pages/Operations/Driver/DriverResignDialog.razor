@inject IRoleService<RoleModel> Irole
@inject AuthenticationStateProvider auth
@inject IDriverService Iservice
@inject MudBlazor.ISnackbar Snackbar
@inject IDialogService DialogService

<MudDialog Class="admin-dialog-glass">
    <TitleContent>
        <div class="header-section mb-2 pt-4 px-4">
            <div class="d-flex align-center justify-space-between">
                <div class="d-flex align-center">
                    <div class="icon-badge primary-badge mr-4">
                        <div class="admin-header-icon-badge mb-3">
                            <MudIcon Icon="@Icons.Material.Filled.PersonRemove" Color="Color.Secondary" Style="font-size: 3rem;" />
                        </div>
                    </div>
                    <div>
                        <MudText Typo="Typo.h5" Class="admin-title"><b>Personnel Resignation Processing</b></MudText>
                        <MudText Typo="Typo.body2" Class="admin-subtitle">Formal documentation and system-level decommissioning of active driving staff.</MudText>
                    </div>
                </div>
            </div>
            <div class="title-accent mt-4"></div>
        </div>
    </TitleContent>
    <DialogContent>
        <MudContainer Class="admin-dialog-container">
            <div class="dialog-content-wrapper pa-4">
                <div class="admin-glass-card pa-6 mb-6" style="border-left: 4px solid var(--mud-palette-warning); background: rgba(var(--mud-palette-warning-rgb), 0.05);">
                    <div class="d-flex align-center">
                        <MudIcon Icon="@Icons.Material.Filled.Warning" Color="Color.Warning" Class="mr-3" Size="Size.Large" />
                        <div>
                            <MudText Typo="Typo.subtitle1" Class="fw-bold fw-700 color-warning" Style="color: var(--mud-palette-warning-darken);">Deactivation Warning</MudText>
                            <MudText Typo="Typo.body2">
                                Initiating resignation for <b>@(model.Driver?.DriverName ?? "Unknown")</b>. This will permanently revoke active status.
                            </MudText>
                        </div>
                    </div>
                </div>

                <EditForm id="formDriverResign" Model="@model" OnValidSubmit="Submit">
                    <ObjectGraphDataAnnotationsValidator />
                    
                    <div class="admin-glass-card pa-6">
                        <div class="d-flex align-center mb-6">
                            <MudIcon Icon="@Icons.Material.Filled.Description" Color="Color.Primary" Class="mr-2" />
                            <span class="admin-section-label mb-0">Resignation Documentation</span>
                        </div>
                        
                        <MudGrid Spacing="3">
                            <MudItem xs="12">
                                <MudTextField Value="model.Driver?.DriverName" Label="Personnel Member (Locked)" Variant="Variant.Outlined" Margin="Margin.Normal" Disabled="true" Class="modern-input" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.AccountCircle"></MudTextField>
                            </MudItem>
                            <MudItem xs="12">
                                <MudTextField @bind-Value="model.Remarks" Label="Exit Interview / Clearance Remarks" Variant="Variant.Outlined" Lines="4" Margin="Margin.Normal" For="@(() => model.Remarks)" Class="modern-input" Placeholder="Document the reasons for resignation and any handover notes..."></MudTextField>
                            </MudItem>
                        </MudGrid>
                    </div>
                </EditForm>
            </div>
        </MudContainer>
    </DialogContent>
    <DialogActions>
        <div class="d-flex w-100 flex-wrap pa-4 gap-3 align-center">
            <MudSpacer />
            <MudButton @onclick="Cancel" Variant="Variant.Outlined" Color="Color.Default" Style="border-radius: 12px; font-weight: 700; text-transform: none; border-color: rgba(0,0,0,0.15);">Discard</MudButton>
            <MudButton Disabled="@_busy" form="formDriverResign" Variant="Variant.Filled" Color="Color.Error" ButtonType="ButtonType.Submit" Style="background: var(--mud-palette-error); color: white; font-weight: 800; border-radius: 12px; text-transform: none; white-space: nowrap; padding: 8px 32px;" StartIcon="@Icons.Material.Filled.VerifiedUser">Finalize Resignation</MudButton>
        </div>
    </DialogActions>
</MudDialog>

@code {

    [CascadingParameter] IMudDialogInstance MudDialog { get; set; }
    [Parameter]
    public DriverResignModel model { get; set; } = new();
    [Parameter]
    public int? DriverID { get; set; }
    private bool _busy;

    public bool HasPermissionDriverServiceRemoveDriver { get; set; } = false;
    public bool HasPermissionDriverServiceResign { get; set; } = false;
    public int DocTypeID = 50;

    // Lifecycle method called when the component is initialized
    protected override async Task OnInitializedAsync()
    {
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionDriverServiceRemoveDriver = await Irole.HasClaim(DocTypeID.ToString(), "RemoveDriver", ctc.Token);
        HasPermissionDriverServiceResign = await Irole.HasClaim(DocTypeID.ToString(), "Resign", ctc.Token);
    }

    void Cancel()
    {
        MudDialog.Cancel();
    }

    // Method to submit the resignation
    public async Task Submit()
    {
        if (_busy)
        {
            Snackbar.Add("Please wait while form is being submitted!", Severity.Warning);
            return;
        }
        if (HasPermissionDriverServiceResign)
        {
            var authprov = await auth.GetAuthenticationStateAsync();
            var user = authprov.User;

            // Attempt to remove the driver from the truck
            string removedFromTruck = Iservice.RemoveDriverFromTruck(model.Driver?.DriverID, user.Identity.Name);
            if (removedFromTruck == "OnTrip")
            {
                await DialogService.ShowMessageBoxAsync("Warning", "The Driver is currently on a trip.", yesText: "OK");
                return;
            }
            else if (removedFromTruck == "DriverRemoved")
            {
                Snackbar.Add("Driver removed from the truck", Severity.Warning);
            }
            else if (removedFromTruck != "NoAssignedTruck")
            {
                Snackbar.Add(removedFromTruck, Severity.Error);
            }
            
            if (removedFromTruck == "NoAssignedTruck" || removedFromTruck == "DriverRemoved")
            {
                _busy = true;
                try
                {
                    // Call the service to process the resignation
                    Iservice.Resign(DriverID, model.Remarks, user.Identity.Name);
                    Snackbar.Add("Driver Resigned successfully", Severity.Success);
                    MudDialog.Close(DialogResult.Ok(model));
                }
                catch (Exception ex)
                {
                    Snackbar.Add(ex.Message, Severity.Error);
                }
                finally
                {
                    await Task.Delay(200);
                    _busy = false;
                }
            }
        }
        else
        {
            await DialogService.ShowMessageBoxAsync(
                "Permission denied!",
                "You don't have any permission to Resign Driver.");
        }
    }
}
