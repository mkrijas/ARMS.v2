@using System.Threading;
@inject AuthenticationStateProvider auth
@inject IDriverService Iservice
@inject ITruckService Itruckservice
@inject ITripService Itripservice
@inject IBranchService Ibranchservice
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject IRoleService<RoleModel> Irole

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.Edit" Class="mr-3" /> Driver Resign
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudContainer Style="max-height: 400px; overflow-y: scroll; margin-left:20px">
            <EditForm id="formDriver" Model="@model" OnValidSubmit="Submit">
                <ObjectGraphDataAnnotationsValidator />
                <ValidationSummary />
                <MudGrid>
                    <MudItem xs="12" md="12">
                        <MudTextField Value="model.Driver.DriverName" Label="Name" Variant="Variant.Outlined" Margin="Margin.Dense" Disabled=true></MudTextField>
                    </MudItem>
                    <MudItem xs="12" md="12">
                        <MudTextField @bind-Value="model.Remarks" Label="Remarks" Variant="Variant.Outlined" Lines="3" Margin="Margin.Dense" For="@(() => model.Remarks)"></MudTextField>
                    </MudItem>
                </MudGrid>
            </EditForm>
        </MudContainer>
    </DialogContent>
    <DialogActions>
        <MudButton Disabled="@_busy" form="formDriver" Variant="Variant.Filled" Color="Color.Primary" ButtonType="ButtonType.Submit" Class="px-12">Resign</MudButton>
    </DialogActions>
</MudDialog>

@code {

    [CascadingParameter] MudDialogInstance MudDialog { get; set; }
    [Parameter]
    public DriverResignModel model { get; set; } = new();
    [Parameter]
    public int? DriverID { get; set; }
    private bool _busy;

    public bool HasPermissionDriverServiceRemoveDriver { get; set; } = false;
    public bool HasPermissionDriverServiceResign { get; set; } = false;
    public int DocTypeID = 50;

    // Lifecycle method called when the component is initialized
    protected override async Task OnInitializedAsync()
    {
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionDriverServiceRemoveDriver = await Irole.HasClaim(DocTypeID.ToString(), "RemoveDriver", ctc.Token);
        HasPermissionDriverServiceResign = await Irole.HasClaim(DocTypeID.ToString(), "Resign", ctc.Token);
    }

    void Cancel()
    {
        MudDialog.Cancel();
    }

    // Method to submit the resignation
    public async Task Submit()
    {
        if (_busy)
        {
            Snackbar.Add("Please wait while form is being submitted!", Severity.Warning);
            return;
        }
        if (HasPermissionDriverServiceResign)
        {
            var authprov = await auth.GetAuthenticationStateAsync();
            var user = authprov.User;

            // Attempt to remove the driver from the truck
            string removedFromTruck = Iservice.RemoveDriverFromTruck(model.Driver?.DriverID, user.Identity.Name);
            if (removedFromTruck == "OnTrip")
            {
                await DialogService.ShowMessageBox("Warning", "The Driver is currently on a trip.", yesText: "OK");
                return;
            }
            else if (removedFromTruck == "DriverRemoved")
            {
                Snackbar.Add("Driver removed from the truck", Severity.Warning);
            }
            else
            {
                Snackbar.Add(removedFromTruck, Severity.Error);
            }
            if (removedFromTruck == "NoAssignedTruck" || removedFromTruck == "DriverRemoved")
            {
                _busy = true;
                try
                {
                    // Call the service to process the resignation
                    Iservice.Resign(DriverID, model.Remarks, user.Identity.Name);
                    Snackbar.Add("Driver Resigned successfully", Severity.Success);
                }
                catch (Exception ex)
                {
                    Snackbar.Add(ex.Message, Severity.Error);
                }
            }
            MudDialog.Close(model);
            await Task.Delay(200);
            _busy = false;
        }
        else
        {
            bool? result = await DialogService.ShowMessageBox(
                "Permission denied!",
                "You don't have any permission to Resign Driver.");
        }
    }
}