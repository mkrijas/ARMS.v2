@using System.Threading;
@attribute [Authorize]
@inject AuthenticationStateProvider auth
@inject IPartyService Iparty
@inject IDriverService Iservice
@inject IBranchService Ibranchservice
@inject IAddressService Iaddress
@inject IBankAccountService IbankAccount
@inject IContactService Icontact
@inject IDialogService DialogService
@inject MudBlazor.ISnackbar snackbar
@inject IRoleService<RoleModel> Irole

<style>
    .or-divider {
        text-align: center;
        border-bottom: 1px solid rgba(0, 0, 0, 0.32);
        line-height: 0;
        margin: 0;
    }

    .or-divider span {
        background-color: white;
        padding: 0 10px;
        color: rgba(0, 0, 0, 0.54);
    }
</style>

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.TrackChanges" Class="mr-3 mb-n1" />
            Track Driver
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudGrid>
            <MudItem xs="12" sm="6">
                <MudStack Spacing="8">
                    <MudAutocomplete Style="padding-bottom: 10px;" T="DriverModel" Label="Select Driver" Value="driver" ValueChanged="InputValue" Disabled="@DisableDriver" ResetValueOnEmptyText="true" SearchFunc="@(async (string s, CancellationToken t) => await SearchDrivers(s, t))" ToStringFunc="@(e => (e == null || e.DriverID == null) ? null : $"{e.DriverCode} | {e.DriverName}")" Variant="Variant.Outlined" Margin="Margin.Dense"></MudAutocomplete>
                    
                    <div class="or-divider">
                        <span>OR</span>
                    </div>

                    <MudNumericField HideSpinButtons MaxLength="12" Value="AdhaarNo" ValueChanged="@((string x) => InputValue(x,"AdhaarNo"))" Disabled="@DisableAdhaarNo" Label="ADHAAR No" Variant="Variant.Outlined" Margin="Margin.Dense"></MudNumericField>
                    
                    <div class="or-divider">
                        <span>OR</span>
                    </div>

                    <MudTextField Value="LicenceNo" ValueChanged="@((string x) => InputValue(x,"LicenceNo"))" Disabled="@DisableLicenceNo" Label="DL No" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => licencemodel.LicenceNo)" Mask="@(new PatternMask("aa0000000000000"))" HelperText="Licence Format : KL1120230001111" Class="mt-3"></MudTextField>
                </MudStack>
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudPaper Elevation="0" Class="pa-2">
                    @if (model != null && model.DriverID != null)
                    {
                        <MudStack Spacing="4">
                            <MudText><b>Driver Code :</b> @model.DriverCode</MudText>
                            <MudText><b>Driver Name :</b> @model.DriverName</MudText>
                            <MudText><b>AdhaarNo :</b> @model.AdhaarNo</MudText>
                            <MudText><b>LicenceNo :</b> @model.DriverLicence?.LicenceNo</MudText>
                            <MudText><b>Branch :</b> @Branch</MudText>
                            <MudText><b>Work Period :</b> @WorkPeriod</MudText>
                            <MudText><b>Status :</b> @model.Status</MudText>
                        </MudStack>
                    }
                </MudPaper>
            </MudItem>
        </MudGrid>
    </DialogContent>
    <DialogActions>
        <div style="padding-right:12px; padding-bottom:12px;">
            <MudButton Size="Size.Large" Variant="Variant.Filled" Color="Color.Success" OnClick="ReloadCollection" Class="ml-auto">Track</MudButton>
        </div>
    </DialogActions>
</MudDialog>

@code {

    [CascadingParameter] IMudDialogInstance MudDialog { get; set; }
    public DriverModel driver { get; set; } = new();
    public DriverModel model { get; set; } = new();
    public DriverLicenceModel licencemodel { get; set; } = new();
    private List<DriverModel> drivers;
    private string AdhaarNo;
    private string LicenceNo;
    private string Branch;

    private bool DisableDriver = false;
    private bool DisableAdhaarNo = false;
    private bool DisableLicenceNo = false;

    string WorkPeriod;

    private void Cancel()
    {
        MudDialog.Cancel();
    }

    // Lifecycle method called when the component is initialized
    protected override async Task OnInitializedAsync()
    {
        // Retrieve the list of driversc
        drivers = Iservice.Select().ToList();
    }

    // Method to handle input value changes Aadhaar number and license number
    public async Task InputValue(string Value, string operation)
    {
        if (operation == "AdhaarNo" && (Value != null || Value != ""))
        {
            AdhaarNo = Value;
            DisableDriver = true;
            DisableLicenceNo = true;
        }
        if (operation == "LicenceNo" && (Value != null || Value != ""))
        {
            LicenceNo = Value;
            DisableDriver = true;
            DisableAdhaarNo = true;
        }
        if (Value == null || Value == "")
        {
            DisableDriver = false;
            DisableAdhaarNo = false;
            DisableLicenceNo = false;
        }
        StateHasChanged();
    }

    // Method to handle input value changes for a DriverModel
    public async Task InputValue(DriverModel model)
    {
        driver = model;
        if (model != null)
        {
            DisableAdhaarNo = true;
            DisableLicenceNo = true;
        }
        else
        {
            DisableDriver = false;
            DisableAdhaarNo = false;
            DisableLicenceNo = false;
        }
    }

    // Method to reload the driver collection based on input values
    public void ReloadCollection()
    {
        DriverModel result = new();
        if (driver != null && driver.DriverID != null)
        {
            result = Iservice.FindDriver("GetByDriverID", driver); // Find driver by ID
        }
        if (AdhaarNo != null && AdhaarNo != "")
        {
            result = Iservice.FindDriver("GetByAdhaar", AdhaarNo); // Find driver by Aadhaar number
        }
        if (LicenceNo != null && LicenceNo != "")
        {
            result = Iservice.FindDriver("GetBylicence", LicenceNo); // Find driver by license number
        }
        if (driver != null || AdhaarNo != null || LicenceNo != null)
        {
            if (result.DriverID != null)
            {
                model = new();
                model = result;
                Branch = Ibranchservice.SelectByID(model.HomeBranchID).BranchName; // Get the branch name
                WorkPeriod = Iservice.GetWorkPeriod(model.DriverID); // Get the work period
                StateHasChanged();
            }
            else
            {
                snackbar.Add("No data found", Severity.Error);
                return;
            }
        }
        else
        {
            snackbar.Add("No input given !", Severity.Error);
            return;
        }
    }

    // Method to search for drivers based on a search string
    private async Task<IEnumerable<DriverModel>> SearchDrivers(string searchString, CancellationToken token)
    {
        return await Task.FromResult(drivers.Where(x => x.DriverName.Contains(searchString == null ? string.Empty : searchString, StringComparison.InvariantCultureIgnoreCase)
                                                    || (x.DriverCode.Contains(searchString == null ? string.Empty : searchString, StringComparison.InvariantCultureIgnoreCase))));
    }
}
