@using System.Threading;
@attribute [Authorize]
@inject AuthenticationStateProvider auth
@inject IPartyService Iparty
@inject IDriverService Iservice
@inject IBranchService Ibranchservice
@inject IAddressService Iaddress
@inject IBankAccountService IbankAccount
@inject IContactService Icontact
@inject IDialogService DialogService
@inject MudBlazor.ISnackbar snackbar
@inject IRoleService<RoleModel> Irole

<MudDialog Style="overflow-y: hidden;">
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.TrackChanges" Class="mr-3 mb-n1" />
            Track Driver
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudGrid>
            <MudItem xs="6">
                @* <MudItem xs="12">
                    <MudAutocomplete Style="padding-bottom: 10px;" T="DriverModel" Label="Select Driver" @bind-Value="driver" ResetValueOnEmptyText="true" SearchFunc="SearchDrivers" ToStringFunc="@(e => (e == null || e.DriverID == null) ? null : $"{e.DriverCode} | {e.DriverName}")" Variant="Variant.Outlined" Margin="Margin.Dense"></MudAutocomplete>
                </MudItem> *@
                 <MudItem xs="12">
                    <MudNumericField HideSpinButtons MaxLength="12" @bind-Value="AdhaarNo" Label="ADHAAR No" Variant="Variant.Outlined" Margin="Margin.Dense"></MudNumericField>
                 </MudItem>
                 <MudItem xs="12">
                     <MudTextField @bind-Value="LicenceNo" Label="DL No" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => licencemodel.LicenceNo)" Mask="@(new PatternMask("aa0000000000000"))" HelperText="Licence Format : KL1120230001111" Class="mt-3"></MudTextField>
                 </MudItem>
             </MudItem>
             <MudItem xs="6" Style="padding-top:0px;">
                 <MudItem xs="12">
                     <MudList Style="padding:0px;">
                        @if (model != null && model.DriverID != null)
                        {
                            <MudListItem>
                                <b>Driver Name : @model.DriverName</b>
                            </MudListItem>
                            <MudListItem>
                                <b>Branch : @Branch</b>
                            </MudListItem>
                            <MudListItem>
                                <b>Work Period : @WorkPeriod</b>
                            </MudListItem>
                            <MudListItem>
                                <b>Status : @model.Status</b>
                            </MudListItem>
                        }
                    </MudList>
                </MudItem>
            </MudItem>
        </MudGrid>
    </DialogContent>
    <DialogActions>
        <div style="padding-right:12px; padding-bottom:12px;">
            <MudButton Size="Size.Large" Variant="Variant.Filled" Color="Color.Success" OnClick="ReloadCollection" Class="ml-auto">Track</MudButton>
        </div>
    </DialogActions>
</MudDialog>

@code {

    [CascadingParameter] MudDialogInstance MudDialog { get; set; }
    public DriverModel driver { get; set; } = new();
    public DriverModel model { get; set; } = new();
    public DriverLicenceModel licencemodel { get; set; } = new();
    private List<DriverModel> drivers;
    private string AdhaarNo;
    private string LicenceNo;
    private string Branch;
    string WorkPeriod;

    private void Cancel()
    {
        MudDialog.Cancel();
    }

    protected override async Task OnInitializedAsync()
    {
        drivers = Iservice.Select().ToList();
    }

    public void ReloadCollection()
    {
        model.AdhaarNo = AdhaarNo;
        licencemodel.LicenceNo = LicenceNo;
        if (model.AdhaarNo != null || licencemodel.LicenceNo != null)
        {
            var result = Iservice.FindDriver(model, licencemodel);
            if (result.DriverID != null)
            {
                model = result;
                Branch = Ibranchservice.SelectByID(model.HomeBranchID).BranchName;
                WorkPeriod = Iservice.GetWorkPeriod(model.DriverID);
            }
            else
            {
                snackbar.Add("No data found", Severity.Error);
                return;
            }
        }
        else
        {
            snackbar.Add("Adhar No or Licence No required", Severity.Error);
            return;
        }
    }

    private async Task<IEnumerable<DriverModel>> SearchDrivers(string searchString)
    {
        return await Task.FromResult(drivers.Where(x => x.DriverName.Contains(searchString == null ? string.Empty : searchString, StringComparison.InvariantCultureIgnoreCase)
                                                    || (x.DriverCode.Contains(searchString == null ? string.Empty : searchString, StringComparison.InvariantCultureIgnoreCase))));
    }
}