@using System.Threading;
@inject AuthenticationStateProvider auth
@inject IDriverTransferService Iservice
@inject IBranchService Ibranchservice
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject IRoleService<RoleModel> Irole

<DialogForm @ref="@dialogForm" Title="Transfer Acceptance Protocol" Subtitle="Verify staff credentials and finalize or reject the logistical transfer between branches." Icon="@Icons.Material.Filled.TransferWithinAStation" AdminStyle="true" formID="formDriverTransferEnd" model="@model" _busy="_busy">
    <FormContent>
        <div class="dialog-content-wrapper">
            <EditForm id="formDriverTransferEnd" Model="@model" OnValidSubmit="Accept">
                <ObjectGraphDataAnnotationsValidator />
                
                <div class="admin-glass-card pa-6">
                    <div class="d-flex align-center mb-6">
                        <MudIcon Icon="@Icons.Material.Filled.FactCheck" Color="Color.Primary" Class="mr-2" />
                        <span class="admin-section-label mb-0">Incoming Staff Verification</span>
                    </div>
                    
                    <MudGrid Spacing="3">
                        <MudItem xs="12">
                            <MudTextField Value="model.Driver.DriverName" Label="Personnel Member" Variant="Variant.Outlined" Margin="Margin.Normal" For="@(() => model.Driver.DriverName)" Disabled Class="modern-input" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.PersonOutline"></MudTextField>
                        </MudItem>
                        
                        <MudItem xs="12" md="6">
                            <MudTextField @bind-Value="model.InitiatedBranch.BranchName" Label="Originating Branch" Variant="Variant.Outlined" Margin="Margin.Normal" For="@(() => model.InitiatedBranch.BranchName)" Disabled Class="modern-input" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Business"></MudTextField>
                        </MudItem>
                        
                        <MudItem xs="12" md="6">
                            <MudDatePicker Label="Effective Arrival Date" Variant="Variant.Outlined" Margin="Margin.Normal" DisableToolbar="true" Editable="true" @bind-Date="model.DriverTransferEndModel.TransferEndDate" DateFormat="dd/MM/yyyy" Class="modern-input" AdornmentIcon="@Icons.Material.Filled.EventAvailable" AdornmentColor="Color.Primary" />
                        </MudItem>
                        
                        <MudItem xs="12">
                            <MudTextField @bind-Value="model.DriverTransferEndModel.Remarks" Label="Acceptance/Rejection Remarks" Variant="Variant.Outlined" Margin="Margin.Normal" For="@(() => model.Remarks)" Class="modern-input" Lines="3" Placeholder="Enter any relevant observations..."></MudTextField>
                        </MudItem>
                    </MudGrid>
                </div>
            </EditForm>
        </div>
    </FormContent>
    <Actions>
        <div class="d-flex gap-4">
            <MudButton Disabled="@_busy" Variant="Variant.Filled" Color="Color.Primary" OnClick="Accept" Class="px-12 rounded-pill py-3 shadow-none">Accept Personnel</MudButton>
            @if (model.DriverTransferEndModel.TransferStatus == null)
            {
                <MudButton Disabled="@_busy" Variant="Variant.Filled" Color="Color.Warning" OnClick="Reject" Class="px-12 rounded-pill py-3 shadow-none">Reject Transfer</MudButton>
            }
        </div>
    </Actions>
</DialogForm>

@code {
    DialogForm dialogForm;
    [Parameter]
    public DriverTransferInitiationModel model { get; set; } = new();
    private int branchID { get; set; } = 0;
    private bool _busy;

    public bool HasPermissionDriverTransferEdit { get; set; } = false;
    public int DocTypeID = 49;

    // Lifecycle method called when the component is initialized
    protected override async Task OnInitializedAsync()
    {
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionDriverTransferEdit = await Irole.HasClaim(DocTypeID.ToString(), "Edit", ctc.Token);

        branchID = model?.DestinationBranch?.BranchID ?? 0;
    }

    void Cancel()
    {
        dialogForm.Cancel();
    }

    // Method to accept the driver transfer
    public async Task Accept()
    {
        if (_busy)
        {
            Snackbar.Add("Please wait while form is being submitted!", Severity.Warning);
            return;
        }
        if (HasPermissionDriverTransferEdit)
        {
            var authprov = await auth.GetAuthenticationStateAsync();
            var user = authprov.User;
            if (model.Driver == null || model.Driver.DriverID == 0)
            {
                bool? result = await DialogService.ShowMessageBoxAsync(
                    "Warning",
                    "Please, Select driver.", yesText: "OK");
                return;
            }
            if (model != null)
            {
                _busy = true;
                model.IsdriverReject = 0;
                try
                {
                    model.DriverTransferEndModel.TransferStatus = true;
                    Iservice.UpdateStatus(model); // Update the transfer status in the service
                    Snackbar.Add("Transfered succesfully", Severity.Success);
                }
                catch (Exception ex)
                {
                    Snackbar.Add(ex.Message, Severity.Error);
                }
            }
            dialogForm.Close(model);
            await Task.Delay(200);
            _busy = false;
        }
        else
        {
            bool? ResultModel = await DialogService.ShowMessageBoxAsync(
                "Permission denied!",
                "You don't have any permission to Add or Edit DriverTransfer.");
        }
    }

    // Method to reject the driver transfer
    public async Task Reject()
    {
        if (HasPermissionDriverTransferEdit)
        {
            var authprov = await auth.GetAuthenticationStateAsync();
            var user = authprov.User;
            if (model.Driver == null || model.Driver.DriverID == 0)
            {
                bool? result = await DialogService.ShowMessageBoxAsync(
                    "Warning",
                    "Please, Select truck.", yesText: "OK");
                return;
            }
            if (model != null)
            {
                model.IsdriverReject = 1;
                try
                {
                    model.DriverTransferEndModel.TransferStatus = false;
                    Iservice.UpdateStatus(model); // Update the transfer status in the service
                    Snackbar.Add("Driver Transfer Rejected", Severity.Error);
                }
                catch (Exception ex)
                {
                    Snackbar.Add(ex.Message, Severity.Error);
                }
            }
            dialogForm.Close(model);
        }
        else
        {
            bool? ResultModel = await DialogService.ShowMessageBoxAsync(
                "Permission denied!",
                "You don't have any permission to Add or Edit DriverTransfer.");
        }
    }
}
