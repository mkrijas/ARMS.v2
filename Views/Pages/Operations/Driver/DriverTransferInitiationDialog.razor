@inject IRoleService<RoleModel> Irole
@inject AuthenticationStateProvider auth
@inject IDriverTransferService Iservice
@inject IBranchService Ibranchservice
@inject IDriverService Idriverservice
@inject MudBlazor.ISnackbar Snackbar
@inject IDialogService DialogService

<MudDialog Class="admin-dialog-glass">
    <TitleContent>
        <div class="header-section mb-2 pt-4 px-4">
            <div class="d-flex align-center justify-space-between">
                <div class="d-flex align-center">
                    <div class="icon-badge primary-badge mr-4">
                        <div class="admin-header-icon-badge mb-3">
                            <MudIcon Icon="@Icons.Material.Filled.LocalShipping" Color="Color.Secondary" Style="font-size: 3rem;" />
                        </div>
                    </div>
                    <div>
                        <MudText Typo="Typo.h5" Class="admin-title"><b>Personnel Transfer Initiation</b></MudText>
                        <MudText Typo="Typo.body2" Class="admin-subtitle">Authorize the logistical relocation of driving staff between operational branches.</MudText>
                    </div>
                </div>
            </div>
            <div class="title-accent mt-4"></div>
        </div>
    </TitleContent>
    <DialogContent>
        <MudContainer Class="admin-dialog-container">
            <div class="dialog-content-wrapper pa-4">
                <EditForm id="formDriverTransfer" Model="@model" OnValidSubmit="Submit">
                    <ObjectGraphDataAnnotationsValidator />
                    
                    <div class="admin-glass-card pa-6">
                        <div class="d-flex align-center mb-6">
                            <MudIcon Icon="@Icons.Material.Filled.AssignmentInd" Color="Color.Primary" Class="mr-2" />
                            <span class="admin-section-label mb-0">Transfer Authorization Details</span>
                        </div>
                        
                        <MudGrid Spacing="3">
                            <MudItem xs="12">
                                <MudTextField Value="model.Driver?.DriverName" Label="Staff Member (Read-Only)" Variant="Variant.Outlined" Margin="Margin.Normal" ReadOnly Class="modern-input" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Person"></MudTextField>
                            </MudItem>
                            
                            <MudItem xs="12" md="6">
                                <MudSelect For="@(() => model.DestinationBranch.BranchID)" Label="Target Destination Branch" Variant="Variant.Outlined" Margin="Margin.Normal" @bind-Value="model.DestinationBranch.BranchID" T="int?" AnchorOrigin="Origin.BottomCenter" TransformOrigin="Origin.BottomCenter" AdornmentColor="Color.Secondary" Required Class="modern-input">
                                    @foreach (BranchModel ditem in DestinationBranchList)
                                    {
                                        <MudSelectItem Value="@ditem.BranchID">@ditem.BranchName</MudSelectItem>
                                    }
                                </MudSelect>
                            </MudItem>
                            
                            <MudItem xs="12" md="6">
                                <MudDatePicker Label="Effective Initiation Date" Variant="Variant.Outlined" Margin="Margin.Normal" DisableToolbar="true" Editable="true" @bind-Date="model.TransferInitiatedDate" DateFormat="dd/MM/yyyy" Class="modern-input" AdornmentIcon="@Icons.Material.Filled.DateRange" AdornmentColor="Color.Primary" />
                            </MudItem>
                            
                            <MudItem xs="12">
                                <MudTextField @bind-Value="model.Remarks" Label="Transfer Justification / Logistical Remarks" Variant="Variant.Outlined" Margin="Margin.Normal" For="@(() => model.Remarks)" Class="modern-input" Lines="3" Placeholder="Provide context for the transfer..."></MudTextField>
                            </MudItem>
                        </MudGrid>
                    </div>
                </EditForm>
            </div>
        </MudContainer>
    </DialogContent>
    <DialogActions>
        <div class="d-flex w-100 flex-wrap pa-4 gap-3 align-center">
            <MudSpacer />
            <MudButton @onclick="Cancel" Variant="Variant.Outlined" Color="Color.Default" Style="border-radius: 12px; font-weight: 700; text-transform: none; border-color: rgba(0,0,0,0.15);">Discard</MudButton>
            <MudButton Disabled="@_busy" form="formDriverTransfer" Variant="Variant.Filled" Color="Color.Success" ButtonType="ButtonType.Submit" Style="background: var(--mud-palette-success); color: white; font-weight: 800; border-radius: 12px; text-transform: none; white-space: nowrap; padding: 8px 32px;" StartIcon="@Icons.Material.Filled.Send">Authorize Relocation</MudButton>
        </div>
    </DialogActions>
</MudDialog>

@code {

    [CascadingParameter] IMudDialogInstance MudDialog { get; set; }
    [Parameter]
    public DriverTransferInitiationModel model { get; set; } = new();
    [Parameter]
    public int? DriverID { get; set; }
    private List<BranchModel> DestinationBranchList = new();
    private int BranchID { get; set; } = 0;
    private bool _busy;

    public bool HasPermissionDriverTransferEdit { get; set; } = false;
    public int DocTypeID = 49;

    // Lifecycle method called when the component is initializedc
    protected override async Task OnInitializedAsync()
    {
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionDriverTransferEdit = await Irole.HasClaim(DocTypeID.ToString(), "Edit", ctc.Token);

        var authprov = await auth.GetAuthenticationStateAsync();
        var User = authprov.User;
        if (model.InitiatedBranch == null)
        {
            model.InitiatedBranch = new();
            model.InitiatedBranch.BranchID = int.Parse(User.Claims.First(x => x.Type == "BranchID").Value);
        }
        if (model.DestinationBranch == null)
        {
            model.DestinationBranch = new();
        }
        if (model.Driver == null)
        {
            model.Driver = new();
        }
        BranchID = model?.InitiatedBranch?.BranchID ?? 0;
        // Retrieve the list of destination branches excluding the current branch
        DestinationBranchList = Ibranchservice.Select().Where(d => d.BranchID != BranchID).ToList();
    }

    void Cancel()
    {
        MudDialog.Cancel();
    }

    // Method to submit the driver transfer
    public async Task Submit()
    {
        if (_busy)
        {
            Snackbar.Add("Please wait while form is being submitted!", Severity.Warning);
            return;
        }
        if (HasPermissionDriverTransferEdit)
        {
            var authprov = await auth.GetAuthenticationStateAsync();
            var user = authprov.User;
            var brancIDString = authprov.User.Claims.First(x => x.Type == "BranchID").Value;
            if (model.Driver == null || model.Driver.DriverID == 0)
            {
                await DialogService.ShowMessageBoxAsync(
                    "Warning",
                    "Please, Select Driver.",
                    yesText: "OK");
                return;
            }

            // Attempt to remove the driver from the truck
            string removedFromTruck = Idriverservice.RemoveDriverFromTruck(model.Driver?.DriverID, user.Identity.Name);
            if (removedFromTruck == "OnTrip")
            {
                await DialogService.ShowMessageBoxAsync("Warning", "The Driver is currently on a trip.", yesText: "OK");
                return;
            }
            if (removedFromTruck == "NoAssignedTruck" || removedFromTruck == "DriverRemoved")
            {
                try
                {
                    model.InitiatedBranch.BranchID = int.Parse(brancIDString);
                    if (model.DestinationBranch == null || model.DestinationBranch.BranchID == null)
                    {
                        await DialogService.ShowMessageBoxAsync(
                            "Warning",
                            "Select branch !.",
                            yesText: "OK");
                        return;
                    }
                    _busy = true;
                    Iservice.UpdateOutgoing(model); // Update the transfer status in the service
                    Snackbar.Add("Transferred successfully", Severity.Success);
                    MudDialog.Close(DialogResult.Ok(model));
                }
                catch (Exception ex)
                {
                    Snackbar.Add(ex.Message, Severity.Error);
                }
                finally
                {
                    await Task.Delay(200);
                    _busy = false;
                }
            }
        }
        else
        {
            await DialogService.ShowMessageBoxAsync(
                "Permission denied!",
                "You don't have any permission to Add or Edit DriverTransfer.");
        }
    }

    // Method to handle driver selection
    private async Task DriverSelected(DriverModel obj)
    {
        model.Driver = obj;
    }
}
