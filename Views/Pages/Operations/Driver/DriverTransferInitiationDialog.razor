@inject AuthenticationStateProvider auth
@inject IDriverTransferService Iservice
@inject IDriverService Idriverservice
@inject ITruckService Itruckservice
@inject ITripService Itripservice
@inject IBranchService Ibranchservice
@inject IDialogService DialogService
@inject ISnackbar Snackbar

@using System.Threading;
@inject IRoleService<RoleModel> Irole

<MudDialog>
    <TitleContent>
        @if (model.DriverTransferID == null || model.DriverTransferID == 0)
        {
            <MudText Typo="Typo.h6">
                <MudIcon Icon="@Icons.Material.Filled.Edit" Class="mr-3" /> Driver Transfer Initiation.
            </MudText>
        }
        else
        {
            <MudText Typo="Typo.h6">
                <MudIcon Icon="@Icons.Material.Filled.Edit" Class="mr-3" /> Edit Driver Transfer Initiation.
            </MudText>
        }
    </TitleContent>
    <DialogContent>

        <MudContainer Style="max-height: 400px; overflow-y: scroll; margin-left:20px">
            <EditForm id="formDriver" Model="@model" OnValidSubmit="Submit">
                <ObjectGraphDataAnnotationsValidator />
                <ValidationSummary />
                <MudGrid>
                    <MudItem xs="12" md="12">
                        <MudTextField Value="model.Driver?.DriverName" Label="Name" Variant="Variant.Outlined" Margin="Margin.Dense"></MudTextField>
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudSelect Label="Destination Branch" Variant="Variant.Outlined" Margin="Margin.Dense" @bind-Value="model.DestinationBranch.BranchID" T="int?" AnchorOrigin="Origin.TopCenter" TransformOrigin="Origin.TopCenter" AdornmentColor="Color.Secondary" Required>
                            @foreach (BranchModel ditem in DestinationBranchList)
                            {
                                <MudSelectItem Value="@ditem.BranchID">@ditem.BranchName</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudDatePicker Label="Initiated Date" Variant="Variant.Outlined" Margin="Margin.Dense" DisableToolbar="true" Editable="true" @bind-Date="model.TransferInitiatedDate" DateFormat="dd/MM/yyyy" />
                    </MudItem>
                    <MudItem xs="12" md="12">
                        <MudTextField @bind-Value="model.Remarks" Label="Remarks" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.Remarks)"></MudTextField>
                    </MudItem>
                </MudGrid>

            </EditForm>
        </MudContainer>

    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Submit" Class="px-12">Submit</MudButton>
    </DialogActions>
</MudDialog>

@code {

    [CascadingParameter] MudDialogInstance MudDialog { get; set; }

    [Parameter]
    public DriverTransferInitiationModel model { get; set; } = new();
    [Parameter]
    public int? DriverID { get; set; }


    private List<BranchModel> DestinationBranchList = new();
    private int BranchID { get; set; } = 0;

    public bool HasPermissionTransferEdit { get; set; } = false;
    public int DocTypeID = 35;

    protected override async Task OnInitializedAsync()
    {
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionTransferEdit = await Irole.HasClaim(DocTypeID.ToString(), "Edit", ctc.Token);

        var authprov = await auth.GetAuthenticationStateAsync();
        var User = authprov.User;
        if (model.InitiatedBranch == null)
        {
            model.InitiatedBranch = new();
            model.InitiatedBranch.BranchID = int.Parse(User.Claims.First(x => x.Type == "BranchID").Value);
        }
        if (model.DestinationBranch == null)
        {
            model.DestinationBranch = new();
        }
        if (model.Driver == null)
        {
            model.Driver = new();
        }
        BranchID = model?.InitiatedBranch?.BranchID ?? 0;

        DestinationBranchList = Ibranchservice.Select().Where(d => d.BranchID != BranchID).ToList();
    }


    void Cancel()
    {
        MudDialog.Cancel();
    }


    public async Task Submit()
    {
        if (HasPermissionTransferEdit)
        {
            var authprov = await auth.GetAuthenticationStateAsync();
            var user = authprov.User;
            var brancIDString = authprov.User.Claims.First(x => x.Type == "BranchID").Value;

            if (model.Driver == null || model.Driver.DriverID == 0)
            {
                bool? result = await DialogService.ShowMessageBox(
                    "Warning",
                    "Please, Select Driver.",
                    yesText: "OK");
                return;
            }

            string removedFromTruck = Idriverservice.RemoveDriverFromTruck(model.Driver?.DriverID, user.Identity.Name);

            if (removedFromTruck == "OnTrip")
            {
                await DialogService.ShowMessageBox("Warning", "The Driver is currently on a trip.", yesText: "OK");
                return;
            }
            else if (removedFromTruck == "DriverRemoved")
            {
                Snackbar.Add("Driver removed from the truck", Severity.Warning);
            }
            else
            {
                Snackbar.Add(removedFromTruck, Severity.Error);

            }
            if (removedFromTruck == "NoAssignedTruck" || removedFromTruck == "DriverRemoved")
            {

                try
                {
                    model.InitiatedBranch.BranchID = int.Parse(brancIDString);

                    if (model.DestinationBranch == null)
                    {
                        bool? result = await DialogService.ShowMessageBox(
                              "Warning",
                              "Select branch !.",
                              yesText: "OK");
                        return;
                    }
                    Iservice.UpdateOutgoing(model);
                    Snackbar.Add("Transferred successfully", Severity.Success);
                }
                catch (Exception ex)
                {
                    Snackbar.Add(ex.Message, Severity.Error);
                }
            }
            MudDialog.Close(model);
        }
        else
        {
            bool? result = await DialogService.ShowMessageBox(
               "Permission denied!",
               "You dont have any permission to submit.");
        }
    }


    private async Task DriverSelected(DriverModel obj)
    {
        model.Driver = obj;
    }

}

