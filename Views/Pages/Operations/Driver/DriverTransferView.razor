@page "/DriverTransferView"
@using System.Threading;
@using ArmsModels.BaseModels.General
@using ArmsServices.DataServices.General
@using Microsoft.AspNetCore.SignalR.Client;
@using Views.Data
@attribute [Authorize]
@inject AuthenticationStateProvider auth
@inject IDriverTransferService Iservice
@inject IPushNotificationService IpushNotificationService
@inject MudBlazor.ISnackbar snackbar
@inject IDialogService DialogService
@inject IBranchService Ibranchservice
@inject NavigationManager NavigationManager
@inject SignalRService signalRService
@inject IRoleService<RoleModel> Irole

<div class="admin-page-container">
    <div class="admin-header-tiered mb-6">
        <div class="d-flex align-center justify-space-between">
            <div>
                <MudText Typo="Typo.h4" Class="admin-title">Logistical Driver Mobility</MudText>
                <MudText Typo="Typo.body2" Class="admin-subtitle">Coordinate inter-branch driver transfers and monitor technical transit statuses.</MudText>
            </div>
            <MudButton StartIcon="@Icons.Material.Filled.Add" Variant="Variant.Filled" Color="Color.Primary" Class="admin-register-btn" OnClick="@(()=> OpenDialogEditOutGoing(new DriverTransferInitiationModel()))">INITIATE TRANSFER</MudButton>
        </div>
    </div>

    <div class="admin-glass-card pa-0 overflow-hidden">
        <MudTabs Elevation="0" Rounded="false" ApplyEffectsToContainer="true" Class="modern-tabs">
            <MudTabPanel Text="OUTGOING TRANSFERS">
                <MudTable Items="@collectionOutGoing" Elevation="0" Class="modern-admin-table" Dense="false" Hover="true">
                    <HeaderContent>
                        <MudTh><MudTableSortLabel SortBy="new Func<DriverTransferInitiationModel, object>(x=> x.Driver.DriverName)" InitialDirection="SortDirection.Ascending"><span class="admin-header-text">DRIVER SPECIFICATION</span></MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<DriverTransferInitiationModel, object>(x=> x.DestinationBranch.BranchName)" InitialDirection="SortDirection.Ascending"><span class="admin-header-text">DESTINATION NODE</span></MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<DriverTransferInitiationModel, object>(x=> x.TransferInitiatedDate)" InitialDirection="SortDirection.Ascending"><span class="admin-header-text">INITIATION DATE</span></MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<DriverTransferInitiationModel, object>(x=> x.DriverTransferEndModel.StatusText)" InitialDirection="SortDirection.Ascending"><span class="admin-header-text">LIFECYCLE STATUS</span></MudTableSortLabel></MudTh>
                        @* <MudTh><MudTableSortLabel SortBy="new Func<DriverTransferInitiationModel, object>(x=> x.Remarks)" InitialDirection="SortDirection.Ascending"><span class="admin-header-text">REMARKS</span></MudTableSortLabel></MudTh> *@
                        <MudTh Style="text-align: right;"><span class="admin-header-text">ACTIONS</span></MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="Driver">
                            <div class="d-flex align-center">
                                <MudIcon Icon="@Icons.Material.Filled.AccountCircle" Color="Color.Primary" Class="mr-3" />
                                <span class="admin-td-primary fw-600">@context.Driver.DriverName</span>
                            </div>
                        </MudTd>
                        <MudTd DataLabel="Destination Branch">@context.DestinationBranch.BranchName</MudTd>
                        <MudTd DataLabel="Date">@context.TransferInitiatedDate?.ToString("dd MMM yyyy")</MudTd>
                        <MudTd DataLabel="Status">
                            <MudChip T="string" Size="Size.Small" Color="@(context.DriverTransferEndModel.StatusText?.Contains("Accepted") == true ? Color.Success : Color.Warning)" Variant="Variant.Text" Class="fw-700">@context.DriverTransferEndModel.StatusText</MudChip>
                        </MudTd>
                        @* <MudTd DataLabel="Remarks">@context.Remarks</MudTd> *@
                        <MudTd DataLabel="Actions" Style="text-align: right;">
                             <MudTooltip Text="Edit Parameters">
                                <MudIconButton @onclick="@(()=> OpenDialogEditOutGoing(context))" Color="Color.Primary" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Variant="Variant.Text" />
                            </MudTooltip>
                            <MudTooltip Text="Abort Transfer">
                                <MudIconButton @onclick="@(()=> OpenDialogDeleteOutGoing(context))" Color="Color.Error" Icon="@Icons.Material.Filled.Cancel" Size="Size.Small" Variant="Variant.Text" />
                            </MudTooltip>
                        </MudTd>
                    </RowTemplate>
                    <PagerContent>
                        <div class="pa-4">
                            <MudTablePager PageSizeOptions="new int[] { 10, 20, 50, 100 }" />
                        </div>
                    </PagerContent>
                </MudTable>
            </MudTabPanel>
            <MudTabPanel Text="INCOMING REQUISITIONS">
                <MudTable Items="@collectionIncoming" Elevation="0" Class="modern-admin-table" Dense="false" Hover="true">
                    <HeaderContent>
                        <MudTh><MudTableSortLabel SortBy="new Func<DriverTransferInitiationModel, object>(x=> x.Driver.DriverName)" InitialDirection="SortDirection.Ascending"><span class="admin-header-text">DRIVER SPECIFICATION</span></MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<DriverTransferInitiationModel, object>(x=> x.InitiatedBranch.BranchName)" InitialDirection="SortDirection.Ascending"><span class="admin-header-text">ORIGIN BRANCH</span></MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<DriverTransferInitiationModel, object>(x=> x.DriverTransferEndModel.StatusText)" InitialDirection="SortDirection.Ascending"><span class="admin-header-text">TRANSFER STATUS</span></MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<DriverTransferInitiationModel, object>(x=> x.TransferInitiatedDate)" InitialDirection="SortDirection.Ascending"><span class="admin-header-text">OFFER DATE</span></MudTableSortLabel></MudTh>
                        @* <MudTh><MudTableSortLabel SortBy="new Func<DriverTransferInitiationModel, object>(x=> x.Remarks)" InitialDirection="SortDirection.Ascending"><span class="admin-header-text">REMARKS</span></MudTableSortLabel></MudTh> *@
                        <MudTh Style="text-align: right;"><span class="admin-header-text">ACTIONS</span></MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="Driver">
                             <div class="d-flex align-center">
                                <MudIcon Icon="@Icons.Material.Filled.Person" Color="Color.Secondary" Class="mr-3" />
                                <span class="admin-td-primary fw-600">@context.Driver.DriverName</span>
                            </div>
                        </MudTd>
                        <MudTd DataLabel="Initiated Branch">@context.InitiatedBranch.BranchName</MudTd>
                        <MudTd DataLabel="Transfer Status">
                             <MudChip T="string" Size="Size.Small" Color="Color.Info" Variant="Variant.Text" Class="fw-700">@context.DriverTransferEndModel.StatusText</MudChip>
                        </MudTd>
                        <MudTd DataLabel="Date">@context.TransferInitiatedDate?.ToString("dd MMM yyyy")</MudTd>
                        @* <MudTd DataLabel="Remarks">@context.Remarks</MudTd> *@
                        <MudTd DataLabel="Actions" Style="text-align: right;">
                            <MudTooltip Text="Process Requisition">
                                <MudIconButton @onclick="@(()=> OpenDialogEditIncoming(context))" Color="Color.Primary" Icon="@Icons.Material.Filled.HowToReg" Size="Size.Small" Variant="Variant.Text" />
                            </MudTooltip>
                        </MudTd>
                    </RowTemplate>
                    <PagerContent>
                        <div class="pa-4">
                            <MudTablePager PageSizeOptions="new int[] { 10, 20, 50, 100 }" />
                        </div>
                    </PagerContent>
                </MudTable>
            </MudTabPanel>
        </MudTabs>
    </div>
</div>

@code {

    int CurrentBranchId = 0;
    private List<BranchModel> BranchList = new();

    #region SignaIR Notification

    private PushNotificationModel notificationMessage = new PushNotificationModel();

    #endregion
    private bool _busy;
    public bool HasPermissionDriverTransferEdit { get; set; } = false;
    public bool HasPermissionDriverTransferDelete { get; set; } = false;
    public int DocTypeID = 49;

    // Lifecycle method called when the component is initialized
    protected override async Task OnInitializedAsync()
    {
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionDriverTransferEdit = await Irole.HasClaim(DocTypeID.ToString(), "Edit", ctc.Token);
        HasPermissionDriverTransferDelete = await Irole.HasClaim(DocTypeID.ToString(), "Edit", ctc.Token);

        // Retrieve the list of branches from the service
        BranchList = Ibranchservice.Select().ToList();
        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;
        var brancIDString = authprov.User.Claims.First(x => x.Type == "BranchID").Value;
        CurrentBranchId = int.Parse(brancIDString);
        await signalRService.StartAsync();

        // hubConnection = new HubConnectionBuilder().WithUrl(NavigationManager.ToAbsoluteUri("/chatHub")).Build();
        // signalRService.RegisterReceivedMessage(e => Receive(e));
        // await hubConnection.StartAsync();

        await GetAllOutGoing();
        await GetAllIncoming();
    }

    // Method to retrieve all outgoing and incoming transfers
    private async Task GetAll()
    {
        await GetAllOutGoing();
        await GetAllIncoming();
    }

    #region Outgoing

    private DriverTransferInitiationModel modelOutGoing = new();
    private List<DriverTransferInitiationModel> collectionOutGoing = new();

    string state = "Message box hasn't been opened yet";

    // Method to open the dialog for editing outgoing transfers
    private async Task OpenDialogEditOutGoing(DriverTransferInitiationModel DriverTransferInitiation)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        _busy = true;
        if (HasPermissionDriverTransferEdit)
        {
            var authprov = await auth.GetAuthenticationStateAsync();
            var user = authprov.User;
            var brancIDString = authprov.User.Claims.First(x => x.Type == "BranchID").Value;

            if (DriverTransferInitiation.InitiatedBranch == null)
            {
                DriverTransferInitiation.InitiatedBranch = new();
            }
            if (DriverTransferInitiation.DestinationBranch == null)
            {
                DriverTransferInitiation.DestinationBranch = new();
            }
            DriverTransferInitiation.InitiatedBranch.BranchID = int.Parse(brancIDString);
            var modelOutGoing = new DialogParameters { ["model"] = DriverTransferInitiation.Clone() };
            var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Medium };
            var dialog = await DialogService.ShowAsync<DriverTransferInitiationDialog>("Simple Dialog", modelOutGoing, options);
            var result = await dialog.Result;
            var isCancelled = result.Canceled;
            if (!isCancelled)
            {
                var ReturnData = (DriverTransferInitiationModel)result.Data;
                notificationMessage.InitiateBranch = BranchList?.FirstOrDefault(s => s.BranchID == Convert.ToInt32(ReturnData?.InitiatedBranch?.BranchID ?? 0)) ?? null;
                notificationMessage.ReceivedBranch = BranchList?.FirstOrDefault(s => s.BranchID == Convert.ToInt32(ReturnData?.DestinationBranch?.BranchID ?? 0)) ?? null;
                notificationMessage.MessageTitle = "Driver " + (ReturnData?.Driver?.DriverName ?? "") + " is transfered to this branch.";
                notificationMessage.MessageBody = "Driver " + (ReturnData?.Driver?.DriverName ?? "") + " is transfered from " + (notificationMessage?.InitiateBranch?.BranchName ?? "") + " to this branch on " + (DateTime.Now).ToString() + ".";
                notificationMessage.RedirectedTo = 0;
                notificationMessage.ExpiredBy = 7;
                notificationMessage.DocumentID = ReturnData.DriverTransferID;
                notificationMessage.MessageGroupID = "DriverTransfer";
                notificationMessage.PageToRedirectLink = "/DriverTransferView";
                notificationMessage.ClaimValue = "Edit";
                notificationMessage.DocumentTypeID = DocTypeID;
                notificationMessage.MsgDate = DateTime.Now;
                await signalRService.Send(notificationMessage);

                await GetAll();
            }
        }
        else
        {
            bool? ResultModel = await DialogService.ShowMessageBoxAsync(
                "Permission denied!",
                "You don't have any permission to Add or Edit DriverTransfer.");
        }
        await Task.Delay(200);
        _busy = false;
    }

    // Method to open the dialog for deleting outgoing transfers
    private async Task OpenDialogDeleteOutGoing(DriverTransferInitiationModel DriverTransferInitiation)
    {
        if (HasPermissionDriverTransferDelete)
        {
            bool? result = await DialogService.ShowMessageBoxAsync(
                "Warning",
                "Are you sure you want to delete this entry?",
                yesText: "Delete!", cancelText: "Cancel");
            state = result == null ? "Cancelled" : "Deleted!";
            if (state == "Deleted!")
            {
                var authprov = await auth.GetAuthenticationStateAsync();
                var user = authprov.User;
                var brancIDString = authprov.User.Claims.First(x => x.Type == "BranchID").Value;
                try
                {
                    var BranchID = int.Parse(brancIDString);

                    // Call the service to delete the transfer initiation
                    Iservice.DeleteInitiation(DriverTransferInitiation.DriverTransferID, BranchID, DriverTransferInitiation.Driver.DriverID);
                    snackbar.Add("Driver Transfer Canceled", Severity.Warning);
                }
                catch (Exception ex)
                {
                    snackbar.Add(ex.Message, Severity.Error);
                }
                await GetAll();
            }
        }
        else
        {
            bool? ResultModel = await DialogService.ShowMessageBoxAsync(
                "Permission denied!",
                "You don't have any permission to Delete DriverTransfer.");
        }
    }

    // Method to retrieve all outgoing driver transfers
    private async Task GetAllOutGoing()
    {
        collectionOutGoing = new();
        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;
        var brancIDString = authprov.User.Claims.First(x => x.Type == "BranchID").Value;
        if (modelOutGoing.InitiatedBranch == null)
        {
            modelOutGoing.InitiatedBranch = new();
        }
        modelOutGoing.InitiatedBranch.BranchID = int.Parse(brancIDString);

        // Retrieve all outgoing drivers for the current branch
        foreach (var item in Iservice.SelectOutgoingDrivers(modelOutGoing.InitiatedBranch.BranchID))
        {
            collectionOutGoing.Add(item);
        }
    }

    #endregion

    #region Incoming

    private DriverTransferInitiationModel modelIncoming = new();
    private List<DriverTransferInitiationModel> collectionIncoming = new();

    // Method to open the dialog for editing incoming transfers
    private async Task OpenDialogEditIncoming(DriverTransferInitiationModel DriverTransferEnd)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        _busy = true;
        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;
        var brancIDString = authprov.User.Claims.First(x => x.Type == "BranchID").Value;
        if (DriverTransferEnd.DriverTransferEndModel == null)
        {
            DriverTransferEnd.DriverTransferEndModel = new();
        }
        if (DriverTransferEnd.DestinationBranch == null)
        {
            DriverTransferEnd.DestinationBranch = new();
        }
        DriverTransferEnd.DestinationBranch.BranchID = int.Parse(brancIDString);
        if (DriverTransferEnd.DriverTransferEndModel == null)
        {
            DriverTransferEnd.DriverTransferEndModel = new DriverTransferEndModel();
        }
        DriverTransferEnd.DriverTransferEndModel.TransferEndDate = DateTime.Now;
        var modelIncoming = new DialogParameters { ["model"] = DriverTransferEnd.Clone() };
        var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Medium };
        var dialog = await DialogService.ShowAsync<DriverTransferEndDialog>("Simple Dialog", modelIncoming, options);
        var result = await dialog.Result;
        var isCancelled = result.Canceled;
        if (!isCancelled)
        {
            var ReturnData = (DriverTransferInitiationModel)result.Data;
            if (ReturnData.IsdriverReject == 1)
            {
                notificationMessage.InitiateBranch = BranchList?.FirstOrDefault(s => s.BranchID == Convert.ToInt32(ReturnData?.DestinationBranch?.BranchID ?? 0)) ?? null;
                notificationMessage.ReceivedBranch = BranchList?.FirstOrDefault(s => s.BranchID == Convert.ToInt32(ReturnData?.InitiatedBranch?.BranchID ?? 0)) ?? null;
                notificationMessage.MessageTitle = "Driver " + (ReturnData?.Driver?.DriverName ?? "") + " is rejected.";
                notificationMessage.MessageBody = "Driver " + (ReturnData?.Driver?.DriverName ?? "") + " is rejected from " + (notificationMessage?.InitiateBranch?.BranchName ?? "") + " on " + (DateTime.Now).ToString() + ".";
                notificationMessage.RedirectedTo = 0;
                notificationMessage.MsgDate = DateTime.Now;
                notificationMessage.ExpiredBy = 7;
                notificationMessage.DocumentID = ReturnData.DriverTransferID;
                notificationMessage.MessageGroupID = "DriverTransfer";
                notificationMessage.PageToRedirectLink = "/DriverTransferView";
                notificationMessage.ClaimValue = "Edit";
                notificationMessage.DocumentTypeID = DocTypeID;
                await signalRService.Send(notificationMessage);
            }
            await GetAll();
        }
        await Task.Delay(200);
        _busy = false;
    }

    // Method to retrieve all incoming driver transfers
    private async Task GetAllIncoming()
    {
        collectionIncoming = new();
        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;
        var brancIDString = authprov.User.Claims.First(x => x.Type == "BranchID").Value;
        if (modelIncoming.DriverTransferEndModel == null)
        {
            modelIncoming.DriverTransferEndModel = new();
        }
        if (modelIncoming.DestinationBranch == null)
        {
            modelIncoming.DestinationBranch = new();
        }
        modelIncoming.DestinationBranch.BranchID = int.Parse(brancIDString);
        foreach (var item in Iservice.SelectIncomingDrivers(modelIncoming.DestinationBranch?.BranchID ?? 0))
        {
            collectionIncoming.Add(item);
        }
    }
    #endregion
}
