@page "/DriverTransferView"

@using ArmsModels.BaseModels.General
@using ArmsServices.DataServices.General
@using Microsoft.AspNetCore.SignalR.Client;
@using Views.Data

@inject IDriverTransferService Iservice
@inject IPushNotificationService IpushNotificationService
@inject MudBlazor.ISnackbar snackbar

@inject AuthenticationStateProvider auth
@attribute [Authorize]
@inject IDialogService DialogService
@inject IBranchService Ibranchservice
@inject NavigationManager NavigationManager
@inject SignalRService signalRService

@using System.Threading;
@inject IRoleService<RoleModel> Irole

<MudGrid Spacing="4">
    <MudItem xs="12">
        <MudTabs Elevation="2" Rounded="true" ApplyEffectsToContainer="true" PanelClass="pa-6">
            <MudTabPanel Text="Driver Transfer Outgoing">
                <MudTable Items="@collectionOutGoing" Dense="true" Hover="true" Striped="true" Elevation="0" @bind-place="modelOutGoing">
                    <HeaderContent>
                        <MudTh><MudTableSortLabel SortBy="new Func<DriverTransferInitiationModel, object>(x=> x.Driver.DriverName)" InitialDirection="SortDirection.Ascending">Driver</MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<DriverTransferInitiationModel, object>(x=> x.DestinationBranch.BranchName)" InitialDirection="SortDirection.Ascending">Destination Branch</MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<DriverTransferInitiationModel, object>(x=> x.TransferInitiatedDate)" InitialDirection="SortDirection.Ascending">Date</MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<DriverTransferInitiationModel, object>(x=> x.DriverTransferEndModel.StatusText)" InitialDirection="SortDirection.Ascending">Status</MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<DriverTransferInitiationModel, object>(x=> x.Remarks)" InitialDirection="SortDirection.Ascending">Remarks</MudTableSortLabel></MudTh>
                        <MudTh>Actions</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="Driver">@context.Driver.DriverName</MudTd>
                        <MudTd DataLabel="Destination Branch">@context.DestinationBranch.BranchName</MudTd>
                        <MudTd DataLabel="Date">@context.TransferInitiatedDate</MudTd>
                        <MudTd DataLabel="Status">@context.DriverTransferEndModel.StatusText</MudTd>
                        <MudTd DataLabel="Remarks">@context.Remarks</MudTd>
                        <MudTd DataLabel="">
                            <MudTooltip Text="Edit">
                                <MudIconButton @onclick="@(()=> OpenDialogEditOutGoing(context))" Color="Color.Primary" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" IconSize="Size.Small" />
                            </MudTooltip>
                            <MudTooltip Text="Cancel">
                                <MudIconButton @onclick="@(()=> OpenDialogDeleteOutGoing(context))" Color="Color.Primary" Icon="@Icons.Material.Filled.Cancel" Size="Size.Small" IconSize="Size.Small" />
                            </MudTooltip>
                        </MudTd>
                    </RowTemplate>

                    <PagerContent>
                        <MudTablePager PageSizeOptions="new int[] { 5, 10, 20, 50, 100 }" />
                    </PagerContent>

                </MudTable>
            </MudTabPanel>

            <MudTabPanel Text="Driver Transfer Incoming">
                <MudTable Items="@collectionIncoming" Dense="true" Hover="true" Striped="true" Elevation="0" @bind-place="modelIncoming">

                    <HeaderContent>
                        <MudTh><MudTableSortLabel SortBy="new Func<DriverTransferInitiationModel, object>(x=> x.Driver.DriverName)" InitialDirection="SortDirection.Ascending">Driver</MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<DriverTransferInitiationModel, object>(x=> x.InitiatedBranch.BranchName)" InitialDirection="SortDirection.Ascending">Initiated Branch</MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<DriverTransferInitiationModel, object>(x=> x.DriverTransferEndModel.StatusText)" InitialDirection="SortDirection.Ascending">Transfer Status</MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<DriverTransferInitiationModel, object>(x=> x.TransferInitiatedDate)" InitialDirection="SortDirection.Ascending">Date</MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<DriverTransferInitiationModel, object>(x=> x.Remarks)" InitialDirection="SortDirection.Ascending">Remarks</MudTableSortLabel></MudTh>
                        <MudTh>Actions</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="Driver">@context.Driver.DriverName</MudTd>
                        <MudTd DataLabel="Initiated Branch">@context.InitiatedBranch.BranchName</MudTd>
                        <MudTd DataLabel="Transfer Status">@context.DriverTransferEndModel.StatusText</MudTd>
                        <MudTd DataLabel="Date">@context.TransferInitiatedDate</MudTd>
                        <MudTd DataLabel="Remarks">@context.Remarks</MudTd>
                        <MudTd DataLabel="">
                            <MudTooltip Text="Edit">
                                <MudIconButton @onclick="@(()=> OpenDialogEditIncoming(context))" Color="Color.Primary" Icon="@Icons.Material.Filled.HowToReg" Size="Size.Small" IconSize="Size.Small" />
                            </MudTooltip>
                        </MudTd>
                    </RowTemplate>

                    <PagerContent>
                        <MudTablePager PageSizeOptions="new int[] { 5, 10, 20, 50, 100 }" />
                    </PagerContent>

                </MudTable>
            </MudTabPanel>
        </MudTabs>
    </MudItem>
</MudGrid>

@code {

    int CurrentBranchId = 0;

    private List<BranchModel> BranchList = new();

    #region SignaIR Notification

    private PushNotificationModel notificationMessage = new PushNotificationModel();

    #endregion

    public bool HasPermissionDriverTransferEdit { get; set; } = false;
    public bool HasPermissionDriverTransferDelete { get; set; } = false;
    public int DocTypeID = 49;

    protected override async Task OnInitializedAsync()
    {
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionDriverTransferEdit = await Irole.HasClaim(DocTypeID.ToString(), "Edit", ctc.Token);
        HasPermissionDriverTransferDelete = await Irole.HasClaim(DocTypeID.ToString(), "Edit", ctc.Token);


        BranchList = Ibranchservice.Select().ToList();
        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;
        var brancIDString = authprov.User.Claims.First(x => x.Type == "BranchID").Value;

        CurrentBranchId = int.Parse(brancIDString);

        await signalRService.StartAsync();

        // hubConnection = new HubConnectionBuilder().WithUrl(NavigationManager.ToAbsoluteUri("/chatHub")).Build();
        // signalRService.RegisterReceivedMessage(e => Receive(e));

        // await hubConnection.StartAsync();

        
        await GetAllOutGoing();
        await GetAllIncoming();
    }


    private async Task GetAll()
    {

        await GetAllOutGoing();
        await GetAllIncoming();
    }


    #region Outgoing



    private DriverTransferInitiationModel modelOutGoing = new();

    private List<DriverTransferInitiationModel> collectionOutGoing = new();

    string state = "Message box hasn't been opened yet";

    private async Task OpenDialogEditOutGoing(DriverTransferInitiationModel DriverTransferInitiation)
    {
        if (HasPermissionDriverTransferEdit)
        {
            var authprov = await auth.GetAuthenticationStateAsync();
            var user = authprov.User;
            var brancIDString = authprov.User.Claims.First(x => x.Type == "BranchID").Value;


            if (DriverTransferInitiation.InitiatedBranch == null)
            {
                DriverTransferInitiation.InitiatedBranch = new();
            }
            if (DriverTransferInitiation.DestinationBranch == null)
            {
                DriverTransferInitiation.DestinationBranch = new();
            }
            DriverTransferInitiation.InitiatedBranch.BranchID = int.Parse(brancIDString);


            var modelOutGoing = new DialogParameters { ["model"] = DriverTransferInitiation };

            var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Medium };
            var dialog = DialogService.Show<DriverTransferInitiationDialog>("Simple Dialog", modelOutGoing, options);

            var result = await dialog.Result;

            var isCancelled = result.Cancelled;
            if (!isCancelled)
            {
                var ReturnData = (DriverTransferInitiationModel)result.Data;
                notificationMessage.InitiateBranch = BranchList?.FirstOrDefault(s => s.BranchID == Convert.ToInt32(ReturnData?.InitiatedBranch?.BranchID ?? 0)) ?? null;
                notificationMessage.ReceivedBranch = BranchList?.FirstOrDefault(s => s.BranchID == Convert.ToInt32(ReturnData?.DestinationBranch?.BranchID ?? 0)) ?? null;
                notificationMessage.MessageTitle = "Driver " + (ReturnData?.Driver?.DriverName ?? "") + " is transfered to this branch.";
                notificationMessage.MessageBody = "Driver " + (ReturnData?.Driver?.DriverName ?? "") + " is transfered from " + (notificationMessage?.InitiateBranch?.BranchName ?? "") + " to this branch on " + (DateTime.Now).ToString() + ".";
                notificationMessage.RedirectedTo = 0;
                notificationMessage.ExpiredBy = 7;
                notificationMessage.DocumentID = ReturnData.DriverTransferID;
                notificationMessage.MessageGroupID = "DriverTransfer";
                notificationMessage.PageToRedirectLink = "/DriverTransferView";
                notificationMessage.ClaimValue = "Edit";
                notificationMessage.DocumentTypeID = DocTypeID;
                notificationMessage.MsgDate = DateTime.Now;
                await signalRService.Send(notificationMessage);

                await GetAll();
            }
        }
        else
        {
            bool? ResultModel = await DialogService.ShowMessageBox(
               "Permission denied!",
               "You dont have any permission to Add or Edit DriverTransfer.");
        }
    }


    private async Task OpenDialogDeleteOutGoing(DriverTransferInitiationModel DriverTransferInitiation)
    {
        if (HasPermissionDriverTransferDelete)
        {
            bool? result = await DialogService.ShowMessageBox(
                "Warning",
                "Are you sure you want to delete this entry?",
                yesText: "Delete!", cancelText: "Cancel");
            state = result == null ? "Cancelled" : "Deleted!";
            if (state == "Deleted!")
            {

                var authprov = await auth.GetAuthenticationStateAsync();
                var user = authprov.User;
                var brancIDString = authprov.User.Claims.First(x => x.Type == "BranchID").Value;

                try
                {
                    var BranchID = int.Parse(brancIDString);

                    Iservice.DeleteInitiation(DriverTransferInitiation.DriverTransferID, BranchID, DriverTransferInitiation.Driver.DriverID);
                    snackbar.Add("Driver Transfer Canceled", Severity.Warning);

                }
                catch (Exception ex)
                {
                    snackbar.Add(ex.Message, Severity.Error);
                }
                await GetAll();
            }
        }
        else
        {
            bool? ResultModel = await DialogService.ShowMessageBox(
               "Permission denied!",
               "You dont have any permission to Delete DriverTransfer.");
        }
    }


    private async Task GetAllOutGoing()
    {

        collectionOutGoing = new();

        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;
        var brancIDString = authprov.User.Claims.First(x => x.Type == "BranchID").Value;

        if (modelOutGoing.InitiatedBranch == null)
        {
            modelOutGoing.InitiatedBranch = new();
        }
        modelOutGoing.InitiatedBranch.BranchID = int.Parse(brancIDString);

        foreach (var item in Iservice.SelectOutgoingDrivers(modelOutGoing.InitiatedBranch.BranchID))
        {
            collectionOutGoing.Add(item);
        }
    }


    #endregion

    #region Incoming


    private DriverTransferInitiationModel modelIncoming = new();

    private List<DriverTransferInitiationModel> collectionIncoming = new();

    private async Task OpenDialogEditIncoming(DriverTransferInitiationModel DriverTransferEnd)
    {
        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;
        var brancIDString = authprov.User.Claims.First(x => x.Type == "BranchID").Value;
        if (DriverTransferEnd.DriverTransferEndModel == null)
        {
            DriverTransferEnd.DriverTransferEndModel = new();
        }
        if (DriverTransferEnd.DestinationBranch == null)
        {
            DriverTransferEnd.DestinationBranch = new();
        }
        DriverTransferEnd.DestinationBranch.BranchID = int.Parse(brancIDString);
        if (DriverTransferEnd.DriverTransferEndModel == null)
        {
            DriverTransferEnd.DriverTransferEndModel = new DriverTransferEndModel();
        }
        DriverTransferEnd.DriverTransferEndModel.TransferEndDate = DateTime.Now;
        var modelIncoming = new DialogParameters { ["model"] = DriverTransferEnd };

        var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Medium };
        var dialog = DialogService.Show<DriverTransferEndDialog>("Simple Dialog", modelIncoming, options);

        var result = await dialog.Result;

        var isCancelled = result.Cancelled;

        if (!isCancelled)
        {
            var ReturnData = (DriverTransferInitiationModel)result.Data;
            if (ReturnData.IsdriverReject == 1)
            {

                notificationMessage.InitiateBranch = BranchList?.FirstOrDefault(s => s.BranchID == Convert.ToInt32(ReturnData?.DestinationBranch?.BranchID ?? 0)) ?? null;
                notificationMessage.ReceivedBranch = BranchList?.FirstOrDefault(s => s.BranchID == Convert.ToInt32(ReturnData?.InitiatedBranch?.BranchID ?? 0)) ?? null;
                notificationMessage.MessageTitle = "Driver " + (ReturnData?.Driver?.DriverName ?? "") + " is rejected.";
                notificationMessage.MessageBody = "Driver " + (ReturnData?.Driver?.DriverName ?? "") + " is rejected from " + (notificationMessage?.InitiateBranch?.BranchName ?? "") + " on " + (DateTime.Now).ToString() + ".";
                notificationMessage.RedirectedTo = 0;
                notificationMessage.MsgDate = DateTime.Now;
                notificationMessage.ExpiredBy = 7;
                notificationMessage.DocumentID = ReturnData.DriverTransferID;
                notificationMessage.MessageGroupID = "DriverTransfer";
                notificationMessage.PageToRedirectLink = "/DriverTransferView";
                notificationMessage.ClaimValue = "Edit";
                notificationMessage.DocumentTypeID = DocTypeID;
                await signalRService.Send(notificationMessage);
            }
            await GetAll();
        }
    }


    private async Task GetAllIncoming()
    {
        collectionIncoming = new();
        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;
        var brancIDString = authprov.User.Claims.First(x => x.Type == "BranchID").Value;
        if (modelIncoming.DriverTransferEndModel == null)
        {
            modelIncoming.DriverTransferEndModel = new();
        }

        if (modelIncoming.DestinationBranch == null)
        {
            modelIncoming.DestinationBranch = new();
        }
        modelIncoming.DestinationBranch.BranchID = int.Parse(brancIDString);

        foreach (var item in Iservice.SelectIncomingDrivers(modelIncoming.DestinationBranch?.BranchID ?? 0))
        {
            collectionIncoming.Add(item);
        }
    }
    #endregion
}