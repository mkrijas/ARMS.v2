@page "/Driver"
@inject IDriverService Iservice
@inject IDriverFaultService Ifaultservice
@inject IBranchService Ibranchservice
@inject IDialogService DialogService
@inject MudBlazor.ISnackbar snackbar
@attribute [Authorize]
@inject AuthenticationStateProvider auth
@inject IPartyService Iparty
@inject SignalRService signalRService
@using System.IO
@using System.Security.AccessControl
@inject NavigationManager nav
@using MimeTypes
@using System.Threading;
@using OfficeOpenXml
@using OfficeOpenXml.Style
@inject IRoleService<RoleModel> Irole
@inject IJSRuntime JSRuntime


@if (_isLoading)
{
    <LoaderComponent IsFullScreen="true" 
                    ShowLogo="false" 
                    Size="medium" 
                    LoadingText="Loading Drivers" 
                    SubText="Please wait..." />
}
else
{
    <div class="admin-page-container">
        <div class="admin-header-tiered mb-6">
            <div class="d-flex align-center justify-space-between">
                <div>
                    <MudText Typo="Typo.h4" Class="admin-title">Driver Registry</MudText>
                    <MudText Typo="Typo.body2" Class="admin-subtitle">Maintain driver profiles, license compliance, status tracking, and performance metrics.</MudText>
                </div>
                <div class="d-flex gap-2">
                    <MudButton StartIcon="@Icons.Material.Filled.Add" Variant="Variant.Filled" Color="Color.Primary" Class="admin-register-btn" OnClick="@(()=>Edit(0))">REGISTER DRIVER</MudButton>
                </div>
            </div>
        </div>

        <div class="admin-glass-card mb-6 pa-4">
            <div class="d-flex align-center gap-4 w-100 flex-wrap">
                <div style="flex-grow: 1; min-width: 250px;">
                    <MudTextField @bind-Value="searchDriver" Placeholder="Search by name, code or mobile..." Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" Variant="Variant.Outlined" Margin="Margin.Dense" Class="admin-input-group" Clearable="true" />
                </div>
                <div class="d-flex gap-2">
                    <MudButton OnClick="OpenTracking" StartIcon="@Icons.Material.Filled.TrackChanges" Variant="Variant.Filled" Color="Color.Secondary" Class="action-btn-primary" Style="border-radius: 12px; height: 40px;">Track Driver</MudButton>
                    <MudButton OnClick="OpenRejoin" StartIcon="@Icons.Material.Filled.Autorenew" Variant="Variant.Filled" Color="Color.Warning" Class="action-btn-primary" Style="border-radius: 12px; height: 40px;">Rejoin Driver</MudButton>
                    <MudButton OnClick="ExcelDownload" StartIcon="@Icons.Material.Outlined.Article" Variant="Variant.Filled" Color="Color.Primary" Class="action-btn-primary" Style="background: #367588; border-radius: 12px; height: 40px; color: white;">Export CSV</MudButton>
                </div>
            </div>
        </div>

        <div class="admin-glass-card pa-0 overflow-hidden">
            <MudTable Items="@collection" RowClassFunc="RowClassFunc" Elevation="0" Filter="new Func<DriverModel, bool>(search)" Class="modern-admin-table">
                <HeaderContent>
                    <MudTh><MudTableSortLabel SortBy="new Func<DriverModel, object>(x => x.DriverCode)" InitialDirection="SortDirection.Ascending"><span class="admin-header-text">CODE/NAME</span></MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<DriverModel, object>(x => x.Mobile)" InitialDirection="SortDirection.Ascending"><span class="admin-header-text">CONTACT INFO</span></MudTableSortLabel></MudTh>
                    @if (BranchID == 7)
                    {
                        <MudTh><MudTableSortLabel SortBy="new Func<DriverModel, object>(x=> x.HomeBranchName)" InitialDirection="SortDirection.Ascending"><span class="admin-header-text">HOME BRANCH</span></MudTableSortLabel></MudTh>
                    }
                    <MudTh><MudTableSortLabel SortBy="new Func<DriverModel, object>(x => x.JoiningDate)" InitialDirection="SortDirection.Ascending"><span class="admin-header-text">JOINED</span></MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<DriverModel, object>(x => x.DriverAgent.TradeName)" InitialDirection="SortDirection.Ascending"><span class="admin-header-text">CONTRACTOR</span></MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<DriverModel, object>(x => x.DateOfBirth)" InitialDirection="SortDirection.Ascending"><span class="admin-header-text">STATUS/AGE</span></MudTableSortLabel></MudTh>
                    <MudTh Style="text-align: right;"><span class="admin-header-text">ACTIONS</span></MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Code/Name">
                        <div class="d-flex flex-column">
                            <MudText Typo="Typo.body2" Class="admin-td-primary">@context.DriverName</MudText>
                            <MudText Typo="Typo.caption" Class="admin-td-secondary">@context.DriverCode</MudText>
                        </div>
                    </MudTd>
                    <MudTd DataLabel="Contact">
                        <div class="d-flex flex-column">
                            <MudText Typo="Typo.body2" Class="admin-td-primary">@context.Mobile</MudText>
                            @if (!context.HasValidLicense)
                            {
                                <MudText Typo="Typo.caption" Color="Color.Error">INVALID LICENSE</MudText>
                            }
                        </div>
                    </MudTd>
                    @if (BranchID == 7)
                    {
                        <MudTd DataLabel="Home Branch">@context.HomeBranchName</MudTd>
                    }
                    <MudTd DataLabel="Joined">@context.JoiningDate?.ToString("dd MMM yyyy")</MudTd>
                    <MudTd DataLabel="Contractor">@context.DriverAgent.TradeName</MudTd>
                    <MudTd DataLabel="Status/Age">
                        <div class="d-flex align-center gap-2">
                            <MudChip T="string" Size="Size.Small" Color="@(context.Status == "Active" ? Color.Success : Color.Default)" Variant="Variant.Text">@context.Status</MudChip>
                            <MudText Typo="Typo.body2" Class="admin-td-secondary">@(DateTime.Today.Year - context.DateOfBirth.Value.Year + (DateTime.Today.DayOfYear < context.DateOfBirth.Value.DayOfYear ? -1 : 0)) yrs</MudText>
                        </div>
                    </MudTd>
                    <MudTd DataLabel="Actions" Style="text-align: right;">
                        <div class="d-flex justify-end gap-1">
                            <MudTooltip Text="DL Documents">
                                <MudIconButton OnClick="@(() => nav.NavigateTo("dl/" + context.DriverID.ToString()))" Color="Color.Primary" Icon="@Icons.Material.Filled.FileCopy" Size="Size.Small" Variant="Variant.Text" />
                            </MudTooltip>
                            <MudTooltip Text="Edit">
                                <MudIconButton OnClick="@(() => Edit(context.DriverID))" Color="Color.Primary" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Variant="Variant.Text" />
                            </MudTooltip>
                            <MudMenu Icon="@Icons.Material.Filled.MoreHoriz" AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight" Size="Size.Small">
                                <MudMenuItem OnClick="@(() => Transfer(context.DriverID))" Icon="@Icons.Material.Filled.SwapHoriz">Transfer</MudMenuItem>
                                @if (context.UserInfo.RecordStatus != 4)
                                {
                                    <MudMenuItem OnClick="@(() => BeginLeave(context.DriverID))" Icon="@Icons.Material.Filled.Timer">Allot Leave</MudMenuItem>
                                }
                                else
                                {
                                    <MudMenuItem OnClick="@(() => EndLeave(context.DriverID))" Icon="@Icons.Material.Filled.PlayArrow">End Leave</MudMenuItem>
                                }
                                @if (context.UserInfo.RecordStatus != 9)
                                {
                                    <MudMenuItem OnClick="@(() => Fault(context.DriverID))" Icon="@Icons.Material.Filled.ReportProblem" Color="Color.Warning">Report Fault</MudMenuItem>
                                }
                                else
                                {
                                    <MudMenuItem OnClick="@(() => RemoveBlacklist(context.DriverID))" Icon="@Icons.Material.Filled.VerifiedUser" Color="Color.Success">Clear Blacklist</MudMenuItem>
                                }
                                <MudDivider />
                                <MudMenuItem OnClick="@(() => Resign(context.DriverID))" Icon="@Icons.Material.Filled.PersonRemove" Color="Color.Error">Resign</MudMenuItem>
                            </MudMenu>
                        </div>
                    </MudTd>
                </RowTemplate>
                <PagerContent>
                    <div class="pa-4">
                        <MudTablePager PageSizeOptions="new int[] { 10, 20, 50, 100 }" />
                    </div>
                </PagerContent>
            </MudTable>
        </div>
    </div>
}



@code {

    private bool _isLoading = true;
    private DateTime _loadStartTime;

    IBrowserFile driverImage;
    IBrowserFile adhaarImage;
    private List<DriverModel> collection = new List<DriverModel>();
    private List<DriverModel> ExcelCollection = new List<DriverModel>();

    private string searchDriver = "";
    private bool _busy;

    MudMessageBox mbox { get; set; } = new();
    string UserID;
    int BranchID;

    string state = "Message box hasn't been opened yet";

    public bool HasPermissionDriverTransferEdit { get; set; } = false;
    public int DocTypeIDDriverTransfer = 49;

    public bool HasPermissionDriverServiceEdit { get; set; } = false;
    public bool HasPermissionDriverServiceResign { get; set; } = false;
    public bool HasPermissionDriverServiceAllotLeave { get; set; } = false;
    public int DocTypeIDDriver = 50;

    public bool HasPermissionDriverFaultServiceRemoveDriver { get; set; } = false;
    public int DocTypeIDDriverFault = 53;

    private List<BranchModel> BranchList = new();

    #region SignaIR Notification

    private PushNotificationModel notificationMessage = new PushNotificationModel();

    #endregion

    // Lifecycle method called when the component is initialized
    protected override async Task OnInitializedAsync()
    {
        _loadStartTime = DateTime.Now;
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionDriverTransferEdit = await Irole.HasClaim(DocTypeIDDriverTransfer.ToString(), "Edit", ctc.Token);
        HasPermissionDriverServiceEdit = await Irole.HasClaim(DocTypeIDDriver.ToString(), "Edit", ctc.Token);
        HasPermissionDriverServiceResign = await Irole.HasClaim(DocTypeIDDriver.ToString(), "Resign", ctc.Token);
        HasPermissionDriverServiceAllotLeave = await Irole.HasClaim(DocTypeIDDriver.ToString(), "AllotLeave", ctc.Token);
        HasPermissionDriverFaultServiceRemoveDriver = await Irole.HasClaim(DocTypeIDDriverFault.ToString(), "Remove", ctc.Token);

        // Retrieve the list of branches from the service
        BranchList = Ibranchservice.Select().ToList();
        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;
        BranchID = int.Parse(user.Claims.FirstOrDefault(x => x.Type == "BranchID").Value);
        await signalRService.StartAsync();

        GetAll();
        await EnsureMinimumLoadTime();
        _isLoading = false;
    }

    private async Task EnsureMinimumLoadTime()
    {
        var elapsed = (DateTime.Now - _loadStartTime).TotalMilliseconds;
        if (elapsed < 100)
        {
            await Task.Delay(100 - (int)elapsed);
        }
    }

    // Method to retrieve all drivers for the current branch
    private void GetAll()
    {
        collection = Iservice.SelectByBranch(BranchID).ToList(); // Fetch drivers based on branch ID
    }

    // Method to begin leave for a driver
    private async void BeginLeave(int? DriverID)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        _busy = true;
        if (HasPermissionDriverServiceAllotLeave)
        {
            DriverLeaveModel DriverLeave = new();
            var DriverData = collection.FirstOrDefault(x => x.DriverID == DriverID);
            DriverLeave.Driver = DriverData;
            var parameters = new DialogParameters();
            parameters.Add("model", DriverID != 0 ? DriverLeave : new());
            DialogOptions maxWidth = new DialogOptions() { MaxWidth = MaxWidth.Medium, FullWidth = true };
            var dialog = await DialogService.ShowAsync<DriverLeaveDialog>("Driver On Leave", parameters, maxWidth);
            var result = await dialog.Result;
            collection.Find(x => x.DriverID == DriverID).UserInfo.RecordStatus = 4;
            StateHasChanged();

            GetAll();
        }
        else
        {
            bool? result = await DialogService.ShowMessageBoxAsync(
                "Permission denied!",
                "You don't have any permission to AllotLeave to Driver.");
        }
        await Task.Delay(200);
        _busy = false;
    }

    // Method to determine the row class based on driver's status
    private string RowClassFunc(DriverModel driver, Int32 index)
    {
        if (driver.UserInfo.RecordStatus == 9)
        {
            return "bg-error-light";
        }
        if (!driver.HasValidLicense)
        {
            return "bg-warning-light";
        }
        return string.Empty;
    }

    // Method to end leave for a driver
    private async Task EndLeave(int? DriverID)
    {
        if (HasPermissionDriverServiceAllotLeave)
        {
            var authprov = await auth.GetAuthenticationStateAsync();
            var user = authprov.User;

            // Call the service to end leave
            int qryResult = Iservice.EndLeave(DriverID, user.Identity.Name);
            if (qryResult > 0)
            {
                collection.Find(x => x.DriverID == DriverID).UserInfo.RecordStatus = 3;
                StateHasChanged();
            }
        }
        else
        {
            bool? result = await DialogService.ShowMessageBoxAsync(
                "Permission denied!",
                "You don't have any permission to AllotLeave to Driver.");
        }
    }

    // Method to edit driver information
    private async Task Edit(int? id)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        _busy = true;
        if (HasPermissionDriverServiceEdit)
        {
            var parameters = new DialogParameters();
            parameters.Add("model", id != 0 ? collection.FirstOrDefault(x => x.DriverID == id) : new DriverModel());
            DialogOptions maxWidth = new DialogOptions() { MaxWidth = MaxWidth.Medium, FullWidth = true };
            var dialog = await DialogService.ShowAsync<DriverDialog>("Driver", parameters, maxWidth);
            var result = await dialog.Result;
            if (!result.Canceled)
            {
                DriverModel editedModel = (DriverModel)result.Data;
                if (collection.Exists(x => x.DriverID == editedModel.DriverID))
                {
                    collection[collection.FindIndex(x => x.DriverID == editedModel.DriverID)] = editedModel;
                }
                else
                {
                    collection.Add(editedModel);
                }
            }
        }
        else
        {
            bool? ResultModel = await DialogService.ShowMessageBoxAsync(
                "Permission denied!",
                "You don't have any permission to Add or Edit Driver.");
        }
        GetAll();
        StateHasChanged();
        await Task.Delay(200);
        _busy = false;
    }

    // Method to resign a driver
    private async Task Resign(int? driverId)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        _busy = true;
        if (HasPermissionDriverServiceResign)
        {
            var parameters = new DialogParameters();
            DriverResignModel model = new();
            model.Driver = collection.FirstOrDefault(x => x.DriverID == driverId);
            parameters.Add("model", model);
            parameters.Add("driverId", driverId);
            DialogOptions maxWidth = new DialogOptions() { MaxWidth = MaxWidth.Medium, FullWidth = true };
            var dialog = await DialogService.ShowAsync<DriverResignDialog>("Resign Driver", parameters, maxWidth);
            var result = await dialog.Result;

            // Check if the driver resigned successfully
            if (result.Canceled == false)
            {
                // Call the Delete service method
                try
                {
                    var authprov = await auth.GetAuthenticationStateAsync();
                    var user = authprov.User;
                    Iservice.Delete(driverId, user.Identity.Name); // Delete the driver
                }
                catch (Exception ex)
                {
                    snackbar.Add(ex.Message, Severity.Error);
                }
            }
            GetAll();
        }
        else
        {
            bool? result = await DialogService.ShowMessageBoxAsync(
                "Permission denied!",
                "You don't have any permission to Resign Driver.");
        }
        await Task.Delay(200);
        _busy = false;
    }

    // Method to transfer a driver
    private async Task Transfer(int? DriverID)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        _busy = true;
        if (HasPermissionDriverTransferEdit)
        {
            DriverTransferInitiationModel DriverTransfer = new();
            var DriverData = collection.FirstOrDefault(x => x.DriverID == DriverID);
            DriverTransfer.Driver = DriverData;
            var parameters = new DialogParameters();
            parameters.Add("model", DriverID != 0 ? DriverTransfer : new());
            DialogOptions maxWidth = new DialogOptions() { MaxWidth = MaxWidth.Medium, FullWidth = true };
            var dialog = await DialogService.ShowAsync<DriverTransferInitiationDialog>("Transfer Driver", parameters, maxWidth);
            var result = await dialog.Result;
            var isCancelled = result.Canceled;
            if (!isCancelled)
            {
                var ReturnData = (DriverTransferInitiationModel)result.Data;
                notificationMessage.InitiateBranch = BranchList?.FirstOrDefault(s => s.BranchID == Convert.ToInt32(ReturnData?.InitiatedBranch?.BranchID ?? 0)) ?? null;
                notificationMessage.ReceivedBranch = BranchList?.FirstOrDefault(s => s.BranchID == Convert.ToInt32(ReturnData?.DestinationBranch?.BranchID ?? 0)) ?? null;
                notificationMessage.MessageTitle = "Driver " + (ReturnData?.Driver?.DriverName ?? "") + " is transfered to this branch.";
                notificationMessage.MessageBody = "Driver " + (ReturnData?.Driver?.DriverName ?? "") + " is transfered from " + (notificationMessage?.InitiateBranch?.BranchName ?? "") + " to this branch on " + (DateTime.Now).ToString() + ".";
                notificationMessage.RedirectedTo = 0;
                notificationMessage.ExpiredBy = 7;
                notificationMessage.DocumentID = ReturnData.DriverTransferID;
                notificationMessage.MessageGroupID = "DriverTransfer";
                notificationMessage.PageToRedirectLink = "/DriverTransferView";
                notificationMessage.ClaimValue = "Edit";
                notificationMessage.DocumentTypeID = DocTypeIDDriverTransfer;
                notificationMessage.MsgDate = DateTime.Now;
                await signalRService.Send(notificationMessage);
            }
            GetAll();
        }
        else
        {
            bool? ResultModel = await DialogService.ShowMessageBoxAsync(
                "Permission denied!",
                "You don't have any permission to Add or Edit DriverTransfer.");
        }
        await Task.Delay(200);
        _busy = false;
    }

    // Method to report a fault for a driver
    private async Task Fault(int? DriverID)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        _busy = true;
        if (HasPermissionDriverServiceEdit)
        {
            DriverFaultModel DriverFault = new();
            var DriverData = collection.FirstOrDefault(x => x.DriverID == DriverID);
            DriverFault.Driver = DriverData;
            var parameters = new DialogParameters();
            parameters.Add("model", DriverID != 0 ? DriverFault : new());
            DialogOptions maxWidth = new DialogOptions() { MaxWidth = MaxWidth.Medium, FullWidth = true };
            var dialog = await DialogService.ShowAsync<DriverFaultDialog>("Driver Fault", parameters, maxWidth);
            var result = await dialog.Result;
            GetAll();
        }
        else
        {
            bool? ResultModel = await DialogService.ShowMessageBoxAsync(
                "Permission denied!",
                "You don't have any permission to Add or Edit Driver.");
        }
        await Task.Delay(200);
        _busy = false;
    }

    // Method to remove a driver from the blacklist
    private async Task RemoveBlacklist(int? DriverID)
    {
        if (HasPermissionDriverFaultServiceRemoveDriver)
        {
            bool? result = await DialogService.ShowMessageBoxAsync(
                "Warning",
                "Are you sure you want to remove from blacklist?",
                yesText: "Delete!", cancelText: "Cancel");
            state = result == null ? "Cancelled" : "Deleted!";

            if (state == "Deleted!")
            {
                var authprov = await auth.GetAuthenticationStateAsync();
                var user = authprov.User;

                // Call the service to remove the driver from the blacklist
                int qryResult = Ifaultservice.Delete(DriverID, user.Identity.Name);
                snackbar.Add("Driver removed from Blacklist", Severity.Warning);
            }
            GetAll();
        }
        else
        {
            bool? result = await DialogService.ShowMessageBoxAsync(
                "Permission denied!",
                "You don't have any permission to Edit DriverFault.");
        }
    }

    // Method to search for drivers based on the search string
    private bool search(DriverModel Driver)
    {
        if (Driver.DriverName != null && (Driver.DriverName.Contains(searchDriver, StringComparison.OrdinalIgnoreCase) || Driver.DriverCode.Contains(searchDriver, StringComparison.OrdinalIgnoreCase)))
        {
            return true;
        }
        return false;
    }

    // Method to open the driver tracking dialog
    private async Task OpenTracking()
    {
        DialogOptions para = new DialogOptions() { MaxWidth = MaxWidth.Medium, FullWidth = true };
        await DialogService.ShowAsync<DriverTrackingDialog>("Driver Tracking", para);
    }

    // Method to open the driver rejoin dialog
    private async Task OpenRejoin()
    {
        DialogOptions para = new DialogOptions() { MaxWidth = MaxWidth.Medium, FullWidth = true };
        await DialogService.ShowAsync<DriverRejoinViewDialog>("Driver Rejoin", para);
    }

    // Method to download the driver list as an Excel file
    public async Task ExcelDownload()
    {
        var fileName = "DriverList.xlsx";
        var sheetName = "Sheet1"; // Change the sheet name as needed
        ExcelCollection = Iservice.ExcelDataCollection(BranchID).ToList();
        if (ExcelCollection.Count > 0)
        {
            var fileBytes = GenerateExcelBytes(sheetName);
            await JSRuntime.InvokeVoidAsync("triggerFileDownload", fileName, Convert.ToBase64String(fileBytes));
        }
        else
        {
            bool? result = await DialogService.ShowMessageBoxAsync(
                "Oops !",
                "No Data Found.");
        }
    }

    // Method to generate Excel bytes for the driver list
    public byte[] GenerateExcelBytes(string sheetName)
    {       
        using (var package = new ExcelPackage())
        {
            var worksheet = package.Workbook.Worksheets.Add(sheetName);

            // Add column headers
            worksheet.Cells[1, 1].Value = "HomeBranch Name";
            worksheet.Cells[1, 2].Value = "Joining Date";
            worksheet.Cells[1, 3].Value = "Driver Code";
            worksheet.Cells[1, 4].Value = "Driver Name";
            worksheet.Cells[1, 5].Value = "Date Of Birth";
            worksheet.Cells[1, 6].Value = "Adhaar No";
            worksheet.Cells[1, 7].Value = "Contractor/Supplier";
            worksheet.Cells[1, 8].Value = "Reference";
            worksheet.Cells[1, 9].Value = "Mobile No";
            worksheet.Cells[1, 10].Value = "Email";
            worksheet.Cells[1, 11].Value = "Building";
            worksheet.Cells[1, 12].Value = "Street";
            worksheet.Cells[1, 13].Value = "Place";
            worksheet.Cells[1, 14].Value = "City";
            worksheet.Cells[1, 15].Value = "PinCode";
            worksheet.Cells[1, 16].Value = "Beneficiary Name";
            worksheet.Cells[1, 17].Value = "Account Number";
            worksheet.Cells[1, 18].Value = "IFSC Code";
            worksheet.Cells[1, 19].Value = "MICR Code";
            worksheet.Cells[1, 20].Value = "SWIFT Code";
            worksheet.Cells[1, 21].Value = "Bank Name";
            worksheet.Cells[1, 22].Value = "Bank Branch";
            worksheet.Cells[1, 23].Value = "Licence Type";
            worksheet.Cells[1, 24].Value = "Licence No";
            worksheet.Cells[1, 25].Value = "Licence Expiry Date";
            worksheet.Cells[1, 26].Value = "Badge No";
            worksheet.Cells[1, 27].Value = "Badge Expiry Date";
            for (int i = 1; i <= 27; i++)
            {
                worksheet.Cells[1, i].Style.Font.Bold = true;
            }

            worksheet.Column(2).Style.Numberformat.Format = "dd-MM-yyyy"; // Date format
            worksheet.Column(5).Style.Numberformat.Format = "dd-MM-yyyy"; // Date format
            worksheet.Column(25).Style.Numberformat.Format = "dd-MM-yyyy"; // Date format
            worksheet.Column(27).Style.Numberformat.Format = "dd-MM-yyyy"; // Date format
                                                                           //worksheet.Column(15).Style.Numberformat.Format = "0.00"; // Integer format
                                                                           //worksheet.Column(16).Style.Numberformat.Format = "0.00"; // Integer format

            // Add data rows
            int row = 2;
            foreach (var item in ExcelCollection)
            {
                worksheet.Cells[row, 1].Value = item.HomeBranchName;
                worksheet.Cells[row, 2].Value = item.JoiningDate;
                worksheet.Cells[row, 3].Value = item.DriverCode;
                worksheet.Cells[row, 4].Value = item.DriverName;
                worksheet.Cells[row, 5].Value = item.DateOfBirth;
                worksheet.Cells[row, 6].Value = item.AdhaarNo;
                worksheet.Cells[row, 7].Value = item.DriverAgent.TradeName;
                worksheet.Cells[row, 8].Value = item.AdditionalInfo;
                worksheet.Cells[row, 9].Value = item.Mobile;
                worksheet.Cells[row, 10].Value = item.Email;
                worksheet.Cells[row, 11].Value = item.Address.Building;
                worksheet.Cells[row, 12].Value = item.Address.Street;
                worksheet.Cells[row, 13].Value = item.Address.Place;
                worksheet.Cells[row, 14].Value = item.Address.City;
                worksheet.Cells[row, 15].Value = item.Address.PinCode;
                worksheet.Cells[row, 16].Value = item.BankAccount.BeneficiaryName;
                worksheet.Cells[row, 17].Value = item.BankAccount.AccountNumber;
                worksheet.Cells[row, 18].Value = item.BankAccount.IfscCode;
                worksheet.Cells[row, 19].Value = item.BankAccount.MicrCode;
                worksheet.Cells[row, 20].Value = item.BankAccount.SwiftCode;
                worksheet.Cells[row, 21].Value = item.BankAccount.BankTitle;
                worksheet.Cells[row, 22].Value = item.BankAccount.BankBranch;
                worksheet.Cells[row, 23].Value = item.DriverLicence.LicenceType;
                worksheet.Cells[row, 24].Value = item.DriverLicence.LicenceNo;
                worksheet.Cells[row, 25].Value = item.DriverLicence.DLExpiryDate;
                worksheet.Cells[row, 26].Value = item.DriverLicence.BadgeNo;
                worksheet.Cells[row, 27].Value = item.DriverLicence.BadgeExpiryDate;

                if (item.DriverLicence.DLExpiryDate < DateTime.Now)
                {
                    using (var range = worksheet.Cells[row, 1, row, 27])
                    {
                        range.Style.Fill.PatternType = ExcelFillStyle.Solid;
                        range.Style.Fill.BackgroundColor.SetColor(System.Drawing.Color.Red);
                    }
                }
                if (item.UserInfo.RecordStatus == 9)
                {
                    using (var range = worksheet.Cells[row, 1, row, 27])
                    {
                        range.Style.Fill.PatternType = ExcelFillStyle.Solid;
                        range.Style.Font.Color.SetColor(System.Drawing.Color.White);
                        range.Style.Fill.BackgroundColor.SetColor(System.Drawing.Color.Black);
                    }
                }

                row++;
            }

            worksheet.Cells[worksheet.Dimension.Address].Style.Border.Top.Style = ExcelBorderStyle.Thin;
            worksheet.Cells[worksheet.Dimension.Address].Style.Border.Left.Style = ExcelBorderStyle.Thin;
            worksheet.Cells[worksheet.Dimension.Address].Style.Border.Right.Style = ExcelBorderStyle.Thin;
            worksheet.Cells[worksheet.Dimension.Address].Style.Border.Bottom.Style = ExcelBorderStyle.Thin;

            // Save the Excel package to a memory stream
            using (var stream = new MemoryStream())
            {
                package.SaveAs(stream);
                return stream.ToArray();
            }
        }
    }
}
