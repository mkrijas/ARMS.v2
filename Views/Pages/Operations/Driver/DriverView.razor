@page "/Driver"
@inject IDriverService Iservice
@inject IDriverFaultService Ifaultservice
@inject IBranchService Ibranchservice
@inject IDialogService DialogService
@inject MudBlazor.ISnackbar snackbar
@attribute [Authorize]
@inject AuthenticationStateProvider auth
@inject IPartyService Iparty
@inject SignalRService signalRService
@using System.IO
@using System.Security.AccessControl
@inject NavigationManager nav
@using MimeTypes
@using System.Threading;
@using OfficeOpenXml
@using OfficeOpenXml.Style
@inject IRoleService<RoleModel> Irole
@inject IJSRuntime JSRuntime

<style>
    .RedRow {
        background-color: #ff8080;
    }
</style>

<MudGrid Spacing="4">
    <MudItem xs="12" md="12">
        <MudTable Items="@collection" RowClassFunc="RowClassFunc" Elevation="10" Filter="new Func<DriverModel, bool>(search)">
            <ToolBarContent>
                <MudText Typo="Typo.h6">Drivers</MudText>
                <MudIconButton Icon="@Icons.Material.Filled.Add" Title="Add" @onclick="(()=>Edit(0))" Color="Color.Dark" Size="Size.Small"></MudIconButton>
                <MudIconButton Icon="@Icons.Material.Filled.TrackChanges" Title="Track" @onclick="OpenTracking" Color="Color.Dark" Size="Size.Small"></MudIconButton>
                <MudSpacer></MudSpacer>
                <MudTextField @bind-Value="searchDriver" Placeholder="Search Drivers... " Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0"></MudTextField>
                <MudButton OnClick="ExcelDownload" Style="margin: 14px; margin-left: 60px;" StartIcon="@Icons.Material.Outlined.Article" Variant="Variant.Filled" Color="Color.Primary" ButtonType="ButtonType.Button">Export to Excel</MudButton>
            </ToolBarContent>
            <HeaderContent>
                <MudTh><MudTableSortLabel SortBy="new Func<DriverModel, object>(x => x.DriverName)" InitialDirection="SortDirection.Ascending">Driver</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<DriverModel, object>(x => x.Mobile)" InitialDirection="SortDirection.Ascending">Mobile</MudTableSortLabel></MudTh>
                @if (BranchID == 7)
                {
                    <MudTh><MudTableSortLabel SortBy="new Func<DriverModel, object>(x=> x.HomeBranchName)" InitialDirection="SortDirection.Ascending">HomeBranchName</MudTableSortLabel></MudTh>
                }
                <MudTh><MudTableSortLabel SortBy="new Func<DriverModel, object>(x => x.DriverAgent.TradeName)" InitialDirection="SortDirection.Ascending">Contractor</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<DriverModel, object>(x => x.DateOfBirth)" InitialDirection="SortDirection.Ascending">AGE</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<DriverModel, object>(x=> x.Status)" InitialDirection="SortDirection.Ascending">Status</MudTableSortLabel></MudTh>
                <MudTh>Actions</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Driver">
                    <MudText Typo="Typo.h6">@context.DriverName </MudText>
                    @if (!context.HasValidLicense)
                    {
                        <MudText Typo="Typo.caption">(Invalid License)</MudText>
                    }
                </MudTd>
                <MudTd DataLabel="Mobile">@context.Mobile</MudTd>
                @if (BranchID == 7)
                {
                    <MudTd DataLabel="HomeBranchName">@context.HomeBranchName</MudTd>
                }
                <MudTd DataLabel="PartyName">@context.DriverAgent.TradeName</MudTd>
                <MudTd DataLabel="DOB">@(DateTime.Today.Year - context.DateOfBirth.Value.Year + (DateTime.Today.DayOfYear < context.DateOfBirth.Value.DayOfYear ? -1 : 0))</MudTd>
                <MudTd DataLabel="Status">@context.Status</MudTd>
                <MudTd DataLabel="">
                    @if (context.UserInfo.RecordStatus != 4)
                    {
                        <MudTooltip Text="Put the Driver on leave">
                            <MudFab @onclick="@(() => BeginLeave(context.DriverID))" Color="Color.Warning" Class="mx-2" Icon="@Icons.Material.Filled.KeyboardArrowDown" IconSize="Size.Small" Size="Size.Small" />
                        </MudTooltip>
                    }
                    else if (context.UserInfo.RecordStatus == 4)
                    {
                        <MudTooltip Text="End the leave">
                            <MudFab @onclick="@(() => EndLeave(context.DriverID))" Color="Color.Success" Class="mx-2" Icon="@Icons.Material.Filled.KeyboardArrowUp" IconSize="Size.Small" Size="Size.Small" />
                        </MudTooltip>
                    }
                    <MudTooltip Text="Driving licence">
                        <MudFab Label="DL" OnClick="@(() => nav.NavigateTo("dl/" + context.DriverID.ToString()))" Color="Color.Primary" Class="mx-2" Icon="@Icons.Material.Filled.FileCopy" Size="Size.Small" IconSize="Size.Small" />
                    </MudTooltip>
                    <MudTooltip Text="Edit">
                        <MudFab @onclick="@(() => Edit(context.DriverID))" Color="Color.Primary" Class="mx-2" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" IconSize="Size.Small" />
                    </MudTooltip>
                    <MudTooltip Text="Transfer">
                        <MudFab @onclick="@(() => Transfer(context.DriverID))" Color="Color.Primary" Icon="@Icons.Material.Filled.SwapHoriz" Size="Size.Small" IconSize="Size.Small" />
                    </MudTooltip>
                    @if (context.UserInfo.RecordStatus != 9)
                    {
                        <MudTooltip Text="Driver Fault">
                            <MudFab @onclick="@(() => Fault(context.DriverID))" Color="Color.Warning" Class="mx-2" Icon="@Icons.Material.Filled.Warning" Size="Size.Small" IconSize="Size.Small" />
                        </MudTooltip>
                    }
                    else if (context.UserInfo.RecordStatus == 9)
                    {
                        <MudTooltip Text="Remove From Blacklist">
                            <MudFab @onclick="@(() => RemoveBlacklist(context.DriverID))" Color="Color.Default" Class="mx-2" Icon="@Icons.Material.Filled.Cancel" IconSize="Size.Small" Size="Size.Small" />
                        </MudTooltip>
                    }
                    <MudTooltip Text="Resign">
                        <MudFab @onclick="@(() => Resign(context.DriverID))" Color="Color.Warning" Icon="@Icons.Material.Filled.PersonRemove" Size="Size.Small" IconSize="Size.Small" />
                    </MudTooltip>
                </MudTd>
            </RowTemplate>
            <PagerContent>
                <MudTablePager PageSizeOptions="new int[] { 10, 20, 50, 100 }" />
            </PagerContent>
        </MudTable>
    </MudItem>
</MudGrid>

@code {

    IBrowserFile driverImage;
    IBrowserFile adhaarImage;
    private List<DriverModel> collection = new List<DriverModel>();
    private List<DriverModel> ExcelCollection = new List<DriverModel>();

    private string searchDriver = "";
    private bool _busy;

    MudMessageBox mbox { get; set; } = new();
    string UserID;
    int BranchID;

    string state = "Message box hasn't been opened yet";

    public bool HasPermissionDriverTransferEdit { get; set; } = false;
    public int DocTypeIDDriverTransfer = 49;

    public bool HasPermissionDriverServiceEdit { get; set; } = false;
    public bool HasPermissionDriverServiceResign { get; set; } = false;
    public bool HasPermissionDriverServiceAllotLeave { get; set; } = false;
    public int DocTypeIDDriver = 50;

    public bool HasPermissionDriverFaultServiceEditDriver { get; set; } = false;
    public int DocTypeIDDriverFault = 53;

    private List<BranchModel> BranchList = new();

    #region SignaIR Notification

    private PushNotificationModel notificationMessage = new PushNotificationModel();

    #endregion


    protected override async Task OnInitializedAsync()
    {
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionDriverTransferEdit = await Irole.HasClaim(DocTypeIDDriverTransfer.ToString(), "Edit", ctc.Token);
        HasPermissionDriverServiceEdit = await Irole.HasClaim(DocTypeIDDriver.ToString(), "Edit", ctc.Token);
        HasPermissionDriverServiceResign = await Irole.HasClaim(DocTypeIDDriver.ToString(), "Resign", ctc.Token);
        HasPermissionDriverServiceAllotLeave = await Irole.HasClaim(DocTypeIDDriver.ToString(), "AllotLeave", ctc.Token);
        HasPermissionDriverFaultServiceEditDriver = await Irole.HasClaim(DocTypeIDDriverFault.ToString(), "Edit", ctc.Token);
        BranchList = Ibranchservice.Select().ToList();
        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;
        BranchID = int.Parse(user.Claims.FirstOrDefault(x => x.Type == "BranchID").Value);
        await signalRService.StartAsync();

        GetAll();
    }

    private void GetAll()
    {
        collection = Iservice.SelectByBranch(BranchID).ToList();
    }

    private async void BeginLeave(int? DriverID)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        _busy = true;
        if (HasPermissionDriverServiceAllotLeave)
        {
            DriverLeaveModel DriverLeave = new();
            var DriverData = collection.FirstOrDefault(x => x.DriverID == DriverID);
            DriverLeave.Driver = DriverData;
            var parameters = new DialogParameters();
            parameters.Add("model", DriverID != 0 ? DriverLeave : new());
            DialogOptions maxWidth = new DialogOptions() { MaxWidth = MaxWidth.Medium, FullWidth = true };
            var dialog = DialogService.Show<DriverLeaveDialog>("Driver On Leave", parameters, maxWidth);
            var result = await dialog.Result;
            collection.Find(x => x.DriverID == DriverID).UserInfo.RecordStatus = 4;
            StateHasChanged();

            GetAll();
        }
        else
        {
            bool? result = await DialogService.ShowMessageBox(
                "Permission denied!",
                "You dont have any permission to AllotLeave to Driver.");
        }
        await Task.Delay(200);
        _busy = false;
    }

    private string RowClassFunc(DriverModel driver, Int32 index)
    {
        if (driver.UserInfo.RecordStatus == 9)
        {
            return "RedRow";
        }
        if (!driver.HasValidLicense)
        {
            return "InvalidRow";
        }
        return string.Empty;
    }

    private async Task EndLeave(int? DriverID)
    {
        if (HasPermissionDriverServiceAllotLeave)
        {
            var authprov = await auth.GetAuthenticationStateAsync();
            var user = authprov.User;
            int qryResult = Iservice.EndLeave(DriverID, user.Identity.Name);
            if (qryResult > 0)
            {
                collection.Find(x => x.DriverID == DriverID).UserInfo.RecordStatus = 3;
                StateHasChanged();
            }
        }
        else
        {
            bool? result = await DialogService.ShowMessageBox(
                "Permission denied!",
                "You dont have any permission to AllotLeave to Driver.");
        }
    }

    private async Task Edit(int? id)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        _busy = true;
        if (HasPermissionDriverServiceEdit)
        {
            var parameters = new DialogParameters();
            parameters.Add("model", id != 0 ? collection.FirstOrDefault(x => x.DriverID == id) : new DriverModel());
            DialogOptions maxWidth = new DialogOptions() { MaxWidth = MaxWidth.Medium, FullWidth = true };
            var dialog = DialogService.Show<DriverDialog>("Driver", parameters, maxWidth);
            var result = await dialog.Result;
            if (!result.Canceled)
            {
                DriverModel editedModel = (DriverModel)result.Data;
                if (collection.Exists(x => x.DriverID == editedModel.DriverID))
                {
                    collection[collection.FindIndex(x => x.DriverID == editedModel.DriverID)] = editedModel;
                }
                else
                {
                    collection.Add(editedModel);
                }
            }
        }
        else
        {
            bool? ResultModel = await DialogService.ShowMessageBox(
                "Permission denied!",
                "You dont have any permission to Add or Edit Driver.");
        }
        GetAll();
        StateHasChanged();
        await Task.Delay(200);
        _busy = false;
    }

    private async Task Resign(int? driverId)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        _busy = true;
        if (HasPermissionDriverServiceResign)
        {
            var parameters = new DialogParameters();
            DriverResignModel model = new();
            model.Driver = collection.FirstOrDefault(x => x.DriverID == driverId);
            parameters.Add("model", model);
            parameters.Add("driverId", driverId);
            DialogOptions maxWidth = new DialogOptions() { MaxWidth = MaxWidth.Medium, FullWidth = true };
            var dialog = DialogService.Show<DriverResignDialog>("Resign Driver", parameters, maxWidth);
            var result = await dialog.Result;

            // Check if the driver resigned successfully
            if (result.Cancelled == false)
            {
                // Call the Delete service method
                try
                {
                    var authprov = await auth.GetAuthenticationStateAsync();
                    var user = authprov.User;
                    Iservice.Delete(driverId, user.Identity.Name);
                }
                catch (Exception ex)
                {
                    snackbar.Add(ex.Message, Severity.Error);
                }
            }
            GetAll();
        }
        else
        {
            bool? result = await DialogService.ShowMessageBox(
                "Permission denied!",
                "You dont have any permission to Resign Driver.");
        }
        await Task.Delay(200);
        _busy = false;
    }

    private async Task Transfer(int? DriverID)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        _busy = true;
        if (HasPermissionDriverTransferEdit)
        {
            DriverTransferInitiationModel DriverTransfer = new();
            var DriverData = collection.FirstOrDefault(x => x.DriverID == DriverID);
            DriverTransfer.Driver = DriverData;
            var parameters = new DialogParameters();
            parameters.Add("model", DriverID != 0 ? DriverTransfer : new());
            DialogOptions maxWidth = new DialogOptions() { MaxWidth = MaxWidth.Medium, FullWidth = true };
            var dialog = DialogService.Show<DriverTransferInitiationDialog>("Transfer Driver", parameters, maxWidth);
            var result = await dialog.Result;
            var isCancelled = result.Cancelled;
            if (!isCancelled)
            {
                var ReturnData = (DriverTransferInitiationModel)result.Data;
                notificationMessage.InitiateBranch = BranchList?.FirstOrDefault(s => s.BranchID == Convert.ToInt32(ReturnData?.InitiatedBranch?.BranchID ?? 0)) ?? null;
                notificationMessage.ReceivedBranch = BranchList?.FirstOrDefault(s => s.BranchID == Convert.ToInt32(ReturnData?.DestinationBranch?.BranchID ?? 0)) ?? null;
                notificationMessage.MessageTitle = "Driver " + (ReturnData?.Driver?.DriverName ?? "") + " is transfered to this branch.";
                notificationMessage.MessageBody = "Driver " + (ReturnData?.Driver?.DriverName ?? "") + " is transfered from " + (notificationMessage?.InitiateBranch?.BranchName ?? "") + " to this branch on " + (DateTime.Now).ToString() + ".";
                notificationMessage.RedirectedTo = 0;
                notificationMessage.ExpiredBy = 7;
                notificationMessage.DocumentID = ReturnData.DriverTransferID;
                notificationMessage.MessageGroupID = "DriverTransfer";
                notificationMessage.PageToRedirectLink = "/DriverTransferView";
                notificationMessage.ClaimValue = "Edit";
                notificationMessage.DocumentTypeID = DocTypeIDDriverTransfer;
                notificationMessage.MsgDate = DateTime.Now;
                await signalRService.Send(notificationMessage);
            }
            GetAll();
        }
        else
        {
            bool? ResultModel = await DialogService.ShowMessageBox(
                "Permission denied!",
                "You dont have any permission to Add or Edit DriverTransfer.");
        }
        await Task.Delay(200);
        _busy = false;
    }

    private async Task Fault(int? DriverID)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        _busy = true;
        if (HasPermissionDriverServiceEdit)
        {
            DriverFaultModel DriverFault = new();
            var DriverData = collection.FirstOrDefault(x => x.DriverID == DriverID);
            DriverFault.Driver = DriverData;
            var parameters = new DialogParameters();
            parameters.Add("model", DriverID != 0 ? DriverFault : new());
            DialogOptions maxWidth = new DialogOptions() { MaxWidth = MaxWidth.Medium, FullWidth = true };
            var dialog = DialogService.Show<DriverFaultDialog>("Driver Fault", parameters, maxWidth);
            var result = await dialog.Result;
            GetAll();
        }
        else
        {
            bool? ResultModel = await DialogService.ShowMessageBox(
                "Permission denied!",
                "You dont have any permission to Add or Edit Driver.");
        }
        await Task.Delay(200);
        _busy = false;
    }

    private async Task RemoveBlacklist(int? DriverID)
    {
        if (HasPermissionDriverFaultServiceEditDriver)
        {
            bool? result = await DialogService.ShowMessageBox(
                "Warning",
                "Are you sure you want to remove from blacklist?",
                yesText: "Delete!", cancelText: "Cancel");
            state = result == null ? "Cancelled" : "Deleted!";

            if (state == "Deleted!")
            {
                var authprov = await auth.GetAuthenticationStateAsync();
                var user = authprov.User;
                int qryResult = Ifaultservice.Delete(DriverID, user.Identity.Name);
                snackbar.Add("Driver removed from Blacklist", Severity.Warning);
            }
            GetAll();
        }
        else
        {
            bool? result = await DialogService.ShowMessageBox(
                "Permission denied!",
                "You dont have any permission to Edit DriverFault.");
        }
    }

    private bool search(DriverModel Driver)
    {
        if (Driver.DriverName != null && Driver.DriverName.Contains(searchDriver, StringComparison.OrdinalIgnoreCase))
        {
            return true;
        }
        return false;
    }

    private async Task OpenTracking()
    {
        DialogOptions para = new DialogOptions() { MaxWidth = MaxWidth.Medium, FullWidth = true };
        DialogService.Show<DriverTrackingDialog>("Driver Tracking", para);
    }

    public async Task ExcelDownload()
    {
        var fileName = "DriverList.xlsx";
        var sheetName = "Sheet1"; // Change the sheet name as needed
        ExcelCollection = Iservice.ExcelDataCollection(BranchID).ToList();
        if (ExcelCollection.Count > 0)
        {
            var fileBytes = GenerateExcelBytes(sheetName);
            await JSRuntime.InvokeVoidAsync("triggerFileDownload", fileName, Convert.ToBase64String(fileBytes));
        }
        else
        {
            bool? result = await DialogService.ShowMessageBox(
                "Oops !",
                "No Data Found.");
        }
    }

    public byte[] GenerateExcelBytes(string sheetName)
    {
        using (var package = new ExcelPackage())
        {
            var worksheet = package.Workbook.Worksheets.Add(sheetName);

            // Add column headers
            worksheet.Cells[1, 1].Value = "HomeBranch Name";
            worksheet.Cells[1, 2].Value = "Driver Name";
            worksheet.Cells[1, 3].Value = "Date Of Birth";
            worksheet.Cells[1, 4].Value = "Adhaar No";
            worksheet.Cells[1, 5].Value = "Contractor/Supplier";
            worksheet.Cells[1, 6].Value = "Reference";
            worksheet.Cells[1, 7].Value = "Mobile No";
            worksheet.Cells[1, 8].Value = "Email";
            worksheet.Cells[1, 9].Value = "Building";
            worksheet.Cells[1, 10].Value = "Street";
            worksheet.Cells[1, 11].Value = "Place";
            worksheet.Cells[1, 12].Value = "City";
            worksheet.Cells[1, 13].Value = "PinCode";
            worksheet.Cells[1, 14].Value = "Beneficiary Name";
            worksheet.Cells[1, 15].Value = "Account Number";
            worksheet.Cells[1, 16].Value = "IFSC Code";
            worksheet.Cells[1, 17].Value = "MICR Code";
            worksheet.Cells[1, 18].Value = "SWIFT Code";
            worksheet.Cells[1, 19].Value = "Bank Name";
            worksheet.Cells[1, 20].Value = "Bank Branch";
            worksheet.Cells[1, 21].Value = "Licence Type";
            worksheet.Cells[1, 22].Value = "Licence No";
            worksheet.Cells[1, 23].Value = "Licence Expiry Date";
            worksheet.Cells[1, 24].Value = "Badge No";
            worksheet.Cells[1, 25].Value = "Badge Expiry Date";
            for (int i = 1; i <= 25; i++)
            {
                worksheet.Cells[1, i].Style.Font.Bold = true;
            }

            worksheet.Column(3).Style.Numberformat.Format = "dd-MM-yyyy"; // Date format
            worksheet.Column(23).Style.Numberformat.Format = "dd-MM-yyyy"; // Date format
            worksheet.Column(25).Style.Numberformat.Format = "dd-MM-yyyy"; // Date format
            //worksheet.Column(15).Style.Numberformat.Format = "0.00"; // Integer format
            //worksheet.Column(16).Style.Numberformat.Format = "0.00"; // Integer format

            // Add data rows
            int row = 2;
            foreach (var item in ExcelCollection)
            {
                worksheet.Cells[row, 1].Value = item.HomeBranchName;
                worksheet.Cells[row, 2].Value = item.DriverName;
                worksheet.Cells[row, 3].Value = item.DateOfBirth;
                worksheet.Cells[row, 4].Value = item.AdhaarNo;
                worksheet.Cells[row, 5].Value = item.DriverAgent.TradeName;
                worksheet.Cells[row, 6].Value = item.AdditionalInfo;
                worksheet.Cells[row, 7].Value = item.Mobile;
                worksheet.Cells[row, 8].Value = item.Email;
                worksheet.Cells[row, 9].Value = item.Address.Building;
                worksheet.Cells[row, 10].Value = item.Address.Street;
                worksheet.Cells[row, 11].Value = item.Address.Place;
                worksheet.Cells[row, 12].Value = item.Address.City;
                worksheet.Cells[row, 13].Value = item.Address.PinCode;
                worksheet.Cells[row, 14].Value = item.BankAccount.BeneficiaryName;
                worksheet.Cells[row, 15].Value = item.BankAccount.AccountNumber;
                worksheet.Cells[row, 16].Value = item.BankAccount.IfscCode;
                worksheet.Cells[row, 17].Value = item.BankAccount.MicrCode;
                worksheet.Cells[row, 18].Value = item.BankAccount.SwiftCode;
                worksheet.Cells[row, 19].Value = item.BankAccount.BankTitle;
                worksheet.Cells[row, 20].Value = item.BankAccount.BankBranch;
                worksheet.Cells[row, 21].Value = item.DriverLicence.LicenceType;
                worksheet.Cells[row, 22].Value = item.DriverLicence.LicenceNo;
                worksheet.Cells[row, 23].Value = item.DriverLicence.DLExpiryDate;
                worksheet.Cells[row, 24].Value = item.DriverLicence.BadgeNo;
                worksheet.Cells[row, 25].Value = item.DriverLicence.BadgeExpiryDate;

                if (item.DriverLicence.DLExpiryDate < DateTime.Now)
                {
                    using (var range = worksheet.Cells[row, 1, row, 25])
                    {
                        range.Style.Fill.PatternType = ExcelFillStyle.Solid;
                        range.Style.Fill.BackgroundColor.SetColor(System.Drawing.Color.Red);
                    }
                }

                row++;
            }

            worksheet.Cells[worksheet.Dimension.Address].Style.Border.Top.Style = ExcelBorderStyle.Thin;
            worksheet.Cells[worksheet.Dimension.Address].Style.Border.Left.Style = ExcelBorderStyle.Thin;
            worksheet.Cells[worksheet.Dimension.Address].Style.Border.Right.Style = ExcelBorderStyle.Thin;
            worksheet.Cells[worksheet.Dimension.Address].Style.Border.Bottom.Style = ExcelBorderStyle.Thin;

            // Save the Excel package to a memory stream
            using (var stream = new MemoryStream())
            {
                package.SaveAs(stream);
                return stream.ToArray();
            }
        }
    }
}