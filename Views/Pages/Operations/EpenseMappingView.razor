@page "/ExpenseMapping"
@inject IDialogService DialogService
@inject IExpenseMappingServices Iservice
@inject MudBlazor.ISnackbar snackbar
@inject AuthenticationStateProvider auth
@attribute [Authorize]
@inject IDialogService DialogService
<MudGrid Spacing="4">
   <MudItem xs="12">
        <MudTable Items="@collection"  Dense="true" Hover="true"  Striped="true" Elevation="10" Filter="new Func<ExpenseMapping, bool>(search)" @bind-place="model">
           

             <ToolBarContent>
                <MudText Typo="Typo.h6">Expense Mapping</MudText>
                <MudIconButton Icon="@Icons.Material.Filled.Add" Title="Add" @onclick="@(()=> OpenDialog(model))"  Color="Color.Dark" Size="Size.Small"></MudIconButton>
                
                <MudSpacer></MudSpacer>
                <MudTextField @bind-Value="searchEma" Placeholder="Search EMA... "
                              Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                              IconSize="Size.Medium" Class="mt-0"></MudTextField>
            </ToolBarContent>
            <HeaderContent>
                <MudTh><MudTableSortLabel SortBy="new Func<ExpenseMapping, object>(x=> x.ExpenseID)" InitialDirection="SortDirection.Ascending">ExpenseID</MudTableSortLabel></MudTh>
             <MudTh><MudTableSortLabel SortBy="new Func<ExpenseMapping, object>(x=> x.ExpenseTitle)" InitialDirection="SortDirection.Ascending">ExpenseTitle</MudTableSortLabel></MudTh>
               
                <MudTh>Actions</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="ExpenseID">@context.ExpenseID</MudTd>
                <MudTd DataLabel="ExpenseTitle">@context.ExpenseTitle</MudTd>
              
                <MudTd DataLabel="">
                    <MudFab @onclick="@(()=> OpenDialog(context))" Color="Color.Primary" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" IconSize="Size.Small" />
                    <MudFab @onclick="@(()=> Delete(context))" Color="Color.Primary" Icon="@Icons.Material.Filled.Delete" Size="Size.Small" IconSize="Size.Small" />
                </MudTd>
            </RowTemplate>
            <PagerContent>
                <MudTablePager PageSizeOptions="new int[] { 5, 10, 20, 50, 100 }" />
            </PagerContent>
        </MudTable>
    </MudItem>
    </MudGrid>

@code {
       private ExpenseMapping model = new ExpenseMapping();
    private List<ExpenseMapping> collection = new List<ExpenseMapping>();

      private string searchEma = "";
       protected override async Task OnInitializedAsync()
    {
        model = new();
        GetAll();
    }
       private  void GetAll()
    {
        collection = new List<ExpenseMapping>();
        //foreach (var item in Iservice.Select.lis)
        //{
        //    collection.Add(item);
        //}
         collection = Iservice.Select ().ToList();

    } 
     private void Delete(ExpenseMapping ep)
    {
        Iservice.Delete(ep.ExpenseID, "Rijas");
        snackbar.Add("Deleted Successfully", Severity.Success);
        GetAll();
    }

    private bool search(ExpenseMapping ep)
    {
     //if (ep.ExpenseID != null && ep.ExpenseID.Contains(searchEma, StringComparison.OrdinalIgnoreCase))
     //   {
     //       return true;
     //   }
     //   else if (ep.ExpenseID == null)
     //   return true;
        return false;
    }
    private async Task OpenDialog(ExpenseMapping ema)
    {
        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;

        DialogParameters parms = new DialogParameters();
        parms.Add("model",ema);
        var dialog =  DialogService.Show<ExpenseMappingDialog>(ema.ExpenseID == null?"ADD":"EDIT",parms);
        var result = await dialog.Result;

        if(!result.Cancelled)
        {   
            ExpenseMapping UpatedModel = (ExpenseMapping)result.Data;            
            model.UserInfo.UserID = user.Identity.Name;

            try
            {

                Iservice.Update(UpatedModel);
                model = new();
                snackbar.Add("Saved Successfully", Severity.Success);
                model = new ExpenseMapping();
                GetAll();
            }
            catch (Exception ex)
            {
                snackbar.Add(ex.Message, Severity.Warning);
            }

        }
    }
}
