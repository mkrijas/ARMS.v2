@using System.Threading;
@attribute [Authorize]
@inject AuthenticationStateProvider auth
@inject IExpenseMappingServices Iservice
@inject IChartOfAccountService accountService
@inject MudBlazor.ISnackbar snackbar
@inject IDialogService DialogService
@inject IRoleService<RoleModel> Irole

<MudDialog Class="admin-dialog-glass">
    <TitleContent>
        <div class="header-section mb-2 pt-4 px-4">
            <div class="d-flex align-center justify-space-between">
                <div class="d-flex align-center">
                    <div class="icon-badge primary-badge mr-4">
                        <div class="admin-header-icon-badge mb-3">
                            <MudIcon Icon="@Icons.Material.Filled.AccountTree" Color="Color.Secondary" Style="font-size: 3rem;" />
                        </div>
                    </div>
                    <div>
                        <MudText Typo="Typo.h5" Class="admin-title"><b>Chart of Account Mapping</b></MudText>
                        <MudText Typo="Typo.body2" Class="admin-subtitle">
                            Synchronize operational expense titles with secondary financial ledgers.
                        </MudText>
                    </div>
                </div>
            </div>
            <div class="title-accent mt-4"></div>
        </div>
    </TitleContent>
    <DialogContent>
        <MudContainer Class="admin-dialog-container">
            <div class="dialog-content-wrapper">
                <EditForm id="formExpenseMapping" Model="@model" OnValidSubmit="OnValidSubmit">
                    <ObjectGraphDataAnnotationsValidator />
                    
                    <div class="admin-glass-card pa-6">
                        <div class="d-flex align-center mb-6">
                            <MudIcon Icon="@Icons.Material.Filled.Tune" Color="Color.Primary" Class="mr-2" />
                            <span class="admin-section-label mb-0">Structural Mapping Details</span>
                        </div>
                        
                        <MudGrid Spacing="3">
                            <MudItem xs="12">
                                <MudTextField @bind-Value="model.ExpenseTitle" Label="Functional Description" Variant="Variant.Outlined" Margin="Margin.Normal" For="@(() => model.ExpenseTitle)" Class="modern-input" Placeholder="Enter expense description..."></MudTextField>
                            </MudItem>
                            
                            <MudItem xs="12">
                                <div class="coa-selector-container py-2">
                                    <CoaSelector @bind-Value="SelectedAccount" LabelName="Regulatory Ledger Account (COA)"></CoaSelector>
                                </div>
                            </MudItem>
                            
                            <MudItem xs="12" md="6">
                                <MudTextField @bind-Value="model.Area" Label="Operational Area" Variant="Variant.Outlined" Margin="Margin.Normal" For="@(() => model.Area)" Class="modern-input" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.LocationOn" Placeholder="e.g., Workshop, Transit"></MudTextField>
                            </MudItem>
                            
                            <MudItem xs="12" md="6">
                                <div class="modern-static-field @(edit == 1 ? "visible" : "invisible")">
                                    <MudTextField @bind-Value="model.ExpenseCode" ReadOnly="true" Label="System Generated Code" Variant="Variant.Outlined" Margin="Margin.Normal" For="@(() => model.ExpenseCode)" Class="modern-input" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.QrCode"></MudTextField>
                                </div>
                            </MudItem>
                        </MudGrid>
                    </div>
                </EditForm>
            </div>
        </MudContainer>
    </DialogContent>
    <DialogActions>
        <div class="d-flex w-100 px-4 pb-4 align-center gap-3">
            <MudSpacer></MudSpacer>
            <MudButton @onclick="Cancel" Variant="Variant.Outlined" Color="Color.Default" Style="border-radius: 12px; font-weight: 700; text-transform: none; border-color: rgba(0,0,0,0.15);">Cancel</MudButton>
            <MudButton Disabled="@_busy" form="formExpenseMapping" Variant="Variant.Filled" ButtonType="ButtonType.Submit" Color="Color.Success" Style="background: var(--mud-palette-success); color: white; font-weight: 800; border-radius: 12px; text-transform: none; white-space: nowrap; padding: 8px 24px;" StartIcon="@Icons.Material.Filled.DoneAll">Submit</MudButton>
        </div>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; }

    [Parameter]
    public ExpenseMapping model { get; set; }
    public string CodeView { get; set; } = "invisible";
    private List<ExpenseMapping> collection = new List<ExpenseMapping>();
    public static int edit = 0;
    private ExpenseMapping tds = new();
    DialogForm dialogForm;
    private ChartOfAccountModel SelectedAccount = null;
    private bool _busy;

    public bool HasPermissionExpenseMappingEdit { get; set; } = false;
    public int DocTypeID = 47;

    // Lifecycle method called when the component is initialized
    protected override async Task OnInitializedAsync()
    {
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionExpenseMappingEdit = await Irole.HasClaim(DocTypeID.ToString(), "Edit", ctc.Token);

        if (model.ExpenseID != null)
        {
            edit = 1;
            CodeView = "visible";
        }
        try
        {
            if (model.MappedCoaID != null && model.MappedCoaID.CoaID != null && model.MappedCoaID.CoaID != 0)
            {
                SelectedAccount = accountService.SelectByID(model.MappedCoaID.CoaID); // Get the selected account
            }
        }
        catch (Exception ex)
        {
            snackbar.Add(ex.Message, Severity.Error);
        }
    }

    // Method called when the form is valid and submitted
    private async Task OnValidSubmit(EditContext context)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is being submitted!", Severity.Warning);
            return;
        }
        _busy = true;
        if (HasPermissionExpenseMappingEdit)
        {
            model.MappedCoaID = SelectedAccount;
            dialogForm.Close(model);
        }
        else
        {
            bool? ResultModel = await DialogService.ShowMessageBoxAsync(
                "Permission denied!",
                "You don't have any permission to Add or Edit Expense.");
        }
        await Task.Delay(200);
        _busy = false;
    }

    // Method to search for accounts based on the search string
    private async Task<IEnumerable<ChartOfAccountModel>> SearchAccounts(string searchString, CancellationToken token)
    {
        return await Task.FromResult(accountService.FilterSubLedgers(searchString));
    }

    private void Cancel() => dialogForm.Cancel();
}
