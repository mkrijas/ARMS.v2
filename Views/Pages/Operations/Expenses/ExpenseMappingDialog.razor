@using System.Threading;
@attribute [Authorize]
@inject AuthenticationStateProvider auth
@inject IExpenseMappingServices Iservice
@inject IChartOfAccountService accountService
@inject MudBlazor.ISnackbar snackbar
@inject IDialogService DialogService
@inject IRoleService<RoleModel> Irole

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.Build" Class="mr-3 mb-n1" />
            Create Expense Mapping
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudContainer Style="min-height:300px;max-height: 800px;">
            <EditForm id="formtdsRate" Model="@model" OnValidSubmit="OnValidSubmit">
                <ObjectGraphDataAnnotationsValidator />
                <ValidationSummary />
                <MudGrid Spacing="2">
                    <MudItem xs="12" md="12">
                        <MudTextField @bind-Value="model.ExpenseTitle" Label="Description" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.ExpenseTitle)"></MudTextField>
                    </MudItem>
                    <MudItem xs="6" md="12">
                        <CoaSelector @bind-Value="SelectedAccount" LabelName="Select Mapped Coa ID"></CoaSelector>
                    </MudItem>
                    <MudItem xs="12" md="12">
                        <MudTextField @bind-Value="model.Area" Label="Area" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.Area)"></MudTextField>
                    </MudItem>
                    <MudItem xs="12" md="12">
                        <MudTextField @bind-Value="model.ExpenseCode" Class="@CodeView" ReadOnly="true" Label="Expense Code" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.ExpenseCode)"></MudTextField>
                    </MudItem>
                </MudGrid>
            </EditForm>
        </MudContainer>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Disabled="@_busy" form="formtdsRate" Variant="Variant.Filled" Color="Color.Success" ButtonType="ButtonType.Submit">Submit</MudButton>
    </DialogActions>
</MudDialog>

@code {

    [Parameter]
    public ExpenseMapping model { get; set; }
    public string CodeView { get; set; } = "invisible";
    private List<ExpenseMapping> collection = new List<ExpenseMapping>();
    public static int edit = 0;
    private ExpenseMapping tds = new();
    [CascadingParameter] MudDialogInstance MudDialog { get; set; }
    private ChartOfAccountModel SelectedAccount = null;
    private bool _busy;

    public bool HasPermissionExpenseMappingEdit { get; set; } = false;
    public int DocTypeID = 47;

    protected override async Task OnInitializedAsync()
    {
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionExpenseMappingEdit = await Irole.HasClaim(DocTypeID.ToString(), "Edit", ctc.Token);

        if (model.ExpenseID != null)
        {
            edit = 1;
            CodeView = "visible";
        }
        try
        {
            if (model.MappedCoaID != null && model.MappedCoaID.CoaID != null && model.MappedCoaID.CoaID != 0)
            {
                SelectedAccount = accountService.SelectByID(model.MappedCoaID.CoaID);
            }
        }
        catch (Exception ex)
        {
            snackbar.Add(ex.Message, Severity.Error);
        }
    }

    private async Task OnValidSubmit(EditContext context)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is being submitted!", Severity.Warning);
            return;
        }
        _busy = true;
        if (HasPermissionExpenseMappingEdit)
        {
            model.MappedCoaID = SelectedAccount;
            MudDialog.Close(model);
        }
        else
        {
            bool? ResultModel = await DialogService.ShowMessageBox(
                "Permission denied!",
                "You dont have any permission to Add or Edit Expense.");
        }
        await Task.Delay(200);
        _busy = false;
    }

    private async Task<IEnumerable<ChartOfAccountModel>> SearchAccounts(string searchString)
    {
        return await Task.FromResult(accountService.FilterSubLedgers(searchString));
    }

    private void Cancel()
    {
        MudDialog.Cancel();
    }
}