@page "/ExpenseMapping"
@inject IDialogService DialogService
@inject IExpenseMappingServices Iservice
@inject MudBlazor.ISnackbar snackbar
@inject AuthenticationStateProvider auth
@attribute [Authorize]
@inject IDialogService DialogService
@using System.Threading;
@inject IRoleService<RoleModel> Irole

<MudGrid Spacing="4">
    <MudItem xs="12">
        <MudTable Items="@collection" Dense="true" Hover="true" Striped="true" Elevation="10" @bind-place="model">
            <ToolBarContent>
                <MudText Typo="Typo.h6">Expense Mapping</MudText>
                <MudIconButton Disabled="@_busy" Icon="@Icons.Material.Filled.Add" Title="Add" @onclick="@(()=> OpenDialog(model))" Color="Color.Dark" Size="Size.Small"></MudIconButton>
                <MudSpacer></MudSpacer>
            </ToolBarContent>
            <HeaderContent>
                <MudTh><MudTableSortLabel SortBy="new Func<ExpenseMapping, object>(x=> x.ExpenseTitle)" InitialDirection="SortDirection.Ascending">ExpenseTitle</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<ExpenseMapping, object>(x=> x.ExpenseCode)" InitialDirection="SortDirection.Ascending">ExpenseCode</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<ExpenseMapping, object>(x=> x.AccountName)" InitialDirection="SortDirection.Ascending">Mapped Chart Of Account</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<ExpenseMapping, object>(x=> x.Area)" InitialDirection="SortDirection.Ascending">Area</MudTableSortLabel></MudTh>
                <MudTh>Actions</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="ExpenseID">@context.ExpenseTitle</MudTd>
                <MudTd DataLabel="ExpenseTitle">@context.ExpenseCode</MudTd>
                <MudTd DataLabel="ExpenseTitle">@context.AccountName</MudTd>
                <MudTd DataLabel="ExpenseID">@context.Area</MudTd>
                <MudTd DataLabel="">
                    <MudFab @onclick="@(()=> OpenDialog(context))" Color="Color.Primary" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" IconSize="Size.Small" />
                    <MudFab @onclick="@(()=> Delete(context))" Color="Color.Primary" Icon="@Icons.Material.Filled.Delete" Size="Size.Small" IconSize="Size.Small" />
                </MudTd>
            </RowTemplate>
            <PagerContent>
                <MudTablePager PageSizeOptions="new int[] { 10, 20, 50, 100 }" />
            </PagerContent>
        </MudTable>
    </MudItem>
</MudGrid>

@code {

    private ExpenseMapping model = new ExpenseMapping();
    private List<ExpenseMapping> collection = new List<ExpenseMapping>();
    public bool IsApproved { get; set; } = false;
    private bool _busy;
    public bool HasPermissionExpenseMappingEdit { get; set; } = false;
    public bool HasPermissionExpenseMappingDelete { get; set; } = false;
    public int DocTypeID = 47;

    private string searchEma = "";

    // Lifecycle method called when the component is initialized
    protected override async Task OnInitializedAsync()
    {
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionExpenseMappingEdit = await Irole.HasClaim(DocTypeID.ToString(), "Edit", ctc.Token);
        HasPermissionExpenseMappingDelete = await Irole.HasClaim(DocTypeID.ToString(), "Delete", ctc.Token);

        model = new();
        GetAll();
    }

    // Method to retrieve all expense mappings
    private void GetAll()
    {
        collection = new List<ExpenseMapping>();
        foreach (var item in Iservice.Select()) // Fetch all expense mappings from the service
        {
            collection.Add(item);
        }
    }

    // Method to delete an expense mapping
    private async Task Delete(ExpenseMapping model)
    {
        if (HasPermissionExpenseMappingDelete)
        {
            bool? result = await DialogService.ShowMessageBox(
                "Warning !",
                "Are you sure, you want to delete - " + model.ExpenseTitle + " (" + model.ExpenseCode + ") ?");
            if (result == true)
            {
                var authprov = await auth.GetAuthenticationStateAsync();
                var user = authprov.User;

                // Call the service to delete the expense mapping
                int value = Iservice.Delete(model.ExpenseID, user.Identity.Name);
                if (value != -1)
                {
                    if (collection != null && collection.Any(s => s.ExpenseID == model.ExpenseID))
                    {
                        collection.Remove(collection.FirstOrDefault(s => s.ExpenseID == model.ExpenseID));
                        snackbar.Add("Deleted Successfully", Severity.Success);
                    }
                }
            }
        }
        else
        {
            bool? result = await DialogService.ShowMessageBox(
                "Permission denied!",
                "You don't have any permission to Delete Expense.");
        }
    }

    // Method to open the dialog
    private async Task OpenDialog(ExpenseMapping ema)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        _busy = true;
        if (HasPermissionExpenseMappingEdit)
        {
            var authprov = await auth.GetAuthenticationStateAsync();
            var user = authprov.User;
            DialogParameters parms = new DialogParameters();
            parms.Add("model", ema.Clone());
            var dialog = DialogService.Show<ExpenseMappingDialog>(ema.ExpenseID == null ? "ADD" : "EDIT", parms);
            var result = await dialog.Result;
            if (!result.Cancelled)
            {
                ExpenseMapping UpatedModel = (ExpenseMapping)result.Data;
                UpatedModel.UserInfo.UserID = user.Identity.Name;
                try
                {
                    // Call the service to update the expense mapping
                    var ResultModel = Iservice.Update(UpatedModel);
                    if (ResultModel != null)
                    {
                        if (collection.Exists(x => x.ExpenseID == ResultModel.ExpenseID))
                        {
                            collection[collection.FindIndex(x => x.ExpenseID == ResultModel.ExpenseID)] = ResultModel;
                        }
                        else
                        {
                            collection.Add(ResultModel);
                        }
                        UpatedModel = new();
                        ResultModel = new();
                        model = new();
                        snackbar.Add("Saved Successfully", Severity.Success);
                    }
                }
                catch (Exception ex)
                {
                    snackbar.Add(ex.Message, Severity.Warning);
                }
            }
        }
        else
        {
            bool? ResultModel = await DialogService.ShowMessageBox(
                "Permission denied!",
                "You don't have any permission to Add or Edit Expense.");
        }
        await Task.Delay(200);
        _busy = false;
    }
}