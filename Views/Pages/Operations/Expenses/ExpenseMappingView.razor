@page "/ExpenseMapping"
@inject IDialogService DialogService
@inject IExpenseMappingServices Iservice
@inject MudBlazor.ISnackbar snackbar
@inject AuthenticationStateProvider auth
@attribute [Authorize]
@inject IDialogService DialogService
@using System.Threading;
@inject IRoleService<RoleModel> Irole

<div class="admin-page-container">
    <div class="admin-header-tiered mb-6">
        <div class="d-flex align-center justify-space-between">
            <div>
                <MudText Typo="Typo.h4" Class="admin-title">Expense Mapping</MudText>
                <MudText Typo="Typo.body2" Class="admin-subtitle">Link operational expense codes to Chart of Accounts for automated financial posting.</MudText>
            </div>
            <MudButton StartIcon="@Icons.Material.Filled.Add" Variant="Variant.Filled" Color="Color.Primary" Class="admin-register-btn" OnClick="@(()=> OpenDialog(new ExpenseMapping()))" Disabled="@_busy">ADD MAPPING</MudButton>
        </div>
    </div>

    <div class="admin-glass-card pa-0 overflow-hidden">
        <MudTable Items="@collection" Dense="true" Hover="true" Elevation="0" Class="modern-admin-table">
            <HeaderContent>
                <MudTh><MudTableSortLabel SortBy="new Func<ExpenseMapping, object>(x=> x.ExpenseTitle)" InitialDirection="SortDirection.Ascending"><span class="admin-header-text">EXPENSE TITLE</span></MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<ExpenseMapping, object>(x=> x.ExpenseCode)" InitialDirection="SortDirection.Ascending"><span class="admin-header-text">CODE</span></MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<ExpenseMapping, object>(x=> x.AccountName)" InitialDirection="SortDirection.Ascending"><span class="admin-header-text">MAPPED COA ACCOUNT</span></MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<ExpenseMapping, object>(x=> x.Area)" InitialDirection="SortDirection.Ascending"><span class="admin-header-text">AREA</span></MudTableSortLabel></MudTh>
                <MudTh Style="text-align: right;"><span class="admin-header-text">ACTIONS</span></MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Expense Title"><MudText Typo="Typo.body2" Class="admin-td-primary">@context.ExpenseTitle</MudText></MudTd>
                <MudTd DataLabel="Code"><MudText Typo="Typo.body2" Class="admin-td-secondary fw-700">@context.ExpenseCode</MudText></MudTd>
                <MudTd DataLabel="Mapped Account"><MudText Typo="Typo.body2" Class="admin-td-primary">@context.AccountName</MudText></MudTd>
                <MudTd DataLabel="Area"><MudChip T="string" Size="Size.Small" Variant="Variant.Text" Color="Color.Info" Class="pa-0">@context.Area</MudChip></MudTd>
                <MudTd DataLabel="Actions" Style="text-align: right;">
                    <div class="d-flex justify-end gap-1">
                        <MudTooltip Text="Edit">
                            <MudIconButton OnClick="@(()=> OpenDialog(context))" Color="Color.Primary" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Variant="Variant.Text" />
                        </MudTooltip>
                        <MudTooltip Text="Delete">
                            <MudIconButton OnClick="@(()=> Delete(context))" Color="Color.Error" Icon="@Icons.Material.Filled.DeleteOutline" Size="Size.Small" Variant="Variant.Text" />
                        </MudTooltip>
                    </div>
                </MudTd>
            </RowTemplate>
            <PagerContent>
                <div class="pa-4">
                    <MudTablePager PageSizeOptions="new int[] { 10, 20, 50, 100 }" />
                </div>
            </PagerContent>
        </MudTable>
    </div>
</div>

@code {

    private ExpenseMapping model = new ExpenseMapping();
    private List<ExpenseMapping> collection = new List<ExpenseMapping>();
    public bool IsApproved { get; set; } = false;
    private bool _busy;
    public bool HasPermissionExpenseMappingEdit { get; set; } = false;
    public bool HasPermissionExpenseMappingDelete { get; set; } = false;
    public int DocTypeID = 47;

    private string searchEma = "";

    // Lifecycle method called when the component is initialized
    protected override async Task OnInitializedAsync()
    {
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionExpenseMappingEdit = await Irole.HasClaim(DocTypeID.ToString(), "Edit", ctc.Token);
        HasPermissionExpenseMappingDelete = await Irole.HasClaim(DocTypeID.ToString(), "Delete", ctc.Token);

        model = new();
        GetAll();
    }

    // Method to retrieve all expense mappings
    private void GetAll()
    {
        collection = new List<ExpenseMapping>();
        foreach (var item in Iservice.Select()) // Fetch all expense mappings from the service
        {
            collection.Add(item);
        }
    }

    // Method to delete an expense mapping
    private async Task Delete(ExpenseMapping model)
    {
        if (HasPermissionExpenseMappingDelete)
        {
            bool? result = await DialogService.ShowMessageBoxAsync(
                "Warning !",
                "Are you sure, you want to delete - " + model.ExpenseTitle + " (" + model.ExpenseCode + ") ?");
            if (result == true)
            {
                var authprov = await auth.GetAuthenticationStateAsync();
                var user = authprov.User;

                // Call the service to delete the expense mapping
                int value = Iservice.Delete(model.ExpenseID, user.Identity.Name);
                if (value != -1)
                {
                    if (collection != null && collection.Any(s => s.ExpenseID == model.ExpenseID))
                    {
                        collection.Remove(collection.FirstOrDefault(s => s.ExpenseID == model.ExpenseID));
                        snackbar.Add("Deleted Successfully", Severity.Success);
                    }
                }
            }
        }
        else
        {
            bool? result = await DialogService.ShowMessageBoxAsync(
                "Permission denied!",
                "You don't have any permission to Delete Expense.");
        }
    }

    // Method to open the dialog
    private async Task OpenDialog(ExpenseMapping ema)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        _busy = true;
        if (HasPermissionExpenseMappingEdit)
        {
            var authprov = await auth.GetAuthenticationStateAsync();
            var user = authprov.User;
            DialogParameters parms = new DialogParameters();
            parms.Add("model", ema.Clone());
            var dialog = await DialogService.ShowAsync<ExpenseMappingDialog>(ema.ExpenseID == null ? "ADD" : "EDIT", parms);
            var result = await dialog.Result;
            if (!result.Canceled)
            {
                ExpenseMapping UpatedModel = (ExpenseMapping)result.Data;
                UpatedModel.UserInfo.UserID = user.Identity.Name;
                try
                {
                    // Call the service to update the expense mapping
                    var ResultModel = Iservice.Update(UpatedModel);
                    if (ResultModel != null)
                    {
                        if (collection.Exists(x => x.ExpenseID == ResultModel.ExpenseID))
                        {
                            collection[collection.FindIndex(x => x.ExpenseID == ResultModel.ExpenseID)] = ResultModel;
                        }
                        else
                        {
                            collection.Add(ResultModel);
                        }
                        UpatedModel = new();
                        ResultModel = new();
                        model = new();
                        snackbar.Add("Saved Successfully", Severity.Success);
                    }
                }
                catch (Exception ex)
                {
                    snackbar.Add(ex.Message, Severity.Warning);
                }
            }
        }
        else
        {
            bool? ResultModel = await DialogService.ShowMessageBoxAsync(
                "Permission denied!",
                "You don't have any permission to Add or Edit Expense.");
        }
        await Task.Delay(200);
        _busy = false;
    }
}

