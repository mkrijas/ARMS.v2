@page "/TripReviewManager"
@using System.ComponentModel.DataAnnotations
@layout AdminMainLayout
@attribute [Authorize]
@inject AuthenticationStateProvider auth
@inject IBranchService Ibranch
@inject ITruckService Itruck
@inject IDriverService Idriver
@inject ITripService Itrip

<div class="admin-page-container">
    <div class="admin-header-tiered mb-6">
        <div class="d-flex align-center justify-space-between">
            <div>
                <MudText Typo="Typo.h4" Class="admin-title">Trip Settlement</MudText>
                <MudText Typo="Typo.body2" Class="admin-subtitle">Review, settle, and audit trip expenses and fuel records.</MudText>
            </div>
        </div>
    </div>

    <div class="admin-glass-card pa-6 mb-6">
        <EditForm id="form" Model="@Selector" OnValidSubmit="OnValidSubmit">
            <MudGrid Spacing="3" Class="align-end">
                <MudItem xs="12" sm="3">
                    <MudSelect T="int?" @bind-Value="Selector.BranchID" Label="Branch" Variant="Variant.Outlined" Margin="Margin.Dense" Class="modern-input" Color="Color.Primary" AnchorOrigin="Origin.BottomCenter">
                        @foreach (var br in branches)
                        {
                            <MudSelectItem T="int?" Value="br.BranchID">@br.BranchName</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="6" sm="2">
                    <MudSelect T="int" @bind-Value="Selector.Year" Label="Financial Year" Variant="Variant.Outlined" Margin="Margin.Dense" Class="modern-input" Color="Color.Primary">
                        @foreach (var y in Years)
                        {
                            <MudSelectItem Value="@y">@y</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="6" sm="2">
                    <MudSelect T="int" @bind-Value="Selector.Month" Label="Month" Variant="Variant.Outlined" Margin="Margin.Dense" Class="modern-input" Color="Color.Primary">
                        @foreach (var m in Months)
                        {
                            <MudSelectItem Value="@m">@System.Globalization.DateTimeFormatInfo.CurrentInfo.GetMonthName(m)</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" sm="3">
                    <MudNumericField T="int?" @bind-Value="Selector.TripNumber" Label="Trip Number" Variant="Variant.Outlined" Margin="Margin.Dense" Class="modern-input" />
                </MudItem>
                <MudItem xs="12" sm="2">
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true" ButtonType="ButtonType.Submit" Style="height: 40px;" Class="fw-600">FIND TRIP</MudButton>
                </MudItem>
            </MudGrid>
        </EditForm>
    </div>

    @if (SelectedTrip != null)
    {
        <div class="trip-details-container fade-in">
            <TripDetailsCard Trip="SelectedTrip" @ref="TripDetailsComponentRef"></TripDetailsCard>
        </div>
    }
    else
    {
        <div class="trip-details-container opacity-50">
            <TripDetailsCard Trip="new TripModel()"></TripDetailsCard>
        </div>
    }
</div>

@code {

    private TripDetailsCard TripDetailsComponentRef = new();
    private TripModel SelectedTrip { get; set; }
    private TripSelector Selector = new();
    private List<BranchModel> branches = new();
    private int[] Years = Array.Empty<int>();
    private int[] Months = Array.Empty<int>();

    // Method called when the component is initialized
    protected override async Task OnInitializedAsync()
    {
        var authprov = await auth.GetAuthenticationStateAsync();
        // Load the list of branches
        branches = Ibranch.Select().ToList();

        Selector = new();
        Selector.BranchID = int.Parse(authprov.User.Claims.FirstOrDefault(c => c.Type == "BranchID").Value);
        Selector.Year = DateTime.Today.Year;
        Selector.Month = DateTime.Today.Month;

        int range = Selector.Year - 2021;
        Years = Enumerable.Range(2021, range + 1).ToArray();
        Months = Enumerable.Range(1, 12).ToArray();
    }

    // Class to hold the selection criteria for trips
    class TripSelector
    {
        [Required]
        public int? BranchID { get; set; }
        [Required]
        public int Year { get; set; }
        [Required]
        public int Month { get; set; }
        [Required]
        public int? TripNumber { get; set; }
    }

    // Method called when the form is submitted and is valid
    private void OnValidSubmit(EditContext context)
    {
        string TripNumber = "T/" + Selector?.BranchID.ToString() + "/" + Selector.Year.ToString().Substring(2) + Selector.Month.ToString("00") + "/" + ((int?)Selector?.TripNumber).ToString();
        SelectedTrip = Itrip.SelectByTripNumber(TripNumber);
        if (SelectedTrip != null)
        {
            TripDetailsComponentRef.Refresh(SelectedTrip);
        }
    }
}
