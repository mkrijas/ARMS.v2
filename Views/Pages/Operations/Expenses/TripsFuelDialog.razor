@attribute [Authorize]
@inject AuthenticationStateProvider auth
@using System.Threading;
@using ArmsServices.DataServices.General
@using Core.IDataServices.Operations
@inject MudBlazor.ISnackbar snackbar
@inject ITripFuelService Iservice
@inject IInventoryItemService InvService
@inject ITripService tripService;
@inject ITruckAvailabilityService truckAvailabilityService;
@inject IDialogService DialogService
@inject IPartyService partyService
@inject IGstItemService gstItemService
@inject ITdsRateService tdsService
@inject ITaxPurchaseService taxPurchase
@inject IConfigTable IConfig
@inject IRoleService<RoleModel> Irole
@inject IPushNotificationService notiService


<EditForm id="formfuel" Model="@Tmodel" OnValidSubmit="OnValidSubmit">
    <ObjectGraphDataAnnotationsValidator />
    <ValidationSummary />
    <MudDialog>
        <TitleContent>
            <MudText Typo="Typo.h6">
                <MudIcon Icon="@Icons.Material.Filled.Build" Class="mr-3 mb-n1" />
                Fueling
            </MudText>
        </TitleContent>
        <DialogContent>
            <MudContainer Style="min-height:300px;max-height:800px;">
                <MudGrid Spacing="3">
                    <MudItem xs="12" md="12">
                        <MudRadioGroup @bind-SelectedOption="Tmodel.ItemType">
                            <MudRadio Option="@("Fuel")" Color="Color.Primary">Fuel</MudRadio>
                            <MudRadio Option="@("AdBlue")" Color="Color.Primary">AdBlue</MudRadio>
                        </MudRadioGroup>
                    </MudItem>
                    <MudItem xs="12" md="4">
                        <MudDatePicker Label="Entry Date" Variant="Variant.Outlined" Margin="Margin.Dense" DisableToolbar="true" Editable="true" DateFormat="dd/MM/yyyy" @bind-Date="Tmodel.EntryDate" Disabled/>
                    </MudItem>
                    @if (Tmodel.ItemType == "Fuel")
                    {
                        <MudItem xs="12" md="4">
                            <InventoryItemSelector Value="invItem" CurrentVariant="Variant.Outlined" CurrentMargine="Margin.Dense" ValueChanged="FuelItemSelected" ItemGroup2="Fuel" ItemGroup="@FuelGroupID"></InventoryItemSelector>
                        </MudItem>
                    }
                    @if (Tmodel.ItemType == "AdBlue")
                    {
                        <MudItem xs="12" md="4">
                            <InventoryItemSelector Value="invItem" CurrentVariant="Variant.Outlined" CurrentMargine="Margin.Dense" ValueChanged="FuelItemSelected" ItemGroup2="AdBlue" ItemGroup="@AdBlueGroupID"></InventoryItemSelector>
                        </MudItem>
                    }
                    <MudItem xs="12" md="4">
                        <MudTextField @bind-Value="Tmodel.Quantity" TextChanged="(()=> Tmodel.Amount = Tmodel.RatePerLitre * Tmodel.Quantity)" Adornment="Adornment.End" AdornmentText="@invItem?.UoM" Label="Quantity" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => Tmodel.Quantity)"></MudTextField>
                    </MudItem>
                    <MudItem xs="12" md="4">
                        <MudTextField @bind-Value="Tmodel.RefInvoiceNo" Label="Reference Invoice No" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => Tmodel.RefInvoiceNo)"></MudTextField>
                    </MudItem>
                    <MudItem xs="12" md="4" >
                        <CostCenterSelector @bind-Value="@Tmodel.CostCenter" ></CostCenterSelector>
                    </MudItem>
                    <MudItem xs="12" md="4">
                        <DimensionSelector @bind-Value="@Tmodel.Dimension"   ></DimensionSelector>
                    </MudItem>
                    <MudItem xs="12" md="4">
                        <MudCheckBox CheckedChanged="((bool e)=>SetUsedItem(e))" Checked="Tmodel.IsUsedItem" Label="Used Item" Color="Color.Primary"></MudCheckBox>
                    </MudItem>
                    
                    @if (Tmodel.IsPurchase)
                    {
                        <MudItem xs="12">
                            <MudText Typo="Typo.h4" Class="mt-4">Invoice Details</MudText>
                            <MudDivider DividerType="DividerType.Middle" Class="my-6" />
                        </MudItem>
                        <MudItem xs="12" md="4">
                            <PartySelector @bind-Value="Tmodel.PurchaseModel.PartyInfo" BranchID="branchID" NatureOfBusiness="Supplier"></PartySelector>
                        </MudItem>
                        <MudItem xs="12" md="4">
                            <MudTextField @bind-Value="Tmodel.PurchaseModel.InvoiceNo" Label="Invoice No" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => Tmodel.PurchaseModel.InvoiceNo)"></MudTextField>
                        </MudItem>
                        <MudItem xs="12" md="4">
                            <MudDatePicker Label="Invoice Date" Variant="Variant.Outlined" Margin="Margin.Dense" DisableToolbar="true" Editable="true" DateFormat="dd/MM/yyyy" @bind-Date="Tmodel.PurchaseModel.InvoiceDate" />
                        </MudItem>
                        <MudItem xs="12" md="4">
                            <MudTextField @bind-Value="Tmodel.RatePerLitre" TextChanged="(()=> Tmodel.Amount = Tmodel.RatePerLitre * Tmodel.Quantity)" Label="Rate Per Liter" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => Tmodel.RatePerLitre)"></MudTextField>
                        </MudItem>
                        <MudItem xs="12" md="4">
                            <MudTextField @bind-Value="Tmodel.Amount" TextChanged="(()=>  Tmodel.RatePerLitre  = Tmodel.Amount / Tmodel.Quantity)" Label="Amount" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => Tmodel.Amount)"></MudTextField>
                        </MudItem>
                        <MudItem xs="12" md="4">
                            <MudTextField @bind-Value="Tmodel.PurchaseModel.Narration" Label="Remarks" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => Tmodel.PurchaseModel.Narration)"></MudTextField>
                        </MudItem>
                    }
                </MudGrid>
            </MudContainer>
        </DialogContent>
        <DialogActions>
            <MudCheckBox @bind-Checked="@Tmodel.IsPurchase" Color="Color.Primary" Label="Is Purchase?"></MudCheckBox>
            <MudButton Disabled="@_busy" form="formfuel" Variant="Variant.Filled" Color="Color.Success" ButtonType="ButtonType.Submit">Submit</MudButton>
            <MudButton @onclick="Cancel" Variant="Variant.Filled" Color="Color.Primary">Cancel</MudButton>
        </DialogActions>
    </MudDialog>
</EditForm>

@code {

    [Parameter]
    public TripFuelModel Tmodel { get; set; }
    [Parameter]
    public String TripNumberDisplay { get; set; }
    [Parameter]
    public String TruckNumber { get; set; }
    private List<CostCenterModel> costCenter = new();
    private List<DimensionModel> dimension = new();
    //public bool? IsPur = null;
    [CascadingParameter] MudDialogInstance MudDialog { get; set; }
    private InventoryItemModel invItem;
    private int FuelGroupID;
    private int AdBlueGroupID;
    private bool _busy;

    public bool HasPermissionTripFuelServiceEdit { get; set; } = false;
    public int DocTypeID = 40;

    int branchID;
    string UserID;

    private async void OnValidSubmit()
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is being submitted!", Severity.Warning);
            return;
        }
        _busy = true;
        if (HasPermissionTripFuelServiceEdit)
        {

            Tmodel.PurchaseModel.BranchID = branchID;
            Tmodel.PurchaseModel.UserInfo.UserID = UserID;
            TaxPurchaseItemModel item = Tmodel.PurchaseModel.Items.FirstOrDefault();
            if (item == null)
            {
                item = new TaxPurchaseItemModel();
                Tmodel.PurchaseModel.Items.Add(item);
            }
            item.ItemQty = Tmodel.Quantity;
            item.ItemID = Tmodel.FuelItemID;
            item.CostCenter = Tmodel.CostCenter;
            item.Dimension = Tmodel.Dimension;

            if (Tmodel.IsPurchase)
            {
                Tmodel.PurchaseModel.NonStoreInventory = true;
                item.ItemRate = Tmodel.RatePerLitre;
                item.Amount = Tmodel.Amount;
                item.CoaID = invItem.Group.MappedNonInventoryPurchaseHead;
                item.GstRate = gstItemService.SelectByItem(Tmodel.FuelItemID ?? 0)?.FirstOrDefault()?.TaxRate ?? 0;
                if (item.GstRate != null && item.GstRate != 0)
                {
                    if (partyService.IsLocal(Tmodel.PurchaseModel.PartyInfo.PartyID, branchID))
                    {
                        item.CGST = Math.Round((item.Amount ?? 0) * (item.GstRate ?? 0) / 200, 2);
                        item.SGST = Math.Round((item.Amount ?? 0) * (item.GstRate ?? 0) / 200, 2);
                    }
                    else
                    {
                        item.IGST = Math.Round((item.Amount ?? 0) * (item.GstRate ?? 0) / 100, 2);
                    }
                }
                //Tmodel.PurchaseModel.Narration = Tmodel.Quantity.ToString() + " Ltr";
                var tdsRate = tdsService.GetTdsRate(Tmodel.PurchaseModel.PartyInfo.PartyID ?? 0, item.CoaID ?? 0);
                item.TDS = Math.Round((item.Amount ?? 0) * tdsRate / 100, MidpointRounding.AwayFromZero);
                Tmodel.Amount = item.Amount + (item.CGST??0) + (item.SGST??0) + (item.IGST??0);
                try
                {
                    Tmodel.PurchaseModel.TaxPurchaseType = "Fuel";
                    Tmodel.PurchaseModel = taxPurchase.Update(Tmodel.PurchaseModel);
                    notiService.CreateAuthNotifications(branchID, 9, Tmodel.PurchaseModel.PID.Value);
                }
                catch (Exception ex)
                {
                    snackbar.Add(ex.Message, Severity.Error);
                    goto ExitCode;
                }
            }

            try
            {
                Tmodel = Iservice.Update(Tmodel);
                snackbar.Add("Saved Successfully", Severity.Success);

                MudDialog.Close(Tmodel);
                Tmodel = new();
            }
            catch (Exception ex)
            {
                snackbar.Add(ex.Message, Severity.Error);
                goto ExitCode;
            }            
        }
        else
        {
            bool? ResultModel = await DialogService.ShowMessageBox(
                "Permission denied!",
                "You dont have any permission to Add or Edit TripFuel.");
        }
    ExitCode:
        await Task.Delay(200);
        _busy = false;
        StateHasChanged();
    }

    public void SetUsedItem(bool val)
    {
        Tmodel.IsUsedItem = val;
    }

    protected override async Task OnInitializedAsync()
    {
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionTripFuelServiceEdit = await Irole.HasClaim(DocTypeID.ToString(), "Edit", ctc.Token);

        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;
        branchID = int.Parse(authprov.User.Claims.First(x => x.Type == "BranchID").Value);
        UserID = user.Identity.Name;
        if (Tmodel.TripID == null)
        {
            var transfer = truckAvailabilityService.GetTransferByID(Tmodel.RequestApprovalHistoryID);
            Tmodel.PurchaseModel.Narration = "Transfer NO: " + transfer.DocNumber + " Truck NO: " + transfer.Truck.RegNo; // + " QTY: " + Tmodel.Quantity.ToString() + " Ltr";
            Tmodel.Narration = "Transfer NO: " + transfer.DocNumber + " Truck NO: " + transfer.Truck.RegNo; // + " QTY: " + Tmodel.Quantity.ToString() + " Ltr";
        }
        else
        {
            Tmodel.PurchaseModel.Narration = "Trip NO: " + TripNumberDisplay + " Truck NO: " + TruckNumber; // + " QTY: " + Tmodel.Quantity.ToString() + " Ltr";
            Tmodel.Narration = "Trip NO: " + TripNumberDisplay + " Truck NO: " + TruckNumber; // + " QTY: " + Tmodel.Quantity.ToString() + " Ltr";
        }

        if (Tmodel != null && Tmodel.FuelItemID != null)
        {
            invItem = InvService.SelectByID(Tmodel.FuelItemID);

        }
        int.TryParse(IConfig.GetByInventoryFuelGroupID().ValueString, out FuelGroupID);

        int.TryParse(IConfig.GetByInventoryAdBlueGroupID().ValueString, out AdBlueGroupID);


        if (Tmodel.ItemType == null)
        {
            Tmodel.ItemType = "Fuel";
        }
    }

    private void Cancel()
    {
        MudDialog.Close();
    }

    void FuelItemSelected(InventoryItemModel item)
    {
        invItem = item;
        Tmodel.FuelItemID = item?.InventoryItemID;
    }

    void ShowTaxInfo()
    {
        var item = Tmodel.PurchaseModel.Items[0];
        GstModel gst = new GstModel()
            {
                CGST = item.CGST,
                IGST = item.IGST,
                SGST = item.SGST,
                TDS = item.TDS,
                GstRate = item.GstRate
            };
        DialogParameters parms = new DialogParameters();
        parms.Add("tax", gst.Clone());
        var dialog = DialogService.Show<TaxRatedialog>("Tax Details", parms);
    }
}