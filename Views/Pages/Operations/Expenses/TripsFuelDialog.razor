@attribute [Authorize]
@inject AuthenticationStateProvider auth
@using System.Threading;
@using System.Transactions;
@using ArmsServices.DataServices.General
@using Core.IDataServices.Operations
@inject MudBlazor.ISnackbar snackbar
@inject ITripFuelService Iservice
@inject IInventoryItemService InvService
@inject ITripService tripService;
@inject ITruckAvailabilityService truckAvailabilityService;
@inject IDialogService DialogService
@inject IPartyService partyService
@inject IGstItemService gstItemService
@inject ITdsRateService tdsService
@inject ITaxPurchaseService taxPurchase
@inject IConfigTable IConfig
@inject IRoleService<RoleModel> Irole
@inject IPushNotificationService notiService


<MudDialog Class="admin-dialog-glass">
    <TitleContent>
        <div class="header-section mb-2 pt-4 px-4">
            <div class="d-flex align-center justify-space-between">
                <div class="d-flex align-center">
                    <div class="icon-badge primary-badge mr-4">
                        <div class="admin-header-icon-badge mb-3">
                            <MudIcon Icon="@Icons.Material.Filled.LocalGasStation" Color="Color.Secondary" Style="font-size: 3rem;" />
                        </div>
                    </div>
                    <div>
                        <MudText Typo="Typo.h5" Class="admin-title"><b>Fueling Management</b></MudText>
                        <MudText Typo="Typo.body2" Class="admin-subtitle">
                            Register energy consumption and reconcile purchase invoices for operational manifests.
                        </MudText>
                    </div>
                </div>
            </div>
            <div class="title-accent mt-4"></div>
        </div>
    </TitleContent>
    <DialogContent>
        <MudContainer Class="admin-dialog-container">
            <div class="dialog-content-wrapper">
                <EditForm id="formfuel" Model="@Tmodel" OnValidSubmit="OnValidSubmit">
                    <div class="admin-glass-card pa-6">
                        <ObjectGraphDataAnnotationsValidator />
                        <ValidationSummary />
                        <MudGrid Spacing="3">
                            <MudItem xs="12" md="12">
                                <MudRadioGroup T="string" @bind-Value="Tmodel.ItemType">
                                    <MudRadio Value="@("Fuel")" Color="Color.Primary">Fuel</MudRadio>
                                    <MudRadio Value="@("AdBlue")" Color="Color.Primary">AdBlue</MudRadio>
                                </MudRadioGroup>
                            </MudItem>
                            <MudItem xs="12" md="4">
                                <MudDatePicker Label="Entry Date" Variant="Variant.Outlined" Margin="Margin.Dense" DisableToolbar="true" Editable="true" DateFormat="dd/MM/yyyy" @bind-Date="Tmodel.EntryDate" Disabled Class="modern-input" />
                            </MudItem>
                            @if (Tmodel.ItemType == "Fuel")
                            {
                                <MudItem xs="12" md="4">
                                    <InventoryItemSelector Value="invItem" CurrentVariant="Variant.Outlined" CurrentMargine="Margin.Dense" ValueChanged="FuelItemSelected" ItemGroup2="Fuel" ItemGroup="@FuelGroupID" Class="modern-input"></InventoryItemSelector>
                                    <ValidationMessage For="@(() => Tmodel.FuelItemID)">Please select an item</ValidationMessage>
                                </MudItem>
                            }
                            @if (Tmodel.ItemType == "AdBlue")
                            {
                                <MudItem xs="12" md="4">
                                    <InventoryItemSelector Value="invItem" CurrentVariant="Variant.Outlined" CurrentMargine="Margin.Dense" ValueChanged="FuelItemSelected" ItemGroup2="AdBlue" ItemGroup="@AdBlueGroupID" Class="modern-input"></InventoryItemSelector>
                                    <ValidationMessage For="@(() => Tmodel.FuelItemID)">Please select an item</ValidationMessage>
                                </MudItem>
                            }
                            <MudItem xs="12" md="4">
                                <MudTextField T="decimal?" Value="@Tmodel.Quantity" ValueChanged="(decimal? v) => OnQuantityChanged(v)" Adornment="Adornment.End" AdornmentText="@invItem?.UoM" Label="Quantity" Variant="Variant.Outlined" Margin="Margin.Dense" Class="modern-input" For="@(() => Tmodel.Quantity)"></MudTextField>
                            </MudItem>
                            <MudItem xs="12" md="4">
                                <MudTextField @bind-Value="Tmodel.RefInvoiceNo" Label="Reference Invoice No" Variant="Variant.Outlined" Margin="Margin.Dense" Class="modern-input" For="@(() => Tmodel.RefInvoiceNo)"></MudTextField>
                            </MudItem>
                            <MudItem xs="12" md="4">
                                <CostCenterSelector For="@(() => Tmodel.CostCenter)" @bind-Value="@Tmodel.CostCenter" Class="modern-input"></CostCenterSelector>
                            </MudItem>
                            <MudItem xs="12" md="4">
                                <DimensionSelector For="@(() => Tmodel.Dimension)" @bind-Value="@Tmodel.Dimension" Class="modern-input"></DimensionSelector>
                            </MudItem>
                            <MudItem xs="12" md="4">
                                <MudCheckBox T="bool" ValueChanged="((bool e)=>SetUsedItem(e))" Value="Tmodel.IsUsedItem" Label="Used Item" Color="Color.Primary"></MudCheckBox>
                            </MudItem>

                            @if (Tmodel.IsPurchase)
                            {
                                <MudItem xs="12">
                                    <div class="d-flex align-center mt-6">
                                        <MudIcon Icon="@Icons.Material.Filled.Receipt" Color="Color.Primary" Class="mr-2" />
                                        <MudText Typo="Typo.h6" Class="admin-title">Invoice Specifications</MudText>
                                    </div>
                                    <div class="title-accent" style="width: 100px;"></div>
                                </MudItem>
                                <MudItem xs="12" md="4">
                                    <PartySelector For="@(() => Tmodel.PurchaseModel.PartyInfo)" @bind-Value="Tmodel.PurchaseModel.PartyInfo" BranchID="branchID" NatureOfBusiness="Supplier" Class="modern-input"></PartySelector>
                                </MudItem>
                                <MudItem xs="12" md="4">
                                    <MudTextField @bind-Value="Tmodel.PurchaseModel.InvoiceNo" Label="Invoice No" Variant="Variant.Outlined" Margin="Margin.Dense" Class="modern-input" For="@(() => Tmodel.PurchaseModel.InvoiceNo)"></MudTextField>
                                </MudItem>
                                <MudItem xs="12" md="4">
                                    <MudDatePicker Label="Invoice Date" Variant="Variant.Outlined" Margin="Margin.Dense" DisableToolbar="true" Editable="true" DateFormat="dd/MM/yyyy" @bind-Date="Tmodel.PurchaseModel.InvoiceDate" Class="modern-input" />
                                </MudItem>
                                <MudItem xs="12" md="4">
                                    <MudTextField T="decimal?" Value="@Tmodel.RatePerLitre" ValueChanged="(decimal? v) => OnRateChanged(v)" Label="Rate Per Liter" Variant="Variant.Outlined" Margin="Margin.Dense" Class="modern-input" For="@(() => Tmodel.RatePerLitre)"></MudTextField>
                                </MudItem>
                                <MudItem xs="12" md="4">
                                    <MudTextField T="decimal?" Value="@Tmodel.Amount" ValueChanged="(decimal? v) => OnAmountChanged(v)" Label="Amount" Variant="Variant.Outlined" Margin="Margin.Dense" Class="modern-input" For="@(() => Tmodel.Amount)"></MudTextField>
                                </MudItem>
                                <MudItem xs="12" md="4">
                                    <MudTextField @bind-Value="Tmodel.PurchaseModel.Narration" Label="Remarks" Variant="Variant.Outlined" Margin="Margin.Dense" Class="modern-input" For="@(() => Tmodel.PurchaseModel.Narration)"></MudTextField>
                                </MudItem>
                            }
                        </MudGrid>
                    </div>
                </EditForm>
            </div>
        </MudContainer>
    </DialogContent>
    <DialogActions>
        <div class="d-flex w-100 flex-wrap pa-4 gap-3 align-center">
            <MudCheckBox T="bool" @bind-Value="@Tmodel.IsPurchase" Color="Color.Primary" Label="Procurement Mode?"></MudCheckBox>
            <MudSpacer />
            <MudButton @onclick="Cancel" Variant="Variant.Outlined" Color="Color.Default" Style="border-radius: 12px; font-weight: 700; text-transform: none; border-color: rgba(0,0,0,0.15);">Cancel</MudButton>
            <MudButton Disabled="@_busy" form="formfuel" Variant="Variant.Filled" ButtonType="ButtonType.Submit" Color="Color.Success" Style="background: var(--mud-palette-success); color: white; font-weight: 800; border-radius: 12px; text-transform: none; white-space: nowrap; padding: 8px 24px;" StartIcon="@Icons.Material.Filled.DoneAll">Submit</MudButton>
        </div>
    </DialogActions>
</MudDialog>

@code {
    [Parameter]
    public TripFuelModel Tmodel { get; set; }
    [Parameter]
    public String TripNumberDisplay { get; set; }
    [Parameter]
    public String TruckNumber { get; set; }
    private List<CostCenterModel> costCenter = new();
    private List<DimensionModel> dimension = new();
    //public bool? IsPur = null;
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; }
    private InventoryItemModel invItem;
    private int FuelGroupID;
    private int AdBlueGroupID;
    private bool _busy;

    public bool HasPermissionTripFuelServiceEdit { get; set; } = false;
    public int DocTypeID = 40;

    int branchID;
    string UserID;

    // Method called on form submission
    private async Task OnValidSubmit()
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is being submitted!", Severity.Warning);
            return;
        }
        _busy = true;
        if (HasPermissionTripFuelServiceEdit)
        {
            var scopeOptions = new TransactionOptions
            {
                IsolationLevel = IsolationLevel.ReadCommitted,
                Timeout = TransactionManager.DefaultTimeout
            };

            using (var tran = new TransactionScope(TransactionScopeOption.Required, scopeOptions, TransactionScopeAsyncFlowOption.Enabled))
            {
                try
                {

                    Tmodel.PurchaseModel.BranchID = branchID;
                    Tmodel.PurchaseModel.UserInfo.UserID = UserID;
                    TaxPurchaseItemModel item = Tmodel.PurchaseModel.Items.FirstOrDefault();
                    if (item == null)
                    {
                        item = new TaxPurchaseItemModel();
                        Tmodel.PurchaseModel.Items.Add(item);
                    }
                    item.ItemQty = Tmodel.Quantity;
                    item.ItemID = Tmodel.FuelItemID;
                    item.CostCenter = Tmodel.CostCenter;
                    item.Dimension = Tmodel.Dimension;

                    if (Tmodel.IsPurchase)
                    {
                        Tmodel.PurchaseModel.NonStoreInventory = true;
                        item.ItemRate = Tmodel.RatePerLitre;
                        item.Amount = Tmodel.Amount;
                        item.CoaID = invItem.Group.MappedNonInventoryPurchaseHead;

                        // Get GST rate for the item
                        item.GstRate = gstItemService.SelectByItem(Tmodel.FuelItemID ?? 0)?.FirstOrDefault()?.TaxRate ?? 0;

                        // Determine if the item is taxable
                        bool IsTaxable = Tmodel.PurchaseModel.PartyInfo.GstType == "Registered" || Tmodel.PurchaseModel.PartyInfo.GstType == "SEZ";
                        if (item.GstRate != null && item.GstRate != 0 && IsTaxable)
                        {
                            if (partyService.IsLocal(Tmodel.PurchaseModel.PartyInfo.PartyID, branchID))
                            {
                                item.CGST = Math.Round((item.Amount ?? 0) * (item.GstRate ?? 0) / 200, 2);
                                item.SGST = Math.Round((item.Amount ?? 0) * (item.GstRate ?? 0) / 200, 2);
                            }
                            else
                            {
                                item.IGST = Math.Round((item.Amount ?? 0) * (item.GstRate ?? 0) / 100, 2);
                            }
                        }
                        //Tmodel.PurchaseModel.Narration = Tmodel.Quantity.ToString() + " Ltr";

                        // Calculate TDS based on the party and item
                        var tdsRate = tdsService.GetTdsRate(Tmodel.PurchaseModel.PartyInfo.PartyID ?? 0, item.CoaID ?? 0);
                        item.TDS = Math.Round((item.Amount ?? 0) * tdsRate / 100, MidpointRounding.AwayFromZero);
                        Tmodel.Amount = item.Amount + (item.CGST ?? 0m) + (item.SGST ?? 0m) + (item.IGST ?? 0m);

                        Tmodel.PurchaseModel.TaxPurchaseType = "Fuel";

                        // Update the purchase model
                        Tmodel.PurchaseModel = taxPurchase.Update(Tmodel.PurchaseModel);
                        if (Tmodel.PurchaseModel.PID != null)
                        {
                            notiService.CreateAuthNotifications(branchID, 9, Tmodel.PurchaseModel.PID.Value);
                        }


                    }

                    // Update the trip fuel model
                    Tmodel = Iservice.Update(Tmodel);
                    snackbar.Add("Saved Successfully", Severity.Success);

                    Tmodel = new();

                    tran.Complete();
                }
                catch (Exception e)
                {
                    snackbar.Add(e.Message, Severity.Error);
                    goto ExitCode;
                }
            }
            
        }
        else
        {
            bool? ResultModel = await DialogService.ShowMessageBoxAsync(
                "Permission denied!",
                "You don't have any permission to Add or Edit TripFuel.");
        }
        MudDialog.Close(Tmodel);
    ExitCode:
        await Task.Delay(200);
        _busy = false;
        StateHasChanged();
    }

    // Method to set the used item flag
    public void SetUsedItem(bool val)
    {
        Tmodel.IsUsedItem = val;
    }

    // Method called when the component is initialized
    protected override async Task OnInitializedAsync()
    {
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionTripFuelServiceEdit = await Irole.HasClaim(DocTypeID.ToString(), "Edit", ctc.Token);

        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;
        branchID = int.Parse(authprov.User.Claims.First(x => x.Type == "BranchID").Value);
        UserID = user.Identity.Name;
        if (Tmodel.TripID == null)
        {
            var transfer = truckAvailabilityService.GetTransferByID(Tmodel.RequestApprovalHistoryID);
            Tmodel.PurchaseModel.Narration = "Transfer NO: " + transfer.DocNumber + " Truck NO: " + transfer.Truck.RegNo; // + " QTY: " + Tmodel.Quantity.ToString() + " Ltr";
            Tmodel.Narration = "Transfer NO: " + transfer.DocNumber + " Truck NO: " + transfer.Truck.RegNo; // + " QTY: " + Tmodel.Quantity.ToString() + " Ltr";
        }
        else
        {
            Tmodel.PurchaseModel.Narration = "Trip NO: " + TripNumberDisplay + " Truck NO: " + TruckNumber; // + " QTY: " + Tmodel.Quantity.ToString() + " Ltr";
            Tmodel.Narration = "Trip NO: " + TripNumberDisplay + " Truck NO: " + TruckNumber; // + " QTY: " + Tmodel.Quantity.ToString() + " Ltr";
        }

        if (Tmodel != null && Tmodel.FuelItemID != null)
        {
            invItem = InvService.SelectByID(Tmodel.FuelItemID);

        }

        // Retrieve fuel group and AdBlue group IDs from configuration
        var fuelGroupConfig = IConfig.GetByInventoryFuelGroupID();
        if (fuelGroupConfig != null)
        {
            int.TryParse(fuelGroupConfig.ValueString, out FuelGroupID);
        }
        var adBlueGroupConfig = IConfig.GetByInventoryAdBlueGroupID();
        if (adBlueGroupConfig != null)
        {
            int.TryParse(adBlueGroupConfig.ValueString, out AdBlueGroupID);
        }


        if (Tmodel.ItemType == null)
        {
            Tmodel.ItemType = "Fuel";
        }
    }

    private void Cancel()
    {
        MudDialog.Close();
    }

    // Method called when a fuel item is selected
    void FuelItemSelected(InventoryItemModel item)
    {
        invItem = item;
        Tmodel.FuelItemID = item?.InventoryItemID;
    }

    // Method to show tax information in a dialog
    async Task ShowTaxInfo()
    {
        var item = Tmodel.PurchaseModel.Items[0];
        GstModel gst = new GstModel()
            {
                CGST = item.CGST,
                IGST = item.IGST,
                SGST = item.SGST,
                TDS = item.TDS,
                GstRate = item.GstRate
            };
        DialogParameters parms = new DialogParameters();
        parms.Add("tax", gst.Clone());
        var dialog = await DialogService.ShowAsync<TaxRatedialog>("Tax Details", parms);
    }

    private void OnQuantityChanged(decimal? val)
    {
        Tmodel.Quantity = val;
        Tmodel.Amount = (Tmodel.RatePerLitre ?? 0) * (Tmodel.Quantity ?? 0);
    }

    private void OnRateChanged(decimal? val)
    {
        Tmodel.RatePerLitre = val;
        Tmodel.Amount = (Tmodel.RatePerLitre ?? 0) * (Tmodel.Quantity ?? 0);
    }

    private void OnAmountChanged(decimal? val)
    {
        Tmodel.Amount = val;
        if ((Tmodel.Quantity ?? 0) > 0)
        {
            Tmodel.RatePerLitre = Tmodel.Amount / Tmodel.Quantity;
        }
    }
}
