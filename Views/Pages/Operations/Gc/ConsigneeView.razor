@page "/consignee"
@page "/consignee/{OrderID:int}"
@using System.Threading;
@attribute [Authorize]
@inject AuthenticationStateProvider auth
@inject IConsigneeService Iservice
@inject IOrderService Iorder
@inject MudBlazor.ISnackbar snackbar
@inject IDialogService DialogService
@inject IRoleService<RoleModel> Irole

@if (loading)
{
    <MudProgressCircular Color="Color.Primary" Style="height:200px;width:200px;" Indeterminate="true" />
}
else
{
    <MudTable Items="@collection" Elevation="10" Filter="new Func<ConsigneeModel, bool>(search)">
        <ToolBarContent>
            <MudText Typo="Typo.h6">@Order?.OrderName Consignees</MudText>
            <MudIconButton Icon="@Icons.Material.Filled.Add" Title="Add" @onclick="@(() => Edit(new ConsigneeModel()))" Color="Color.Dark" Size="Size.Small"></MudIconButton>
            <MudSpacer></MudSpacer>
            <MudTextField @bind-Value="searchConsignee" Placeholder="Search Consignees... " Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0"></MudTextField>
        </ToolBarContent>
        <HeaderContent>
            <MudTh><MudTableSortLabel SortBy="new Func<ConsigneeModel, object>(x => x.ConsigneeName)" InitialDirection="SortDirection.Ascending">Name</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel SortBy="new Func<ConsigneeModel, object>(x => x.Address.Place)" InitialDirection="SortDirection.Ascending">Place</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel SortBy="new Func<ConsigneeModel, object>(x => x.Mobile)" InitialDirection="SortDirection.Ascending">Mobile</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel SortBy="new Func<ConsigneeModel, object>(x => x.Consignor)" InitialDirection="SortDirection.Ascending">Type</MudTableSortLabel></MudTh>
            <MudTh>Actions</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Name"><MudHighlighter Style="background-color:cornflowerblue;font-weight:bold" Text="@context.ConsigneeName" HighlightedText="@searchConsignee" /></MudTd>
            <MudTd DataLabel="Place">@context.Address.Place</MudTd>
            <MudTd DataLabel="Mobile">@context.Mobile</MudTd>
            <MudTd DataLabel="Type">@(context.Consignor == true ? "Consignor" : "Consignee") </MudTd>
            <MudTd DataLabel="">
                <MudFab @onclick="@(() => Edit(context))" Color="Color.Primary" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" IconSize="Size.Small" />
                <MudFab @onclick="@(() => Delete(context))" Color="Color.Primary" Icon="@Icons.Material.Filled.Delete" Size="Size.Small" IconSize="Size.Small" />
            </MudTd>
        </RowTemplate>
        <PagerContent>
            <MudTablePager PageSizeOptions="new int[] { 5, 10, 20, 50, 100 }" />
        </PagerContent>
    </MudTable>
}

@code {

    [Parameter]
    public int? OrderID { get; set; }
    private OrderModel Order = new OrderModel();
    private List<ConsigneeModel> collection = new List<ConsigneeModel>();
    private int BranchID { get; set; } = 0;
    bool loading = false;

    public bool HasPermissionConsigneeServiceEdit { get; set; } = false;
    public bool HasPermissionConsigneeServiceDelete { get; set; } = false;
    public int DocTypeID = 56;

    protected override async Task OnInitializedAsync()
    {
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionConsigneeServiceEdit = await Irole.HasClaim(DocTypeID.ToString(), "Edit", ctc.Token);
        HasPermissionConsigneeServiceDelete = await Irole.HasClaim(DocTypeID.ToString(), "Delete", ctc.Token);

        loading = true;
        Order = await Iorder.SelectByID(OrderID);
        await GetAll();
        loading = false;
    }

    private async Task GetAll()
    {
        collection = await Iservice.SelectByOrder(OrderID.GetValueOrDefault()).ToListAsync();
    }

    private async Task Edit(ConsigneeModel model)
    {
        if (HasPermissionConsigneeServiceEdit)
        {
            DialogParameters parms = new DialogParameters();
            parms.Add("model", model);
            parms.Add("Order", Order);
            var dialog = DialogService.Show<Consineedilog>("Add/Edit", parms, new DialogOptions() { MaxWidth = MaxWidth.Large });
            var result = await dialog.Result;
            if (!result.Canceled)
            {
                await GetAll();
            }
        }
        else
        {
            bool? ResultModel = await DialogService.ShowMessageBox(
                "Permission denied!",
                "You dont have any permission to Add or Edit Consignee.");
        }
    }

    private async Task Delete(ConsigneeModel model)
    {
        if (HasPermissionConsigneeServiceDelete)
        {
            bool? result = await DialogService.ShowMessageBox(
                "Warning !",
                "Are you sure, you want to delete - " + model.ConsigneeName + " ?");
            if (result == true)
            {
                var authprov = await auth.GetAuthenticationStateAsync();
                await Iservice.Delete(model.ConsigneeID, authprov.User.Identity.Name);
                snackbar.Add("Deleted Successfully", Severity.Success);
                await GetAll();
            }
        }
        else
        {
            bool? result = await DialogService.ShowMessageBox(
                "Permission denied!",
                "You dont have any permission to Delete Consignee.");
        }
    }

    private string searchConsignee = "";

    private bool search(ConsigneeModel model)
    {
        if (model.ConsigneeName != null && model.ConsigneeName.Contains(searchConsignee, StringComparison.OrdinalIgnoreCase))
        {
            return true;
        }
        return false;
    }
}