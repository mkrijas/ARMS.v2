@page "/consignee"
@page "/consignee/{OrderID:int}"
@using System.Threading;
@attribute [Authorize]
@inject AuthenticationStateProvider auth
@inject IConsigneeService Iservice
@inject IOrderService Iorder
@inject MudBlazor.ISnackbar snackbar
@inject IDialogService DialogService
@inject IRoleService<RoleModel> Irole

@if (_isLoading)
{
    <div @key="@("loader")" style="display: flex; justify-content: center; align-items: center; min-height: 400px;">
        <LoaderComponent IsFullScreen="true" 
                        ShowLogo="false" 
                        Size="medium" 
                        LoadingText="Loading Consignees" 
                        SubText="Please wait..." />
    </div>
}
else
{
<div class="admin-page-container" @key="@("content")">
    <div class="admin-header-tiered mb-6">
        <div class="d-flex align-center justify-space-between">
            <div>
                <MudText Typo="Typo.h4" Class="admin-title">@Order?.OrderName Partners</MudText>
                <MudText Typo="Typo.body2" Class="admin-subtitle">Manage consignors and consignees linked to this order.</MudText>
            </div>
            <MudButton StartIcon="@Icons.Material.Filled.Add" Variant="Variant.Filled" Color="Color.Primary" Class="admin-register-btn" OnClick="@(() => Edit(new ConsigneeModel()))" Disabled="@_busy">ADD PARTNER</MudButton>
        </div>
    </div>

    <div class="admin-glass-card mb-6 pa-4">
        <div class="d-flex align-center gap-4">
            <div style="flex-grow: 1;">
                <MudTextField @bind-Value="searchConsignee" Placeholder="Search Partners..." Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" Variant="Variant.Outlined" Margin="Margin.Dense" Class="admin-input-group" Clearable="true" />
            </div>
        </div>
    </div>

    <div class="admin-glass-card pa-0 overflow-hidden">
        <MudTable Items="@collection" Dense="true" Hover="true" Elevation="0" Class="modern-admin-table" Filter="new Func<ConsigneeModel, bool>(search)">
            <HeaderContent>
                <MudTh><MudTableSortLabel SortBy="new Func<ConsigneeModel, object>(x => x.ConsigneeName)" InitialDirection="SortDirection.Ascending"><span class="admin-header-text">NAME</span></MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<ConsigneeModel, object>(x => x.Address.Place)"><span class="admin-header-text">PLACE</span></MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<ConsigneeModel, object>(x => x.Mobile)"><span class="admin-header-text">MOBILE</span></MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<ConsigneeModel, object>(x => x.Consignor)"><span class="admin-header-text">TYPE</span></MudTableSortLabel></MudTh>
                <MudTh Style="text-align: right;"><span class="admin-header-text">ACTIONS</span></MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Name">
                    <MudText Typo="Typo.body2" Class="admin-td-primary fw-600">@context.ConsigneeName</MudText>
                </MudTd>
                <MudTd DataLabel="Place">@context.Address.Place</MudTd>
                <MudTd DataLabel="Mobile">@context.Mobile</MudTd>
                <MudTd DataLabel="Type">
                    <MudChip T="string" Color="@(context.Consignor == true ? Color.Primary : Color.Secondary)" Size="Size.Small" Variant="Variant.Text" Class="pa-0">
                        @(context.Consignor == true ? "Consignor" : "Consignee")
                    </MudChip>
                </MudTd>
                <MudTd DataLabel="Actions" Style="text-align: right;">
                    <div class="d-flex justify-end gap-1">
                        <MudTooltip Text="Edit">
                            <MudIconButton OnClick="@(() => Edit(context))" Color="Color.Primary" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Variant="Variant.Text" />
                        </MudTooltip>
                        <MudTooltip Text="Delete">
                            <MudIconButton OnClick="@(() => Delete(context))" Color="Color.Error" Icon="@Icons.Material.Filled.DeleteOutline" Size="Size.Small" Variant="Variant.Text" />
                        </MudTooltip>
                    </div>
                </MudTd>
            </RowTemplate>
            <PagerContent>
                <div class="pa-4">
                    <MudTablePager PageSizeOptions="new int[] { 10, 20, 50, 100 }" />
                </div>
            </PagerContent>
        </MudTable>
    </div>
</div>
}


@code {

    [Parameter]
    public int? OrderID { get; set; }
    private OrderModel Order = new OrderModel();
    private List<ConsigneeModel> collection = new List<ConsigneeModel>();
    private int BranchID { get; set; } = 0;
    bool loading = false;
    private bool _isLoading = true;
    private bool _busy;
    public bool HasPermissionConsigneeServiceEdit { get; set; } = false;
    public bool HasPermissionConsigneeServiceDelete { get; set; } = false;
    public int DocTypeID = 56;

    // Method called when the component is initialized
    protected override async Task OnInitializedAsync()
    {
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionConsigneeServiceEdit = await Irole.HasClaim(DocTypeID.ToString(), "Edit", ctc.Token);
        HasPermissionConsigneeServiceDelete = await Irole.HasClaim(DocTypeID.ToString(), "Delete", ctc.Token);

        loading = true;

        // Fetch the order details by ID
        Order = await Iorder.SelectByID(OrderID);
        await GetAll();
        loading = false;
        _isLoading = false;
    }

    // Method to fetch all consignee models
    private async Task GetAll()
    {
        // Retrieve the list of consignee models
        collection = await Iservice.SelectByOrder(OrderID.GetValueOrDefault()).ToListAsync();
    }

    // Method to edit a consignee
    private async Task Edit(ConsigneeModel model)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        _busy = true;
        if (HasPermissionConsigneeServiceEdit)
        {
            DialogParameters parms = new DialogParameters();
            parms.Add("model", model.Clone());
            parms.Add("Order", Order);
            var dialog = await DialogService.ShowAsync<Consineedilog>("Add/Edit", parms, new DialogOptions() { MaxWidth = MaxWidth.Large });
            var result = await dialog.Result;
            if (!result.Canceled)
            {
                await GetAll();
            }
        }
        else
        {
            bool? ResultModel = await DialogService.ShowMessageBoxAsync(
                "Permission denied!",
                "You don't have any permission to Add or Edit Consignee.");
        }
        await Task.Delay(200);
        _busy = false;
    }

    // Method to delete a consignee
    private async Task Delete(ConsigneeModel model)
    {
        if (HasPermissionConsigneeServiceDelete)
        {
            bool? result = await DialogService.ShowMessageBoxAsync(
                "Warning !",
                "Are you sure, you want to delete - " + model.ConsigneeName + " ?");
            if (result == true)
            {
                var authprov = await auth.GetAuthenticationStateAsync();

                // Call the service to delete the consignee
                await Iservice.Delete(model.ConsigneeID, authprov.User.Identity.Name);
                snackbar.Add("Deleted Successfully", Severity.Success);
                await GetAll();
            }
        }
        else
        {
            bool? result = await DialogService.ShowMessageBoxAsync(
                "Permission denied!",
                "You don't have any permission to Delete Consignee.");
        }
    }

    private string searchConsignee = "";

    private bool search(ConsigneeModel model)
    {
        if (model.ConsigneeName != null && model.ConsigneeName.Contains(searchConsignee, StringComparison.OrdinalIgnoreCase))
        {
            return true;
        }
        return false;
    }
}

