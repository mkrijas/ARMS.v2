@code {

    [Parameter]
    public int? OrderID { get; set; }

    private ConsigneeModel model = new ConsigneeModel();
    private OrderModel Order = new OrderModel();
    private PlaceModel Place = new PlaceModel();

    private List<ConsigneeModel> collection = new List<ConsigneeModel>();
    private List<PlaceModel> places = new List<PlaceModel>();
    private List<OrderModel> orders = new List<OrderModel>();

    private int BranchID { get; set; } = 0;
    public string customstr { get; set; } = "CONSIGNEE";


    protected override async Task OnInitializedAsync()
    {
        places = Iplace.Select(0).ToList();
        await foreach (var item in Iorder.Select(0))
        {
            orders.Add(item);
        }

        model.Address = new AddressModel() { AddresseeName = "temp", Place = "temp" };

        if (OrderID != null)
        {
            Order = await Iorder.SelectByID(OrderID.Value);
        }

        await GetAll();
    }


    private async Task<IEnumerable<PlaceModel>> Search(string searchString)
    {
        return await Task.FromResult(
            places.Where(x => x.PlaceName.Contains(searchString == null ? string.Empty : searchString, StringComparison.InvariantCultureIgnoreCase)));
    }

    private async Task<IEnumerable<OrderModel>> SearchOrders(string searchString)
    {
        var o = orders.Where(x => x.OrderName.Contains(searchString == null ? string.Empty : searchString, StringComparison.InvariantCultureIgnoreCase));
        return await Task.FromResult(o);
    }

    private async Task GetAll()
    {
        collection = new();
        await foreach (var item in Iservice.SelectByOrder(OrderID.GetValueOrDefault()))
        {
            collection.Add(item);
        }
    }



    private async Task OnValidSubmit(EditContext context)
    {
        if (Place?.PlaceID == 0)
        {
            snackbar.Add("Place is not selected", Severity.Error);
            return;
        }
        else
        if (!places.Select(x => x.PlaceName).Contains(Place.PlaceName))
        {
            snackbar.Add("Invalid Place", Severity.Error);
            return;
        }

        model.PlaceID = Place.PlaceID;
        model.Address.Place = Place.PlaceName;
        model.OrderID = Order.OrderID;
        model.Address.AddresseeName = model.ConsigneeName;
        CustomStringToBoolConverter cs = new CustomStringToBoolConverter();
        model.Consignor = cs.SetFunc(customstr).Value;


        var authprov = await auth.GetAuthenticationStateAsync();
        model.UserInfo.UserID = authprov.User.Identity.Name;
        try
        {
            model = await Iservice.Update(model);
            snackbar.Add("Saved Successfully", Severity.Success);
            if (collection.Exists(x => x.ConsigneeID == model.ConsigneeID))
            {
                collection[collection.FindIndex(x => x.ConsigneeID == model.ConsigneeID)] = model;
            }
            else
            {
                collection.Add(model);
            }
            model = new ConsigneeModel();
            Order = new OrderModel();
            Place = new PlaceModel();
        }
        catch (Exception ex)
        {
            snackbar.Add(ex.Message, Severity.Warning);
        }
    }
    private void Edit(int? id)
    {
        model = collection.FirstOrDefault(x => x.ConsigneeID == id);
        CustomStringToBoolConverter cs = new CustomStringToBoolConverter();
        customstr = cs.GetFunc(model.Consignor);
     //   Order = orders.FirstOrDefault(x => x.OrderID == model.OrderID);
       // Place = places.FirstOrDefault(x => x.PlaceID == model.PlaceID);
        DialogParameters parms = new DialogParameters();
        parms.Add("model",model);
        DialogService.Show<Consineedilog>("Add Consignee",parms);


    }
    private async void Delete(int? id)
    {
        var authprov = await auth.GetAuthenticationStateAsync();
        await Iservice.Delete(id, authprov.User.Identity.Name);
        snackbar.Add("Deleted Successfully", Severity.Success);
        await GetAll();
    }

    private string searchConsignee = "";

    private bool search(ConsigneeModel model)
    {
        if (model.ConsigneeName != null && model.ConsigneeName.Contains(searchConsignee, StringComparison.OrdinalIgnoreCase))
        {
            return true;
        }
        return false;
    }
    public class CustomStringToBoolConverter : BoolConverter<string>
    {

        public CustomStringToBoolConverter()
        {
            SetFunc = OnSet;
            GetFunc = OnGet;
        }

        private string TrueString = "CONSIGNOR";
        private string FalseString = "CONSIGNEE";
        private string NullString = "SELECT";

        private string OnGet(bool? value)
        {
            try
            {
                return (value == true) ? TrueString : FalseString;
            }
            catch (Exception e)
            {
                UpdateGetError("Conversion error: " + e.Message);
                return NullString;
            }
        }

        private bool? OnSet(string arg)
        {
            if (arg == null)
                return null;
            try
            {
                if (arg == TrueString)
                    return true;
                if (arg == FalseString)
                    return false;
                else
                    return null;
            }
            catch (FormatException e)
            {
                UpdateSetError("Conversion error: " + e.Message);
                return null;
            }
        }

    }
         private void OpenDialog()
    {

         DialogParameters parms = new DialogParameters();
        parms.Add("model", new ConsigneeModel());

        DialogService.Show<Consineedilog>("ADD PLACE",parms);
    }
}




