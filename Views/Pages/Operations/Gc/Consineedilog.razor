@inject IConsigneeService Iservice
@inject MudBlazor.ISnackbar snackbar
@inject AuthenticationStateProvider auth
@attribute [Authorize]
@inject IDialogService DialogService

@inject IPlaceService Iplace
@inject IOrderService Iorder




<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">Add/Edit  @(model.Consignor?"Consignor":"Consignee")
            <MudRadioGroup @bind-SelectedOption="model.Consignor">
                <MudRadio Option="true" Color="Color.Primary" Dense="true">Consignor</MudRadio>
                <MudRadio Option="false" Color="Color.Secondary" Dense="false">Consignee</MudRadio>
            </MudRadioGroup>
        @*    <MudSwitch @bind-Checked="customstr" Color="Color.Error" Converter="@(new CustomStringToBoolConverter())"> <MudText Typo="Typo.h6">Add/Edit @(customstr)</MudText></MudSwitch>*@
            </MudText>
    </TitleContent>
    <DialogContent>
    <EditForm id="ConsigneeForm" Model="@model" OnValidSubmit="OnValidSubmit">
        <ObjectGraphDataAnnotationsValidator />
        <ValidationSummary />      
            <MudTabs>
                <MudTabPanel Text="Info" Class="p-3">
                    <MudGrid>
                        <MudItem xs="12" md="6">
                            <MudTextField @bind-Value="model.ConsigneeName" Label="Consignee Name" Variant="Variant.Outlined" For="@(() => model.ConsigneeName)"></MudTextField>
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <MudTextField @bind-Value="model.Mobile" Label="Mobile" Variant="Variant.Outlined" For="@(() => model.Mobile)" Mask="@(new PatternMask("0000000000"))" ></MudTextField>
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <MudAutocomplete T="PlaceModel" Label="Place" Value="Place" ValueChanged="PlaceSelected" ResetValueOnEmptyText="true" Variant="Variant.Outlined"
                                             SearchFunc="@Search" ToStringFunc="@(e => e == null ? null : $"{e.PlaceName}")"></MudAutocomplete>
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <MudAutocomplete ReadOnly Disabled T="OrderModel" Label="Order" Value="Order" ValueChanged="OrderSelected" ResetValueOnEmptyText="true" Variant="Variant.Outlined"
                                             SearchFunc="@SearchOrders" ToStringFunc="@(e => e == null ? null : $"{e.OrderName}")"></MudAutocomplete>
                        </MudItem>
                    </MudGrid>
                </MudTabPanel>
                <MudTabPanel Text="Address" Class="p-3">
                    <AddressView Address="model.Address" HideLabel HidePlace="true"></AddressView>
                </MudTabPanel>
            </MudTabs>
    </EditForm>
        </DialogContent>
        <DialogActions>
            <MudButton form="ConsigneeForm" Variant="Variant.Filled" Color="Color.Success" ButtonType="ButtonType.Submit">Save @customstr</MudButton>
        </DialogActions>
    </MudDialog>


    @code {

    [Parameter]
    public ConsigneeModel model { get; set; }
    [Parameter]
    public OrderModel Order { get; set; }

    [CascadingParameter] MudDialogInstance MudDialog { get; set; }

    private PlaceModel Place = new PlaceModel();
    private List<PlaceModel> places = new List<PlaceModel>();
    private List<OrderModel> orders = new List<OrderModel>();

    public string customstr { get; set; } = "CONSIGNEE";

    private string searchConsignee = "";

    protected override async Task OnInitializedAsync()
    {
        places = Iplace.Select(0).ToList();
        orders = await Iorder.Select(0).ToListAsync();

        CustomStringToBoolConverter cs = new CustomStringToBoolConverter();
        customstr = cs.GetFunc(model.Consignor);

        Place = places.FirstOrDefault(x => x.PlaceID == model.PlaceID);
        if(Order == null)
            Order = orders.FirstOrDefault(y => y.OrderID == model.OrderID);
        model.OrderID = Order.OrderID;
    }

    private void PlaceSelected(PlaceModel _place)
    {
        Place = _place;
        model.PlaceID = _place?.PlaceID;
        model.Address.Place = _place?.PlaceName;
    }

    private void OrderSelected(OrderModel _order)
    {
        Order = _order;
        model.OrderID = _order.OrderID;
    }

    public class CustomStringToBoolConverter : BoolConverter<string>
    {

        public CustomStringToBoolConverter()
        {
            SetFunc = OnSet;
            GetFunc = OnGet;
        }

        private string TrueString = "CONSIGNOR";
        private string FalseString = "CONSIGNEE";
        private string NullString = "SELECT";

        private string OnGet(bool? value)
        {
            try
            {
                return (value == true) ? TrueString : FalseString;
            }
            catch (Exception e)
            {
                UpdateGetError("Conversion error: " + e.Message);
                return NullString;
            }
        }

        private bool? OnSet(string arg)
        {
            if (arg == null)
                return null;
            try
            {
                if (arg == TrueString)
                    return true;
                if (arg == FalseString)
                    return false;
                else
                    return null;
            }
            catch (FormatException e)
            {
                UpdateSetError("Conversion error: " + e.Message);
                return null;
            }
        }
    }

    private async Task<IEnumerable<PlaceModel>> Search(string searchString)
    {
        return await Task.FromResult(
            places.Where(x => x.PlaceName.Contains(searchString == null ? string.Empty : searchString, StringComparison.InvariantCultureIgnoreCase)));
    }

    private async Task<IEnumerable<OrderModel>> SearchOrders(string searchString)
    {
        var o = orders.Where(x => x.OrderName.Contains(searchString == null ? string.Empty : searchString, StringComparison.InvariantCultureIgnoreCase));
        return await Task.FromResult(o);
    }


    private async void OnValidSubmit(EditContext context)
    {
        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;
        model.UserInfo.UserID = user.Identity.Name;        
        //CustomStringToBoolConverter cs = new CustomStringToBoolConverter();
        //model.Consignor = cs.SetFunc(customstr).Value;

        MudDialog.Close(model);
    }

}