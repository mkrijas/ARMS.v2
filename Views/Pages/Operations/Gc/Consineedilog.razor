@using Views.Pages.Operations.Place
@inject IConsigneeService Iservice
@inject IPlaceService Iplace
@inject IOrderService Iorder
@inject MudBlazor.ISnackbar snackbar
@inject AuthenticationStateProvider auth
@inject IRoleService<RoleModel> Irole
@inject IDialogService DialogService

<MudDialog Class="admin-dialog-glass">
    <TitleContent>
        <div class="header-section mb-2 pt-4 px-4">
            <div class="d-flex align-center justify-space-between">
                <div class="d-flex align-center">
                    <div class="icon-badge primary-badge mr-4">
                        <div class="admin-header-icon-badge mb-3">
                            <MudIcon Icon="@Icons.Material.Filled.PersonAdd" Color="Color.Secondary" Style="font-size: 3rem;" />
                        </div>
                    </div>
                    <div>
                        <MudText Typo="Typo.h5" Class="admin-title"><b>Consignee / Consignor</b></MudText>
                        <MudText Typo="Typo.body2" Class="admin-subtitle">Manage shipping partners and contact information.</MudText>
                    </div>
                </div>
            </div>
            <div class="title-accent mt-4"></div>
        </div>
    </TitleContent>
    <DialogContent>
        <MudContainer Class="admin-dialog-container">
            <div class="dialog-content-wrapper pa-4">
                <EditForm id="ConsigneeForm" Model="@model" OnValidSubmit="OnValidSubmit">
                    <div class="admin-glass-card pa-0 overflow-hidden mb-6">
                        <div class="px-6 py-4 d-flex align-center justify-space-between border-bottom-subtle" style="background: rgba(var(--mud-palette-primary-rgb), 0.03); border-bottom: 1px solid rgba(var(--mud-palette-primary-rgb), 0.1);">
                            <div class="d-flex align-center">
                                <MudIcon Icon="@Icons.Material.Filled.Settings" Color="Color.Primary" Class="mr-2" />
                                <span class="admin-section-label mb-0">Partner Type Identification</span>
                            </div>
                            <MudRadioGroup Value="model.Consignor" T="bool" ValueChanged="OnSelectedOptionChanged" Class="admin-radio-group">
                                <MudRadio Value="true" Color="Color.Primary" Dense="true"><span class="fw-700">Consignor</span></MudRadio>
                                <MudRadio Value="false" Color="Color.Secondary" Dense="true"><span class="fw-700">Consignee</span></MudRadio>
                            </MudRadioGroup>
                        </div>

                        <ObjectGraphDataAnnotationsValidator />
                        <MudValidationSummary />

                        <MudTabs Elevation="0" Rounded="true" ApplyEffectsToInnerViews="true" Class="premium-tabs" PanelClass="pa-6" Style="background: transparent;">
                            <MudTabPanel Text="Basic Information" Icon="@Icons.Material.Filled.Info">
                                <MudGrid Spacing="4" Class="pa-4">
                                    <MudItem xs="12" md="6">
                                        <MudTextField @bind-Value="model.ConsigneeName" Label="@label" Variant="Variant.Outlined" Margin="Margin.Normal" For="@(() => model.ConsigneeName)" Class="modern-input"></MudTextField>
                                    </MudItem>
                                    <MudItem xs="12" md="6">
                                        <MudNumericField HideSpinButtons MaxLength="10" @bind-Value="model.Mobile" Label="Mobile Number" Variant="Variant.Outlined" Margin="Margin.Normal" For="@(() => model.Mobile)" Class="modern-input" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Phone"></MudNumericField>
                                    </MudItem>
                                    <MudItem xs="12" md="6">
                                        <MudAutocomplete T="PlaceModel" Label="Place" Value="Place" ValueChanged="PlaceSelected" ResetValueOnEmptyText="true" SearchFunc="@(async (string s, CancellationToken t) => await Search(s, t))" ToStringFunc="@(e => e == null ? null : $"{e.PlaceName}")"
                                                         Variant="Variant.Outlined" Margin="Margin.Normal" Adornment="Adornment.End" AdornmentIcon="@Icons.Material.Rounded.Add" OnAdornmentClick="OpenPlaceDialog" Immediate="true" MaxItems="50" Class="modern-input" AdornmentColor="Color.Primary">
                                             <NoItemsTemplate>
                                                 <MudText Typo="Typo.body2" Class="pa-4">Create new Place</MudText>
                                             </NoItemsTemplate>
                                        </MudAutocomplete>
                                    </MudItem>
                                    <MudItem xs="12" md="6">
                                        <MudAutocomplete ReadOnly Disabled T="OrderModel" Label="Parent Order" Value="Order" ValueChanged="OrderSelected" ResetValueOnEmptyText="true" Variant="Variant.Outlined" Margin="Margin.Normal" SearchFunc="@(async (string s, CancellationToken t) => await SearchOrders(s, t))" ToStringFunc="@(e => e == null ? null : $"{e.OrderName}")" Class="modern-input" AdornmentIcon="@Icons.Material.Filled.Link"></MudAutocomplete>
                                    </MudItem>
                                </MudGrid>
                            </MudTabPanel>
                            <MudTabPanel Text="Physical Address" Icon="@Icons.Material.Filled.LocationOn">
                                <div class="glass-inner-panel pa-4" style="background: rgba(0,0,0,0.02); border-radius: 16px;">
                                    <AddressView Address="model.Address" HideLabel HidePlace="true"></AddressView>
                                </div>
                            </MudTabPanel>
                        </MudTabs>
                    </div>
                </EditForm>
            </div>
        </MudContainer>
    </DialogContent>
    <DialogActions>
        <div class="d-flex w-100 flex-wrap pa-4 gap-3 align-center">
            <MudSpacer />
            <MudButton @onclick="Cancel" Variant="Variant.Outlined" Color="Color.Default" Style="border-radius: 12px; font-weight: 700; text-transform: none; border-color: rgba(0,0,0,0.15);">Discard</MudButton>
            <MudButton Disabled="@_busy" form="ConsigneeForm" Variant="Variant.Filled" Color="Color.Success" ButtonType="ButtonType.Submit" Style="background: var(--mud-palette-success); color: white; font-weight: 800; border-radius: 12px; text-transform: none; white-space: nowrap; padding: 8px 32px;" StartIcon="@Icons.Material.Filled.Save">Register Partner</MudButton>
        </div>
    </DialogActions>
</MudDialog>

@code {

    [CascadingParameter] IMudDialogInstance MudDialog { get; set; }
    [Parameter]
    public ConsigneeModel model { get; set; }
    [Parameter]
    public OrderModel Order { get; set; }
    private PlaceModel Place = new PlaceModel();
    private List<PlaceModel> places = new List<PlaceModel>();
    private List<OrderModel> orders = new List<OrderModel>();
    public string label { get; set; } = "Consignee";
    private string searchConsignee = "";
    private bool _busy;

    public bool HasPermissionConsigneeServiceEdit { get; set; } = false;
    public int DocTypeID = 56;

    // Method called when the component is initialized
    protected override async Task OnInitializedAsync()
    {
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionConsigneeServiceEdit = await Irole.HasClaim(DocTypeID.ToString(), "Edit", ctc.Token);

        // Load places and orders
        places = Iplace.Select(0, null).ToList();
        orders = await Iorder.Select(0).ToListAsync();
        Place = places.FirstOrDefault(x => x.PlaceID == model.PlaceID);
        if (Order == null)
        {
            Order = orders.FirstOrDefault(y => y.OrderID == model.OrderID);
        }
        if (model != null && Order != null)
        {
            model.OrderID = Order.OrderID;
        }

        if (model != null)
        {
            label = model.Consignor ? "Consignor" : "Consignee";
        }
    }

    // Method called when a place is selected
    private void PlaceSelected(PlaceModel _place)
    {
        Place = _place;
        model.PlaceID = _place?.PlaceID;
        model.Address.Place = _place?.PlaceName;
    }

    // Method called when an order is selected
    private void OrderSelected(OrderModel _order)
    {
        Order = _order;
        model.OrderID = _order.OrderID;
    }

    // Method to handle changes in the selected option (consignee/consignor)
    public void OnSelectedOptionChanged(bool value)
    {
        model.Consignor = value;
        if (value)
        {
            label = "Consignor";
        }
        else
        {
            label = "Consignee";
        }
        StateHasChanged();
    }

    // Method to search for places based on a search string
    private async Task<IEnumerable<PlaceModel>> Search(string searchString, CancellationToken token)
    {
        return await Task.FromResult(
            places.Where(x => x.PlaceName.Contains(searchString == null ? string.Empty : searchString, StringComparison.InvariantCultureIgnoreCase)));
    }

    // Method to search for orders based on a search string
    private async Task<IEnumerable<OrderModel>> SearchOrders(string searchString, CancellationToken token)
    {
        var o = orders.Where(x => x.OrderName.Contains(searchString == null ? string.Empty : searchString, StringComparison.InvariantCultureIgnoreCase));
        return await Task.FromResult(o);
    }

    // Method called when the form is submitted
    private async Task OnValidSubmit(EditContext context)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is being submitted!", Severity.Warning);
            return;
        }
        _busy = true;

        if (HasPermissionConsigneeServiceEdit)
        {
            var authprov = await auth.GetAuthenticationStateAsync();
            var user = authprov.User;
            model.UserInfo.UserID = user.Identity.Name;
            model.ConsigneeName = FontStyle.ConvertToCamelCase(model.ConsigneeName);
            
            await Iservice.Update(model);
            MudDialog.Close(DialogResult.Ok(model));
        }
        else
        {
            bool? ResultModel = await DialogService.ShowMessageBoxAsync(
                "Permission denied!",
                "You don't have any permission to Add or Edit Consignee.");
        }
        await Task.Delay(200);
        _busy = false;
    }

    // Method to open a dialog for adding a new place
    private async Task OpenPlaceDialog()
    {
        DialogParameters parms = new DialogParameters();
        parms.Add("placemodel", new PlaceModel());
        var dialog = await DialogService.ShowAsync<PlaceDilogue>("Add Place", parms);
        var result = await dialog.Result;
        if (!result.Canceled)
        {
            places = Iplace.Select(0, null).ToList();
        }
    }

    private void Cancel()
    {
        MudDialog.Cancel();
    }
}
