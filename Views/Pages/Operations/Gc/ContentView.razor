@page "/content"
@using System.Threading;
@attribute [Authorize]
@inject AuthenticationStateProvider auth
@inject IContentService Iservice
@inject MudBlazor.ISnackbar snackbar
@inject IDialogService DialogService
@inject IRoleService<RoleModel> Irole

<div class="admin-page-container">
    <div class="admin-header-tiered mb-6">
        <div class="d-flex align-center justify-space-between">
            <div>
                <MudText Typo="Typo.h4" Class="admin-title">Content Types</MudText>
                <MudText Typo="Typo.body2" Class="admin-subtitle">Define and manage material types, units of measurement, and conversion ratios.</MudText>
            </div>
            <MudButton StartIcon="@Icons.Material.Filled.Add" Variant="Variant.Filled" Color="Color.Primary" Class="admin-register-btn" OnClick="(() => Edit(new ContentModel()))" Disabled="@_busy">ADD CONTENT</MudButton>
        </div>
    </div>

    <div class="admin-glass-card mb-6 pa-4">
        <div class="d-flex align-center gap-4">
            <div style="flex-grow: 1;">
                <MudTextField @bind-Value="searchContent" Placeholder="Search Content types..." Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" Variant="Variant.Outlined" Margin="Margin.Dense" Class="admin-input-group" Clearable="true" />
            </div>
        </div>
    </div>

    <div class="admin-glass-card pa-0 overflow-hidden">
        <MudTable Items="@collection" Dense="true" Hover="true" Elevation="0" Class="modern-admin-table" Filter="new Func<ContentModel, bool>(search)">
            <HeaderContent>
                <MudTh><MudTableSortLabel SortBy="new Func<ContentModel, object>(x=> x.ContentName)" InitialDirection="SortDirection.Ascending"><span class="admin-header-text">CONTENT</span></MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<ContentModel, object>(x=> x.PrimaryUnit)"><span class="admin-header-text">PRIMARY UNIT</span></MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<ContentModel, object>(x=> x.SecondaryUnit)"><span class="admin-header-text">SECONDARY UNIT</span></MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<ContentModel, object>(x=> x.UnitRatio)"><span class="admin-header-text">RATIO</span></MudTableSortLabel></MudTh>
                <MudTh Style="text-align: right;"><span class="admin-header-text">ACTIONS</span></MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Content"><MudText Typo="Typo.body2" Class="admin-td-primary fw-600">@context.ContentName</MudText></MudTd>
                <MudTd DataLabel="Primary Unit">@context.PrimaryUnit</MudTd>
                <MudTd DataLabel="Secondary Unit">@context.SecondaryUnit</MudTd>
                <MudTd DataLabel="Unit Ratio">@context.UnitRatio</MudTd>
                <MudTd DataLabel="Actions" Style="text-align: right;">
                    <div class="d-flex justify-end gap-1">
                        <MudTooltip Text="Edit">
                            <MudIconButton OnClick="@(()=> Edit(context))" Color="Color.Primary" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Variant="Variant.Text" />
                        </MudTooltip>
                        <MudTooltip Text="Delete">
                            <MudIconButton OnClick="@(()=> Delete(context))" Color="Color.Error" Icon="@Icons.Material.Filled.DeleteOutline" Size="Size.Small" Variant="Variant.Text" />
                        </MudTooltip>
                    </div>
                </MudTd>
            </RowTemplate>
            <PagerContent>
                <div class="pa-4">
                    <MudTablePager PageSizeOptions="new int[] { 10, 20, 50, 100 }" />
                </div>
            </PagerContent>
        </MudTable>
    </div>
</div>

@code {

    private ContentModel model = new ContentModel();
    private List<ContentModel> collection = new List<ContentModel>();
    public List<DistrictModel> districts = new List<DistrictModel>();

    private string searchContent = "";
    private bool _busy;
    public bool HasPermissionContentServiceEdit { get; set; } = false;
    public bool HasPermissionContentServiceDelete { get; set; } = false;
    public int DocTypeID = 55;

    // Method called when the component is initialized
    protected override async Task OnInitializedAsync()
    {
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionContentServiceEdit = await Irole.HasClaim(DocTypeID.ToString(), "Edit", ctc.Token);
        HasPermissionContentServiceDelete = await Irole.HasClaim(DocTypeID.ToString(), "Delete", ctc.Token);

        await GetAll();
    }

    // Method to retrieve all content models
    private async Task GetAll()
    {
        await foreach (var content in Iservice.Select(0))
        {
            collection.Add(content);
        }
    }

    // Method called when the form is submitted
    private async Task OnValidSubmit(EditContext context)
    {
        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;
        model.UserInfo.UserID = user.Identity.Name;
        try
        {
            // Update the content model
            model = await Iservice.Update(model);
            if (collection.Exists(x => x.ContentID == model.ContentID))
            {
                collection[collection.FindIndex(x => x.ContentID == model.ContentID)] = model;
            }
            else
            {
                collection.Add(model);
            }
            model = new ContentModel();
            snackbar.Add("Saved Successfully", Severity.Success);
            StateHasChanged();
        }
        catch (Exception ex)
        {
            snackbar.Add(ex.Message, Severity.Warning);
        }
    }

    // Method to edit a content model
    private async Task Edit(ContentModel model)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        _busy = true;
        if (HasPermissionContentServiceEdit)
        {
            DialogParameters parms = new DialogParameters();
            parms.Add("model", model.Clone());
            var dialog = await DialogService.ShowAsync<Contentedit>("Edit", parms);
            var result = await dialog.Result;

            // you can check if the modal was cancelled
            var isCancelled = result.Canceled;
            if (!isCancelled)
            {
                ContentModel UpatedModel = (ContentModel)result.Data;
                if (UpatedModel != null)
                {
                    if (collection.Exists(x => x.ContentID == UpatedModel.ContentID))
                    {
                        collection[collection.FindIndex(x => x.ContentID == UpatedModel.ContentID)] = UpatedModel;
                    }
                    else
                    {
                        collection.Add(UpatedModel);
                    }
                }
                model = new();
            }
        }
        else
        {
            bool? ResultModel = await DialogService.ShowMessageBoxAsync(
                "Permission denied!",
                "You don't have any permission to Add or Edit Content.");
        }
        await Task.Delay(200);
        _busy = false;
    }

    // Method to delete a content model
    private async Task Delete(ContentModel model)
    {
        if (HasPermissionContentServiceDelete)
        {
            bool? result = await DialogService.ShowMessageBoxAsync(
                "Warning !",
                "Are you sure, you want to delete - " + model.ContentName + " ?");
            if (result == true)
            {
                var authprov = await auth.GetAuthenticationStateAsync();
                var user = authprov.User;

                // Call the service to delete the content
                int value = await Iservice.Delete(model.ContentID, user.Identity.Name);
                if (value != -1)
                {
                    if (collection != null && collection.Any(s => s.ContentID == model.ContentID))
                    {
                        collection.Remove(collection.FirstOrDefault(s => s.ContentID == model.ContentID));
                        snackbar.Add("Deleted Successfully", Severity.Success);
                    }
                }
            }
        }
        else
        {
            bool? result = await DialogService.ShowMessageBoxAsync(
                "Permission denied!",
                "You don't have any permission to Delete Content.");
        }
    }

    // Method to search for content based on a search string
    private bool search(ContentModel model)
    {
        if (model.ContentName != null && model.ContentName.Contains(searchContent, StringComparison.OrdinalIgnoreCase))
        {
            return true;
        }
        return false;
    }
}

