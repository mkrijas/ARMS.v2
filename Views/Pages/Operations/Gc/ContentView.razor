@page "/content"
@using System.Threading;
@attribute [Authorize]
@inject AuthenticationStateProvider auth
@inject IContentService Iservice
@inject MudBlazor.ISnackbar snackbar
@inject IDialogService DialogService
@inject IRoleService<RoleModel> Irole

<MudGrid Spacing="4">
    <MudItem xs="12" md="12">
        <MudTable Items="@collection" Elevation="5" Filter="new Func<ContentModel, bool>(search)" @bind-model="model">
            <ToolBarContent>
                <MudTextField @bind-Value="searchContent" Placeholder="Search here" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium"></MudTextField>
            </ToolBarContent>
            <ToolBarContent>
                <MudText Typo="Typo.h6">Content</MudText>
                <MudIconButton Disabled="@_busy" Icon="@Icons.Material.Filled.Add" Title="Add" @onclick="(() => Edit(new ContentModel()))" Color="Color.Dark" Size="Size.Small"></MudIconButton>
                <MudSpacer></MudSpacer>
                <MudTextField @bind-Value="searchContent" Placeholder="Search here" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium"></MudTextField>
            </ToolBarContent>
            <HeaderContent>
                <MudTh class="rowclas"><MudTableSortLabel SortBy="new Func<ContentModel, object>(x=> x.ContentName)" InitialDirection="SortDirection.Ascending">Content</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<ContentModel, object>(x=> x.PrimaryUnit)" InitialDirection="SortDirection.Ascending">Primary Unit</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<ContentModel, object>(x=> x.SecondaryUnit)" InitialDirection="SortDirection.Ascending">Secondary Unit</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<ContentModel, object>(x=> x.UnitRatio)" InitialDirection="SortDirection.Ascending">Unit Ratio</MudTableSortLabel></MudTh>
                <MudTh>Actions</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Content">@context.ContentName</MudTd>
                <MudTd DataLabel="Primary Unit">@context.PrimaryUnit</MudTd>
                <MudTd DataLabel="Secondary Unit">@context.SecondaryUnit</MudTd>
                <MudTd DataLabel="Unit Ratio">@context.UnitRatio</MudTd>
                <MudTd DataLabel="">
                    <MudFab style="font-size:5px" @onclick="@(()=> Edit(context))" Color="Color.Primary" Icon="@Icons.Material.Outlined.Edit" Size="Size.Small" IconSize="Size.Small" />
                    <MudFab @onclick="@(()=> Delete(context))" Color="Color.Primary" Icon="@Icons.Material.Outlined.Delete" Size="Size.Small" IconSize="Size.Small" />
                </MudTd>
            </RowTemplate>
            <PagerContent>
                <MudTablePager PageSizeOptions="new int[] { 10, 20, 50, 100 }" />
            </PagerContent>
        </MudTable>
    </MudItem>
</MudGrid>

@code {

    private ContentModel model = new ContentModel();
    private List<ContentModel> collection = new List<ContentModel>();
    public List<DistrictModel> districts = new List<DistrictModel>();

    private string searchContent = "";
    private bool _busy;
    public bool HasPermissionContentServiceEdit { get; set; } = false;
    public bool HasPermissionContentServiceDelete { get; set; } = false;
    public int DocTypeID = 55;

    // Method called when the component is initialized
    protected override async Task OnInitializedAsync()
    {
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionContentServiceEdit = await Irole.HasClaim(DocTypeID.ToString(), "Edit", ctc.Token);
        HasPermissionContentServiceDelete = await Irole.HasClaim(DocTypeID.ToString(), "Delete", ctc.Token);

        await GetAll();
    }

    // Method to retrieve all content models
    private async Task GetAll()
    {
        await foreach (var content in Iservice.Select(0))
        {
            collection.Add(content);
        }
    }

    // Method called when the form is submitted
    private async Task OnValidSubmit(EditContext context)
    {
        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;
        model.UserInfo.UserID = user.Identity.Name;
        try
        {
            // Update the content model
            model = await Iservice.Update(model);
            if (collection.Exists(x => x.ContentID == model.ContentID))
            {
                collection[collection.FindIndex(x => x.ContentID == model.ContentID)] = model;
            }
            else
            {
                collection.Add(model);
            }
            model = new ContentModel();
            snackbar.Add("Saved Successfully", Severity.Success);
            StateHasChanged();
        }
        catch (Exception ex)
        {
            snackbar.Add(ex.Message, Severity.Warning);
        }
    }

    // Method to edit a content model
    private async Task Edit(ContentModel model)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        _busy = true;
        if (HasPermissionContentServiceEdit)
        {
            DialogParameters parms = new DialogParameters();
            parms.Add("model", model.Clone());
            var dialog = DialogService.Show<Contentedit>("Edit", parms);
            var result = await dialog.Result;

            // you can check if the modal was cancelled
            var isCancelled = result.Canceled;
            if (!isCancelled)
            {
                ContentModel UpatedModel = (ContentModel)result.Data;
                if (UpatedModel != null)
                {
                    if (collection.Exists(x => x.ContentID == UpatedModel.ContentID))
                    {
                        collection[collection.FindIndex(x => x.ContentID == UpatedModel.ContentID)] = UpatedModel;
                    }
                    else
                    {
                        collection.Add(UpatedModel);
                    }
                }
                model = new();
            }
        }
        else
        {
            bool? ResultModel = await DialogService.ShowMessageBox(
                "Permission denied!",
                "You don't have any permission to Add or Edit Content.");
        }
        await Task.Delay(200);
        _busy = false;
    }

    // Method to delete a content model
    private async Task Delete(ContentModel model)
    {
        if (HasPermissionContentServiceDelete)
        {
            bool? result = await DialogService.ShowMessageBox(
                "Warning !",
                "Are you sure, you want to delete - " + model.ContentName + " ?");
            if (result == true)
            {
                var authprov = await auth.GetAuthenticationStateAsync();
                var user = authprov.User;

                // Call the service to delete the content
                int value = await Iservice.Delete(model.ContentID, user.Identity.Name);
                if (value != -1)
                {
                    if (collection != null && collection.Any(s => s.ContentID == model.ContentID))
                    {
                        collection.Remove(collection.FirstOrDefault(s => s.ContentID == model.ContentID));
                        snackbar.Add("Deleted Successfully", Severity.Success);
                    }
                }
            }
        }
        else
        {
            bool? result = await DialogService.ShowMessageBox(
                "Permission denied!",
                "You don't have any permission to Delete Content.");
        }
    }

    // Method to search for content based on a search string
    private bool search(ContentModel model)
    {
        if (model.ContentName != null && model.ContentName.Contains(searchContent, StringComparison.OrdinalIgnoreCase))
        {
            return true;
        }
        return false;
    }
}