@attribute [Authorize]
@inject AuthenticationStateProvider auth
@using System.Threading;
@inject IContentService Iservice
@inject MudBlazor.ISnackbar snackbar
@inject IDialogService DialogService
@inject IRoleService<RoleModel> Irole

<DialogForm @ref="@dialogForm" Title="Content Property" Subtitle="Configure material types and unit measurement properties." Icon="@Icons.Material.Filled.Build" AdminStyle="true" formID="contentForm" model="@model" _busy="_busy">
    <FormContent>
        <div class="dialog-content-wrapper pa-4">
            <EditForm id="contentForm" Model="@model" OnValidSubmit="OnValidSubmit">
                <div class="admin-glass-card pa-6">
                    <ObjectGraphDataAnnotationsValidator />
                    <MudValidationSummary />
                    <MudGrid Spacing="3">
                        <MudItem xs="12">
                            <MudTextField @bind-Value="model.ContentName" Label="Content Name" Variant="Variant.Outlined" For="@(() => model.ContentName)" Class="modern-input"></MudTextField>
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <MudTextField @bind-Value="model.PrimaryUnit" Label="Primary Unit" Variant="Variant.Outlined" For="@(() => model.PrimaryUnit)" Class="modern-input"></MudTextField>
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <MudTextField @bind-Value="model.SecondaryUnit" Label="Secondary Unit" Variant="Variant.Outlined" For="@(() => model.SecondaryUnit)" Class="modern-input"></MudTextField>
                        </MudItem>
                        <MudItem xs="12">
                            <MudNumericField HideSpinButtons @bind-Value="model.UnitRatio" Label="Unit Conversion Ratio" Variant="Variant.Outlined" For="@(() => model.UnitRatio)" Class="modern-input"></MudNumericField>
                        </MudItem>
                    </MudGrid>
                </div>
            </EditForm>
        </div>
    </FormContent>
</DialogForm>

@code {

    [Parameter]
    public ContentModel model { get; set; }
    private List<ContentModel> collection = new List<ContentModel>();
    public List<DistrictModel> districts = new List<DistrictModel>();
    DialogForm dialogForm;
    private bool _busy;

    public bool HasPermissionContentServiceEdit { get; set; } = false;
    public int DocTypeID = 55;

    // Method called when the component is initialized
    protected override async Task OnInitializedAsync()
    {
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionContentServiceEdit = await Irole.HasClaim(DocTypeID.ToString(), "Edit", ctc.Token);
        await Task.Run(() => GetAll());
    }

    private async Task GetAll()
    {
        await foreach (var content in Iservice.Select(0))
        {
            collection.Add(content);
        }
    }

    private async void OnValidSubmit(EditContext context)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is being submitted!", Severity.Warning);
            return;
        }
        _busy = true;
        if (HasPermissionContentServiceEdit)
        {
            var authprov = await auth.GetAuthenticationStateAsync();
            var user = authprov.User;
            model.UserInfo.UserID = user.Identity.Name;
            model.ContentName = FontStyle.ConvertToCamelCase(model.ContentName);
            model.PrimaryUnit = model.PrimaryUnit.ToUpper();
            model.SecondaryUnit = model.SecondaryUnit.ToUpper();
            try
            {
                // Update the content model
                model = await Iservice.Update(model);
                snackbar.Add("Saved Successfully", Severity.Success);
                dialogForm.Close(model);
            }
            catch (Exception ex)
            {
                snackbar.Add(ex.Message, Severity.Warning);
            }
        }
        else
        {
            await DialogService.ShowMessageBoxAsync(
                "Permission denied!",
                "You don't have any permission to Add or Edit Content.");
        }
        await Task.Delay(200);
        _busy = false;
    }
}
