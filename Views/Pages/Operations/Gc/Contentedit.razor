@attribute [Authorize]
@inject AuthenticationStateProvider auth
@using System.Threading;
@inject IContentService Iservice
@inject MudBlazor.ISnackbar snackbar
@inject IDialogService DialogService
@inject IRoleService<RoleModel> Irole

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.Build" Class="mr-3 mb-n1" />
            Content
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudContainer Style="max-height: 450px; overflow-y: scroll">
            <EditForm id="formContent" Model="@model" OnValidSubmit="OnValidSubmit">
                <ObjectGraphDataAnnotationsValidator />
                <ValidationSummary />
                <MudGrid Spacing="2">
                    <MudItem xs="12" md="12">
                        <MudTextField @bind-Value="model.ContentName" Label="Content" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.ContentName)"></MudTextField>
                    </MudItem>
                    <MudItem xs="12" md="12">
                        <MudTextField @bind-Value="model.PrimaryUnit" Label="Primary Unit" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.PrimaryUnit)"></MudTextField>
                    </MudItem>
                    <MudItem xs="12" md="12">
                        <MudTextField @bind-Value="model.SecondaryUnit" Label="Secondary Unit" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.SecondaryUnit)"></MudTextField>
                    </MudItem>
                    <MudItem xs="12" md="12">
                        <MudTextField InputType="InputType.Number" @bind-Value="model.UnitRatio" Label="Ratio" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.UnitRatio)"></MudTextField>
                    </MudItem>
                </MudGrid>
            </EditForm>
        </MudContainer>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Disabled="@_busy" form="formContent" Variant="Variant.Filled" Color="Color.Success" ButtonType="ButtonType.Submit">Save</MudButton>
    </DialogActions>
</MudDialog>

@code {

    [Parameter]
    public ContentModel model { get; set; }
    private List<ContentModel> collection = new List<ContentModel>();
    public List<DistrictModel> districts = new List<DistrictModel>();
    [CascadingParameter] MudDialogInstance MudDialog { get; set; }
    private bool _busy;

    public bool HasPermissionContentServiceEdit { get; set; } = false;
    public int DocTypeID = 55;

    void Submit() => MudDialog.Close(DialogResult.Ok(true));
    void Cancel() => MudDialog.Cancel();

    protected override async Task OnInitializedAsync()
    {
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionContentServiceEdit = await Irole.HasClaim(DocTypeID.ToString(), "Edit", ctc.Token);

        await Task.Run(() => GetAll());
    }

    private async Task GetAll()
    {
        await foreach (var content in Iservice.Select(0))
        {
            collection.Add(content);
        }
    }

    private async void OnValidSubmit(EditContext context)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is being submitted!", Severity.Warning);
            return;
        }
        _busy = true;
        if (HasPermissionContentServiceEdit)
        {
            var authprov = await auth.GetAuthenticationStateAsync();
            var user = authprov.User;
            model.UserInfo.UserID = user.Identity.Name;
            model.ContentName = FontStyle.ConvertToCamelCase(model.ContentName);
            model.PrimaryUnit = model.PrimaryUnit.ToUpper();
            model.SecondaryUnit = model.SecondaryUnit.ToUpper();
            try
            {
                model = await Iservice.Update(model);
                snackbar.Add("Saved Successfully", Severity.Success);
                StateHasChanged();
                MudDialog.Close(model);
            }
            catch (Exception ex)
            {
                snackbar.Add(ex.Message, Severity.Warning);
            }
        }
        else
        {
            bool? ResultModel = await DialogService.ShowMessageBox(
                "Permission denied!",
                "You dont have any permission to Add or Edit Content.");
        }
        await Task.Delay(200);
        _busy = false;
    }
}