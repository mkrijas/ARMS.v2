@attribute [Authorize]
@inject AuthenticationStateProvider auth
@using System.Threading;
@inject IGcService Iservice
@inject IDialogService DialogService
@inject MudBlazor.ISnackbar snackbar
@inject IRoleService<RoleModel> Irole
@inject IPushNotificationService IpushNotificationService
@inject SignalRService signalRService

<DialogForm @ref="@dialogForm" Title="E-Way Bill Compliance" Subtitle="Register and validate regulatory travel documentation for active cargo consignments." Icon="@Icons.Material.Filled.Assignment" AdminStyle="true" formID="formEwayBill" model="@model" _busy="_busy">
    <FormContent>
        <div class="dialog-content-wrapper">
            <EditForm id="formEwayBill" Model="@model" OnValidSubmit="OnValidSubmit">
                <ObjectGraphDataAnnotationsValidator/>
                
                <div class="admin-glass-card pa-6 mb-6">
                    <div class="d-flex align-center justify-space-between">
                        <div class="d-flex align-center">
                            <MudIcon Icon="@Icons.Material.Filled.Numbers" Color="Color.Primary" Class="mr-3" />
                            <div>
                                <MudText Typo="Typo.subtitle2" Class="color-muted mb-n1">Consignment Set ID</MudText>
                                <MudText Typo="Typo.h6" Class="fw-700">@model.SetGcNumber</MudText>
                            </div>
                        </div>
                        <div class="admin-badge secondary px-4 py-2 rounded-pill">
                            <span class="fw-600">@model.Gcs.Count Invoices</span>
                        </div>
                    </div>
                </div>

                <div class="admin-glass-card pa-0 overflow-hidden">
                    <MudTabs Outlined="false" Position="Position.Left" Rounded="false" Border="true" ApplyEffectsToContainer="true" 
                             Class="modern-tabs-vertical" PanelClass="pa-8" 
                             SliderColor="Color.Primary" ActivePanelIndex="0">
                        @foreach (var wrapperitem in model.Gcs.Select((value, i) => new { i, value }))
                        {
                            var item = wrapperitem.value.EwayBill;
                            <MudTabPanel Text="@(wrapperitem.value.BillNumber)" Icon="@Icons.Material.Filled.Description">
                                <div class="invoice-container">
                                    <div class="d-flex align-center mb-6">
                                        <MudIcon Icon="@Icons.Material.Filled.ReceiptLong" Color="Color.Primary" Class="mr-2" />
                                        <span class="admin-section-label mb-0">Invoice Verification #@wrapperitem.value.BillNumber</span>
                                    </div>

                                    <MudGrid Spacing="4">
                                        <MudItem xs="12">
                                            <MudTextField Mask="@(new PatternMask("000000000000"))" @bind-Value="item.EwayBillRef" Label="12-Digit E-Way Bill Number" Variant="Variant.Outlined" Margin="Margin.Normal" For="@(() => item.EwayBillRef)" Class="modern-input" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.QrCode" Placeholder="Enter 12 digits..."></MudTextField>
                                        </MudItem>
                                        <MudItem xs="12" md="6">
                                            <MudDatePicker Label="Issuance Date" Variant="Variant.Outlined" Margin="Margin.Normal" DateChanged="((e) => EwayBillDateChanged(item, e))" DisableToolbar="true" Editable="true" Date="item.EwayBillDate" DateFormat="dd/MM/yyyy" Class="modern-input" AdornmentIcon="@Icons.Material.Filled.Today" />
                                        </MudItem>
                                        <MudItem xs="12" md="6">
                                            <MudDatePicker Label="Legal Expiry Date" Variant="Variant.Outlined" Margin="Margin.Normal" DisableToolbar="true" Editable="true" @bind-Date="@(item.ExpireOn)" DateFormat="dd/MM/yyyy" Class="modern-input" AdornmentIcon="@Icons.Material.Filled.RunningWithErrors" />
                                        </MudItem>
                                    </MudGrid>
                                </div>
                            </MudTabPanel>
                        }
                    </MudTabs>
                </div>
            </EditForm>
        </div>
    </FormContent>
</DialogForm>

@code {
    DialogForm dialogForm;
    [Parameter] public GcSetModel model { get; set; }
    private bool _busy;

    public bool HasPermissionGcServiceEdit { get; set; } = false;
    public int DocTypeID = 46;

    [Parameter]
    public int? MessageDocumentID { get; set; } = null;
    public string UserID { get; set; }
    public int BranchID { get; set; }

    #region SignaIR Notification
    private List<PushNotificationModel> currentNotificationMessages = new List<PushNotificationModel>();
    private PushNotificationModel notificationMessage = new PushNotificationModel();
    #endregion

    // Method called when the component is initialized
    protected override async Task OnInitializedAsync()
    {
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionGcServiceEdit = await Irole.HasClaim(DocTypeID.ToString(), "Edit", ctc.Token);
        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;
        UserID = user.Identity.Name;
        BranchID = int.Parse(authprov.User.Claims.First(x => x.Type == "BranchID").Value);
        await signalRService.StartAsync();
    }

    private void Cancel()
    {
        model = new();
        dialogForm.Cancel();
    }

    // Method called when the form is submitted
    private async Task OnValidSubmit(EditContext context)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is being submitted!", Severity.Warning);
            return;
        }
        
        if (HasPermissionGcServiceEdit)
        {
            _busy = true;
            var authprov = await auth.GetAuthenticationStateAsync();
            try
            {
                foreach (var item in model.Gcs)
                {
                    if (item.EwayBill.EwayBillRef.Length != 12)
                    {
                        snackbar.Add("EwayBill Number Must be 12 digits long !!", Severity.Warning);
                        _busy = false;
                        return;
                    }
                    item.EwayBill.GcID = item.GcID;
                    item.EwayBill.UserInfo.UserID = authprov.User.Identity.Name;

                    // Update the EwayBill
                    var EwayBill = Iservice.UpdateEwayBill(item.EwayBill);
                }
                snackbar.Add("Saved Successfully", Severity.Success);
                await Task.Delay(200);
                dialogForm.Close(DialogResult.Ok(model));
            }
            catch (Exception ex)
            {
                snackbar.Add(ex.Message, Severity.Warning);
                return;
            }
            _busy = false;
        }
        else
        {
            bool? ResultModel = await DialogService.ShowMessageBoxAsync(
                "Permission denied!",
                "You don't have any permission to Add or Edit GC.");
        }
    }

    // Method to handle changes in the EwayBill date
    private void EwayBillDateChanged(EwayBillModel ewaymodel, DateTime? date)
    {
        ewaymodel.EwayBillDate = date;
        if (date != null)
        {
            DateTime dateValue = date.Value;
            ewaymodel.ExpireOn = dateValue.AddDays(1);
        }
        else
        {
            ewaymodel.ExpireOn = null;
        }
    }
}
