@inject IGcService Iservice

@inject IDialogService DialogService
@inject MudBlazor.ISnackbar snackbar
@attribute [Authorize]
@inject AuthenticationStateProvider auth

@using System.Threading;
@inject IRoleService<RoleModel> Irole

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.FileCopy" />
            Eway Bill
        </MudText>
    </TitleContent>
    <DialogContent>

        <EditForm id="form" Model="@model" OnValidSubmit="OnValidSubmit">
            <ValidationSummary />
            <MudText Typo="Typo.h6">@model.SetGcNumber</MudText>

            <MudTabs Outlined="true" Position="Position.Right" Rounded="true" Border="true"
                     ApplyEffectsToContainer="true" Class="mt-8" PanelClass="pa-6">
                @foreach (var wrapperitem in model.Gcs.Select((value, i) => new { i, value }))
                {
                    var item = wrapperitem.value.EwayBill;
                    <MudTabPanel Text="@("Invoice No:"+wrapperitem.value.BillNumber)">
                        <MudGrid>
                            <MudItem xs="6">
                                <MudTextField @bind-Value="item.EwayBillRef" Label="Eway Bill Number" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => item.EwayBillRef)"></MudTextField>
                            </MudItem>
                            <MudItem xs="6">
                                <MudDatePicker Label="Bill Date" Variant="Variant.Outlined" Margin="Margin.Dense" TransformOrigin="Origin.BottomLeft" AnchorOrigin="Origin.BottomRight" DateChanged="((e) => EwayBillDateChanged(item, e))" DisableToolbar="true" Editable="true" Date="item.EwayBillDate" HelperText="Enter Date" DateFormat="dd/MM/yyyy" />
                            </MudItem>
                            <MudItem xs="12">
                                <MudDatePicker Label="Expire On" Variant="Variant.Outlined" Margin="Margin.Dense" TransformOrigin="Origin.BottomLeft" AnchorOrigin="Origin.BottomRight" DisableToolbar="true" Editable="true" @bind-Date="@(item.ExpireOn)" />
                            </MudItem>
                        </MudGrid>
                    </MudTabPanel>
                }
            </MudTabs>
        </EditForm>

    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton form="form" Variant="Variant.Filled" Color="Color.Success" ButtonType="ButtonType.Submit">Save</MudButton>
    </DialogActions>
</MudDialog>

@code {

    [CascadingParameter] MudDialogInstance MudDialog { get; set; }
    [Parameter] public GcSetModel model { get; set; }

    public bool HasPermissionGcServiceEdit { get; set; } = false;
    public int DocTypeID = 46;

    protected override async Task OnInitializedAsync()
    {
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionGcServiceEdit = await Irole.HasClaim(DocTypeID.ToString(), "Edit", ctc.Token);
    }

    private void Cancel()
    {
        model = new();
        MudDialog.Cancel();
    }


    private async Task OnValidSubmit(EditContext context)
    {
        if (HasPermissionGcServiceEdit)
        {
            var authprov = await auth.GetAuthenticationStateAsync();

            foreach (var item in model.Gcs)
            {
                item.EwayBill.GcID = item.GcID;
                item.EwayBill.UserInfo.UserID = authprov.User.Identity.Name;

                try
                {
                    EwayBillModel result = Iservice.UpdateEwayBill(item.EwayBill);
                }
                catch (Exception ex)
                {
                    snackbar.Add(ex.Message, Severity.Warning);
                    return;
                }
            }
            snackbar.Add("Saved Successfully", Severity.Success);
            MudDialog.Close(DialogResult.Ok(model));
            model = new GcSetModel();
        }
        else
        {
            bool? ResultModel = await DialogService.ShowMessageBox(
                "Permission denied!",
                "You dont have any permission to Add or Edit GC.");
        }
    }


    private void EwayBillDateChanged(EwayBillModel ewaymodel, DateTime? date)
    {
        ewaymodel.EwayBillDate = date;
        if (date != null)
        {
            DateTime dateValue = date.Value;
            ewaymodel.ExpireOn = dateValue.AddDays(2);
        }
        else
        {
            ewaymodel.ExpireOn = null;
        }
    }

}
