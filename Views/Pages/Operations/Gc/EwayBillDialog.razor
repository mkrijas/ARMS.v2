@attribute [Authorize]
@inject AuthenticationStateProvider auth
@using System.Threading;
@inject IGcService Iservice
@inject IDialogService DialogService
@inject MudBlazor.ISnackbar snackbar
@inject IRoleService<RoleModel> Irole
@inject IPushNotificationService IpushNotificationService
@inject SignalRService signalRService

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.FileCopy" />
            Eway Bill
        </MudText>
    </TitleContent>
    <DialogContent>
        <EditForm id="form" Model="@model" OnValidSubmit="OnValidSubmit">
            <ValidationSummary />
            <MudText Typo="Typo.h6">@model.SetGcNumber</MudText>
            <MudTabs Outlined="true" Position="Position.Right" Rounded="true" Border="true" ApplyEffectsToContainer="true" Class="mt-8" PanelClass="pa-6">
                @foreach (var wrapperitem in model.Gcs.Select((value, i) => new { i, value }))
                {
                    var item = wrapperitem.value.EwayBill;
                    <MudTabPanel Text="@("Invoice No:"+wrapperitem.value.BillNumber)">
                        <MudGrid>
                            <MudItem xs="6">
                                <MudTextField @bind-Value="item.EwayBillRef" Label="Eway Bill Number" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => item.EwayBillRef)"></MudTextField>
                            </MudItem>
                            <MudItem xs="6">
                                <MudDatePicker Label="Bill Date" Variant="Variant.Outlined" Margin="Margin.Dense" TransformOrigin="Origin.BottomLeft" AnchorOrigin="Origin.BottomRight" DateChanged="((e) => EwayBillDateChanged(item, e))" DisableToolbar="true" Editable="true" Date="item.EwayBillDate" HelperText="Enter Date" DateFormat="dd/MM/yyyy" />
                            </MudItem>
                            <MudItem xs="12">
                                <MudDatePicker Label="Expire On" Variant="Variant.Outlined" Margin="Margin.Dense" TransformOrigin="Origin.BottomLeft" AnchorOrigin="Origin.BottomRight" DisableToolbar="true" Editable="true" @bind-Date="@(item.ExpireOn)" />
                            </MudItem>
                        </MudGrid>
                    </MudTabPanel>
                }
            </MudTabs>
        </EditForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Disabled="@_busy" form="form" Variant="Variant.Filled" Color="Color.Success" ButtonType="ButtonType.Submit">Save</MudButton>
    </DialogActions>
</MudDialog>

@code {

    [CascadingParameter] MudDialogInstance MudDialog { get; set; }
    [Parameter] public GcSetModel model { get; set; }
    private bool _busy;

    public bool HasPermissionGcServiceEdit { get; set; } = false;
    public int DocTypeID = 46;

    [Parameter]
    public int? MessageDocumentID { get; set; } = null;
    public string UserID { get; set; }
    public int BranchID { get; set; }

    #region SignaIR Notification
    private List<PushNotificationModel> currentNotificationMessages = new List<PushNotificationModel>();
    private PushNotificationModel notificationMessage = new PushNotificationModel();
    #endregion

    protected override async Task OnInitializedAsync()
    {
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionGcServiceEdit = await Irole.HasClaim(DocTypeID.ToString(), "Edit", ctc.Token);
        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;
        UserID = user.Identity.Name;
        BranchID = int.Parse(authprov.User.Claims.First(x => x.Type == "BranchID").Value);
        await signalRService.StartAsync();
    }

    private void Cancel()
    {
        model = new();
        MudDialog.Cancel();
    }

    private async Task OnValidSubmit(EditContext context)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is being submitted!", Severity.Warning);
            return;
        }
        if (HasPermissionGcServiceEdit)
        {
            _busy = true;
            var authprov = await auth.GetAuthenticationStateAsync();
            foreach (var item in model.Gcs)
            {
                item.EwayBill.GcID = item.GcID;
                item.EwayBill.UserInfo.UserID = authprov.User.Identity.Name;
                try
                {
                    EwayBillModel result = Iservice.UpdateEwayBill(item.EwayBill);
                    if (MessageDocumentID != null && item != null && item.EwayBill != null && item.EwayBill.ExpireOn != null && (item.EwayBill.ExpireOn - DateTime.Now).Value.TotalHours >= 4)
                    {
                        notificationMessage = new();
                        notificationMessage.DocumentID = MessageDocumentID;
                        notificationMessage.MessageGroupID = "EWayBill";
                        notificationMessage.DocumentTypeID = DocTypeID;
                        currentNotificationMessages = IpushNotificationService.SelectNotificationsBasedOnBranchDocumentIdDocumentTypeId(BranchID, MessageDocumentID, DocTypeID).ToList();
                        string MessageIDs = string.Join(",", currentNotificationMessages.Select(d => d.MessageID).ToList());
                        IpushNotificationService.AknowledgedSelectedItems(MessageIDs, UserID);
                        await signalRService.Send(notificationMessage);
                    }
                }
                catch (Exception ex)
                {
                    snackbar.Add(ex.Message, Severity.Warning);
                    return;
                }
            }
            snackbar.Add("Saved Successfully", Severity.Success);
            MudDialog.Close(DialogResult.Ok(model));
            model = new GcSetModel();
            await Task.Delay(200);
            _busy = false;
        }
        else
        {
            bool? ResultModel = await DialogService.ShowMessageBox(
                "Permission denied!",
                "You dont have any permission to Add or Edit GC.");
        }
    }

    private void EwayBillDateChanged(EwayBillModel ewaymodel, DateTime? date)
    {
        ewaymodel.EwayBillDate = date;
        if (date != null)
        {
            DateTime dateValue = date.Value;
            ewaymodel.ExpireOn = dateValue.AddDays(2);
        }
        else
        {
            ewaymodel.ExpireOn = null;
        }
    }
}