@using MudBlazor
@using ArmsModels.BaseModels.General;
@using System.Threading;
@inject IGcService Iservice
@inject AuthenticationStateProvider auth
@inject MudBlazor.ISnackbar snackbar
@inject IRoleService<RoleModel> Irole
@inject IDialogService DialogService

<MudDialog Class="my-dialogue pb-3">
    <DialogContent>
            <MudGrid style="padding:0px;">
                @foreach (var i in GcList)
                {
                <MudItem sm="12" style="border:1px solid lightgray; border-bottom-left-radius:7px; border-bottom-right-radius:7px; width:100%;">
                    <MudGrid>
                        <MudItem sm="4" Class="d-flex align-items-center">
                            <MudCheckBox Value="@i.IsAcknowledged"
                                         ValueChanged="((bool value) => ConfirmAcknowledgement(i, value))"
                                         Color="Color.Primary"
                                         Label="@($"{i.GcPrefix} {i.GcNumber}")"
                                         Class="text-nowrap" />
                        </MudItem>
                    </MudGrid>
                </MudItem>
                }
            </MudGrid>
    </DialogContent>
</MudDialog>

@code {

    [Parameter]
    public long? GcSetID { get; set; }
    private List<GcModel> GcList;
    private GcModel Gc;

    // Method called when the component is initialized
    protected override async Task OnInitializedAsync()
    {

        // CancellationTokenSource ctc = new CancellationTokenSource();
        // HasPermissionBranchSettingsServiceEdit = await Irole.HasClaim(BranchSettingsDocTypeID.ToString(), "Edit", ctc.Token);

        // Fetch the list of GcModels
        GcList = Iservice.GetGcs(GcSetID).ToList();
    }

    // Method to confirm the acknowledgment of a GcModel
    private async Task ConfirmAcknowledgement(GcModel gc,bool value)
    {
        if (!value)
        {
            gc.IsAcknowledged = value;
            Iservice.ConfirmAcknowledgement(gc.GcID, false); // Call the service to confirm acknowledgment
        }
        if (value)
        {
            bool? confirm = await DialogService.ShowMessageBox("Confirmation !",
                "Are you sure, you want to Acknowledge?", "Yes", "No");
            if (confirm == true)
            {
                gc.IsAcknowledged = value;
                Iservice.ConfirmAcknowledgement(gc.GcID, true);
            }           
        }
    }
