@using System.Threading;
@inject AuthenticationStateProvider auth
@inject IDialogService DialogService
@inject IGcService Iservice
@inject MudBlazor.ISnackbar snackbar
@inject IRoleService<RoleModel> Irole

<div style="position:relative">
    @if (item.UnloadEndEventID != null)
    {
        <span class="stamp is-Delivered">DELIVERED</span>
        @* <h2 class="Finished">DELIVERED</h2> *@
    }

    <MudCard Class="@Class" Style="@Style">
        <MudCardHeader>
            <CardHeaderAvatar>
                <MudAvatar Color="ewaycolor">GC</MudAvatar>
            </CardHeaderAvatar>
            <CardHeaderContent>
                <MudText Typo="Typo.body1" GutterBottom="true"><b>@item.SetGcNumber</b></MudText>
                <MudText Typo="Typo.caption">@item.SetBillNumber</MudText>
            </CardHeaderContent>
            <CardHeaderActions>
                @if (IsLoading)
                {
                    <MudTooltip Text="Remove GC">
                        <MudIconButton @onclick="@(() => RemoveButtonClicked(item.GcSetID))" Icon="@Icons.Material.Filled.Close" Color="Color.Error" />
                    </MudTooltip>
                }
            </CardHeaderActions>
        </MudCardHeader>
        <MudCardContent>
            
            <MudText Typo="Typo.h6"><b> @item.ConsigneeName </b></MudText>
            <MudText>From:  @item.ConsignorName</MudText>
            <MudText Typo="Typo.body2" Color="Color.Info">@item.RouteName</MudText>
            <MudText>Rs @item.TotalFreight</MudText>            
            <MudText Typo="Typo.h5" Color="Color.Primary">@item.TotalBillQuantity   @item.UoM  @item.Content</MudText>
            
            @if (unloading)
            {
                <MudTextField @bind-Value="@item.SetUnloadQuantity" Label="UnloadingQuantity" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => @item.SetUnloadQuantity)"></MudTextField>
                <MudItem xs="12" md="6" Class="d-flex align-center">
                    @if (!string.IsNullOrEmpty(item.Acknowledgement))
                    {
                        <a href="@item.Acknowledgement" download="Acknowledgement">
                            <MudText Typo="Typo.h6" Color="Color.Primary">
                                Acknowledgement
                                <MudIcon Icon="@Icons.Material.Filled.Download" Title="Download" />
                            </MudText>
                        </a>
                    }
                </MudItem>
            }
        </MudCardContent>
        <MudCardActions>
            @if (!unloading)
            {
                <MudButton @onclick="@(() => Edit(item.GcSetID))" Color="Color.Primary" Disabled="@IsLocked">EDIT</MudButton>
                <MudButton @onclick="@(() => EwayBill(item.GcSetID))" Variant="Variant.Text" Color="@ewaycolor">Eway Bill</MudButton>
                <MudButton @onclick="@(() => Delete(item.GcSetID))" Color="Color.Primary" Disabled="@(item.TripID!= null)">DELETE</MudButton>
            }
            @if (unloading)
            {
                <MudTooltip Text="Upload Acknowledgement">
                    <MyFileUpload FolderName="Gc/Acknowledgement" FileName="@Guid.NewGuid().ToString()" Label="Acknowledgement" @bind-FilePath="@item.Acknowledgement"></MyFileUpload>
                </MudTooltip>
            }
        </MudCardActions>
    </MudCard>
</div>

@code {

    [Parameter]
    public int? MessageDocumentID { get; set; } = null;
    [Parameter]
    public GcSetModel item { get; set; }
    [Parameter]
    public string Class { get; set; }
    [Parameter]
    public bool IsLocked { get; set; } = false;
    [Parameter]
    public string Style { get; set; }
    [Parameter]
    public bool IsLoading { get; set; } = false;
    [Parameter]
    public bool unloading { get; set; } = false;
    [Parameter]
    public EventCallback<long?> OnGcRemoved { get; set; }
    [Parameter]
    public EventCallback<long?> OnGcDeleted { get; set; }



    private Color ewaycolor = new();
    private Color FillExpColor = new();
    private string UserID;

    private bool _busy;
    public bool HasPermissionGcServiceEdit { get; set; } = false;
    public bool HasPermissionGcServiceAppentToTrip { get; set; } = false;
    public int DocTypeID = 46;

    protected override async Task OnInitializedAsync()
    {
        CancellationTokenSource ctc = new CancellationTokenSource();

        var authState = await auth.GetAuthenticationStateAsync();
        UserID = authState.User.Identity.Name;

        HasPermissionGcServiceEdit = await Irole.HasClaim(DocTypeID.ToString(), "Edit", ctc.Token);
        HasPermissionGcServiceAppentToTrip = await Irole.HasClaim(DocTypeID.ToString(), "AppentToTrip", ctc.Token);
        if (MessageDocumentID != null)
        {
            await EwayBill(item.GcSetID);
        }

    }

    protected override void OnParametersSet()
    {
        setEwayBillColor();
        if (item.UnloadEndEventID != null)
        { IsLocked = true; }
    }

    private void setEwayBillColor()
    {
        if (item.Gcs.Exists(x => x.EwayBill.ExpireOn == null || x.EwayBill?.ExpireOn < DateTime.Now))
        {
            ewaycolor = Color.Error;
        }
        else
        {
            ewaycolor = Color.Primary;
        }
    }

    private void setExpButtonColor()
    {
        FillExpColor = Color.Tertiary;
    }

    private async Task EwayBill(long? id)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        _busy = true;
        var parameters = new DialogParameters();
        item.Gcs.ForEach(x => { x.EwayBill.EwayBillDate = x.EwayBill.EwayBillDate ?? DateTime.Today; x.EwayBill.ExpireOn = x.EwayBill.ExpireOn ?? DateTime.Today.AddDays(2); });
        parameters.Add("MessageDocumentID", MessageDocumentID);
        parameters.Add("model", item.Clone());
        var result = DialogService.Show<EwayBillDialog>("EwayBill", parameters);
        var data = await result.Result;
        if (!data.Canceled)
        {
            if (data.Data != null)
            {
                item = (GcSetModel)data.Data;
                setEwayBillColor();
            }
        }
        await Task.Delay(200);
        _busy = false;
    }


    private async Task Delete(long? id)
    {
        bool? result = await DialogService.ShowMessageBox(
           "Warning",
           "Are You Sure you want to Delete this GC!",
           yesText: "Delete!", cancelText: "Cancel");

        if (result != null && result.Value)
        {
            try
            {
                Iservice.DeleteSet(id, UserID);
                await OnGcDeleted.InvokeAsync(id);
            }
            catch (Exception ex)
            {
                snackbar.Add(ex.Message, Severity.Error);
            }
        }

    }

    private async Task Edit(long? id)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        _busy = true;
        if (HasPermissionGcServiceEdit)
        {
            var parameters = new DialogParameters();
            parameters.Add("model", item.Clone());
            DialogOptions maxWidth = new DialogOptions() { MaxWidth = MaxWidth.Large, FullWidth = true };
            var result = DialogService.Show<GcDialog>("Edit GC", parameters, maxWidth);
            var data = await result.Result;
            if (!data.Canceled)
            {
                if (data.Data != null)
                {
                    item = (GcSetModel)data.Data;                   
                }
            }
            StateHasChanged();
        }
        else
        {
            bool? ResultModel = await DialogService.ShowMessageBox(
                "Permission denied!",
                "You dont have any permission to Add or Edit GC.");
        }
        await Task.Delay(200);
        _busy = false;
    }

    private async Task RemoveButtonClicked(long? id)
    {
        if (HasPermissionGcServiceAppentToTrip)
        {
            var e = await auth.GetAuthenticationStateAsync();
            var user = e.User;
            var userID = user.Identity.Name;
            Iservice.RemoveFromTrip(item.GcSetID, item.TripID.Value, userID);
            snackbar.Add("Removed", Severity.Success, null);
            await OnGcRemoved.InvokeAsync(id);
        }
        else
        {
            bool? ResultModel = await DialogService.ShowMessageBox(
                "Permission denied!",
                "You dont have any permission to AppendToTrip GC.");
        }
    }
}