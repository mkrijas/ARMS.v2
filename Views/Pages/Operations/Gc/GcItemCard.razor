@using System.Threading;
@using Core.BaseModels.Finance.Transactions;
@inject AuthenticationStateProvider auth
@inject IDialogService DialogService
@inject IGcService Iservice
@inject ITripService tripService;
@inject MudBlazor.ISnackbar snackbar
@inject IRoleService<RoleModel> Irole
@* @using Views.Shared; *@

<div class="gc-item-card-wrapper pa-1">
    <MudCard Class="@($"gc-mockup-card {Class}")" Elevation="0" Style="position: relative;">
        @if (item.UnloadEndEventID != null)
        {
            <div style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; pointer-events: none; z-index: 10; overflow: hidden; background-color: rgba(255,255,255,0.2);">
                <div class="stamp is-Delivered">
                    <div class="icon-box">
                        <MudIcon Icon="@Icons.Material.Filled.Check" Size="Size.Large" />
                    </div>
                    <div class="text-box"> <b>DELIVERED</b></div>
                </div>
            </div>
        }
        
        <div class="pa-4 d-flex align-start">
            <MudAvatar Class="gc-avatar mr-4" Size="Size.Large">GC</MudAvatar>
            <div class="d-flex flex-column" style="margin-top: 2px;">
                <div class="gc-title mb-1">@item.SetGcNumber</div>
                <div class="gc-subtitle">Bill No: @item.SetBillNumber</div>
            </div>
        </div>
        
        <div class="px-5 pb-0">
            <MudGrid Spacing="2">
                <MudItem xs="6">
                    <div class="info-pane h-100 pb-2">
                        <div class="d-flex align-start mb-1">
                            <MudIcon Icon="@Icons.Material.Outlined.Storefront" Size="Size.Small" Style="color: #64748b; margin-top: 2px;" Class="mr-2" />
                            <div>
                                <div class="box-label">CONSIGNOR</div>
                                <div class="box-value">@item?.ConsignorName</div>
                            </div>
                        </div>
                        <div class="d-flex align-center my-2" style="padding-left: 2px;">
                            <MudIcon Icon="@Icons.Material.Filled.ArrowDownward" Size="Size.Small" Style="color: #cbd5e1;" />
                        </div>
                        <div class="d-flex align-start">
                            <MudIcon Icon="@Icons.Material.Outlined.Domain" Size="Size.Small" Style="color: #64748b; margin-top: 2px;" Class="mr-2" />
                            <div>
                                <div class="box-label">CONSIGNEE</div>
                                <div class="box-value">@item?.ConsigneeName</div>
                            </div>
                        </div>
                    </div>
                </MudItem>
                <MudItem xs="6">
                    <div class="info-pane h-100 d-flex flex-column justify-center pl-4">
                        <div class="d-flex align-center mb-4">
                            <div class="orange-circle mr-3">
                                <MudIcon Icon="@Icons.Material.Filled.Inventory2" Style="color: #f97316;" Size="Size.Medium" />
                            </div>
                            <div>
                                <div class="value-large">@item.TotalBillQuantity<span class="value-unit ml-1">@item.UoM</span></div>
                                <div class="box-value text-muted mt-n1" style="font-weight: 600; font-size: 0.8rem;">@item.Content</div>
                            </div>
                        </div>
                        <div class="d-flex align-center mt-2">
                            <MudIcon Icon="@Icons.Material.Filled.Payments" Style="color: #10b981;" Size="Size.Small" Class="mr-2" />
                            <div class="value-success">₹ @item.TotalFreight</div>
                        </div>
                    </div>
                </MudItem>
                <MudItem xs="12">
                     <div class="route-pane mt-1">
                         <MudIcon Icon="@Icons.Material.Rounded.Route" Style="color: #f97316;" Size="Size.Small" Class="mr-3" />
                         <div class="route-text">@item?.RouteName</div>
                     </div>
                </MudItem>
                
                @if (unloading)
                {
                    <MudItem xs="12">
                        <MudDivider Class="my-2" Style="border-color: rgba(0,0,0,0.05);" />
                        <MudGrid Spacing="2">
                            <MudItem xs="6">
                                <MudTextField @bind-Value="@item.TotalUnloadingQuantity" Label="Qty" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => @item.TotalUnloadingQuantity)"></MudTextField>
                            </MudItem>
                            <MudItem xs="6">
                                <MudTextField @bind-Value="@item.PONo" Label="PO No" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => @item.PONo)"></MudTextField>
                            </MudItem>
                        </MudGrid>

                        @if (!string.IsNullOrEmpty(item.Acknowledgement))
                        {
                            <div class="d-flex align-center mt-3 justify-center">
                                <a href="@item.Acknowledgement" download="Acknowledgement" style="text-decoration:none;">
                                    <MudChip T="string" Icon="@Icons.Material.Filled.Download" Color="Color.Success" Size="Size.Small" Label="true">Ack</MudChip>
                                </a>
                            </div>
                        }
                    </MudItem>
                }
            </MudGrid>
        </div>
        
        <div class="px-5 py-4 mt-2 d-flex justify-end align-center gap-3">
            @if (!unloading)
            {
                <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" @onclick="@(() => Edit(item.GcSetID))" Style="color: #000;" Disabled="@IsLocked" />
                <MudIconButton Icon="@Icons.Material.Filled.Receipt" Size="Size.Small" @onclick="@(() => EwayBill(item.GcSetID))" Style="color: #000;" />
                <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" @onclick="@(() => Delete(item.GcSetID))" Style="color: #ef4444;" Disabled="@(item.TripID != null)" />
                <MudIconButton Icon="@Icons.Material.Filled.Print" Size="Size.Small" @onclick="@(() => Print(item.GcSetID))" Style="color: #000;" />
            }
            @if (unloading)
            {
                <MudTooltip Text="Upload Proof of Delivery (Ack Document)" Placement="Placement.Top">
                    <MyFileUpload FolderName="Gc/Acknowledgement" FileName="@Guid.NewGuid().ToString()" Label="Upload POD" @bind-FilePath="@item.Acknowledgement" Style="width: 140px;"></MyFileUpload>
                </MudTooltip>
                <MudTooltip Text="Confirm Delivery & Acknowledgement" Placement="Placement.Top">
                    <MudIconButton Icon="@Icons.Material.Filled.Verified" Color="Color.Success" @onclick="@(() => OpenConfirmAcknowledgement(item.GcSetID))" />
                </MudTooltip>
                <MudTooltip Text="Report Material Shortage or Damage" Placement="Placement.Top">
                    <MudIconButton Icon="@Icons.Material.Filled.ReportProblem" Color="Color.Error" @onclick="@(() => OpenShortageDamageCompensation())" />
                </MudTooltip>
            }
        </div>
    </MudCard>
</div>

@code {

    [Parameter]
    public int? MessageDocumentID { get; set; } = null;
    [Parameter]
    public GcSetModel item { get; set; }
    [Parameter]
    public string Class { get; set; }
    [Parameter]
    public bool IsLocked { get; set; } = false;
    [Parameter]
    public string Style { get; set; }
    [Parameter]
    public bool IsLoading { get; set; } = false;
    [Parameter]
    public bool unloading { get; set; } = false;
    [Parameter]
    public EventCallback<long?> OnGcRemoved { get; set; }
    [Parameter]
    public EventCallback<long?> OnGcDeleted { get; set; }

    public string ReportName { get; set; }
    public Dictionary<string, string> ReportParameters { get; set; } = new();

    private Color ewaycolor = new();
    private Color FillExpColor = new();
    private string UserID;

    private bool _busy;
    public bool HasPermissionGcServiceEdit { get; set; } = false;
    public bool HasPermissionGcServiceAppentToTrip { get; set; } = false;
    public int DocTypeID = 46;

    // Method called when the component is initialized
    protected override async Task OnInitializedAsync()
    {
        CancellationTokenSource ctc = new CancellationTokenSource();

        var authState = await auth.GetAuthenticationStateAsync();
        UserID = authState.User.Identity.Name;

        HasPermissionGcServiceEdit = await Irole.HasClaim(DocTypeID.ToString(), "Edit", ctc.Token);
        HasPermissionGcServiceAppentToTrip = await Irole.HasClaim(DocTypeID.ToString(), "AppentToTrip", ctc.Token);
        if (MessageDocumentID != null)
        {
            await EwayBill(item.GcSetID);
        }
    }


    protected override void OnParametersSet()
    {
        setEwayBillColor();
        // if (item.UnloadEndEventID != null)
        // { IsLocked = true; }
    }

    // Method to set the color of the EwayBill based on its expiration statusc
    private void setEwayBillColor()
    {
        if (item.Gcs.Exists(x => x.EwayBill.ExpireOn == null || x.EwayBill?.ExpireOn < DateTime.Now))
        {
            ewaycolor = Color.Error;
        }
        else
        {
            ewaycolor = Color.Primary;
        }
    }

    // Method to set the color for the expiration button
    private void setExpButtonColor()
    {
        FillExpColor = Color.Tertiary;
    }

    // Method to open the EwayBill dialog
    private async Task EwayBill(long? id)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        _busy = true;
        var parameters = new DialogParameters();
        item.Gcs.ForEach(x => { x.EwayBill.EwayBillDate = x.EwayBill.EwayBillDate ?? DateTime.Today; x.EwayBill.ExpireOn = x.EwayBill.ExpireOn ?? DateTime.Today.AddDays(2); });
        parameters.Add("MessageDocumentID", MessageDocumentID);
        parameters.Add("model", item.Clone());
        var dialog = await DialogService.ShowAsync<EwayBillDialog>("EwayBill", parameters);
        var Result = await dialog.Result;
        if (!Result.Canceled)
        {   
            if (Result.Data != null)
            {
                item = (GcSetModel)Result.Data;
                setEwayBillColor();
            }
        }
        await Task.Delay(200);
        _busy = false;
    }

    // Method to print the consignment note bill
    private async Task Print(long? GcSetID)
    {
        ReportParameters.Clear();
        ReportParameters.Add("GcSetID", GcSetID.ToString());
        var parameters = new DialogParameters();
        parameters.Add("Parameters", ReportParameters); // Add the dictionary as a parameter
        parameters.Add("ReportName", "PrintConsignmentNoteBill");

        DialogOptions maxWidth = new DialogOptions() { MaxWidth = MaxWidth.Medium, FullWidth = true };
        var result = await DialogService.ShowAsync<PrintDialog>("PRINT", parameters, maxWidth);
    }

    // Method to delete a GC
    private async Task Delete(long? id)
    {
        bool? result = await DialogService.ShowMessageBoxAsync(
           "Warning",
           "Are You Sure you want to Delete this GC!",
           yesText: "Delete!", cancelText: "Cancel");

        if (result != null && result.Value)
        {
            try
            {
                Iservice.DeleteSet(id, UserID); // Call the service to delete the GC
                await OnGcDeleted.InvokeAsync(id);
            }
            catch (Exception ex)
            {
                snackbar.Add(ex.Message, Severity.Error);
            }
        }
    }

    // Method to edit a GC
    private async Task Edit(long? id)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        _busy = true;
        if (HasPermissionGcServiceEdit)
        {
            var parameters = new DialogParameters();
            parameters.Add("model", item.Clone());
            DialogOptions maxWidth = new DialogOptions() { MaxWidth = MaxWidth.Large, FullWidth = true };
            var result = await DialogService.ShowAsync<GcDialog>("Edit GC", parameters, maxWidth);
            var data = await result.Result;
            if (!data.Canceled)
            {
                if (data.Data != null)
                {
                    item = Iservice.SelectByID(id); // Update the item with the selected data
                }
            }
            StateHasChanged();
        }
        else
        {
            bool? ResultModel = await DialogService.ShowMessageBoxAsync(
                "Permission denied!",
                "You don't have any permission to Add or Edit GC.");
        }
        await Task.Delay(200);
        _busy = false;
    }

    // Method to handle the removal of a GC from a trip
    private async Task RemoveButtonClicked(long? id)
    {
        if (HasPermissionGcServiceAppentToTrip)
        {
            var e = await auth.GetAuthenticationStateAsync();
            var user = e.User;
            var userID = user.Identity.Name;

            // Call the service to remove the GC
            Iservice.RemoveFromTrip(item.GcSetID, item.TripID.Value, userID);
            snackbar.Add("Removed", Severity.Success, null);
            await OnGcRemoved.InvokeAsync(id);
        }
        else
        {
            bool? ResultModel = await DialogService.ShowMessageBoxAsync(
                "Permission denied!",
                "You don't have any permission to AppendToTrip GC.");
        }
    }

    // Method to open the shortage/damage compensation dialog
    private async Task OpenShortageDamageCompensation(ShortageDamageCompensationModel sdcModel = null)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        _busy = true;

        // Fetch trip information
        var info = tripService.Select(item.TripID);
        DialogParameters parms = new DialogParameters();
        DialogOptions maxWidth = new DialogOptions() { MaxWidth = MaxWidth.Medium, FullWidth = true, CloseButton = true, CloseOnEscapeKey = true };
        if (sdcModel == null)
        {
            sdcModel = new ShortageDamageCompensationModel()
            {
                TripID = item.TripID,
                DriverID = info.DriverID,
                GcSetID = item.GcSetID,
                SetGcNumber = item.SetGcNumber
            };
        }
        else
        {
            parms.Add("ReadOnly", true);
        }
        parms.Add("model", sdcModel.Clone());
        var dialog = await DialogService.ShowAsync<Finance.Transactions.ShortageDamageCompensationDialog>("ADD", parms, maxWidth);
        var result = await dialog.Result;
        await Task.Delay(200);
        _busy = false;
    }

    // Method to open the confirmation dialog for acknowledgment
    private async Task OpenConfirmAcknowledgement(long? GcSetID)
    {
        DialogParameters parms = new DialogParameters();
        DialogOptions maxWidth = new DialogOptions() { MaxWidth = MaxWidth.Small };
        parms.Add("GcSetID", GcSetID);
        var dialog = await DialogService.ShowAsync<GcConfirmAcknowledgement>("Confirm Acknowledgement", parms, maxWidth);
        var result = await dialog.Result;
        await Task.Delay(200);
        _busy = false;
    }

}
