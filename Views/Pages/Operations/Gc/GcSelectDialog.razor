@using System.Threading;
@inject AuthenticationStateProvider auth
@inject IGcService Iservice
@inject IRouteService Iroute
@inject IOrderService Iorder
@inject IDialogService DialogService
@inject MudBlazor.ISnackbar snackbar
@inject IRoleService<RoleModel> Irole

<DialogForm @ref="@dialogForm" Title="Consignment Selection Manifest" Subtitle="Select and authorize pending Goods Consignments for immediate vehicle deployment." Icon="@Icons.Material.Filled.Inventory" AdminStyle="true" formID="formGcSelect" model="@collection" _busy="_busy">
    <FormContent>
        <div class="dialog-content-wrapper">
            <div class="d-flex align-center justify-space-between mb-4">
                <div class="d-flex align-center gap-4">
                    <div class="admin-badge primary px-4 py-2 rounded-pill">
                        <MudIcon Icon="@Icons.Material.Filled.LocalShipping" Size="Size.Small" Class="mr-2" />
                        <span class="fw-600">@Truck.RegNo</span>
                    </div>
                </div>
                <MudTooltip Text="Generate New Consignment">
                    <MudIconButton Icon="@Icons.Material.Filled.AddCircle" Color="Color.Primary" Variant="Variant.Filled" OnClick="@Add" Size="Size.Medium" Class="shadow-sm" />
                </MudTooltip>
            </div>
            <div class="admin-glass-card pa-6 dc">
                <div class="d-flex align-center justify-space-between mb-6">
                    <div class="d-flex align-center">
                        <MudIcon Icon="@Icons.Material.Filled.FilterList" Color="Color.Primary" Class="mr-2" />
                        <span class="admin-section-label mb-0">Unassigned Consignments (@collection.Count)</span>
                    </div>
                    <div class="selection-status px-4 py-1 rounded-pill" style="background: rgba(var(--mud-palette-success-rgb), 0.1); border: 1px solid var(--mud-palette-success);">
                        <MudText Typo="Typo.caption" Color="Color.Success" Class="fw-600">Selected: @collection.Count(x => x.Selected)</MudText>
                    </div>
                </div>
                
                <MudGrid Spacing="3">
                    @foreach (var row in collection)
                    {
                        var bgClass = row.Selected ? "gc-card-selected" : "gc-card-standard";
                        var item = row.model;

                        <MudItem xs="12" md="12" lg="6" xl="4">
                            <div @onclick="@(()=> row.Selected = !row.Selected)" @ondblclick="@(()=> dblClickHandler(item))" class="gc-card-wrapper cursor-pointer transition-all">
                                <GcItemCard item="row.model" Class="@bgClass" OnGcDeleted="Deleted"></GcItemCard>
                            </div>
                        </MudItem>
                    }
                </MudGrid>
            </div>
        </div>
    </FormContent>
    <Actions>
        @{
            SelectedCount = collection.Count(x => x.Selected == true); var disabled = SelectedCount == 0;
        }
        <div class="d-flex gap-4">
            <MudButton OnClick="Load" Variant="Variant.Filled" Color="Color.Success" Disabled="@disabled" StartIcon="@Icons.Material.Filled.FileDownload" Class="px-12 rounded-pill py-3 shadow-none">Commit Selection</MudButton>
        </div>
    </Actions>
</DialogForm>

<style>
    .gc-card-selected {
        border: 2px solid var(--mud-palette-primary) !important;
        background: rgba(var(--mud-palette-primary-rgb), 0.05) !important;
        transform: translateY(-2px);
        box-shadow: var(--mud-elevation-4);
    }

    .gc-card-standard {
        border: 1px solid var(--mud-palette-divider) !important;
        transition: all 0.2s ease;
    }

    .gc-card-standard:hover {
        border-color: var(--mud-palette-primary-lighten) !important;
        background: var(--mud-palette-background-grey) !important;
    }

    .dc {
        min-height: 50vh;
        max-height: 65vh;
        overflow-y: auto;
    }
</style>

@code {
    DialogForm dialogForm;
    private bool _busy;
    [Parameter] public TruckModel Truck { get; set; }
    [Parameter] public long TripID { get; set; }
    private int BranchID { get; set; }
    private int SelectedCount = 0;
    private List<SelectableCollection<GcSetModel>> collection = new();

    public bool HasPermissionGcServiceEdit { get; set; } = false;
    public bool HasPermissionGcServiceAppentToTrip { get; set; } = false;
    public int DocTypeID = 46;

    private void Cancel()
    {
        dialogForm.Cancel();
    }

    // Method called when the component is initialized
    protected override async Task OnInitializedAsync()
    {
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionGcServiceEdit = await Irole.HasClaim(DocTypeID.ToString(), "Edit", ctc.Token);
        HasPermissionGcServiceAppentToTrip = await Irole.HasClaim(DocTypeID.ToString(), "AppentToTrip", ctc.Token);

        await GetAll();
    }

    // Method to fetch all unassigned GcSetModels
    private async Task GetAll()
    {
        var e = await auth.GetAuthenticationStateAsync();
        string BranchIDString = e.User.Claims.First(x => x.Type == "BranchID").Value;
        BranchID = int.Parse(BranchIDString);
        collection.Clear();

        // Fetch unassigned GcSetModels
        foreach (var item in Iservice.SelectUnAssigned(BranchID))
        {
            collection.Add(new() { model = item });
        }
    }

    // Method to handle double-click on a GcSetModel
    protected async Task dblClickHandler(GcSetModel item)
    {
        if (HasPermissionGcServiceAppentToTrip)
        {
            var e = await auth.GetAuthenticationStateAsync();
            var user = e.User;
            var userID = user.Identity.Name;
            if (item.Gcs.Any(y => DateTime.Compare(DateTime.Now, (y.EwayBill?.ExpireOn) ?? DateTime.MinValue) > 0))
            {
                await DialogService.ShowMessageBoxAsync("EWAY BILL MISSING!","No Valid Ewaybill found!.");
                return;
            }           
                // Append the GcSetModel to the trip
                Iservice.AppendToTrip(TripID, item.GcSetID, userID);
                dialogForm.Close(DialogResult.Ok("Appended"));
                snackbar.Add("Loaded", Severity.Success, null);
            
        }
        else
        {
            bool? ResultModel = await DialogService.ShowMessageBoxAsync(
                "Permission denied!",
                "You don't have any permission to AppendToTrip GC.");
        }
    }

    // Method to handle deletion of a GcSetModel
    void Deleted(long? id)
    {
        collection.Remove(collection.First(x => x.model.GcSetID == id));
    }

    // Method to load selected GcSetModels
    private async Task Load()
    {
        if (HasPermissionGcServiceAppentToTrip)
        {

            if (collection.Where(x => x.Selected).Any())
            {
                var e = await auth.GetAuthenticationStateAsync();
                var user = e.User;
                var userID = user.Identity.Name;
                foreach (var item in collection.Where(x => x.Selected))
                {
                    if (item.model.Gcs.Any(y => DateTime.Compare(DateTime.Now, (y.EwayBill?.ExpireOn) ?? DateTime.MinValue) > 0))
                    {
                        await DialogService.ShowMessageBoxAsync("EWAY BILL MISSING!", "No Valid Ewaybill found!.");
                        return;
                    }

                    int result = Iservice.AppendToTrip(TripID, item.model.GcSetID, userID);
                }

                dialogForm.Close(DialogResult.Ok("Appended"));
            }
            else
            {
                bool? ResultModel = await DialogService.ShowMessageBoxAsync(
                "None Selected!",
                "Please select a consignment to load!.");
            }
        }
        else
        {
            bool? ResultModel = await DialogService.ShowMessageBoxAsync(
                "Permission denied!",
                "You don't have any permission to AppendToTrip GC.");
        }
    }

    class SelectableCollection<T>
    {
        public bool Selected { get; set; } = false;
        public T model { get; set; }
    }

    // Method to add a new GcSetModel
    private async Task Add()
    {
        if (HasPermissionGcServiceEdit)
        {
            var parameters = new DialogParameters();
            parameters.Add("model", new GcSetModel() { BranchID = BranchID });
            DialogOptions maxWidth = new DialogOptions() { MaxWidth = MaxWidth.Medium, FullWidth = true };
            var dialog = await DialogService.ShowAsync<GcDialog>("Create New GC", parameters, maxWidth);
            var result = await dialog.Result;
            if (!result.Canceled)
            {
                await GetAll();
            }
        }
        else
        {
            bool? ResultModel = await DialogService.ShowMessageBoxAsync(
                "Permission denied!",
                "You don't have any permission to Add or Edit GC.");
        }
    }
}
