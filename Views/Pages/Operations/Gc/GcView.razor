@page "/gc"
@page "/gc/{id:int}"
@inject IGcService Iservice
@inject IRouteService Iroute
@inject IOrderService Iorder
@inject IDialogService DialogService
@inject MudBlazor.ISnackbar snackbar
@attribute [Authorize]
@inject AuthenticationStateProvider auth
@inject NavigationManager UriHelper
@using System.Threading;
@inject IRoleService<RoleModel> Irole

<MudText Typo="Typo.h5" GutterBottom="true">
    UNASSIGNED CONSIGNMENTS
    <MudIconButton Icon="@Icons.Material.Filled.Add" Title="Add" @onclick="@Add" Color="Color.Dark" Size="Size.Medium"></MudIconButton>
</MudText>
<MudGrid>
    @foreach (var item in collection)
    {
        <MudItem xs="12" md="4" xl="3">
            <GcItemCard item="item" MessageDocumentID="id"></GcItemCard>
        </MudItem>
    }
</MudGrid>

@code {

    private int BranchID;
    private List<GcSetModel> collection = new();
    [Parameter]
    public int? id { get; set; } = null;

    private string searchString = "";

    public bool HasPermissionGcServiceEdit { get; set; } = false;
    public bool HasPermissionGCServiceDelete { get; set; } = false;
    public int DocTypeID = 46;

    protected override async Task OnInitializedAsync()
    {
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionGcServiceEdit = await Irole.HasClaim(DocTypeID.ToString(), "Edit", ctc.Token);
        HasPermissionGCServiceDelete = await Irole.HasClaim(DocTypeID.ToString(), "Delete", ctc.Token);

        var e = await auth.GetAuthenticationStateAsync();
        string BranchIDString = e.User.Claims.First(x => x.Type == "BranchID").Value;
        BranchID = int.Parse(BranchIDString);

        GetAll(BranchID);
    }

    private void GetAll(int BranchID)
    {
        var collectionResult = Iservice.SelectUnAssigned(BranchID);
        if (id != null && collectionResult != null && collectionResult.Any(g => g.Gcs != null && g.Gcs.Any(d => d.EwayBill != null && d.EwayBill.GcID == id)))
        {
            collection = collectionResult.Where(g => g.Gcs != null && g.Gcs.Any(d => d.EwayBill != null && d.EwayBill.GcID == id)).ToList();
        }
        else
        {
            collection = collectionResult.ToList();
        }
    }

    private async Task Add()
    {
        if (HasPermissionGcServiceEdit)
        {
            var parameters = new DialogParameters();
            parameters.Add("model", new GcSetModel() { BranchID = BranchID });
            DialogOptions maxWidth = new DialogOptions() { MaxWidth = MaxWidth.Medium, FullWidth = true };
            var result = DialogService.Show<GcDialog>("Create New GC", parameters, maxWidth);
            var data = await result.Result;
            GetAll(BranchID);
        }
        else
        {
            bool? ResultModel = await DialogService.ShowMessageBox(
                "Permission denied!",
                "You dont have any permission to Add or Edit GC.");
        }
    }

    private async Task Delete(long? id)
    {
        if (HasPermissionGCServiceDelete)
        {
            bool? result = await DialogService.ShowMessageBox(
                "Warning !",
                "Are you sure, you want to delete ?");
            if (result == true)
            {
                var authprov = await auth.GetAuthenticationStateAsync();
                var user = authprov.User;
                Iservice.Delete(id, user.Identity.Name);
                snackbar.Add("Deleted Successfully", Severity.Success);
            }
            GetAll(BranchID);
        }
        else
        {
            bool? result = await DialogService.ShowMessageBox(
                "Permission denied!",
                "You dont have any permission to Delete GC.");
        }
    }

    private bool search(GcSetModel model)
    {
        if (model.SetBillNumber != null && model.SetBillNumber.Contains(searchString, StringComparison.OrdinalIgnoreCase))
        {
            return true;
        }
        return false;
    }
}