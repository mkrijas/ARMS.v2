    void Deleted(long? id)
    {
        collection.Remove(collection.First(x => x.GcSetID == id));
    }

    private bool search(GcSetModel model)
    {
        if (model.SetBillNumber != null && model.SetBillNumber.Contains(searchString, StringComparison.OrdinalIgnoreCase))
        {
            return true;
        }
        return false;
    }
}