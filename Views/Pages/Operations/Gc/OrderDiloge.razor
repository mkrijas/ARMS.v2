@inject IContentService Icontent
@inject IOrderService Iservice
@inject MudBlazor.ISnackbar snackbar

<MudDialog Class="admin-dialog-glass">
    <TitleContent>
        <div class="header-section mb-2 pt-4 px-4">
            <div class="d-flex align-center justify-space-between">
                <div class="d-flex align-center">
                    <div class="icon-badge primary-badge mr-4">
                        <div class="admin-header-icon-badge mb-3">
                            <MudIcon Icon="@Icons.Material.Filled.ShoppingCart" Color="Color.Secondary" Style="font-size: 3rem;" />
                        </div>
                    </div>
                    <div>
                        <MudText Typo="Typo.h5" Class="admin-title"><b>Order Configuration</b></MudText>
                        <MudText Typo="Typo.body2" Class="admin-subtitle">Create or edit customer orders and manage content details.</MudText>
                    </div>
                </div>
            </div>
            <div class="title-accent mt-4"></div>
        </div>
    </TitleContent>
    <DialogContent>
        <MudContainer Class="admin-dialog-container">
            <div class="dialog-content-wrapper pa-4">
                <EditForm id="orderForm" Model="@model" OnValidSubmit="OnValidSubmit">
                    <ObjectGraphDataAnnotationsValidator />
                    <MudValidationSummary />
                    <div class="admin-glass-card pa-6">
                        <MudGrid Spacing="3">
                            <MudItem xs="12">
                                <MudTextField @bind-Value="model.OrderName" Label="Order Title" Variant="Variant.Outlined" Margin="Margin.Normal" For="@(() => model.OrderName)" Class="modern-input"></MudTextField>
                            </MudItem>
                            <MudItem xs="12">
                                 <PartySelector For="@(() => model.Party)" @bind-Value="model.Party" NatureOfBusiness="Customer" IncludeSisterConcern Class="modern-input"></PartySelector>
                            </MudItem>
                            <MudItem xs="12" md="6">
                                <MudSelect For="@(() => model.ContentID)" Label="Content" T="short?" Value="@model.ContentID" ValueChanged="SetContentObject" Variant="Variant.Outlined" Margin="Margin.Normal" AdornmentColor="Color.Secondary" Class="modern-input">
                                    @foreach (var item in contents)
                                    {
                                        <MudSelectItem Value="@item.ContentID">@item.ContentName</MudSelectItem>
                                    }
                                </MudSelect>
                            </MudItem>
                            <MudItem xs="12" md="6">
                                <MudTextField @bind-Value="model.Declaration" Label="Declaration" Variant="Variant.Outlined" Margin="Margin.Normal" For="@(() => model.Declaration)" Class="modern-input"></MudTextField>
                            </MudItem>
                            <MudItem xs="12" md="6" Class="d-flex align-center">
                                <MudCheckBox T="bool" @bind-Value="model.IsLimitedQuantity" Color="Color.Primary" Label="Limited Quantity"></MudCheckBox>
                            </MudItem>
                            @if (model.IsLimitedQuantity)
                            {
                                <MudItem xs="12" md="6">
                                    <MudTextField @bind-Value="model.OrderQuantity" Label="Order Quantity" Variant="Variant.Outlined" Margin="Margin.Normal" For="@(() => model.OrderQuantity)" Adornment="Adornment.End" AdornmentText="@model?.Content?.PrimaryUnit" AdornmentColor="Color.Dark" Class="modern-input"></MudTextField>
                                </MudItem>
                            }
                        </MudGrid>
                    </div>
                </EditForm>
            </div>
        </MudContainer>
    </DialogContent>
    <DialogActions>
        <div class="d-flex w-100 flex-wrap pa-4 gap-3 align-center">
            <MudSpacer />
            <MudButton @onclick="Cancel" Variant="Variant.Outlined" Color="Color.Default" Style="border-radius: 12px; font-weight: 700; text-transform: none; border-color: rgba(0,0,0,0.15);">Discard</MudButton>
            <MudButton Disabled="@_busy" form="orderForm" Variant="Variant.Filled" Color="Color.Success" ButtonType="ButtonType.Submit" Style="background: var(--mud-palette-success); color: white; font-weight: 800; border-radius: 12px; text-transform: none; white-space: nowrap; padding: 8px 24px;" StartIcon="@Icons.Material.Filled.Save">Initiate Order</MudButton>
        </div>
    </DialogActions>
</MudDialog>

@code {

    [CascadingParameter] IMudDialogInstance MudDialog { get; set; }
    [Parameter]
    public OrderModel model { get; set; }
    private List<OrderModel> collection = new List<OrderModel>();
    private List<ContentModel> contents = new List<ContentModel>();
    private string searchString = "";
    private string unit = "";
    private bool _busy;

    // Method called when the component is initialized
    protected override async Task OnInitializedAsync()
    {
        // Fetch all content items
        await foreach (var item in Icontent.Select(0))
        {
            contents.Add(item);
        }
        await GetAll();
        if (model != null)
            SetContentObject(model.ContentID);
    }

    // Method to search for contents based on the search string
    private async Task<IEnumerable<ContentModel>> Search(string searchString)
    {
        return await Task.FromResult(
            contents.Where(x => x.ContentName.Contains(searchString == null ? string.Empty : searchString, StringComparison.InvariantCultureIgnoreCase)));
    }

    // Method to fetch all OrderModels
    private async Task GetAll()
    {
        await foreach (var item in Iservice.Select(0))
        {
            collection.Add(item);
        }
    }

    // Method to set the content object
    private void SetContentObject(short? ContentID)
    {
        model.ContentID = ContentID;
        if (contents != null && contents.Any(s => s.ContentID == ContentID))
            model.Content = contents.FirstOrDefault(s => s.ContentID == ContentID);
    }

    // Method called when the form is submitted successfully
    private async Task OnValidSubmit(EditContext context)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is being submitted!", Severity.Warning);
            return;
        }
        if (model.Party == null || model.Party.PartyID == 0)
        {
            snackbar.Add("Client is not selected", Severity.Error);
            return;
        }
        if (!model.IsLimitedQuantity)
        {
            model.OrderQuantity = 0;
        }
        else
        {
            var isValid = context.Validate();
            if (!isValid)
            {
                return;
            }
        }
        _busy = true;
        model.ClientID = model.Party.PartyID;
        MudDialog.Close(DialogResult.Ok(model));
        await Task.Delay(200);
        _busy = false;
    }

    private void Cancel()
    {
        MudDialog.Cancel();
    }
}
