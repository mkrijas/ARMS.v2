@attribute [Authorize]
@inject AuthenticationStateProvider auth
@inject NavigationManager UriHelper
@using System.Threading;
@inject IOrderService Iservice
@inject IContentService Icontent
@inject IPartyService Iparty
@inject IRoleService<RoleModel> Irole
@inject IDialogService DialogService
@inject MudBlazor.ISnackbar snackbar

<MudDialog>
    <TitleContent>
        <h3>Order</h3>
    </TitleContent>
    <DialogContent>
        <EditForm id="orderForm" Model="@model" OnValidSubmit="OnValidSubmit">
            <ObjectGraphDataAnnotationsValidator />
            <ValidationSummary />
            <MudGrid>
                <MudItem xs="12" md="12">
                    <MudTextField @bind-Value="model.OrderName" Label="Order Title" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.OrderName)"></MudTextField>
                </MudItem>
                <MudItem xs="12" md="12">
                    <PartySelector @bind-Value="model.Party" NatureOfBusiness="Customer" ></PartySelector>
                </MudItem>
                <MudItem xs="12" md="12">
                    <MudSelect Label="Content" T="short?" Value="@model.ContentID" ValueChanged="SetContentObject" Variant="Variant.Outlined" Margin="Margin.Dense" OffsetY="true" AdornmentColor="Color.Secondary">
                        @foreach (var item in contents)
                        {
                            <MudSelectItem Value="@item.ContentID">@item.ContentName</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" md="12">
                    <MudTextField @bind-Value="model.Declaration" Label="Declaration" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.Declaration)"></MudTextField>
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudCheckBox @bind-Checked="model.IsLimitedQuantity" Color="Color.Primary" Label="Limited Quantity" Variant="Variant.Outlined" Margin="Margin.Dense"></MudCheckBox>
                </MudItem>
                @if (model.IsLimitedQuantity)
                {
                    <MudItem xs="12" md="6">
                        <MudTextField @bind-Value="model.OrderQuantity" Label="Order Quantity" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.OrderQuantity)" Adornment="Adornment.End" AdornmentText="@model?.Content?.PrimaryUnit" AdornmentColor="Color.Dark"></MudTextField>
                    </MudItem>
                }
            </MudGrid>
        </EditForm>
    </DialogContent>
    <DialogActions>
        <MudButton Disabled="@_busy" form="orderForm" Variant="Variant.Filled" Color="Color.Success" ButtonType="ButtonType.Submit">Submit</MudButton>
        <MudButton OnClick="Cancel" Variant="Variant.Filled" Color="Color.Default" ButtonType="ButtonType.Button">Cancel</MudButton>
    </DialogActions>
</MudDialog>

@code {

    [Parameter]
    public OrderModel model { get; set; }
    private List<OrderModel> collection = new List<OrderModel>();
    private List<ContentModel> contents = new List<ContentModel>();
    [CascadingParameter] MudDialogInstance MudDialog { get; set; }
    private string searchString = "";
    private string unit = "";
    private bool _busy;

    protected override async Task OnInitializedAsync()
    {
        await foreach (var item in Icontent.Select(0))
        {
            contents.Add(item);
        }
        await GetAll();
        if (model != null)
            SetContentObject(model.ContentID);
    }

    private async Task<IEnumerable<ContentModel>> Search(string searchString)
    {
        return await Task.FromResult(
            contents.Where(x => x.ContentName.Contains(searchString == null ? string.Empty : searchString, StringComparison.InvariantCultureIgnoreCase)));
    }

    private async Task GetAll()
    {
        await foreach (var item in Iservice.Select(0))
        {
            collection.Add(item);
        }
    }

    private void SetContentObject(short? ContentID)
    {
        model.ContentID = ContentID;
        if (contents != null && contents.Any(s => s.ContentID == ContentID))
            model.Content = contents.FirstOrDefault(s => s.ContentID == ContentID);
    }

    private async Task OnValidSubmit(EditContext context)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is being submitted!", Severity.Warning);
            return;
        }
        if (model.Party?.PartyID == 0)
        {
            snackbar.Add("Client is not selected", Severity.Error);
            return;
        }
        if (!model.IsLimitedQuantity)
        {
            model.OrderQuantity = 0;
        }
        else
        {
            var isValid = context.Validate();
            if (!isValid)
            {
                return;
            }
        }
        _busy = true;
        model.ClientID = model.Party.PartyID;
        MudDialog.Close(model);
        await Task.Delay(200);
        _busy = false;
    }
    private void Cancel() => MudDialog.Cancel();
}