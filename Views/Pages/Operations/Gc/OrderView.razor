@page "/order"
@using System.Threading;
@inject IOrderService Iservice
@inject IContentService Icontent
@inject IPartyService Iparty
@inject MudBlazor.ISnackbar snackbar
@attribute [Authorize]
@inject AuthenticationStateProvider auth
@inject NavigationManager UriHelper
@inject IDialogService DialogService
@inject IRoleService<RoleModel> Irole

<div class="admin-page-container">
    <div class="admin-header-tiered mb-6">
        <div class="d-flex align-center justify-space-between">
            <div>
                <MudText Typo="Typo.h4" Class="admin-title">Orders</MudText>
                <MudText Typo="Typo.body2" Class="admin-subtitle">Manage customer orders, track quantities, and link consignments.</MudText>
            </div>
            <MudButton StartIcon="@Icons.Material.Filled.Add" Variant="Variant.Filled" Color="Color.Primary" Class="admin-register-btn" OnClick="@(()=> OpenDialog(model))" Disabled="@_busy">ADD ORDER</MudButton>
        </div>
    </div>

    <div class="admin-glass-card mb-6 pa-4">
        <div class="d-flex align-center gap-4">
            <div style="flex-grow: 1;">
                <MudTextField @bind-Value="searchString" Placeholder="Search Orders..." Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" Variant="Variant.Outlined" Margin="Margin.Dense" Class="admin-input-group" Clearable="true" />
            </div>
        </div>
    </div>

    <div class="admin-glass-card pa-0 overflow-hidden">
        <MudTable Items="@collection" Dense="true" Hover="true" Elevation="0" Class="modern-admin-table" Filter="new Func<OrderModel, bool>(search)">
            <HeaderContent>
                <MudTh><MudTableSortLabel SortBy="new Func<OrderModel, object>(x => x.OrderName)" InitialDirection="SortDirection.Ascending"><span class="admin-header-text">TITLE</span></MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<OrderModel, object>(x => x.Party.TradeName)"><span class="admin-header-text">CLIENT NAME</span></MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<OrderModel, object>(x => x.Content.ContentName)"><span class="admin-header-text">CONTENT</span></MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<OrderModel, object>(x => x.OrderQuantity)"><span class="admin-header-text">QUANTITY</span></MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<OrderModel, object>(x => x.GstNo)"><span class="admin-header-text">GST NO</span></MudTableSortLabel></MudTh>
                <MudTh Style="text-align: right;"><span class="admin-header-text">ACTIONS</span></MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Order Name"><MudText Typo="Typo.body2" Class="admin-td-primary fw-600">@context.OrderName</MudText></MudTd>
                <MudTd DataLabel="Client">@context.Party.TradeName</MudTd>
                <MudTd DataLabel="Content"><MudText Typo="Typo.body2" Class="admin-td-secondary">@context.Content.ContentName</MudText></MudTd>
                <MudTd DataLabel="Quantity"><MudText Typo="Typo.body2" Class="admin-td-amount">@context.OrderQuantity</MudText></MudTd>
                <MudTd DataLabel="GstNo">@context.GstNo</MudTd>
                <MudTd DataLabel="Actions" Style="text-align: right;">
                    <div class="d-flex justify-end gap-1">
                        <MudTooltip Text="View Consignees/Consignors">
                            <MudIconButton OnClick="@(() => ViewConsignees(context.OrderID))" Color="Color.Primary" Icon="@Icons.Material.Filled.People" Size="Size.Small" Variant="Variant.Text" />
                        </MudTooltip>
                        <MudTooltip Text="View Tariffs">
                            <MudIconButton OnClick="@(() => ViewTariff(context.OrderID))" Color="Color.Info" Icon="@Icons.Material.Filled.Money" Size="Size.Small" Variant="Variant.Text" />
                        </MudTooltip>
                        <MudTooltip Text="Edit">
                            <MudIconButton OnClick="@(()=> OpenDialog(context))" Color="Color.Primary" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Variant="Variant.Text" />
                        </MudTooltip>
                        <MudTooltip Text="Delete">
                            <MudIconButton OnClick="@(() => Delete(context))" Color="Color.Error" Icon="@Icons.Material.Filled.DeleteOutline" Size="Size.Small" Variant="Variant.Text" />
                        </MudTooltip>
                    </div>
                </MudTd>
            </RowTemplate>
            <PagerContent>
                <div class="pa-4">
                    <MudTablePager PageSizeOptions="new int[] { 10, 20, 50, 100 }" />
                </div>
            </PagerContent>
        </MudTable>
    </div>
</div>

    @code {

    private OrderModel model = new OrderModel();
    private List<OrderModel> collection = new List<OrderModel>();
    private List<PartyModel> parties = new List<PartyModel>();
    private List<ContentModel> contents = new List<ContentModel>();

    public bool HasPermissionOrderServiceEdit { get; set; } = false;
    public bool HasPermissionOrderServiceDelete { get; set; } = false;
    public int DocTypeID = 45;
    private bool _busy;
    private string searchString = "";
    private string unit = "";
    int? BranchID;

    // Method called when the component is initialized
    protected override async Task OnInitializedAsync()
    {
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionOrderServiceEdit = await Irole.HasClaim(DocTypeID.ToString(), "Edit", ctc.Token);
        HasPermissionOrderServiceDelete = await Irole.HasClaim(DocTypeID.ToString(), "Delete", ctc.Token);

        var authprov = await auth.GetAuthenticationStateAsync();
        var brancIDString = authprov.User.Claims.First(x => x.Type == "BranchID").Value;
        BranchID = int.Parse(brancIDString);

        // Fetch all content items
        await foreach (var item in Icontent.Select(0))
        {
            contents.Add(item);
        }
        await GetAll();
    }

    // Method to search for contents based on the search string
    private async Task<IEnumerable<ContentModel>> Search(string searchString)
    {
        return await Task.FromResult(
            contents.Where(x => x.ContentName.Contains(searchString == null ? string.Empty : searchString, StringComparison.InvariantCultureIgnoreCase)));
    }

    // Method to fetch all OrderModels
    private async Task GetAll()
    {
        collection = await Iservice.SelectByBranch(BranchID).ToListAsync();
    }

    // Method to navigate to the consignees page
    private void ViewConsignees(int? id)
    {
        UriHelper.NavigateTo("consignee/" + id);
    }

    // Method to navigate to the tariff page
    private void ViewTariff(int? id)
    {
        UriHelper.NavigateTo("tariff/" + id);
    }

    // Method to delete an order
    private async Task Delete(OrderModel model)
    {
        if (HasPermissionOrderServiceDelete)
        {
            bool? result = await DialogService.ShowMessageBoxAsync(
                "Warning !",
                "Are you sure, you want to delete - " + model.OrderName + " ?");
            if (result == true)
            {
                var authprov = await auth.GetAuthenticationStateAsync();
                await Iservice.Delete(model.OrderID, authprov.User.Identity.Name); // Delete the order
                snackbar.Add("Deleted Successfully", Severity.Success);
                await GetAll();
            }
        }
        else
        {
            bool? result = await DialogService.ShowMessageBoxAsync(
                "Permission denied!",
                "You don't have any permission to Delete Order.");
        }
    }

    // Method to search for an order based on the search string
    private bool search(OrderModel model)
    {
        if ((model.OrderName != null && model.OrderName.Contains(searchString, StringComparison.OrdinalIgnoreCase))||
        (model.Party.TradeName != null && model.Party.TradeName.Contains(searchString, StringComparison.OrdinalIgnoreCase)) ||
        (model.GstNo != null && model.GstNo.Contains(searchString, StringComparison.OrdinalIgnoreCase)))
        {
            return true;
        }
        return false;
    }

    // Method to open the dialog
    private async Task OpenDialog(OrderModel odr)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        _busy = true;
        if (HasPermissionOrderServiceEdit)
        {
            var authprov = await auth.GetAuthenticationStateAsync();
            var user = authprov.User;

            DialogParameters parms = new DialogParameters();
            parms.Add("model", odr.Clone());
            var dialog = await DialogService.ShowAsync<OrderDiloge>(odr.OrderID == null ? "ADD" : "EDIT", parms);
            var result = await dialog.Result;
            if (!result.Canceled)
            {
                OrderModel UpdatedModel = (OrderModel)result.Data;
                UpdatedModel.OrderName = FontStyle.ConvertToCamelCase(UpdatedModel.OrderName);
                UpdatedModel.UserInfo.UserID = user.Identity.Name;
                try
                {
                    await Iservice.Update(UpdatedModel); // Update the order
                    snackbar.Add("Saved Successfully", Severity.Success);
                    model = new();
                    await GetAll();
                }
                catch (Exception ex)
                {
                    snackbar.Add(ex.Message, Severity.Warning);
                }
            }
        }
        else
        {
            bool? ResultModel = await DialogService.ShowMessageBoxAsync(
                "Permission denied!",
                "You don't have any permission to Add or Edit Order.");
        }
        await Task.Delay(200);
        _busy = false;
    }
}
