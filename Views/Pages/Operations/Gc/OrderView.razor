@page "/order"

@inject IOrderService Iservice
@inject IContentService Icontent
@inject IPartyService Iparty

@inject MudBlazor.ISnackbar snackbar
@attribute [Authorize]
@inject AuthenticationStateProvider auth

@inject NavigationManager UriHelper
@inject IDialogService DialogService


<MudGrid Spacing="4">

    <MudItem xs="12" md="12">
        <MudTable Items="@collection"  Dense="true" Hover="true"  Striped="true"
        Elevation="10" Filter="new Func<OrderModel, bool>(search)" @bind-model="model">        

             <ToolBarContent>
                <MudText Typo="Typo.h6">Orders</MudText>
                <MudIconButton Icon="@Icons.Material.Filled.Add" Title="Add" @onclick="@(()=> OpenDialog(model))"  Color="Color.Dark" Size="Size.Small"></MudIconButton>
                
                <MudSpacer></MudSpacer>

               <MudTextField @bind-Value="searchString" Placeholder="Search Orders... "
                              Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                              IconSize="Size.Medium" Class="mt-0"></MudTextField>
            </ToolBarContent>
            <HeaderContent>
                <MudTh><MudTableSortLabel SortBy="new Func<OrderModel, object>(x => x.OrderName)" InitialDirection="SortDirection.Ascending">title</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<OrderModel, object>(x => x.Party.TradeName)" InitialDirection="SortDirection.Ascending">Client Name</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<OrderModel, object>(x => x.Content.ContentName)" InitialDirection="SortDirection.Ascending">Content</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<OrderModel, object>(x => x.OrderQuantity)" InitialDirection="SortDirection.Ascending">Quantity</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<OrderModel, object>(x => x.GstNo)" InitialDirection="SortDirection.Ascending">GstNo</MudTableSortLabel></MudTh>

                <MudTh>Actions</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Order Name">@context.OrderName</MudTd>
                <MudTd DataLabel="Client">@context.Party.TradeName</MudTd>
                <MudTd DataLabel="Content">@context.Content.ContentName</MudTd>
                <MudTd DataLabel="Quantity">@context.OrderQuantity</MudTd>
                <MudTd DataLabel="GstNo">@context.GstNo</MudTd>
                
                <MudTd DataLabel="">
                    <MudTooltip Text="View Consignees/Consignors">
                        <MudFab @onclick="@(() => ViewConsignees(context.OrderID))" Color="Color.Primary" Icon="@Icons.Material.Filled.People" Size="Size.Small" IconSize="Size.Small" />
                    </MudTooltip>
                    <MudTooltip Text="View Tariffs">
                        <MudFab @onclick="@(() => ViewTariff(context.OrderID))" Color="Color.Primary" Icon="@Icons.Material.Filled.Money" Size="Size.Small" IconSize="Size.Small" />
                    </MudTooltip>
                    <MudFab @onclick="@(()=> OpenDialog(context))" Color="Color.Primary" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" IconSize="Size.Small" />
                    <MudFab @onclick="@(() => Delete(context.OrderID))" Color="Color.Primary" Icon="@Icons.Material.Filled.Delete" Size="Size.Small" IconSize="Size.Small" />
                </MudTd>
            </RowTemplate>
            <PagerContent>
                <MudTablePager PageSizeOptions="new int[] { 5, 10, 20, 50, 100 }" />
            </PagerContent>
        </MudTable>
    </MudItem>
</MudGrid>
@code {

    private OrderModel model = new OrderModel();
    private List<OrderModel> collection = new List<OrderModel>();
    private List<PartyModel> parties = new List<PartyModel>();
    private List<ContentModel> contents = new List<ContentModel>();

    //public bool IsApproved { get; set; } = false;
    //public bool HasPermissionEdit { get; set; } = false;
    //public bool HasPermissionDelete { get; set; } = false;
    //public int DocTypeID = 21;

    private string searchString = "";
    private string unit = "";

    protected override async Task OnInitializedAsync()
    {        
        await foreach (var item in Icontent.Select(0))
        {
            contents.Add(item);
        }
        await GetAll();
    }


    private async Task<IEnumerable<ContentModel>> Search(string searchString)
    {
        return await Task.FromResult(
            contents.Where(x => x.ContentName.Contains(searchString == null ? string.Empty : searchString, StringComparison.InvariantCultureIgnoreCase)));
    }

    private async Task GetAll()
    {       
        collection = await Iservice.Select(0).ToListAsync();
    }


    private void ViewConsignees(int? id)
    {
        UriHelper.NavigateTo("consignee/" + id);
    }
    private void ViewTariff(int? id)
    {
        UriHelper.NavigateTo("tariff/"+id);
    }

    private async Task Delete(int? id)
    {
        var authprov = await auth.GetAuthenticationStateAsync();
        await Iservice.Delete(id, authprov.User.Identity.Name);
        snackbar.Add("Deleted Successfully", Severity.Success);
        await GetAll();
    }

    private bool search(OrderModel model)
    {
        if (model.OrderName != null && model.OrderName.Contains(searchString, StringComparison.OrdinalIgnoreCase))
        {
            return true;
        }
        return false;
    }
    private async Task OpenDialog(OrderModel odr)
    {
        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;

        DialogParameters parms = new DialogParameters();
        parms.Add("model", odr);
        var dialog = DialogService.Show<OrderDiloge>(odr.OrderID == null ? "ADD" : "EDIT", parms);
        var result = await dialog.Result;
        if (!result.Canceled)
        {
            OrderModel UpdatedModel = (OrderModel)result.Data;
            model.UserInfo.UserID = user.Identity.Name;
            try
            {
                await Iservice.Update(UpdatedModel);
                snackbar.Add("Saved Successfully", Severity.Success);
                model = new();
                await GetAll();
            }
            catch (Exception ex)
            {
                snackbar.Add(ex.Message, Severity.Warning);
            }
        }
    }

}




