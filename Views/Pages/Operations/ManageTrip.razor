@page "/ManageTrip"
@inject AuthenticationStateProvider auth
@attribute [Authorize]
@inject IDialogService DialogService
@inject ITripService tripIservice
@inject ITruckService Itruck
@inject IDriverService Idriver
@inject IEventService Ievent

<MudPaper Class="pl-5">
   
        <MudGrid Spacing="7">
            <MudItem xs="12" md="5" >
                <TruckSelector @bind-Value="SelectedTruck" />

            </MudItem>
            <MudItem xs="12" md="5">
                <MudTextField @bind-Value="tripnumber" Label="Trip Number" Variant="Variant.Outlined" Margin="Margin.Dense"></MudTextField>

            </MudItem>
            <MudItem xs="12" md="2">
                <MudButton OnClick="fetch" Variant="Variant.Filled" Color="Color.Success" ButtonType="ButtonType.Submit">Fetch</MudButton>
            </MudItem>
        </MudGrid>
</MudPaper>

   <MudGrid  Class="mt-5">
    @foreach (var item in collection)
    {
        <MudItem xs="6" md="6"  xl="4" lg="6">
                    <TripDetailsCard trips="item" Elevation="10"></TripDetailsCard>
         </MudItem>
    }
</MudGrid>
   


@code {
    //Event

    
    private EventModel CurrentEvent { get; set; }
    private EventTypeModel EventType { get; set; }
    private TripModel CurrentTrip { get; set; }
    //Evnt
    public TruckModel SelectedTruck { get; set; }
    private List<TripModel> collection = new List<TripModel>();
    public string tripnumber;
    public async Task fetch()
    {
        if (tripnumber == null)
        {
            tripnumber = string.Empty;
        }
        
        int? tr = SelectedTruck.TruckID;
        var authprov = await auth.GetAuthenticationStateAsync();
        var brancIDString = authprov.User.Claims.First(x => x.Type == "BranchID").Value;
        int brancID = int.Parse(brancIDString);

     
        CurrentEvent = Ievent.GetCurrentEvent(SelectedTruck.TruckID);

        collection = new List<TripModel>();
        foreach (var item in tripIservice.SearchTrips(SelectedTruck.TruckID, brancID, tripnumber))
        {
            collection.Add(item);
        }
       
    }
}
