@inject IOpTranService Iservice
@inject ITripService tripIservice
@inject ITripFuelService tripFuelIservice
@inject ICostCenterService costIservice
@inject IGstUsageIDService usageIservice
@inject IDimensionService dimensionIservice
@inject MudBlazor.ISnackbar snackbar
@inject ITdsRateService tdsIService
@inject IChartOfAccountService accountService
@inject IConfiguration configuration
@using Microsoft.Extensions.Configuration
@inject IBranchService brIservice
@inject AuthenticationStateProvider auth
@attribute [Authorize]
@inject IDialogService DialogService
@inject IInventoryItemService itemIservice

@using Pages.Operations.Expenses

<style>
    .selected 
    {
        background-color: #1E88E5 !important;
    }

        .selected > td 
        {
            color: white !important;
        }

            .selected > td .mud-input 
            {
                color: white !important;
            }
</style>
<div class="pa-8">
    <div class="header-section mb-8">
        <div class="d-flex align-center">
            <div class="icon-badge primary-badge mr-4">
                <MudIcon Icon="@Icons.Material.Filled.LocalShipping" Size="Size.Large" />
            </div>
            <div>
                <MudText Typo="Typo.h4" Class="admin-title"><b>Strategic Logistics Control</b></MudText>
                <MudText Typo="Typo.body1" Class="admin-subtitle">
                    Real-time fleet tracking, trip management, and operational oversight.
                </MudText>
            </div>
        </div>
        <div class="title-accent mt-4" style="width: 200px;"></div>
    </div>

    <MudPaper Class="admin-glass-card pa-8 mb-8">
        <MudGrid Spacing="6" Justify="Justify.Center" AlignItems="AlignItems.Center">
            <MudItem xs="12" md="5">
                <TruckSelector @bind-Value="SelectedTruck" Class="modern-input" />  
            </MudItem>
            <MudItem xs="12" md="4">
                <MudTextField @bind-Value="tripnumber" Label="Fleet Trip Identifier" 
                             Variant="Variant.Outlined" Margin="Margin.Normal" 
                             Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.ConfirmationNumber"
                             Class="modern-input"></MudTextField>
            </MudItem>
            <MudItem xs="12" md="3" Class="d-flex justify-center">
                <MudButton OnClick="fetch" Variant="Variant.Filled" Color="Color.Primary" 
                           Size="Size.Large" Class="action-btn-primary px-10 rounded-xl"
                           Style="background: #367588 !important; color: white !important;">
                    Sync Telemetry
                </MudButton>
            </MudItem>
        </MudGrid>
    </MudPaper>

    <div class="@value mb-8">
        <MudPaper Class="admin-glass-card overflow-hidden">
            <MudTable Items="@collection" MultiSelection="true" @ref="mudTable" 
                      RowClassFunc="@SelectedRowClassFunc" OnRowClick="@RowClickEvent" 
                      @bind-SelectedItem="selectedItem1" Dense="true" Hover="true" 
                      Elevation="0" T="TripModel" Class="modern-table">
                <ToolBarContent>
                    <div class="d-flex align-center">
                        <MudIcon Icon="@Icons.Material.Filled.ListAlt" Color="Color.Primary" Class="mr-2" />
                        <MudText Typo="Typo.h6" Class="admin-title">Operational Trips</MudText>
                    </div>
                    <MudSpacer />
                </ToolBarContent>
                <HeaderContent>
                    <MudTh><MudTableSortLabel SortBy="new Func<TripModel, object>(x=> x.TripDate)">Registry Date</MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<TripModel, object>(x=> x.TripNumber)">Trip Manifest ID</MudTableSortLabel></MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Date">@context.TripDate?.ToString("dd MMM yyyy")</MudTd>
                    <MudTd DataLabel="ID">
                        <div class="d-flex align-center">
                            <span class="rounded-pill px-3 py-1 mr-2" style="background: rgba(54, 117, 136, 0.1); color: #367588; font-family: 'Outfit', sans-serif; font-weight: 700; font-size: 0.8rem;">TRIP</span>
                            <MudText Typo="Typo.body2" Style="font-weight: 600;">@context.TripNumber</MudText>
                        </div>
                    </MudTd>
                </RowTemplate>
                <PagerContent>
                    <MudTablePager />
                </PagerContent>
            </MudTable>
        </MudPaper>
    </div>

    <div class="@IsPurBtn mb-8">
        <MudPaper Class="pa-6 rounded-xl d-flex align-center justify-space-between" 
                  Style="background: linear-gradient(135deg, #141A46 0%, #367588 100%); color: white; box-shadow: 0 20px 40px -10px rgba(20, 26, 70, 0.3);">
            <div class="d-flex align-center">
                <div class="icon-badge white-badge mr-4" style="background: rgba(255,255,255,0.2) !important;">
                    <MudIcon Icon="@Icons.Material.Filled.LocalGasStation" Style="color: white;" />
                </div>
                <div>
                    <MudText Typo="Typo.h6"><b>Operational Fueling</b></MudText>
                    <MudText Typo="Typo.body2" Style="opacity: 0.8;">Register energy consumption for the selected trip manifest.</MudText>
                </div>
            </div>
            <MudButton @onclick="OpenDialog" StartIcon="@Icons.Material.Filled.Add" 
                       Variant="Variant.Filled" Color="Color.Default" 
                       Style="background: white !important; color: #141A46 !important; font-weight: 800;"
                       Class="rounded-xl px-6">
                Record Consumption
            </MudButton>
        </MudPaper>
    </div>

    <div class="@valueTran">
