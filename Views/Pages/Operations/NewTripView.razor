@using System.Threading;
@inject ITripService Iservice
@inject IPlaceService Iplace
@inject IEventService Ievent
@inject MudBlazor.ISnackbar snackbar
@attribute [Authorize]
@inject AuthenticationStateProvider auth
@inject IRoleService<RoleModel> Irole
@inject IDialogService DialogService

<MudDialog>
    <DialogContent>
        <EditForm id="form" Model="@model" OnValidSubmit="OnValidSubmit">
            <DataAnnotationsValidator />
            <ValidationSummary />
            <MudGrid Spacing="4">
                @if (IsLoading)
                {
                    <MudProgressCircular Color="Color.Primary" Style="height:70px;width:70px;" Indeterminate="true" />
                }
                else
                {
                    <MudItem xs="12" md="12">
                        <MudText Typo="Typo.h4"><MudIcon Icon="@Icons.Material.Filled.LocalShipping" Title="Truck" /> @Truck.RegNo</MudText>
                    </MudItem>
                    <MudItem xs="12" md="12">
                        @if (AssignedDriver == null)
                        {
                            <MudText Typo="Typo.h4" Color="Color.Warning"><MudIcon Icon="@Icons.Material.Filled.AirlineSeatReclineNormal" Title="Driver" /> UNASSAIGNED</MudText>
                        }
                        else
                        {
                            <MudText Typo="Typo.h4" Color="Color.Primary"><MudIcon Icon="@Icons.Material.Filled.AirlineSeatReclineNormal" Title="Driver" /> @AssignedDriver.DriverName</MudText>
                        }
                        <MudText></MudText>
                    </MudItem>
                    <MudItem xs="12" md="12">
                        <MudCheckBox @bind-Checked="@startWithLoading" Label="Start with Loading" @onclick="EventSelected"></MudCheckBox>
                    </MudItem>
                }
                <MudItem xs="12" md="6">
                    <MudAutocomplete T="PlaceModel" Label="Origin" @bind-Value="Origin" ResetValueOnEmptyText="true" SearchFunc="SearchPlaces" ToStringFunc="@(e => e == null ? null : $"{e.PlaceName}")"></MudAutocomplete>
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudNumericField HideSpinButtons @bind-Value="KmReading" Label="Audometer Reading" Variant="Variant.Outlined" Margin="Margin.Dense"></MudNumericField>
                 </MudItem>
                 @if (!startWithLoading)
                {
                    <MudItem xs="12" md="6">
                        <MudAutocomplete T="PlaceModel" Label="Destination" @bind-Value="Destination" ResetValueOnEmptyText="true" SearchFunc="SearchPlaces" ToStringFunc="@(e => e == null ? null : $"{e.PlaceName}")"></MudAutocomplete>
                    </MudItem>
                }
                <MudItem xs="12" md="6">
                    <MudSelect Label="Select Destination Event" T="byte?" @bind-Value="currentEvent.NextEventTypeID" OffsetY="true" Variant="Variant.Outlined" AdornmentColor="Color.Secondary">
                        @foreach (var item in EventTypes)
                        {
                            <MudSelectItem T="byte?" Value="@item.EventTypeID">@item.EventTypeName</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
            </MudGrid>
        </EditForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton form="form" Variant="Variant.Filled" Color="Color.Success" ButtonType="ButtonType.Submit">Start Trip</MudButton>
    </DialogActions>
</MudDialog>

@code {

    [CascadingParameter] MudDialogInstance MudDialog { get; set; }
    [Parameter] public TruckModel Truck { get; set; }
    [Parameter] public DriverModel AssignedDriver { get; set; }
    private EventModel lastEvent;
    private TripModel model = new();
    private bool IsLoading = false;
    private bool startWithLoading = false;
    private PlaceModel Origin = new();
    private PlaceModel Destination = new();
    private long? KmReading;
    bool isSubmitting;
    EventModel currentEvent = new();
    private List<PlaceModel> places;
    private List<EventTypeModel> EventTypes;

    public bool HasPermissionTripServiceEdit { get; set; } = false;
    public bool HasPermissionTripServiceDelete { get; set; } = false;
    public int DocTypeID = 39;

    private void Cancel()
    {
        MudDialog.Cancel();
    }

    protected override async Task OnInitializedAsync()
    {
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionTripServiceEdit = await Irole.HasClaim(DocTypeID.ToString(), "Edit", ctc.Token);
        HasPermissionTripServiceDelete = await Irole.HasClaim(DocTypeID.ToString(), "Delete", ctc.Token);

        places = new();
        places = Iplace.Select(0).ToList();
        EventTypes = Ievent.GetEventTypes().ToList();
        lastEvent = Ievent.GetCurrentEvent(Truck.TruckID);
        if (EventTypes != null && EventTypes.Count() != 0 && EventTypes.Any(x => x.EventTypeID == 1))
        {
            currentEvent.NextEventTypeID = EventTypes.FirstOrDefault(x => x.EventTypeID == 1).DefaultNextEventTypeID;
        }
        KmReading = lastEvent?.EventReading;
        int? OriginID = lastEvent?.DestinationID;
        Origin = OriginID == null ? null : await Iplace.SelectByID(OriginID.Value);
        model.BranchID = int.Parse(Task.Run(() => auth.GetAuthenticationStateAsync()).Result.User.Claims.FirstOrDefault(c => c.Type == "BranchID").Value);
        model.TruckID = Truck.TruckID;
        model.TripDate = DateTime.Today;
    }

    private async Task<IEnumerable<PlaceModel>> SearchPlaces(string searchString)
    {
        return await Task.FromResult(places.Where(x => x.PlaceName.Contains(searchString == null ? string.Empty : searchString, StringComparison.InvariantCultureIgnoreCase)));
    }

    private void EventSelected()
    {
        if (EventTypes != null && EventTypes.Count() != 0)
        {
            if (!startWithLoading)
            {
                if (EventTypes.Any(x => x.EventTypeID == 2))
                {
                    currentEvent.NextEventTypeID = EventTypes.FirstOrDefault(x => x.EventTypeID == 2).DefaultNextEventTypeID;
                }
            }
            else
            {
                if (EventTypes.Any(x => x.EventTypeID == 1))
                {
                    currentEvent.NextEventTypeID = EventTypes.FirstOrDefault(x => x.EventTypeID == 1).DefaultNextEventTypeID;
                }
            }
        }
    }

    private async Task OnValidSubmit(EditContext context)
    {
        if (HasPermissionTripServiceEdit)
        {
            if (isSubmitting)
                return;

            isSubmitting = true;

            try
            {
                var authprov = await auth.GetAuthenticationStateAsync();

                if (AssignedDriver == null)
                {
                    snackbar.Add("Driver is not assigned", Severity.Warning);
                    return;
                }

                model.DriverID = AssignedDriver?.DriverID;
                model.UserInfo.UserID = authprov.User.Identity.Name;
                model = Iservice.Update(model);

                #region Add loading event

                currentEvent.BranchID = model.BranchID;
                currentEvent.DestinationID = startWithLoading ? Origin?.PlaceID ?? null : Destination?.PlaceID ?? null;
                currentEvent.OriginID = Origin?.PlaceID ?? null;
                currentEvent.DriverID = model.DriverID;
                currentEvent.EventTime = DateTime.Now;
                currentEvent.EventReading = KmReading;
                currentEvent.EventTypeID = 1;
                currentEvent.TripID = model.TripID;
                currentEvent.TruckID = model.TruckID;
                currentEvent.UserInfo.UserID = model.UserInfo.UserID;
                currentEvent = Ievent.Update(currentEvent);

                #endregion

                if (startWithLoading)
                {
                    currentEvent.TruckEventID = null;
                    currentEvent.EventTypeID = 2;
                    currentEvent = Ievent.Update(currentEvent);
                }
                MudDialog.Close(DialogResult.Ok(model));
            }
            catch (Exception ex)
            {
                snackbar.Add(ex.Message, Severity.Warning);
            }
            finally
            {
                isSubmitting = false;
            }
        }
        else
        {
            bool? ResultModel = await DialogService.ShowMessageBox(
                "Permission denied!",
                "You dont have any permission to Add or Edit Trip.");
        }
    }
}