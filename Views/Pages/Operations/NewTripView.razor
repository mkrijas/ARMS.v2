@using System.Threading;
@using System.ComponentModel.DataAnnotations

@attribute [Authorize]
@inject AuthenticationStateProvider auth
@inject ITripService Iservice
@inject IPlaceService Iplace
@inject IEventService Ievent
@inject MudBlazor.ISnackbar snackbar
@inject IRoleService<RoleModel> Irole
@inject IDialogService DialogService
@inject IBranchSettingsService IbranchSettings

<MudDialog>
    <DialogContent>
        <EditForm id="formStartTrip" Model="@model" OnValidSubmit="OnValidSubmit">
            <ObjectGraphDataAnnotationsValidator />
            <ValidationSummary/>            
            <MudGrid Spacing="4">
                @if (IsLoading)
                {
                    <MudProgressCircular Color="Color.Primary" Style="height:70px;width:70px;" Indeterminate="true" />
                }
                else
                {
                    <MudItem xs="12" md="12">
                        <MudText Typo="Typo.h4"><MudIcon Icon="@Icons.Material.Filled.LocalShipping" Title="Truck" /> @Truck.RegNo</MudText>
                    </MudItem>
                    <MudItem xs="12" md="12">
                        @if (AssignedDriver == null)
                        {
                            <MudText Typo="Typo.h4" Color="Color.Warning"><MudIcon Icon="@Icons.Material.Filled.AirlineSeatReclineNormal" Title="Driver" /> UNASSAIGNED</MudText>
                        }
                        else
                        {
                            <MudText Typo="Typo.h4" Color="Color.Primary"><MudIcon Icon="@Icons.Material.Filled.AirlineSeatReclineNormal" Title="Driver" /> @AssignedDriver.DriverName</MudText>
                        }
                        <MudText></MudText>
                    </MudItem>
                    <MudItem xs="12" md="12">
                        <MudCheckBox Checked="@startWithLoading" Label="Start with Loading" T="bool" CheckedChanged="EventSelected"></MudCheckBox>
                    </MudItem>
                }              
                @if (_canEditTime)
                {
                    <MudItem xs="12" md="6">
                        <MudTextField Label="Date n Time" Format="s" Variant="Variant.Outlined" @bind-Value="@currentEvent.EventTime" InputType="InputType.DateTimeLocal" Margin="Margin.Dense"></MudTextField>
                    </MudItem>
                }
                <MudItem xs="12" md="6">
                    <MudNumericField HideSpinButtons @bind-Value="currentEvent.EventReading" Label="Audometer Reading" Variant="Variant.Outlined" Margin="Margin.Dense"></MudNumericField>
                 </MudItem>
                 <MudItem xs="12" md="6">
                     <MudAutocomplete T="PlaceModel" Variant="Variant.Outlined" Label="Origin" Value="Origin" ValueChanged="OriginChanged" ResetValueOnEmptyText="true" SearchFunc="SearchPlaces" ToStringFunc="@(e => e == null ? null : $"{e.PlaceName}")" Margin="Margin.Dense"></MudAutocomplete>
                 </MudItem>
                 @if (!startWithLoading)
                {
                    <MudItem xs="12" md="6">
                        <MudAutocomplete T="PlaceModel" Variant="Variant.Outlined" Label="Destination" Value="Destination" ValueChanged="DestinationChanged" ResetValueOnEmptyText="true" SearchFunc="SearchPlaces" ToStringFunc="@(e => e == null ? null : $"{e.PlaceName}")" Margin="Margin.Dense"></MudAutocomplete>
                    </MudItem>
                }
                <MudItem xs="12" md="6">
                    <MudSelect Label="Select Destination Event" T="byte?" @bind-Value="currentEvent.NextEventTypeID" Variant="Variant.Outlined" AdornmentColor="Color.Secondary" Margin="Margin.Dense">
                        @foreach (var item in DestinationEventTypes)
                        {
                            <MudSelectItem T="byte?" Value="@item.EventTypeID">@item.EventTypeName</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
            </MudGrid>
        </EditForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Disabled="@_busy" form="formStartTrip" Variant="Variant.Filled" Color="Color.Success" ButtonType="ButtonType.Submit">Start Trip</MudButton>
    </DialogActions>
</MudDialog>

@code {

    [CascadingParameter] MudDialogInstance MudDialog { get; set; }
    [Parameter] public TruckModel Truck { get; set; }
    [Parameter] public DriverModel AssignedDriver { get; set; }
    private EventModel lastEvent;
    private TripModel model = new();
    private bool IsLoading = false;
    private bool startWithLoading = false;
    private PlaceModel Origin = new();
    private PlaceModel Destination = new();
    //private long? KmReading;
    bool isSubmitting;
    EventModel currentEvent = new();
    private List<PlaceModel> places;
    private List<EventTypeModel> EventTypes;
    private List<EventTypeModel> DestinationEventTypes;
    private bool _busy;
    private bool HasPermissionTripServiceEdit { get; set; } = false;
    private bool HasPermissionTripServiceDelete { get; set; } = false;
    private int DocTypeID = 39;

    int BranchID;
    string UserID;
    bool _canEditTime;


    private void Cancel()
    {
        MudDialog.Cancel();
    }

    protected override async Task OnInitializedAsync()
    {
        model.StartEvent = currentEvent;
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionTripServiceEdit = await Irole.HasClaim(DocTypeID.ToString(), "Edit", ctc.Token);
        HasPermissionTripServiceDelete = await Irole.HasClaim(DocTypeID.ToString(), "Delete", ctc.Token);

        var authprov = await auth.GetAuthenticationStateAsync();
        UserID = authprov.User.Identity.Name;
        BranchID = int.Parse(authprov.User.Claims.First(x => x.Type == "BranchID").Value);
        _canEditTime = IbranchSettings.IsEnabled(BranchID,2);

        places = new();
        places = Iplace.Select(0).ToList();
        EventTypes = Ievent.GetEventTypes().Where(x => x.IsTripRelated).ToList();
        DestinationEventTypes = EventTypes.Where(s => s.EventTypeID != 1 &&( startWithLoading == false && s.EventTypeID > 1 || startWithLoading == true && s.EventTypeID > 2)).ToList();
        lastEvent = Ievent.GetCurrentEvent(Truck.TruckID);
        if (EventTypes != null && EventTypes.Count() != 0 && EventTypes.Any(x => x.EventTypeID == 1))
        {
            currentEvent.NextEventTypeID = EventTypes.FirstOrDefault(x => x.EventTypeID == 1).DefaultNextEventTypeID;
        }
        currentEvent.EventReading = lastEvent?.EventReading;
        int? OriginID = lastEvent?.DestinationID;
        currentEvent.OriginID = OriginID;
        Origin = OriginID == null ? null : await Iplace.SelectByID(OriginID.Value);


        #region Add Start event

        currentEvent.BranchID = BranchID;       
        currentEvent.DriverID = AssignedDriver?.DriverID;
        currentEvent.EventTime = DateTime.Now;        
        currentEvent.EventTypeID = 1;        
        currentEvent.TruckID = Truck.TruckID;
        currentEvent.UserInfo.UserID = UserID;

        #endregion


        model.BranchID = BranchID;
        model.TruckID = Truck.TruckID;
        model.TripDate = currentEvent.EventTime.Value.Date;
    }

    private async Task<IEnumerable<PlaceModel>> SearchPlaces(string searchString)
    {
        return await Task.FromResult(places.Where(x => x.PlaceName.Contains(searchString == null ? string.Empty : searchString, StringComparison.InvariantCultureIgnoreCase)));
    }


    private void OriginChanged(PlaceModel _origin)
    {
        Origin = _origin;
        currentEvent.OriginID = _origin?.PlaceID;
        currentEvent.OriginName = _origin?.PlaceName;
        if(startWithLoading)
        {
            currentEvent.DestinationID = _origin?.PlaceID;
        }       
    }

    private void DestinationChanged(PlaceModel _destination)
    {
        Destination = _destination;
        currentEvent.DestinationID = _destination?.PlaceID;
        currentEvent.DestinationName = _destination?.PlaceName;
    }    

    private void EventSelected(bool startLoading)
    {
        DestinationEventTypes = EventTypes.Where(s => s.EventTypeID != null && startLoading == false && s.EventTypeID > 1 || s.EventTypeID != null && startLoading == true && s.EventTypeID > 2).ToList();

        if (EventTypes != null && EventTypes.Count() != 0)
        {
            if (!startLoading)
            {
                if (EventTypes.Any(x => x.EventTypeID == 1))
                {
                    currentEvent.NextEventTypeID = EventTypes.FirstOrDefault(x => x.EventTypeID == 1).DefaultNextEventTypeID;
                    StateHasChanged();
                }
            }
            else
            {
                if (EventTypes.Any(x => x.EventTypeID == 2))
                {
                    currentEvent.NextEventTypeID = EventTypes.FirstOrDefault(x => x.EventTypeID == 2).DefaultNextEventTypeID;
                }
                currentEvent.DestinationID = currentEvent.OriginID;
            }
        }
        startWithLoading = startLoading;
        model.StartWithLoading = startLoading;
    }





    private async Task OnValidSubmit(EditContext context)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }

      
            if (HasPermissionTripServiceEdit)
            {
                if (isSubmitting)
                {
                    return;
                }
                isSubmitting = true;
                try
                {
                    if (AssignedDriver == null)
                    {
                        snackbar.Add("Driver is not assigned", Severity.Warning);
                        return;
                    }
                    _busy = true;
                    model.DriverID = AssignedDriver?.DriverID;
                    model.TripDate = currentEvent.EventTime.Value.Date;
                    model.UserInfo.UserID = UserID;
                    model = Iservice.Update(model);

                    #region Add Start event

                    currentEvent.TripID = model.TripID;                  
                    currentEvent = Ievent.Update(currentEvent);

                    #endregion

                    if (startWithLoading)
                    {
                        currentEvent.TruckEventID = null;
                        currentEvent.EventTypeID = 2;
                        currentEvent = Ievent.Update(currentEvent);
                    }
                    MudDialog.Close(DialogResult.Ok(model));
                }
                catch (Exception ex)
                {
                    snackbar.Add(ex.Message, Severity.Warning);
                }
                finally
                {
                    isSubmitting = false;
                    await Task.Delay(200);
                    _busy = false;
                }
            }
            else
            {
                bool? ResultModel = await DialogService.ShowMessageBox(
                    "Permission denied!",
                    "You dont have any permission to Add or Edit Trip.");
            }
       
    }
}