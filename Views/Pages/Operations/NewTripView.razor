@using System.ComponentModel.DataAnnotations
@using ArmsModels.BaseModels.Finance.Transactions
@using Core.BaseModels.Finance.Transactions;
@attribute [Authorize]
@inject AuthenticationStateProvider auth
@inject ITripService Iservice
@inject IPlaceService Iplace
@inject IEventService Ievent
@inject ITruckService Itruck
@inject IMileageShortageReceiptService Imileage
@inject MudBlazor.ISnackbar snackbar
@inject IRoleService<RoleModel> Irole
@inject IDialogService DialogService
@inject IBranchSettingsService IbranchSettings

<MudDialog Class="admin-dialog-glass">
    <TitleContent>
        <div class="header-section mb-2 pt-4 px-4">
            <div class="d-flex align-center justify-space-between">
                <div class="d-flex align-center">
                    <div class="icon-badge primary-badge mr-4">
                        <div class="admin-header-icon-badge mb-3">
                            <MudIcon Icon="@Icons.Material.Filled.AddRoad" Color="Color.Secondary" Style="font-size: 3rem;" />
                        </div>
                    </div>
                    <div>
                        <MudText Typo="Typo.h5" Class="admin-title"><b>Commence New Expedition</b></MudText>
                        <MudText Typo="Typo.body2" Class="admin-subtitle">Initialize logistical journey parameters and authorize vehicle departure.</MudText>
                    </div>
                </div>
            </div>
            <div class="title-accent mt-4"></div>
        </div>
    </TitleContent>
    <DialogContent>
        <MudContainer Class="admin-dialog-container">
            <div class="dialog-content-wrapper pa-4">
                @if (model != null)
                {
                    <EditForm id="formStartTrip" Model="@model" OnValidSubmit="OnValidSubmit">
                        <ObjectGraphDataAnnotationsValidator />
                        
                        <div class="admin-glass-card pa-0 mb-6 overflow-hidden">
                            <div class="pa-6" style="background-color: var(--mud-palette-primary); background-image: linear-gradient(135deg, rgba(255,255,255,0.15) 0%, rgba(255,255,255,0.35) 100%);">
                                <div class="d-flex align-center justify-space-between">
                                    <div class="d-flex align-center">
                                        <div class="mr-4 pa-3 rounded-lg" style="background: rgba(255,255,255,0.15); backdrop-filter: blur(4px);">
                                            <MudIcon Icon="@Icons.Material.Filled.LocalShipping" Color="Color.Inherit" style="color: white !important;" Size="Size.Large"/>
                                        </div>
                                        <div>
                                            <MudText Typo="Typo.h5" Class="white-text fw-700">@Truck.RegNo</MudText>
                                            <MudText Typo="Typo.caption" Class="white-text-secondary">Expeditionary Asset Registration</MudText>
                                        </div>
                                    </div>
                                    <div class="d-flex align-center">
                                        <div class="text-right mr-3">
                                            <MudText Typo="Typo.subtitle1" Class="white-text fw-600">@(AssignedDriver?.DriverName ?? "UNASSIGNED")</MudText>
                                            <MudText Typo="Typo.caption" Class="white-text-secondary">Designated Operator</MudText>
                                        </div>
                                        <MudAvatar Color="Color.Surface" Size="Size.Large" Class="shadow-sm">
                                            <MudIcon Icon="@Icons.Material.Filled.Person" Color="Color.Primary" />
                                        </MudAvatar>
                                    </div>
                                </div>
                            </div>
                        </div>

                        @if (IsLoading)
                        {
                            <div class="d-flex justify-center align-center py-12">
                                <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Large" />
                            </div>
                        }
                        else
                        {
                            <div class="admin-glass-card pa-6">
                                <div class="d-flex align-center mb-6">
                                    <MudIcon Icon="@Icons.Material.Filled.Settings" Color="Color.Primary" Class="mr-2" />
                                    <span class="admin-section-label mb-0">Configuration & Telemetry</span>
                                </div>

                                <MudGrid Spacing="3">
                                    <MudItem xs="12">
                                        <div class="modern-checkbox pa-2 rounded-lg" style="background: rgba(var(--mud-palette-primary-rgb), 0.05); border: 1px dashed var(--mud-palette-primary);">
                                            <MudCheckBox Value="@startWithLoading" Label="Commence with Cargo Loading Operations" T="bool" ValueChanged="EventSelected" Color="Color.Primary" Dense="true" UncheckedColor="Color.Default"></MudCheckBox>
                                        </div>
                                    </MudItem>

                                    @if (_canEditTime)
                                    {
                                        <MudItem xs="12" md="6">
                                            <MudTextField Label="Expedition Commencement Timestamp" Format="s" Variant="Variant.Outlined" @bind-Value="@currentEvent.EventTime" InputType="InputType.DateTimeLocal" Margin="Margin.Normal" Max='@DateTime.Now.ToString("yyyy-MM-ddTHH:mm")' Min="2024-04-01T00:00" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Schedule" Class="modern-input"/>
                                        </MudItem>
                                    }
                                    
                                    <MudItem xs="12" md="6">
                                        <MudNumericField HideSpinButtons @bind-Value="currentEvent.EventReading" Label="Verified Odometer Synchronicity" Variant="Variant.Outlined" Margin="Margin.Normal" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Speed" Class="modern-input" Placeholder="Enter current reading..."></MudNumericField>
                                    </MudItem>

                                    <MudItem xs="12" md="@(startWithLoading ? 12 : 6)">
                                        <MudAutocomplete T="PlaceModel" Variant="Variant.Outlined" Label="Expeditionary Origin" Value="Origin" ValueChanged="OriginChanged" ResetValueOnEmptyText="true" SearchFunc="SearchPlaces" ToStringFunc="@(e => e?.PlaceName)" Margin="Margin.Normal" MaxItems="50" AdornmentIcon="@Icons.Material.Filled.Home" AdornmentColor="Color.Success" Class="modern-input" Placeholder="Search origin..."></MudAutocomplete>
                                    </MudItem>
                                    
                                    @if (!startWithLoading)
                                    {
                                        <MudItem xs="12" md="6">
                                            <MudAutocomplete T="PlaceModel" Variant="Variant.Outlined" Label="Strategic Destination" Value="Destination" ValueChanged="DestinationChanged" ResetValueOnEmptyText="true" SearchFunc="SearchPlaces" ToStringFunc="@(e => e?.PlaceName)" Margin="Margin.Normal" MaxItems="50" AdornmentIcon="@Icons.Material.Filled.Flag" AdornmentColor="Color.Error" Class="modern-input" Placeholder="Search destination..."></MudAutocomplete>
                                        </MudItem>
                                    }

                                    <MudItem xs="12">
                                        <MudSelect For="@(() => currentEvent.NextEventTypeID)" Label="Operational Objective / Next Phase" T="byte?" @bind-Value="currentEvent.NextEventTypeID" Variant="Variant.Outlined" AdornmentColor="Color.Secondary" Margin="Margin.Normal" ToStringFunc="GetEventTypeName" AnchorOrigin="MudBlazor.Origin.BottomLeft" Class="modern-input" AdornmentIcon="@Icons.Material.Filled.DoubleArrow">
                                            @foreach (var item in DestinationEventTypes)
                                            {
                                                <MudSelectItem T="byte?" Value="@item.EventTypeID">@item.EventTypeName</MudSelectItem>
                                            }
                                        </MudSelect>
                                    </MudItem>
                                </MudGrid>
                            </div>
                        }
                    </EditForm>
                }
                else
                {
                    <div class="d-flex justify-center align-center py-12">
                        <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Large" />
                    </div>
                }
            </div>
        </MudContainer>
    </DialogContent>
    <DialogActions>
        <div class="d-flex w-100 flex-wrap pa-4 gap-3 align-center">
            <MudSpacer />
            <MudButton @onclick="Cancel" Variant="Variant.Outlined" Color="Color.Default" Style="border-radius: 12px; font-weight: 700; text-transform: none; border-color: rgba(0,0,0,0.15);">Discard</MudButton>
            <MudButton Disabled="@_busy" form="formStartTrip" Variant="Variant.Filled" ButtonType="ButtonType.Submit" Color="Color.Success" Style="background: var(--mud-palette-success); color: white; font-weight: 800; border-radius: 12px; text-transform: none; white-space: nowrap; padding: 8px 24px;" StartIcon="@Icons.Material.Filled.DoneAll">Submit</MudButton>
        </div>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; }
    [Parameter] public TruckModel Truck { get; set; }
    [Parameter] public DriverModel AssignedDriver { get; set; }
    private EventModel lastEvent;
    private TripModel model = new();
    private bool IsLoading = false;
    private bool startWithLoading = false;
    private PlaceModel Origin = new();
    private PlaceModel Destination = new();
    //private long? KmReading;
    bool isSubmitting;
    EventModel currentEvent = new();
    private List<PlaceModel> places;
    private List<EventTypeModel> EventTypes = new();
    private List<EventTypeModel> DestinationEventTypes = new();
    private bool _busy;
    private bool HasPermissionTripServiceEdit { get; set; } = false;
    private bool HasPermissionTripServiceDelete { get; set; } = false;
    private int DocTypeID = 39;
    private long? lastTripID;

    int BranchID;
    string UserID;
    bool _canEditTime;
    //private IEnumerable<MileageShortageReceiptModel> mileages;

    private void Cancel()
    {
        MudDialog.Cancel();
    }

    protected override async Task OnInitializedAsync()
    {
        if (model == null) model = new();
        model.StartEvent = currentEvent;
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionTripServiceEdit = await Irole.HasClaim(DocTypeID.ToString(), "Edit", ctc.Token);
        HasPermissionTripServiceDelete = await Irole.HasClaim(DocTypeID.ToString(), "Delete", ctc.Token);

        var authprov = await auth.GetAuthenticationStateAsync();
        UserID = authprov.User.Identity.Name;
        BranchID = int.Parse(authprov.User.Claims.First(x => x.Type == "BranchID").Value);
        _canEditTime = IbranchSettings.IsEnabled(BranchID, 2);

        places = new();
        places = Iplace.Select(0, null).ToList();
        EventTypes = Ievent.GetEventTypes().Where(x => x.IsTripRelated).ToList();
        DestinationEventTypes = EventTypes.Where(s => s.EventTypeID != 1 && (startWithLoading == false && s.EventTypeID > 1 || startWithLoading == true && s.EventTypeID > 2)).ToList();
        lastEvent = Ievent.GetCurrentEvent(Truck.TruckID);
        if (EventTypes != null && EventTypes.Count() != 0 && EventTypes.Any(x => x.EventTypeID == 1))
        {
            currentEvent.NextEventTypeID = EventTypes.FirstOrDefault(x => x.EventTypeID == 1).DefaultNextEventTypeID;
        }
        currentEvent.EventReading = lastEvent?.EventReading;
        int? OriginID = lastEvent?.DestinationID;
        currentEvent.OriginID = OriginID;
        Origin = OriginID == null ? null : await Iplace.SelectByID(OriginID.Value);


        #region Add Start event

        currentEvent.BranchID = BranchID;
        currentEvent.DriverID = AssignedDriver?.DriverID;
        currentEvent.EventTime = DateTime.Now;
        currentEvent.EventTypeID = 1;
        currentEvent.TruckID = Truck.TruckID;
        currentEvent.UserInfo.UserID = UserID;

        #endregion


        model.BranchID = BranchID;
        model.TruckID = Truck.TruckID;
        model.TripDate = currentEvent.EventTime.Value.Date;
        model.EventTime = currentEvent.EventTime;
        model.EventReading = currentEvent.EventReading;
        model.OriginID = currentEvent.OriginID;
        model.DestinationID = currentEvent.DestinationID;
    }

    private async Task<IEnumerable<PlaceModel>> SearchPlaces(string searchString, CancellationToken token)
    {
        return await Task.FromResult(places.Where(x => x.PlaceName.Contains(searchString == null ? string.Empty : searchString, StringComparison.InvariantCultureIgnoreCase)));
    }


    private void OriginChanged(PlaceModel _origin)
    {
        Origin = _origin;
        currentEvent.OriginID = _origin?.PlaceID;
        currentEvent.OriginName = _origin?.PlaceName;
        if (startWithLoading)
        {
            currentEvent.DestinationID = _origin?.PlaceID;
        }
        model.OriginID = currentEvent.OriginID;
    }

    private void DestinationChanged(PlaceModel _destination)
    {
        Destination = _destination;
        currentEvent.DestinationID = _destination?.PlaceID;
        currentEvent.DestinationName = _destination?.PlaceName;
        model.DestinationID = currentEvent.DestinationID;
    }

    private void EventSelected(bool startLoading)
    {
        DestinationEventTypes = EventTypes.Where(s => s.EventTypeID != null && startLoading == false && s.EventTypeID > 1 || s.EventTypeID != null && startLoading == true && s.EventTypeID > 2).ToList();

        if (EventTypes != null && EventTypes.Count() != 0)
        {
            if (!startLoading)
            {
                if (EventTypes.Any(x => x.EventTypeID == 1))
                {
                    currentEvent.NextEventTypeID = EventTypes.FirstOrDefault(x => x.EventTypeID == 1).DefaultNextEventTypeID;
                    StateHasChanged();
                }
            }
            else
            {
                if (EventTypes.Any(x => x.EventTypeID == 2))
                {
                    currentEvent.NextEventTypeID = EventTypes.FirstOrDefault(x => x.EventTypeID == 2).DefaultNextEventTypeID;
                }
                currentEvent.DestinationID = currentEvent.OriginID;
                model.DestinationID = currentEvent.DestinationID;
            }
        }
        startWithLoading = startLoading;
        model.StartWithLoading = startLoading;
    }

    private async Task OnValidSubmit(EditContext context)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }


        if (HasPermissionTripServiceEdit)
        {
            if (isSubmitting)
            {
                return;
            }
            isSubmitting = true;
            try
            {
                lastTripID = Itruck.GetLastTrip(Truck.TruckID);
                TripInfoModel tripInfo = Iservice.GetTripInfo(lastTripID);
                bool IsBranchMileage = IbranchSettings.IsEnabled(BranchID, 4);
                if (IsBranchMileage && lastTripID != null)
                {
                    if (!tripInfo.IsMileageOverride)
                    {
                       var mileages = Imileage.SelectByTripID(lastTripID).ToList();

                        if (!mileages.Any())
                        {
                            snackbar.Add(string.Format("Complete mileage shortage for trip {0}", tripInfo.TripNumber), Severity.Warning);
                            return;
                        }
                    }
                }

                if (AssignedDriver == null)
                {
                    snackbar.Add("Driver is not assigned", Severity.Warning);
                    return;
                }
                _busy = true;
                model.DriverID = AssignedDriver?.DriverID;
                model.TripDate = currentEvent.EventTime.Value.Date;
                model.UserInfo.UserID = UserID;
                model.EventTime = currentEvent.EventTime;
                model.EventReading = currentEvent.EventReading;
                model.OriginID = currentEvent.OriginID;
                model.DestinationID = currentEvent.DestinationID;

                if (ValidateEvent())
                {
                    model = Iservice.Update(model);
                    // #region Add Start event
                    // if (model.TripID != null)
                    // {
                    //     currentEvent.TripID = model.TripID;
                    //     currentEvent = Ievent.Update(currentEvent);

                    //     #endregion

                    //     if (startWithLoading)
                    //     {
                    //         currentEvent.TruckEventID = null;
                    //         currentEvent.EventTypeID = 2;
                    //         currentEvent = Ievent.Update(currentEvent);
                    //     }
                    MudDialog.Close(DialogResult.Ok(model));
                    // }
                }
                else
                {
                    snackbar.Add("Time cannot be before previous  event", Severity.Warning);
                }
            }
            catch (Exception ex)
            {
                snackbar.Add(ex.Message, Severity.Warning);
            }
            finally
            {
                isSubmitting = false;
                await Task.Delay(200);
                _busy = false;
            }
        }
        else
        {
            bool? ResultModel = await DialogService.ShowMessageBoxAsync(
                "Permission denied!",
                "You don't have any permission to Add or Edit Trip.");
        }

    }


    private string GetEventTypeName(byte? id)
    {
        return EventTypes.FirstOrDefault(x => x.EventTypeID == id)?.EventTypeName ?? id?.ToString();
    }

    private bool ValidateEvent()
    {
        EventModel PreEvent = Ievent.GetCurrentEvent(Truck.TruckID);

        if (PreEvent != null && currentEvent.EventTime < PreEvent.EventTime)
        {
            snackbar.Add("Event Time cannot be before preivious event", Severity.Error);
            return false;
        }
        if ((PreEvent != null && PreEvent.EventTypeID == currentEvent.EventTypeID))
        {
            snackbar.Add("Cannot enter an event twice in a row", Severity.Warning);
            return false;
        }

        if (DateTime.Compare(currentEvent.EventTime.Value, DateTime.Now.AddHours(-6)) < 0)
        {
            snackbar.Add("Cannot Start Trip 6 hours earlier!!", Severity.Warning);
            return false;
        }
        return true;
    }
}
