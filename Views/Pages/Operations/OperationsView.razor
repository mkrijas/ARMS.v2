@page "/operations"


@inject IBranchService Ibranch
@inject ITruckService Itruck
@inject IDriverService Idriver
@inject ITripService Itrip
@inject IEventService Ievent
@inject IGcService Igc
@inject IPlaceService Iplace
@inject MudBlazor.ISnackbar snackbar
@attribute [Authorize]
@inject AuthenticationStateProvider auth

@inject IDialogService DialogService

@using Pages.Truck


<MudGrid Spacing="4">

    <MudItem xs="12" md="6">
        <MudAutocomplete Clearable="true" T="TruckModel" Variant="Variant.Outlined" Label="Select Truck" ResetValueOnEmptyText="true" ValueChanged="IsTruckSelected"
            Value="SelectedTruck"  SearchFunc="Search" ToStringFunc="@(e => e == null ? null : $"{e.RegNo}")"></MudAutocomplete>
    </MudItem>
    <MudItem xs="12" md="6">
        @if (CurrentTrip != null)
        {
            <MudText hidden="@HideStatus" Typo="Typo.h4" Style="display:inline-block"><MudIcon Icon="@Icons.Filled.Transform" Title="Trip Number" Color="Color.Primary" /> @(CurrentTrip?.TripPrefix + CurrentTrip?.TripNumber)</MudText>
        }


        @if (AssignedDriver == null && SelectedTruck != null)
        {
            <MudText Typo="Typo.h4" Style="display:inline-block"><MudIcon Icon="@Icons.Filled.AirlineSeatReclineNormal" Title="Driver" Color="Color.Warning" /> UNASSAIGNED</MudText>
        }
        else if (AssignedDriver != null)
        {
            <MudText Typo="Typo.h4" Style="display:inline-block"><MudIcon Icon="@Icons.Filled.AirlineSeatReclineNormal" Title="Driver" Color="Color.Success" /> @AssignedDriver.DriverName</MudText>
        }
    </MudItem>
    <MudItem xs="12" md="12" hidden="@HideStatus">
        <h5> @TruckStatus    </h5>
    </MudItem>


    <MudItem xs="12" md="12" hidden="@HideControls">
        <MudButtonGroup Color="Color.Default" Variant="Variant.Filled">
            <MudButton StartIcon="@Icons.Material.Filled.AddTask" OnClick="UpdateEvent" IconColor="Color.Default" >@EventButtonLabel</MudButton>
            @if (CurrentTrip != null)
            {
                 <MudButton StartIcon="@Icons.Material.Outlined.Cancel" OnClick="CancelTrip" IconColor="Color.Error">Cancel Trip</MudButton>
            }
        <MudButton StartIcon="@Icons.Material.Filled.ReportProblem"  OnClick="ReportBreakDown" IconColor="Color.Secondary">Breakdown/Accident</MudButton>
        <MudButton StartIcon="@Icons.Material.Outlined.PersonAddAlt1"  OnClick="AssignDriver" IconColor="Color.Primary">@AssignDriverLabel</MudButton>
       @if (CurrentEvent?.EventTypeID == 2)
       {<MudButton StartIcon="@Icons.Material.Outlined.AddTask"  OnClick="AddConsignment" IconColor="Color.Tertiary">Load Consignment</MudButton>}
        <MudButton StartIcon="@Icons.Material.Outlined.Money"  OnClick="AddTransaction" IconColor="Color.Primary">Inc/Exp</MudButton>
        </MudButtonGroup>
    </MudItem>
</MudGrid>
@if (AssignedGCs != null)
{
    <MudGrid Spacing="4">
        @foreach (var gc in AssignedGCs)
        {
            <MudItem xs="4">
                <Views.Pages.Gc.GcItemCard item="gc"></Views.Pages.Gc.GcItemCard>
            </MudItem>
        }
    </MudGrid>
}
@code{
    [Parameter]
    public TruckModel SelectedTruck { get; set; }

    private List<TruckModel> Trucks;

    private DriverModel AssignedDriver { get; set; }
    private EventModel CurrentEvent { get; set; }
    private EventTypeModel EventType { get; set; }
    private TripModel CurrentTrip { get; set; }

    private List<GcSetModel> AssignedGCs { get; set; }




    string TruckStatus;
    string EventButtonLabel;
    string AssignDriverLabel;
    string OriginName;
    string DestnationName;

    private bool HideControls { get; set; } = true;
    public bool HideStatus { get; set; } = true;
    private bool DisableEventButton { get; set; } = false;
    private bool DisableCancelButton { get; set; } = true;

    protected override void OnInitialized()
    {
        Trucks = new();
        foreach (var item in Itruck.Select(0))
        {
            Trucks.Add(item);
        }


    }

    private async Task<IEnumerable<TruckModel>> Search(string searchString)
    {
        return await Task.FromResult(Trucks.Where(x => x.RegNo.Contains(searchString == null ? string.Empty : searchString, StringComparison.InvariantCultureIgnoreCase)));
    }


    private void GetTruckInfo()
    {
    }

    private async Task UpdateEvent()
    {
        var parameters = new DialogParameters();
        parameters.Add("Truck", SelectedTruck);
        parameters.Add("AssignedDriver", AssignedDriver);
        parameters.Add("CurrentEvent", CurrentEvent);

        if (EventButtonLabel == "Start New Trip")
        {
            var result = DialogService.Show<NewTripView>("Start Trip", parameters);
            var Data = await result.Result;
            CurrentTrip = (TripModel)Data.Data;
        }
        else
        {
            parameters.Add("CurrentTrip", CurrentTrip);
            var result = DialogService.Show<UpdateEventView>("Update Event", parameters);
            var Data = await result.Result;
            var ev = Data.Data;
        }

        truckStatusUpdated();
    }

    private void CancelTrip()
    {

    }

    private void ReportBreakDown()
    {

    }

    private async Task AssignDriver()
    {
        var parameters = new DialogParameters();
        parameters.Add("Truck", SelectedTruck);
        parameters.Add("AssignedDriver", AssignedDriver);
        var result = DialogService.Show<AssignDriverView>(AssignDriverLabel, parameters);
        var Data = await result.Result;
        var ev = Data.Data;
        AssignedDriver = (DriverModel)ev;
    }

    private async Task AddConsignment()
    {
        var parameters = new DialogParameters();
        parameters.Add("Truck", SelectedTruck);
        parameters.Add("TripID", CurrentTrip.TripID);
        DialogOptions maxWidth = new DialogOptions() { MaxWidth = MaxWidth.Large, FullWidth = true };
        var result = DialogService.Show<Pages.Gc.GcSelectDialog>("Load Consignment", parameters, maxWidth);
        var Data = await result.Result;
        var ev = Data.Data;
        AssignedGCs = Igc.SelectByTrip(CurrentTrip.TripID);
    }
    private async Task AddTransaction()
    {
        var parameters = new DialogParameters();
        parameters.Add("trip", CurrentTrip);
        DialogOptions maxWidth = new DialogOptions() { MaxWidth = MaxWidth.Large, FullWidth = true };
        var result = DialogService.Show<TransactionDialog>("Inc/Exp", parameters, maxWidth);
        var Data = await result.Result;
        var ev = Data.Data;
    }


    private async Task IsTruckSelected(TruckModel model)
    {
        SelectedTruck = model;
        truckStatusUpdated();
    }


    private void truckStatusUpdated()
    {
        if (SelectedTruck == null)
        {
            HideControls = true;
            HideStatus = true;
            CurrentEvent = null;
            EventType = null;
            AssignedGCs = null;
        }
        else
        {

            int? DriverID = Itruck.GetAssignedDriver(SelectedTruck.TruckID);

            AssignedDriver = DriverID == null ? null : Idriver.SelectByID(DriverID.Value);
            AssignDriverLabel = AssignedDriver == null ? "Assign Driver" : "Replace Driver";
            CurrentEvent = Ievent.GetCurrentEvent(SelectedTruck.TruckID);
            CurrentTrip = null;


            if (CurrentEvent != null)
            {
                HideStatus = false;
                EventType = Ievent.GetEventType(CurrentEvent.EventTypeID);
                CurrentTrip = Itrip.Select(CurrentEvent.TripID);
                OriginName = Task.Run(async () => await Iplace.SelectByID(CurrentEvent.OriginID)).Result.PlaceName;

                AssignedGCs = Igc.SelectByTrip(CurrentTrip.TripID);

                string TruckStatusAppend;
                if (!EventType.IsStationary)
                {
                    DestnationName = Task.Run(async () => await Iplace.SelectByID(CurrentEvent.DestinationID)).Result.PlaceName;
                    TruckStatusAppend = " From " + OriginName + " To " + DestnationName;
                }
                else
                {
                    TruckStatusAppend = " At " + OriginName;
                }

                TruckStatus = EventType?.EventStatusText + " On " + @CurrentEvent?.EventTime + TruckStatusAppend + " (Reported by " + Ibranch.GetBranchName(CurrentEvent.BranchID) + ")";
            }

            if (EventType != null && EventType.IsBlocking)
            {
                HideControls = true;
            }
            else
            if (EventType == null || EventType.EventStatusText == "UnAssigned")
            {
                HideControls = false;
                HideStatus = true;
                EventButtonLabel = "Start New Trip";

            }
            else
            {
                HideControls = false;
                HideStatus = false;
                EventButtonLabel = "Add Event";
            }
        }
    }

}