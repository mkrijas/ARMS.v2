@attribute [Authorize]
@inject AuthenticationStateProvider auth
@using System.Threading;
@inject IDistrictService Iservice
@inject MudBlazor.ISnackbar snackbar
@inject IRoleService<RoleModel> Irole
@inject IDialogService DialogService

<MudDialog Class="admin-dialog-glass">
    <TitleContent>
        <div class="header-section mb-2 pt-4 px-4">
            <div class="d-flex align-center justify-space-between">
                <div class="d-flex align-center">
                    <div class="icon-badge primary-badge mr-4">
                        <div class="admin-header-icon-badge mb-3">
                            <MudIcon Icon="@Icons.Material.Filled.LocationCity" Color="Color.Secondary" Style="font-size: 3rem;" />
                        </div>
                    </div>
                    <div>
                        <MudText Typo="Typo.h5" Class="admin-title"><b>District Management</b></MudText>
                        <MudText Typo="Typo.body2" Class="admin-subtitle">
                            Manage administrative districts and their associated states.
                        </MudText>
                    </div>
                </div>
            </div>
            <div class="title-accent mt-4"></div>
        </div>
    </TitleContent>
    <DialogContent>
        <MudContainer Class="admin-dialog-container">
            <div class="dialog-content-wrapper pa-4">
                <EditForm id="districtForm" Model="@model" OnValidSubmit="OnValidSubmit">
                    <div class="admin-glass-card pa-6">
                        <DataAnnotationsValidator />
                        <MudValidationSummary />
                        <MudGrid Spacing="3">
                            <MudItem xs="12">
                                <MudTextField @bind-Value="@model.DistrictName" Label="District Name" Variant="Variant.Outlined" Margin="Margin.Normal" For="@(() => model.DistrictName)" Class="modern-input"></MudTextField>
                            </MudItem>
                            <MudItem xs="12">
                                <MudAutocomplete T="StateModel" Label="State" Value="@model.State" ResetValueOnEmptyText="true" SearchFunc="@Search" ToStringFunc="@(e=> e==null?null : $"{e.StateName}")" Immediate="true" ValueChanged="StateSelected" Variant="Variant.Outlined" Class="modern-input"></MudAutocomplete>
                            </MudItem>
                        </MudGrid>
                    </div>
                </EditForm>
            </div>
        </MudContainer>
    </DialogContent>
    <DialogActions>
        <div class="d-flex w-100 flex-wrap pa-4 gap-3 align-center">
            <MudSpacer />
            <MudButton @onclick="Cancel" Variant="Variant.Outlined" Color="Color.Default" Style="border-radius: 12px; font-weight: 700; text-transform: none; border-color: rgba(0,0,0,0.15);">Discard</MudButton>
            <MudButton Disabled="@_busy" form="districtForm" Variant="Variant.Filled" ButtonType="ButtonType.Submit" Color="Color.Success" Style="background: var(--mud-palette-success); color: white; font-weight: 800; border-radius: 12px; text-transform: none; white-space: nowrap; padding: 8px 24px;" StartIcon="@Icons.Material.Filled.DoneAll">Synchronize District</MudButton>
        </div>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; }

    [Parameter]
    public DistrictModel model { get; set; }
    StateModel SelectedState = new();
    private List<StateModel> states = new();
    private bool _busy;

    private void Cancel() => MudDialog.Cancel();

    public bool HasPermissionDistrictServiceEdit { get; set; } = false;
    public int DistrictDocTypeID = 54;

    protected override async Task OnInitializedAsync()
    {
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionDistrictServiceEdit = await Irole.HasClaim(DistrictDocTypeID.ToString(), "Edit", ctc.Token);

        states = Iservice.GetStates().ToList();
    }

    private async Task<IEnumerable<StateModel>> Search(string searchString, CancellationToken token)
    {
        return await Task.FromResult(states.Where(x => x.StateName.Contains(searchString == null ? string.Empty : searchString, StringComparison.InvariantCultureIgnoreCase)));
    }

    private void StateSelected(StateModel state)
    {
        SelectedState = state;
        model.StateID = state?.StateID ?? null;
    }

    public static string ConvertToTitleCase(string input)
    {
        string[] words = input.Split(' ');
        string a = "";
        string b = "";
        for (int i = 0; i < words.Length; i++)
        {
            if (!string.IsNullOrEmpty(words[i]))
            {
                for (int j = 0; j < words[i].Length; j++)
                {
                    if (char.IsLetter(words[i][j]))
                    {
                        b = char.ToUpper(words[i][j]) + words[i].Substring(j + 1).ToLower();
                        break;
                    }
                    else
                    {
                        a = words[i][j].ToString();
                    }
                }
                words[i] = a + b;
                a = "";
            }
        }
        return string.Join(" ", words);
    }

    private async void OnValidSubmit(EditContext context)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is being submitted!", Severity.Warning);
            return;
        }
        if (HasPermissionDistrictServiceEdit)
        {
            _busy = true;
            var authprov = await auth.GetAuthenticationStateAsync();
            var user = authprov.User;
            model.UserInfo.UserID = user.Identity.Name;
            model.DistrictName = ConvertToTitleCase(model.DistrictName);

            try
            {
                model = Iservice.Update(model);
                MudDialog.Close(DialogResult.Ok(model));
                model = new DistrictModel();
                snackbar.Add("Saved Successfully", Severity.Success);
            }
            catch (Exception ex)
            {
                snackbar.Add(ex.Message, Severity.Warning);
            }
            await Task.Delay(200);
            _busy = false;
        }
        else
        {
            bool? ResultModel = await DialogService.ShowMessageBoxAsync(
                "Permission denied!",
                "You don't have any permission to Add or Edit District.");
        }
    }
}
