@attribute [Authorize]
@inject AuthenticationStateProvider auth
@using System.Threading;
@inject IDistrictService Iservice
@inject MudBlazor.ISnackbar snackbar
@inject IRoleService<RoleModel> Irole
@inject IDialogService DialogService

<MudDialog>
    <DialogContent>
        <EditForm id="districtForm" Model="@model" OnValidSubmit="OnValidSubmit">
            <DataAnnotationsValidator />
            <ValidationSummary />
            <MudTextField @bind-Value="@model.DistrictName" Label="District Name" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.DistrictName)"></MudTextField>
            <MudAutocomplete T="StateModel" Label="State" Value="@SelectedState" ResetValueOnEmptyText="true" SearchFunc="@Search" ToStringFunc="@(e=> e==null?null : $"{e.StateName}")" Immediate="true" ValueChanged="StateSelected" Variant="Variant.Outlined"></MudAutocomplete>
        </EditForm>
    </DialogContent>
    <DialogActions>
        <MudButton Disabled="@_busy" form="districtForm" Variant="Variant.Filled" Color="Color.Success" ButtonType="ButtonType.Submit">Submit</MudButton>
    </DialogActions>
</MudDialog>

@code {

    [Parameter]
    public DistrictModel model { get; set; }
    [CascadingParameter] MudDialogInstance MudDialog { get; set; }
    StateModel SelectedState = new();
    private List<StateModel> states = new();
    private bool _busy;

    public bool HasPermissionDistrictServiceEdit { get; set; } = false;
    public int DocTypeID = 54;

    protected override async Task OnInitializedAsync()
    {
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionDistrictServiceEdit = await Irole.HasClaim(DocTypeID.ToString(), "Edit", ctc.Token);

        states = Iservice.GetStates().ToList();
    }

    private async Task<IEnumerable<StateModel>> Search(string searchString)
    {
        return await Task.FromResult(states.Where(x => x.StateName.Contains(searchString == null ? string.Empty : searchString, StringComparison.InvariantCultureIgnoreCase)));
    }

    private void StateSelected(StateModel state)
    {
        SelectedState = state;
        model.StateID = state?.StateID ?? null;
    }

    private async void OnValidSubmit(EditContext context)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is being submitted!", Severity.Warning);
            return;
        }
        _busy = true;
        if (HasPermissionDistrictServiceEdit)
        {
            var authprov = await auth.GetAuthenticationStateAsync();
            var user = authprov.User;
            model.UserInfo.UserID = user.Identity.Name;
            try
            {
                model = Iservice.Update(model);
                MudDialog.Close(model);
                model = new DistrictModel();
                snackbar.Add("Saved Successfully", Severity.Success);
            }
            catch (Exception ex)
            {
                snackbar.Add(ex.Message, Severity.Warning);
            }
        }
        else
        {
            bool? ResultModel = await DialogService.ShowMessageBox(
                "Permission denied!",
                "You dont have any permission to Add or Edit District.");
        }
        await Task.Delay(2000);
        _busy = false;
    }
}