@page "/district"
@inject IDistrictService Iservice
@inject MudBlazor.ISnackbar snackbar
@inject AuthenticationStateProvider auth
@attribute [Authorize]
@inject IDialogService DialogService
@using System.Threading;
@using Microsoft.Data.SqlClient;
@inject IRoleService<RoleModel> Irole

<div class="admin-page-container">
    <div class="admin-header-tiered mb-6">
        <div class="d-flex align-center justify-space-between">
            <div>
                <MudText Typo="Typo.h4" Class="admin-title">District Management</MudText>
                <MudText Typo="Typo.body2" Class="admin-subtitle">Manage administrative districts and states for geographical organization and logistics planning.</MudText>
            </div>
            <MudButton StartIcon="@Icons.Material.Filled.Add" Variant="Variant.Filled" Color="Color.Primary" Class="admin-register-btn" OnClick="@(()=> OpenDialog(new DistrictModel()))" Disabled="@_busy">ADD DISTRICT</MudButton>
        </div>
    </div>

    <div class="admin-glass-card mb-6 pa-4">
        <div class="d-flex align-center gap-4">
            <div style="flex-grow: 1;">
                <MudTextField @bind-Value="searchDistrict" Placeholder="Search by district name..." Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" Variant="Variant.Outlined" Margin="Margin.Dense" Class="admin-input-group" Clearable="true" />
            </div>
        </div>
    </div>

    <div class="admin-glass-card pa-0 overflow-hidden">
        <MudTable Items="@collection" Elevation="0" Filter="new Func<DistrictModel, bool>(search)" Class="modern-admin-table">
            <HeaderContent>
                <MudTh><MudTableSortLabel SortBy="new Func<DistrictModel, object>(x=> x.DistrictName)" InitialDirection="SortDirection.Ascending"><span class="admin-header-text">DISTRICT NAME</span></MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<DistrictModel, object>(x=> x.State.StateName)" InitialDirection="SortDirection.Ascending"><span class="admin-header-text">STATE</span></MudTableSortLabel></MudTh>
                <MudTh Style="text-align: right;"><span class="admin-header-text">ACTIONS</span></MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="District Name"><MudText Typo="Typo.body2" Class="admin-td-primary">@context.DistrictName</MudText></MudTd>
                <MudTd DataLabel="State">@context.State.StateName</MudTd>
                <MudTd DataLabel="Actions" Style="text-align: right;">
                    <div class="d-flex justify-end gap-1">
                        <MudTooltip Text="Edit">
                            <MudIconButton OnClick="@(()=> OpenDialog(context))" Color="Color.Primary" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Variant="Variant.Text" />
                        </MudTooltip>
                        <MudTooltip Text="Delete">
                            <MudIconButton OnClick="@(()=> Delete(context))" Color="Color.Error" Icon="@Icons.Material.Filled.DeleteOutline" Size="Size.Small" Variant="Variant.Text" />
                        </MudTooltip>
                    </div>
                </MudTd>
            </RowTemplate>
            <PagerContent>
                <div class="pa-4">
                    <MudTablePager PageSizeOptions="new int[] { 10, 20, 50, 100 }" />
                </div>
            </PagerContent>
        </MudTable>
    </div>
</div>

    @code {

    private DistrictModel model = new DistrictModel();
    public List<DistrictModel> collection = new List<DistrictModel>();

    private string searchDistrict = "";
    private bool _busy;

    public bool HasPermissionPlaceServiceEdit { get; set; } = false;
    public bool HasPermissionPlaceServiceDelete { get; set; } = false;
    public int DistrictDocTypeID = 54;

    protected override async Task OnInitializedAsync()
    {
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionPlaceServiceEdit = await Irole.HasClaim(DistrictDocTypeID.ToString(), "Edit", ctc.Token);
        HasPermissionPlaceServiceDelete = await Irole.HasClaim(DistrictDocTypeID.ToString(), "Delete", ctc.Token);

        await GetAll();
    }

    private async Task GetAll()
    {
        collection = Iservice.Select(0).ToList();
    }

    private async void Delete(DistrictModel model)
    {
        if (HasPermissionPlaceServiceDelete)
        {
            bool? result = await DialogService.ShowMessageBoxAsync(
                "Warning !",
                "Are you sure, you want to delete - " + model.DistrictName + " ?");
            if (result == true)
            {
                try
                {
                    var authprov = await auth.GetAuthenticationStateAsync();
                    var user = authprov.User;
                    Iservice.Delete(model.DistrictID, user.Identity.Name);
                    StateHasChanged();
                    snackbar.Add("Deleted Successfully", Severity.Success);
                }
                catch (SqlException ex)
                {
                    if (ex.Number == 547)
                    {
                        bool? value = await DialogService.ShowMessageBoxAsync(
                            "Warning !",
                            model.DistrictName + " is already in use !");
                    }
                    else
                    {
                        snackbar.Add(ex.Message, Severity.Warning);
                    }
                }
            }
            await GetAll();
        }
        else
        {
            bool? result = await DialogService.ShowMessageBoxAsync(
                "Permission denied!",
                "You don't have any permission to Delete District.");
        }
    }

    private bool search(DistrictModel district)
    {
        if (district.DistrictName != null && district.DistrictName.Contains(searchDistrict, StringComparison.OrdinalIgnoreCase))
        {
            return true;
        }
        return false;
    }

    private async Task OpenDialog(DistrictModel model)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        _busy = true;

        if (HasPermissionPlaceServiceEdit)
        {
            DialogParameters parms = new DialogParameters();
            parms.Add("model", model.Clone());
            var dialog = await DialogService.ShowAsync<DistrictDialogue>("District", parms);
            var result = await dialog.Result;
        }
        else
        {
            bool? ResultModel = await DialogService.ShowMessageBoxAsync(
                "Permission denied!",
                "You don't have any permission to Edit District.");
        }
        await GetAll();
        await Task.Delay(200);
        _busy = false;
    }
}

