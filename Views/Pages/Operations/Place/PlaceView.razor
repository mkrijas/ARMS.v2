@page "/place"
@inject IPlaceService Iservice
@inject IDistrictService Idistrict
@inject MudBlazor.ISnackbar snackbar
@inject AuthenticationStateProvider auth
@attribute [Authorize]
@inject IDialogService DialogService
@using System.Threading;
@inject IRoleService<RoleModel> Irole

@if (_isLoading)
{
    <div @key="@("loader")" style="display: flex; justify-content: center; align-items: center; min-height: 400px;">
        <LoaderComponent IsFullScreen="true" 
                        ShowLogo="false" 
                        Size="medium" 
                        LoadingText="Loading Places" 
                        SubText="Please wait..." />
    </div>
}
else
{
<div class="admin-page-container fade-in" @key="@("content")">
    <div class="admin-header-tiered mb-6">
        <div class="d-flex align-center justify-space-between">
            <div>
                <MudText Typo="Typo.h4" Class="admin-title">Locality Master</MudText>
                <MudText Typo="Typo.body2" Class="admin-subtitle">Manage granular location data, pincodes, and logistical route points.</MudText>
            </div>
            <MudButton StartIcon="@Icons.Material.Filled.Add" Variant="Variant.Filled" Color="Color.Primary" Class="admin-register-btn" OnClick="@(()=> OpenDialog(new PlaceModel()))" Disabled="@_busy">ADD LOCALITY</MudButton>
        </div>
    </div>

    <div class="admin-glass-card mb-6 pa-4">
        <div class="d-flex align-center gap-4">
            <div style="flex-grow: 1;">
                <MudTextField @bind-Value="searchPlace" Placeholder="Search by locality name or pincode..." Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" Variant="Variant.Outlined" Margin="Margin.Dense" Class="admin-input-group" Clearable="true" />
            </div>
        </div>
    </div>

    <div class="admin-glass-card pa-0 overflow-hidden">
        <MudTable Items="@collection" Elevation="0" Filter="new Func<PlaceModel, bool>(search)" Class="modern-admin-table" Hover="true">
            <HeaderContent>
                <MudTh><MudTableSortLabel SortBy="new Func<PlaceModel, object>(x=> x.PlaceName)" InitialDirection="SortDirection.Ascending"><span class="admin-header-text">LOCALITY NAME</span></MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<PlaceModel, object>(x=> x.PinCode)" InitialDirection="SortDirection.Ascending"><span class="admin-header-text">PINCODE / ZIP</span></MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<PlaceModel, object>(x=> x.District.DistrictName)" InitialDirection="SortDirection.Ascending"><span class="admin-header-text">DISTRICT / REGION</span></MudTableSortLabel></MudTh>
                <MudTh Style="text-align: right;"><span class="admin-header-text">ACTIONS</span></MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Place"><span class="admin-td-primary fw-600">@context.PlaceName</span></MudTd>
                <MudTd DataLabel="PinCode">@context.PinCode</MudTd>
                <MudTd DataLabel="DistrictName">@context.District.DistrictName</MudTd>
                <MudTd DataLabel="Actions" Style="text-align: right;">
                    <div class="d-flex justify-end gap-1">
                        <MudTooltip Text="Edit Parameters">
                            <MudIconButton OnClick="@(()=> OpenDialog(context))" Color="Color.Primary" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Variant="Variant.Text" />
                        </MudTooltip>
                        <MudTooltip Text="Delete Locality">
                            <MudIconButton OnClick="@(()=> Delete(context))" Color="Color.Error" Icon="@Icons.Material.Filled.DeleteOutline" Size="Size.Small" Variant="Variant.Text" />
                        </MudTooltip>
                    </div>
                </MudTd>
            </RowTemplate>
            <PagerContent>
                <div class="pa-4">
                    <MudTablePager PageSizeOptions="new int[] { 10, 20, 50, 100 }" />
                </div>
            </PagerContent>
        </MudTable>
    </div>
</div>
}



@code {

    private bool _isLoading = true;
    private DateTime _loadStartTime;

    private PlaceModel model = new PlaceModel();
    private List<PlaceModel> collection = new List<PlaceModel>();
    public List<DistrictModel> districts = new List<DistrictModel>();

    private string searchPlace = "";
    private bool _busy;
    public bool HasPermissionPlaceServiceEdit { get; set; } = false;
    public bool HasPermissionPlaceServiceDelete { get; set; } = false;
    public int DocTypeID = 44;

    protected override async Task OnInitializedAsync()
    {
        _loadStartTime = DateTime.Now;
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionPlaceServiceEdit = await Irole.HasClaim(DocTypeID.ToString(), "Edit", ctc.Token);
        HasPermissionPlaceServiceDelete = await Irole.HasClaim(DocTypeID.ToString(), "Delete", ctc.Token);

        await GetAll();
        await EnsureMinimumLoadTime();
        _isLoading = false;
    }

    private async Task EnsureMinimumLoadTime()
    {
        var elapsed = (DateTime.Now - _loadStartTime).TotalMilliseconds;
        if (elapsed < 100)
        {
            await Task.Delay(100 - (int)elapsed);
        }
    }

    private async Task<IEnumerable<DistrictModel>> Search(string searchString)
    {
        return await Task.FromResult(districts.Where(x => x.DistrictName.Contains(searchString == null ? string.Empty : searchString, StringComparison.InvariantCultureIgnoreCase)));
    }

    private async Task GetAll()
    {
        collection = Iservice.Select(0, null).ToList();
    }

    private async void Delete(PlaceModel model)
    {
        if (HasPermissionPlaceServiceDelete)
        {
            bool? result = await DialogService.ShowMessageBoxAsync(
                "Warning !",
                "Are you sure, you want to delete - " + model.PlaceName + " ?");
            if (result == true)
            {
                var authprov = await auth.GetAuthenticationStateAsync();
                var user = authprov.User;
                await Iservice.Delete(model.PlaceID, user.Identity.Name);
                snackbar.Add("Deleted Successfully", Severity.Success);
            }
        }
        else
        {
            bool? result = await DialogService.ShowMessageBoxAsync(
                "Permission denied!",
                "You don't have any permission to Delete Place.");
        }
        await GetAll();
        StateHasChanged();
    }

    private bool search(PlaceModel place)
    {
        if (place.PlaceName != null && place.PlaceName.Contains(searchPlace, StringComparison.OrdinalIgnoreCase))
        {
            return true;
        }
        return false;
    }

    private async Task OpenDialog(PlaceModel model)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        _busy = true;
        if (HasPermissionPlaceServiceEdit)
        {
            DialogParameters parms = new DialogParameters();
            parms.Add("placemodel", model.Clone());
            var dialog = await DialogService.ShowAsync<PlaceDilogue>("PLACE", parms);
            var result = await dialog.Result;
        }
        else
        {
            bool? ResultModel = await DialogService.ShowMessageBoxAsync(
                "Permission denied!",
                "You don't have any permission to Add or Edit Place.");
        }
        await GetAll();
        await Task.Delay(200);
        _busy = false;
    }
}

