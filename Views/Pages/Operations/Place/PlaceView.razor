@page "/place"
@inject IPlaceService Iservice
@inject IDistrictService Idistrict
@inject MudBlazor.ISnackbar snackbar
@inject AuthenticationStateProvider auth
@attribute [Authorize]
@inject IDialogService DialogService

@using System.Threading;
@inject IRoleService<RoleModel> Irole

<MudGrid Spacing="4">
    <MudItem xs="12">
        <MudTable Items="@collection" Elevation="10" Filter="new Func<PlaceModel, bool>(search)" @bind-place="model">
            <ToolBarContent>
                <MudText Typo="Typo.h6">Manage Places</MudText>
                <MudIconButton Icon="@Icons.Material.Filled.Add" Title="Add" @onclick="@(()=> OpenDialog(new PlaceModel()))" Color="Color.Dark" Size="Size.Small"></MudIconButton>

                <MudSpacer></MudSpacer>

                <MudTextField @bind-Value="searchPlace" Placeholder="Search Places... "
                              Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                              IconSize="Size.Medium" Class="mt-0"></MudTextField>
            </ToolBarContent>

            <HeaderContent>
                <MudTh><MudTableSortLabel SortBy="new Func<PlaceModel, object>(x=> x.PlaceName)" InitialDirection="SortDirection.Ascending">Place</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<PlaceModel, object>(x=> x.PinCode)" InitialDirection="SortDirection.Ascending">PinCode</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<PlaceModel, object>(x=> x.District.DistrictName)" InitialDirection="SortDirection.Ascending">District</MudTableSortLabel></MudTh>
                <MudTh>Action</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Place">@context.PlaceName</MudTd>
                <MudTd DataLabel="PinCode">@context.PinCode</MudTd>
                <MudTd DataLabel="DistrictName">@context.District.DistrictName</MudTd>
                <MudTd DataLabel="">
                    <MudFab @onclick="@(()=> OpenDialog(context))" Color="Color.Primary" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" IconSize="Size.Small" />
                    <MudFab @onclick="@(()=> Delete(context.PlaceID))" Color="Color.Primary" Icon="@Icons.Material.Filled.Delete" Size="Size.Small" IconSize="Size.Small" />
                </MudTd>
            </RowTemplate>
            <PagerContent>
                <MudTablePager PageSizeOptions="new int[] { 5, 10, 20, 50, 100 }" />
            </PagerContent>
        </MudTable>
    </MudItem>
</MudGrid>

@code {

    private PlaceModel model = new PlaceModel();
    private List<PlaceModel> collection = new List<PlaceModel>();
    public List<DistrictModel> districts = new List<DistrictModel>();

    private string searchPlace = "";

    public bool HasPermissionPlaceServiceEdit { get; set; } = false;
    public bool HasPermissionPlaceServiceDelete { get; set; } = false;
    public int DocTypeID = 44;

    protected override async Task OnInitializedAsync()
    {
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionPlaceServiceEdit = await Irole.HasClaim(DocTypeID.ToString(), "Edit", ctc.Token);
        HasPermissionPlaceServiceDelete = await Irole.HasClaim(DocTypeID.ToString(), "Delete", ctc.Token);

        GetAll();
    }


    private async Task<IEnumerable<DistrictModel>> Search(string searchString)
    {
        return await Task.FromResult(districts.Where(x => x.DistrictName.Contains(searchString == null ? string.Empty : searchString, StringComparison.InvariantCultureIgnoreCase)));
    }


    private void GetAll()
    {
        collection = Iservice.Select(0).ToList();
    }


    private async void Delete(int? id)
    {
        if (HasPermissionPlaceServiceDelete)
        {
            await Iservice.Delete(id, "Rijas");
            snackbar.Add("Deleted Successfully", Severity.Success);
            GetAll();
        }
        else
        {
            bool? result = await DialogService.ShowMessageBox(
              "Permission denied!",
              "You dont have any permission to Delete Place.");
        }
    }


    private bool search(PlaceModel place)
    {
        if (place.PlaceName != null && place.PlaceName.Contains(searchPlace, StringComparison.OrdinalIgnoreCase))
        {
            return true;
        }
        return false;
    }


    private async Task OpenDialog(PlaceModel model)
    {
        if (HasPermissionPlaceServiceEdit)
        {
            DialogParameters parms = new DialogParameters();
            parms.Add("placemodel", model);
            DialogService.Show<PlaceDilogue>("ADD/EDIT PLACE", parms);
            GetAll();
        }
        else
        {
            bool? ResultModel = await DialogService.ShowMessageBox(
                "Permission denied!",
                "You dont have any permission to Add or Edit Place.");
        }
    }
}