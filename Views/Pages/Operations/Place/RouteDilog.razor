@attribute [Authorize]
@inject AuthenticationStateProvider auth
@using System.Threading;
@inject IRouteService Iservice
@inject IPlaceService Iplace
@inject MudBlazor.ISnackbar snackbar
@inject IDialogService DialogService
@inject IRoleService<RoleModel> Irole

<MudDialog Class="admin-dialog-glass">
    <TitleContent>
        <div class="header-section mb-2 pt-4 px-4">
            <div class="d-flex align-center justify-space-between">
                <div class="d-flex align-center">
                    <div class="icon-badge primary-badge mr-4">
                        <div class="admin-header-icon-badge mb-3">
                            <MudIcon Icon="@Icons.Material.Filled.AltRoute" Color="Color.Secondary" Style="font-size: 3rem;" />
                        </div>
                    </div>
                    <div>
                        <MudText Typo="Typo.h5" Class="admin-title"><b>Route Configuration</b></MudText>
                        <MudText Typo="Typo.body2" Class="admin-subtitle">
                            Define transit routes, speed limits, and distance parameters.
                        </MudText>
                    </div>
                </div>
            </div>
            <div class="title-accent mt-4"></div>
        </div>
    </TitleContent>
    <DialogContent>
        <MudContainer Class="admin-dialog-container">
            <div class="dialog-content-wrapper pa-4">
                <EditForm id="routeForm" Model="@routemodel" OnValidSubmit="SubmitRoute">
                    <div class="admin-glass-card pa-6">
                        <ObjectGraphDataAnnotationsValidator />
                        <MudValidationSummary />
                        @if (ValidationMessageOrgin != null)
                        {
                            <div class="validation-message mb-2">@(ValidationMessageOrgin)</div>
                        }
                        @if (ValidationMessageDestination != null)
                        {
                            <div class="validation-message mb-4">@(ValidationMessageDestination)</div>
                        }
                        <MudGrid Spacing="3">
                            <MudItem xs="12" md="4">
                                <MudAutocomplete SelectValueOnTab T="PlaceModel" Label="Origin" Value="@routemodel.Origin" ResetValueOnEmptyText="true" SearchFunc="@(async (string s, CancellationToken t) => await Search(s, t))" ValueChanged="@ValidateOrgine" ToStringFunc="@(e=> e==null?null : $"{e.PlaceName}")"
                                                 Variant="Variant.Outlined" Immediate="true" MaxItems="50" Class="modern-input"></MudAutocomplete>
                            </MudItem>
                            <MudItem xs="12" md="4">
                                <MudAutocomplete SelectValueOnTab T="PlaceModel" Label="Via (Optional)" @bind-Value="@routemodel.Via" ResetValueOnEmptyText="true" SearchFunc="@(async (string s, CancellationToken t) => await Search(s, t))" ToStringFunc="@(e=> e==null?null : $"{e.PlaceName}")"
                                                 Variant="Variant.Outlined" Immediate="true" MaxItems="50" Class="modern-input"></MudAutocomplete>
                            </MudItem>
                            <MudItem xs="12" md="4">
                                <MudAutocomplete SelectValueOnTab T="PlaceModel" Label="Destination" Value="@routemodel.Destination" ResetValueOnEmptyText="true" SearchFunc="@(async (string s, CancellationToken t) => await Search(s, t))" ValueChanged="@ValidateDestination" ToStringFunc="@(e=> e==null?null : $"{e.PlaceName}")"
                                                 Variant="Variant.Outlined" Immediate="true" Adornment="Adornment.End" AdornmentIcon="@Icons.Material.Filled.Add" OnAdornmentClick="AddPlace" AdornmentAriaLabel="Add Place" MaxItems="50" Class="modern-input"></MudAutocomplete>
                            </MudItem>                
                            <MudItem xs="12" md="4">
                                <MudNumericField HideSpinButtons="true" @bind-Value="@routemodel.SpeedLimit" Label="Speed Limit (km/h)" Variant="Variant.Outlined" Margin="Margin.Normal" For="@(() => routemodel.SpeedLimit)" Class="modern-input"></MudNumericField>
                            </MudItem>
                            <MudItem xs="12" md="4">
                                <MudNumericField HideSpinButtons="true" @bind-Value="@routemodel.RunningHours" Label="Est. Running Hours" Variant="Variant.Outlined" Margin="Margin.Normal" For="@(() =>routemodel.RunningHours)" Class="modern-input"></MudNumericField>
                            </MudItem>
                            <MudItem xs="12" md="4">
                                <MudNumericField @bind-Value="@routemodel.TollBooths" Label="Count of Toll Booths" Variant="Variant.Outlined" Margin="Margin.Normal" For="@(() => routemodel.TollBooths)" Class="modern-input"></MudNumericField>
                            </MudItem>
                            <MudItem xs="12" md="3">
                                <MudNumericField HideSpinButtons="true" @bind-Value="@routemodel.Distance" Label="Distance (Client)" Variant="Variant.Outlined" Margin="Margin.Normal" For="@(() => routemodel.Distance)" Class="modern-input"></MudNumericField>
                            </MudItem>
                            <MudItem xs="12" md="3">
                                <MudNumericField HideSpinButtons="true" @bind-Value="@routemodel.DistanceInGps" Label="Distance (GPS)" Variant="Variant.Outlined" Margin="Margin.Normal" For="@(() => routemodel.DistanceInGps)" Class="modern-input"></MudNumericField>
                            </MudItem>
                            <MudItem xs="12" md="3">
                                <MudTextField @bind-Value="@routemodel.MileageModifierPercentage" Label="Mileage Modifier %" Adornment="Adornment.End" AdornmentText="%" Variant="Variant.Outlined" Margin="Margin.Normal" For="@(() => routemodel.MileageModifierPercentage)" Class="modern-input"></MudTextField>
                            </MudItem>
                            <MudItem xs="12" md="3">
                                <MudNumericField ReadOnly="(!HasPermissionRouteServiceModify && routemodel.RouteID != null)" HideSpinButtons="true" @bind-Value="@routemodel.SettledKm" Label="Settled KM" Variant="Variant.Outlined" Margin="Margin.Normal" For="@(() => routemodel.SettledKm)" Class="modern-input"></MudNumericField>
                            </MudItem>
                            <MudItem xs="12">
                                <div class="px-2 py-1">
                                    <MudText Typo="Typo.subtitle2" Class="mb-2">Route Classification</MudText>
                                    <MudRadioGroup T="string" @bind-Value="@routemodel.RouteType" Class="admin-radio-group">
                                        @foreach (var rtype in RouteTypes)
                                        {
                                            <MudRadio T="string" Value="@rtype" Color="Color.Primary" Dense="true">@rtype</MudRadio>
                                        }
                                    </MudRadioGroup>
                                </div>
                            </MudItem>
                        </MudGrid>
                    </div>
                </EditForm>
            </div>
        </MudContainer>
    </DialogContent>
    <DialogActions>
        <div class="d-flex w-100 flex-wrap pa-4 gap-3 align-center">
            <MudSpacer />
            <MudButton @onclick="Cancel" Variant="Variant.Outlined" Color="Color.Default" Style="border-radius: 12px; font-weight: 700; text-transform: none; border-color: rgba(0,0,0,0.15);">Discard</MudButton>
            <MudButton Disabled="@_busy" form="routeForm" Variant="Variant.Filled" ButtonType="ButtonType.Submit" Color="Color.Success" @onclick="@(() => ValidateOrgineAndDestination())" Style="background: var(--mud-palette-success); color: white; font-weight: 800; border-radius: 12px; text-transform: none; white-space: nowrap; padding: 8px 24px;" StartIcon="@Icons.Material.Filled.DoneAll">Save Route</MudButton>
        </div>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; }

    [Parameter]
    public RouteModel routemodel { get; set; }
    public List<PlaceModel> places = new List<PlaceModel>();
    private List<string> RouteTypes = new List<string>() { "Highland", "City", "Highway", "Other" };
    private string searchRoute = "";
    private bool _busy;

    public string ValidationMessageOrgin = null;
    public string ValidationMessageDestination = null;
    public bool HasPermissionRouteServiceEdit { get; set; } = false;
    public bool HasPermissionRouteServiceModify { get; set; } = false;
    public int DocTypeID = 43;

    protected override async Task OnInitializedAsync()
    {
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionRouteServiceEdit = await Irole.HasClaim(DocTypeID.ToString(), "Edit", ctc.Token);
        HasPermissionRouteServiceModify = await Irole.HasClaim(DocTypeID.ToString(), "Modify", ctc.Token);

        places = Iplace.Select(0, null).ToList();
        if (routemodel?.RouteID != null)
        {
            routemodel.Origin = places.FirstOrDefault(x => x.PlaceID == routemodel.Origin.PlaceID);
            routemodel.Via = places.FirstOrDefault(x => x.PlaceID == routemodel.Via.PlaceID);
            routemodel.Destination = places.FirstOrDefault(x => x.PlaceID == routemodel.Destination.PlaceID);
        }
    }

    private async Task<IEnumerable<PlaceModel>> Search(string searchString, CancellationToken token)
    {
        return await Task.FromResult(places.Where(x => x.PlaceName.Contains(searchString == null ? string.Empty : searchString, StringComparison.InvariantCultureIgnoreCase)));
    }

    private async Task SubmitRoute(EditContext context)
    {
        if (routemodel.Origin == null || routemodel.Origin.PlaceID == null || routemodel.Destination == null || routemodel.Destination.PlaceID == null)
        {
            if (routemodel.Origin == null || routemodel.Origin.PlaceID == null)
            {
                ValidationMessageOrgin = "Please select origin. \n";
            }

            if (routemodel.Destination == null || routemodel.Destination.PlaceID == null)
            {
                ValidationMessageDestination = "Please select destination. \n";
            }
            return;

        }

        if (_busy)
        {
            snackbar.Add("Please wait while form is being submitted!", Severity.Warning);
            return;
        }

        ValidationMessageOrgin = null;
        ValidationMessageDestination = null;
        if (HasPermissionRouteServiceEdit)
        {
            if (!places.Select(x => x.PlaceName).Contains(routemodel.Origin.PlaceName))
            {
                snackbar.Add("Invalid Origin", Severity.Error);
                return;
            }
            //else
            //     if (!places.Select(x => x.PlaceName).Contains(routemodel.Via.PlaceName))
            //{
            //    snackbar.Add("Invalid Via", Severity.Error);
            //    return;
            //}
            else
            if (!places.Select(x => x.PlaceName).Contains(routemodel.Destination.PlaceName))
            {
                snackbar.Add("Invalid Destination", Severity.Error);
                return;
            }
            _busy = true;
            var authprov = await auth.GetAuthenticationStateAsync();
            routemodel.UserInfo.UserID = authprov.User.Identity.Name;
            if (string.IsNullOrEmpty(routemodel.Via?.PlaceName??null))
            {
                if (routemodel.Via == null)
                {
                    routemodel.Via = new();
                }
                routemodel.Via.PlaceName = string.Empty;
                routemodel.RouteName = routemodel.Origin.PlaceName + "-" + routemodel.Destination.PlaceName;
            }
            else
            {
                routemodel.RouteName = routemodel.Origin.PlaceName + "-" + routemodel.Via.PlaceName + "-" + routemodel.Destination.PlaceName;

            }
            try
            {
                routemodel = await Iservice.Update(routemodel);
                snackbar.Add("Saved Successfully", Severity.Success);
                MudDialog.Close(DialogResult.Ok(routemodel));
                routemodel = new RouteModel();
            }
            catch (Exception ex)
            {
                snackbar.Add(ex.Message, Severity.Warning);
            }
            await Task.Delay(200);
            _busy = false;
        }
        else
        {
            bool? ResultModel = await DialogService.ShowMessageBoxAsync(
                "Permission denied!",
                "You don't have any permission to Add or Edit Route.");
        }
    }

    private void ValidateOrgine(PlaceModel obj)
    {
        routemodel.Origin = obj;
        if (routemodel.Origin == null || routemodel.Origin.PlaceID == null)
        {
            ValidationMessageOrgin = "Please select origin. \n";
        }

        else
        {
            ValidationMessageOrgin = null;
        }
    }

    private void ValidateDestination(PlaceModel obj)
    {
        routemodel.Destination = obj;
        if (routemodel.Destination == null || routemodel.Destination.PlaceID == null)
        {
            ValidationMessageDestination = "Please select destination. \n";
        }
        else
        {
            ValidationMessageDestination = null;
        }
    }

    private void ValidateOrgineAndDestination()
    {

        if (routemodel.Origin == null || routemodel.Origin.PlaceID == null || routemodel.Destination == null || routemodel.Destination.PlaceID == null)
        {
            if (routemodel.Origin == null || routemodel.Origin.PlaceID == null)
            {
                ValidationMessageOrgin = "Please select origin. \n";
            }

            if (routemodel.Destination == null || routemodel.Destination.PlaceID == null)
            {
                ValidationMessageDestination = "Please select destination. \n";
            }
        }
        else
        {
            ValidationMessageOrgin = null;
            ValidationMessageDestination = null;
        }
    }

    private async Task AddPlace()
    {
        DialogParameters parms = new DialogParameters();
        PlaceModel placeModel = new();
        parms.Add("placemodel", placeModel.Clone());
        var dialog = await DialogService.ShowAsync<PlaceDilogue>("ADD/EDIT PLACE", parms);
        var result = await dialog.Result;
        if (!result.Canceled)
        {
            places = Iplace.Select(0, null).ToList();
        }
    }
    private void Cancel() => MudDialog.Cancel();
}
