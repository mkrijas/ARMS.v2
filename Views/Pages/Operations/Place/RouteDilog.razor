@attribute [Authorize]
@inject AuthenticationStateProvider auth
@using System.Threading;
@inject IRouteService Iservice
@inject IPlaceService Iplace
@inject MudBlazor.ISnackbar snackbar
@inject IDialogService DialogService
@inject IRoleService<RoleModel> Irole

<MudDialog>
    <DialogContent>
        <EditForm id="routeForm" Model="@routemodel" OnValidSubmit="OnValidSubmit">
            <ObjectGraphDataAnnotationsValidator />
            <ValidationSummary />
            @if (ValidationMessageOrgin != null)
            {
                <div class="validation-message">@(ValidationMessageOrgin)</div>
            }
            @if (ValidationMessageDestination != null)
            {
                <div class="validation-message">@(ValidationMessageDestination)</div>
            }
            <MudGrid>
                <MudItem xs="12" md="4">
                    <MudAutocomplete SelectValueOnTab T="PlaceModel" Label="Origin" Value="@routemodel.Origin" ResetValueOnEmptyText="true" SearchFunc="@Search" ValueChanged="@ValidateOrgine" ToStringFunc="@(e=> e==null?null : $"{e.PlaceName}")"
                                     Variant="Variant.Outlined" Immediate="true"></MudAutocomplete>
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudAutocomplete SelectValueOnTab T="PlaceModel" Label="Via" @bind-Value="@routemodel.Via" ResetValueOnEmptyText="true" SearchFunc="@Search" ToStringFunc="@(e=> e==null?null : $"{e.PlaceName}")"
                                     Variant="Variant.Outlined" Immediate="true"></MudAutocomplete>
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudAutocomplete SelectValueOnTab T="PlaceModel" Label="Destination" Value="@routemodel.Destination" ResetValueOnEmptyText="true" SearchFunc="@Search" ValueChanged="@ValidateDestination" ToStringFunc="@(e=> e==null?null : $"{e.PlaceName}")"
                                     Variant="Variant.Outlined" Immediate="true" Adornment="Adornment.End" AdornmentIcon="@Icons.Material.Filled.Add" OnAdornmentClick="AddPlace" AdornmentAriaLabel="Add Place"></MudAutocomplete>
                </MudItem>
                <MudItem xs="12" md="3">
                    <MudNumericField HideSpinButtons="true" @bind-Value="@routemodel.Distance" Label="Distance" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => routemodel.Distance)"></MudNumericField>
                </MudItem>
                <MudItem xs="12" md="3">
                    <MudNumericField HideSpinButtons="true" @bind-Value="@routemodel.SpeedLimit" Label="Speed Limit" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => routemodel.SpeedLimit)"></MudNumericField>
                </MudItem>
                <MudItem xs="12" md="3">
                    <MudNumericField HideSpinButtons="true" @bind-Value="@routemodel.RunningHours" Label="Running Hours" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() =>routemodel.RunningHours)"></MudNumericField>
                </MudItem>
                <MudItem xs="12" md="3">
                    <MudNumericField @bind-Value="@routemodel.TollBooths" Label="No of TollBooths" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => routemodel.TollBooths)"></MudNumericField>
                </MudItem>
                <MudItem xs="12">
                    <MudRadioGroup @bind-SelectedOption="@routemodel.RouteType">
                        @foreach (var rtype in RouteTypes)
                        {
                            <MudRadio Option="@rtype" Color="Color.Primary">@rtype</MudRadio>
                        }
                    </MudRadioGroup>
                </MudItem>
            </MudGrid>
        </EditForm>
    </DialogContent>
    <DialogActions>
        <MudButton Disabled="@_busy" form="routeForm" Variant="Variant.Filled" Color="Color.Success" @onclick="@(() => ValidateOrgineAndDestination())" ButtonType="ButtonType.Submit">Save Route</MudButton>
    </DialogActions>
</MudDialog>

@code {

    [Parameter]
    public RouteModel routemodel { get; set; }
    [CascadingParameter] MudDialogInstance MudDialog { get; set; }
    public List<PlaceModel> places = new List<PlaceModel>();
    private List<string> RouteTypes = new List<string>() { "Highland", "City", "Highway", "Other" };
    private string searchRoute = "";
    private bool _busy;

    public string ValidationMessageOrgin = null;
    public string ValidationMessageDestination = null;
    public bool HasPermissionRouteServiceEdit { get; set; } = false;
    public int DocTypeID = 43;

    protected override async Task OnInitializedAsync()
    {
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionRouteServiceEdit = await Irole.HasClaim(DocTypeID.ToString(), "Edit", ctc.Token);

        places = Iplace.Select(0, null).ToList();
        if (routemodel?.RouteID != null)
        {
            routemodel.Origin = places.FirstOrDefault(x => x.PlaceID == routemodel.Origin.PlaceID);
            routemodel.Via = places.FirstOrDefault(x => x.PlaceID == routemodel.Via.PlaceID);
            routemodel.Destination = places.FirstOrDefault(x => x.PlaceID == routemodel.Destination.PlaceID);
        }
    }

    private async Task<IEnumerable<PlaceModel>> Search(string searchString)
    {
        return await Task.FromResult(places.Where(x => x.PlaceName.Contains(searchString == null ? string.Empty : searchString, StringComparison.InvariantCultureIgnoreCase)));
    }

    private async Task OnValidSubmit(EditContext context)
    {
        if (routemodel.Origin == null || routemodel.Origin.PlaceID == null || routemodel.Destination == null || routemodel.Destination.PlaceID == null)
        {
            if (routemodel.Origin == null || routemodel.Origin.PlaceID == null)
            {
                ValidationMessageOrgin = "Please select origin. \n";
            }

            if (routemodel.Destination == null || routemodel.Destination.PlaceID == null)
            {
                ValidationMessageDestination = "Please select destination. \n";
            }
            return;

        }

        if (_busy)
        {
            snackbar.Add("Please wait while form is being submitted!", Severity.Warning);
            return;
        }

        ValidationMessageOrgin = null;
        ValidationMessageDestination = null;
        if (HasPermissionRouteServiceEdit)
        {
            if (!places.Select(x => x.PlaceName).Contains(routemodel.Origin.PlaceName))
            {
                snackbar.Add("Invalid Origin", Severity.Error);
                return;
            }
            //else
            //     if (!places.Select(x => x.PlaceName).Contains(routemodel.Via.PlaceName))
            //{
            //    snackbar.Add("Invalid Via", Severity.Error);
            //    return;
            //}
            else
            if (!places.Select(x => x.PlaceName).Contains(routemodel.Destination.PlaceName))
            {
                snackbar.Add("Invalid Destination", Severity.Error);
                return;
            }
            _busy = true;
            var authprov = await auth.GetAuthenticationStateAsync();
            routemodel.UserInfo.UserID = authprov.User.Identity.Name;
            if (string.IsNullOrEmpty(routemodel.Via?.PlaceName??null))
            {
                if (routemodel.Via == null)
                {
                    routemodel.Via = new();
                }
                routemodel.Via.PlaceName = string.Empty;
                routemodel.RouteName = routemodel.Origin.PlaceName + "-" + routemodel.Destination.PlaceName;
            }
            else
            {
                routemodel.RouteName = routemodel.Origin.PlaceName + "-" + routemodel.Via.PlaceName + "-" + routemodel.Destination.PlaceName;

            }
            routemodel.MieageModifier = 1;
            try
            {
                routemodel = await Iservice.Update(routemodel);
                snackbar.Add("Saved Successfully", Severity.Success);
                MudDialog.Close(routemodel);
                routemodel = new RouteModel();
            }
            catch (Exception ex)
            {
                snackbar.Add(ex.Message, Severity.Warning);
            }
            await Task.Delay(200);
            _busy = false;
        }
        else
        {
            bool? ResultModel = await DialogService.ShowMessageBox(
                "Permission denied!",
                "You dont have any permission to Add or Edit Route.");
        }
    }

    private void ValidateOrgine(PlaceModel obj)
    {
        routemodel.Origin = obj;
        if (routemodel.Origin == null || routemodel.Origin.PlaceID == null)
        {
            ValidationMessageOrgin = "Please select origin. \n";
        }

        else
        {
            ValidationMessageOrgin = null;
        }
    }

    private void ValidateDestination(PlaceModel obj)
    {
        routemodel.Destination = obj;
        if (routemodel.Destination == null || routemodel.Destination.PlaceID == null)
        {
            ValidationMessageDestination = "Please select destination. \n";
        }
        else
        {
            ValidationMessageDestination = null;
        }
    }

    private void ValidateOrgineAndDestination()
    {

        if (routemodel.Origin == null || routemodel.Origin.PlaceID == null || routemodel.Destination == null || routemodel.Destination.PlaceID == null)
        {
            if (routemodel.Origin == null || routemodel.Origin.PlaceID == null)
            {
                ValidationMessageOrgin = "Please select origin. \n";
            }

            if (routemodel.Destination == null || routemodel.Destination.PlaceID == null)
            {
                ValidationMessageDestination = "Please select destination. \n";
            }
        }
        else
        {
            ValidationMessageOrgin = null;
            ValidationMessageDestination = null;
        }
    }

    private async Task AddPlace()
    {
        DialogParameters parms = new DialogParameters();
        PlaceModel placeModel = new();
        parms.Add("placemodel", placeModel.Clone());
        var dialog = DialogService.Show<PlaceDilogue>("ADD/EDIT PLACE", parms);
        var result = await dialog.Result;
        if (!result.Canceled)
        {
            places = Iplace.Select(0, null).ToList();
        }
    }
}