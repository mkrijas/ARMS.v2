@page "/route"
@inject IRouteService Iservice
@inject IPlaceService Iplace
@inject MudBlazor.ISnackbar snackbar
@attribute [Authorize]
@inject AuthenticationStateProvider auth
@inject IDialogService DialogService
@using System.Threading;
@inject IRoleService<RoleModel> Irole

<MudTable Items="@collection" Dense="true" Hover="true" Striped="true" Elevation="10" Filter="new Func<RouteModel, bool>(search)" @bind-model="model">
    <ToolBarContent>
        <MudText Typo="Typo.h6">Manage Routes</MudText>
        <MudIconButton Disabled="@_busy" Icon="@Icons.Material.Filled.Add" Title="Add" @onclick="@(()=> Edit(new RouteModel()))" Color="Color.Dark" Size="Size.Small"></MudIconButton>
        <MudSpacer></MudSpacer>
        <MudTextField @bind-Value="searchRoute" Placeholder="Search Routes... " Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0"></MudTextField>
        <MudCheckBox Label="Disabled Routes" CheckedChanged="((bool value)=>DisabledChanged(value))" Checked="@IsDisabled" Size="Size.Medium" Color="Color.Primary" Class="tablefont margin0"></MudCheckBox>
    </ToolBarContent>
    <HeaderContent>
        <MudTh><MudTableSortLabel SortBy="new Func<RouteModel, object>(x=> x.RouteName)" InitialDirection="SortDirection.Ascending">Route</MudTableSortLabel></MudTh>
        <MudTh><MudTableSortLabel SortBy="new Func<RouteModel, object>(x=> x.Distance)" InitialDirection="SortDirection.Ascending">Distance</MudTableSortLabel></MudTh>
        <MudTh><MudTableSortLabel SortBy="new Func<RouteModel, object>(x=> x.SpeedLimit)" InitialDirection="SortDirection.Ascending">Running Hours</MudTableSortLabel></MudTh>
        <MudTh><MudTableSortLabel SortBy="new Func<RouteModel, object>(x=> x.RouteType)" InitialDirection="SortDirection.Ascending">Route Type</MudTableSortLabel></MudTh>
        <MudTh><MudTableSortLabel SortBy="new Func<RouteModel, object>(x=> x.TollBooths)" InitialDirection="SortDirection.Ascending">No of Tollbooths</MudTableSortLabel></MudTh>
        <MudTh>Actions</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd DataLabel="Route">@context.RouteName</MudTd>
        <MudTd DataLabel="Distance">@context.Distance</MudTd>
        <MudTd DataLabel="RunningHours">@context.RunningHours</MudTd>
        <MudTd DataLabel="RouteType">@context.RouteType</MudTd>
        <MudTd DataLabel="TollBooths">@context.TollBooths</MudTd>
        <MudTd DataLabel="">
            @if (IsDisabled)
            {
                <MudTooltip Text="Enable">
                    <MudFab @onclick="@(()=> Edit(context))" Color="Color.Primary" Icon="@Icons.Material.Filled.KeyboardReturn" Size="Size.Small" IconSize="Size.Small" />
                </MudTooltip>
            }
            else
            {
                <MudTooltip Text="Edit">
                    <MudFab @onclick="@(()=> Edit(context))" Color="Color.Primary" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" IconSize="Size.Small" />
                </MudTooltip>
                <MudTooltip Text="Disable">
                    <MudFab @onclick="@(()=> Delete(context))" Color="Color.Primary" Icon="@Icons.Material.Filled.DisabledByDefault" Size="Size.Small" IconSize="Size.Small" />
                </MudTooltip>
            }
        </MudTd>
    </RowTemplate>
    <PagerContent>
        <MudTablePager PageSizeOptions="new int[] { 10, 20, 50, 100 }" />
    </PagerContent>
</MudTable>

    @code {

    private RouteModel model = new RouteModel();
    private List<RouteModel> collection = new List<RouteModel>();
    public List<PlaceModel> places = new List<PlaceModel>();
    private List<string> RouteTypes = new List<string>() { "Highland", "City", "Highway", "Other" };

    private string searchRoute = "";
    private bool _busy;
    public bool HasPermissionRouteServiceEdit { get; set; } = false;
    public bool HasPermissionRouteServiceDelete { get; set; } = false;
    public int DocTypeID = 43;
    public bool IsDisabled { get; set; } = false;

    protected override async Task OnInitializedAsync()
    {
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionRouteServiceEdit = await Irole.HasClaim(DocTypeID.ToString(), "Edit", ctc.Token);
        HasPermissionRouteServiceDelete = await Irole.HasClaim(DocTypeID.ToString(), "Delete", ctc.Token);

        places = Iplace.Select(0, null).ToList();
        await GetAll(IsDisabled);
    }

    private async Task<IEnumerable<PlaceModel>> Search(string searchString)
    {
        return await Task.FromResult(places.Where(x => x.PlaceName.Contains(searchString == null ? string.Empty : searchString, StringComparison.InvariantCultureIgnoreCase)));
    }

    private async Task GetAll(bool val)
    {
        collection = new();
        if (val)
        {
            await foreach (var route in Iservice.GetDisabled(0))
            {
                collection.Add(route);
            }
        }
        else
        {
            await foreach (var route in Iservice.Select(0))
            {
                collection.Add(route);
            }
        }
    }

    async Task DisabledChanged(bool value)
    {
        IsDisabled = value;
        await GetAll(IsDisabled);
    }

    private async Task Delete(RouteModel model)
    {
        if (HasPermissionRouteServiceDelete)
        {
            bool? result = await DialogService.ShowMessageBox(
                "Warning !",
                "Are you sure, you want to disable - " + model.RouteName + " ?");
            if (result == true)
            {
                var authprov = await auth.GetAuthenticationStateAsync();
                var user = authprov.User;
                int value = Iservice.Delete(model.RouteID, user.Identity.Name);
                if (value != -1)
                {
                    if (collection != null && collection.Any(s => s.RouteID == model.RouteID))
                    {
                        collection.Remove(collection.FirstOrDefault(s => s.RouteID == model.RouteID));
                        snackbar.Add("Disabled Successfully", Severity.Success);
                    }
                }
            }
        }
        else
        {
            bool? result = await DialogService.ShowMessageBox(
                "Permission denied!",
                "You don't have any permission to Delete Route.");
        }
    }

    private bool search(RouteModel model)
    {
        if (model.RouteName != null && model.RouteName.Contains(searchRoute, StringComparison.OrdinalIgnoreCase))
        {
            return true;
        }
        return false;
    }

    private async Task Edit(RouteModel model)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        _busy = true;
        if (HasPermissionRouteServiceEdit)
        {
            DialogParameters parms = new DialogParameters();
            parms.Add("routemodel", model.Clone());
            var dialog = DialogService.Show<RouteDilog>("Route", parms, new DialogOptions() { MaxWidth = MaxWidth.Large });
            var result = await dialog.Result;

            // you can check if the modal was cancelled
            var isCancelled = result.Canceled;
            if (!isCancelled)
            {
                RouteModel UpatedModel = (RouteModel)result.Data;
                if (UpatedModel != null)
                {
                    if (collection.Exists(x => x.RouteID == UpatedModel.RouteID))
                    {
                        collection[collection.FindIndex(x => x.RouteID == UpatedModel.RouteID)] = UpatedModel;
                    }
                    else
                    {
                        collection.Add(UpatedModel);
                    }
                }
                model = new();
            }
        }
        else
        {
            bool? ResultModel = await DialogService.ShowMessageBox(
                "Permission denied!",
                "You don't have any permission to Add or Edit Route.");
        }
        await Task.Delay(200);
        _busy = false;
        await GetAll(IsDisabled);
    }
}