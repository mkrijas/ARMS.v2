@page "/route"
@inject IRouteService Iservice
@inject IPlaceService Iplace
@inject MudBlazor.ISnackbar snackbar
@attribute [Authorize]
@inject AuthenticationStateProvider auth
@inject IDialogService DialogService
@using System.Threading;
@inject IRoleService<RoleModel> Irole

@if (_isLoading)
{
    <LoaderComponent IsFullScreen="true" 
                    ShowLogo="false" 
                    Size="medium" 
                    LoadingText="Loading Routes" 
                    SubText="Please wait..." />
}
else
{
    <div class="admin-page-container">
        <div class="admin-header-tiered mb-6">
            <div class="d-flex align-center justify-space-between">
                <div>
                    <MudText Typo="Typo.h4" Class="admin-title">Route Management</MudText>
                    <MudText Typo="Typo.body2" Class="admin-subtitle">Define and optimize transportation routes, track distances, and manage toll requirements.</MudText>
                </div>
                <MudButton StartIcon="@Icons.Material.Filled.Add" Variant="Variant.Filled" Color="Color.Primary" Class="admin-register-btn" OnClick="@(()=> Edit(new RouteModel()))" Disabled="@_busy">CREATE ROUTE</MudButton>
            </div>
        </div>

        <div class="admin-glass-card mb-6 pa-4">
            <div class="d-flex align-center gap-4">
                <div style="flex-grow: 1;">
                    <MudTextField @bind-Value="searchRoute" Placeholder="Search by route name..." Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" Variant="Variant.Outlined" Margin="Margin.Dense" Class="admin-input-group" Clearable="true" />
                </div>
                <MudToggleIconButton Toggled="@IsDisabled" ToggledChanged="DisabledChanged" Icon="@Icons.Material.Outlined.Visibility" Color="Color.Default" ToggledIcon="@Icons.Material.Filled.VisibilityOff" ToggledColor="Color.Warning" Title="Show Disabled" />
                <MudText Typo="Typo.body2" Class="admin-td-secondary">@(IsDisabled ? "Showing Disabled" : "Active Only")</MudText>
            </div>
        </div>

        <div class="admin-glass-card pa-0 overflow-hidden">
            <MudTable Items="@collection" Dense="true" Hover="true" Elevation="0" Filter="new Func<RouteModel, bool>(search)" Class="modern-admin-table">
                <HeaderContent>
                    <MudTh><MudTableSortLabel SortBy="new Func<RouteModel, object>(x=> x.RouteName)" InitialDirection="SortDirection.Ascending"><span class="admin-header-text">ROUTE NAME</span></MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<RouteModel, object>(x=> x.Distance)" InitialDirection="SortDirection.Ascending"><span class="admin-header-text">LOGISTICS</span></MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<RouteModel, object>(x=> x.RouteType)" InitialDirection="SortDirection.Ascending"><span class="admin-header-text">TYPE</span></MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<RouteModel, object>(x=> x.TollBooths)" InitialDirection="SortDirection.Ascending"><span class="admin-header-text">TOLLS</span></MudTableSortLabel></MudTh>
                    <MudTh Style="text-align: right;"><span class="admin-header-text">ACTIONS</span></MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Route Name"><MudText Typo="Typo.body2" Class="admin-td-primary">@context.RouteName</MudText></MudTd>
                    <MudTd DataLabel="Logistics">
                        <div class="d-flex flex-column">
                            <MudText Typo="Typo.body2" Class="admin-td-primary">@context.Distance km</MudText>
                            <MudText Typo="Typo.caption" Class="admin-td-secondary">@context.RunningHours hrs travel</MudText>
                        </div>
                    </MudTd>
                    <MudTd DataLabel="Type"><MudChip T="string" Size="Size.Small" Variant="Variant.Text" Color="Color.Info">@context.RouteType</MudChip></MudTd>
                    <MudTd DataLabel="Tolls"><MudText Typo="Typo.body2" Class="admin-td-amount">@context.TollBooths Booths</MudText></MudTd>
                    <MudTd DataLabel="Actions" Style="text-align: right;">
                        <div class="d-flex justify-end gap-1">
                            @if (IsDisabled)
                            {
                                <MudTooltip Text="Enable Route">
                                    <MudIconButton OnClick="@(()=> Edit(context))" Color="Color.Success" Icon="@Icons.Material.Filled.RestartAlt" Size="Size.Small" Variant="Variant.Text" />
                                </MudTooltip>
                            }
                            else
                            {
                                <MudTooltip Text="Edit">
                                    <MudIconButton OnClick="@(()=> Edit(context))" Color="Color.Primary" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Variant="Variant.Text" />
                                </MudTooltip>
                                <MudTooltip Text="Disable Route">
                                    <MudIconButton OnClick="@(()=> Delete(context))" Color="Color.Error" Icon="@Icons.Material.Filled.Block" Size="Size.Small" Variant="Variant.Text" />
                                </MudTooltip>
                            }
                        </div>
                    </MudTd>
                </RowTemplate>
                <PagerContent>
                    <div class="pa-4">
                        <MudTablePager PageSizeOptions="new int[] { 10, 20, 50, 100 }" />
                    </div>
                </PagerContent>
            </MudTable>
        </div>
    </div>
}



    @code {

    private bool _isLoading = true;
    private DateTime _loadStartTime;

    private RouteModel model = new RouteModel();
    private List<RouteModel> collection = new List<RouteModel>();
    public List<PlaceModel> places = new List<PlaceModel>();
    private List<string> RouteTypes = new List<string>() { "Highland", "City", "Highway", "Other" };

    private string searchRoute = "";
    private bool _busy;
    public bool HasPermissionRouteServiceEdit { get; set; } = false;
    public bool HasPermissionRouteServiceDelete { get; set; } = false;
    public int DocTypeID = 43;
    public bool IsDisabled { get; set; } = false;

    protected override async Task OnInitializedAsync()
    {
        _loadStartTime = DateTime.Now;
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionRouteServiceEdit = await Irole.HasClaim(DocTypeID.ToString(), "Edit", ctc.Token);
        HasPermissionRouteServiceDelete = await Irole.HasClaim(DocTypeID.ToString(), "Delete", ctc.Token);

        places = Iplace.Select(0, null).ToList();
        await GetAll(IsDisabled);
        await EnsureMinimumLoadTime();
        _isLoading = false;
    }

    private async Task EnsureMinimumLoadTime()
    {
        var elapsed = (DateTime.Now - _loadStartTime).TotalMilliseconds;
        if (elapsed < 100)
        {
            await Task.Delay(100 - (int)elapsed);
        }
    }

    private async Task<IEnumerable<PlaceModel>> Search(string searchString)
    {
        return await Task.FromResult(places.Where(x => x.PlaceName.Contains(searchString == null ? string.Empty : searchString, StringComparison.InvariantCultureIgnoreCase)));
    }

    private async Task GetAll(bool val)
    {
        collection = new();
        if (val)
        {
            await foreach (var route in Iservice.GetDisabled(0))
            {
                collection.Add(route);
            }
        }
        else
        {
            await foreach (var route in Iservice.Select(0))
            {
                collection.Add(route);
            }
        }
    }

    async Task DisabledChanged(bool value)
    {
        IsDisabled = value;
        await GetAll(IsDisabled);
    }

    private async Task Delete(RouteModel model)
    {
        if (HasPermissionRouteServiceDelete)
        {
            bool? result = await DialogService.ShowMessageBoxAsync(
                "Warning !",
                "Are you sure, you want to disable - " + model.RouteName + " ?");
            if (result == true)
            {
                var authprov = await auth.GetAuthenticationStateAsync();
                var user = authprov.User;
                int value = Iservice.Delete(model.RouteID, user.Identity.Name);
                if (value != -1)
                {
                    if (collection != null && collection.Any(s => s.RouteID == model.RouteID))
                    {
                        collection.Remove(collection.FirstOrDefault(s => s.RouteID == model.RouteID));
                        snackbar.Add("Disabled Successfully", Severity.Success);
                    }
                }
            }
        }
        else
        {
            bool? result = await DialogService.ShowMessageBoxAsync(
                "Permission denied!",
                "You don't have any permission to Delete Route.");
        }
    }

    private bool search(RouteModel model)
    {
        if (model.RouteName != null && model.RouteName.Contains(searchRoute, StringComparison.OrdinalIgnoreCase))
        {
            return true;
        }
        return false;
    }

    private async Task Edit(RouteModel model)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        _busy = true;
        if (HasPermissionRouteServiceEdit)
        {
            DialogParameters parms = new DialogParameters();
            parms.Add("routemodel", model.Clone());
            var dialog = await DialogService.ShowAsync<RouteDilog>("Route", parms, new DialogOptions() { MaxWidth = MaxWidth.Large });
            var result = await dialog.Result;

            // you can check if the modal was cancelled
            var isCancelled = result.Canceled;
            if (!isCancelled)
            {
                RouteModel UpatedModel = (RouteModel)result.Data;
                if (UpatedModel != null)
                {
                    if (collection.Exists(x => x.RouteID == UpatedModel.RouteID))
                    {
                        collection[collection.FindIndex(x => x.RouteID == UpatedModel.RouteID)] = UpatedModel;
                    }
                    else
                    {
                        collection.Add(UpatedModel);
                    }
                }
                model = new();
            }
        }
        else
        {
            bool? ResultModel = await DialogService.ShowMessageBoxAsync(
                "Permission denied!",
                "You don't have any permission to Add or Edit Route.");
        }
        await Task.Delay(200);
        _busy = false;
        await GetAll(IsDisabled);
    }
}

