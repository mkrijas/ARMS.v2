@page "/ProjectTonnage"
@attribute [Authorize]
@inject AuthenticationStateProvider auth
@using Core.BaseModels.Operations
@using Core.IDataServices.Operations
@inject IProjectTonnageService IProjectTonnage
@inject IDialogService DialogService
@inject MudBlazor.ISnackbar snackbar
@using Microsoft.Data.SqlClient;

<div class="admin-page-container">
    <div class="admin-header-tiered mb-6">
        <div class="d-flex align-center justify-space-between">
            <div>
                <MudText Typo="Typo.h4" Class="admin-title">Project Tonnage Standards</MudText>
                <MudText Typo="Typo.body2" Class="admin-subtitle">Configure standardized weight capacities and axle-to-body classifications for fleet projects.</MudText>
            </div>
        </div>
    </div>

    <div class="admin-glass-card mb-6 pa-4">
        <div class="d-flex align-center gap-4">
            <div style="flex-grow: 1;">
                <MudTextField @bind-Value="searchString" Placeholder="Search by body type, wheels or tonnage capacity..." Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" Variant="Variant.Outlined" Margin="Margin.Dense" Class="admin-input-group" Clearable="true" />
            </div>
        </div>
    </div>

    <div class="admin-glass-card pa-0 overflow-hidden">
        <MudTable Items="@MainModel" Elevation="0" Class="modern-admin-table" Hover="true" CanCancelEdit="true" Filter="new Func<ProjectTonnageModel,bool>(FilterFunc)" RowEditPreview="BackupItem" RowEditCancel="ResetItemToOriginalValues" RowEditCommit="Update">
            <HeaderContent>
                <MudTh><MudTableSortLabel SortBy="new Func<ProjectTonnageModel, object>(x=>x.BodyType)"><span class="admin-header-text">BODY CONFIGURATION</span></MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<ProjectTonnageModel, object>(x=>x.Wheels)"><span class="admin-header-text">WHEEL COUNT</span></MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<ProjectTonnageModel, object>(x=>x.Tonnage)"><span class="admin-header-text">RATED TONNAGE</span></MudTableSortLabel></MudTh>
                <MudTh Style="width: 100px;"><span class="admin-header-text">ACTIONS</span></MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="BodyType"><span class="admin-td-primary fw-600">@context.BodyType</span></MudTd>
                <MudTd DataLabel="Wheels">@context.Wheels Wheels</MudTd>
                <MudTd DataLabel="Tonnage">@context.Tonnage MT</MudTd>
                <MudTd></MudTd>
            </RowTemplate>
            <RowEditingTemplate>
                <MudTd DataLabel="BodyType">
                    <MudTextField Variant="Variant.Outlined" Margin="Margin.Dense" @bind-Value="@context.BodyType" Required Class="modern-input" />
                </MudTd>
                <MudTd DataLabel="Wheels">
                    <MudNumericField Variant="Variant.Outlined" Margin="Margin.Dense" @bind-Value="@context.Wheels" Class="modern-input" />
                </MudTd>
                <MudTd DataLabel="Tonnage">
                    <MudNumericField Variant="Variant.Outlined" Margin="Margin.Dense" @bind-Value="@context.Tonnage" Required Class="modern-input" />
                </MudTd>
            </RowEditingTemplate>
            <FooterContent>
                <MudTd DataLabel="BodyType">
                    <MudTextField Label="Body Type" Variant="Variant.Filled" Margin="Margin.Dense" @bind-Value="@InsertElement.BodyType" Required Class="modern-input" />
                </MudTd>
                <MudTd DataLabel="Wheels">
                    <MudNumericField Label="Wheels" Variant="Variant.Filled" Margin="Margin.Dense" @bind-Value="@InsertElement.Wheels" Class="modern-input" />
                </MudTd>
                <MudTd DataLabel="Tonnage">
                    <MudTextField Label="Tonnage" Variant="Variant.Filled" Margin="Margin.Dense" @bind-Value="@InsertElement.Tonnage" Required Class="modern-input" />
                </MudTd>
                <MudTd DataLabel="Create" Style="text-align: right;">
                    <MudButton OnClick="(()=>Update(InsertElement))" Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" Class="rounded-lg">CREATE</MudButton>
                </MudTd>
            </FooterContent>
            <PagerContent>
                <div class="pa-4">
                    <MudTablePager PageSizeOptions="new int[] { 10, 20, 50, 100 }" />
                </div>
            </PagerContent>
        </MudTable>
    </div>
</div>

@code {

    private List<ProjectTonnageModel> MainModel = new();
    private ProjectTonnageModel InsertElement = new();
    private ProjectTonnageModel elementBeforeEdit;
    private int? BranchID;
    private string searchString = "";

    protected override async Task OnInitializedAsync()
    {
        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;
        BranchID = int.Parse(user.Claims.FirstOrDefault(x => x.Type == "BranchID").Value);

        MainModel = IProjectTonnage.Select(BranchID).ToList();
    }

    private void BackupItem(object element)
    {
        ProjectTonnageModel item = (ProjectTonnageModel)element;
        elementBeforeEdit = new()
            {
                BodyType = item.BodyType,
                Wheels = item.Wheels,
                Tonnage = item.Tonnage,
            };
    }

    private void ResetItemToOriginalValues(object element)
    {
        ProjectTonnageModel item = (ProjectTonnageModel)element;
        item.BodyType = elementBeforeEdit.BodyType;
        item.Wheels = elementBeforeEdit.Wheels;
        item.Tonnage = elementBeforeEdit.Tonnage;
    }

    private async void Update(object element)
    {
        ProjectTonnageModel item = (ProjectTonnageModel)element;
        var authState = auth.GetAuthenticationStateAsync().Result;
        item.UserInfo.UserID = authState.User.Identity.Name;
        item.BranchID = BranchID;
        try
        {
            var a = IProjectTonnage.Update(item);
            MainModel = IProjectTonnage.Select(BranchID).ToList();
            snackbar.Add("Successfully Submitted", Severity.Success);
        }
        catch (Exception ex)
        {
            if (ex.Message.Contains("Violation of UNIQUE KEY constraint", StringComparison.OrdinalIgnoreCase))
            {
                bool? result = await DialogService.ShowMessageBoxAsync(
                    "Oops !",
                    (MarkupString)$"<b>{item.BodyType}</b> bodytype with <b>{item.Wheels}</b> wheels already exists !"
                );
            }
            else
            {
                snackbar.Add(ex.Message, Severity.Error);
            }
        }
        InsertElement = new();
        StateHasChanged();
    }

    private bool FilterFunc(ProjectTonnageModel element)
    {
        if (string.IsNullOrWhiteSpace(searchString))
            return true;
        if (element.BodyType.Contains(searchString, StringComparison.OrdinalIgnoreCase))
            return true;
        if (element.Wheels.ToString().Contains(searchString, StringComparison.OrdinalIgnoreCase))
            return true;
        if (element.Tonnage.ToString().Contains(searchString, StringComparison.OrdinalIgnoreCase))
            return true;
        return false;
    }
}
