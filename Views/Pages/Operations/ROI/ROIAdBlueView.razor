@page "/ROIAdBlue"
@using System.Threading;
@using Core.BaseModels.Operations.ROI
@using Core.IDataServices.Operations.ROI
@layout ROILayout
@attribute [Authorize]
@inject AuthenticationStateProvider auth
@inject NavigationManager NavigationManager;
@inject IROIAdBlueRatioService IService
@inject IDialogService DialogService
@inject MudBlazor.ISnackbar snackbar
@inject IJSRuntime JSRuntime

<div class="fade-in">
    <div class="admin-header-tiered mb-6">
        <div class="d-flex align-center justify-space-between">
            <div>
                <MudText Typo="Typo.h4" Class="admin-title">ROI AdBlue Consumption</MudText>
                <MudText Typo="Typo.body2" Class="admin-subtitle">Maintain standard AdBlue ratios for various vehicle configurations to track emission control fluid efficiency.</MudText>
            </div>
            <MudButton StartIcon="@Icons.Material.Filled.Add" Variant="Variant.Filled" Color="Color.Primary" Class="admin-register-btn" OnClick="@(()=> Edit(new ROIAdBlueStdModel()))">NEW RATIO</MudButton>
        </div>
    </div>

    <div class="admin-glass-card mb-6 pa-4">
        <div class="d-flex align-center gap-4">
            <div style="flex-grow: 1;">
                <MudTextField @bind-Value="SearchItem" Placeholder="Search by wheels, BS type or ratio..." Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" Variant="Variant.Outlined" Margin="Margin.Dense" Class="admin-input-group" Clearable="true" />
            </div>
        </div>
    </div>

    <div class="admin-glass-card pa-0 overflow-hidden">
        <MudTable Items="@collection" Elevation="0" Filter="new Func<ROIAdBlueStdModel, bool>(search)" Class="modern-admin-table" Hover="true">
            <HeaderContent>
                <MudTh><MudTableSortLabel SortBy="new Func<ROIAdBlueStdModel, object>(x=> x.Wheels)" InitialDirection="SortDirection.Ascending"><span class="admin-header-text">CONFIGURATION</span></MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<ROIAdBlueStdModel, object>(x=> x.BSType)"><span class="admin-header-text">BS TYPE</span></MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<ROIAdBlueStdModel, object>(x => x.AdBlueRatio)"><span class="admin-header-text">ADBLUE RATIO (%)</span></MudTableSortLabel></MudTh>
                <MudTh Style="text-align: right;"><span class="admin-header-text">ACTIONS</span></MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Configuration"><span class="fw-600">@context.Wheels Wheels</span></MudTd>
                <MudTd DataLabel="BSType">@context.BSType</MudTd>                
                <MudTd DataLabel="AdBlue">
                    <MudChip T="string" Size="Size.Small" Color="Color.Info" Variant="Variant.Text" Class="fw-700">@(context.AdBlueRatio?.ToString("P1"))</MudChip>
                </MudTd>
                <MudTd DataLabel="Actions" Style="text-align: right;">
                    <MudTooltip Text="Adjust Ratio">
                        <MudIconButton OnClick="@(() => Edit(context))" Color="Color.Primary" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Variant="Variant.Text" />
                    </MudTooltip>
                </MudTd>
            </RowTemplate>
            <PagerContent>
                <div class="pa-4">
                    <MudTablePager PageSizeOptions="new int[] { 10, 20, 50, 100 }" />
                </div>
            </PagerContent>
        </MudTable>
    </div>
</div>

@code {

    private List<ROIAdBlueStdModel> collection = new List<ROIAdBlueStdModel>();
    private string SearchItem = "";
    string UserID;
    int? BranchID;

    protected override async Task OnInitializedAsync()
    {
        var authprov = await auth.GetAuthenticationStateAsync();
        UserID = authprov.User.Identity.Name;
        BranchID = int.Parse(authprov.User.Claims.First(x => x.Type == "BranchID").Value);
        GetAll();
    }

    private void GetAll()
    {
        collection = IService.Select(BranchID).ToList();
    }

    private async Task Edit(ROIAdBlueStdModel model)
    {
        try
        {
            var parameters = new DialogParameters();
            parameters.Add("model", model.Clone());
            DialogOptions maxWidth = new DialogOptions() { MaxWidth = MaxWidth.Medium, FullWidth = true };
            var dialog = await DialogService.ShowAsync<ROIAdBlueDialog>("Add/Edit", parameters, maxWidth);
            var result = await dialog.Result;
            if (!result.Canceled)
            {
                snackbar.Add("Saved Successfully", Severity.Success);
            }
        }
        catch (Exception a)
        {
            snackbar.Add(a.Message, Severity.Error);
        }
        GetAll();
    }

    private bool search(ROIAdBlueStdModel model)
    {
        if (
            (model.Wheels.ToString().Contains(SearchItem, StringComparison.OrdinalIgnoreCase)) ||
            (model.BSType.Contains(SearchItem, StringComparison.OrdinalIgnoreCase)) ||            
            (model.AdBlueRatio.ToString().Contains(SearchItem, StringComparison.OrdinalIgnoreCase))
        )
        {
            return true;
        }
        return false;
    }
}

