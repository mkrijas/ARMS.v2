@page "/ROIAdminExpense"
@using System.Threading;
@using Core.BaseModels.Operations.ROI
@using Core.IDataServices.Operations.ROI
@layout ROILayout
@attribute [Authorize]
@inject AuthenticationStateProvider auth
@inject NavigationManager NavigationManager;
@inject IROIAdminExpenseService IService
@inject IDialogService DialogService
@inject MudBlazor.ISnackbar snackbar

<div class="fade-in">
    <div class="admin-header-tiered mb-6">
        <div class="d-flex align-center justify-space-between">
            <div>
                <MudText Typo="Typo.h4" Class="admin-title">ROI Administrative Expenses</MudText>
                <MudText Typo="Typo.body2" Class="admin-subtitle">Monitor and manage overhead costs for Branch and HO administration to calculate accurate net ROI.</MudText>
            </div>
            <MudButton StartIcon="@Icons.Material.Filled.Add" Variant="Variant.Filled" Color="Color.Primary" Class="admin-register-btn" OnClick="@(()=> Edit(new ROIAdminExpenseModel()))">ADD EXPENSE RECORD</MudButton>
        </div>
    </div>

    <div class="admin-glass-card mb-6 pa-4">
        <div class="d-flex align-center gap-4">
            <div style="flex-grow: 1;">
                <MudTextField @bind-Value="SearchItem" Placeholder="Search by branch admin, HO admin or date..." Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" Variant="Variant.Outlined" Margin="Margin.Dense" Class="admin-input-group" Clearable="true" />
            </div>
        </div>
    </div>

    <div class="admin-glass-card pa-0 overflow-hidden">
        <MudTable Items="@collection" Elevation="0" Filter="new Func<ROIAdminExpenseModel, bool>(search)" Class="modern-admin-table" Hover="true">
            <HeaderContent>
                <MudTh><MudTableSortLabel SortBy="new Func<ROIAdminExpenseModel, object>(x=> x.BranchAdmin)" InitialDirection="SortDirection.Ascending"><span class="admin-header-text">BRANCH OVERHEADS</span></MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<ROIAdminExpenseModel, object>(x=> x.HOAdmin)" InitialDirection="SortDirection.Ascending"><span class="admin-header-text">HO OVERHEADS</span></MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<ROIAdminExpenseModel, object>(x=> x.FromDate)" InitialDirection="SortDirection.Ascending"><span class="admin-header-text">START DATE</span></MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<ROIAdminExpenseModel, object>(x=> x.ToDate)" InitialDirection="SortDirection.Ascending"><span class="admin-header-text">END DATE</span></MudTableSortLabel></MudTh>
                <MudTh Style="text-align: right;"><span class="admin-header-text">ACTIONS</span></MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="BranchAdmin">
                    <MudChip T="string" Size="Size.Small" Color="Color.Default" Variant="Variant.Text" Class="fw-700">@context.BranchAdmin?.ToString("N2")</MudChip>
                </MudTd>
                <MudTd DataLabel="HOAdmin">
                    <MudChip T="string" Size="Size.Small" Color="Color.Secondary" Variant="Variant.Text" Class="fw-700">@context.HOAdmin?.ToString("N2")</MudChip>
                </MudTd>
                <MudTd DataLabel="FromDate">@context.FromDate?.ToString("dd MMM yyyy")</MudTd>
                <MudTd DataLabel="ToDate">@context.ToDate?.ToString("dd MMM yyyy")</MudTd>
                <MudTd DataLabel="Actions" Style="text-align: right;">
                    <MudTooltip Text="Update Overheads">
                        <MudIconButton OnClick="@(() => Edit(context))" Color="Color.Primary" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Variant="Variant.Text" />
                    </MudTooltip>
                </MudTd>
            </RowTemplate>
            <PagerContent>
                <div class="pa-4">
                    <MudTablePager PageSizeOptions="new int[] { 10, 20, 50, 100 }" />
                </div>
            </PagerContent>
        </MudTable>
    </div>
</div>

@code {

    private List<ROIAdminExpenseModel> collection = new List<ROIAdminExpenseModel>();
    private string SearchItem = "";
    string UserID;

    protected override async Task OnInitializedAsync()
    {
        var authprov = await auth.GetAuthenticationStateAsync();
        UserID = authprov.User.Identity.Name;
        GetAll();
    }

    private void GetAll()
    {
        collection = IService.Select().ToList();
    }

    private async Task Edit(ROIAdminExpenseModel model)
    {
        try
        {
            var parameters = new DialogParameters();
            parameters.Add("model", model.Clone());
            DialogOptions maxWidth = new DialogOptions() { MaxWidth = MaxWidth.Medium, FullWidth = true };
            var dialog = await DialogService.ShowAsync<ROIAdminExpenseDialog>("Add/Edit", parameters, maxWidth);
            var result = await dialog.Result;
            if (!result.Canceled)
            {
                snackbar.Add("Saved Successfully", Severity.Success);
            }
        }
        catch (Exception a)
        {
            snackbar.Add(a.Message, Severity.Error);
        }
        GetAll();
    }

    private bool search(ROIAdminExpenseModel model)
    {
        if ((model.BranchAdmin.ToString().Contains(SearchItem, StringComparison.OrdinalIgnoreCase)) ||
            (model.FromDate.ToString().Contains(SearchItem, StringComparison.OrdinalIgnoreCase)) ||
            (model.ToDate.ToString().Contains(SearchItem, StringComparison.OrdinalIgnoreCase)) ||
            (model.HOAdmin.ToString().Contains(SearchItem, StringComparison.OrdinalIgnoreCase)))
        {
            return true;
        }
        return false;
    }
}

