@using System.Threading;
@using Core.BaseModels.Operations.ROI
@using Core.IDataServices.Operations.ROI
@attribute [Authorize]
@inject AuthenticationStateProvider auth
@inject IROIDriverBattaService Iservice
@inject IBranchService Ibranchservice
@inject MudBlazor.ISnackbar snackbar
@inject IDialogService DialogService
@inject IRoleService<RoleModel> Irole

<DialogForm @ref="@dialogForm" Title="Driver Batta Configuration" Subtitle="Standardize allowance rates based on operational parameters." Icon="@Icons.Material.Filled.Payments" AdminStyle="true" formID="formroibatta" model="@model" _busy="_busy">
    <FormContent>
        <div class="dialog-content-wrapper">
            <EditForm id="formroibatta" Model="@model" OnValidSubmit="OnValidSubmit">
                <div class="admin-glass-card pa-6">
                    <ValidationSummary />
                <MudGrid Spacing="3">
                    <MudItem xs="12" md="6">
                        <MudNumericField HideSpinButtons @bind-Value="model.FromStdKM" 
                                       Label="Distance Threshold (From KM)" Variant="Variant.Outlined" 
                                       Margin="Margin.Normal" Adornment="Adornment.Start" 
                                       AdornmentIcon="@Icons.Material.Filled.Route"
                                       Class="modern-input" For="@(() => model.FromStdKM)"></MudNumericField>
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudNumericField HideSpinButtons @bind-Value="model.ToStdKM" 
                                       Label="Distance Threshold (To KM)" Variant="Variant.Outlined" 
                                       Margin="Margin.Normal" Adornment="Adornment.Start" 
                                       AdornmentIcon="@Icons.Material.Filled.Map"
                                       Class="modern-input" For="@(() => model.ToStdKM)"></MudNumericField>
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudNumericField HideSpinButtons @bind-Value="model.Wheels" 
                                       Label="Axle Configuration (Wheels)" Variant="Variant.Outlined" 
                                       Margin="Margin.Normal" Placeholder="00" MaxLength="2" 
                                       Class="modern-input" Adornment="Adornment.Start" 
                                       AdornmentIcon="@Icons.Material.Filled.SettingsInputHdmi" />
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudSelect Margin="Margin.Normal" Variant="Variant.Outlined" 
                                  Label="Vehicle Body Profile" @bind-Value="model.BodyType" 
                                  Class="modern-input" AdornmentIcon="@Icons.Material.Filled.LocalShipping">
                            <MudSelectItem Value="@("Bulker")">Pneumatic Bulker</MudSelectItem>
                            <MudSelectItem Value="@("Open")">Open Body / Container</MudSelectItem>
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudNumericField HideSpinButtons @bind-Value="model.LoadingMTFrom" 
                                       Label="Payload Weight (From MT)" Variant="Variant.Outlined" 
                                       Margin="Margin.Normal" Class="modern-input"
                                       Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Scale"
                                       For="@(() => model.LoadingMTFrom)"></MudNumericField>
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudNumericField HideSpinButtons @bind-Value="model.LoadingMTTo" 
                                       Label="Payload Weight (To MT)" Variant="Variant.Outlined" 
                                       Margin="Margin.Normal" Class="modern-input"
                                       Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Balance"
                                       For="@(() => model.LoadingMTTo)"></MudNumericField>
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudAutocomplete Clearable="true" Variant="Variant.Outlined" Margin="Margin.Normal" 
                                         T="BranchModel" Label="Operational Node (Branch)" 
                                         ResetValueOnEmptyText="true" ValueChanged="BranchChanged" 
                                         Value="model.Branch" Class="modern-input"
                                         SearchFunc="SearchBranch" ToStringFunc="@(e=> e==null?null : $"{e.BranchName}")"
                                         Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.AccountTree"></MudAutocomplete>
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudNumericField HideSpinButtons @bind-Value="model.Amount" 
                                       Label="Allowance Disbursement Rate" Variant="Variant.Outlined" 
                                       Margin="Margin.Normal" Class="modern-input"
                                       Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.CurrencyRupee"
                                       For="@(() => model.Amount)"></MudNumericField>
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudDatePicker Label="Validity Inception" Variant="Variant.Outlined" 
                                      Margin="Margin.Normal" DisableToolbar="true" Editable="true" 
                                      @bind-Date="model.FromDate" DateFormat="dd/MM/yyyy" Class="modern-input" />
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudDatePicker Label="Validity Termination" Variant="Variant.Outlined" 
                                      Margin="Margin.Normal" DisableToolbar="true" Editable="true" 
                                      @bind-Date="model.ToDate" DateFormat="dd/MM/yyyy" Class="modern-input" />
                    </MudItem>
                </MudGrid>
                </div>
            </EditForm>
        </div>
    </FormContent>
    <Actions>
        <div class="d-flex pa-4 gap-4 w-100 justify-end align-center">
            <MudButton OnClick="Cancel" Variant="Variant.Text">Cancel</MudButton>
            <MudButton Size="Size.Large" Variant="Variant.Filled" Color="Color.Primary" 
                       form="formroibatta" ButtonType="ButtonType.Submit" 
                       Class="action-btn-primary px-12"
                       Style="background: #367588 !important; color: white !important;">
                Sync Batta Rate
            </MudButton>
        </div>
    </Actions>
</DialogForm>

@code {
    private DialogForm dialogForm;
    private bool _busy = false;

    [Parameter]
    public ROIDriverBattaModel model { get; set; }
    [CascadingParameter]
    IMudDialogInstance MudDialog { get; set; }
    public List<ROIDriverBattaModel> Collection = new();
    public List<BranchModel> branches = new();
    string UserID;
    int BranchID;
    public int DocTypeID = 143;
    public bool HasPermissionROIServiceEdit { get; set; } = false;

    protected override async Task OnInitializedAsync()
    {
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionROIServiceEdit = await Irole.HasClaim(DocTypeID.ToString(), "Edit", ctc.Token);

        var authprov = await auth.GetAuthenticationStateAsync();
        UserID = authprov.User.Identity.Name;
        BranchID = int.Parse(authprov.User.Claims.First(x => x.Type == "BranchID").Value);

        branches = Ibranchservice.Select().ToList();
    }

    public async Task<IEnumerable<BranchModel>> SearchBranch(string searchString, CancellationToken token)
    {
        return await Task.FromResult(branches.Where(x => x.BranchName.Contains(searchString == null ? string.Empty : searchString, StringComparison.InvariantCultureIgnoreCase)));
    }

    public void BranchChanged(BranchModel obj)
    {
        model.Branch = obj;
    }

    private async void OnValidSubmit(EditContext context)
    {
        if (HasPermissionROIServiceEdit)
        {
            model.UserInfo.UserID = UserID;
            try
            {
                model = Iservice.Update(model);
                MudDialog.Close(model);
            }
            catch (Exception ex)
            {
                snackbar.Add(ex.Message, Severity.Warning);
            }
        }
        else
        {
            bool? result = await DialogService.ShowMessageBoxAsync(
                "Permission denied!",
                "You don't have any permission to Edit ROI settings.");
        }
    }

    private void Cancel()
    {
        MudDialog.Cancel();
    }
}
