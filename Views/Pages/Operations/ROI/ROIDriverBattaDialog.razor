@using System.Threading;
@using Core.BaseModels.Operations.ROI
@using Core.IDataServices.Operations.ROI
@attribute [Authorize]
@inject AuthenticationStateProvider auth
@inject IROIDriverBattaService Iservice
@inject IBranchService Ibranchservice
@inject MudBlazor.ISnackbar snackbar
@inject IDialogService DialogService
@inject IRoleService<RoleModel> Irole

<MudDialog Style="overflow-y: hidden;">
    <TitleContent>
        <MudText Typo="Typo.h6">
            Add/Edit Driver Batta
        </MudText>
    </TitleContent>
    <DialogContent>
        <EditForm id="formroibatta" Model="@model" OnValidSubmit="OnValidSubmit">
            <ObjectGraphDataAnnotationsValidator />
            <ValidationSummary />
            <MudGrid>
                <MudItem xs="12" md="6">
                    <MudTextField @bind-Value="model.FromStdKM" Label="Standard KM From" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.FromStdKM)"></MudTextField>
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudTextField @bind-Value="model.ToStdKM" Label="Standard KM To" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.ToStdKM)"></MudTextField>
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudNumericField HideSpinButtons @bind-Value="model.Wheels" Label="Wheels" Variant="Variant.Outlined" Margin="Margin.Dense" MaxLength="2" />
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudSelect Margin="Margin.Dense" Variant="Variant.Outlined" Label="Select Type" @bind-Value="model.BodyType" AdornmentColor="Color.Secondary">
                        <MudSelectItem Value="@("Bulk")">Bulk</MudSelectItem>
                        <MudSelectItem Value="@("Open")">Open</MudSelectItem>
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudTextField @bind-Value="model.LoadingMTFrom" Label="Loading MT From" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.LoadingMTFrom)"></MudTextField>
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudTextField @bind-Value="model.LoadingMTTo" Label="Loading MT To" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.LoadingMTTo)"></MudTextField>
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudAutocomplete Clearable="true" Variant="Variant.Outlined" Margin="Margin.Dense" T="BranchModel" Label="State" ResetValueOnEmptyText="true" ValueChanged="BranchChanged" Value="model.Branch"
                                     SearchFunc="SearchBranch" ToStringFunc="@(e=> e==null?null : $"{e.BranchName}")"></MudAutocomplete>
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudTextField @bind-Value="model.Amount" Label="Amount" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.Amount)"></MudTextField>
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudDatePicker Label="Period From" Variant="Variant.Outlined" Margin="Margin.Dense" DisableToolbar="true" Editable="true" @bind-Date="model.FromDate" HelperText="Enter Date" DateFormat="dd/MM/yyyy" />
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudDatePicker Label="Period To" Variant="Variant.Outlined" Margin="Margin.Dense" DisableToolbar="true" Editable="true" @bind-Date="model.ToDate" HelperText="Enter Date" DateFormat="dd/MM/yyyy" />
                </MudItem>
            </MudGrid>
        </EditForm>
    </DialogContent>
    <DialogActions>
        <div style="padding-right:12px; padding-bottom:12px;">
            <MudButton Size="Size.Large" Variant="Variant.Filled" Color="Color.Success" form="formroibatta" ButtonType="ButtonType.Submit" Class="ml-auto">Sumbit</MudButton>
        </div>
    </DialogActions>
</MudDialog>

@code {

    [Parameter]
    public ROIDriverBattaModel model { get; set; }
    [CascadingParameter]
    MudDialogInstance MudDialog { get; set; }
    public List<ROIDriverBattaModel> Collection = new();
    public List<BranchModel> branches = new();
    string UserID;
    int BranchID;

    protected override async Task OnInitializedAsync()
    {
        var authprov = await auth.GetAuthenticationStateAsync();
        UserID = authprov.User.Identity.Name;
        BranchID = int.Parse(authprov.User.Claims.First(x => x.Type == "BranchID").Value);

        branches = Ibranchservice.Select().ToList();
    }

    public async Task<IEnumerable<BranchModel>> SearchBranch(string searchString)
    {
        return await Task.FromResult(branches.Where(x => x.BranchName.Contains(searchString == null ? string.Empty : searchString, StringComparison.InvariantCultureIgnoreCase)));
    }

    public void BranchChanged(BranchModel obj)
    {
        model.Branch = obj;
    }

    private async void OnValidSubmit(EditContext context)
    {
        model.UserInfo.UserID = UserID;
        try
        {
            model = Iservice.Update(model);
            MudDialog.Close(model);
        }
        catch (Exception ex)
        {
            snackbar.Add(ex.Message, Severity.Warning);
        }
    }

    private void Cancel()
    {
        MudDialog.Cancel();
    }
}