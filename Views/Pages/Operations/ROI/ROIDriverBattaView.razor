@page "/ROIDriverBatta"
@using System.Threading;
@using Core.BaseModels.Operations.ROI
@using Core.IDataServices.Operations.ROI
@layout ROILayout
@attribute [Authorize]
@inject AuthenticationStateProvider auth
@inject NavigationManager NavigationManager;
@inject IROIDriverBattaService IService
@inject IDialogService DialogService
@inject MudBlazor.ISnackbar snackbar
@inject IJSRuntime JSRuntime

<div class="fade-in">
    <div class="admin-header-tiered mb-6">
        <div class="d-flex align-center justify-space-between">
            <div>
                <MudText Typo="Typo.h4" Class="admin-title">ROI Driver Batta & Allowances</MudText>
                <MudText Typo="Typo.body2" Class="admin-subtitle">Configure distance-based allowances and freight percentage batta to ensure competitive driver compensation and accurate ROI.</MudText>
            </div>
             <div class="d-flex align-center gap-4">
                <MudButton StartIcon="@Icons.Material.Filled.Add" Variant="Variant.Filled" Color="Color.Primary" Class="admin-register-btn" OnClick="@(()=> Edit(new ROIDriverBattaModel()))">ADD BATTA RATE</MudButton>
            </div>
        </div>
    </div>

    <div class="admin-glass-card mb-6 pa-4">
        <div class="d-flex align-center gap-4">
            <div style="flex-grow: 1;">
                <MudTextField @bind-Value="SearchItem" Placeholder="Search by standards, body type, wheels or amount..." Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" Variant="Variant.Outlined" Margin="Margin.Dense" Class="admin-input-group" Clearable="true" />
            </div>
        </div>
    </div>

    <div class="admin-glass-card pa-0 overflow-hidden">
        <MudTabs Elevation="0" Rounded="false" ApplyEffectsToContainer="true" Class="modern-tabs">
            <MudTabPanel Text="DISTANCE-BASED BATTA">
                <MudTable Items="@collection" Elevation="0" Class="modern-admin-table" Hover="true" Filter="new Func<ROIDriverBattaModel, bool>(search)">
                    <HeaderContent>
                        <MudTh><MudTableSortLabel SortBy="new Func<ROIDriverBattaModel, object>(x=> x.FromStdKM)" InitialDirection="SortDirection.Ascending"><span class="admin-header-text">STD DISTANCE (KM)</span></MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<ROIDriverBattaModel, object>(x=> x.Wheels)" InitialDirection="SortDirection.Ascending"><span class="admin-header-text">WHEELS</span></MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<ROIDriverBattaModel, object>(x=> x.BodyType)" InitialDirection="SortDirection.Ascending"><span class="admin-header-text">BODY TYPE</span></MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<ROIDriverBattaModel, object>(x=> x.LoadingMTFrom)" InitialDirection="SortDirection.Ascending"><span class="admin-header-text">TONNAGE (MT)</span></MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<ROIDriverBattaModel, object>(x=> x.Amount)" InitialDirection="SortDirection.Ascending"><span class="admin-header-text">BATTA AMOUNT</span></MudTableSortLabel></MudTh>
                        <MudTh><span class="admin-header-text">VALIDITY PERIOD</span></MudTh>
                        <MudTh Style="text-align: right;"><span class="admin-header-text">ACTIONS</span></MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="Std KM">
                             <MudChip T="string" Size="Size.Small" Color="Color.Default" Variant="Variant.Text" Class="fw-700">@context.FromStdKM - @context.ToStdKM KM</MudChip>
                        </MudTd>
                        <MudTd DataLabel="Wheels"><span class="fw-600">@context.Wheels Wheels</span></MudTd>
                        <MudTd DataLabel="BodyType">@context.BodyType</MudTd>
                        <MudTd DataLabel="Tonnage">@context.LoadingMTFrom - @context.LoadingMTTo MT</MudTd>
                        <MudTd DataLabel="DriverBatta">
                            <MudChip T="string" Size="Size.Small" Color="Color.Success" Variant="Variant.Text" Class="fw-700">@context.Amount?.ToString("N2")</MudChip>
                        </MudTd>
                        <MudTd DataLabel="Validity">
                            <div class="d-flex flex-column">
                                <span class="fw-500">@context.FromDate?.ToString("dd MMM yyyy")</span>
                                <MudText Typo="Typo.caption" Alpha="0.6">to @context.ToDate?.ToString("dd MMM yyyy")</MudText>
                            </div>
                        </MudTd>
                        <MudTd DataLabel="Actions" Style="text-align: right;">
                            <MudTooltip Text="Adjust Rate">
                                <MudIconButton OnClick="@(() => Edit(context))" Color="Color.Primary" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Variant="Variant.Text" />
                            </MudTooltip>
                        </MudTd>
                    </RowTemplate>
                    <PagerContent>
                         <div class="pa-4">
                            <MudTablePager PageSizeOptions="new int[] { 10, 20, 50, 100 }" />
                        </div>
                    </PagerContent>
                </MudTable>
            </MudTabPanel>
            <MudTabPanel Text="FREIGHT PERCENTAGE BATTA">
                <MudTable Items="@collectioninfrtpercentage" Elevation="0" Class="modern-admin-table" Hover="true" Filter="new Func<ROIDriverBattaInFrtPercentageModel, bool>(searchinfrtpercentage)">
                    <HeaderContent>
                        <MudTh><MudTableSortLabel SortBy="new Func<ROIDriverBattaInFrtPercentageModel, object>(x=> x.Percentage)" InitialDirection="SortDirection.Ascending"><span class="admin-header-text">FREIGHT PERCENTAGE</span></MudTableSortLabel></MudTh>
                        <MudTh><span class="admin-header-text">EFFECTIVE FROM</span></MudTh>
                        <MudTh><span class="admin-header-text">EFFECTIVE TO</span></MudTh>
                        <MudTh Style="text-align: right;"><span class="admin-header-text">ACTIONS</span></MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="Percentage">
                            <MudChip T="string" Size="Size.Medium" Color="Color.Secondary" Variant="Variant.Filled" Class="fw-700 px-4">@($"{context.DisplayPercentage}%")</MudChip>
                        </MudTd>
                        <MudTd DataLabel="FromDate">@context.FromDate?.ToString("dd MMM yyyy")</MudTd>
                        <MudTd DataLabel="ToDate">@context.ToDate?.ToString("dd MMM yyyy")</MudTd>
                        <MudTd DataLabel="Actions" Style="text-align: right;">
                             <MudTooltip Text="Modify Batta %">
                                <MudIconButton OnClick="@(() => EditInFrtPercentage(context))" Color="Color.Primary" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Variant="Variant.Text" />
                            </MudTooltip>
                        </MudTd>
                    </RowTemplate>
                    <PagerContent>
                         <div class="pa-4">
                            <MudTablePager PageSizeOptions="new int[] { 10, 20, 50, 100 }" />
                        </div>
                    </PagerContent>
                </MudTable>
            </MudTabPanel>
        </MudTabs>
    </div>
</div>

@code {

    private List<ROIDriverBattaModel> collection = new List<ROIDriverBattaModel>();
    private List<ROIDriverBattaInFrtPercentageModel> collectioninfrtpercentage = new List<ROIDriverBattaInFrtPercentageModel>();
    private string SearchItem = "";
    string UserID;
    int? BranchID;

    protected override async Task OnInitializedAsync()
    {
        var authprov = await auth.GetAuthenticationStateAsync();
        UserID = authprov.User.Identity.Name;
        BranchID = int.Parse(authprov.User.Claims.First(x => x.Type == "BranchID").Value);
        GetAll();
    }

    private void GetAll()
    {
        collection = IService.Select(BranchID).ToList();
        collectioninfrtpercentage = IService.SelectInFrtPercentage(BranchID).ToList();
    }

    private async Task Edit(ROIDriverBattaModel model)
    {
        try
        {
            var parameters = new DialogParameters();
            parameters.Add("model", model.Clone());
            DialogOptions maxWidth = new DialogOptions() { MaxWidth = MaxWidth.Medium, FullWidth = true };
            var dialog = await DialogService.ShowAsync<ROIDriverBattaDialog>("Add/Edit", parameters, maxWidth);
            var result = await dialog.Result;
            if (!result.Canceled)
            {
                snackbar.Add("Saved Successfully", Severity.Success);
            }
        }
        catch (Exception a)
        {
            snackbar.Add(a.Message, Severity.Error);
        }
        GetAll();
    }

    private bool search(ROIDriverBattaModel model)
    {
        if ((model.FromStdKM.ToString().Contains(SearchItem, StringComparison.OrdinalIgnoreCase)) ||
            (model.ToStdKM.ToString().Contains(SearchItem, StringComparison.OrdinalIgnoreCase)) ||
            (model.Wheels.ToString().Contains(SearchItem, StringComparison.OrdinalIgnoreCase)) ||
            (model.LoadingMTFrom.ToString().Contains(SearchItem, StringComparison.OrdinalIgnoreCase)) ||
            (model.LoadingMTTo.ToString().Contains(SearchItem, StringComparison.OrdinalIgnoreCase)) ||
            (model.FromDate.ToString().Contains(SearchItem, StringComparison.OrdinalIgnoreCase)) ||
            (model.ToDate.ToString().Contains(SearchItem, StringComparison.OrdinalIgnoreCase)) ||
            (model.Amount.ToString().Contains(SearchItem, StringComparison.OrdinalIgnoreCase)))
        {
            return true;
        }
        return false;
    }

    private async Task EditInFrtPercentage(ROIDriverBattaInFrtPercentageModel model)
    {
        try
        {
            var parameters = new DialogParameters();
            parameters.Add("model", model.Clone());
            DialogOptions maxWidth = new DialogOptions() { MaxWidth = MaxWidth.Medium, FullWidth = true };
            var dialog = await DialogService.ShowAsync<ROIDriverBattaInFrtPercentageDialog>("Add/Edit", parameters, maxWidth);
            var result = await dialog.Result;
            if (!result.Canceled)
            {
                snackbar.Add("Saved Successfully", Severity.Success);
            }
        }
        catch (Exception a)
        {
            snackbar.Add(a.Message, Severity.Error);
        }
        GetAll();
    }

    private bool searchinfrtpercentage(ROIDriverBattaInFrtPercentageModel model)
    {
        if ((model.FromDate.ToString().Contains(SearchItem, StringComparison.OrdinalIgnoreCase)) ||
            (model.ToDate.ToString().Contains(SearchItem, StringComparison.OrdinalIgnoreCase)) ||
            (model.Percentage.ToString().Contains(SearchItem, StringComparison.OrdinalIgnoreCase)))
        {
            return true;
        }
        return false;
    }
}

