@page "/ROIDriverBatta"
@using System.Threading;
@using Core.BaseModels.Operations.ROI
@using Core.IDataServices.Operations.ROI
@layout ROILayout
@attribute [Authorize]
@inject AuthenticationStateProvider auth
@inject NavigationManager NavigationManager;
@inject IROIDriverBattaService IService
@inject IDialogService DialogService
@inject MudBlazor.ISnackbar snackbar
@inject IJSRuntime JSRuntime

<MudGrid Spacing="4">
    <MudItem xs="12">
        <MudTabs Elevation="2" Rounded="true" ApplyEffectsToContainer="true" PanelClass="px-4 py-6">
            <MudTabPanel Style="min-width: 200px;" Text="Batta">
                <MudTable Items="@collection" Dense="true" Hover="true" Striped="true" Elevation="1" Filter="new Func<ROIDriverBattaModel, bool>(search)">
                    <ToolBarContent>
                        <MudText Typo="Typo.h6">ROI Driver Batta</MudText>
                        <MudIconButton Icon="@Icons.Material.Filled.Add" Title="Add" @onclick="@(()=> Edit(new ROIDriverBattaModel()))" Color="Color.Dark" Size="Size.Small"></MudIconButton>
                        <MudSpacer></MudSpacer>
                        <MudTextField @bind-Value="SearchItem" Placeholder="Search" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0"></MudTextField>
                    </ToolBarContent>
                    <HeaderContent>
                        <MudTh><MudTableSortLabel SortBy="new Func<ROIDriverBattaModel, object>(x=> x.FromStdKM)" InitialDirection="SortDirection.Ascending">Standard KM</MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<ROIDriverBattaModel, object>(x=> x.Wheels)" InitialDirection="SortDirection.Ascending">Wheels</MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<ROIDriverBattaModel, object>(x=> x.BodyType)" InitialDirection="SortDirection.Ascending">Body Type</MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<ROIDriverBattaModel, object>(x=> x.LoadingMTFrom)" InitialDirection="SortDirection.Ascending">Tonnage</MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<ROIDriverBattaModel, object>(x=> x.Amount)" InitialDirection="SortDirection.Ascending">Amount</MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<ROIDriverBattaModel, object>(x=> x.FromDate)" InitialDirection="SortDirection.Ascending">From</MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<ROIDriverBattaModel, object>(x=> x.ToDate)" InitialDirection="SortDirection.Ascending">To</MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<ROIDriverBattaModel, object>(x=> x.Amount)" InitialDirection="SortDirection.Ascending">Action</MudTableSortLabel></MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="FromStdKM">@context.FromStdKM - @context.ToStdKM</MudTd>
                        <MudTd DataLabel="Wheels">@context.Wheels</MudTd>
                        <MudTd DataLabel="BodyType">@context.BodyType</MudTd>
                        <MudTd DataLabel="Tonnage">@context.LoadingMTFrom - @context.LoadingMTTo</MudTd>
                        <MudTd DataLabel="DriverBatta">@context.Amount</MudTd>
                        <MudTd DataLabel="FromDate">@context.FromDate?.ToShortDateString()</MudTd>
                        <MudTd DataLabel="ToDate">@context.ToDate?.ToShortDateString()</MudTd>
                        <MudTd>
                            <MudFab @onclick="@(() => Edit(context))" Title="Edit" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Edit" Size="Size.Small" />
                        </MudTd>
                    </RowTemplate>
                    <PagerContent>
                        <MudTablePager PageSizeOptions="new int[] { 10, 20, 50, 100 }" />
                    </PagerContent>
                </MudTable>
            </MudTabPanel>
            <MudTabPanel Style="min-width: 200px;" Text="Batta In Percentage">
                <MudTable Items="@collectioninfrtpercentage" Dense="true" Hover="true" Striped="true" Elevation="1" Filter="new Func<ROIDriverBattaInFrtPercentageModel, bool>(searchinfrtpercentage)">
                    <ToolBarContent>
                        <MudText Typo="Typo.h6">ROI Driver Batta In Frieght</MudText>
                        <MudIconButton Icon="@Icons.Material.Filled.Add" Title="Add" @onclick="@(()=> EditInFrtPercentage(new ROIDriverBattaInFrtPercentageModel()))" Color="Color.Dark" Size="Size.Small"></MudIconButton>
                        <MudSpacer></MudSpacer>
                        <MudTextField @bind-Value="SearchItem" Placeholder="Search" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0"></MudTextField>
                    </ToolBarContent>
                    <HeaderContent>
                        <MudTh><MudTableSortLabel SortBy="new Func<ROIDriverBattaInFrtPercentageModel, object>(x=> x.Percentage)" InitialDirection="SortDirection.Ascending">Freight</MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<ROIDriverBattaInFrtPercentageModel, object>(x=> x.FromDate)" InitialDirection="SortDirection.Ascending">From</MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<ROIDriverBattaInFrtPercentageModel, object>(x=> x.ToDate)" InitialDirection="SortDirection.Ascending">To</MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<ROIDriverBattaInFrtPercentageModel, object>(x=> x.Percentage)" InitialDirection="SortDirection.Ascending">Action</MudTableSortLabel></MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="DriverBatta">@($"{context.DisplayPercentage}%")</MudTd>
                        <MudTd DataLabel="FromDate">@context.FromDate?.ToShortDateString()</MudTd>
                        <MudTd DataLabel="ToDate">@context.ToDate?.ToShortDateString()</MudTd>
                        <MudTd>
                            <MudFab @onclick="@(() => EditInFrtPercentage(context))" Title="Edit" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Edit" Size="Size.Small" />
                        </MudTd>
                    </RowTemplate>
                    <PagerContent>
                        <MudTablePager PageSizeOptions="new int[] { 10, 20, 50, 100 }" />
                    </PagerContent>
                </MudTable>
            </MudTabPanel>
        </MudTabs>
    </MudItem>
</MudGrid>

@code {

    private List<ROIDriverBattaModel> collection = new List<ROIDriverBattaModel>();
    private List<ROIDriverBattaInFrtPercentageModel> collectioninfrtpercentage = new List<ROIDriverBattaInFrtPercentageModel>();
    private string SearchItem = "";
    string UserID;
    int? BranchID;

    protected override async Task OnInitializedAsync()
    {
        var authprov = await auth.GetAuthenticationStateAsync();
        UserID = authprov.User.Identity.Name;
        BranchID = int.Parse(authprov.User.Claims.First(x => x.Type == "BranchID").Value);
        GetAll();
    }

    private void GetAll()
    {
        collection = IService.Select(BranchID).ToList();
        collectioninfrtpercentage = IService.SelectInFrtPercentage(BranchID).ToList();
    }

    private async Task Edit(ROIDriverBattaModel model)
    {
        try
        {
            var parameters = new DialogParameters();
            parameters.Add("model", model.Clone());
            DialogOptions maxWidth = new DialogOptions() { MaxWidth = MaxWidth.Medium, FullWidth = true };
            var dialog = DialogService.Show<ROIDriverBattaDialog>("Add/Edit", parameters, maxWidth);
            var result = await dialog.Result;
            if (!result.Canceled)
            {
                snackbar.Add("Saved Successfully", Severity.Success);
            }
        }
        catch (Exception a)
        {
            snackbar.Add(a.Message, Severity.Error);
        }
        GetAll();
    }

    private bool search(ROIDriverBattaModel model)
    {
        if ((model.FromStdKM.ToString().Contains(SearchItem, StringComparison.OrdinalIgnoreCase)) ||
            (model.ToStdKM.ToString().Contains(SearchItem, StringComparison.OrdinalIgnoreCase)) ||
            (model.Wheels.ToString().Contains(SearchItem, StringComparison.OrdinalIgnoreCase)) ||
            (model.LoadingMTFrom.ToString().Contains(SearchItem, StringComparison.OrdinalIgnoreCase)) ||
            (model.LoadingMTTo.ToString().Contains(SearchItem, StringComparison.OrdinalIgnoreCase)) ||
            (model.FromDate.ToString().Contains(SearchItem, StringComparison.OrdinalIgnoreCase)) ||
            (model.ToDate.ToString().Contains(SearchItem, StringComparison.OrdinalIgnoreCase)) ||
            (model.Amount.ToString().Contains(SearchItem, StringComparison.OrdinalIgnoreCase)))
        {
            return true;
        }
        return false;
    }

    private async Task EditInFrtPercentage(ROIDriverBattaInFrtPercentageModel model)
    {
        try
        {
            var parameters = new DialogParameters();
            parameters.Add("model", model.Clone());
            DialogOptions maxWidth = new DialogOptions() { MaxWidth = MaxWidth.Medium, FullWidth = true };
            var dialog = DialogService.Show<ROIDriverBattaInFrtPercentageDialog>("Add/Edit", parameters, maxWidth);
            var result = await dialog.Result;
            if (!result.Canceled)
            {
                snackbar.Add("Saved Successfully", Severity.Success);
            }
        }
        catch (Exception a)
        {
            snackbar.Add(a.Message, Severity.Error);
        }
        GetAll();
    }

    private bool searchinfrtpercentage(ROIDriverBattaInFrtPercentageModel model)
    {
        if ((model.FromDate.ToString().Contains(SearchItem, StringComparison.OrdinalIgnoreCase)) ||
            (model.ToDate.ToString().Contains(SearchItem, StringComparison.OrdinalIgnoreCase)) ||
            (model.Percentage.ToString().Contains(SearchItem, StringComparison.OrdinalIgnoreCase)))
        {
            return true;
        }
        return false;
    }
}

