@page "/ROIFixedExpense"
@using System.Threading;
@using Core.BaseModels.Operations.ROI
@using Core.IDataServices.Operations.ROI
@layout ROILayout
@attribute [Authorize]
@inject AuthenticationStateProvider auth
@inject NavigationManager NavigationManager;
@inject IROIFixedExpenseService IService
@inject IDialogService DialogService
@inject MudBlazor.ISnackbar snackbar

<MudGrid Spacing="4">
    <MudItem xs="12">
        <MudTable Items="@collection" Dense="true" Hover="true" Striped="true" Elevation="1" Filter="new Func<ROIFixedExpenseModel, bool>(search)">
            <ToolBarContent>
                <MudText Typo="Typo.h6">ROI Expense</MudText>
                <MudIconButton Icon="@Icons.Material.Filled.Add" Title="Add" @onclick="@(()=> Edit(new ROIFixedExpenseModel()))" Color="Color.Dark" Size="Size.Small"></MudIconButton>
                <MudSpacer></MudSpacer>
                <MudTextField @bind-Value="SearchItem" Placeholder="Search" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0"></MudTextField>
            </ToolBarContent>
            <HeaderContent>
                <MudTh><MudTableSortLabel SortBy="new Func<ROIFixedExpenseModel, object>(x=> x.Wheels)" InitialDirection="SortDirection.Ascending">Wheels</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<ROIFixedExpenseModel, object>(x=> x.BSType)" InitialDirection="SortDirection.Ascending">BSType</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<ROIFixedExpenseModel, object>(x=> x.BodyType)" InitialDirection="SortDirection.Ascending">BodyType</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<ROIFixedExpenseModel, object>(x=> x.BranchAdmin)" InitialDirection="SortDirection.Ascending">BranchAdmin</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<ROIFixedExpenseModel, object>(x=> x.HOAdmin)" InitialDirection="SortDirection.Ascending">HOAdmin</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<ROIFixedExpenseModel, object>(x=> x.Tax)" InitialDirection="SortDirection.Ascending">Tax</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<ROIFixedExpenseModel, object>(x=> x.Maintenance)" InitialDirection="SortDirection.Ascending">Maintenance</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<ROIFixedExpenseModel, object>(x=> x.Tyre)" InitialDirection="SortDirection.Ascending">Tyre</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<ROIFixedExpenseModel, object>(x=> x.TaxAndInsurance)" InitialDirection="SortDirection.Ascending">TaxAndInsurance</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<ROIFixedExpenseModel, object>(x=> x.FC)" InitialDirection="SortDirection.Ascending">Fc</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<ROIFixedExpenseModel, object>(x=> x.FromDate)" InitialDirection="SortDirection.Ascending">From</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<ROIFixedExpenseModel, object>(x=> x.ToDate)" InitialDirection="SortDirection.Ascending">To</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<ROIFixedExpenseModel, object>(x=> x.FC)" InitialDirection="SortDirection.Ascending">Action</MudTableSortLabel></MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Wheels">@context.Wheels</MudTd>
                <MudTd DataLabel="BSType">@context.BSType.BSType</MudTd>
                <MudTd DataLabel="BodyType">@context.BodyType</MudTd>
                <MudTd DataLabel="BranchAdmin">@context.BranchAdmin</MudTd>
                <MudTd DataLabel="HOAdmin">@context.HOAdmin</MudTd>
                <MudTd DataLabel="Tax">@context.Tax</MudTd>
                <MudTd DataLabel="Maintenance">@context.Maintenance</MudTd>
                <MudTd DataLabel="Tyre">@context.Tyre</MudTd>
                <MudTd DataLabel="TaxAndInsurance">@context.TaxAndInsurance</MudTd>
                <MudTd DataLabel="FC">@context.FC</MudTd>
                <MudTd DataLabel="FromDate">@context.FromDate?.ToShortDateString()</MudTd>
                <MudTd DataLabel="ToDate">@context.ToDate?.ToShortDateString()</MudTd>
                <MudTd>
                    <MudFab @onclick="@(() => Edit(context))" Title="Edit" Color="Color.Primary" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" IconSize="Size.Small" />
                </MudTd>
            </RowTemplate>
            <PagerContent>
                <MudTablePager PageSizeOptions="new int[] { 10, 20, 50, 100 }" />
            </PagerContent>
        </MudTable>
    </MudItem>
</MudGrid>

@code {

    private List<ROIFixedExpenseModel> collection = new List<ROIFixedExpenseModel>();
    private string SearchItem = "";
    string UserID;

    protected override async Task OnInitializedAsync()
    {
        var authprov = await auth.GetAuthenticationStateAsync();
        UserID = authprov.User.Identity.Name;
        GetAll();
    }

    private void GetAll()
    {
        collection = IService.Select().ToList();
    }

    private async Task Edit(ROIFixedExpenseModel model)
    {
        try
        {
            var parameters = new DialogParameters();
            parameters.Add("model", model.Clone());
            DialogOptions maxWidth = new DialogOptions() { MaxWidth = MaxWidth.Medium, FullWidth = true };
            var dialog = DialogService.Show<ROIFixedExpenseDialog>("Add/Edit", parameters, maxWidth);
            var result = await dialog.Result;
            if (!result.Cancelled)
            {
                snackbar.Add("Saved Successfully", Severity.Success);
            }
        }
        catch (Exception a)
        {
            snackbar.Add(a.Message, Severity.Error);
        }
        GetAll();
    }

    private bool search(ROIFixedExpenseModel model)
    {
        if ((model.Wheels.ToString().Contains(SearchItem, StringComparison.OrdinalIgnoreCase)) ||
            (model.FromDate.ToString().Contains(SearchItem, StringComparison.OrdinalIgnoreCase)) ||
            (model.ToDate.ToString().Contains(SearchItem, StringComparison.OrdinalIgnoreCase)) ||
            (model.BodyType.Contains(SearchItem, StringComparison.OrdinalIgnoreCase)) ||
            (model.BSType.BSType.Contains(SearchItem, StringComparison.OrdinalIgnoreCase)))
        {
            return true;
        }
        return false;
    }
}