@attribute [Authorize]
@inherits LayoutComponentBase
@layout MainLayout

@attribute [Authorize]

<div class="admin-page-container">
    <div class="d-flex flex-grow-1 gap-6">
        <div class="flex-shrink-0" style="width: 280px;">
            <div class="admin-glass-card pa-4 sticky-nav" style="position: sticky; top: 12px;">
                <div class="px-2 mb-4">
                    <MudText Typo="Typo.subtitle2" Class="fw-700 opacity-60 mb-1">ROI ENGINE CORE</MudText>
                    <MudDivider Class="mb-3" />
                </div>
                <MudNavMenu Rounded="true" Margin="Margin.Dense" Color="Color.Primary" Class="modern-nav-menu">
                    <MudNavLink Match="NavLinkMatch.Prefix" Href="/ROITonnage" Icon="@Icons.Material.Filled.Scale" Class="rounded-lg mb-1">ROI Tonnage</MudNavLink>
                    <MudNavLink Href="/ROIDriverIncentive" Match="NavLinkMatch.All" Icon="@Icons.Material.Outlined.CardGiftcard" Class="rounded-lg mb-1">Driver Incentives</MudNavLink>
                    <MudNavLink Match="NavLinkMatch.Prefix" Href="/ROIMileage" Icon="@Icons.Material.Filled.Speed" Class="rounded-lg mb-1">ROI Mileage</MudNavLink>
                    <MudNavLink Match="NavLinkMatch.Prefix" Href="/ROIAdBlue" Icon="@Icons.Material.Filled.Science" Class="rounded-lg mb-1">ROI AdBlue-Ratio</MudNavLink>
                    <MudNavLink Match="NavLinkMatch.Prefix" Href="/ROITime" Icon="@Icons.Material.Filled.Timer" Class="rounded-lg mb-1">ROI Time</MudNavLink>
                    <MudNavLink Match="NavLinkMatch.Prefix" Href="/ROIDriverBatta" Icon="@Icons.Material.Filled.Payments" Class="rounded-lg mb-1">ROI Driver Batta</MudNavLink>
                    <MudNavLink Match="NavLinkMatch.Prefix" Href="/ROITagging" Icon="@Icons.Material.Filled.LocalOffer" Class="rounded-lg mb-1">ROI Tagging</MudNavLink>
                    <MudNavLink Match="NavLinkMatch.Prefix" Href="/ROILoadingCharges" Icon="@Icons.Material.Filled.FileUpload" Class="rounded-lg mb-1">ROI Loading</MudNavLink>
                    <MudNavLink Match="NavLinkMatch.Prefix" Href="/ROIUnloadingCharges" Icon="@Icons.Material.Filled.FileDownload" Class="rounded-lg mb-1">ROI Unloading</MudNavLink>
                    <MudNavLink Match="NavLinkMatch.Prefix" Href="/ROIToll" Icon="@Icons.Material.Filled.AddRoad" Class="rounded-lg mb-1">ROI Toll</MudNavLink>
                    
                    <div class="px-2 mt-4 mb-2">
                        <MudText Typo="Typo.subtitle2" Class="fw-700 opacity-60 mb-1">OPERATIONAL EXPENDITURE</MudText>
                        <MudDivider Class="mb-3" />
                    </div>
                    
                    <MudNavLink Match="NavLinkMatch.Prefix" Href="/ROIAdminExpense" Icon="@Icons.Material.Filled.AccountBalance" Class="rounded-lg mb-1">Admin Expense</MudNavLink>
                    <MudNavLink Match="NavLinkMatch.Prefix" Href="/ROITyreAndMaintenanceExpense" Icon="@Icons.Material.Filled.Build" Class="rounded-lg mb-1">Tyre & Maint.</MudNavLink>
                    <MudNavLink Match="NavLinkMatch.Prefix" Href="/ROITaxAndFCExpense" Icon="@Icons.Material.Filled.Description" Class="rounded-lg mb-1">Tax & FC</MudNavLink>
                    <MudNavLink Match="NavLinkMatch.Prefix" Href="/ROIRouteExpenseAndDriverSalary" Icon="@Icons.Material.Filled.Money" Class="rounded-lg mb-1">Route & Salary</MudNavLink>
                </MudNavMenu>
            </div>
        </div>
        <div class="flex-auto">
            @Body
        </div>
    </div>
</div>

<style>
    .modern-nav-menu .mud-nav-link {
        transition: all 0.2s ease;
        padding: 10px 16px;
    }
    .modern-nav-menu .mud-nav-link.active {
        background: var(--mud-palette-primary-hover) !important;
        color: var(--mud-palette-primary) !important;
        font-weight: 600;
    }
</style>
