@page "/ROILoadingCharges"
@using System.Threading;
@using Core.BaseModels.Operations.ROI
@using Core.IDataServices.Operations.ROI
@layout ROILayout
@attribute [Authorize]
@inject AuthenticationStateProvider auth
@inject NavigationManager NavigationManager;
@inject IROILoadingChargesService IService
@inject IDialogService DialogService
@inject MudBlazor.ISnackbar snackbar
@inject IJSRuntime JSRuntime

<div class="fade-in">
    <div class="admin-header-tiered mb-6">
        <div class="d-flex align-center justify-space-between">
            <div>
                <MudText Typo="Typo.h4" Class="admin-title">ROI Loading Charges</MudText>
                <MudText Typo="Typo.body2" Class="admin-subtitle">Maintain standard loading expenditure norms per configuration and load weight for ROI calculations.</MudText>
            </div>
            <MudButton StartIcon="@Icons.Material.Filled.Add" Variant="Variant.Filled" Color="Color.Primary" Class="admin-register-btn" OnClick="@(()=> Edit(new ROILoadingChargesModel()))">ADD CHARGE RATE</MudButton>
        </div>
    </div>

    <div class="admin-glass-card mb-6 pa-4">
        <div class="d-flex align-center gap-4">
            <div style="flex-grow: 1;">
                <MudTextField @bind-Value="SearchItem" Placeholder="Search by configuration, order or amount..." Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" Variant="Variant.Outlined" Margin="Margin.Dense" Class="admin-input-group" Clearable="true" />
            </div>
        </div>
    </div>

    <div class="admin-glass-card pa-0 overflow-hidden">
        <MudTable Items="@collection" Elevation="0" Filter="new Func<ROILoadingChargesModel, bool>(search)" Class="modern-admin-table" Hover="true">
            <HeaderContent>
                <MudTh><MudTableSortLabel SortBy="new Func<ROILoadingChargesModel, object>(x=> x.Wheels)" InitialDirection="SortDirection.Ascending"><span class="admin-header-text">CONFIGURATION</span></MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<ROILoadingChargesModel, object>(x=> x.Order.OrderName)" InitialDirection="SortDirection.Ascending"><span class="admin-header-text">ORDER ENTITY</span></MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<ROILoadingChargesModel, object>(x=> x.LoadingMTFrom)" InitialDirection="SortDirection.Ascending"><span class="admin-header-text">TONNAGE (MT)</span></MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<ROILoadingChargesModel, object>(x=> x.Amount)" InitialDirection="SortDirection.Ascending"><span class="admin-header-text">STD CHARGE</span></MudTableSortLabel></MudTh>
                <MudTh><span class="admin-header-text">VALIDITY</span></MudTh>
                <MudTh Style="text-align: right;"><span class="admin-header-text">ACTIONS</span></MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Configuration">
                    <div class="d-flex flex-column">
                        <span class="fw-600">@context.Wheels Wheels</span>
                        <MudText Typo="Typo.caption" Alpha="0.6">@context.BodyType</MudText>
                    </div>
                </MudTd>
                <MudTd DataLabel="OrderName"><span class="admin-td-primary fw-600">@context.Order.OrderName</span></MudTd>
                <MudTd DataLabel="MT Range">
                    <MudChip T="string" Size="Size.Small" Color="Color.Info" Variant="Variant.Text" Class="fw-700">@context.LoadingMTFrom - @context.LoadingMTTo MT</MudChip>
                </MudTd>
                <MudTd DataLabel="Amount">
                    <MudChip T="string" Size="Size.Small" Color="Color.Success" Variant="Variant.Text" Class="fw-700">@context.Amount?.ToString("N2")</MudChip>
                </MudTd>
                <MudTd DataLabel="Validity">
                    <div class="d-flex flex-column">
                        <span class="fw-500">@context.FromDate?.ToString("dd MMM yyyy")</span>
                        <MudText Typo="Typo.caption" Alpha="0.6">to @context.ToDate?.ToString("dd MMM yyyy")</MudText>
                    </div>
                </MudTd>
                <MudTd DataLabel="Actions" Style="text-align: right;">
                    <MudTooltip Text="Adjust Charges">
                        <MudIconButton OnClick="@(() => Edit(context))" Color="Color.Primary" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Variant="Variant.Text" />
                    </MudTooltip>
                </MudTd>
            </RowTemplate>
            <PagerContent>
                <div class="pa-4">
                    <MudTablePager PageSizeOptions="new int[] { 10, 20, 50, 100 }" />
                </div>
            </PagerContent>
        </MudTable>
    </div>
</div>

@code {

    private List<ROILoadingChargesModel> collection = new List<ROILoadingChargesModel>();
    private string SearchItem = "";
    string UserID;
    int? BranchID;

    protected override async Task OnInitializedAsync()
    {
        var authprov = await auth.GetAuthenticationStateAsync();
        UserID = authprov.User.Identity.Name;
        BranchID = int.Parse(authprov.User.Claims.First(x => x.Type == "BranchID").Value);
        GetAll();
    }

    private void GetAll()
    {
        collection = IService.Select(BranchID).ToList();
    }

    private async Task Edit(ROILoadingChargesModel model)
    {
        try
        {
            var parameters = new DialogParameters();
            parameters.Add("model", model.Clone());
            DialogOptions maxWidth = new DialogOptions() { MaxWidth = MaxWidth.Medium, FullWidth = true };
            var dialog = await DialogService.ShowAsync<ROILoadingChargesDialog>("Add/Edit", parameters, maxWidth);
            var result = await dialog.Result;
            if (!result.Canceled)
            {
                snackbar.Add("Saved Successfully", Severity.Success);
            }
        }
        catch (Exception a)
        {
            snackbar.Add(a.Message, Severity.Error);
        }
        GetAll();
    }

    private bool search(ROILoadingChargesModel model)
    {
        if ((model.Order.OrderName.Contains(SearchItem, StringComparison.OrdinalIgnoreCase)) ||
            (model.Wheels.ToString().Contains(SearchItem, StringComparison.OrdinalIgnoreCase)) ||
            (model.LoadingMTFrom.ToString().Contains(SearchItem, StringComparison.OrdinalIgnoreCase)) ||
            (model.LoadingMTTo.ToString().Contains(SearchItem, StringComparison.OrdinalIgnoreCase)) ||
            (model.Amount.ToString().Contains(SearchItem, StringComparison.OrdinalIgnoreCase)) ||
            (model.FromDate.ToString().Contains(SearchItem, StringComparison.OrdinalIgnoreCase)) ||
            (model.ToDate.ToString().Contains(SearchItem, StringComparison.OrdinalIgnoreCase)))
        {
            return true;
        }
        return false;
    }
}

