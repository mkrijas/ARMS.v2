@page "/ROIMileage"
@using System.Threading;
@using Core.BaseModels.Operations.ROI
@using Core.IDataServices.Operations.ROI
@layout ROILayout
@attribute [Authorize]
@inject AuthenticationStateProvider auth
@inject NavigationManager NavigationManager;
@inject IROIMileageService IService
@inject IDialogService DialogService
@inject MudBlazor.ISnackbar snackbar
@inject IJSRuntime JSRuntime

<div class="fade-in">
    <div class="admin-header-tiered mb-6">
        <div class="d-flex align-center justify-space-between">
            <div>
                <MudText Typo="Typo.h4" Class="admin-title">ROI Mileage Norms</MudText>
                <MudText Typo="Typo.body2" Class="admin-subtitle">Set fuel efficiency benchmarks and distance expectations based on vehicle classification and load weight.</MudText>
            </div>
            <MudButton StartIcon="@Icons.Material.Filled.Add" Variant="Variant.Filled" Color="Color.Primary" Class="admin-register-btn" OnClick="@(()=> Edit(new ROIMileageModel()))">NEW BENCHMARK</MudButton>
        </div>
    </div>

    <div class="admin-glass-card mb-6 pa-4">
        <div class="d-flex align-center gap-4">
            <div style="flex-grow: 1;">
                <MudTextField @bind-Value="SearchItem" Placeholder="Search by truck type, base specification or mileage..." Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" Variant="Variant.Outlined" Margin="Margin.Dense" Class="admin-input-group" Clearable="true" />
            </div>
        </div>
    </div>

    <div class="admin-glass-card pa-0 overflow-hidden">
        <MudTable Items="@collection" Elevation="0" Filter="new Func<ROIMileageModel, bool>(search)" Class="modern-admin-table" Hover="true">
            <HeaderContent>
                <MudTh><MudTableSortLabel SortBy="new Func<ROIMileageModel, object>(x=> x.TruckTypeID)" InitialDirection="SortDirection.Ascending"><span class="admin-header-text">VEHICLE CLASSIFICATION</span></MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<ROIMileageModel, object>(x=> x.BodyType)" InitialDirection="SortDirection.Ascending"><span class="admin-header-text">CONFIGURATION</span></MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<ROIMileageModel, object>(x=> x.LoadingMTFrom)" InitialDirection="SortDirection.Ascending"><span class="admin-header-text">LOAD CAPACITY (MT)</span></MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<ROIMileageModel, object>(x=> x.Mileage)" InitialDirection="SortDirection.Ascending"><span class="admin-header-text">TARGET MILEAGE</span></MudTableSortLabel></MudTh>
                <MudTh Style="text-align: right;"><span class="admin-header-text">ACTIONS</span></MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="TruckType">
                    <div class="d-flex flex-column">
                        <span class="admin-td-primary fw-600">@context.TruckType</span>
                        <MudText Typo="Typo.caption" Alpha="0.6">@context.BSType</MudText>
                    </div>
                </MudTd>
                <MudTd DataLabel="BodyType">@context.BodyType</MudTd>
                <MudTd DataLabel="MT Range">
                    <MudChip T="string" Size="Size.Small" Color="Color.Info" Variant="Variant.Text" Class="fw-700">@context.LoadingMTFrom - @context.LoadingMTTo MT</MudChip>
                </MudTd>
                <MudTd DataLabel="Mileage"><span class="fw-700 text-primary">@context.Mileage KM/L</span></MudTd>
                <MudTd DataLabel="Actions" Style="text-align: right;">
                    <MudTooltip Text="Update Norms">
                        <MudIconButton OnClick="@(() => Edit(context))" Color="Color.Primary" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Variant="Variant.Text" />
                    </MudTooltip>
                </MudTd>
            </RowTemplate>
            <PagerContent>
                <div class="pa-4">
                    <MudTablePager PageSizeOptions="new int[] { 10, 20, 50, 100 }" />
                </div>
            </PagerContent>
        </MudTable>
    </div>
</div>

@code {

    private List<ROIMileageModel> collection = new List<ROIMileageModel>();
    private string SearchItem = "";
    string UserID;
    int? BranchID;

    protected override async Task OnInitializedAsync()
    {
        var authprov = await auth.GetAuthenticationStateAsync();
        UserID = authprov.User.Identity.Name;
        BranchID = int.Parse(authprov.User.Claims.First(x => x.Type == "BranchID").Value);
        GetAll();
    }

    private void GetAll()
    {
        collection = IService.Select(BranchID).ToList();
    }

    private async Task Edit(ROIMileageModel model)
    {
        try
        {
            var parameters = new DialogParameters();
            parameters.Add("model", model.Clone());
            DialogOptions maxWidth = new DialogOptions() { MaxWidth = MaxWidth.Medium, FullWidth = true };
            var dialog = await DialogService.ShowAsync<ROIMileageDialog>("Add/Edit", parameters, maxWidth);
            var result = await dialog.Result;
            if (!result.Canceled)
            {
                snackbar.Add("Saved Successfully", Severity.Success);
            }
        }
        catch (Exception a)
        {
            snackbar.Add(a.Message, Severity.Error);
        }
        GetAll();
    }

    private bool search(ROIMileageModel model)
    {
        if ((model.TruckType.Contains(SearchItem, StringComparison.OrdinalIgnoreCase)) ||
            (model.BSType.ToString().Contains(SearchItem, StringComparison.OrdinalIgnoreCase)) ||
            (model.LoadingMTFrom.ToString().Contains(SearchItem, StringComparison.OrdinalIgnoreCase)) ||
            (model.LoadingMTTo.ToString().Contains(SearchItem, StringComparison.OrdinalIgnoreCase)) ||
            (model.Mileage.ToString().Contains(SearchItem, StringComparison.OrdinalIgnoreCase)))
        {
            return true;
        }
        return false;
    }
}

