@using System.Threading;
@using Core.BaseModels.Operations.ROI
@using Core.IDataServices.Operations.ROI
@attribute [Authorize]
@inject AuthenticationStateProvider auth
@inject IROIOrderTonnageModifierService IROIOrderTonnageModifierService
@inject IDialogService DialogService
@inject MudBlazor.ISnackbar snackbar
@inject IRoleService<RoleModel> Irole

<MudDialog Style="overflow-y: hidden;">
    <TitleContent>
        <MudText Typo="Typo.h6">
            Modifier
        </MudText>
    </TitleContent>
    <DialogContent>
        <EditForm Model="@model" id="ROITonnageForm" OnValidSubmit="Submit">
            <MudTable Items="@Collection" Dense="true" Hover="true" Striped="true" Elevation="1">
                <ToolBarContent>
                    <MudText Typo="Typo.h6">@model.Order.OrderName</MudText>
                    <MudSpacer />
                </ToolBarContent>
                <HeaderContent>
                    <MudTh><MudTableSortLabel SortBy="new Func<ROIOrderTonnageModifierSubModel, object>(x=> x.Wheels)" InitialDirection="SortDirection.Ascending">Wheels</MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<ROIOrderTonnageModifierSubModel, object>(x=> x.Modifier)" InitialDirection="SortDirection.Ascending">Tonnage</MudTableSortLabel></MudTh>
                    <MudTh>Actions</MudTh>
                </HeaderContent>
                <RowTemplate Context="item">
                    <MudTd DataLabel="Wheels">
                        <MudText Margin="Margin.Dense">@item.Wheels</MudText>
                    </MudTd>
                    <MudTd DataLabel="Modifier">
                        <MudTextField @bind-Value="@item.Modifier" Label="Modifier" Variant="Variant.Outlined" Margin="Margin.Dense" Dense="true" />
                    </MudTd>
                    <MudTd DataLabel="Actions">
                        <MudFab Style="font-size:5px" @onclick="() => Delete(item)" Color="Color.Error" Icon="@Icons.Material.Filled.Delete" Size="Size.Small" IconSize="Size.Small" />
                    </MudTd>
                </RowTemplate>
                <PagerContent>
                    <MudTablePager PageSizeOptions="new int[] { 10, 20, 50, 100 }" />
                </PagerContent>
            </MudTable>
        </EditForm>
    </DialogContent>
    <DialogActions>
        <div style="padding-right:12px; padding-bottom:12px;">
            <MudButton Size="Size.Large" Variant="Variant.Filled" Color="Color.Success" form="ROITonnageForm" ButtonType="ButtonType.Submit" Class="ml-auto">Submit</MudButton>
        </div>
    </DialogActions>
</MudDialog>

@code {

    [CascadingParameter] MudDialogInstance MudDialog { get; set; }
    [Parameter]
    public ROIOrderTonnageModifierModel model { get; set; } = new();
    public List<ROIOrderTonnageModifierSubModel> Collection = new();
    string UserID;
    int BranchID;
    public int DocTypeID = 143;
    public bool HasPermissionROIServiceEdit { get; set; } = false;

    protected override async Task OnInitializedAsync()
    {
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionROIServiceEdit = await Irole.HasClaim(DocTypeID.ToString(), "Edit", ctc.Token);

        var authprov = await auth.GetAuthenticationStateAsync();
        UserID = authprov.User.Identity.Name;
        BranchID = int.Parse(authprov.User.Claims.First(x => x.Type == "BranchID").Value);
        
        GetAll();
    }

    private void GetAll()
    {
        Collection = IROIOrderTonnageModifierService.SelectByOrder(null, model.Order.OrderID, BranchID).ToList();
    }

    private void Delete(ROIOrderTonnageModifierSubModel context)
    {
        context.Modifier = null;
    }

    protected async Task Submit()
    {
        if(HasPermissionROIServiceEdit)
        {
            model.modifiers = Collection;
            model.UserInfo.UserID = UserID;

            try
            {
                model = IROIOrderTonnageModifierService.Update(model);
                MudDialog.Close(model);
            }
            catch (Exception ex)
            {
                snackbar.Add(ex.Message, Severity.Warning);
            }
        }
        else
        {
            bool? result = await DialogService.ShowMessageBox(
                "Permission denied!",
                "You don't have any permission to Edit ROI settings.");
        }
    }

    public void Cancel()
    {
        MudDialog.Cancel();
    }
}
