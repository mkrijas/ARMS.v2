@page "/ROIRouteExpenseAndDriverSalary"
@using System.Threading;
@using Core.BaseModels.Operations.ROI
@using Core.IDataServices.Operations.ROI
@layout ROILayout
@attribute [Authorize]
@inject AuthenticationStateProvider auth
@inject NavigationManager NavigationManager;
@inject IROIRouteExpenseAndDriverSalaryService IService
@inject IDialogService DialogService
@inject MudBlazor.ISnackbar snackbar
@inject IJSRuntime JSRuntime

<MudGrid Spacing="4">
    <MudItem xs="12">
        <MudTable Items="@collection" Dense="true" Hover="true" Striped="true" Elevation="1" Filter="new Func<ROIRouteExpenseAndDriverSalaryModel, bool>(search)">
            <ToolBarContent>
                <MudText Typo="Typo.h6">ROI Route Expense & Driver Salary</MudText>
                <MudIconButton Icon="@Icons.Material.Filled.Add" Title="Add" @onclick="@(()=> Edit(new ROIRouteExpenseAndDriverSalaryModel()))" Color="Color.Dark" Size="Size.Small"></MudIconButton>
                <MudSpacer></MudSpacer>
                <MudTextField @bind-Value="SearchItem" Placeholder="Search" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0"></MudTextField>
            </ToolBarContent>
            <HeaderContent>
                <MudTh><MudTableSortLabel SortBy="new Func<ROIRouteExpenseAndDriverSalaryModel, object>(x=> x.RouteExpense)" InitialDirection="SortDirection.Ascending">Rote Expense</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<ROIRouteExpenseAndDriverSalaryModel, object>(x=> x.DriverSalary)" InitialDirection="SortDirection.Ascending">Driver Salary</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<ROIRouteExpenseAndDriverSalaryModel, object>(x=> x.FromDate)" InitialDirection="SortDirection.Ascending">From</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<ROIRouteExpenseAndDriverSalaryModel, object>(x=> x.ToDate)" InitialDirection="SortDirection.Ascending">To</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<ROIRouteExpenseAndDriverSalaryModel, object>(x=> x.RouteExpense)" InitialDirection="SortDirection.Ascending">Action</MudTableSortLabel></MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="RouteExpense">@context.RouteExpense</MudTd>
                <MudTd DataLabel="DriverSalary">@context.DriverSalary</MudTd>
                <MudTd DataLabel="FromDate">@context.FromDate?.ToShortDateString()</MudTd>
                <MudTd DataLabel="ToDate">@context.ToDate?.ToShortDateString()</MudTd>
                <MudTd>
                    <MudFab @onclick="@(() => Edit(context))" Title="Edit" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Edit" Size="Size.Small" />
                </MudTd>
            </RowTemplate>
            <PagerContent>
                <MudTablePager PageSizeOptions="new int[] { 10, 20, 50, 100 }" />
            </PagerContent>
        </MudTable>            
    </MudItem>
</MudGrid>

@code {

    private List<ROIRouteExpenseAndDriverSalaryModel> collection = new List<ROIRouteExpenseAndDriverSalaryModel>();
    private string SearchItem = "";
    string UserID;
    int? BranchID;

    protected override async Task OnInitializedAsync()
    {
        var authprov = await auth.GetAuthenticationStateAsync();
        UserID = authprov.User.Identity.Name;
        BranchID = int.Parse(authprov.User.Claims.First(x => x.Type == "BranchID").Value);
        GetAll();
    }

    private void GetAll()
    {
        collection = IService.SelectByBranch(BranchID).ToList();
    }

    private async Task Edit(ROIRouteExpenseAndDriverSalaryModel model)
    {
        try
        {
            var parameters = new DialogParameters();
            parameters.Add("model", model.Clone());
            DialogOptions maxWidth = new DialogOptions() { MaxWidth = MaxWidth.Medium, FullWidth = true };
            var dialog = DialogService.Show<ROIRouteExpenseAndDriverSalaryDialog>("Add/Edit", parameters, maxWidth);
            var result = await dialog.Result;
            if (!result.Canceled)
            {
                snackbar.Add("Saved Successfully", Severity.Success);
            }
        }
        catch (Exception a)
        {
            snackbar.Add(a.Message, Severity.Error);
        }
        GetAll();
    }

    private bool search(ROIRouteExpenseAndDriverSalaryModel model)
    {
        if ((model.DriverSalary.ToString().Contains(SearchItem, StringComparison.OrdinalIgnoreCase)) ||
            (model.FromDate.ToString().Contains(SearchItem, StringComparison.OrdinalIgnoreCase)) ||
            (model.ToDate.ToString().Contains(SearchItem, StringComparison.OrdinalIgnoreCase)) ||
            (model.RouteExpense.ToString().Contains(SearchItem, StringComparison.OrdinalIgnoreCase)))
        {
            return true;
        }
        return false;
    }

}

