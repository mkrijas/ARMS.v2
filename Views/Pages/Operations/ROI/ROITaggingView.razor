@page "/ROITagging"
@using System.Threading;
@using Core.BaseModels.Operations.ROI
@using Core.IDataServices.Operations.ROI
@layout ROILayout
@attribute [Authorize]
@inject AuthenticationStateProvider auth
@inject NavigationManager NavigationManager;
@inject IROITaggingService IService
@inject IDialogService DialogService
@inject MudBlazor.ISnackbar snackbar
@inject IJSRuntime JSRuntime

<MudGrid Spacing="4">
    <MudItem xs="12">
        <MudTable Items="@collection" Dense="true" Hover="true" Striped="true" Elevation="1" Filter="new Func<ROITaggingModel, bool>(search)">
            <ToolBarContent>
                <MudText Typo="Typo.h6">ROI Tagging</MudText>
                <MudIconButton Icon="@Icons.Material.Filled.Add" Title="Add" @onclick="@(()=> Edit(new ROITaggingModel()))" Color="Color.Dark" Size="Size.Small"></MudIconButton>
                <MudSpacer></MudSpacer>
                <MudTextField @bind-Value="SearchItem" Placeholder="Search" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0"></MudTextField>
            </ToolBarContent>
            <HeaderContent>
                <MudTh><MudTableSortLabel SortBy="new Func<ROITaggingModel, object>(x=> x.Wheels)" InitialDirection="SortDirection.Ascending">Wheels</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<ROITaggingModel, object>(x=> x.BodyType)" InitialDirection="SortDirection.Ascending">Body Type</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<ROITaggingModel, object>(x=> x.Order.OrderName)" InitialDirection="SortDirection.Ascending">Order Name</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<ROITaggingModel, object>(x=> x.Amount)" InitialDirection="SortDirection.Ascending">Amount</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<ROITaggingModel, object>(x=> x.FromDate)" InitialDirection="SortDirection.Ascending">From</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<ROITaggingModel, object>(x=> x.ToDate)" InitialDirection="SortDirection.Ascending">To</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<ROITaggingModel, object>(x=> x.Amount)" InitialDirection="SortDirection.Ascending">Action</MudTableSortLabel></MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Wheels">@context.Wheels</MudTd>
                <MudTd DataLabel="BodyType">@context.BodyType</MudTd>
                <MudTd DataLabel="OrderName">@context.Order.OrderName</MudTd>
                <MudTd DataLabel="Amount">@context.Amount</MudTd>
                <MudTd DataLabel="FromDate">@context.FromDate?.ToShortDateString()</MudTd>
                <MudTd DataLabel="ToDate">@context.ToDate?.ToShortDateString()</MudTd>
                <MudTd>
                    <MudFab @onclick="@(() => Edit(context))" Title="Edit" Color="Color.Primary" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" IconSize="Size.Small" />
                </MudTd>
            </RowTemplate>
            <PagerContent>
                <MudTablePager PageSizeOptions="new int[] { 10, 20, 50, 100 }" />
            </PagerContent>
        </MudTable>
    </MudItem>
</MudGrid>

@code {

    private List<ROITaggingModel> collection = new List<ROITaggingModel>();
    private string SearchItem = "";
    string UserID;

    protected override async Task OnInitializedAsync()
    {
        var authprov = await auth.GetAuthenticationStateAsync();
        UserID = authprov.User.Identity.Name;
        GetAll();
    }

    private void GetAll()
    {
        collection = IService.Select().ToList();
    }

    private async Task Edit(ROITaggingModel model)
    {
        try
        {
            var parameters = new DialogParameters();
            parameters.Add("model", model.Clone());
            DialogOptions maxWidth = new DialogOptions() { MaxWidth = MaxWidth.Medium, FullWidth = true };
            var dialog = DialogService.Show<ROITaggingDialog>("Add/Edit", parameters, maxWidth);
            var result = await dialog.Result;
            if (!result.Cancelled)
            {
                snackbar.Add("Saved Successfully", Severity.Success);
            }
        }
        catch (Exception a)
        {
            snackbar.Add(a.Message, Severity.Error);
        }
        GetAll();
    }

    private bool search(ROITaggingModel model)
    {
        if ((model.ID != null && model.Order.OrderName.Contains(SearchItem, StringComparison.OrdinalIgnoreCase)))
        {
            return true;
        }
        return false;
    }
}