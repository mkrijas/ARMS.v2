@page "/ROITagging"
@using System.Threading;
@using Core.BaseModels.Operations.ROI
@using Core.IDataServices.Operations.ROI
@layout ROILayout
@attribute [Authorize]
@inject AuthenticationStateProvider auth
@inject NavigationManager NavigationManager;
@inject IROITaggingService IService
@inject IDialogService DialogService
@inject MudBlazor.ISnackbar snackbar
@inject IJSRuntime JSRuntime

<div class="fade-in">
    <div class="admin-header-tiered mb-6">
        <div class="d-flex align-center justify-space-between">
            <div>
                <MudText Typo="Typo.h4" Class="admin-title">ROI Tagging Configuration</MudText>
                <MudText Typo="Typo.body2" Class="admin-subtitle">Manage regional tagging fees and promotional surcharges grouped by vehicle configuration.</MudText>
            </div>
            <MudButton StartIcon="@Icons.Material.Filled.Add" Variant="Variant.Filled" Color="Color.Primary" Class="admin-register-btn" OnClick="@(()=> Edit(new ROITaggingModel()))">ADD CHARGE</MudButton>
        </div>
    </div>

    <div class="admin-glass-card mb-6 pa-4">
        <div class="d-flex align-center gap-4">
            <div style="flex-grow: 1;">
                <MudTextField @bind-Value="SearchItem" Placeholder="Search by order, wheels or amount..." Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" Variant="Variant.Outlined" Margin="Margin.Dense" Class="admin-input-group" Clearable="true" />
            </div>
        </div>
    </div>

    <div class="admin-glass-card pa-0 overflow-hidden">
        <MudTable Items="@collection" Elevation="0" Filter="new Func<ROITaggingModel, bool>(search)" Class="modern-admin-table" Hover="true">
            <HeaderContent>
                <MudTh><MudTableSortLabel SortBy="new Func<ROITaggingModel, object>(x=> x.Wheels)" InitialDirection="SortDirection.Ascending"><span class="admin-header-text">WHEELS</span></MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<ROITaggingModel, object>(x=> x.BodyType)" InitialDirection="SortDirection.Ascending"><span class="admin-header-text">BODY TYPE</span></MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<ROITaggingModel, object>(x=> x.Order.OrderName)" InitialDirection="SortDirection.Ascending"><span class="admin-header-text">ORDER ENTITY</span></MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<ROITaggingModel, object>(x=> x.TaggingAmount)" InitialDirection="SortDirection.Ascending"><span class="admin-header-text">AMOUNT</span></MudTableSortLabel></MudTh>                
                <MudTh><MudTableSortLabel SortBy="new Func<ROITaggingModel, object>(x=> x.FromDate)" InitialDirection="SortDirection.Ascending"><span class="admin-header-text">EFFECTIVE FROM</span></MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<ROITaggingModel, object>(x=> x.ToDate)" InitialDirection="SortDirection.Ascending"><span class="admin-header-text">EFFECTIVE TO</span></MudTableSortLabel></MudTh>
                <MudTh Style="text-align: right;"><span class="admin-header-text">ACTIONS</span></MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Wheels"><span class="fw-600">@context.Wheels</span></MudTd>
                <MudTd DataLabel="BodyType">@context.BodyType</MudTd>
                <MudTd DataLabel="OrderName"><span class="admin-td-primary fw-600">@context.Order.OrderName</span></MudTd>
                <MudTd DataLabel="TaggingAmount">
                    <MudChip T="string" Size="Size.Small" Color="Color.Success" Variant="Variant.Text" Class="fw-700">@context.TaggingAmount?.ToString("N2")</MudChip>
                </MudTd>              
                <MudTd DataLabel="FromDate">@context.FromDate?.ToString("dd MMM yyyy")</MudTd>
                <MudTd DataLabel="ToDate">@context.ToDate?.ToString("dd MMM yyyy")</MudTd>
                <MudTd DataLabel="Actions" Style="text-align: right;">
                    <MudTooltip Text="Modify Charge">
                        <MudIconButton OnClick="@(() => Edit(context))" Color="Color.Primary" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Variant="Variant.Text" />
                    </MudTooltip>
                </MudTd>
            </RowTemplate>
            <PagerContent>
                <div class="pa-4">
                    <MudTablePager PageSizeOptions="new int[] { 10, 20, 50, 100 }" />
                </div>
            </PagerContent>
        </MudTable>
    </div>
</div>

@code {

    private List<ROITaggingModel> collection = new List<ROITaggingModel>();
    private string SearchItem = "";
    string UserID;
    int? BranchID;

    protected override async Task OnInitializedAsync()
    {
        var authprov = await auth.GetAuthenticationStateAsync();
        UserID = authprov.User.Identity.Name;
        BranchID = int.Parse(authprov.User.Claims.First(x => x.Type == "BranchID").Value);
        GetAll();
    }

    private void GetAll()
    {
        collection = IService.Select(BranchID).ToList();
    }

    private async Task Edit(ROITaggingModel model)
    {
        try
        {
            var parameters = new DialogParameters();
            parameters.Add("model", model.Clone());
            DialogOptions maxWidth = new DialogOptions() { MaxWidth = MaxWidth.Medium, FullWidth = true };
            var dialog = await DialogService.ShowAsync<ROITaggingDialog>("Add/Edit", parameters, maxWidth);
            var result = await dialog.Result;
            if (!result.Canceled)
            {
                snackbar.Add("Saved Successfully", Severity.Success);
            }
        }
        catch (Exception a)
        {
            snackbar.Add(a.Message, Severity.Error);
        }
        GetAll();
    }

    private bool search(ROITaggingModel model)
    {
        if ((model.Order.OrderName.Contains(SearchItem, StringComparison.OrdinalIgnoreCase)) ||
            (model.Wheels.ToString().Contains(SearchItem, StringComparison.OrdinalIgnoreCase)) ||
            (model.TaggingAmount.ToString().Contains(SearchItem, StringComparison.OrdinalIgnoreCase)) ||           
            (model.FromDate.ToString().Contains(SearchItem, StringComparison.OrdinalIgnoreCase)) ||
            (model.ToDate.ToString().Contains(SearchItem, StringComparison.OrdinalIgnoreCase)))
        {
            return true;
        }
        return false;
    }
}

