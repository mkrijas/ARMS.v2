@page "/ROITaxAndFCExpense"
@using System.Threading;
@using Core.BaseModels.Operations.ROI
@using Core.IDataServices.Operations.ROI
@layout ROILayout
@attribute [Authorize]
@inject AuthenticationStateProvider auth
@inject NavigationManager NavigationManager;
@inject IROITaxAndFCExpenseService IService
@inject IDialogService DialogService
@inject MudBlazor.ISnackbar snackbar

<div class="fade-in">
    <div class="admin-header-tiered mb-6">
        <div class="d-flex align-center justify-space-between">
            <div>
                <MudText Typo="Typo.h4" Class="admin-title">ROI Tax & Compliance Expenses</MudText>
                <MudText Typo="Typo.body2" Class="admin-subtitle">Monitor statutory expenses including Tax, Insurance, and Fitness Certificate costs at a vehicle level for ROI accuracy.</MudText>
            </div>
            <MudButton StartIcon="@Icons.Material.Filled.Add" Variant="Variant.Filled" Color="Color.Primary" Class="admin-register-btn" OnClick="@(()=> Edit(new ROITaxAndFCExpenseModel()))">ADD COMPLIANCE RECORD</MudButton>
        </div>
    </div>

    <div class="admin-glass-card mb-6 pa-4">
        <div class="d-flex align-center gap-4">
            <div style="flex-grow: 1;">
                <MudTextField @bind-Value="SearchItem" Placeholder="Search by vehicle, tax or FC cost..." Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" Variant="Variant.Outlined" Margin="Margin.Dense" Class="admin-input-group" Clearable="true" />
            </div>
        </div>
    </div>

    <div class="admin-glass-card pa-0 overflow-hidden">
        <MudTable Items="@collection" Elevation="0" Filter="new Func<ROITaxAndFCExpenseModel, bool>(search)" Class="modern-admin-table" Hover="true">
            <HeaderContent>
                <MudTh><MudTableSortLabel SortBy="new Func<ROITaxAndFCExpenseModel, object>(x=> x.Truck?.RegNo)" InitialDirection="SortDirection.Ascending"><span class="admin-header-text">VEHICLE</span></MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<ROITaxAndFCExpenseModel, object>(x=> x.TaxAndInsurance)"><span class="admin-header-text">TAX & INSURANCE</span></MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<ROITaxAndFCExpenseModel, object>(x=> x.FC)"><span class="admin-header-text">FC CHARGES</span></MudTableSortLabel></MudTh>
                <MudTh><span class="admin-header-text">VALIDITY</span></MudTh>
                <MudTh Style="text-align: right;"><span class="admin-header-text">ACTIONS</span></MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Truck"><span class="admin-td-primary fw-600">@context.Truck?.RegNo</span></MudTd>
                <MudTd DataLabel="TaxAndInsurance">
                    <MudChip T="string" Size="Size.Small" Color="Color.Info" Variant="Variant.Text" Class="fw-700">@context.TaxAndInsurance?.ToString("N2")</MudChip>
                </MudTd>
                <MudTd DataLabel="FC">
                    <MudChip T="string" Size="Size.Small" Color="Color.Secondary" Variant="Variant.Text" Class="fw-700">@context.FC?.ToString("N2")</MudChip>
                </MudTd>
                <MudTd DataLabel="Validity">
                    <div class="d-flex flex-column">
                        <span class="fw-500">@context.FromDate?.ToString("dd MMM yyyy")</span>
                        <MudText Typo="Typo.caption" Alpha="0.6">to @context.ToDate?.ToString("dd MMM yyyy")</MudText>
                    </div>
                </MudTd>
                <MudTd DataLabel="Actions" Style="text-align: right;">
                    <MudTooltip Text="Update Compliance Costs">
                        <MudIconButton OnClick="@(() => Edit(context))" Color="Color.Primary" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Variant="Variant.Text" />
                    </MudTooltip>
                </MudTd>
            </RowTemplate>
            <PagerContent>
                <div class="pa-4">
                    <MudTablePager PageSizeOptions="new int[] { 10, 20, 50, 100 }" />
                </div>
            </PagerContent>
        </MudTable>
    </div>
</div>

@code {

    private List<ROITaxAndFCExpenseModel> collection = new List<ROITaxAndFCExpenseModel>();
    private string SearchItem = "";
    string UserID;
    int? BranchID;

    protected override async Task OnInitializedAsync()
    {
        var authprov = await auth.GetAuthenticationStateAsync();
        UserID = authprov.User.Identity.Name;
        BranchID = int.Parse(authprov.User.Claims.First(x => x.Type == "BranchID").Value);
        GetAll();
    }

    private void GetAll()
    {
        collection = IService.Select(BranchID).ToList();
    }

    private async Task Edit(ROITaxAndFCExpenseModel model)
    {
        try
        {
            var parameters = new DialogParameters();
            parameters.Add("model", model.Clone());
            DialogOptions maxWidth = new DialogOptions() { MaxWidth = MaxWidth.Medium, FullWidth = true };
            var dialog = await DialogService.ShowAsync<ROITaxAndFCExpenseDialog>("Add/Edit", parameters, maxWidth);
            var result = await dialog.Result;
            if (!result.Canceled)
            {
                snackbar.Add("Saved Successfully", Severity.Success);
            }
        }
        catch (Exception a)
        {
            snackbar.Add(a.Message, Severity.Error);
        }
        GetAll();
    }

    private bool search(ROITaxAndFCExpenseModel model)
    {
        if ((model.Truck?.RegNo is not null && model.Truck.RegNo.Contains(SearchItem, StringComparison.OrdinalIgnoreCase)) ||
            (model.FromDate.ToString().Contains(SearchItem, StringComparison.OrdinalIgnoreCase)) ||
            (model.ToDate.ToString().Contains(SearchItem, StringComparison.OrdinalIgnoreCase)) ||
            (model.FC.ToString().Contains(SearchItem, StringComparison.OrdinalIgnoreCase)) ||
            (model.TaxAndInsurance.ToString().Contains(SearchItem, StringComparison.OrdinalIgnoreCase)))
        {
            return true;
        }
        return false;
    }
}

