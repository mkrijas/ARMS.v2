@page "/ROITaxAndFCExpense"
@using System.Threading;
@using Core.BaseModels.Operations.ROI
@using Core.IDataServices.Operations.ROI
@layout ROILayout
@attribute [Authorize]
@inject AuthenticationStateProvider auth
@inject NavigationManager NavigationManager;
@inject IROITaxAndFCExpenseService IService
@inject IDialogService DialogService
@inject MudBlazor.ISnackbar snackbar

<MudGrid Spacing="4">
    <MudItem xs="12">
        <MudTable Items="@collection" Dense="true" Hover="true" Striped="true" Elevation="1" Filter="new Func<ROITaxAndFCExpenseModel, bool>(search)">
            <ToolBarContent>
                <MudText Typo="Typo.h6">ROI Tax And FC Expense</MudText>
                <MudIconButton Icon="@Icons.Material.Filled.Add" Title="Add" @onclick="@(()=> Edit(new ROITaxAndFCExpenseModel()))" Color="Color.Dark" Size="Size.Small"></MudIconButton>
                <MudSpacer></MudSpacer>
                <MudTextField @bind-Value="SearchItem" Placeholder="Search" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0"></MudTextField>
            </ToolBarContent>
            <HeaderContent>
                <MudTh><MudTableSortLabel SortBy="new Func<ROITaxAndFCExpenseModel, object>(x=> x.Truck.RegNo)" InitialDirection="SortDirection.Ascending">Reg No</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<ROITaxAndFCExpenseModel, object>(x=> x.TaxAndInsurance)" >TaxAndInsurance</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<ROITaxAndFCExpenseModel, object>(x=> x.FC)" >Fc</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<ROITaxAndFCExpenseModel, object>(x=> x.FromDate)" >From</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<ROITaxAndFCExpenseModel, object>(x=> x.ToDate)" >To</MudTableSortLabel></MudTh>
                <MudTh>Action</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Truck">@context.Truck.RegNo</MudTd>
                <MudTd DataLabel="TaxAndInsurance">@context.TaxAndInsurance</MudTd>
                <MudTd DataLabel="FC">@context.FC</MudTd>
                <MudTd DataLabel="FromDate">@context.FromDate?.ToShortDateString()</MudTd>
                <MudTd DataLabel="ToDate">@context.ToDate?.ToShortDateString()</MudTd>
                <MudTd>
                    <MudFab @onclick="@(() => Edit(context))" Title="Edit" Color="Color.Primary" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" IconSize="Size.Small" />
                </MudTd>
            </RowTemplate>
            <PagerContent>
                <MudTablePager PageSizeOptions="new int[] { 10, 20, 50, 100 }" />
            </PagerContent>
        </MudTable>
    </MudItem>
</MudGrid>

@code {

    private List<ROITaxAndFCExpenseModel> collection = new List<ROITaxAndFCExpenseModel>();
    private string SearchItem = "";
    string UserID;
    int? BranchID;

    protected override async Task OnInitializedAsync()
    {
        var authprov = await auth.GetAuthenticationStateAsync();
        UserID = authprov.User.Identity.Name;
        BranchID = int.Parse(authprov.User.Claims.First(x => x.Type == "BranchID").Value);
        GetAll();
    }

    private void GetAll()
    {
        collection = IService.Select(BranchID).ToList();
    }

    private async Task Edit(ROITaxAndFCExpenseModel model)
    {
        try
        {
            var parameters = new DialogParameters();
            parameters.Add("model", model.Clone());
            DialogOptions maxWidth = new DialogOptions() { MaxWidth = MaxWidth.Medium, FullWidth = true };
            var dialog = DialogService.Show<ROITaxAndFCExpenseDialog>("Add/Edit", parameters, maxWidth);
            var result = await dialog.Result;
            if (!result.Canceled)
            {
                snackbar.Add("Saved Successfully", Severity.Success);
            }
        }
        catch (Exception a)
        {
            snackbar.Add(a.Message, Severity.Error);
        }
        GetAll();
    }

    private bool search(ROITaxAndFCExpenseModel model)
    {
        if ((model.Truck.RegNo.Contains(SearchItem, StringComparison.OrdinalIgnoreCase)) ||
            (model.FromDate.ToString().Contains(SearchItem, StringComparison.OrdinalIgnoreCase)) ||
            (model.ToDate.ToString().Contains(SearchItem, StringComparison.OrdinalIgnoreCase)) ||
            (model.FC.ToString().Contains(SearchItem, StringComparison.OrdinalIgnoreCase)) ||
            (model.TaxAndInsurance.ToString().Contains(SearchItem, StringComparison.OrdinalIgnoreCase)))
        {
            return true;
        }
        return false;
    }
}