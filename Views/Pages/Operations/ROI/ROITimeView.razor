@page "/ROITime"
@using System.Threading;
@using Core.BaseModels.Operations.ROI
@using Core.IDataServices.Operations.ROI
@layout ROILayout
@attribute [Authorize]
@inject AuthenticationStateProvider auth
@inject NavigationManager NavigationManager


@inject IROITimeService IROITimeService
@inject IDialogService DialogService
@inject MudBlazor.ISnackbar snackbar
@inject IJSRuntime JSRuntime

<div class="fade-in">
    <div class="admin-header-tiered mb-6">
        <div class="d-flex align-center justify-space-between">
            <div>
                <MudText Typo="Typo.h4" Class="admin-title">ROI Time Parameters</MudText>
                <MudText Typo="Typo.body2" Class="admin-subtitle">Optimize logistical cycles by configuring standard loading durations and vehicle speed benchmarks.</MudText>
            </div>
            <div class="d-flex align-center gap-4">
                <MudToggleGroup T="bool" Value="@ViewChange" ValueChanged="@((bool x) => TableViewChange(x))" SelectionMode="SelectionMode.SingleSelection" Color="Color.Primary" CheckMark="false" FixedContent="true" Class="admin-toggle-group">
                    <MudToggleItem Value="false" Text="SPEED NORMS" />
                    <MudToggleItem Value="true" Text="DURATION NORMS" />
                </MudToggleGroup>
                @if (!ViewChange)
                {
                    <MudButton StartIcon="@Icons.Material.Filled.Add" Variant="Variant.Filled" Color="Color.Primary" Class="admin-register-btn" OnClick="@(()=> EditWheelSpeed(new ROIWheelSpeedModel()))">ADD SPEED</MudButton>
                }
            </div>
        </div>
    </div>

    <div class="admin-glass-card mb-6 pa-4">
        <div class="d-flex align-center gap-4">
            <div style="flex-grow: 1;">
                <MudTextField @bind-Value="SearchItem" Placeholder="Search by wheels, speed or order entity..." Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" Variant="Variant.Outlined" Margin="Margin.Dense" Class="admin-input-group" Clearable="true" />
            </div>
        </div>
    </div>

    <div class="admin-glass-card pa-0 overflow-hidden">
        @if (!ViewChange)
        {
            <MudTable Items="@WheelSpeedcollection" Elevation="0" Class="modern-admin-table" Hover="true" Filter="new Func<ROIWheelSpeedModel, bool>(SearchWheelSpeed)">
                <HeaderContent>
                    <MudTh><MudTableSortLabel SortBy="new Func<ROIWheelSpeedModel, object>(x=> x.Wheels)" InitialDirection="SortDirection.Ascending"><span class="admin-header-text">WHEEL CONFIGURATION</span></MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<ROIWheelSpeedModel, object>(x=> x.Speed)" InitialDirection="SortDirection.Ascending"><span class="admin-header-text">ESTIMATED SPEED (KM/H)</span></MudTableSortLabel></MudTh>
                    <MudTh Style="text-align: right;"><span class="admin-header-text">ACTIONS</span></MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Wheels"><span class="fw-600">@context.Wheels Wheels</span></MudTd>
                    <MudTd DataLabel="Speed">
                        <MudChip T="string" Size="Size.Small" Color="Color.Secondary" Variant="Variant.Text" Class="fw-700">@context.Speed KM/H</MudChip>
                    </MudTd>
                    <MudTd DataLabel="Actions" Style="text-align: right;">
                        <MudTooltip Text="Adjust Speed">
                            <MudIconButton OnClick="@(() => EditWheelSpeed(context))" Color="Color.Primary" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Variant="Variant.Text" />
                        </MudTooltip>
                    </MudTd>
                </RowTemplate>
                <PagerContent>
                    <div class="pa-4">
                        <MudTablePager PageSizeOptions="new int[] { 10, 20, 50, 100 }" />
                    </div>
                </PagerContent>
            </MudTable>
        }
        else
        {
            <MudTable Items="@LoadUnloadcollection" Elevation="0" Class="modern-admin-table" Hover="true" Filter="new Func<ROILoadAndUnloadModel, bool>(SearchLoadUnloadDuration)">
                <HeaderContent>
                    <MudTh><MudTableSortLabel SortBy="new Func<ROILoadAndUnloadModel, object>(x=> x.Order?.OrderName)" InitialDirection="SortDirection.Ascending"><span class="admin-header-text">ORDER ENTITY</span></MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<ROILoadAndUnloadModel, object>(x=> x?.LoadingDuration)" InitialDirection="SortDirection.Ascending"><span class="admin-header-text">LOADING (HRS)</span></MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<ROILoadAndUnloadModel, object>(x=> x?.UnLoadingDuration)" InitialDirection="SortDirection.Ascending"><span class="admin-header-text">UNLOADING (HRS)</span></MudTableSortLabel></MudTh>
                    <MudTh Style="text-align: right;"><span class="admin-header-text">ACTIONS</span></MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="OrderName"><span class="admin-td-primary fw-600">@context.Order?.OrderName</span></MudTd>
                    <MudTd DataLabel="LoadingDuration">
                        <span class="fw-500">@context?.LoadingDuration hrs</span>
                    </MudTd>
                    <MudTd DataLabel="UnLoadingDuration">
                        <span class="fw-500 text-info">@context?.UnLoadingDuration hrs</span>
                    </MudTd>
                    <MudTd DataLabel="Actions" Style="text-align: right;">
                        <MudTooltip Text="Adjust Durations">
                            <MudIconButton OnClick="@(() => EditLoadUnloadDuration(context))" Color="Color.Primary" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Variant="Variant.Text" />
                        </MudTooltip>
                    </MudTd>
                </RowTemplate>
                <PagerContent>
                    <div class="pa-4">
                        <MudTablePager PageSizeOptions="new int[] { 10, 20, 50, 100 }" />
                    </div>
                </PagerContent>
            </MudTable>
        }
    </div>
</div>

@code {

    private List<ROIWheelSpeedModel> WheelSpeedcollection = new List<ROIWheelSpeedModel>();
    private List<ROILoadAndUnloadModel> LoadUnloadcollection = new List<ROILoadAndUnloadModel>();
    private string SearchItem = "";
    private string Title = "";
    string UserID;
    int? BranchID;
    private bool ViewChange = false;

    protected override async Task OnInitializedAsync()
    {
        var authprov = await auth.GetAuthenticationStateAsync();
        UserID = authprov.User.Identity.Name;
        BranchID = int.Parse(authprov.User.Claims.First(x => x.Type == "BranchID").Value);
        await GetAll(ViewChange);
    }

    private async Task GetAll(bool a)
    {
        @if (!a)
        {
            WheelSpeedcollection = IROITimeService.SelectWheelSpeed(null).ToList();
        }
        else
        {
            LoadUnloadcollection = IROITimeService.SelectLoadUnload(null,BranchID).ToList();
        }
        ViewChange = a;
        StateHasChanged();
    }

    private async Task TableViewChange(bool a)
    {
        await GetAll(a);
    }

    private async Task EditWheelSpeed(ROIWheelSpeedModel model)
    {
        try
        {
            var parameters = new DialogParameters();
            parameters.Add("model", model.Clone());
            DialogOptions maxWidth = new DialogOptions() { MaxWidth = MaxWidth.Medium, FullWidth = true };
            var dialog = await DialogService.ShowAsync<ROITimeWheelSpeedDialog>("Add/Edit", parameters, maxWidth);
            var result = await dialog.Result;
            if (!result.Canceled)
            {
                snackbar.Add("Saved Successfully", Severity.Success);
            }
        }
        catch (Exception a)
        {
            snackbar.Add(a.Message, Severity.Error);
        }
        await GetAll(ViewChange);
    }

    private async Task EditLoadUnloadDuration(ROILoadAndUnloadModel model)
    {
        try
        {
            var parameters = new DialogParameters();
            parameters.Add("model", model.Clone());
            DialogOptions maxWidth = new DialogOptions() { MaxWidth = MaxWidth.Medium, FullWidth = true };
            var dialog = await DialogService.ShowAsync<ROITimeLoadUnloadDurationDialog>("Add/Edit", parameters, maxWidth);
            var result = await dialog.Result;
            if (!result.Canceled)
            {
                snackbar.Add("Saved Successfully", Severity.Success);
            }
        }
        catch (Exception a)
        {
            snackbar.Add(a.Message, Severity.Error);
        }
        await GetAll(ViewChange);
    }

    private bool SearchWheelSpeed(ROIWheelSpeedModel model)
    {
        if ((model.ID != null && model.Wheels.ToString().Contains(SearchItem, StringComparison.OrdinalIgnoreCase)) ||
            (model.ID != null && model.Speed.ToString().Contains(SearchItem, StringComparison.OrdinalIgnoreCase)))
        {
            return true;
        }
        return false;
    }

    private bool SearchLoadUnloadDuration(ROILoadAndUnloadModel model)
    {
        if (model != null && model.Order.OrderName.Contains(SearchItem, StringComparison.OrdinalIgnoreCase))
        {
            return true;
        }
        return false;
    }
}

