@page "/ROIToll"
@using System.Threading;
@using Core.BaseModels.Operations.ROI
@using Core.IDataServices.Operations.ROI
@layout ROILayout
@attribute [Authorize]
@inject AuthenticationStateProvider auth
@inject NavigationManager NavigationManager;
@inject IROITollService IService
@inject IDialogService DialogService
@inject MudBlazor.ISnackbar snackbar

<MudGrid Spacing="4">
    <MudItem xs="12">
        <MudTable Items="@collection" Dense="true" Hover="true" Striped="true" Elevation="1" Filter="new Func<ROITollModel, bool>(search)">
            <ToolBarContent>
                <MudText Typo="Typo.h6">ROI Toll</MudText>
                <MudIconButton Icon="@Icons.Material.Filled.Add" Title="Add" @onclick="@(()=> Edit(new ROITollModel()))" Color="Color.Dark" Size="Size.Small"></MudIconButton>
                <MudSpacer></MudSpacer>
                <MudTextField @bind-Value="SearchItem" Placeholder="Search" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0"></MudTextField>
            </ToolBarContent>
            <HeaderContent>
                <MudTh><MudTableSortLabel SortBy="new Func<ROITollModel, object>(x=> x.Wheels)" InitialDirection="SortDirection.Ascending">Wheels</MudTableSortLabel></MudTh>>
                <MudTh><MudTableSortLabel SortBy="new Func<ROITollModel, object>(x=> x.Route.RouteName)" InitialDirection="SortDirection.Ascending">Route Name</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<ROITollModel, object>(x=> x.Toll)" InitialDirection="SortDirection.Ascending">Toll</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<ROITollModel, object>(x=> x.Toll)" InitialDirection="SortDirection.Ascending">Action</MudTableSortLabel></MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Wheels">@context.Wheels</MudTd>
                <MudTd DataLabel="OrderName">@context.Route.RouteName</MudTd>
                <MudTd DataLabel="Tagging">@context.Toll</MudTd>
                <MudTd>
                    <MudFab @onclick="@(() => Edit(context))" Title="Edit" Color="Color.Primary" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" IconSize="Size.Small" />
                </MudTd>
            </RowTemplate>
            <PagerContent>
                <MudTablePager PageSizeOptions="new int[] { 10, 20, 50, 100 }" />
            </PagerContent>
        </MudTable>
    </MudItem>
</MudGrid>

@code {

    private List<ROITollModel> collection = new List<ROITollModel>();
    private string SearchItem = "";
    string UserID;

    protected override async Task OnInitializedAsync()
    {
        var authprov = await auth.GetAuthenticationStateAsync();
        UserID = authprov.User.Identity.Name;
        GetAll();
    }

    private void GetAll()
    {
        collection = IService.Select().ToList();
    }

    private async Task Edit(ROITollModel model)
    {
        try
        {
            var parameters = new DialogParameters();
            parameters.Add("model", model.Clone());
            DialogOptions maxWidth = new DialogOptions() { MaxWidth = MaxWidth.Medium, FullWidth = true };
            var dialog = DialogService.Show<ROITollDialog>("Add/Edit", parameters, maxWidth);
            var result = await dialog.Result;
            if (!result.Cancelled)
            {
                snackbar.Add("Saved Successfully", Severity.Success);
            }
        }
        catch (Exception a)
        {
            snackbar.Add(a.Message, Severity.Error);
        }
        GetAll();
    }

    private bool search(ROITollModel model)
    {
        if ((model.ID != null && model.Route.RouteName.Contains(SearchItem, StringComparison.OrdinalIgnoreCase)))
        {
            return true;
        }
        return false;
    }
}