@using System.Threading;
@using Core.BaseModels.Operations.ROI
@using Core.IDataServices.Operations.ROI
@attribute [Authorize]
@inject AuthenticationStateProvider auth
@inject ITruckService ITruckService
@inject IROITonnageService IROITonnageService
@inject IRouteService IRouteService
@inject IOrderService IOrderService
@inject IDialogService DialogService
@inject MudBlazor.ISnackbar snackbar
@inject IRoleService<RoleModel> Irole

<MudDialog Style="overflow-y: hidden;">
    <TitleContent>
        <MudText Typo="Typo.h6">
            Add/Edit Tonnage
        </MudText>
    </TitleContent>
    <DialogContent>
        <EditForm Model="@model" id="ROITonnageForm" OnValidSubmit="Submit">
            <MudGrid>
                <MudItem xs="12">
                    <TruckSelector Class="bg-white" Value="model.Truck" BranchID="BranchID" ValueChanged="TruckChanged" Filter="AvailableForBranch" HomeOrOperation="Operation" />
                </MudItem>
                <MudItem xs="6">
                    <MudNumericField HideSpinButtons @bind-Value="model.FromTonnage" Label="From Tonnage" Variant="Variant.Outlined" Margin="Margin.Dense" MaxLength="10" />
                </MudItem>
                <MudItem xs="6">
                    <MudNumericField HideSpinButtons @bind-Value="model.ToTonnage" Label="To Tonnage" Variant="Variant.Outlined" Margin="Margin.Dense" MaxLength="10" />
                </MudItem>
            </MudGrid>
            <ObjectGraphDataAnnotationsValidator />
            <ValidationSummary />
        </EditForm>
    </DialogContent>
    <DialogActions>
        <div style="padding-right:12px; padding-bottom:12px;">
            <MudButton Size="Size.Large" Variant="Variant.Filled" Color="Color.Success" form="ROITonnageForm" ButtonType="ButtonType.Submit" Class="ml-auto">Submit</MudButton>
        </div>
    </DialogActions>
</MudDialog>

@code {

    [CascadingParameter] IMudDialogInstance MudDialog { get; set; }
    // public List<ROITonnageModel> Collection = new();
    [Parameter]
    public ROITonnageModel model { get; set; } = new();
    public List<ROITonnageModel> WheelList = new();
    public List<byte?> WheelsList { get; set; } = new();
    public List<string> BSTypeList = new();
    public List<OrderModel> OrderList { get; set; }
    public List<RouteModel> RoutList = new();
    string UserID;
    int BranchID;
    public int DocTypeID = 143;
    public bool HasPermissionROIServiceEdit { get; set; } = false;

    protected override async Task OnInitializedAsync()
    {
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionROIServiceEdit = await Irole.HasClaim(DocTypeID.ToString(), "Edit", ctc.Token);

        var authprov = await auth.GetAuthenticationStateAsync();
        UserID = authprov.User.Identity.Name;
        BranchID = int.Parse(authprov.User.Claims.First(x => x.Type == "BranchID").Value);
    }

    public void TruckChanged(TruckModel obj)
    {
        model.Truck = obj;
    }

    protected async Task Submit()
    {
        if (HasPermissionROIServiceEdit)
        {
            model.UserInfo.UserID = UserID;
            try
            {
                model = IROITonnageService.Update(model);
                MudDialog.Close(model);
            }
            catch (Exception ex)
            {
                snackbar.Add(ex.Message, Severity.Warning);
            }
        }
        else
        {
            bool? result = await DialogService.ShowMessageBox(
                "Permission denied!",
                "You don't have any permission to Edit ROI settings.");
        }
    }

    public void Cancel()
    {
        MudDialog.Cancel();
    }
}
