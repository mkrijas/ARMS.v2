@using System.Threading;
@using Core.BaseModels.Operations.ROI
@using Core.IDataServices.Operations.ROI
@attribute [Authorize]
@inject AuthenticationStateProvider auth
@inject ITruckService ITruckService
@inject IROITonnageService IROITonnageService
@inject IRouteService IRouteService
@inject IOrderService IOrderService
@inject IDialogService DialogService

<MudDialog Style="overflow-y: hidden;">
    <TitleContent>
        <MudText Typo="Typo.h6">
            Add/Edit Tonnage
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudGrid>
            <MudItem xs="6">
                <MudAutocomplete Clearable="true" Variant="Variant.Outlined" Margin="Margin.Dense" T="OrderModel" Label="Order" ResetValueOnEmptyText="true" ValueChanged="OrderChanged" Value="model.Order"
                                 SearchFunc="SearchOrders" ToStringFunc="@(e=> e == null ? null : $"{e.OrderName}")"></MudAutocomplete>
            </MudItem>
            <MudItem xs="6">
                <MudAutocomplete T="RouteModel" Variant="Variant.Outlined" Margin="Margin.Dense" Label="Route" Value="model.Route" ValueChanged="RouteChanged" ResetValueOnEmptyText="true"
                                 SearchFunc="SearchRoutes" ToStringFunc="@(e => e == null ? null : $"{e.RouteName}")"></MudAutocomplete>
            </MudItem>
            <MudItem xs="4">
                <MudNumericField HideSpinButtons @bind-Value="model.Wheels" Label="Wheels" Variant="Variant.Outlined" Margin="Margin.Dense" MaxLength="2" />
            </MudItem>
            <MudItem xs="4">
                <MudAutocomplete Clearable="true" Variant="Variant.Outlined" Margin="Margin.Dense" T="ROITonnageModel" Label="BS-Type" ResetValueOnEmptyText="true" ValueChanged="BSTypeChanged" Value="model"
                                 SearchFunc="SearchBSType" ToStringFunc="@(e=> e == null ? null : $"{e.BSType}")"></MudAutocomplete>
            </MudItem>
            <MudItem xs="4">
                <MudNumericField HideSpinButtons @bind-Value="model.Tonnage" Label="Tonnage" Variant="Variant.Outlined" Margin="Margin.Dense" MaxLength="10" />
            </MudItem>
        </MudGrid>
    </DialogContent>
    <DialogActions>
        <div style="padding-right:12px; padding-bottom:12px;">
            <MudButton Size="Size.Large" Variant="Variant.Filled" Color="Color.Success" OnClick="Submit" Class="ml-auto">Sumbit</MudButton>
        </div>
    </DialogActions>
</MudDialog>

@code {

    [CascadingParameter] MudDialogInstance MudDialog { get; set; }
    public List<ROITonnageModel> Collection = new();
    [Parameter]
    public ROITonnageModel model { get; set; } = new();
    public List<ROITonnageModel> BSTypeList = new();
    public List<OrderModel> OrderList { get; set; }
    public List<RouteModel> RoutList = new();
    string UserID;
    int BranchID;

    protected override async Task OnInitializedAsync()
    {
        var authprov = await auth.GetAuthenticationStateAsync();
        UserID = authprov.User.Identity.Name;
        BranchID = int.Parse(authprov.User.Claims.First(x => x.Type == "BranchID").Value);

        BSTypeList = ITruckService.SelectBSType().ToList();
        Collection = IROITonnageService.Select(null).ToList();
        OrderList = await IOrderService.SelectByBranch(0).ToListAsync();
        await foreach (var route in IRouteService.Select(0))
        {
            RoutList.Add(route);
        }
    }

    public void OrderChanged(OrderModel obj)
    {
        model.Order = obj;
    }

    public void RouteChanged(RouteModel obj)
    {
        model.Route = obj;
    }

    public void BSTypeChanged(ROITonnageModel obj)
    {
        model.BSType = obj?.BSType;
    }

    protected async Task Submit()
    {
        model.UserInfo.UserID = UserID;
        try
        {
            model = Iservice.Update(model);
            MudDialog.Close(model);
        }
        catch (Exception ex)
        {
            snackbar.Add(ex.Message, Severity.Warning);
        }
    }

    public async Task<IEnumerable<OrderModel>> SearchOrders(string searchString)
    {
        return await Task.FromResult(OrderList.Where(x => x.OrderName.Contains(searchString == null ? string.Empty : searchString, StringComparison.InvariantCultureIgnoreCase)));
    }

    public async Task<IEnumerable<RouteModel>> SearchRoutes(string searchString)
    {
        return await Task.FromResult(RoutList.Where(x => x.RouteName.Contains(searchString == null ? string.Empty : searchString, StringComparison.InvariantCultureIgnoreCase)));
    }

    public async Task<IEnumerable<ROITonnageModel>> SearchBSType(string searchString)
    {
        return await Task.FromResult(BSTypeList.Where(x => x.BSType.Contains(searchString == null ? string.Empty : searchString, StringComparison.InvariantCultureIgnoreCase)));
    }

    public void Cancel()
    {
        MudDialog.Cancel();
    }
}