@page "/ROITonnage"
@using System.Threading
@using Core.BaseModels.Operations.ROI
@using Core.IDataServices.Operations.ROI
@layout ROILayout
@attribute [Authorize]
@inject AuthenticationStateProvider auth
@inject NavigationManager NavigationManager
@inject IROITonnageService IROITonnageService
@inject IROIOrderTonnageModifierService IROIOrderTonnageModifierService
@inject ITruckService ITruckService
@inject IDialogService DialogService
@inject MudBlazor.ISnackbar snackbar
@inject IJSRuntime JSRuntime
@inject IRoleService<RoleModel> Irole

<MudGrid Spacing="4">
    <MudItem xs="12">
         <MudTabs Elevation="2" Rounded="true" ApplyEffectsToContainer="true" PanelClass="px-4 py-6">
            <MudTabPanel Style="min-width: 200px;" Text="Tonnage">
                <MudTable Items="@collection" Dense="true" Hover="true" Striped="true" Elevation="1" Filter="new Func<ROITonnageModel, bool>(search)">
                    <ToolBarContent>
                        <MudText Typo="Typo.h6">ROI Tonnages</MudText>
                        <MudSpacer />
                        <MudTextField @bind-Value="SearchItem" Placeholder="Search" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0"></MudTextField>
                    </ToolBarContent>
                    <HeaderContent>
                        <MudTh><MudTableSortLabel SortBy="new Func<ROITonnageModel, object>(x=> x.Truck.RegNo)" InitialDirection="SortDirection.Ascending">Truck</MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<ROITonnageModel, object>(x=> x.Truck.BodyType)" InitialDirection="SortDirection.Ascending">Body Type</MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<ROITonnageModel, object>(x=> x.Truck.TruckType)" InitialDirection="SortDirection.Ascending">Truck Type</MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<ROITonnageModel, object>(x=> x.Truck.wheels)" InitialDirection="SortDirection.Ascending">wheels</MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<ROITonnageModel, object>(x=> x.FromTonnage)" InitialDirection="SortDirection.Ascending">Tonnage</MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<ROITonnageModel, object>(x=> x.ToTonnage)" InitialDirection="SortDirection.Ascending">Actions</MudTableSortLabel></MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="RegNo">
                            <MudText Margin="Margin.Dense">@context.Truck.RegNo</MudText>
                        </MudTd>
                        <MudTd DataLabel="Body Type">
                            <MudText Margin="Margin.Dense">@context.Truck.BodyType</MudText>
                        </MudTd>
                        <MudTd DataLabel="Truck Type">
                            <MudText Margin="Margin.Dense">@context.Truck.TruckType</MudText>
                        </MudTd>
                        <MudTd DataLabel="Wheels">
                            <MudText Margin="Margin.Dense">@context.Truck.wheels</MudText>
                        </MudTd>
                        <MudTd DataLabel="Tonnage"> 
                            @if(context.HideTextField)
                            {
                                <div style="display : flex; gap : 10px; width : 80%;">
                                    <MudTextField Label="From" @bind-Value = "@context.FromTonnage" Variant="Variant.Outlined" Margin="Margin.Dense"/>
                                    <MudTextField Label="To" @bind-Value = "@context.ToTonnage" Variant="Variant.Outlined" Margin="Margin.Dense"/>  
                                </div>
                            }
                            else
                            {
                                <MudText Margin="Margin.Dense">@context.FromTonnage - @context.ToTonnage</MudText>
                            }
                        </MudTd>
                        <MudTd DataLabel="Actions">
                            @if (context.HideTextField)
                            {
                                <MudFab Style="font-size:5px" @onclick="() => Submit(context)" Color="Color.Success" Icon="@Icons.Material.Filled.Save" Size="Size.Small" IconSize="Size.Small" />
                                <MudFab Style="font-size:5px" @onclick="() => Cancel(context)" Color="Color.Error" Icon="@Icons.Material.Filled.Cancel" Size="Size.Small" IconSize="Size.Small" />
                            }
                            else
                            {
                                <MudFab Style="font-size:5px" @onclick="() => Edit(context)" Color="Color.Primary" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" IconSize="Size.Small" />
                                <MudFab Style="font-size:5px" @onclick="() => Delete(context)" Color="Color.Error" Icon="@Icons.Material.Filled.Delete" Size="Size.Small" IconSize="Size.Small" />
                            }
                        </MudTd>
                    </RowTemplate>
                    <PagerContent>
                        <MudTablePager PageSizeOptions="new int[] { 10, 20, 50, 100 }" />
                    </PagerContent>
                </MudTable>
            </MudTabPanel>
            <MudTabPanel Style="min-width: 200px;" Text="Modifier">
                <MudTable Items="@collectionModifier" Dense="true" Hover="true" Striped="true" Elevation="1" Filter="new Func<ROIOrderTonnageModifierModel, bool>(searchOrder)">
                    <ToolBarContent>
                        <MudText Typo="Typo.h6">ROI Tonnages</MudText>
                        <MudSpacer />
                        <MudTextField @bind-Value="SearchItem" Placeholder="Search" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0"></MudTextField>
                    </ToolBarContent>
                    <HeaderContent>
                        <MudTh Style="width:30%;font-weight: bold;">Order</MudTh>
                        <MudTh Style="width:30%;font-weight: bold;">Wheels:modifier</MudTh>
                        <MudTh Style="width:10%;font-weight: bold;">Actions</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="Order">
                            <MudText Margin="Margin.Dense">@context.Order.OrderName</MudText>
                        </MudTd>
                        <MudTd DataLabel="Wheels">                                
                            <MudText Margin="Margin.Dense">@context.DisplayModifiers</MudText>
                        </MudTd>
                        <MudTd DataLabel="Actions">
                            <MudFab Style="font-size:5px" @onclick="() => EditModifier(context)" Color="Color.Primary" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" IconSize="Size.Small" />
                        </MudTd>
                    </RowTemplate>

                    <PagerContent>
                        <MudTablePager PageSizeOptions="new int[] { 10, 20, 50, 100 }" />
                    </PagerContent>
                </MudTable>
            </MudTabPanel>
         </MudTabs>
    </MudItem>
</MudGrid>

@code {
    private List<ROITonnageModel> collection = new();
    private List<ROIOrderTonnageModifierModel> collectionModifier = new();
    private string SearchItem = "";
    string? UserID;
    int? BranchID;
    public int DocTypeID = 143;
    public bool HasPermissionROIServiceDelete { get; set; } = false;

    protected override async Task OnInitializedAsync()
    {
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionROIServiceDelete = await Irole.HasClaim(DocTypeID.ToString(), "Delete", ctc.Token);

        var authprov = await auth.GetAuthenticationStateAsync();
        UserID = authprov.User.Identity?.Name;
        BranchID = int.Parse(authprov.User.Claims.First(x => x.Type == "BranchID").Value);
        GetAll();
    }

    private void GetAll()
    {
        collection = IROITonnageService.Select(null, BranchID).ToList();
        collectionModifier = IROIOrderTonnageModifierService.Select(null, BranchID).ToList();
    }

    private void Edit(ROITonnageModel context)
    {
        context.HideTextField = true;
    }

    private async Task Submit(ROITonnageModel model)
    {
        var authprov = await auth.GetAuthenticationStateAsync();
        UserID = authprov.User.Identity?.Name;
        model.UserInfo.UserID = UserID;

        try
        {
            IROITonnageService.Update(model);
            snackbar.Add("Updated Successfully", Severity.Success);
            model.HideTextField = false;
        }
        catch (Exception ex)
        {
            snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
        GetAll();
    }

    private void Cancel(ROITonnageModel context)
    {
        context.HideTextField = false;
        GetAll(); // Refresh on cancel to revert changes
    }

    private async Task Delete(ROITonnageModel model)
    {
        if (HasPermissionROIServiceDelete)
        {
            try
            {
                bool? value = await DialogService.ShowMessageBox(
                    "Warning!",
                    "Are you sure you want to delete?");
                if (value == true)
                {
                    int result = IROITonnageService.Delete(model.ID.Value, UserID);
                    if (result != 0)
                    {
                        snackbar.Add("Deleted Successfully", Severity.Success);
                        GetAll();
                    }
                }
            }
            catch (Exception ex)
            {
                snackbar.Add($"Error: {ex.Message}", Severity.Error);
            }
        }
        else
        {
            bool? result = await DialogService.ShowMessageBox(
                "Permission denied!",
                "You don't have any permission to Delete ROI settings.");
        }
    }

    private bool search(ROITonnageModel model)
    {
        return string.IsNullOrWhiteSpace(SearchItem) ||
               (model.Truck?.RegNo?.Contains(SearchItem, StringComparison.OrdinalIgnoreCase) ?? false);
    }

    private bool searchOrder(ROIOrderTonnageModifierModel model)
    {
        return string.IsNullOrWhiteSpace(SearchItem) ||
               (model.Order?.OrderName?.Contains(SearchItem, StringComparison.OrdinalIgnoreCase) ?? false);
    }

    private async Task EditModifier(ROIOrderTonnageModifierModel model)
    {
        try
        {
            var parameters = new DialogParameters();
            parameters.Add("model", model.Clone());
            DialogOptions maxWidth = new DialogOptions() { MaxWidth = MaxWidth.Medium, FullWidth = true };
            var dialog = DialogService.Show<ROIOrderTonnageModifierDialog>("Add/Edit", parameters, maxWidth);
            var result = await dialog.Result;
            if (!result.Canceled)
            {
                snackbar.Add("Saved Successfully", Severity.Success);
            }
        }
        catch (Exception a)
        {
            snackbar.Add(a.Message, Severity.Error);
        }
        GetAll();
    }

}
