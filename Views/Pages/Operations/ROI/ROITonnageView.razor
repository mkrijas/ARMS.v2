@page "/ROITonnage"
@using System.Threading
@using Core.BaseModels.Operations.ROI
@using Core.IDataServices.Operations.ROI
@layout ROILayout
@attribute [Authorize]
@inject AuthenticationStateProvider auth
@inject NavigationManager NavigationManager
@inject IROITonnageService IROITonnageService
@inject IROIOrderTonnageModifierService IROIOrderTonnageModifierService
@inject ITruckService ITruckService
@inject IDialogService DialogService
@inject MudBlazor.ISnackbar snackbar
@inject IJSRuntime JSRuntime
@inject IRoleService<RoleModel> Irole

<div class="fade-in">
    <div class="admin-header-tiered mb-6">
        <div class="d-flex align-center justify-space-between">
            <div>
                <MudText Typo="Typo.h4" Class="admin-title">ROI Tonnage & Modifiers</MudText>
                <MudText Typo="Typo.body2" Class="admin-subtitle">Calibrate payload capacities and order-specific tonnage modifiers for precise ROI evaluations.</MudText>
            </div>
        </div>
    </div>

    <div class="admin-glass-card mb-6 pa-4">
        <div class="d-flex align-center gap-4">
            <div style="flex-grow: 1;">
                <MudTextField @bind-Value="SearchItem" Placeholder="Search by registration number, order or body type..." Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" Variant="Variant.Outlined" Margin="Margin.Dense" Class="admin-input-group" Clearable="true" />
            </div>
        </div>
    </div>

    <div class="admin-glass-card pa-0 overflow-hidden">
        <MudTabs Elevation="0" Rounded="false" ApplyEffectsToContainer="true" Class="modern-tabs">
            <MudTabPanel Text="TONNAGE CALCULATIONS">
                <MudTable Items="@collection" Elevation="0" Class="modern-admin-table" Hover="true" Filter="new Func<ROITonnageModel, bool>(search)">
                    <HeaderContent>
                        <MudTh><MudTableSortLabel SortBy="new Func<ROITonnageModel, object>(x=> x.Truck.RegNo)" InitialDirection="SortDirection.Ascending"><span class="admin-header-text">VEHICLE IDENTITY</span></MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<ROITonnageModel, object>(x=> x.Truck.BodyType)" InitialDirection="SortDirection.Ascending"><span class="admin-header-text">CONFIGURATION</span></MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<ROITonnageModel, object>(x=> x.FromTonnage)" InitialDirection="SortDirection.Ascending"><span class="admin-header-text">TONNAGE RANGE (MT)</span></MudTableSortLabel></MudTh>
                        <MudTh Style="text-align: right;"><span class="admin-header-text">ACTIONS</span></MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="RegNo">
                            <span class="admin-td-primary fw-600">@context.Truck.RegNo</span>
                        </MudTd>
                        <MudTd DataLabel="Configuration">
                            <div class="d-flex flex-column">
                                <span class="fw-500">@context.Truck.BodyType</span>
                                <MudText Typo="Typo.caption" Alpha="0.6">@context.Truck.TruckType • @context.Truck.wheels Wheels</MudText>
                            </div>
                        </MudTd>
                        <MudTd DataLabel="Tonnage Range"> 
                            @if(context.HideTextField)
                            {
                                <div class="d-flex align-center gap-2">
                                    <MudNumericField Label="From" @bind-Value="@context.FromTonnage" Variant="Variant.Outlined" Margin="Margin.Dense" Class="modern-input" Style="max-width: 100px;" />
                                    <MudNumericField Label="To" @bind-Value="@context.ToTonnage" Variant="Variant.Outlined" Margin="Margin.Dense" Class="modern-input" Style="max-width: 100px;" />  
                                </div>
                            }
                            else
                            {
                                <MudChip T="string" Size="Size.Small" Color="Color.Info" Variant="Variant.Text" Class="fw-700">@context.FromTonnage - @context.ToTonnage MT</MudChip>
                            }
                        </MudTd>
                        <MudTd DataLabel="Actions" Style="text-align: right;">
                             <div class="d-flex justify-end gap-1">
                                @if (context.HideTextField)
                                {
                                    <MudTooltip Text="Commit Changes">
                                        <MudIconButton OnClick="() => Submit(context)" Color="Color.Success" Icon="@Icons.Material.Filled.Save" Size="Size.Small" Variant="Variant.Text" />
                                    </MudTooltip>
                                    <MudTooltip Text="Discard">
                                        <MudIconButton OnClick="() => Cancel(context)" Color="Color.Error" Icon="@Icons.Material.Filled.Cancel" Size="Size.Small" Variant="Variant.Text" />
                                    </MudTooltip>
                                }
                                else
                                {
                                    <MudTooltip Text="Quick Edit">
                                        <MudIconButton OnClick="() => Edit(context)" Color="Color.Primary" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Variant="Variant.Text" />
                                    </MudTooltip>
                                    <MudTooltip Text="Remove Baseline">
                                        <MudIconButton OnClick="() => Delete(context)" Color="Color.Error" Icon="@Icons.Material.Filled.DeleteOutline" Size="Size.Small" Variant="Variant.Text" />
                                    </MudTooltip>
                                }
                            </div>
                        </MudTd>
                    </RowTemplate>
                    <PagerContent>
                        <div class="pa-4">
                            <MudTablePager PageSizeOptions="new int[] { 10, 20, 50, 100 }" />
                        </div>
                    </PagerContent>
                </MudTable>
            </MudTabPanel>
            <MudTabPanel Text="TONNAGE MODIFIERS">
                <MudTable Items="@collectionModifier" Elevation="0" Class="modern-admin-table" Hover="true" Filter="new Func<ROIOrderTonnageModifierModel, bool>(searchOrder)">
                    <HeaderContent>
                        <MudTh><span class="admin-header-text">ORDER ENTITY</span></MudTh>
                        <MudTh><span class="admin-header-text">WHEEL MODIFIER MAPPING</span></MudTh>
                        <MudTh Style="text-align: right;"><span class="admin-header-text">ACTIONS</span></MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="Order">
                            <span class="admin-td-primary fw-600">@context.Order.OrderName</span>
                        </MudTd>
                        <MudTd DataLabel="Modifiers">                                
                            <div class="d-flex flex-wrap gap-1">
                                @foreach(var mod in (context.DisplayModifiers ?? "").Split(',', StringSplitOptions.RemoveEmptyEntries))
                                {
                                    <MudChip T="string" Size="Size.Small" Color="Color.Secondary" Variant="Variant.Text" Class="fw-600">@mod.Trim()</MudChip>
                                }
                            </div>
                        </MudTd>
                        <MudTd DataLabel="Actions" Style="text-align: right;">
                            <MudTooltip Text="Edit Modifier Matrix">
                                <MudIconButton OnClick="() => EditModifier(context)" Color="Color.Primary" Icon="@Icons.Material.Filled.Settings" Size="Size.Small" Variant="Variant.Text" />
                            </MudTooltip>
                        </MudTd>
                    </RowTemplate>
                    <PagerContent>
                        <div class="pa-4">
                            <MudTablePager PageSizeOptions="new int[] { 10, 20, 50, 100 }" />
                        </div>
                    </PagerContent>
                </MudTable>
            </MudTabPanel>
         </MudTabs>
    </div>
</div>

@code {
    private List<ROITonnageModel> collection = new();
    private List<ROIOrderTonnageModifierModel> collectionModifier = new();
    private string SearchItem = "";
    string? UserID;
    int? BranchID;
    public int DocTypeID = 143;
    public bool HasPermissionROIServiceDelete { get; set; } = false;

    protected override async Task OnInitializedAsync()
    {
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionROIServiceDelete = await Irole.HasClaim(DocTypeID.ToString(), "Delete", ctc.Token);

        var authprov = await auth.GetAuthenticationStateAsync();
        UserID = authprov.User.Identity?.Name;
        BranchID = int.Parse(authprov.User.Claims.First(x => x.Type == "BranchID").Value);
        GetAll();
    }

    private void GetAll()
    {
        collection = IROITonnageService.Select(null, BranchID).ToList();
        collectionModifier = IROIOrderTonnageModifierService.Select(null, BranchID).ToList();
    }

    private void Edit(ROITonnageModel context)
    {
        context.HideTextField = true;
    }

    private async Task Submit(ROITonnageModel model)
    {
        var authprov = await auth.GetAuthenticationStateAsync();
        UserID = authprov.User.Identity?.Name;
        model.UserInfo.UserID = UserID;

        try
        {
            IROITonnageService.Update(model);
            snackbar.Add("Updated Successfully", Severity.Success);
            model.HideTextField = false;
        }
        catch (Exception ex)
        {
            snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
        GetAll();
    }

    private void Cancel(ROITonnageModel context)
    {
        context.HideTextField = false;
        GetAll(); // Refresh on cancel to revert changes
    }

    private async Task Delete(ROITonnageModel model)
    {
        if (HasPermissionROIServiceDelete)
        {
            try
            {
                bool? value = await DialogService.ShowMessageBoxAsync(
                    "Warning!",
                    "Are you sure you want to delete?");
                if (value == true)
                {
                    int result = IROITonnageService.Delete(model.ID.Value, UserID);
                    if (result != 0)
                    {
                        snackbar.Add("Deleted Successfully", Severity.Success);
                        GetAll();
                    }
                }
            }
            catch (Exception ex)
            {
                snackbar.Add($"Error: {ex.Message}", Severity.Error);
            }
        }
        else
        {
            bool? result = await DialogService.ShowMessageBoxAsync(
                "Permission denied!",
                "You don't have any permission to Delete ROI settings.");
        }
    }

    private bool search(ROITonnageModel model)
    {
        return string.IsNullOrWhiteSpace(SearchItem) ||
               (model.Truck?.RegNo?.Contains(SearchItem, StringComparison.OrdinalIgnoreCase) ?? false);
    }

    private bool searchOrder(ROIOrderTonnageModifierModel model)
    {
        return string.IsNullOrWhiteSpace(SearchItem) ||
               (model.Order?.OrderName?.Contains(SearchItem, StringComparison.OrdinalIgnoreCase) ?? false);
    }

    private async Task EditModifier(ROIOrderTonnageModifierModel model)
    {
        try
        {
            var parameters = new DialogParameters();
            parameters.Add("model", model.Clone());
            DialogOptions maxWidth = new DialogOptions() { MaxWidth = MaxWidth.Medium, FullWidth = true };
            var dialog = await DialogService.ShowAsync<ROIOrderTonnageModifierDialog>("Add/Edit", parameters, maxWidth);
            var result = await dialog.Result;
            if (!result.Canceled)
            {
                snackbar.Add("Saved Successfully", Severity.Success);
            }
        }
        catch (Exception a)
        {
            snackbar.Add(a.Message, Severity.Error);
        }
        GetAll();
    }

}

