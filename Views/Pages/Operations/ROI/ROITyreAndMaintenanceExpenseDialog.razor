@using System.Threading;
@using Core.BaseModels.Operations.ROI
@using Core.IDataServices.Operations.ROI
@attribute [Authorize]
@inject AuthenticationStateProvider auth
@inject IROITyreAndMaintenanceExpenseService Iservice
@inject ITruckTypeService Itrucktype
@inject MudBlazor.ISnackbar snackbar
@inject IDialogService DialogService
@inject IRoleService<RoleModel> Irole

<MudDialog Style="overflow-y: hidden;">
    <TitleContent>
        <MudText Typo="Typo.h6">
            Add/Edit Tyre And Maintenance Expense
        </MudText>
    </TitleContent>
    <DialogContent>
        <EditForm id="formexp" Model="@model" OnValidSubmit="OnValidSubmit">
            <ObjectGraphDataAnnotationsValidator />
            <ValidationSummary />
            <MudGrid>
                <MudItem xs="12" md="4">
                    <MudAutocomplete Clearable="true" Variant="Variant.Outlined" Margin="Margin.Dense" T="TruckTypeModel" Label="Truck Type" ResetValueOnEmptyText="true" ValueChanged="TruckTypeChanged" Value="model.TruckType"
                                     SearchFunc="SearchTruckType" ToStringFunc="@(e=> e == null ? null : $"{e.TruckType}")"></MudAutocomplete>
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudNumericField HideSpinButtons @bind-Value="model.Maintenance" Label="Maintenance" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.Maintenance)"></MudNumericField>
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudNumericField HideSpinButtons @bind-Value="model.Tyre" Label="Tyre" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.Tyre)"></MudNumericField>
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudDatePicker Label="Period From" Variant="Variant.Outlined" Margin="Margin.Dense" DisableToolbar="true" Editable="true" @bind-Date="model.FromDate" HelperText="Enter Date" DateFormat="dd/MM/yyyy" />
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudDatePicker Label="Period To" Variant="Variant.Outlined" Margin="Margin.Dense" DisableToolbar="true" Editable="true" @bind-Date="model.ToDate" HelperText="Enter Date" DateFormat="dd/MM/yyyy" />
                </MudItem>
            </MudGrid>
        </EditForm>
    </DialogContent>
    <DialogActions>
        <div style="padding-right:12px; padding-bottom:12px;">
            <MudButton Size="Size.Large" Variant="Variant.Filled" Color="Color.Success" form="formexp" ButtonType="ButtonType.Submit" Class="ml-auto">Sumbit</MudButton>
        </div>
    </DialogActions>
</MudDialog>

@code {

    [Parameter]
    public ROITyreAndMaintenanceExpenseModel model { get; set; }
    [CascadingParameter]
    MudDialogInstance MudDialog { get; set; }
    public List<ROITyreAndMaintenanceExpenseModel> Collection = new();
    public List<TruckTypeModel> TruckTypeList = new();
    string UserID;
    int BranchID;

    protected override async Task OnInitializedAsync()
    {
        var authprov = await auth.GetAuthenticationStateAsync();
        UserID = authprov.User.Identity.Name;
        BranchID = int.Parse(authprov.User.Claims.First(x => x.Type == "BranchID").Value);

        Collection = Iservice.Select().ToList();
        TruckTypeList = Itrucktype.Select(0).ToList();
    }

    public async Task<IEnumerable<TruckTypeModel>> SearchTruckType(string searchString)
    {
        return await Task.FromResult(TruckTypeList.Where(x => x.BSType.Contains(searchString == null ? string.Empty : searchString, StringComparison.InvariantCultureIgnoreCase)));
    }

    public void TruckTypeChanged(TruckTypeModel obj)
    {
        model.TruckType = obj;
    }

    private async void OnValidSubmit(EditContext context)
    {
        model.UserInfo.UserID = UserID;
        try
        {
            model = Iservice.Update(model);
            MudDialog.Close(model);
        }
        catch (Exception ex)
        {
            snackbar.Add(ex.Message, Severity.Warning);
        }
    }

    private void Cancel()
    {
        MudDialog.Cancel();
    }

}