@page "/ROITyreAndMaintenanceExpense"
@using System.Threading;
@using Core.BaseModels.Operations.ROI
@using Core.IDataServices.Operations.ROI
@layout ROILayout
@attribute [Authorize]
@inject AuthenticationStateProvider auth
@inject NavigationManager NavigationManager;
@inject IROITyreAndMaintenanceExpenseService IService
@inject IDialogService DialogService
@inject MudBlazor.ISnackbar snackbar

<MudGrid Spacing="4">
    <MudItem xs="12">
        <MudTable Items="@collection" Dense="true" Hover="true" Striped="true" Elevation="1" Filter="new Func<ROITyreAndMaintenanceExpenseModel, bool>(search)">
            <ToolBarContent>
                <MudText Typo="Typo.h6">ROI Tyre And Maintenance Expense</MudText>
                <MudIconButton Icon="@Icons.Material.Filled.Add" Title="Add" @onclick="@(()=> Edit(new ROITyreAndMaintenanceExpenseModel()))" Color="Color.Dark" Size="Size.Small"></MudIconButton>
                <MudSpacer></MudSpacer>
                <MudTextField @bind-Value="SearchItem" Placeholder="Search" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0"></MudTextField>
            </ToolBarContent>
            <HeaderContent>
                <MudTh><MudTableSortLabel SortBy="new Func<ROITyreAndMaintenanceExpenseModel, object>(x=> x.TruckType?.TruckType)" InitialDirection="SortDirection.Ascending">Truck Type</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<ROITyreAndMaintenanceExpenseModel, object>(x=> x.BsType)" >BS Type</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<ROITyreAndMaintenanceExpenseModel, object>(x=> x.Maintenance)" InitialDirection="SortDirection.Ascending">Maintenance</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<ROITyreAndMaintenanceExpenseModel, object>(x=> x.Tyre)" InitialDirection="SortDirection.Ascending">Tyre</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<ROITyreAndMaintenanceExpenseModel, object>(x=> x.FromDate)" InitialDirection="SortDirection.Ascending">From</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<ROITyreAndMaintenanceExpenseModel, object>(x=> x.ToDate)" InitialDirection="SortDirection.Ascending">To</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<ROITyreAndMaintenanceExpenseModel, object>(x=> x.Maintenance)" InitialDirection="SortDirection.Ascending">Action</MudTableSortLabel></MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="TruckType">@context.TruckType.TruckType</MudTd>
                <MudTd DataLabel="BsType">@context.BsType</MudTd>
                <MudTd DataLabel="Maintenance">@context.Maintenance</MudTd>
                <MudTd DataLabel="Tyre">@context.Tyre</MudTd>
                <MudTd DataLabel="FromDate">@context.FromDate?.ToShortDateString()</MudTd>
                <MudTd DataLabel="ToDate">@context.ToDate?.ToShortDateString()</MudTd>
                <MudTd>
                    <MudFab @onclick="@(() => Edit(context))" Title="Edit" Color="Color.Primary" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" IconSize="Size.Small" />
                </MudTd>
            </RowTemplate>
            <PagerContent>
                <MudTablePager PageSizeOptions="new int[] { 10, 20, 50, 100 }" />
            </PagerContent>
        </MudTable>
    </MudItem>
</MudGrid>

@code {

    private List<ROITyreAndMaintenanceExpenseModel> collection = new List<ROITyreAndMaintenanceExpenseModel>();
    private string SearchItem = "";
    string UserID;

    protected override async Task OnInitializedAsync()
    {
        var authprov = await auth.GetAuthenticationStateAsync();
        UserID = authprov.User.Identity.Name;
        GetAll();
    }

    private void GetAll()
    {
        collection = IService.Select().ToList();
    }

    private async Task Edit(ROITyreAndMaintenanceExpenseModel model)
    {
        try
        {
            var parameters = new DialogParameters();
            parameters.Add("model", model.Clone());
            DialogOptions maxWidth = new DialogOptions() { MaxWidth = MaxWidth.Medium, FullWidth = true };
            var dialog = DialogService.Show<ROITyreAndMaintenanceExpenseDialog>("Add/Edit", parameters, maxWidth);
            var result = await dialog.Result;
            if (!result.Canceled)
            {
                snackbar.Add("Saved Successfully", Severity.Success);
            }
        }
        catch (Exception a)
        {
            snackbar.Add(a.Message, Severity.Error);
        }
        GetAll();
    }

    private bool search(ROITyreAndMaintenanceExpenseModel model)
    {
        if ((model.TruckType.TruckType.Contains(SearchItem, StringComparison.OrdinalIgnoreCase)) ||
            (model.FromDate.ToString().Contains(SearchItem, StringComparison.OrdinalIgnoreCase)) ||
            (model.ToDate.ToString().Contains(SearchItem, StringComparison.OrdinalIgnoreCase)) ||
            (model.Tyre.ToString().Contains(SearchItem, StringComparison.OrdinalIgnoreCase)) ||
            (model.Maintenance.ToString().Contains(SearchItem, StringComparison.OrdinalIgnoreCase)))
        {
            return true;
        }
        return false;
    }
}