@page "/ROITyreAndMaintenanceExpense"
@using System.Threading;
@using Core.BaseModels.Operations.ROI
@using Core.IDataServices.Operations.ROI
@layout ROILayout
@attribute [Authorize]
@inject AuthenticationStateProvider auth
@inject NavigationManager NavigationManager;
@inject IROITyreAndMaintenanceExpenseService IService
@inject IDialogService DialogService
@inject MudBlazor.ISnackbar snackbar

<div class="fade-in">
    <div class="admin-header-tiered mb-6">
        <div class="d-flex align-center justify-space-between">
            <div>
                <MudText Typo="Typo.h4" Class="admin-title">ROI Maintenance & Tyre Costs</MudText>
                <MudText Typo="Typo.body2" Class="admin-subtitle">Maintain standard maintenance and tyre wear expenditure benchmarks for accurate lifecycle ROI calculations.</MudText>
            </div>
            <MudButton StartIcon="@Icons.Material.Filled.Add" Variant="Variant.Filled" Color="Color.Primary" Class="admin-register-btn" OnClick="@(()=> Edit(new ROITyreAndMaintenanceExpenseModel()))">ADD BENCHMARK</MudButton>
        </div>
    </div>

    <div class="admin-glass-card mb-6 pa-4">
        <div class="d-flex align-center gap-4">
            <div style="flex-grow: 1;">
                <MudTextField @bind-Value="SearchItem" Placeholder="Search by truck type, maintenance or tyre cost..." Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" Variant="Variant.Outlined" Margin="Margin.Dense" Class="admin-input-group" Clearable="true" />
            </div>
        </div>
    </div>

    <div class="admin-glass-card pa-0 overflow-hidden">
        <MudTable Items="@collection" Elevation="0" Filter="new Func<ROITyreAndMaintenanceExpenseModel, bool>(search)" Class="modern-admin-table" Hover="true">
            <HeaderContent>
                <MudTh><MudTableSortLabel SortBy="new Func<ROITyreAndMaintenanceExpenseModel, object>(x=> x.TruckType?.TruckType)" InitialDirection="SortDirection.Ascending"><span class="admin-header-text">VEHICLE CLASS</span></MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<ROITyreAndMaintenanceExpenseModel, object>(x=> x.BsType)"><span class="admin-header-text">BS TYPE</span></MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<ROITyreAndMaintenanceExpenseModel, object>(x=> x.Maintenance)" InitialDirection="SortDirection.Ascending"><span class="admin-header-text">MAINTENANCE (STD)</span></MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<ROITyreAndMaintenanceExpenseModel, object>(x=> x.Tyre)" InitialDirection="SortDirection.Ascending"><span class="admin-header-text">TYRE COST (STD)</span></MudTableSortLabel></MudTh>
                <MudTh><span class="admin-header-text">VALIDITY</span></MudTh>
                <MudTh Style="text-align: right;"><span class="admin-header-text">ACTIONS</span></MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="TruckType"><span class="fw-600">@context.TruckType?.TruckType</span></MudTd>
                <MudTd DataLabel="BsType">@context.BsType</MudTd>
                <MudTd DataLabel="Maintenance">
                    <MudChip T="string" Size="Size.Small" Color="Color.Info" Variant="Variant.Text" Class="fw-700">@context.Maintenance?.ToString("N2")</MudChip>
                </MudTd>
                <MudTd DataLabel="Tyre">
                    <MudChip T="string" Size="Size.Small" Color="Color.Secondary" Variant="Variant.Text" Class="fw-700">@context.Tyre?.ToString("N2")</MudChip>
                </MudTd>
                <MudTd DataLabel="Validity">
                    <div class="d-flex flex-column">
                        <span class="fw-500">@context.FromDate?.ToString("dd MMM yyyy")</span>
                        <MudText Typo="Typo.caption" Alpha="0.6">to @context.ToDate?.ToString("dd MMM yyyy")</MudText>
                    </div>
                </MudTd>
                <MudTd DataLabel="Actions" Style="text-align: right;">
                    <MudTooltip Text="Update Norms">
                        <MudIconButton OnClick="@(() => Edit(context))" Color="Color.Primary" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Variant="Variant.Text" />
                    </MudTooltip>
                </MudTd>
            </RowTemplate>
            <PagerContent>
                <div class="pa-4">
                    <MudTablePager PageSizeOptions="new int[] { 10, 20, 50, 100 }" />
                </div>
            </PagerContent>
        </MudTable>
    </div>
</div>

@code {

    private List<ROITyreAndMaintenanceExpenseModel> collection = new List<ROITyreAndMaintenanceExpenseModel>();
    private string SearchItem = "";
    string UserID;

    protected override async Task OnInitializedAsync()
    {
        var authprov = await auth.GetAuthenticationStateAsync();
        UserID = authprov.User.Identity.Name;
        GetAll();
    }

    private void GetAll()
    {
        collection = IService.Select().ToList();
    }

    private async Task Edit(ROITyreAndMaintenanceExpenseModel model)
    {
        try
        {
            var parameters = new DialogParameters();
            parameters.Add("model", model.Clone());
            DialogOptions maxWidth = new DialogOptions() { MaxWidth = MaxWidth.Medium, FullWidth = true };
            var dialog = await DialogService.ShowAsync<ROITyreAndMaintenanceExpenseDialog>("Add/Edit", parameters, maxWidth);
            var result = await dialog.Result;
            if (!result.Canceled)
            {
                snackbar.Add("Saved Successfully", Severity.Success);
            }
        }
        catch (Exception a)
        {
            snackbar.Add(a.Message, Severity.Error);
        }
        GetAll();
    }

    private bool search(ROITyreAndMaintenanceExpenseModel model)
    {
        if ((model.TruckType.TruckType.Contains(SearchItem, StringComparison.OrdinalIgnoreCase)) ||
            (model.FromDate.ToString().Contains(SearchItem, StringComparison.OrdinalIgnoreCase)) ||
            (model.ToDate.ToString().Contains(SearchItem, StringComparison.OrdinalIgnoreCase)) ||
            (model.Tyre.ToString().Contains(SearchItem, StringComparison.OrdinalIgnoreCase)) ||
            (model.Maintenance.ToString().Contains(SearchItem, StringComparison.OrdinalIgnoreCase)))
        {
            return true;
        }
        return false;
    }
}

