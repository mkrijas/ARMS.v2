@using System.Threading;
@using Core.BaseModels.Operations.ROI
@using Core.IDataServices.Operations.ROI
@attribute [Authorize]
@inject AuthenticationStateProvider auth
@inject IROIUnloadingChargesService Iservice
@inject IRouteService Iroute
@inject MudBlazor.ISnackbar snackbar
@inject IDialogService DialogService
@inject IRoleService<RoleModel> Irole

<MudDialog Style="overflow-y: hidden;">
    <TitleContent>
        <MudText Typo="Typo.h6">
            Add/Edit Unloading
        </MudText>
    </TitleContent>
    <DialogContent>
        <EditForm id="formunl" Model="@model" OnValidSubmit="OnValidSubmit">
            <ObjectGraphDataAnnotationsValidator />
            <ValidationSummary />
            <MudGrid>
                <MudItem xs="12" md="8">
                    <MudAutocomplete Clearable="true" Variant="Variant.Outlined" Margin="Margin.Dense" T="RouteModel" Label="Route" ResetValueOnEmptyText="true" ValueChanged="RouteChanged" Value="model.Route"
                                        SearchFunc="SearchRoutes" ToStringFunc="@(e => e == null ? null : $"{e.RouteName}")"></MudAutocomplete>
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudSelect Margin="Margin.Dense" Variant="Variant.Outlined" Label="Rate Basis" @bind-Value="model.RateBasis" AdornmentColor="Color.Secondary">
                        <MudSelectItem Value="@("Fixed")">Fixed</MudSelectItem>
                        <MudSelectItem Value="@("PerMT")">Per MT</MudSelectItem>
                    </MudSelect>
                </MudItem> 

                <MudItem xs="12" md="4">
                    <MudNumericField HideSpinButtons @bind-Value="model.Wheels" Label="Wheels" Variant="Variant.Outlined" Margin="Margin.Dense" MaxLength="2" />
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudSelect Margin="Margin.Dense" Variant="Variant.Outlined" Label="Select Type" @bind-Value="model.BodyType" AdornmentColor="Color.Secondary">
                        <MudSelectItem Value="@("Bulker")">Bulker</MudSelectItem>
                        <MudSelectItem Value="@("Open")">Open</MudSelectItem>
                    </MudSelect>
                </MudItem>

                <MudItem xs="12" md="4">
                    <MudNumericField HideSpinButtons @bind-Value="model.Amount" Label="Amount" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.Amount)"></MudNumericField>
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudDatePicker Label="Period From" Variant="Variant.Outlined" Margin="Margin.Dense" DisableToolbar="true" Editable="true" @bind-Date="model.FromDate" HelperText="Enter Date" DateFormat="dd/MM/yyyy" />
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudDatePicker Label="Period To" Variant="Variant.Outlined" Margin="Margin.Dense" DisableToolbar="true" Editable="true" @bind-Date="model.ToDate" HelperText="Enter Date" DateFormat="dd/MM/yyyy" />
                </MudItem>
            </MudGrid>
        </EditForm>
    </DialogContent>
    <DialogActions>
        <div style="padding-right:12px; padding-bottom:12px;">
            <MudButton Size="Size.Large" Variant="Variant.Filled" Color="Color.Success" form="formunl" ButtonType="ButtonType.Submit" Class="ml-auto">Sumbit</MudButton>
        </div>
    </DialogActions>
</MudDialog>

@code {

    [Parameter]
    public ROIUnloadingChargesModel model { get; set; }
    [CascadingParameter]
    MudDialogInstance MudDialog { get; set; }
    //public List<ROIUnloadingChargesModel> Collection = new();
    public List<RouteModel> RouteList { get; set; }
    string UserID;
    int BranchID;

    protected override async Task OnInitializedAsync()
    {
        var authprov = await auth.GetAuthenticationStateAsync();
        UserID = authprov.User.Identity.Name;
        BranchID = int.Parse(authprov.User.Claims.First(x => x.Type == "BranchID").Value);

        //Collection = Iservice.Select(BranchID).ToList();
        RouteList = await Iroute.SelectByBranch(BranchID).ToListAsync();
    }

    private async Task<IEnumerable<RouteModel>> SearchRoutes(string searchString)
    {
        return await Task.FromResult(RouteList.Where(x => x.RouteName.Contains(searchString == null ? string.Empty : searchString, StringComparison.InvariantCultureIgnoreCase)));
    }

    private void RouteChanged(RouteModel obj)
    {
        model.Route = obj;
    }

    private void OnValidSubmit(EditContext context)
    {
        model.UserInfo.UserID = UserID;
        try
        {
            model = Iservice.Update(model);
            MudDialog.Close(model);
        }
        catch (Exception ex)
        {
            snackbar.Add(ex.Message, Severity.Warning);
        }
    }

    private void Cancel()
    {
        MudDialog.Cancel();
    }

}