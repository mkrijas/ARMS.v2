@attribute [Authorize]
@inject AuthenticationStateProvider auth
@using Core.BaseModels.Operations.ROI
@inject ITruckService ITruckService

<MudDialog Style="overflow-y: hidden;">
    <TitleContent>
        <MudText Typo="Typo.h6">
            Add/Edit Tonnage
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudGrid>
            <MudItem xs="6">
                <MudAutocomplete Clearable="true" Variant="Variant.Outlined" Margin="Margin.Dense" T="int?"Label="Wheels" ResetValueOnEmptyText="true" ValueChanged="WheelChanged" Value="model.Wheels" 
                            SearchFunc="SearchWheel"ToStringFunc="@(e => e?.ToString())">
                </MudAutocomplete>
            </MudItem>
        </MudGrid>
    </DialogContent>
    <DialogActions>
        <div style="padding-right:12px; padding-bottom:12px;">
            <MudButton Size="Size.Large" Variant="Variant.Filled" Color="Color.Success" OnClick="Submit" Class="ml-auto">Sumbit</MudButton>
        </div>
    </DialogActions>
</MudDialog>

@code {

    [CascadingParameter] MudDialogInstance MudDialog { get; set; }
    [Parameter]
    public ROIWheelSpeedModel model { get; set; } = new();
    public List<ROITonnageModel> WheelList = new();
    public List<int?> WheelsList { get; set; } = new();
    string UserID;
    int BranchID;

    protected override async Task OnInitializedAsync()
    {
        var authprov = await auth.GetAuthenticationStateAsync();
        UserID = authprov.User.Identity.Name;
        BranchID = int.Parse(authprov.User.Claims.First(x => x.Type == "BranchID").Value);

        WheelList = ITruckService.SelectWheels().ToList();
        WheelsList = WheelList.Select(x => x.Wheels).ToList();
    }

    public void WheelChanged(int? obj)
    {
        model.Wheels = obj;
    }

    protected async Task Submit()
    {
        // model.UserInfo.UserID = UserID;
        // model = IROITonnageService.Update(model);
        // MudDialog.Close(model);
    }

    public async Task<IEnumerable<int?>> SearchWheel(string searchString)
    {
        return await Task.Run(() => WheelsList.Where(x => x.ToString().Contains(searchString ?? string.Empty, StringComparison.InvariantCultureIgnoreCase)).Cast<int?>());
    }
}