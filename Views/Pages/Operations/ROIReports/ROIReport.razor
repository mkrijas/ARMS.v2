@page "/ROIReport"
@inject ISnackbar Snackbar
@attribute [Authorize]
@inject AuthenticationStateProvider auth
@inherits ReportComponentBase

<div class="fade-in">
    <div class="admin-header-tiered mb-6">
        <div class="d-flex align-center justify-space-between">
            <div>
                <MudText Typo="Typo.h4" Class="admin-title">ROI & Performance Analytics</MudText>
                <MudText Typo="Typo.body2" Class="admin-subtitle">Strategic return on investment auditing for fleet operations. Monitor truck performance, maintenance efficiency, and tyre utilization patterns across the organization.</MudText>
            </div>
        </div>
    </div>

    <div class="admin-glass-card mb-6 pa-6">
        <MudGrid Spacing="4" Class="align-center">
            <MudItem xs="12" sm="3">
                <MudSelect For="@(() => ReportName)" Value="ReportName" ValueChanged="OnChangeReport" Variant="Variant.Outlined" Margin="Margin.Dense" AnchorOrigin="Origin.BottomCenter" T="string" Label="Select Performance Report" Class="admin-input-group">
                    @foreach (var i in ROIReportList)
                    {
                        <MudSelectItem Value="@i.Value">@i.Key</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" sm="3">
                <MudDatePicker Label="From Date" @bind-Date="@FromDate" Variant="Variant.Outlined" Margin="Margin.Dense" Class="admin-input-group" />
            </MudItem>
            <MudItem xs="12" sm="3">
                <MudDatePicker Label="To Date" @bind-Date="@ToDate" Variant="Variant.Outlined" Margin="Margin.Dense" Class="admin-input-group" />
            </MudItem>
            <MudItem xs="12" sm="3" Class="d-flex align-center gap-2">
                <MudTooltip Text="Select Branches">
                    <MudIconButton Icon="@Icons.Material.Filled.List" Variant="Variant.Filled" Color="Color.Success" OnClick="SelectBranches" Class="rounded-lg" />
                </MudTooltip>
                <MudButton FullWidth="true" Variant="Variant.Filled" Color="Color.Primary" OnClick="RenderReportViewer" Class="admin-register-btn">VIEW REPORT</MudButton>
            </MudItem>
        </MudGrid>
    </div>

    <div class="admin-glass-card pa-0 overflow-hidden shadow-sm @(ShowReport ? "" : "d-none")">
        <ReportViewer ReportName="@ReportName" Parameters=@ReportParameters @ref="@report"></ReportViewer>
    </div>
</div>

@code {

    ReportViewer report;
    public Dictionary<string, string> ReportParameters { get; set; } = new();
    public DateTime? FromDate { get; set; } = DateTime.Now;
    public DateTime? ToDate { get; set; } = DateTime.Now;
    public bool ShowReport { get; set; } = false;
    public string ReportName { get; set; }
    public BranchModel CurrentBranch { get; set; } = new();
    private Dictionary<string, string> ROIReportList = new Dictionary<string, string>
    {
        {"TAX and FC Report", "ROI_TruckPerformanceReport"},
        {"Detention Summary Report","ROI_DetentionSummaryReport"},
        {"Truck Maintenance Report","ROI_TruckMaintenanceReport"},
        {"Summary Of Mounted Tyre Report","ROI_TyreUtilizationMountReport"},
        {"Tyre Inventory Report","ROI_TyreUtilizationInventoryReport"},
        {"Std Vs Actual Report","ROI_StdVsActual"},
    };

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();
        var authprov = await auth.GetAuthenticationStateAsync();
        var User = authprov.User;
        string BranchIDString = User.Claims.First(x => x.Type == "BranchID").Value;
        CurrentBranch.BranchName = User.Claims.First(x => x.Type == "BranchName").Value;
        CurrentBranch.BranchID = int.Parse(BranchIDString);
    }

    public void OnChangeReport(string a)
    {
        ReportName = a;
    }

    public async Task RenderReportViewer()
    {
        if (ReportName == null)
        {
            Snackbar.Add("Please select Report.", Severity.Error);
            return;
        }
        if (FromDate == null)
        {
            Snackbar.Add("Please select From Date.", Severity.Error);
            return;
        }
        if (ToDate == null)
        {
            Snackbar.Add("Please select To Date.", Severity.Error);
            return;
        }

        ShowReport = true;
        ReportName = ReportName;
        ReportParameters.Clear();
        ReportParameters.Add("BranchName", CurrentBranch.BranchName);
        ReportParameters.Add("BranchIDS", String.Join(',', SelectedBranches));
        ReportParameters.Add("FromDate", FromDate.Value.ToString("yyyy-MM-dd"));
        ReportParameters.Add("ToDate", ToDate.Value.ToString("yyyy-MM-dd"));
        await report.RenderReport(ReportName);
    }
}
