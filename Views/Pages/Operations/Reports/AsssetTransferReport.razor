@page "/AssetTransferReport"
@inject ISnackbar Snackbar
@attribute [Authorize]
@inject AuthenticationStateProvider auth
@inject IBranchService IBranchService
@inject IAssetClassService IAssetClassService

<div class="fade-in">
    <div class="admin-header-tiered mb-6">
        <div class="d-flex align-center justify-space-between">
            <div>
                <MudText Typo="Typo.h4" Class="admin-title">Asset Transfer Report</MudText>
                <MudText Typo="Typo.body2" Class="admin-subtitle">Track the movement of assets across different branches and departments. Monitor transfer history, subclasses, and temporal shifts in asset allocation.</MudText>
            </div>
        </div>
    </div>

    <div class="admin-glass-card mb-6 pa-6">
        <MudGrid Spacing="4" Class="align-center">
            <MudItem xs="12" sm="4">
                <BranchSelector LabelName="Select Branch" Value="SelectedBranch" ValueChanged="@BranchChanged" Class="admin-input-group"></BranchSelector>
            </MudItem>
            <MudItem xs="12" sm="4">
                <MudSelect For="@(() => SelectedAsset)" Label="Asset Class" @bind-Value="SelectedAsset" SelectedValuesChanged="@((e) => AssetClassChanged(e.FirstOrDefault()))" T="AssetClassModel"
                           ToStringFunc="@(e => e == null ? null : $"{e.AssetClassName}")" Variant="Variant.Outlined" Margin="Margin.Dense" Class="admin-input-group" AnchorOrigin="Origin.BottomCenter">
                    @foreach (var item in assetclassList)
                    {
                        <MudSelectItem Value="@item">@item.AssetClassName</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" sm="4">
                <MudSelect For="@(() => SelectedSubAsset)" Label="Sub Class" @bind-Value="SelectedSubAsset" T="AssetSubClassModel" ToStringFunc="@(e => e == null ? null : $"{e.AssetSubclass}")"
                           Variant="Variant.Outlined" Margin="Margin.Dense" Class="admin-input-group" AnchorOrigin="Origin.BottomCenter">
                    @foreach (var item in assetsubclassList)
                    {
                        <MudSelectItem Value="@item">@item.AssetSubclass</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" sm="5">
                <MudDatePicker Label="From Date" @bind-Date="@FromDate" Variant="Variant.Outlined" Margin="Margin.Dense" Class="admin-input-group" />
            </MudItem>
            <MudItem xs="12" sm="5">
                <MudDatePicker Label="To Date" @bind-Date="@ToDate" Variant="Variant.Outlined" Margin="Margin.Dense" Class="admin-input-group" />
            </MudItem>
            <MudItem xs="12" sm="2">
                <MudButton FullWidth="true" Variant="Variant.Filled" Color="Color.Primary" OnClick="RenderReportViewer" Class="admin-register-btn">VIEW REPORT</MudButton>
            </MudItem>
        </MudGrid>
    </div>

    <div class="admin-glass-card pa-0 overflow-hidden shadow-sm @(ShowReport ? "" : "d-none")">
        <ReportViewer ReportName="@ReportName" Parameters=@ReportParameters SpName="rptAssetTransfer" @ref="@report"></ReportViewer>
    </div>
</div>

@code {
    ReportViewer report;
    public Dictionary<string, string> ReportParameters { get; set; } = new();
    public DateTime? FromDate { get; set; } = DateTime.Now;
    public DateTime? ToDate { get; set; } = DateTime.Now;
    public bool ShowReport { get; set; } = false;
    public string ReportName { get; set; }
    public BranchModel SelectedBranch { get; set; } = new();
    private List<AssetClassModel> assetclassList = new();
    private List<AssetSubClassModel> assetsubclassList = new();
    public AssetClassModel SelectedAsset { get; set; } = new();
    public AssetSubClassModel SelectedSubAsset { get; set; } = new();
    public BranchModel CurrentBranch { get; set; } = new();

    protected override async Task OnInitializedAsync()
    {
        var authprov = await auth.GetAuthenticationStateAsync();
        var User = authprov.User;
        string BranchIDString = User.Claims.First(x => x.Type == "BranchID").Value;
        CurrentBranch.BranchName = User.Claims.First(x => x.Type == "BranchName").Value;
        CurrentBranch.BranchID = int.Parse(BranchIDString);

        assetclassList = IAssetClassService.SelectClasses().ToList();
    }

    private async Task BranchChanged(BranchModel branch)
    {
        SelectedBranch = branch;
    }

    private async Task AssetClassChanged(AssetClassModel asset)
    {
        SelectedAsset = asset;
        assetsubclassList = IAssetClassService.SelectSubClassesByClass(SelectedAsset.AssetClassID.Value).ToList();
    }

    public async Task RenderReportViewer()
    {
        if (FromDate == null)
        {
            Snackbar.Add("Please select From Date.", Severity.Error);
            return;
        }
        if (ToDate == null)
        {
            Snackbar.Add("Please select To Date.", Severity.Error);
            return;
        }
        
        ShowReport = true;
        ReportName = "AssetTransferReport";
        ReportParameters.Clear();
        ReportParameters.Add("BranchName", CurrentBranch.BranchName);
        ReportParameters.Add("BranchID", (SelectedBranch?.BranchID ?? 0).ToString());
        ReportParameters.Add("AssetID", (SelectedAsset?.AssetClassID ?? 0).ToString());
        ReportParameters.Add("AssetSubClassID", (SelectedSubAsset?.AssetSubClassID ?? 0).ToString());
        ReportParameters.Add("FromDate", FromDate.Value.ToString("yyyy-MM-dd"));
        ReportParameters.Add("ToDate", ToDate.Value.ToString("yyyy-MM-dd"));
        await report.RenderReport(ReportName);
    }
}
