    public async Task RenderReportViewer()
    {
        if (!SelectedBranches.Any())
        {
            snackbar.Add("Please select branch.", Severity.Error);
            return;
        }
        if (FromDate == null && OrderFromDate == null && InvoiceFromDate == null)
        {
            Snackbar.Add("Please select any From Date.", Severity.Error);
            return;
        }
        if (ToDate == null && OrderToDate == null && InvoiceToDate == null)
        {
            Snackbar.Add("Please select any To Date.", Severity.Error);
            return;
        }

        ShowReport = true;
        ReportName = "ConsignmentNoteReport";
        ReportParameters.Clear();
        //string branches = String.Join(',', BranchIDS);
        //ReportParameters.Add("BranchIDS", branches);
        ReportParameters.Add("BranchIDS", String.Join(',', SelectedBranches));
        ReportParameters.Add("BranchName", CurrentBranch.BranchName);
        if (FromDate != null && ToDate != null)
        {
            ReportParameters.Add("FromDate", FromDate?.ToString("yyyy/MM/dd") ?? "");
            ReportParameters.Add("ToDate", ToDate?.ToString("yyyy/MM/dd") ?? "");
        }
        if (OrderFromDate != null && OrderToDate != null)
        {
            ReportParameters.Add("OrderFromDate", OrderFromDate?.ToString("yyyy/MM/dd"));
            ReportParameters.Add("OrderToDate", OrderToDate?.ToString("yyyy/MM/dd"));
        }
        if (InvoiceFromDate != null && InvoiceToDate != null)
        {
            ReportParameters.Add("InvoiceFromDate", InvoiceFromDate?.ToString("yyyy/MM/dd"));
            ReportParameters.Add("InvoiceToDate", InvoiceToDate?.ToString("yyyy/MM/dd"));
        }
        await report.RenderReport();
    }
}