@page "/ConsignmentNoteReport"
@inject ISnackbar Snackbar
@attribute [Authorize]
@inject AuthenticationStateProvider auth
@inject IBranchService IBranchService
@inject IAssetClassService IAssetClassService
@inject IBranchService Ibranchservice
@inherits ReportComponentBase

<MudGrid Spacing="4">
    <MudItem xs="12">
        <MudPaper Class="mb-5 p-4">
            <MudToolBar Style="padding-left: 0px; margin-top: -22px;">
                <MudText Typo="Typo.h5" Style="font-weight:500;">ConsignmentNote Report</MudText>
            </MudToolBar>
            <MudDivider />
            <MudGrid Style="padding-top: 22px;">
                <MudItem xs="4">
                    <MudSelect Label="Select Type" @bind-Value="@SelctedOperation" T="string" Variant="Variant.Outlined" Margin="Margin.Dense" AdornmentColor="Color.Secondary" AnchorOrigin="Origin.BottomCenter">
                        <MudSelectItem Value="@("Consignment")">Consignment</MudSelectItem>
                        <MudSelectItem Value="@("Order")">Order</MudSelectItem>
                        <MudSelectItem Value="@("Invoice")">Invoice</MudSelectItem>
                    </MudSelect>
                </MudItem>
                <MudItem xs="3">
                    <MudDatePicker Label="From Date" @bind-Date="@(FromDate)" Variant="Variant.Outlined" Margin="Margin.Dense" />
                </MudItem>
                <MudItem xs="3">
                    <MudDatePicker Label="To Date" @bind-Date="@(ToDate)" Variant="Variant.Outlined" Margin="Margin.Dense" />
                </MudItem>
                <MudItem xs="2" Style="display: flex; align-items: center;">
                    <MudIconButton Style="margin-right: 8px;" Title="Select Branches" Icon="@Icons.Material.Filled.List" Variant="Variant.Filled" Color="Color.Success" OnClick="SelectBranches"></MudIconButton>
                    <MudButton Style="width: -webkit-fill-available;" Variant="Variant.Filled" Color="Color.Success" OnClick="RenderReportViewer">View Report</MudButton>
                </MudItem>
            </MudGrid>
        </MudPaper>
    </MudItem>
</MudGrid>
<MudGrid Style="@(ShowReport?"":"Display:none")">
    <MudItem xs="12">
        <ReportViewer ReportName="@ReportName" Parameters=@ReportParameters @ref="@report"></ReportViewer>
    </MudItem>
</MudGrid>

@code {

    ReportViewer report;
    public Dictionary<string, string> ReportParameters { get; set; } = new();
    public DateTime? FromDate { get; set; }
    public DateTime? ToDate { get; set; }
    public bool ShowReport { get; set; } = false;
    public string ReportName { get; set; }
    public string SelctedOperation { get; set; }
    public BranchModel CurrentBranch { get; set; } = new();

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();
        var authprov = await auth.GetAuthenticationStateAsync();
        var User = authprov.User;
        string BranchIDString = User.Claims.First(x => x.Type == "BranchID").Value;
        CurrentBranch.BranchName = User.Claims.First(x => x.Type == "BranchName").Value;
    }

    public async Task RenderReportViewer()
    {
        if (!SelectedBranches.Any())
        {
            snackbar.Add("Please select branch.", Severity.Error);
            return;
        }
        if (SelctedOperation == null)
        {
            snackbar.Add("Please select Type.", Severity.Error);
            return;
        }
        if (FromDate == null)
        {
            Snackbar.Add("Please select From Date.", Severity.Error);
            return;
        }
        if (ToDate == null)
        {
            Snackbar.Add("Please select To Date.", Severity.Error);
            return;
        }

        ShowReport = true;
        ReportName = "ConsignmentNoteReport";
        ReportParameters.Clear();
        ReportParameters.Add("BranchIDS", String.Join(',', SelectedBranches));
        ReportParameters.Add("BranchName", CurrentBranch.BranchName);
        if (SelctedOperation == "Consignment")
        {
            ReportParameters.Add("FromDate", FromDate?.ToString("yyyy/MM/dd") ?? "");
            ReportParameters.Add("ToDate", ToDate?.ToString("yyyy/MM/dd") ?? "");
        }
        if (SelctedOperation == "Order")
        {
            ReportParameters.Add("OrderFromDate", FromDate?.ToString("yyyy/MM/dd"));
            ReportParameters.Add("OrderToDate", ToDate?.ToString("yyyy/MM/dd"));
        }
        if (SelctedOperation == "Invoice")
        {
            ReportParameters.Add("InvoiceFromDate", FromDate?.ToString("yyyy/MM/dd"));
            ReportParameters.Add("InvoiceToDate", ToDate?.ToString("yyyy/MM/dd"));
        }
        await report.RenderReport();
    }
}