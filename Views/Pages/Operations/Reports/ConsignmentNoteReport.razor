@page "/ConsignmentNoteReport"
@inject ISnackbar Snackbar
@attribute [Authorize]
@inject AuthenticationStateProvider auth
@inject IBranchService IBranchService
@inject IAssetClassService IAssetClassService
@inject IBranchService Ibranchservice
@inherits ReportComponentBase

<div class="fade-in">
    <div class="admin-header-tiered mb-6">
        <div class="d-flex align-center justify-space-between">
            <div>
                <MudText Typo="Typo.h4" Class="admin-title">ConsignmentNote Report</MudText>
                <MudText Typo="Typo.body2" Class="admin-subtitle">Comprehensive tracking and analysis of consignment notes, orders, and invoices across selected branches. Monitor document flow and operational metrics with precision.</MudText>
            </div>
        </div>
    </div>

    <div class="admin-glass-card mb-6 pa-6">
        <MudGrid Spacing="4" Class="align-center">
            <MudItem xs="12" sm="4">
                <MudSelect For="@(() => SelctedOperation)" Label="Select Type" @bind-Value="@SelctedOperation" T="string" Variant="Variant.Outlined" Margin="Margin.Dense" Class="admin-input-group" AnchorOrigin="Origin.BottomCenter">
                    <MudSelectItem Value="@("Consignment")">Consignment</MudSelectItem>
                    <MudSelectItem Value="@("Order")">Order</MudSelectItem>
                    <MudSelectItem Value="@("Invoice")">Invoice</MudSelectItem>
                </MudSelect>
            </MudItem>
            <MudItem xs="12" sm="3">
                <MudDatePicker Label="From Date" @bind-Date="@FromDate" Variant="Variant.Outlined" Margin="Margin.Dense" Class="admin-input-group" />
            </MudItem>
            <MudItem xs="12" sm="3">
                <MudDatePicker Label="To Date" @bind-Date="@ToDate" Variant="Variant.Outlined" Margin="Margin.Dense" Class="admin-input-group" />
            </MudItem>
            <MudItem xs="12" sm="2" Class="d-flex align-center gap-2">
                <MudTooltip Text="Select Branches">
                    <MudIconButton Icon="@Icons.Material.Filled.List" Variant="Variant.Filled" Color="Color.Success" OnClick="SelectBranches" Class="rounded-lg" />
                </MudTooltip>
                <MudButton FullWidth="true" Variant="Variant.Filled" Color="Color.Primary" OnClick="RenderReportViewer" Class="admin-register-btn">VIEW REPORT</MudButton>
            </MudItem>
        </MudGrid>
    </div>

    <div class="admin-glass-card pa-0 overflow-hidden shadow-sm @(ShowReport ? "" : "d-none")">
        <ReportViewer ReportName="@ReportName" Parameters=@ReportParameters SpName="rptConsignmentNoteReport" @ref="@report"></ReportViewer>
    </div>
</div>

@code {

    ReportViewer report;
    public Dictionary<string, string> ReportParameters { get; set; } = new();
    public DateTime? FromDate { get; set; }
    public DateTime? ToDate { get; set; }
    public bool ShowReport { get; set; } = false;
    public string ReportName { get; set; }
    public string SelctedOperation { get; set; }
    public BranchModel CurrentBranch { get; set; } = new();

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();
        var authprov = await auth.GetAuthenticationStateAsync();
        var User = authprov.User;
        string BranchIDString = User.Claims.First(x => x.Type == "BranchID").Value;
        CurrentBranch.BranchName = User.Claims.First(x => x.Type == "BranchName").Value;
    }

    public async Task RenderReportViewer()
    {
        if (!SelectedBranches.Any())
        {
            snackbar.Add("Please select branch.", Severity.Error);
            return;
        }
        if (SelctedOperation == null)
        {
            snackbar.Add("Please select Type.", Severity.Error);
            return;
        }
        if (FromDate == null)
        {
            Snackbar.Add("Please select From Date.", Severity.Error);
            return;
        }
        if (ToDate == null)
        {
            Snackbar.Add("Please select To Date.", Severity.Error);
            return;
        }

        ShowReport = true;
        ReportName = "ConsignmentNoteReport";
        ReportParameters.Clear();
        ReportParameters.Add("BranchIDS", String.Join(',', SelectedBranches));
        ReportParameters.Add("BranchName", CurrentBranch.BranchName);
        
        string fromStr = FromDate?.ToString("yyyy-MM-dd");
        string toStr = ToDate?.ToString("yyyy-MM-dd");

        if (SelctedOperation == "Consignment")
        {
            ReportParameters.Add("FromDate", fromStr);
            ReportParameters.Add("ToDate", toStr);
        }
        else if (SelctedOperation == "Order")
        {
            ReportParameters.Add("OrderFromDate", fromStr);
            ReportParameters.Add("OrderToDate", toStr);
        }
        else if (SelctedOperation == "Invoice")
        {
            ReportParameters.Add("InvoiceFromDate", fromStr);
            ReportParameters.Add("InvoiceToDate", toStr);
        }

        await report.RenderReport(ReportName);
    }
}
