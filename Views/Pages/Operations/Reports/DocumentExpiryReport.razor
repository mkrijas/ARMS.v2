@page "/DocumentExpiryReport"
@inject ISnackbar Snackbar
@attribute [Authorize]
@inject AuthenticationStateProvider auth
@inject IBranchService Ibranchservice
@inject IAssetDocumentService Iservice
@inherits ReportComponentBase

<MudGrid Spacing="4">
    <MudItem xs="12">
        <MudPaper Class="mb-5 p-4">
            <MudToolBar Style="padding-left: 0px; margin-top: -22px;">
                <MudText Typo="Typo.h5" Style="font-weight:500;">Document Expiry Report</MudText>
            </MudToolBar>
            <MudDivider />
            <MudGrid Style="padding-top: 22px;">   
                <MudItem xs="3">
                    <MudSelect T="AssetDocumentTypeModel" @bind-Value="@DocType" ToStringFunc="@(e => e == null ? null : $"{e.DocumentTypeName}")" Label="DocumentType Name" Variant="Variant.Outlined" Margin="Margin.Dense" AnchorOrigin="Origin.BottomCenter" AdornmentColor="Color.Secondary">
                        @foreach (var item in DocTypeName)
                        {
                            <MudSelectItem Value="@item">@item.DocumentTypeName</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="3">
                    <MudSelect Label="Select Status" @bind-Value="DocStatus" T="string" Variant="Variant.Outlined" Margin="Margin.Dense" AnchorOrigin="Origin.BottomCenter" AdornmentColor="Color.Secondary">
                        <MudSelectItem Value="@("EXPIRED")">EXPIRED</MudSelectItem>
                        <MudSelectItem Value="@("EXTENDED")">EXTENDED</MudSelectItem>
                        <MudSelectItem Value="@("-1")">ALL</MudSelectItem>
                    </MudSelect>
                </MudItem>
                <MudItem xs="2">
                    <MudDatePicker Label="From Date" @bind-Date="@(FromDate)" Variant="Variant.Outlined" Margin="Margin.Dense" AnchorOrigin="Origin.BottomCenter"/>
                </MudItem>
                <MudItem xs="2">
                    <MudDatePicker Label="To Date" @bind-Date="@(ToDate)" Variant="Variant.Outlined" Margin="Margin.Dense" AnchorOrigin="Origin.BottomCenter"/>
                </MudItem>
                <MudItem xs="2" Style="display: flex; align-items: center;">
                    <MudIconButton Style="margin-right: 8px;" Title="Select Branches" Icon="@Icons.Material.Filled.List" Variant="Variant.Filled" Color="Color.Success" OnClick="SelectBranches"></MudIconButton>
                    <MudButton Style="width: -webkit-fill-available;" Variant="Variant.Filled" Color="Color.Success" OnClick="RenderReportViewer">View Report</MudButton>
                </MudItem>
            </MudGrid>
        </MudPaper>
    </MudItem>
</MudGrid>
<MudGrid Style="@(ShowReport?"":"Display:none")">
    <MudItem xs="12">
        <ReportViewer ReportName="@ReportName" Parameters=@ReportParameters  @ref="@report"></ReportViewer>
    </MudItem>
</MudGrid>

@code {
    ReportViewer report;
    public Dictionary<string, string> ReportParameters { get; set; } = new();
    public string DocStatus { get; set; }
    public DateTime? FromDate { get; set; } = DateTime.Now;
    public DateTime? ToDate { get; set; } = DateTime.Now;
    public BranchModel SelectedBranch { get; set; } = new();
    public bool ShowReport { get; set; } = false;
    public string ReportName { get; set; }   
    public BranchModel CurrentBranch { get; set; } = new();
    public AssetDocumentTypeModel DocType { get; set; } = new();
    public List<AssetDocumentTypeModel> DocTypeName { get; set; } = new();

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();
        var authprov = await auth.GetAuthenticationStateAsync();
        var User = authprov.User;
        string BranchIDString = User.Claims.First(x => x.Type == "BranchID").Value;
        CurrentBranch.BranchName = User.Claims.First(x => x.Type == "BranchName").Value;
        DocTypeName = Iservice.GetDocumentTypes().ToList();
        //CurrentBranch.BranchID = int.Parse(BranchIDString);
        //BranchList = Ibranchservice.Select().ToList();
    }   

    public async Task RenderReportViewer()
    {
        if (!SelectedBranches.Any())
        {
            snackbar.Add("Please select branch.", Severity.Error);
            return;
        }
        if (FromDate == null)
        {
            Snackbar.Add("Please select From Date.", Severity.Error);
            return;
        }
        if (ToDate == null)
        {
            Snackbar.Add("Please select To Date.", Severity.Error);
            return;
        }

        ShowReport = true;
        @if (DocType.DocumentTypeID == 19 || DocType.DocumentTypeID == 20)
        {
            ReportName = "InsuranceDocumentExpiryReport";
        }
        else
        {
            ReportName = "AssetDocumentExpiryReport";
        }
        ReportParameters.Clear();       
        ReportParameters.Add("BranchIDS", String.Join(',', SelectedBranches));
        ReportParameters.Add("BranchName", CurrentBranch.BranchName);
        ReportParameters.Add("DocStatus", DocStatus);
        ReportParameters.Add("DocTypeID", (DocType.DocumentTypeID ?? 0).ToString());
        ReportParameters.Add("FromDate", FromDate.Value.ToString("yyyy/MM/dd"));
        ReportParameters.Add("ToDate", ToDate.Value.ToString("yyyy/MM/dd"));
        await report.RenderReport();
    }
}
