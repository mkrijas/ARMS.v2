@page "/DocumentExpiryReport"
@inject ISnackbar Snackbar
@attribute [Authorize]
@inject AuthenticationStateProvider auth
@inject IBranchService Ibranchservice
@inject IAssetDocumentService Iservice
@inherits ReportComponentBase

<div class="fade-in">
    <div class="admin-header-tiered mb-6">
        <div class="d-flex align-center justify-space-between">
            <div>
                <MudText Typo="Typo.h4" Class="admin-title">Document Expiry Report</MudText>
                <MudText Typo="Typo.body2" Class="admin-subtitle">Proactive monitoring of asset documentation lifecycle. Track expiry dates for permits, insurance, and certifications to ensure continuous operational compliance.</MudText>
            </div>
        </div>
    </div>

    <div class="admin-glass-card mb-6 pa-6">
        <MudGrid Spacing="4" Class="align-center">
            <MudItem xs="12" sm="3">
                <MudSelect For="@(() => DocType)" T="AssetDocumentTypeModel" @bind-Value="@DocType" ToStringFunc="@(e => e == null ? null : $"{e.DocumentTypeName}")" Label="Document Type" Variant="Variant.Outlined" Margin="Margin.Dense" Class="admin-input-group" AnchorOrigin="Origin.BottomCenter">
                    @foreach (var item in DocTypeName)
                    {
                        <MudSelectItem Value="@item">@item.DocumentTypeName</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" sm="3">
                <MudSelect For="@(() => DocStatus)" Label="Status" @bind-Value="DocStatus" T="string" Variant="Variant.Outlined" Margin="Margin.Dense" Class="admin-input-group" AnchorOrigin="Origin.BottomCenter">
                    <MudSelectItem Value="@("EXPIRED")">EXPIRED</MudSelectItem>
                    <MudSelectItem Value="@("EXTENDED")">EXTENDED</MudSelectItem>
                    <MudSelectItem Value="@("-1")">ALL</MudSelectItem>
                </MudSelect>
            </MudItem>
            <MudItem xs="12" sm="2">
                <MudDatePicker Label="From Date" @bind-Date="@FromDate" Variant="Variant.Outlined" Margin="Margin.Dense" Class="admin-input-group" />
            </MudItem>
            <MudItem xs="12" sm="2">
                <MudDatePicker Label="To Date" @bind-Date="@ToDate" Variant="Variant.Outlined" Margin="Margin.Dense" Class="admin-input-group" />
            </MudItem>
            <MudItem xs="12" sm="2" Class="d-flex align-center gap-2">
                <MudTooltip Text="Select Branches">
                    <MudIconButton Icon="@Icons.Material.Filled.List" Variant="Variant.Filled" Color="Color.Success" OnClick="SelectBranches" Class="rounded-lg" />
                </MudTooltip>
                <MudButton FullWidth="true" Variant="Variant.Filled" Color="Color.Primary" OnClick="RenderReportViewer" Class="admin-register-btn">VIEW REPORT</MudButton>
            </MudItem>
        </MudGrid>
    </div>

    <div class="admin-glass-card pa-0 overflow-hidden shadow-sm @(ShowReport ? "" : "d-none")">
        <ReportViewer ReportName="@ReportName" Parameters=@ReportParameters SpName="rptDocumentexpiry" @ref="@report"></ReportViewer>
    </div>
</div>

@code {
    ReportViewer report;
    public Dictionary<string, string> ReportParameters { get; set; } = new();
    public string DocStatus { get; set; }
    public DateTime? FromDate { get; set; } = DateTime.Now;
    public DateTime? ToDate { get; set; } = DateTime.Now;
    public BranchModel SelectedBranch { get; set; } = new();
    public bool ShowReport { get; set; } = false;
    public string ReportName { get; set; }   
    public BranchModel CurrentBranch { get; set; } = new();
    public AssetDocumentTypeModel DocType { get; set; } = new();
    public List<AssetDocumentTypeModel> DocTypeName { get; set; } = new();

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();
        var authprov = await auth.GetAuthenticationStateAsync();
        var User = authprov.User;
        string BranchIDString = User.Claims.First(x => x.Type == "BranchID").Value;
        CurrentBranch.BranchName = User.Claims.First(x => x.Type == "BranchName").Value;
        DocTypeName = Iservice.GetDocumentTypes().ToList();
        //CurrentBranch.BranchID = int.Parse(BranchIDString);
        //BranchList = Ibranchservice.Select().ToList();
    }   

    public async Task RenderReportViewer()
    {
        if (!SelectedBranches.Any())
        {
            snackbar.Add("Please select branch.", Severity.Error);
            return;
        }
        if (FromDate == null)
        {
            Snackbar.Add("Please select From Date.", Severity.Error);
            return;
        }
        if (ToDate == null)
        {
            Snackbar.Add("Please select To Date.", Severity.Error);
            return;
        }

        ShowReport = true;
        @if (DocType.DocumentTypeID == 19 || DocType.DocumentTypeID == 20)
        {
            ReportName = "InsuranceDocumentExpiryReport";
        }
        else
        {
            ReportName = "AssetDocumentExpiryReport";
        }
        ReportParameters.Clear();       
        ReportParameters.Add("BranchIDS", String.Join(',', SelectedBranches));
        ReportParameters.Add("BranchName", CurrentBranch.BranchName);
        ReportParameters.Add("DocStatus", DocStatus);
        ReportParameters.Add("DocTypeID", (DocType.DocumentTypeID ?? 0).ToString());
        ReportParameters.Add("FromDate", FromDate.Value.ToString("yyyy-MM-dd"));
        ReportParameters.Add("ToDate", ToDate.Value.ToString("yyyy-MM-dd"));
        await report.RenderReport(ReportName);
    }
}
