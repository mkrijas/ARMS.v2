@page "/OperationSummaryReport"
@inject ISnackbar Snackbar
@attribute [Authorize]
@inject AuthenticationStateProvider auth
@inject IBranchService IBranchService
@inject IAssetClassService IAssetClassService
@inherits ReportComponentBase

<div class="admin-page-container">
    <div class="admin-header-tiered mb-6">
        <div class="d-flex align-center justify-space-between">
            <div>
                <MudText Typo="Typo.h4" Class="admin-title">Operation Summary Report</MudText>
                <MudText Typo="Typo.body2" Class="admin-subtitle">Comprehensive overview of trips, consignments, and contracts.</MudText>
            </div>
        </div>
    </div>

    <div class="admin-glass-card pa-6 mb-6">
        <MudGrid Spacing="3" Class="align-end">
            <MudItem xs="12" sm="3">
                <MudDatePicker Label="From Date" @bind-Date="@FromDate" Variant="Variant.Outlined" Margin="Margin.Dense" Class="modern-input" />
            </MudItem>
            <MudItem xs="12" sm="3">
                <MudDatePicker Label="To Date" @bind-Date="@ToDate" Variant="Variant.Outlined" Margin="Margin.Dense" Class="modern-input" />
            </MudItem>
            <MudItem xs="12" sm="3" Class="d-flex align-center">
                <MudRadioGroup T="string" @bind-Value="@ReportName" Class="admin-radio-group">
                    <MudRadio Value="@("OperationSummaryTripReport")" Color="Color.Primary" Dense="true">Trip-Wise</MudRadio>
                    <MudRadio Value="@("OperationSummaryGcReport")" Color="Color.Primary" Dense="true">GC-Wise</MudRadio>
                    <MudRadio Value="@("OperationSummaryOrderReport")" Color="Color.Primary" Dense="true">Contract-Wise</MudRadio>
                </MudRadioGroup>
            </MudItem>
            <MudItem xs="12" sm="1" Class="d-flex align-center">
                <MudCheckBox T="bool" @bind-Value="@AllTrips" Color="Color.Primary" Label="All Trips" Dense="true" />
            </MudItem>
            <MudItem xs="12" sm="2">
                <div class="d-flex gap-2">
                    <MudTooltip Text="Select Branches">
                        <MudIconButton Icon="@Icons.Material.Filled.AccountTree" Variant="Variant.Outlined" Color="Color.Primary" OnClick="SelectBranches" Style="height: 40px; width: 40px;" />
                    </MudTooltip>
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Visibility" OnClick="RenderReportViewer" Class="admin-register-btn flex-grow-1" Style="height: 40px;">VIEW</MudButton>
                </div>
            </MudItem>
        </MudGrid>
    </div>

    <div class="admin-glass-card pa-0 overflow-hidden fade-in" style="@(ShowReport ? "" : "display:none")">
        <ReportViewer ReportName="@ReportName" Parameters="@ReportParameters" @ref="@report"></ReportViewer>
    </div>
</div>

@code {

    ReportViewer report;
    public Dictionary<string, string> ReportParameters { get; set; } = new();
    public DateTime? FromDate { get; set; } = DateTime.Now;
    public DateTime? ToDate { get; set; } = DateTime.Now;
    public bool AllTrips { get; set; } = false;
    public bool ShowReport { get; set; } = false;
    public string ReportName { get; set; } = "OperationSummaryTripReport";
    //public BranchModel SelectedBranch { get; set; } = new();
    public BranchModel CurrentBranch { get; set; } = new();

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();
        var authprov = await auth.GetAuthenticationStateAsync();
        var User = authprov.User;
        string BranchIDString = User.Claims.First(x => x.Type == "BranchID").Value;
        CurrentBranch.BranchName = User.Claims.First(x => x.Type == "BranchName").Value;
        // CurrentBranch.BranchID = int.Parse(BranchIDString);
    }

    // private async Task BranchChanged(BranchModel branch)
    // {
    //     SelectedBranch = branch;
    // }

    public async Task RenderReportViewer()
    {
        if (!SelectedBranches.Any())
        {
            snackbar.Add("Please select branch.", Severity.Error);
            return;
        }
        if (FromDate == null)
        {
            Snackbar.Add("Please select From Date.", Severity.Error);
            return;
        }
        if (ToDate == null)
        {
            Snackbar.Add("Please select To Date.", Severity.Error);
            return;
        }

        ShowReport = true;
        ReportParameters.Clear();
        ReportParameters.Add("BranchName", CurrentBranch.BranchName);
        ReportParameters.Add("BranchIDS", String.Join(',', SelectedBranches));
        // ReportParameters.Add("BranchID", (SelectedBranch?.BranchID ?? 0).ToString());
        ReportParameters.Add("FromDate", FromDate.Value.ToString("yyyy/MM/dd"));
        ReportParameters.Add("ToDate", ToDate.Value.ToString("yyyy/MM/dd"));
        ReportParameters.Add("TripDeleted", AllTrips.ToString());
        await report.RenderReport();
    }
}
