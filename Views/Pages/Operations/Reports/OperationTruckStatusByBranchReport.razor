@page "/OperationTruckStatusByBranchReport"
@using Microsoft.JSInterop
@using Microsoft.AspNetCore.Components
@using Views.Data;
@using System.Text;
@using System.Net;
@inject AuthenticationStateProvider auth
@inject IBranchService Ibranchservice
@inject ISnackbar Snackbar

<MudGrid Spacing="4">
    <MudItem xs="12">
        <MudPaper Class="mb-5 p-4">
            <MudItem xs="12" md="12">
                <MudSelect Label="Select Branch" Variant="Variant.Outlined" Margin="Margin.Dense" @bind-Value="SelectedBranch" ToStringFunc="@((e)=>e==null?null:e.BranchName)" T="BranchModel" OffsetY="true" Direction="Direction.Top" AdornmentColor="Color.Secondary" Required>
                    @foreach (BranchModel ditem in DestinationBranchList)
                    {
                        <MudSelectItem Value="@ditem">@ditem.BranchName</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudGrid>
                <MudItem xs="5" md="5">
                    <MudDatePicker Label="Date" @bind-Date="@(SelectedDateTime)" />
                </MudItem>
                <MudItem xs="2" md="2">
                    <MudButton Style="margin-top:9%;" Variant="Variant.Filled" Color="Color.Success" OnClick="RenderReportViewer">View Report</MudButton>
                </MudItem>
            </MudGrid>
        </MudPaper>
    </MudItem>
</MudGrid>
<MudGrid Style="@(ShowReport?"":"Display:none")">
    <MudItem xs="12">
        <ReportViewer ReportName="@ReportName" Parameters=@ReportParameters></ReportViewer>
    </MudItem>
</MudGrid>

@code {
    public Dictionary<string, string> ReportParameters { get; set; } = new();

    public DateTime? SelectedDateTime { get; set; } = DateTime.Now;
    public int? BranchID { get; set; } = 0;
    public BranchModel SelectedBranch { get; set; } = new();
    public bool ShowReport { get; set; } = false;
    public string ReportName { get; set; }

    private List<BranchModel> DestinationBranchList = new();

    protected override void OnInitialized()
    {
        DestinationBranchList = Ibranchservice.Select().ToList();
    }
    public void RenderReportViewer()
    {

        if (SelectedBranch == null || SelectedBranch.BranchID == null)
        {
            Snackbar.Add("Please select branch.", Severity.Error);
            return;
        }
        if (SelectedDateTime == null)
        {
            Snackbar.Add("Please select date.", Severity.Error);
            return;
        }

        ShowReport = true;
        ReportName = "rpt.Operation.TruckStatusByBranch";
        ReportParameters.Clear();
        ReportParameters.Add("BranchID", SelectedBranch.BranchID.ToString());
        ReportParameters.Add("SelectedDateTime", SelectedDateTime.Value.ToString("yyyy/MM/dd"));
    }
}