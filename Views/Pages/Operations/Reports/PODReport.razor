@page "/PODReport"
@inject ISnackbar Snackbar
@attribute [Authorize]
@inject AuthenticationStateProvider auth
@inject IBranchService Ibranchservice
@inherits ReportComponentBase

<div class="admin-page-container">
    <div class="admin-header-tiered mb-6">
        <div class="d-flex align-center justify-space-between">
            <div>
                <MudText Typo="Typo.h4" Class="admin-title">POD Report</MudText>
                <MudText Typo="Typo.body2" Class="admin-subtitle">Analyze Proof of Delivery status across branches and time periods.</MudText>
            </div>
        </div>
    </div>

    <div class="admin-glass-card pa-6 mb-6">
        <MudGrid Spacing="3" Class="align-end">
            <MudItem xs="12" sm="4">
                <MudDatePicker Label="From Date" @bind-Date="@FromDate" Variant="Variant.Outlined" Margin="Margin.Dense" Class="modern-input" Color="Color.Primary" />
            </MudItem>
            <MudItem xs="12" sm="4">
                <MudDatePicker Label="To Date" @bind-Date="@ToDate" Variant="Variant.Outlined" Margin="Margin.Dense" Class="modern-input" Color="Color.Primary" />
            </MudItem>
            <MudItem xs="12" sm="4">
                <div class="d-flex gap-2">
                    <MudTooltip Text="Select Branches">
                        <MudIconButton Icon="@Icons.Material.Filled.AccountTree" Variant="Variant.Outlined" Color="Color.Primary" OnClick="SelectBranches" Style="height: 40px; width: 40px;" />
                    </MudTooltip>
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Visibility" OnClick="RenderReportViewer" Class="admin-register-btn flex-grow-1" Style="height: 40px;">VIEW REPORT</MudButton>
                </div>
            </MudItem>
        </MudGrid>
    </div>

    <div class="admin-glass-card pa-0 overflow-hidden fade-in" style="@(ShowReport ? "" : "display:none")">
        <ReportViewer ReportName="@ReportName" Parameters="@ReportParameters" @ref="@report"></ReportViewer>
    </div>
</div>

@code {
    ReportViewer report;
    public Dictionary<string, string> ReportParameters { get; set; } = new();
    public DateTime? FromDate { get; set; } = DateTime.Now;
    public DateTime? ToDate { get; set; } = DateTime.Now;
    public BranchModel SelectedBranch { get; set; } = new();
    public bool ShowReport { get; set; } = false;
    public string ReportName { get; set; }
    //private List<BranchModel> BranchList = new();
    //public string BranchID { get; set; } = "";
    //private IEnumerable<string> BranchIDS { get; set; } = new HashSet<string>() { };
    public BranchModel CurrentBranch { get; set; } = new();

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();
        var authprov = await auth.GetAuthenticationStateAsync();
        var User = authprov.User;
        string BranchIDString = User.Claims.First(x => x.Type == "BranchID").Value;
        CurrentBranch.BranchName = User.Claims.First(x => x.Type == "BranchName").Value;
        //CurrentBranch.BranchID = int.Parse(BranchIDString);
        //BranchList = Ibranchservice.Select().ToList();
    }

    // private string GetMultiSelectionText(List<string> selectedValues)
    // {
    //     string Result = "";
    //     foreach (var item in selectedValues)
    //     {
    //         if (BranchList.Any(s => s.BranchID.Value.ToString() == item))
    //         {
    //             if (Result == "")
    //             {
    //                 Result = BranchList.FirstOrDefault(s => s.BranchID.Value.ToString() == item).BranchName;
    //             }
    //             else
    //             {
    //                 Result = Result + ", " + BranchList.FirstOrDefault(s => s.BranchID.Value.ToString() == item).BranchName;
    //             }
    //         }
    //     }
    //     return Result;
    // }

    public async Task RenderReportViewer()
    {
        if (!SelectedBranches.Any())
        {
            snackbar.Add("Please select branch.", Severity.Error);
            return;
        }
        if (FromDate == null)
        {
            Snackbar.Add("Please select From Date.", Severity.Error);
            return;
        }
        if (ToDate == null)
        {
            Snackbar.Add("Please select To Date.", Severity.Error);
            return;
        }

        ShowReport = true;
        ReportName = "PointOfDeliveryReport";
        ReportParameters.Clear();
        //string branches = String.Join(',', BranchIDS);
        //ReportParameters.Add("BranchIDS", branches);
        ReportParameters.Add("BranchIDS", String.Join(',', SelectedBranches));
        ReportParameters.Add("BranchName", CurrentBranch.BranchName);
        ReportParameters.Add("FromDate", FromDate.Value.ToString("yyyy/MM/dd"));
        ReportParameters.Add("ToDate", ToDate.Value.ToString("yyyy/MM/dd"));
        await report.RenderReport();
    }
}
