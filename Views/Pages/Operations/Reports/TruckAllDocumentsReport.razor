@page "/TruckAllDocumentReport"
@attribute [Authorize]
@inherits ReportComponentBase

<div class="fade-in">
    <div class="admin-header-tiered mb-6">
        <div class="d-flex align-center justify-space-between">
            <div>
                <MudText Typo="Typo.h4" Class="admin-title">Truck Documents Archive</MudText>
                <MudText Typo="Typo.body2" Class="admin-subtitle">Centralized access to all vehicle-related documentation. Review compliance audits, registration papers, and mandatory certifications for the entire fleet.</MudText>
            </div>
        </div>
    </div>

    <div class="admin-glass-card pa-0 overflow-hidden shadow-sm @(ReportName is not null ? "" : "d-none")">
        <ReportViewer ReportName="@ReportName" Parameters=@ReportParameters SpName="rptTruckAllDocuments" @ref="@report"></ReportViewer>
    </div>
</div>

@code {

    ReportViewer report;
    public bool ShowReport { get; set; } = false;
    protected string ReportName { get; set; }  
    public BranchModel CurrentBranch { get; set; } = new();

    protected override async Task OnInitializedAsync()
    {
        ReportName = "TruckDocumentsCurrent";
        await base.OnInitializedAsync();   
        var authprov = await auth.GetAuthenticationStateAsync();
        var User = authprov.User;
        CurrentBranch.BranchName = User.Claims.First(x => x.Type == "BranchName").Value;
        await ShowCurrentDocs();
    }

    private async Task ShowCurrentDocs()
    {       
        ReportParameters.Clear();
        ReportParameters.Add("BranchName", CurrentBranch.BranchName);
        ShowReport = true;
        await report.RenderReport(ReportName);
    }
}
