@page "/TruckDocumentAll"
@attribute [Authorize]
@inherits ReportComponentBase

<MudGrid Style="@(ReportName is not null?"":"Display:none")">
    <MudItem xs="12">
        <ReportViewer ReportName="@ReportName" Parameters=@ReportParameters @ref="@report"></ReportViewer>
    </MudItem>
</MudGrid>

@code {

    ReportViewer report;
    public bool ShowReport { get; set; } = false;
    protected string ReportName { get; set; }  

    protected override async Task OnInitializedAsync()
    {
        ReportName = "TruckDocumentsCurrent";
        await base.OnInitializedAsync();     
        await ShowCurrentDocs();
    }

   
    private async Task ShowCurrentDocs()
    {       
        ReportParameters.Clear();
        ShowReport = true;
        await report.RenderReport();
    }
    
}