@using ArmsModels.BaseModels.General
@using ArmsServices.DataServices.Operations
@inject AuthenticationStateProvider auth
@inject IRoutineCheckListMasterService Iservice
@inject IAssetDocumentService IDocumentService

<MudDialog>
    <TitleContent>
        @if (model.ItemID == null || model.ItemID == 0)
        {
            <MudText Typo="Typo.h6">
                <MudIcon Icon="@Icons.Material.Filled.Edit" Class="mr-3" /> Add Item Master.
            </MudText>
        }
        else
        {
            <MudText Typo="Typo.h6">
                <MudIcon Icon="@Icons.Material.Filled.Edit" Class="mr-3" /> Edit Item Master.
            </MudText>
        }
    </TitleContent>
    <DialogContent>

        <MudContainer Style="max-height: 400px; overflow-y: scroll; margin-left:20px">
            <EditForm id="formDriver" Model="@model" OnValidSubmit="Submit">
                <ObjectGraphDataAnnotationsValidator />
                <ValidationSummary />

                <MudItem xs="11" md="11" Class="mb-6">
                    <MudTextField @bind-Value="model.ItemName" Label="Item Name" Variant="Variant.Outlined" Margin="Margin.Normal" For="@(() => model.ItemName)"></MudTextField>
                </MudItem>
                <MudItem xs="11" md="11" Class="mb-6">
                    <MudTextField @bind-Value="model.Description" Label="Description" Variant="Variant.Outlined" Margin="Margin.Normal" For="@(() => model.Description)"></MudTextField>
                </MudItem>
                <MudItem xs="11" md="11">
                    <MudCheckBox @bind-Checked="@model.IsDisabled" Label="Disable"></MudCheckBox>
                </MudItem>
            </EditForm>
        </MudContainer>

    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Submit" Class="px-12">Submit</MudButton>
    </DialogActions>
</MudDialog>

@code {

    [CascadingParameter] MudDialogInstance MudDialog { get; set; }

    [Parameter]
    public RoutineCheckListMasterModel model { get; set; } = new();


    //Dictionary<int?, string> TransNature = new Dictionary<int?, string>()
    //{
    //   (1,"Receipt"),
    //   (-1,"Payment")
    //};
    List<AssetDocumentTypeModel> DocumentTypes = new();

    protected override void OnInitialized()
    {

    }

    protected override void OnParametersSet()
    {
        DocumentTypes = IDocumentService.GetDocumentTypes().ToList();
    }
    void Cancel()
    {
        MudDialog.Cancel();
    }
    public async Task Submit()
    {
        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;
        if (model != null)
        {

            model.UserInfo.UserID = user.Identity.Name;
            Iservice.Update(model);
        }

        MudDialog.Close(DialogResult.Ok(true));
    }
}
