@page "/TariffTypes"
@attribute [Authorize]
@inject AuthenticationStateProvider auth
@using System.Threading;
@inject ITariffService Iservice
@inject MudBlazor.ISnackbar snackbar
@inject IDialogService DialogService
@inject IRoleService<RoleModel> Irole

<div class="admin-page-container">
    <div class="admin-header-tiered mb-6">
        <div class="d-flex align-center justify-space-between">
            <div>
                <MudText Typo="Typo.h4" Class="admin-title">Tariff Types</MudText>
                <MudText Typo="Typo.body2" Class="admin-subtitle">Manage transaction types, financial groups, and accounting signs for logistics tariffs.</MudText>
            </div>
            <MudButton StartIcon="@Icons.Material.Filled.Add" Variant="Variant.Filled" Color="Color.Primary" Class="admin-register-btn" OnClick="@(()=> Edit(new TariffTypeModel()))" Disabled="@_busy">ADD TYPE</MudButton>
        </div>
    </div>

    <div class="admin-glass-card mb-6 pa-4">
        <div style="max-width: 400px;">
            <MudTextField @bind-Value="searchString" Placeholder="Search by name..." Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" Variant="Variant.Outlined" Margin="Margin.Dense" Class="admin-input-group" Clearable="true" />
        </div>
    </div>

    <div class="admin-glass-card pa-0 overflow-hidden">
        <MudTable Items="@collection" Dense="true" Hover="true" Elevation="0" Filter="new Func<TariffTypeModel, bool>(search)" Class="modern-admin-table">
            <HeaderContent>
                <MudTh><MudTableSortLabel SortBy="new Func<TariffTypeModel, object>(x=> x.TariffTypeName)" InitialDirection="SortDirection.Ascending"><span class="admin-header-text">TRANSACTION TYPE</span></MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<TariffTypeModel, object>(x=> x.TariffGroup)" InitialDirection="SortDirection.Ascending"><span class="admin-header-text">NATURE</span></MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<TariffTypeModel, object>(x=> x.TariffSign)" InitialDirection="SortDirection.Ascending"><span class="admin-header-text">MODE</span></MudTableSortLabel></MudTh>
                <MudTh Style="text-align: right;"><span class="admin-header-text">ACTIONS</span></MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Name"><MudText Typo="Typo.body2" Class="admin-td-primary">@context.TariffTypeName</MudText></MudTd>
                <MudTd DataLabel="Nature"><MudChip T="string" Size="Size.Small" Variant="Variant.Text" Color="Color.Info" Class="pa-0">@context.TariffGroup</MudChip></MudTd>
                <MudTd DataLabel="Mode">
                    <MudText Typo="Typo.body2" Class="@(context.TariffSign == 1 ? "admin-td-primary fw-700" : "admin-td-amount fw-700")">
                        @(context.TariffSign == 1 ? "INCOME" : "EXPENSE")
                    </MudText>
                </MudTd>
                <MudTd DataLabel="Actions" Style="text-align: right;">
                    <div class="d-flex justify-end gap-1">
                        <MudTooltip Text="Edit">
                            <MudIconButton OnClick="@(()=> Edit(context))" Color="Color.Primary" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Variant="Variant.Text" />
                        </MudTooltip>
                        <MudTooltip Text="Delete">
                            <MudIconButton OnClick="@(()=> Delete(context))" Color="Color.Error" Icon="@Icons.Material.Filled.DeleteOutline" Size="Size.Small" Variant="Variant.Text" />
                        </MudTooltip>
                    </div>
                </MudTd>
            </RowTemplate>
            <PagerContent>
                <div class="pa-4">
                    <MudTablePager PageSizeOptions="new int[] { 10, 20, 50, 100 }" />
                </div>
            </PagerContent>
        </MudTable>
    </div>
</div>

@code {

    private TariffTypeModel model = new();
    private List<TariffTypeModel> collection = new();

    private string searchString = "";
    private bool _busy;
    public bool HasPermissionTariffServiceEdit { get; set; } = false;
    public bool HasPermissionTariffServiceDelete { get; set; } = false;
    public int DocTypeID = 41;

    protected override async Task OnInitializedAsync()
    {
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionTariffServiceEdit = await Irole.HasClaim(DocTypeID.ToString(), "Edit", ctc.Token);
        HasPermissionTariffServiceDelete = await Irole.HasClaim(DocTypeID.ToString(), "Delete", ctc.Token);

        await GetAll();
    }

    private async Task GetAll()
    {
        collection = Iservice.SelectTariffTypes("All").ToList();
    }

    private async Task Edit(TariffTypeModel model)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        _busy = true;
        if (HasPermissionTariffServiceEdit)
        {
            DialogParameters parms = new DialogParameters();
            parms.Add("model", model.Clone());
            var dialog = await DialogService.ShowAsync<TarrifTypeDilog>("Tariff", parms);
            var result = await dialog.Result;

            // you can check if the modal was cancelled
            var isCancelled = result.Canceled;
            if (!isCancelled)
            {
                TariffTypeModel UpatedModel = (TariffTypeModel)result.Data;
                if (UpatedModel != null)
                {
                    if (collection.Exists(x => x.TariffTypeID == UpatedModel.TariffTypeID))
                    {
                        collection[collection.FindIndex(x => x.TariffTypeID == UpatedModel.TariffTypeID)] = UpatedModel;
                    }
                    else
                    {
                        collection.Add(UpatedModel);
                    }
                }
                model = new();
            }
        }
        else
        {
            bool? ResultModel = await DialogService.ShowMessageBoxAsync(
                "Permission denied!",
                "You don't have any permission to Add or Edit Tariff.");
        }
        await Task.Delay(200);
        _busy = false;
    }

    private async Task Delete(TariffTypeModel model)
    {
        if (HasPermissionTariffServiceEdit)
        {
            bool? result = await DialogService.ShowMessageBoxAsync(
                "Warning !",
                "Are you sure, you want to delete - " + model.TariffTypeName + " (" + model.TariffGroup + ")  ?");
            if (result == true)
            {
                var authprov = await auth.GetAuthenticationStateAsync();
                var user = authprov.User;
                int value = Iservice.Delete(model.TariffTypeID.Value, user.Identity.Name);

                if (value != -1)
                {
                    if (collection != null && collection.Any(s => s.TariffTypeID == model.TariffTypeID.Value))
                    {
                        collection.Remove(collection.FirstOrDefault(s => s.TariffTypeID == model.TariffTypeID.Value));
                        snackbar.Add("Deleted Successfully", Severity.Success);
                    }
                }
            }
        }
        else
        {
            bool? result = await DialogService.ShowMessageBoxAsync(
                "Permission denied!",
                "You don't have any permission to delete Tariff.");
        }
    }

    private bool search(TariffTypeModel model)
    {
        if (model.TariffTypeName != null && model.TariffTypeName.Contains(searchString, StringComparison.OrdinalIgnoreCase))
        {
            return true;
        }
        return false;
    }
}

