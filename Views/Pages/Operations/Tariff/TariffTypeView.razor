    private async Task Edit(TariffTypeModel model)
    {
         DialogParameters parms = new DialogParameters();
        parms.Add("model",model);
        
        var dialog = DialogService.Show<TarrifTypeDilog>("Edit",parms);

        var result = await dialog.Result;

        // you can check if the modal was cancelled
        var isCancelled = result.Cancelled;
        if (!isCancelled)
        {
            await GetAll();
        }

    }
    private void Delete(int? id)
    {
        //await Iservice.Delete(id, "Rijas");
        //snackbar.Add("Deleted Successfully", Severity.Success);
        //await GetAll();
    }


    private bool search(TariffTypeModel model)
    {
        if (model.TariffTypeName != null && model.TariffTypeName.Contains(searchString, StringComparison.OrdinalIgnoreCase))
        {
            return true;
        }
        return false;
    }
      private  async Task  OpenDialog()
    {

        DialogParameters parms = new DialogParameters();
        parms.Add("model", new TariffTypeModel());
        
        var dialog =  DialogService.Show<TarrifTypeDilog>("ADD TARRIF TYPE",parms);

        var result = await dialog.Result;

        // you can check if the modal was cancelled
        var isCancelled = result.Cancelled;
        if (!isCancelled)
        {
            await GetAll();
        }
    }
}



