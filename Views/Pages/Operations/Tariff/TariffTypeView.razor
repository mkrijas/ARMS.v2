@page "/TariffTypes"
@inject ITariffService Iservice
@inject MudBlazor.ISnackbar snackbar
@attribute [Authorize]
@inject AuthenticationStateProvider auth
@inject IDialogService DialogService

@using System.Threading;
@inject IRoleService<RoleModel> Irole

<MudGrid Spacing="4">
    <MudItem xs="12" md="12">
        <MudTable Items="@collection" Elevation="10" Filter="new Func<TariffTypeModel, bool>(search)" @bind-model="model">
            <ToolBarContent>
                <MudText Typo="Typo.h6">Tariffs</MudText>
                <MudIconButton Icon="@Icons.Material.Filled.Add" Title="Add" @onclick="(()=>Edit(new TariffTypeModel()))" Color="Color.Dark" Size="Size.Small"></MudIconButton>
                <MudSpacer></MudSpacer>
                <MudTextField @bind-Value="searchString" Placeholder="Search ... " Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0"></MudTextField>
            </ToolBarContent>
            <HeaderContent>
                <MudTh><MudTableSortLabel SortBy="new Func<TariffTypeModel, object>(x=> x.TariffTypeName)" InitialDirection="SortDirection.Ascending">Transaction Type</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<TariffTypeModel, object>(x=> x.TariffGroup)" InitialDirection="SortDirection.Ascending">Nature</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<TariffTypeModel, object>(x=> x.TariffSign)" InitialDirection="SortDirection.Ascending">Mode</MudTableSortLabel></MudTh>
                <MudTh>Actions</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Name">@context.TariffTypeName</MudTd>
                <MudTd DataLabel="Nature">@context.TariffGroup</MudTd>
                <MudTd DataLabel="Mode">@(context.TariffSign == 1 ? "INCOME" : "EXPENSE")</MudTd>
                    <MudTd DataLabel="">
                        <MudFab @onclick="@(()=> Edit(context))" Color="Color.Primary" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" IconSize="Size.Small" />
                        <MudFab @onclick="@(()=> Delete(context))" Color="Color.Primary" Icon="@Icons.Material.Filled.Delete" Size="Size.Small" IconSize="Size.Small" />
                    </MudTd>
                </RowTemplate>
                <PagerContent>
                    <MudTablePager PageSizeOptions="new int[] { 5, 10, 20, 50, 100 }" />
                </PagerContent>
            </MudTable>
        </MudItem>
    </MudGrid>

    @code {

    private TariffTypeModel model = new();
    private List<TariffTypeModel> collection = new();

    private string searchString = "";

    public bool HasPermissionTariffServiceEdit { get; set; } = false;
    public bool HasPermissionTariffServiceDelete { get; set; } = false;
    public int DocTypeID = 41;

    protected override async Task OnInitializedAsync()
    {
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionTariffServiceEdit = await Irole.HasClaim(DocTypeID.ToString(), "Edit", ctc.Token);
        HasPermissionTariffServiceDelete = await Irole.HasClaim(DocTypeID.ToString(), "Delete", ctc.Token);

        await GetAll();
    }

    private async Task GetAll()
    {
        collection = Iservice.SelectTariffTypes("All").ToList();
    }

    private async Task Edit(TariffTypeModel model)
    {
        if (HasPermissionTariffServiceEdit)
        {
            DialogParameters parms = new DialogParameters();
            parms.Add("model", model.Clone());
            var dialog = DialogService.Show<TarrifTypeDilog>("Tariff", parms);
            var result = await dialog.Result;

            // you can check if the modal was cancelled
            var isCancelled = result.Canceled;
            if (!isCancelled)
            {
                TariffTypeModel UpatedModel = (TariffTypeModel)result.Data;
                if (UpatedModel != null)
                {
                    if (collection.Exists(x => x.TariffTypeID == UpatedModel.TariffTypeID))
                    {
                        collection[collection.FindIndex(x => x.TariffTypeID == UpatedModel.TariffTypeID)] = UpatedModel;
                    }
                    else
                    {
                        collection.Add(UpatedModel);
                    }
                }
                model = new();
            }
        }
        else
        {
            bool? ResultModel = await DialogService.ShowMessageBox(
                "Permission denied!",
                "You dont have any permission to Add or Edit Tariff.");
        }
    }

    private async Task Delete(TariffTypeModel model)
    {
        if (HasPermissionTariffServiceEdit)
        {
            bool? result = await DialogService.ShowMessageBox(
               "Warning !",
               "Are you sure, you want to delete - " + model.TariffTypeName + " (" + model.TariffGroup + ")  ?");
            if (result == true)
            {
                var authprov = await auth.GetAuthenticationStateAsync();
                var user = authprov.User;
                int value = Iservice.Delete(model.TariffTypeID.Value, user.Identity.Name);

                if (value != -1)
                {
                    if (collection != null && collection.Any(s => s.TariffTypeID == model.TariffTypeID.Value))
                    {
                        collection.Remove(collection.FirstOrDefault(s => s.TariffTypeID == model.TariffTypeID.Value));
                        snackbar.Add("Deleted Successfully", Severity.Success);
                    }
                }
            }
        }
        else
        {
            bool? result = await DialogService.ShowMessageBox(
              "Permission denied!",
              "You dont have any permission to delete Tariff.");
        }
    }

    private bool search(TariffTypeModel model)
    {
        if (model.TariffTypeName != null && model.TariffTypeName.Contains(searchString, StringComparison.OrdinalIgnoreCase))
        {
            return true;
        }
        return false;
    }
}