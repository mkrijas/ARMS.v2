@page "/tariff/{OrderID:int}"
@attribute [Authorize]
@inject AuthenticationStateProvider auth
@using System.Threading;
@inject ITariffService Iservice
@inject IRouteService Iroute
@inject IOrderService Iorder
@inject MudBlazor.ISnackbar snackbar
@inject IDialogService DialogService
@inject IRoleService<RoleModel> Irole

<MudGrid>
    <MudItem xs="12" md="12">
        <MudTable Items="@collection" Elevation="10" Filter="new Func<TariffModel, bool>(search)">
            <ToolBarContent>
                <MudText Typo="Typo.h6">@Order.OrderName Tariffs</MudText>
                <MudIconButton Icon="@Icons.Material.Filled.Add" Title="Add" OnClick="@(() => Edit(new TariffModel()))" Color="Color.Dark" Size="Size.Small"></MudIconButton>
                <MudSpacer></MudSpacer>
                <MudTextField @bind-Value="searchString" Placeholder="Search Tariffs..." Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0"></MudTextField>
            </ToolBarContent>
            <HeaderContent>
                <MudTh><MudTableSortLabel SortBy="new Func<TariffModel, object>(x=> x.TariffType.TariffTypeName)" InitialDirection="SortDirection.Ascending">Type</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<TariffModel, object>(x=> x.Formula.Formula)" InitialDirection="SortDirection.Ascending">Formula</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<TariffModel, object>(x=> x.Route.RouteName)" InitialDirection="SortDirection.Ascending">Route</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<TariffModel, object>(x=> x.TruckAxles)" InitialDirection="SortDirection.Ascending">Axles</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<TariffModel, object>(x=> x.TariffRate)" InitialDirection="SortDirection.Ascending">Rate</MudTableSortLabel></MudTh>
                <MudTh>Actions</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Type">@context.TariffType.TariffTypeName</MudTd>
                <MudTd DataLabel="Formula">@context.Formula.Formula</MudTd>
                <MudTd DataLabel="Route">@context.Route.RouteName</MudTd>
                <MudTd DataLabel="Axles">@context.TruckAxles</MudTd>
                <MudTd DataLabel="Rate">@context.TariffRate</MudTd>
                <MudTd DataLabel="">
                    <MudFab @onclick="@(()=> Edit(context))" Color="Color.Primary" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" IconSize="Size.Small" />
                    <MudFab @onclick="@(()=> Delete(context))" Color="Color.Primary" Icon="@Icons.Material.Filled.Delete" Size="Size.Small" IconSize="Size.Small" />
                </MudTd>
            </RowTemplate>
            <PagerContent>
                <MudTablePager PageSizeOptions="new int[] { 5, 10, 20, 50, 100 }" />
            </PagerContent>
        </MudTable>
    </MudItem>
</MudGrid>

@code {

    [Parameter]
    public int OrderID { get; set; }
    #region Declared Properties

    private string searchString = "";

    private OrderModel Order = new();
    private List<TariffModel> collection = new();
    #endregion

    public bool HasPermissionTariffServiceEdit { get; set; } = false;
    public bool HasPermissionTariffServiceDelete { get; set; } = false;
    public int DocTypeID = 41;

    protected override async Task OnInitializedAsync()
    {
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionTariffServiceEdit = await Irole.HasClaim(DocTypeID.ToString(), "Edit", ctc.Token);
        HasPermissionTariffServiceDelete = await Irole.HasClaim(DocTypeID.ToString(), "Delete", ctc.Token);

        if (OrderID != 0)
        {
            Order = await Iorder.SelectByID(OrderID);
        }
        GetAll();
    }

    private void GetAll()
    {
        collection = Iservice.SelectByOrder(OrderID).ToList();
    }

    private async Task Edit(TariffModel editModel)
    {
        if (HasPermissionTariffServiceEdit)
        {
            DialogParameters parms = new DialogParameters();
            parms.Add("model", editModel.Clone());
            parms.Add("Order", Order);
            var dialog = DialogService.Show<TarrifDilog>("Add/Edit Tariffs", parms, new DialogOptions() { MaxWidth = MaxWidth.Large });
            var result = await dialog.Result;
            if (!result.Cancelled)
            {
                TariffModel UpdatedModel = (TariffModel)result.Data;
                if (UpdatedModel != null)
                {
                    if (collection.Exists(x => x.TariffID == UpdatedModel.TariffID))
                    {
                        collection[collection.FindIndex(x => x.TariffID == UpdatedModel.TariffID)] = UpdatedModel;
                    }
                    else
                    {
                        collection.Add(UpdatedModel);
                    }
                    UpdatedModel = new();
                }
            }
        }
        else
        {
            bool? ResultModel = await DialogService.ShowMessageBox(
                "Permission denied!",
                "You dont have any permission to Add or Edit Tariff.");
        }
    }

    private async Task Delete(TariffModel deleteModel)
    {
        if (HasPermissionTariffServiceDelete)
        {
            if (deleteModel != null)
            {
                var authprov = await auth.GetAuthenticationStateAsync();
                var user = authprov.User;
                int result = Iservice.Delete(deleteModel.TariffID, user.Identity.Name);
                if (result != -1)
                {
                    if (collection != null && collection.Any(s => s.TariffID == deleteModel.TariffID))
                    {
                        collection.Remove(collection.FirstOrDefault(s => s.TariffID == deleteModel.TariffID));
                        snackbar.Add("Deleted Successfully", Severity.Success);
                    }
                }
            }
        }
        else
        {
            bool? result = await DialogService.ShowMessageBox(
                "Permission denied!",
                "You dont have any permission to delete Tariff.");
        }
    }

    private bool search(TariffModel model)
    {
        if (model.Order != null && model.Order.OrderName.Contains(searchString, StringComparison.OrdinalIgnoreCase) || model.Route != null && model.Route.RouteName.Contains(searchString, StringComparison.OrdinalIgnoreCase))
        {
            return true;
        }
        return false;
    }
}