@page "/tariff/{OrderID:int}"
@attribute [Authorize]
@inject AuthenticationStateProvider auth
@using System.Threading;
@inject ITariffService Iservice
@inject IRouteService Iroute
@inject IOrderService Iorder
@inject MudBlazor.ISnackbar snackbar
@inject IDialogService DialogService
@inject IRoleService<RoleModel> Irole

@if (_isLoading)
{
    <div @key="@("loader")" style="display: flex; justify-content: center; align-items: center; min-height: 400px;">
        <LoaderComponent IsFullScreen="true" 
                        ShowLogo="false" 
                        Size="medium" 
                        LoadingText="Loading Tariffs" 
                        SubText="Please wait..." />
    </div>
}
else
{
    <div class="admin-page-container">
        <div class="admin-header-tiered mb-6">
            <div class="d-flex align-center justify-space-between">
                <div>
                    <MudText Typo="Typo.h4" Class="admin-title">@(Order?.OrderName ?? "Service") Tariffs</MudText>
                    <MudText Typo="Typo.body2" Class="admin-subtitle">Configure rate formulas and logistics pricing for specific transportation routes.</MudText>
                </div>
                <MudButton StartIcon="@Icons.Material.Filled.Add" Variant="Variant.Filled" Color="Color.Primary" Class="admin-register-btn" OnClick="@(() => Edit(new TariffModel()))" Disabled="@_busy">CREATE TARIFF</MudButton>
            </div>
        </div>

        <div class="admin-glass-card mb-6 pa-4">
            <div style="max-width: 400px;">
                <MudTextField @bind-Value="searchString" Placeholder="Search by type or route..." Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" Variant="Variant.Outlined" Margin="Margin.Dense" Class="admin-input-group" Clearable="true" />
            </div>
        </div>

        <div class="admin-glass-card pa-0 overflow-hidden">
            <MudTable Items="@collection" Dense="true" Hover="true" Elevation="0" Filter="new Func<TariffModel, bool>(search)" Class="modern-admin-table">
                <HeaderContent>
                    <MudTh><MudTableSortLabel SortBy="new Func<TariffModel, object>(x=> x.TariffType.TariffTypeName)" InitialDirection="SortDirection.Ascending"><span class="admin-header-text">TYPE</span></MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<TariffModel, object>(x=> x.Formula.Formula)" InitialDirection="SortDirection.Ascending"><span class="admin-header-text">FORMULA</span></MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<TariffModel, object>(x=> x.Route.RouteName)" InitialDirection="SortDirection.Ascending"><span class="admin-header-text">ROUTE</span></MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<TariffModel, object>(x=> x.Wheels)" InitialDirection="SortDirection.Ascending"><span class="admin-header-text">AXLES</span></MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<TariffModel, object>(x=> x.TariffRate)" InitialDirection="SortDirection.Ascending"><span class="admin-header-text">RATE</span></MudTableSortLabel></MudTh>
                    <MudTh Style="text-align: right;"><span class="admin-header-text">ACTIONS</span></MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Type"><MudText Typo="Typo.body2" Class="admin-td-primary">@context.TariffType.TariffTypeName</MudText></MudTd>
                    <MudTd DataLabel="Formula"><MudChip T="string" Size="Size.Small" Variant="Variant.Text" Color="Color.Info" Class="pa-0">@context.Formula.Formula</MudChip></MudTd>
                    <MudTd DataLabel="Route"><MudText Typo="Typo.body2" Class="admin-td-primary">@context.Route.RouteName</MudText></MudTd>
                    <MudTd DataLabel="Axles"><MudText Typo="Typo.body2" Class="admin-td-secondary">@context.Wheels Axles</MudText></MudTd>
                    <MudTd DataLabel="Rate"><MudText Typo="Typo.body2" Class="admin-td-amount">@context.TariffRate</MudText></MudTd>
                    <MudTd DataLabel="Actions" Style="text-align: right;">
                        <div class="d-flex justify-end gap-1">
                            <MudTooltip Text="Edit">
                                <MudIconButton OnClick="@(()=> Edit(context))" Color="Color.Primary" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Variant="Variant.Text" />
                            </MudTooltip>
                            <MudTooltip Text="Delete">
                                <MudIconButton OnClick="@(()=> Delete(context))" Color="Color.Error" Icon="@Icons.Material.Filled.DeleteOutline" Size="Size.Small" Variant="Variant.Text" />
                            </MudTooltip>
                        </div>
                    </MudTd>
                </RowTemplate>
                <PagerContent>
                    <div class="pa-4">
                        <MudTablePager PageSizeOptions="new int[] { 10, 20, 50, 100 }" />
                    </div>
                </PagerContent>
            </MudTable>
        </div>
    </div>
}



@code {

    private bool _isLoading = true;
    private DateTime _loadStartTime;

    [Parameter]
    public int OrderID { get; set; }
    #region Declared Properties

    private string searchString = "";
    private bool _busy;
    private OrderModel Order = new();
    private List<TariffModel> collection = new();
    #endregion

    public bool HasPermissionTariffServiceEdit { get; set; } = false;
    public bool HasPermissionTariffServiceDelete { get; set; } = false;
    public int DocTypeID = 41;

    protected override async Task OnInitializedAsync()
    {
        _loadStartTime = DateTime.Now;
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionTariffServiceEdit = await Irole.HasClaim(DocTypeID.ToString(), "Edit", ctc.Token);
        HasPermissionTariffServiceDelete = await Irole.HasClaim(DocTypeID.ToString(), "Delete", ctc.Token);

        if (OrderID != 0)
        {
            Order = await Iorder.SelectByID(OrderID);
        }
        GetAll();
        await EnsureMinimumLoadTime();
        _isLoading = false;
    }

    private async Task EnsureMinimumLoadTime()
    {
        var elapsed = (DateTime.Now - _loadStartTime).TotalMilliseconds;
        if (elapsed < 100)
        {
            await Task.Delay(100 - (int)elapsed);
        }
    }

    private void GetAll()
    {
        collection = Iservice.SelectByOrder(OrderID).ToList();
    }

    private async Task Edit(TariffModel editModel)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        _busy = true;
        if (HasPermissionTariffServiceEdit)
        {
            DialogParameters parms = new DialogParameters();
            parms.Add("model", editModel.Clone());
            parms.Add("Order", Order);
            var dialog = await DialogService.ShowAsync<TarrifDilog>("Add/Edit Tariffs", parms, new DialogOptions() { MaxWidth = MaxWidth.Large });
            var result = await dialog.Result;
            if (!result.Canceled)
            {
                TariffModel UpdatedModel = (TariffModel)result.Data;
                if (UpdatedModel != null)
                {
                    if (collection.Exists(x => x.TariffID == UpdatedModel.TariffID))
                    {
                        collection[collection.FindIndex(x => x.TariffID == UpdatedModel.TariffID)] = UpdatedModel;
                    }
                    else
                    {
                        collection.Add(UpdatedModel);
                    }
                    UpdatedModel = new();
                }
            }
        }
        else
        {
            bool? ResultModel = await DialogService.ShowMessageBoxAsync(
                "Permission denied!",
                "You don't have any permission to Add or Edit Tariff.");
        }
        await Task.Delay(200);
        _busy = false;
    }

    private async Task Delete(TariffModel model)
    {
        if (HasPermissionTariffServiceDelete)
        {
            bool? resultmsg = await DialogService.ShowMessageBoxAsync(
                "Warning !",
                new MarkupString("Are you sure, you want to delete - <b>" + model.TariffType.TariffTypeName + " (" + model.Formula.Formula + ")" + "</b> ?"));
            if (resultmsg == true)
            {
                if (model != null)
                {
                    var authprov = await auth.GetAuthenticationStateAsync();
                    var user = authprov.User;
                    int result = Iservice.Delete(model.TariffID, user.Identity.Name);
                    if (result != -1)
                    {
                        if (collection != null && collection.Any(s => s.TariffID == model.TariffID))
                        {
                            collection.Remove(collection.FirstOrDefault(s => s.TariffID == model.TariffID));
                            snackbar.Add("Deleted Successfully", Severity.Success);
                        }
                    }
                }
            }
        }
        else
        {
            bool? result = await DialogService.ShowMessageBoxAsync(
                "Permission denied!",
                "You don't have any permission to delete Tariff.");
        }
    }

    private bool search(TariffModel model)
    {
        if ((model.TariffType != null && model.TariffType.TariffTypeName.Contains(searchString, StringComparison.OrdinalIgnoreCase)) || (model.Route != null && model.Route.RouteID != 0 && model.Route.RouteName.Contains(searchString, StringComparison.OrdinalIgnoreCase)))
        {
            return true;
        }
        return false;
    }
}

