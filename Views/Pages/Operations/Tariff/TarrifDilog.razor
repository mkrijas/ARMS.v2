@attribute [Authorize]
@inject AuthenticationStateProvider auth
@using System.Threading;
@inject ITariffService Iservice
@inject IRouteService Iroute
@inject IOrderService Iorder
@inject IGstUsageIDService usageService
@inject MudBlazor.ISnackbar snackbar
@inject IDialogService DialogService
@inject IRoleService<RoleModel> Irole

<MudDialog Class="admin-dialog-glass">
    <TitleContent>
        <div class="header-section mb-2 pt-4 px-4">
            <div class="d-flex align-center justify-space-between">
                <div class="d-flex align-center">
                    <div class="icon-badge primary-badge mr-4">
                        <div class="admin-header-icon-badge mb-3">
                            <MudIcon Icon="@Icons.Material.Filled.Payments" Color="Color.Secondary" Style="font-size: 3rem;" />
                        </div>
                    </div>
                    <div>
                        <MudText Typo="Typo.h5" Class="admin-title"><b>Tariff Specification</b></MudText>
                        <MudText Typo="Typo.body2" Class="admin-subtitle">
                            Define financial parameters and billing formulas for logistical routes.
                        </MudText>
                    </div>
                </div>
            </div>
            <div class="title-accent mt-4"></div>
        </div>
    </TitleContent>
    <DialogContent>
        <MudContainer Class="admin-dialog-container">
            <div class="dialog-content-wrapper">
                <EditForm id="tariffForm" Model="@model" OnValidSubmit="OnValidSubmit">
                    <DataAnnotationsValidator />
                    
                    <div class="admin-glass-card pa-6">
                        <div class="d-flex align-center mb-6">
                            <MudIcon Icon="@Icons.Material.Filled.SettingsSuggest" Color="Color.Primary" Class="mr-2" />
                            <span class="admin-section-label mb-0">Contractual Parameters</span>
                        </div>
                        
                        <MudGrid Spacing="3">
                            <MudItem xs="12" md="8">
                                <MudAutocomplete T="RouteModel" Label="Logistics Route" @bind-Value="model.Route" ResetValueOnEmptyText="true" Variant="Variant.Outlined" Margin="Margin.Normal" SearchFunc="SearchRoutes" ToStringFunc="@(e=> e==null?null : $"{e.RouteName}")" Class="modern-input" Placeholder="Search route..."></MudAutocomplete>
                            </MudItem>
                            <MudItem xs="12" md="4">
                                <MudSelect For="@(() => model.TariffType)" Label="Tariff Classification" @bind-Value="model.TariffType" ToStringFunc=@((e)=> e?.TariffTypeName) AdornmentColor="Color.Secondary" Variant="Variant.Outlined" Margin="Margin.Normal" Class="modern-input">
                                    @foreach (var item in TariffTypes)
                                    {
                                        <MudSelectItem Value="@item">@item.TariffTypeName</MudSelectItem>
                                    }
                                </MudSelect>
                            </MudItem>
                            <MudItem xs="12" md="4">
                                <MudTextField @bind-Value="model.TariffRate" Label="Standard Rate" Variant="Variant.Outlined" Margin="Margin.Normal" For="@(() => model.TariffRate)" Class="modern-input" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.CurrencyRupee"></MudTextField>
                            </MudItem>
                            <MudItem xs="12" md="4">
                                <MudSelect For="@(() => model.Formula)" Label="Calculation Algorithm" @bind-Value="model.Formula" ToStringFunc=@((e)=> e?.Formula) Margin="Margin.Normal" AdornmentColor="Color.Secondary" Variant="Variant.Outlined" Class="modern-input">
                                    @foreach (var item in Formulas)
                                    {
                                        <MudSelectItem Value="@item">@item.Formula</MudSelectItem>
                                    }
                                </MudSelect>
                            </MudItem>

                            <MudItem xs="12" md="4">
                                <MudTextField @bind-Value="model.Wheels" Label="Configuration Capacity (Wheels)" Variant="Variant.Outlined" Margin="Margin.Normal" For="@(() => model.Wheels)" Class="modern-input" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.SettingsInputHdmi"></MudTextField>
                            </MudItem>
                            
                            <MudItem xs="12">
                                <div class="d-flex align-center py-2 px-4 rounded-lg" style="background: rgba(var(--mud-palette-primary-rgb), 0.05); border: 1px dashed rgba(var(--mud-palette-primary-rgb), 0.2);">
                                    <MudCheckBox T="bool" @bind-Value="model.CalculateOnUnloadingQty" Label="Synchronize with Unloading Metrics" Color="Color.Primary" Dense="true"></MudCheckBox>
                                    <MudTooltip Text="When enabled, tariff will be calculated based on verified unloading quantities instead of loading.">
                                        <MudIcon Icon="@Icons.Material.Filled.HelpOutline" Size="Size.Small" Color="Color.Info" Class="ml-2" />
                                    </MudTooltip>
                                </div>
                            </MudItem>
                        </MudGrid>
                    </div>
                </EditForm>
            </div>
        </MudContainer>
    </DialogContent>
    <DialogActions>
        <div class="d-flex w-100 flex-wrap pa-4 gap-3 align-center">
            <MudSpacer />
            <MudButton @onclick="Cancel" Variant="Variant.Outlined" Color="Color.Default" Style="border-radius: 12px; font-weight: 700; text-transform: none; border-color: rgba(0,0,0,0.15);">Discard</MudButton>
            <MudButton Disabled="@_busy" form="tariffForm" Variant="Variant.Filled" ButtonType="ButtonType.Submit" Color="Color.Success" Style="background: var(--mud-palette-success); color: white; font-weight: 800; border-radius: 12px; text-transform: none; white-space: nowrap; padding: 8px 24px;" StartIcon="@Icons.Material.Filled.DoneAll">Synchronize Records</MudButton>
        </div>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; }

    [Parameter]
    public OrderModel Order { get; set; }

    #region Declared Properties
    [Parameter]
    public TariffModel model { get; set; }

    private string searchString = "";
    private bool _busy;

    private List<TariffFormulaModel> Formulas = new();
    private List<TariffTypeModel> TariffTypes = new();
    private List<RouteModel> Routes = new();
    #endregion

    public bool HasPermissionTariffServiceEdit { get; set; } = false;
    public int DocTypeID = 41;

    protected override async Task OnInitializedAsync()
    {
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionTariffServiceEdit = await Irole.HasClaim(DocTypeID.ToString(), "Edit", ctc.Token);

        model.Order = Order;
        Routes = await Iroute.Select(0).ToListAsync();
        Formulas = Iservice.SelectFormulas().ToList();
        TariffTypes = Iservice.SelectTariffTypes("Operation").ToList();
        model.Order = Order;
    }

    private void Cancel() => MudDialog.Cancel();

    private async Task<IEnumerable<RouteModel>> SearchRoutes(string searchString, CancellationToken token)
    {
        return await Task.FromResult(Routes.Where(x => x.RouteName.Contains(searchString == null ? string.Empty : searchString, StringComparison.InvariantCultureIgnoreCase)));
    }

    private async Task<IEnumerable<TariffTypeModel>> SearchTariffTypes(string searchString, CancellationToken token)
    {
        return await Task.FromResult(TariffTypes.Where(x => x.TariffTypeName.Contains(searchString == null ? string.Empty : searchString, StringComparison.InvariantCultureIgnoreCase)));
    }

    private async Task<IEnumerable<TariffFormulaModel>> SearchFormulas(string searchString, CancellationToken token)
    {
        return await Task.FromResult(Formulas.Where(x => x.Formula.Contains(searchString == null ? string.Empty : searchString, StringComparison.InvariantCultureIgnoreCase)));
    }

    private async Task OnValidSubmit(EditContext context)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is being submitted!", Severity.Warning);
            return;
        }
        _busy = true;
        if (HasPermissionTariffServiceEdit)
        {
            var authprov = await auth.GetAuthenticationStateAsync();
            model.UserInfo.UserID = authprov.User.Identity.Name;
            try
            {
                model = Iservice.Update(model);
                snackbar.Add("Saved Successfully", Severity.Success);
                MudDialog.Close(DialogResult.Ok(model));
                model = new TariffModel();
            }
            catch (Exception ex)
            {
                snackbar.Add(ex.Message, Severity.Warning);
            }
        }
        else
        {
            bool? ResultModel = await DialogService.ShowMessageBoxAsync(
                "Permission denied!",
                "You don't have any permission to Add or Edit Tariff.");
        }
        await Task.Delay(200);
        _busy = false;
    }
}
