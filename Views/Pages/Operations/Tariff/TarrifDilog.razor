@inject ITariffService Iservice
@inject IRouteService Iroute
@inject IOrderService Iorder

@inject IGstUsageIDService usageService
@inject MudBlazor.ISnackbar snackbar
@attribute [Authorize]
@inject AuthenticationStateProvider auth   
 

       

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">Add/Edit Tariff</MudText>
    </TitleContent>
    <DialogContent>
        <EditForm id="tariffForm" Model="@model" OnValidSubmit="OnValidSubmit" >
            <DataAnnotationsValidator />
            <ValidationSummary />           
                <MudGrid Spacing="4">
                    <MudItem xs="12" md="8">
                        <MudAutocomplete T="RouteModel" Label="Route" @bind-Value="model.Route" ResetValueOnEmptyText="true" Variant="Variant.Outlined"
                                         SearchFunc="SearchRoutes" ToStringFunc="@(e=> e==null?null : $"{e.RouteName}")"></MudAutocomplete>
                    </MudItem>
                    <MudItem xs="12" md="4">
                    <MudSelect Label="Select Type" @bind-Value="model.TariffType" ToStringFunc=@((e)=> e?.TariffTypeName) OffsetY="true" AdornmentColor="Color.Secondary" Variant="Variant.Outlined">
                            @foreach (var item in TariffTypes)
                            {
                                <MudSelectItem Value="@item">@item.TariffTypeName</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                <MudItem xs="12" md="4">
                    <MudTextField @bind-Value="model.TariffRate" Label="Tariff Rate" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.TariffRate)"></MudTextField>
                </MudItem>
                    <MudItem xs="12" md="4">
                        <MudSelect Label="Select Formula" @bind-Value="model.Formula" ToStringFunc=@((e)=> e?.Formula) OffsetY="true" Margin="Margin.Dense" AdornmentColor="Color.Secondary" Variant="Variant.Outlined">
                            @foreach (var item in Formulas)
                            {
                                <MudSelectItem Value="@item">@item.Formula</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                  
                    <MudItem xs="12" md="4">
                        <MudTextField @bind-Value="model.TruckAxles" Label="Axles Limit(if any)" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.TruckAxles)"></MudTextField>
                    </MudItem>
                </MudGrid>  
        </EditForm>
    </DialogContent>
    <DialogActions>
        <MudButton form="tariffForm" Variant="Variant.Filled" Color="Color.Success" ButtonType="ButtonType.Submit">Save Tariff</MudButton>
    </DialogActions>
</MudDialog>
          

@code {
    [Parameter]
    public OrderModel Order { get; set; }

    #region Declared Properties
    [Parameter]
    public TariffModel model { get; set; }

    private string searchString = "";    

    //private List<TariffModel> collection = new ();

    private List<TariffFormulaModel> Formulas = new ();
    private List<TariffTypeModel> TariffTypes = new ();
    private List<RouteModel> Routes = new ();    
    [CascadingParameter] MudDialogInstance MudDialog { get; set; }
    #endregion


    protected override async Task OnInitializedAsync()
    {
        Routes = await  Iroute.Select(0).ToListAsync();       
        Formulas = Iservice.SelectFormulas().ToList();            
        TariffTypes = Iservice.SelectTariffTypes("Operation").ToList();
        model.Order = Order;
        GetAll();
    }



    private async Task<IEnumerable<RouteModel>> SearchRoutes(string searchString)
    {
        return await Task.FromResult(Routes.Where(x => x.RouteName.Contains(searchString == null ? string.Empty : searchString, StringComparison.InvariantCultureIgnoreCase)));
    }

    private async Task<IEnumerable<TariffTypeModel>> SearchTariffTypes(string searchString)
    {
        return await Task.FromResult(TariffTypes.Where(x => x.TariffTypeName.Contains(searchString == null ? string.Empty : searchString, StringComparison.InvariantCultureIgnoreCase)));
    }

    private async Task<IEnumerable<TariffFormulaModel>> SearchFormulas(string searchString)
    {
        return await Task.FromResult(Formulas.Where(x => x.Formula.Contains(searchString == null ? string.Empty : searchString, StringComparison.InvariantCultureIgnoreCase)));
    }


    private void GetAll()
    {
        //collection = Iservice.SelectByOrder(Order.OrderID).ToList();       
    }

    private async Task OnValidSubmit(EditContext context)
    { 
        var authprov = await auth.GetAuthenticationStateAsync();
        model.UserInfo.UserID = authprov.User.Identity.Name;
        try
        {
            model = Iservice.Update(model);
            snackbar.Add("Saved Successfully", Severity.Success);
            MudDialog.Close(model);
            //if (collection.Exists(x => x.TariffID == model.TariffID))
            //{
            //    collection[collection.FindIndex(x => x.TariffID == model.TariffID)] = model;
            //}
            //else
            //{
            //    collection.Add(model);
            //}
            model = new TariffModel(); 
        }
        catch (Exception ex)
        {
            snackbar.Add(ex.Message, Severity.Warning);
        }
    }

}
