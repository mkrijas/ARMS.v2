@attribute [Authorize]
@inject AuthenticationStateProvider auth
@using System.Threading;
@inject ITariffService Iservice
@inject MudBlazor.ISnackbar snackbar
@inject IGstUsageIDService Igst
@inject IRoleService<RoleModel> Irole
@inject IDialogService DialogService

<MudDialog Class="admin-dialog-glass">
    <TitleContent>
        <div class="header-section mb-2 pt-4 px-4">
            <div class="d-flex align-center justify-space-between">
                <div class="d-flex align-center">
                    <div class="icon-badge primary-badge mr-4">
                        <div class="admin-header-icon-badge mb-3">
                            <MudIcon Icon="@Icons.Material.Filled.Category" Color="Color.Secondary" Style="font-size: 3rem;" />
                        </div>
                    </div>
                    <div>
                        <MudText Typo="Typo.h5" Class="admin-title"><b>Tariff Grouping & Taxonomy</b></MudText>
                        <MudText Typo="Typo.body2" Class="admin-subtitle">
                            Configure tariff classifications, nature of service, and unit metrics.
                        </MudText>
                    </div>
                </div>
            </div>
            <div class="title-accent mt-4"></div>
        </div>
    </TitleContent>
    <DialogContent>
        <MudContainer Class="admin-dialog-container">
            <div class="dialog-content-wrapper">
                <EditForm id="TarrifForm" Model="@model" OnValidSubmit="OnValidSubmit">
                    <DataAnnotationsValidator />
                    
                    <div class="admin-glass-card pa-6">
                        <div class="d-flex align-center mb-6">
                            <MudIcon Icon="@Icons.Material.Filled.DisplaySettings" Color="Color.Primary" Class="mr-2" />
                            <span class="admin-section-label mb-0">Structural Definition</span>
                        </div>
                        
                        <MudGrid Spacing="3">
                            <MudItem xs="12" md="6">
                                <MudTextField @bind-Value="@model.TariffTypeName" Label="Classification Title" Variant="Variant.Outlined" Margin="Margin.Normal" For="@(() => model.TariffTypeName)" Class="modern-input" Placeholder="Enter tariff type name..."></MudTextField>
                            </MudItem>
                            <MudItem xs="12" md="6">
                                <MudSelect For="@(() => model.TariffGroup)" Label="Nature of Service" T="string" @bind-Value="@model.TariffGroup" Variant="Variant.Outlined" Margin="Margin.Normal" AdornmentColor="Color.Secondary" Class="modern-input">
                                    @foreach (var item in Iservice.TariffGroups)
                                    {
                                        <MudSelectItem Value="@item">@item</MudSelectItem>
                                    }
                                </MudSelect>
                            </MudItem>
                            <MudItem xs="12" md="6">
                                <MudTextField @bind-Value="@model.Unit" Label="Measurement Unit" Variant="Variant.Outlined" Margin="Margin.Normal" For="@(() => model.Unit)" Class="modern-input" Placeholder="e.g., Litre, Metric Ton" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Scale"></MudTextField>
                            </MudItem>
                            <MudItem xs="12" md="6">
                                <MudAutocomplete Variant="Variant.Outlined" Margin="Margin.Normal" T="GstUsageCodeModel" Label="Regulatory Usage ID" Value="@SelectedGstCode" ValueChanged="SetUsageId" Text="@SelectedGstCode?.Description" SearchFunc="@SearchUsageIDs" Class="modern-input"
                                                 ToStringFunc="@(e => (e == null || string.IsNullOrEmpty(e.Description)) ? null : string.Format("{0} | {1}",e.UsageCode,e.Description))" ResetValueOnEmptyText=true CoerceText=true Required=true RequiredError="Usage ID is required!" />
                                <ValidationMessage For="@(()=>model.UsageCode)" />
                            </MudItem>
                            
                            <MudItem xs="12">
                                <div class="d-flex align-center py-3 px-4 rounded-lg mt-2" style="background: rgba(var(--mud-palette-primary-rgb), 0.05); border: 1px dashed rgba(var(--mud-palette-primary-rgb), 0.2);">
                                    <MudCheckBox T="bool" Value="model.GCCreation" ValueChanged="checkChanged" Label="Enable spontaneous creation during GC generation?" Color="Color.Primary" Dense="true"></MudCheckBox>
                                    <MudTooltip Text="If enabled, this tariff type can be instantiated directly while creating a Consignment.">
                                        <MudIcon Icon="@Icons.Material.Filled.AutoFixHigh" Size="Size.Small" Color="Color.Info" Class="ml-2" />
                                    </MudTooltip>
                                </div>
                            </MudItem>
                        </MudGrid>
                    </div>
                </EditForm>
            </div>
        </MudContainer>
    </DialogContent>
    <DialogActions>
        <div class="d-flex w-100 flex-wrap pa-4 gap-3 align-center">
            <MudSpacer />
            <MudButton @onclick="Cancel" Variant="Variant.Outlined" Color="Color.Default" Style="border-radius: 12px; font-weight: 700; text-transform: none; border-color: rgba(0,0,0,0.15);">Discard</MudButton>
            <MudButton Disabled="@_busy" form="TarrifForm" Variant="Variant.Filled" ButtonType="ButtonType.Submit" Color="Color.Success" Style="background: var(--mud-palette-success); color: white; font-weight: 800; border-radius: 12px; text-transform: none; white-space: nowrap; padding: 8px 24px;" StartIcon="@Icons.Material.Filled.DoneAll">Synchronize Records</MudButton>
        </div>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; }
    [Parameter]
    public TariffTypeModel model { get; set; }
    private GstUsageCodeModel SelectedGstCode { get; set; }
    private List<GstUsageCodeModel> UsageIds = new();

    private string searchString = "";
    private bool _busy;

    public bool HasPermissionTariffServiceEdit { get; set; } = false;
    public int DocTypeID = 41;

    protected override async Task OnInitializedAsync()
    {
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionTariffServiceEdit = await Irole.HasClaim(DocTypeID.ToString(), "Edit", ctc.Token);

        await GetAll();

        if (UsageIds != null && UsageIds.Any(s => s.UsageCode == model.UsageCode))
        {
            SelectedGstCode = UsageIds.FirstOrDefault(s => s.UsageCode == model.UsageCode);
        }
        else
        {
            model.UsageCode = null;
        }
    }

    private void checkChanged(bool val)
    {
        model.GCCreation = val;
    }

    private async Task GetAll()
    {
        UsageIds = Igst.Select(DateTime.Today).ToList();
    }

    private void SetUsageId(GstUsageCodeModel obj)
    {
        SelectedGstCode = obj;
        model.UsageCode = SelectedGstCode?.UsageCode ?? null;
    }

    private async Task<IEnumerable<GstUsageCodeModel>> SearchUsageIDs(string value, CancellationToken token)
    {
        // In real life use an asynchronous function for fetching data from an api.
        await Task.Delay(5, token);

        // if text is null or empty, show complete list
        if (string.IsNullOrEmpty(value))
            return UsageIds;
        //return UsageIds.Where(x => x.Contains(value, StringComparison.InvariantCultureIgnoreCase));

        return UsageIds.Where(x => (x.UsageCode + " " +
        x.Description).Contains(value == null ? string.Empty : value, StringComparison.InvariantCultureIgnoreCase)
        && x.Id != 0);
    }

    private async Task OnValidSubmit(EditContext context)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is being submitted!", Severity.Warning);
            return;
        }
        _busy = true;
        if (HasPermissionTariffServiceEdit)
        {
            var authprov = await auth.GetAuthenticationStateAsync();
            model.UserInfo.UserID = authprov.User.Identity.Name;
            try
            {
                model = Iservice.UpdateTariffType(model);
                snackbar.Add("Saved Successfully", Severity.Success);
                MudDialog.Close(DialogResult.Ok(model));
                model = new();
            }
            catch (Exception ex)
            {
                snackbar.Add(ex.Message, Severity.Warning);
            }
        }
        else
        {
            bool? ResultModel = await DialogService.ShowMessageBoxAsync(
                "Permission denied!",
                "You don't have any permission to Add or Edit Tariff.");
        }
        await Task.Delay(200);
        _busy = false;
    }

    private void Cancel() => MudDialog.Cancel();
}
