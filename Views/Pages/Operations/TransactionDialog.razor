
@inject ITransactionService Iservice
@inject ITariffService Itariff

@inject MudBlazor.ISnackbar snackbar
@attribute [Authorize]
@inject AuthenticationStateProvider auth

@using System.ComponentModel.DataAnnotations

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.Create" Class="mr-3 mb-n1" />
            INCOME AND EXPENSES
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudContainer Style="min-height:500px;max-height: 800px;">
            <div @ref="testRef" tabindex="0" @onkeydown="HandleKeyDown">

                <EditForm id="form_trans" Model="@model" OnValidSubmit="OnValidSubmit">
                    <ObjectGraphDataAnnotationsValidator />
                    <ValidationSummary />
                    <MudGrid Spacing="4">
                        @if (IsLoading)
                        {
                            <MudProgressCircular Color="Color.Primary" Style="height: 200px; width: 200px; display: block; margin: 150px auto auto auto; " Indeterminate="true" />
                        }
                        else
                        {
                            <MudItem xs="12" Class="d-flex flex-row">
                                @if (trip != null)
                                {
                                    <MudText>Trip : @(trip.TripPrefix + trip.TripNumber)  </MudText>
                                }
                                else @if (gc != null)
                           {
                            <MudText Class="px-3">Consignments : @gc.SetGcNumber  </MudText>
                        }

                                <MudText Typo="Typo.h4">@(TotalAmount?.ToString("C2"))</MudText>
                            </MudItem>

                            <MudItem xs="12">
                                @foreach (var item in model.Transactions)
                                {
                                    var adText = item.Sign == -1 ? "EXPENSE" : "INCOME";
                                    var adIcon = item.Sign == -1 ? Icons.Filled.East : Icons.Filled.West;
                                    <MudGrid Spacing="2">
                                        <MudItem xs="3">
                                            <MudSelect Label="Tariff Type" T="short?" Value="@item.TariffTypeID" ValueChanged="@((e)=>TariffChanged(e,item))" Variant="Variant.Outlined" OffsetY="true" AdornmentColor="Color.Secondary">
                                                @foreach (var tariffType in TariffTypes)
                                                {
                                                    <MudSelectItem Value="@tariffType.TariffTypeID">@tariffType.TariffTypeName</MudSelectItem>
                                                }
                                            </MudSelect>
                                        </MudItem>
                                        <MudItem xs="2">
                                            <MudTextField T="decimal?" Value="@item.Amount" ValueChanged="((e)=>AmountChanged(e,item))" Label="@adText" Variant="Variant.Outlined" InputType="InputType.Text" For="@(() => item.Amount)" Adornment="Adornment.End" AdornmentIcon="@adIcon" OnAdornmentClick="(()=> SignClick(item))" AdornmentColor="Color.Primary" />
                                        </MudItem>
                                        <MudItem xs="2">
                                            <MudTextField @bind-Value="@item.Quantity" Label="Qty" Variant="Variant.Outlined" For="@(() => item.Quantity)" Adornment="Adornment.End" AdornmentText="@item.Unit" AdornmentColor="Color.Secondary"></MudTextField>
                                        </MudItem>
                                        <MudItem xs="2">
                                            <MudDatePicker @bind-Date="@item.BillDate" Label="Bill Date" Variant="Variant.Outlined" For="@(() => item.BillDate)"></MudDatePicker>
                                        </MudItem>
                                        <MudItem xs="2">
                                            <MudTextField @bind-Value="@item.Reference" Label="reference" Variant="Variant.Outlined" For="@(() => item.Reference)"></MudTextField>
                                        </MudItem>
                                        <MudItem xs="1">
                                            <div class="pa-3">
                                                <MudIconButton Variant="Variant.Filled" Icon="@Icons.Filled.Close" Color="Color.Error" OnClick="(()=> RemoveItem(item))"></MudIconButton>
                                            </div>
                                        </MudItem>
                                    </MudGrid>
                                }
                            </MudItem>
                        }
                    </MudGrid>
                    
                </EditForm>
            </div>
        </MudContainer>
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Filled" Color="Color.Dark" StartIcon="@Icons.Material.Outlined.Add" OnClick="AddMoreRows">Add More Rows</MudButton>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton form="form_trans" Variant="Variant.Filled" Color="Color.Success" ButtonType="ButtonType.Submit">Save Entries</MudButton>
    </DialogActions>
</MudDialog>


<link href="~/style.css" />
@code {

    private ElementReference testRef;


    private void HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.CtrlKey && e.Key == "q")
        {
            model.Transactions.Add(new OpTranSubModel());
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await testRef.FocusAsync();
        }
    }

    [CascadingParameter] MudDialogInstance MudDialog { get; set; }
    [Parameter] public TripModel trip { get; set; }
    [Parameter] public GcSetModel gc { get; set; }
    [Parameter] public OperationTransactionModel model { get; set; }

    private void Cancel()
    {
        MudDialog.Cancel();
    }

    private bool IsLoading = false;

    private List<TariffTypeModel> TariffTypes = new();
    private TariffTypeModel SelectedTariff;
    private Decimal? TotalAmount;



    protected override void OnInitialized()
    {
        IsLoading = true;
        TariffTypes = Itariff.SelectTariffTypes("Operation").ToList();

        if (model == null)
        {
            model = new();
            model.Transactions.Add(new OpTranSubModel());
        }

        if (gc != null)
        {
            model.RefType = "GC";
            model.RefID = gc.GcSetID;
            GenerateEntries();
        }
        else if (trip != null)
        {
            model.RefType = "Trip";
            model.RefID = trip.TripID;
        }

        IsLoading = false;
    }
    protected override void OnParametersSet()
    {
    }

    private void SignClick(OpTranSubModel item)
    {
        item.Sign = item.Sign * -1;
    }

    private void RemoveItem(OpTranSubModel item)
    {
        model.Transactions.Remove(item);
    }

    private void TariffChanged(short? e, OpTranSubModel item)
    {
        item.TariffTypeID = e;
        item.Unit = TariffTypes.FirstOrDefault(x => x.TariffTypeID == e.GetValueOrDefault()).Unit;
        StateHasChanged();
    }

    private async Task OnValidSubmit(EditContext context)
    {
        var authprov = await auth.GetAuthenticationStateAsync();
        model.UserInfo.UserID = authprov.User.Identity.Name;
        model.BranchID = int.Parse(authprov.User.Claims.FirstOrDefault(c => c.Type == "BranchID").Value);
        model.TransactionDate = DateTime.Today;

        try
        {
            foreach (var item in model.Transactions)
            {
                if (item.TariffTypeID == 3)
                {
                    item.AmountAsPerNorms = item.Amount / item.Quantity * item.AmountAsPerNorms;
                }
            }
            model = Iservice.Update(model);
            snackbar.Add("Saved Successfully", Severity.Success);
            MudDialog.Close(DialogResult.Ok(model));
            model = new();
        }
        catch (Exception ex)
        {
            snackbar.Add(ex.Message, Severity.Warning);
        }
    }


    private void GenerateEntries()
    {
        List<TariffModel> tariffs = Itariff.GeneratePendingTariffs(gc.GcSetID).ToList();

        model.Transactions = new List<OpTranSubModel>();
        foreach (var item in tariffs)
        {
            decimal? amt = Itariff.GetTariffAmount(gc, item);
            OpTranSubModel tr = new()
            {
                Amount = amt,
                AmountAsPerNorms = amt,
                BillDate = DateTime.Today,
                Quantity = item.TariffTypeID < 3 ? gc.Gcs.Sum(x => x.BillQuantity) : null,
                Sign = item.TariffSign,
                TariffTypeID = item.TariffTypeID,
                TariffID = item.TariffID,
                Unit = item.Unit,
            };
            if (item.TariffTypeID == 3)
            {
                tr.Quantity = tr.Amount;
                tr.Amount = null;
            }
            model.Transactions.Add(tr);
        }
        TotalAmount = model.Transactions.Sum(x => x.Amount * x.Sign);
    }


    private void AddMoreRows()
    {
        int index = model.Transactions.Count - 1;
        if (index >= 0)
        {
            ValidationContext vc = new ValidationContext(model.Transactions[index]);
            ICollection<ValidationResult> results = new List<ValidationResult>();
            bool isValid = Validator.TryValidateObject(model.Transactions[index], vc, results, true);
            if (isValid)
                model.Transactions.Add(new());
        }
        else
        {
            model.Transactions.Add(new());
        }
    }


    private void AmountChanged(decimal? Amount,OpTranSubModel item)
    {
        item.Amount = Amount;
        TotalAmount = model.Transactions.Sum(x => x.Amount * x.Sign);

    }
}

