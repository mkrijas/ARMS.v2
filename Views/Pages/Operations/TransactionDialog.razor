@inject IOpTranService Iservice
@inject ITariffService Itariff

@inject MudBlazor.ISnackbar snackbar
@attribute [Authorize]
@inject AuthenticationStateProvider auth

@using System.ComponentModel.DataAnnotations

<MudDialog Class="admin-dialog-glass">
    <TitleContent>
        <div class="header-section mb-2 pt-4 px-4">
            <div class="d-flex align-center justify-space-between">
                <div class="d-flex align-center">
                    <div class="icon-badge primary-badge mr-4">
                        <div class="admin-header-icon-badge mb-3">
                            <MudIcon Icon="@Icons.Material.Filled.Create" Color="Color.Secondary" Style="font-size: 3rem;" />
                        </div>
                    </div>
                    <div>
                        <div class="d-flex align-center gap-2">
                            <MudText Typo="Typo.h5" Class="admin-title"><b>Income and Expenses</b></MudText>
                            <MudChip Color="Color.Primary" Variant="Variant.Text" Size="Size.Small" Class="ml-2"><b>@(trip != null ? trip.TripPrefix + trip.TripNumber : gc != null ? gc.SetGcNumber : jobcard != null ? jobcard.JobcardNumber : "")</b></MudChip>
                        </div>
                        <MudText Typo="Typo.body2" Class="admin-subtitle">
                            Track trip-related financial transactions with precision.
                        </MudText>
                    </div>
                </div>
                <div class="d-flex flex-column align-end">
                    <MudText Typo="Typo.caption" Class="admin-subtitle">TOTAL VALUE</MudText>
                    <MudText Typo="Typo.h4" Color="Color.Primary"><b>@(TotalAmount?.ToString("C2") ?? "₹0.00")</b></MudText>
                </div>
            </div>
            <div class="title-accent mt-4"></div>
        </div>
    </TitleContent>
    <DialogContent>
        <MudContainer Class="admin-dialog-container">
            <div class="dialog-content-wrapper">
                <div @ref="testRef" tabindex="0" @onkeydown="HandleKeyDown">
                    <EditForm id="form_trans" Model="@model" OnValidSubmit="OnValidSubmit">
                        <ObjectGraphDataAnnotationsValidator />
                        <ValidationSummary />
                        <MudGrid Spacing="4">
                            @if (_isLoading)
                            {
                                <MudItem xs="12">
                                    <div @key="@("loader")" style="display: flex; justify-content: center; align-items: center; min-height: 200px;">
                                        <LoaderComponent IsFullScreen="false" 
                                                        ShowLogo="false" 
                                                        Size="medium" 
                                                        LoadingText="Loading Transaction" 
                                                        SubText="Please wait..." />
                                    </div>
                                </MudItem>
                            }
                            else
                            {
                                <MudItem xs="12" @key="@("transactions")">
                                    @foreach (var item in model.Transactions)
                                    {
                                        var adText = item.Sign == -1 ? "EXPENSE" : "INCOME";
                                        var adIcon = item.Sign == -1 ? Icons.Filled.East : Icons.Filled.West;
                                        <div class="admin-glass-card pa-4 mb-4" style="border: 1px solid rgba(54, 117, 136, 0.3);">
                                            <MudGrid Spacing="2" Class="align-center">
                                                <MudItem xs="3">
                                                    <MudSelect For="@(() => item.TariffTypeID)" Label="Tariff Type" T="short?" Value="@item.TariffTypeID" ValueChanged="@((e)=>TariffChanged(e,item))" Variant="Variant.Outlined" OffsetY="true" AdornmentColor="Color.Secondary" Class="modern-input">
                                                        @foreach (var tariffType in TariffTypes)
                                                        {
                                                            <MudSelectItem Value="@tariffType.TariffTypeID">@tariffType.TariffTypeName</MudSelectItem>
                                                        }
                                                    </MudSelect>
                                                </MudItem>
                                                <MudItem xs="2">
                                                    <MudTextField T="decimal?" Value="@item.Amount" ValueChanged="((e)=>AmountChanged(e,item))" Label="@adText" Variant="Variant.Outlined" InputType="InputType.Text" For="@(() => item.Amount)" Adornment="Adornment.End" AdornmentIcon="@adIcon" OnAdornmentClick="(()=> SignClick(item))" AdornmentColor="Color.Primary" Class="modern-input" />
                                                </MudItem>
                                                <MudItem xs="2">
                                                    <MudTextField @bind-Value="@item.Quantity" Label="Qty" Variant="Variant.Outlined" For="@(() => item.Quantity)" Adornment="Adornment.End" AdornmentText="@item.Unit" AdornmentColor="Color.Secondary" Class="modern-input"></MudTextField>
                                                </MudItem>
                                                <MudItem xs="2">
                                                    <MudDatePicker @bind-Date="@item.BillDate" Label="Bill Date" Variant="Variant.Outlined" For="@(() => item.BillDate)" Class="modern-input"></MudDatePicker>
                                                </MudItem>
                                                <MudItem xs="2">
                                                    <MudTextField @bind-Value="@item.Reference" Label="Reference" Variant="Variant.Outlined" For="@(() => item.Reference)" Class="modern-input"></MudTextField>
                                                </MudItem>
                                                <MudItem xs="1">
                                                    <div class="pa-1">
                                                        <MudIconButton Variant="Variant.Filled" Icon="@Icons.Filled.Close" Color="Color.Error" OnClick="(()=> RemoveItem(item))" Size="Size.Small" Class="rounded-lg"></MudIconButton>
                                                    </div>
                                                </MudItem>
                                            </MudGrid>
                                        </div>
                                    }
                                </MudItem>
                            }
                        </MudGrid>
                    </EditForm>
                </div>
            </div>
        </MudContainer>
    </DialogContent>
    <DialogActions>
        <div class="d-flex pa-4 gap-4 w-100 align-center">
            <MudButton Variant="Variant.Outlined" Color="Color.Primary" StartIcon="@Icons.Material.Outlined.Add" OnClick="AddMoreRows" Class="rounded-pill px-6">Add More Rows</MudButton>
            <MudSpacer />
            <MudButton OnClick="Cancel" Variant="Variant.Text" Class="px-6">Discard</MudButton>
            <MudButton form="form_trans" Variant="Variant.Filled" Color="Color.Primary" ButtonType="ButtonType.Submit" Class="action-btn-primary px-10 rounded-pill" Style="background: var(--mud-palette-primary) !important; color: white !important;">Save Entries</MudButton>
        </div>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; }
    private bool _busy = false;
    private bool _isLoading = false;

    private ElementReference testRef;


    private void HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.CtrlKey && e.Key == "q")
        {
            model.Transactions.Add(new OpTranSubModel());
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await testRef.FocusAsync();
        }
    }

    [Parameter] public TripModel trip { get; set; }
    [Parameter] public GcSetModel gc { get; set; }
    [Parameter] public JobcardModel jobcard { get; set; }
    [Parameter] public OpTranModel model { get; set; }

    private void Cancel()
    {
        MudDialog.Cancel();
    }

    private bool IsLoading = false;

    private List<TariffTypeModel> TariffTypes = new();
    private TariffTypeModel SelectedTariff;
    private Decimal? TotalAmount;

    private string Area;



    protected override void OnInitialized()
    {
        IsLoading = true;


        if (model == null)
        {
            model = new();
            model.Transactions.Add(new OpTranSubModel());
        }

        if (gc != null)
        {
            model.RefType = "GC";
            model.RefID = gc.GcSetID;
            GenerateEntries();
            Area = "Operation";
        }
        else if (trip != null)
        {
            model.RefType = "Trip";
            model.RefID = trip.TripID;
            Area = "Operation";
        }
        else if (jobcard != null)
        {
            model.RefType = "Jobcard";
            model.RefID = jobcard.JobcardID;
            Area = "Maintenance";
        }
        TariffTypes = Itariff.SelectTariffTypes(Area).ToList();

        IsLoading = false;
    }
    protected override void OnParametersSet()
    {
    }

    private void SignClick(OpTranSubModel item)
    {
        item.Sign = item.Sign * -1;
    }

    private void RemoveItem(OpTranSubModel item)
    {
        model.Transactions.Remove(item);
    }

    private void TariffChanged(short? e, OpTranSubModel item)
    {
        item.TariffTypeID = e;
        item.Unit = TariffTypes.FirstOrDefault(x => x.TariffTypeID == e.GetValueOrDefault()).Unit;
        StateHasChanged();
    }

    private async Task OnValidSubmit(EditContext context)
    {
        var authprov = await auth.GetAuthenticationStateAsync();
        model.UserInfo.UserID = authprov.User.Identity.Name;
        model.BranchID = int.Parse(authprov.User.Claims.FirstOrDefault(c => c.Type == "BranchID").Value);
        model.TransactionDate = DateTime.Today;

        try
        {
            foreach (var item in model.Transactions)
            {
                if (item.TariffTypeID == 3)
                {
                    item.AmountAsPerNorms = item.Amount / item.Quantity * item.AmountAsPerNorms;
                }
            }
            model = Iservice.Update(model);
            snackbar.Add("Saved Successfully", Severity.Success);
            MudDialog.Close(DialogResult.Ok(model));
            model = new();
        }
        catch (Exception ex)
        {
            snackbar.Add(ex.Message, Severity.Warning);
        }
    }


    private void GenerateEntries()
    {
        List<TariffModel> tariffs = Itariff.GeneratePendingTariffs(gc.GcSetID).ToList();

        model.Transactions = new List<OpTranSubModel>();
        foreach (var item in tariffs)
        {
            decimal? amt = Itariff.GetTariffAmount(gc, item);
            OpTranSubModel tr = new()
                {
                    Amount = amt,
                    AmountAsPerNorms = amt,
                    BillDate = DateTime.Today,
                    Quantity = item.TariffTypeID < 3 ? gc.Gcs.Sum(x => x.BillQuantity) : null,
                    Sign = item.TariffSign,
                    TariffTypeID = item.TariffTypeID,
                    TariffID = item.TariffID,
                    Unit = item.Unit,
                };
            if (item.TariffTypeID == 3)
            {
                tr.Quantity = tr.Amount;
                tr.Amount = null;
            }
            model.Transactions.Add(tr);
        }
        TotalAmount = model.Transactions.Sum(x => x.Amount * x.Sign);
    }


    private void AddMoreRows()
    {
        int index = model.Transactions.Count - 1;
        if (index >= 0)
        {
            ValidationContext vc = new ValidationContext(model.Transactions[index]);
            ICollection<ValidationResult> results = new List<ValidationResult>();
            bool isValid = Validator.TryValidateObject(model.Transactions[index], vc, results, true);
            if (isValid)
                model.Transactions.Add(new());
        }
        else
        {
            model.Transactions.Add(new());
        }
    }


    private void AmountChanged(decimal? Amount, OpTranSubModel item)
    {
        item.Amount = Amount;
        TotalAmount = model.Transactions.Sum(x => x.Amount * x.Sign);

    }
}

