@inject IOpTranService Itransaction
@inject ITariffService Itariff

@inject IDialogService DialogService

<div class="d-flex flex-column gap-6">
    @foreach (var item in Transactions)
    {
        <div class="admin-glass-card pa-0 overflow-hidden">
            <div class="pa-4 d-flex align-center justify-space-between" style="background: rgba(var(--mud-palette-primary-rgb), 0.04); border-bottom: 1px solid rgba(0,0,0,0.05);">
                <div class="d-flex align-center gap-3">
                    <div class="pa-2 rounded-lg bg-primary-light">
                        <MudIcon Icon="@(Trip != null ? Icons.Material.Filled.LocalShipping : Icons.Material.Filled.Build)" Color="Color.Primary" Size="Size.Small" />
                    </div>
                    <div>
                        <MudText Typo="Typo.subtitle1" Class="admin-title mb-0" Style="font-size: 1.1rem;">
                            @(Trip != null ? $"Expedition {Trip.TripPrefix}{Trip.TripNumber}" : $"Jobcard {Jobcard.JobcardNumber}")
                        </MudText>
                        <MudText Typo="Typo.caption" Class="admin-td-secondary">Transaction Date: @item.TransactionDate?.ToString("dd MMM yyyy")</MudText>
                    </div>
                </div>
                <MudTooltip Text="Edit Statement">
                    <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Primary" OnClick="(()=>EditTransaction(item))" Size="Size.Small" Variant="Variant.Outlined" />
                </MudTooltip>
            </div>

            <MudSimpleTable Dense="true" Hover="true" Elevation="0" Class="modern-admin-table mb-0">
                <thead>
                    <tr>
                        <th class="admin-header-text">COST CENTER / HEAD</th>
                        <th class="admin-header-text">QUANTITY</th>
                        <th class="admin-header-text">NORMATIVE AMT</th>
                        <th class="admin-header-text">ACTUAL INCURRED</th>
                        <th class="admin-header-text text-right">VARIANCE</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var sub in item.Transactions)
                    {
                        var variance = (sub.Amount ?? 0) - (sub.AmountAsPerNorms ?? 0);
                        <tr>
                            <td><MudText Typo="Typo.body2" Class="admin-td-primary">@(TariffTypes.FirstOrDefault(x => x.TariffTypeID == sub.TariffTypeID)?.TariffTypeName ?? "Unknown Head")</MudText></td>
                            <td>@sub.Quantity @sub.Unit</td>
                            <td><MudText Typo="Typo.body2" Class="admin-td-secondary">@sub.AmountAsPerNorms?.ToString("N2")</MudText></td>
                            <td><MudText Typo="Typo.body2" Class="admin-td-amount">@((sub.Sign * sub.Amount)?.ToString("N2"))</MudText></td>
                            <td class="text-right">
                                <MudText Typo="Typo.body2" Color="@(variance > 0 ? Color.Error : Color.Success)" Style="font-weight: 600;">
                                    @(variance > 0 ? "+" : "")@variance.ToString("N2")
                                </MudText>
                            </td>
                        </tr>
                    }
                </tbody>
            </MudSimpleTable>
        </div>
    }
</div>

@code {

    [Parameter]
    public TripModel Trip { get; set; }
    private TripModel _trip;

    [Parameter]
    public JobcardModel Jobcard { get; set; }
    private JobcardModel _jobcard;

    private List<OpTranModel> Transactions = new();
    private List<TariffTypeModel> TariffTypes = new();


    protected async override Task OnInitializedAsync()
    {
        TariffTypes = Itariff.SelectTariffTypes("All").ToList();
    }


    protected async override Task OnParametersSetAsync()
    {
        if (_trip?.TripID != Trip?.TripID || _jobcard?.JobcardID!= Jobcard?.JobcardID)
        {
            _trip = new TripModel { TripID = Trip?.TripID };
            _jobcard = new JobcardModel { JobcardID = Jobcard?.JobcardID };
            Refresh();
        }
    }


    public void Refresh()
    {
        if (Trip != null)
        {
            Transactions = Itransaction.SelectByTrip(Trip?.TripID).ToList();
        }
        else if (Jobcard != null)
        {
            Transactions = Itransaction.SelectByJobcard(Jobcard?.JobcardID).ToList();
        }
        else
        {
            Transactions = new();
        }
    }

    private async Task EditTransaction(OpTranModel item)
    {
        var parameters = new DialogParameters();
        parameters.Add("model", item);
        if(Trip!= null)
            parameters.Add("Trip", Trip);
        if(Jobcard != null)
            parameters.Add("Jobcard", Jobcard);
        DialogOptions maxWidth = new DialogOptions() { MaxWidth = MaxWidth.Large, FullWidth = true };
        var dialog = await DialogService.ShowAsync<TransactionDialog>("Inc/Exp", parameters, maxWidth);
        var result = await dialog.Result;
        var ev = result.Data;
        if (!result.Canceled)
        {
            Refresh();
        }
    }

}
