@attribute [Authorize]
@using System.Threading;

@inject MudBlazor.ISnackbar snackbar
@inject AuthenticationStateProvider auth
@inject IRoleService<RoleModel> Irole
@inject IDialogService DialogService
@inject ITripAdvanceService Iadvance
@inject IConfigTable config
@inject IGstUsageIDService usage

<MudDialog Class="admin-dialog-glass">
    <TitleContent>
        <div class="header-section mb-2 pt-4 px-4">
            <div class="d-flex align-center justify-space-between">
                <div class="d-flex align-center">
                    <div class="icon-badge primary-badge mr-4">
                        <div class="admin-header-icon-badge mb-3">
                            <MudIcon Icon="@Icons.Material.Filled.Payments" Color="Color.Secondary" Style="font-size: 3rem;" />
                        </div>
                    </div>
                    <div>
                        <MudText Typo="Typo.h5" Class="admin-title"><b>Trip Advance Payment</b></MudText>
                        <MudText Typo="Typo.body2" Class="admin-subtitle">
                            Issue operational advances for trip manifests with secure payment account mapping.
                        </MudText>
                    </div>
                </div>
            </div>
            <div class="title-accent mt-4"></div>
        </div>
    </TitleContent>
    <DialogContent>
        <MudContainer Class="admin-dialog-container">
            <div class="dialog-content-wrapper pa-2">
                @if (model.BranchID.HasValue)
                {
                    <div class="d-flex align-center mb-6 pa-4 rounded-lg" style="background: rgba(54, 117, 136, 0.05); border-left: 4px solid #367588;">
                        <div class="mr-6">
                            <MudText Typo="Typo.caption" Class="admin-subtitle">Trip Manifest</MudText>
                            <MudText Typo="Typo.h6"><b>@(Trip != null ? Trip.TripNumberDisplay : "N/A")</b></MudText>
                        </div>
                        <MudDivider Vertical="true" FlexItem="true" Class="mx-2" />
                        <div class="ml-6">
                            <MudText Typo="Typo.caption" Class="admin-subtitle">Assigned Driver</MudText>
                            <div class="d-flex align-center">
                                <MudIcon Icon="@Icons.Material.Filled.AirlineSeatReclineNormal" Size="Size.Small" Color="Color.Primary" Class="mr-1" />
                                <MudText Typo="Typo.h6"><b>@AssignedDriver.DriverName</b></MudText>
                            </div>
                        </div>
                    </div>

                    <EditForm id="AdvancePayForm" Model="@model" OnValidSubmit="OnValidSubmit">
                        <div class="mt-2">
                            <MudGrid Spacing="3">
                                <MudItem xs="12" md="4">
                                    <MudDatePicker Label="Payment Date" Variant="Variant.Outlined" Margin="Margin.Dense" DisableToolbar="true" Editable="true" @bind-Date="model.Docdate" DateFormat="dd/MM/yyyy" MaxDate="DateTime.Now" Class="modern-input" />
                                </MudItem>
                                <MudItem xs="12" md="4">
                                    <CostCenterSelector For="@(() => model.CostCenter)" @bind-Value="model.CostCenter" @bind-ValueText="@model.CostCenterVal" ReadOnly="@ReadOnly" Class="modern-input" />
                                </MudItem>
                                <MudItem xs="12" md="4">
                                    <DimensionSelector For="@(() => model.Dimension)" @bind-Value="model.Dimension" @bind-ValueText="@model.DimensionVal" ReadOnly="@ReadOnly" Class="modern-input" />
                                </MudItem>
                                <MudItem xs="12">
                                    <PaymentAccountSelector BranchID="@(model.BranchID ?? 0)" PaymentMode="@model.PaymentMode" PaymentModeChanged="OnChangePaymentMode" @bind-ArdCode="@model.PaymentArdCode" @bind-CoaID="@model.PaymentCoaID" BankCharges="@model.BankCharges" @bind-BankTool="@model.PaymentTool" BankChargesChanged="CalculateTotalAmount" Class="modern-input" />
                                    <ValidationMessage For="@(() => model.PaymentArdCode)">Please select Payment Account</ValidationMessage>
                                </MudItem>
                                <MudItem xs="12" md="6">
                                    <MudNumericField HideSpinButtons @bind-Value="model.Amount" Label="Advance Amount" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.Amount)" Required Class="modern-input" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.CurrencyRupee"></MudNumericField>
                                </MudItem>
                                <MudItem xs="12" md="6">
                                    <MudTextField @bind-Value="model.Reference" Label="Transaction Reference" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.Reference)" Class="modern-input"></MudTextField>
                                </MudItem>
                            </MudGrid>
                        </div>
                    </EditForm>
                }
                else
                {
                    <div class="d-flex justify-center align-center pa-12">
                        <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Large" />
                        <MudText Class="ml-4 admin-subtitle">Synchronizing branch data...</MudText>
                    </div>
                }
            </div>
        </MudContainer>
    </DialogContent>
    <DialogActions>
        <div class="d-flex w-100 flex-wrap pa-4 gap-3 align-center">
            <MudSpacer />
            <MudButton @onclick="Cancel" Variant="Variant.Outlined" Color="Color.Default" Style="border-radius: 12px; font-weight: 700; text-transform: none; border-color: rgba(0,0,0,0.15);">Discard</MudButton>
            <MudButton Disabled="@_busy" form="AdvancePayForm" Variant="Variant.Filled" ButtonType="ButtonType.Submit" Color="Color.Success" Style="background: var(--mud-palette-success); color: white; font-weight: 800; border-radius: 12px; text-transform: none; white-space: nowrap; padding: 8px 24px;" StartIcon="@Icons.Material.Filled.DoneAll">Release Funds</MudButton>
        </div>
    </DialogActions>
</MudDialog>

 @code {
    [Parameter]
    public bool ReadOnly { get; set; }
    [Parameter]
    public TripModel Trip { get; set; }
    [Parameter]
    public TruckModel Truck { get; set; }
    [Parameter]
    public DriverModel AssignedDriver { get; set; }
    private TripAdvanceModel model { get; set; } = new();
    private EditContext editContext;
    [CascadingParameter] 
    IMudDialogInstance MudDialog { get; set; }
    private GstUsageCodeModel UsageCodeModel { get; set; }
    private bool _busy;
    public bool HasPermissionSundryPaymentServiceEdit { get; set; } = false;
    int SundryPaymentDocTypeID = 11;

    protected override async Task OnInitializedAsync()
    {
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionSundryPaymentServiceEdit = await Irole.HasClaim(SundryPaymentDocTypeID.ToString(), "Edit", ctc.Token);

        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;      

        model = new()
        {
            BranchID = int.Parse(authprov.User.Claims.First(x => x.Type == "BranchID").Value),
            UserInfo = new ArmsModels.SharedModels.UserInfoModel
            {
                UserID = user.Identity.Name
            },
            Reference = Trip.TripNumberDisplay.ToString() + " Advance"
        };
    }

    public void OnChangePaymentMode(string? val)
    {
        model.PaymentMode = val;
        CalculateTotalAmount(model.BankCharges);
    }

    // Method to calculate the total amount based on bank charges
    public void CalculateTotalAmount(decimal? val)
    {
        model.BankCharges = val;
        if (model.PaymentMode != null)
        {
            if (model.PaymentMode.ToLower().Trim() == ("Bank").ToLower().Trim())
            {
                model.Amount += model?.BankCharges ?? 0;
            }
        }
        else
        {
            snackbar.Add("PaymentMode is not selected !", Severity.Warning);
        }
    }

    public async Task OnValidSubmit(EditContext context)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is being submitted!", Severity.Warning);
            return;
        }
        _busy = true;
        if (HasPermissionSundryPaymentServiceEdit)
        {
            try
            {
                ConfigModel cModel = config.GetTripAdvanceUsageCode();
                UsageCodeModel = usage.SelectByCode(cModel.ValueString);

                // BranchID = BranchID;
                model.TripID = Trip.TripID;
                model.DriverID = AssignedDriver.DriverID;            
                model.CoaID = UsageCodeModel.CoaID;
                model.UsageCode = (cModel.ValueString);
                model.DocumentTypeID = SundryPaymentDocTypeID;
                // DocumentID = sundryPayment.SundryPaymentID,
                model.DocType = "Trip";
                       
                model = Iadvance.Update(model);
                snackbar.Add("Saved Successfully", Severity.Success);
            
                MudDialog.Close(model);
            }
            catch (Exception ex)
            {
                snackbar.Add(ex.Message, Severity.Error);
            }
       
            await Task.Delay(200);
            _busy = false;
        }
        else
        {
            bool? ResultModel = await DialogService.ShowMessageBoxAsync(
                "Permission denied!",
                "You don't have any permission to Add or Edit Sundry Payment.");
        }
    }

    private void Cancel()
    {
        MudDialog.Cancel();
    }
}
