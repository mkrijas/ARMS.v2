    private decimal? FrieghtAmount { get; set; } = 0;
    private decimal? TotalExpense { get; set; } = 0;
    //End
    //tripINfo
    private List<TripInfoModel> TripInfoList = new List<TripInfoModel>();
    private TripInfoModel TripInfoMdl = new();
