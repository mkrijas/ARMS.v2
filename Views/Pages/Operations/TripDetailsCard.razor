            <MudTabPanel ToolTip="Mileage Shortage Receipt" Icon="@Icons.Material.Filled.ReceiptLong" OnClick="MileageTabSelected">
                <div class="TabStyle">
                    <MudList Style="width:700px">
                        @if (MileageList.Count > 0)
                        {
                            <MudGrid>
                                <MudItem md="6">
                                    <MudListItem >
                                        Document Number : <b>@MileageList[0].DocumentNumber</b>
                                    </MudListItem>
                                    <MudListItem >
                                        Running Km : <b>@MileageList[0].RunningKM</b>
                                    </MudListItem>
                                    <MudListItem >
                                        Consumed Fuel :<b>@MileageList[0].ConsumedFuel</b>
                                    </MudListItem>
                                    <MudListItem >
                                        Allotted Mileage :<b>@MileageList[0].AllottedMileage</b>
