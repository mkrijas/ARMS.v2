@using System.Threading;
@using Core.BaseModels.Finance.Transactions;
@using Views.Pages.Operations.Gc
@using Pages.Operations.Expenses
@attribute [Authorize]
@inject AuthenticationStateProvider auth
@inject IOpTranService Iservice
@inject ITripService tripIservice
@inject ITripFuelService tripFuelIservice
@inject ICostCenterService costIservice
@inject IGstUsageIDService usageIservice
@inject IDimensionService dimensionIservice
@inject MudBlazor.ISnackbar snackbar
@inject ITdsRateService tdsIService
@inject IChartOfAccountService accountService
@inject IBranchService brIservice
@inject IDialogService DialogService
@inject IInventoryItemService itemIservice
@inject IInventoryItemService IsInvService
@inject IEventService Ievent
@inject ITruckService Itruck
@inject IDriverService Idriver
@inject IGcService Igc
@inject IRoleService<RoleModel> Irole
@inject IMileageShortageReceiptService IMileageService

<div class="admin-glass-card overflow-hidden" style="min-height: 600px;">
    <div class="admin-header-tiered pa-6 pb-4">
        <div class="d-flex align-center justify-space-between">
            <div class="d-flex align-center">
                <div class="mr-4 pa-3 rounded-lg" style="background: rgba(var(--mud-palette-primary-rgb), 0.1);">
                    <MudIcon Icon="@Icons.Material.Filled.Route" Color="Color.Primary" Size="Size.Large" />
                </div>
                <div>
                    <MudText Typo="Typo.h5" Class="admin-title">@(Trip != null ? Trip.TripNumberDisplay : "Trip Details")</MudText>
                    <div class="d-flex align-center mt-1">
                        <MudSwitch Value="@IsLocked" ValueChanged="((bool value)=>TripLocked(value))" Color="Color.Error" Label="Trip Locked" Dense="true" Size="Size.Small" Class="mr-4" />
                        <MudSwitch Value="@IsMileageOverride" ValueChanged="((bool value)=>OverrideMileageShortage(value))" Color="Color.Error" Label="Override Mileage Shortage" Dense="true" Size="Size.Small" />
                    </div>
                </div>
            </div>
            <div class="d-flex gap-2">
                <MudTooltip Text="Add Fuel">
                    <MudIconButton Icon="@Icons.Material.Filled.LocalGasStation" Disabled="@IsLocked" Size="Size.Medium" Color="Color.Primary" Variant="Variant.Outlined" OnClick="@(()=> OpenFuelForm())" />
                </MudTooltip>
                <MudTooltip Text="Add Expenses">
                    <MudIconButton Icon="@Icons.Material.Filled.ReceiptLong" Disabled="@IsLocked" Color="Color.Primary" Size="Size.Medium" Variant="Variant.Outlined" OnClick="@(()=> OpenExpenseForm())" />
                </MudTooltip>
                <MudTooltip Text="Mileage Shortage Rct">
                    <MudIconButton Icon="@Icons.Material.Filled.Payments" Disabled="@IsLocked" Color="Color.Primary" Size="Size.Medium" Variant="Variant.Outlined" OnClick="@(()=> OpenMileageShortageReceipt())" />
                </MudTooltip>
                <MudTooltip Text="Update Unloading Qty">
                    <MudIconButton Icon="@Icons.Material.Filled.Scale" Disabled="@IsLocked" Size="Size.Medium" Color="Color.Primary" Variant="Variant.Outlined" OnClick="@(()=> UpdateUnloadingQty())" />
                </MudTooltip>
            </div>
        </div>
    </div>

    <div class="pa-4">
        <MudTabs Rounded="true" Elevation="0" ApplyEffectsToContainer="true" Class="premium-tabs" ActiveTabClass="premium-tab-active" Position="Position.Top">
            <MudTabPanel Text="Overview" Icon="@Icons.Material.Filled.Dashboard" Class="pa-4">
                <div class="pa-4">
                    <MudGrid Spacing="3">
                        <MudItem xs="12" md="6">
                            <div class="admin-glass-card pa-4" style="border-left: 4px solid var(--mud-palette-primary);">
                                <div class="d-flex align-center mb-4">
                                    <MudIcon Icon="@Icons.Material.Filled.Person" Color="Color.Primary" Class="mr-2" />
                                    <MudText Typo="Typo.subtitle2" Class="admin-subtitle">Operational Personnel</MudText>
                                </div>
                                <div class="mb-3">
                                    <MudText Typo="Typo.caption" Class="opacity-60">Designated Driver</MudText>
                                    <MudText Typo="Typo.body1" Class="fw-600 mt-n1">@TripInfoMdl?.Driver</MudText>
                                </div>
                                <div class="mb-3">
                                    <MudText Typo="Typo.caption" Class="opacity-60">Expedition Commencement</MudText>
                                    <MudText Typo="Typo.body1" Class="fw-600 mt-n1">@Trip?.TripDate?.ToString("dd MMM yyyy")</MudText>
                                </div>
                            </div>
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <div class="admin-glass-card pa-4" style="border-left: 4px solid var(--mud-palette-secondary);">
                                <div class="d-flex align-center mb-4">
                                    <MudIcon Icon="@Icons.Material.Filled.LocalShipping" Color="Color.Secondary" Class="mr-2" />
                                    <MudText Typo="Typo.subtitle2" Class="admin-subtitle">Asset Performance</MudText>
                                </div>
                                <div class="mb-3">
                                    <MudText Typo="Typo.caption" Class="opacity-60">Vehicle Asset</MudText>
                                    <MudText Typo="Typo.body1" Class="fw-600 mt-n1">@TripInfoMdl?.Truck</MudText>
                                </div>
                                <div class="mb-3">
                                    <MudText Typo="Typo.caption" Class="opacity-60">Total Running KM</MudText>
                                    <MudText Typo="Typo.body1" Class="fw-600 mt-n1 text-primary">@TripInfoMdl?.RunKM km</MudText>
                                </div>
                            </div>
                        </MudItem>
                        <MudItem xs="12">
                            <div class="admin-glass-card pa-4">
                                <MudGrid Spacing="4">
                                    <MudItem xs="6" md="3">
                                        <MudText Typo="Typo.caption" Class="admin-subtitle">FUEL CONSUMPTION</MudText>
                                        <MudText Typo="Typo.h6" Class="fw-700">@TripInfoMdl?.Fuel Ltrs</MudText>
                                    </MudItem>
                                    <MudItem xs="6" md="3">
                                        <MudText Typo="Typo.caption" Class="admin-subtitle">TRIP MILEAGE</MudText>
                                        <MudText Typo="Typo.h6" Class="fw-700 text-success">@TripInfoMdl?.Mileage km/l</MudText>
                                    </MudItem>
                                    <MudItem xs="6" md="3">
                                        <MudText Typo="Typo.caption" Class="admin-subtitle">TOTAL EXPENSES</MudText>
                                        <MudText Typo="Typo.h6" Class="fw-700 text-error">@(TripInfoMdl?.Expenses?.ToString("C0") ?? "0")</MudText>
                                    </MudItem>
                                    <MudItem xs="6" md="3">
                                        <MudText Typo="Typo.caption" Class="admin-subtitle">TOTAL FREIGHT</MudText>
                                        <MudText Typo="Typo.h6" Class="fw-700 text-primary">@(TripInfoMdl?.Freight?.ToString("C0") ?? "0")</MudText>
                                    </MudItem>
                                </MudGrid>
                            </div>
                        </MudItem>
                    </MudGrid>
                </div>
            </MudTabPanel>
            <MudTabPanel Text="Events" Icon="@Icons.Material.Filled.History" OnClick="EventTabSelected">
                <div class="pa-4">
                    @if (IsEventSelected)
                    {
                        <TripEventsComponent Trip="@Trip" IsLocked="@IsLocked"></TripEventsComponent>
                    }
                </div>
            </MudTabPanel>
            <MudTabPanel Text="Consignments" OnClick="GcTabSelected" Icon="@Icons.Material.Filled.Inventory2">
                <div class="pa-4">
                    @if (AssignedGCs != null && AssignedGCs.Count > 0)
                    {
                        <MudGrid Spacing="3">
                            @foreach (var gc in AssignedGCs)
                            {
                                <MudItem xs="12" md="6">
                                    <GcItemCard item="gc" Style="border: 1px solid var(--mud-palette-divider);" IsLocked="@IsLocked"></GcItemCard>
                                </MudItem>
                            }
                        </MudGrid>
                    }
                    else
                    {
                        <div class="d-flex flex-column align-center justify-center py-12 opacity-50">
                            <MudIcon Icon="@Icons.Material.Filled.Inventory2" Size="Size.Large" Class="mb-4" />
                            <MudText Typo="Typo.h6">No consignments recorded for this mission.</MudText>
                        </div>
                    }
                </div>
            </MudTabPanel>
            <MudTabPanel Text="Freight" Icon="@Icons.Material.Filled.CurrencyExchange" OnClick="FreightTabSelected">
                <div class="pa-0">
                    @if (TarifList != null && TarifList.Count > 0)
                    {
                        <MudTable Items="@TarifList" Dense="true" Hover="true" Elevation="0" Class="modern-admin-table">
                            <HeaderContent>
                                <MudTh><span class="admin-header-text">GC NUMBER</span></MudTh>
                                <MudTh><span class="admin-header-text">TARIFF TYPE</span></MudTh>
                                <MudTh Style="text-align: right;"><span class="admin-header-text">AMOUNT</span></MudTh>
                            </HeaderContent>
                            <RowTemplate>
                                <MudTd DataLabel="Gc Number"><span class="admin-td-primary fw-600">@context.GcNumber</span></MudTd>
                                <MudTd DataLabel="Tariff Type Name">@context.TariffTypeName</MudTd>
                                <MudTd DataLabel="Amount" Style="text-align: right;"><span class="admin-td-amount">@(context.Amount?.ToString("N2") ?? "0.00")</span></MudTd>
                            </RowTemplate>
                        </MudTable>
                    }
                    else
                    {
                        <div class="d-flex flex-column align-center justify-center py-12 opacity-50">
                            <MudIcon Icon="@Icons.Material.Filled.CurrencyExchange" Size="Size.Large" Class="mb-4" />
                            <MudText Typo="Typo.h6">No freight tariffs recorded for this mission.</MudText>
                        </div>
                    }
                </div>
            </MudTabPanel>
            <MudTabPanel Text="Expenses" Icon="@Icons.Material.Filled.Receipt" OnClick="ExpenseTabSelected">
                <div class="pa-0">
                    @if (OptranList != null && OptranList.Count > 0)
                    {
                        <MudTable Elevation="0" Items="@OptranList" Dense="true" Hover="true" Class="modern-admin-table">
                            <HeaderContent>
                                <MudTh><span class="admin-header-text">DOC NO</span></MudTh>
                                <MudTh><span class="admin-header-text">OPERATION HEAD</span></MudTh>
                                <MudTh><span class="admin-header-text">REFERENCE</span></MudTh>
                                <MudTh Style="text-align: right;"><span class="admin-header-text">AMOUNT</span></MudTh>
                                <MudTh Style="text-align: right;"><span class="admin-header-text">ACTIONS</span></MudTh>
                            </HeaderContent>
                            <RowTemplate>
                                <MudTd DataLabel="DocNo">@context.DocNo</MudTd>
                                <MudTd DataLabel="ExpenseTitle">@context.ExpenseTitle</MudTd>
                                <MudTd DataLabel="Reference">@context.Reference</MudTd>
                                <MudTd DataLabel="Amount" Style="text-align: right;"><span class="admin-td-amount">@(context.Amount?.ToString("N2") ?? "0.00")</span></MudTd>
                                <MudTd DataLabel="Actions" Style="text-align: right;">
                                    <MudTooltip Text="View Details">
                                        <MudIconButton OnClick="@(()=> OpenExpenseForm(context.OpTranID))" Color="Color.Primary" Icon="@Icons.Material.Filled.Visibility" Size="Size.Small" Variant="Variant.Text" />
                                    </MudTooltip>
                                </MudTd>
                            </RowTemplate>
                        </MudTable>
                    }
                    else
                    {
                        <div class="d-flex flex-column align-center justify-center py-12 opacity-50">
                            <MudIcon Icon="@Icons.Material.Filled.Receipt" Size="Size.Large" Class="mb-4" />
                            <MudText Typo="Typo.h6">No expenses recorded for this mission.</MudText>
                        </div>
                    }
                </div>
            </MudTabPanel>
            <MudTabPanel Text="Fuel & AdBlue" Icon="@Icons.Material.Filled.EvStation" OnClick="FuelTabSelected">
                <div class="pa-0">
                    @if (TFuelList != null && TFuelList.Count > 0)
                    {
                        <MudTable Elevation="0" Items="@TFuelList" Dense="true" Hover="true" Class="modern-admin-table">
                            <HeaderContent>
                                <MudTh><span class="admin-header-text">ENTRY DATE</span></MudTh>
                                <MudTh><span class="admin-header-text">DOC NO</span></MudTh>
                                <MudTh><span class="admin-header-text">ITEM TYPE</span></MudTh>
                                <MudTh><span class="admin-header-text">FUEL TYPE</span></MudTh>
                                <MudTh Style="text-align: right;"><span class="admin-header-text">QTY</span></MudTh>
                                <MudTh Style="text-align: right;"><span class="admin-header-text">RATE/LTR</span></MudTh>
                            </HeaderContent>
                            <RowTemplate>
                                <MudTd DataLabel="EntryDate">@Convert.ToDateTime(@context.EntryDate).ToString("dd MMM yyyy")</MudTd>
                                <MudTd DataLabel="DocNumber">@context.DocNumber</MudTd>
                                <MudTd DataLabel="ItemType">@context.ItemType</MudTd>
                                <MudTd DataLabel="FuelType">@context.FuelItemDescription</MudTd>
                                <MudTd DataLabel="Quantity" Style="text-align: right;"><span class="fw-600">@(context.Quantity?.ToString("N2") ?? "0.00")</span></MudTd>
                                <MudTd DataLabel="Rate" Style="text-align: right;"><span class="admin-td-amount">@(context.RatePerLitre?.ToString("N2") ?? "0.00")</span></MudTd>
                            </RowTemplate>
                        </MudTable>
                    }
                    else
                    {
                        <div class="d-flex flex-column align-center justify-center py-12 opacity-50">
                            <MudIcon Icon="@Icons.Material.Filled.EvStation" Size="Size.Large" Class="mb-4" />
                            <MudText Typo="Typo.h6">No fuel &amp; adblue entries recorded for this mission.</MudText>
                        </div>
                    }
                </div>
            </MudTabPanel>

            <MudTabPanel Text="Mileage Shortage" Icon="@Icons.Material.Filled.Calculate" OnClick="MileageTabSelected">
                <div class="pa-6">
                    @if (MileageList.Count > 0)
                    {
                        <div class="admin-glass-card pa-6" style="max-width: 800px; margin: 0 auto; border: 1px dashed var(--mud-palette-divider);">
                            <MudGrid Spacing="4">
                                <MudItem xs="12" md="6">
                                    <div class="mb-4">
                                        <MudText Typo="Typo.caption" Class="admin-subtitle">Document Number</MudText>
                                        <MudText Typo="Typo.body1" Class="fw-600 mt-n1">@MileageList[0].DocumentNumber</MudText>
                                    </div>
                                    <div class="mb-4">
                                        <MudText Typo="Typo.caption" Class="admin-subtitle">Running Distance</MudText>
                                        <MudText Typo="Typo.body1" Class="fw-600 mt-n1">@MileageList[0].RunningKM km</MudText>
                                    </div>
                                    <div class="mb-4">
                                        <MudText Typo="Typo.caption" Class="admin-subtitle">Consumed Fuel</MudText>
                                        <MudText Typo="Typo.body1" Class="fw-600 mt-n1 text-primary">@MileageList[0].ConsumedFuel Ltrs</MudText>
                                    </div>
                                </MudItem>
                                <MudItem xs="12" md="6">
                                    <div class="mb-4">
                                        <MudText Typo="Typo.caption" Class="admin-subtitle">Allotted Distance</MudText>
                                        <MudText Typo="Typo.body1" Class="fw-600 mt-n1">@MileageList[0].AllottedDistance km</MudText>
                                    </div>
                                    <div class="mb-4">
                                        <MudText Typo="Typo.caption" Class="admin-subtitle">Fuel Unit Price</MudText>
                                        <MudText Typo="Typo.body1" Class="fw-600 mt-n1">@(MileageList[0].FuelPrice?.ToString("C2") ?? "0")</MudText>
                                    </div>
                                    <div class="pa-3 rounded-lg bg-light-error">
                                        <MudText Typo="Typo.caption" Color="Color.Error" Class="fw-600">TOTAL SHORTAGE AMOUNT</MudText>
                                        <MudText Typo="Typo.h5" Color="Color.Error" Class="fw-700 mt-n1">@(MileageList[0].TotalAmount?.ToString("N2") ?? "0")</MudText>
                                    </div>
                                </MudItem>
                            </MudGrid>
                        </div>
                    }
                    else
                    {
                        <div class="d-flex flex-column align-center justify-center py-12 opacity-50">
                            <MudIcon Icon="@Icons.Material.Filled.CheckCircleOutline" Size="Size.Large" Color="Color.Success" Class="mb-4" />
                            <MudText Typo="Typo.h6">No mileage shortage recorded for this trip.</MudText>
                        </div>
                    }
                </div>
            </MudTabPanel>
            <MudTabPanel Text="Telemetry & SLA" Icon="@Icons.Material.Filled.Assessment" OnClick="EventDuration">
                <div class="pa-0 overflow-auto">
                    @if (EventDetailsList != null && EventDetailsList.Count > 0)
                    {
                        <MudTable Elevation="0" Items="@EventDetailsList" Dense="true" Hover="true" Class="modern-admin-table">
                            <HeaderContent>
                                <MudTh><span class="admin-header-text">EVENT PHASE</span></MudTh>
                                <MudTh><span class="admin-header-text">PLACE</span></MudTh>
                                <MudTh><span class="admin-header-text">TIMESTAMP</span></MudTh>
                                <MudTh Style="text-align: right;"><span class="admin-header-text">DURATION (HRS)</span></MudTh>
                                <MudTh Style="text-align: right;"><span class="admin-header-text">KM READING</span></MudTh>
                                <MudTh Style="text-align: right;"><span class="admin-header-text">DISTANCE</span></MudTh>
                                <MudTh><span class="admin-header-text">OPERATOR</span></MudTh>
                            </HeaderContent>
                            <RowTemplate>
                                <MudTd DataLabel="EventName"><span class="fw-600">@context.EventName @context.NextEventName</span></MudTd>
                                <MudTd DataLabel="PlaceName">@context.PlaceName</MudTd>
                                <MudTd DataLabel="DateTime">@context.EventDateTime.Value.ToString("dd MMM, hh:mm tt")</MudTd>
                                <MudTd DataLabel="DateTimeDiff" Style="text-align : right;"><span class="admin-td-primary">@context.EventDateTimeDiff</span></MudTd>
                                <MudTd DataLabel="KMReading" Style="text-align : right;">@context.KMReading</MudTd>
                                <MudTd DataLabel="KMReadingDiff" Style="text-align : right;"><span class="text-success fw-600">@context.KMReadingDiff</span></MudTd>
                                <MudTd DataLabel="UserName">@context.UserInfo.UserID</MudTd>
                            </RowTemplate>
                        </MudTable>
                    }
                    else
                    {
                        <div class="d-flex flex-column align-center justify-center py-12 opacity-50">
                            <MudIcon Icon="@Icons.Material.Filled.Assessment" Size="Size.Large" Class="mb-4" />
                            <MudText Typo="Typo.h6">No telemetry &amp; SLA events recorded for this mission.</MudText>
                        </div>
                    }
                </div>
            </MudTabPanel>
        </MudTabs>
    </div>
</div>

@code {

    [Parameter]
    public TripModel Trip { get; set; }
    [Parameter]
    public bool IsLocked { get; set; } = false;
    [Parameter]
    public bool IsMileageOverride { get; set; } = false;
    string UserID;
    private int? EventCount = 0;
    private bool _busy;

    protected void OnEventCount(int? eventCount)
    {
        EventCount = eventCount;
    }
    private List<OpTranSubModel> OptranList = new();
    private List<TripFuelModel> TFuelList = new();
    private List<MileageShortageReceiptModel> MileageList = new();
    private List<EventCardModel> EventDetailsList = new();
    DialogOptions maxWidth = new DialogOptions() { MaxWidth = MaxWidth.Large, FullWidth = true, CloseButton = true, CloseOnEscapeKey = true };
    public List<GcSetModel> AssignedGCs { get; set; }
    private List<GcTariffModel> TarifList = new();
    private TripInfoModel TripInfoMdl = new();
    private bool IsEventSelected = false;

    public bool HasPermissionTripFuelServiceEdit { get; set; } = false;
    public int DocTypeIDTripFuel = 40;

    public bool HasPermissionTripServiceEnableLock { get; set; } = false;
    public bool HasPermissionTripServiceDisableLock { get; set; } = false;
    public bool HasPermissionTripServiceOverrideMileageShortage { get; set; } = false;
    public int DocTypeIDTrip = 39;

    protected override async Task OnInitializedAsync()
    {
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionTripFuelServiceEdit = await Irole.HasClaim(DocTypeIDTripFuel.ToString(), "Edit", ctc.Token);
        HasPermissionTripServiceEnableLock = await Irole.HasClaim(DocTypeIDTrip.ToString(), "EnableLock", ctc.Token);
        HasPermissionTripServiceDisableLock = await Irole.HasClaim(DocTypeIDTrip.ToString(), "DisableLock", ctc.Token);
        HasPermissionTripServiceOverrideMileageShortage = await Irole.HasClaim(DocTypeIDTrip.ToString(), "OverrideMileageShortage", ctc.Token);
        var authprov = await auth.GetAuthenticationStateAsync();
        UserID = authprov.User.Identity.Name;
        if (Trip.TripID != null)
        {
            TripInfoMdl = tripIservice.GetTripInfo(Trip.TripID);
        }
    }

    async Task UpdateUnloadingQty()
    {
        LoadGcs();
        DialogParameters parms = new DialogParameters();
        parms.Add("GcsToUnload", AssignedGCs);
        DialogOptions options = new DialogOptions() { MaxWidth = MaxWidth.Medium, FullWidth = true };
        var dialog = await DialogService.ShowAsync<UnloadQuantityDialog>("Unloading Qty Update", parms, options);
        var result = await dialog.Result;
        if (!result.Canceled)
        {
            try
            {
                List<GcSetModel> gcs = (List<GcSetModel>)result.Data;
                foreach (var item in gcs)
                {
                    Igc.UpdateUnloadingQuantity(item);
                }
            }
            catch (Exception ex)
            {
                snackbar.Add(ex.Message, Severity.Error, null);
            }
        }
        else
        {
            return;
        }
    }

    public void Refresh(TripModel Trip)
    {
        if (Trip.TripID != null && tripIservice != null)
        {
            TripInfoMdl = tripIservice.GetTripInfo(Trip.TripID);
        }
    }

    public void GcTabSelected()
    {
        LoadGcs();
    }

    public void FreightTabSelected()
    {
        TarifList = tripIservice.GetTariffs(Trip.TripID).ToList();
    }

    public void EventTabSelected()
    {
        IsEventSelected = true;
    }

    public void ExpenseTabSelected()
    {
        OptranList = new();
        var OpList = Iservice.SelectByTrip(Trip.TripID).ToList();
        foreach (var item in OpList)
        {
            OptranList.AddRange(Iservice.GetExpenses(item.OpTranID).Where(x => x.Amount > 0).ToList());
        }
    }

    public void EventDuration()
    {
        EventDetailsList = tripIservice.GetEventList(Trip.TripID).ToList();
    }

    public void FuelTabSelected()
    {
        TFuelList = tripFuelIservice.SelectByTrip(Trip.TripID).ToList();
    }

    public void MileageTabSelected()
    {
        MileageList = IMileageService.SelectByTripID(Trip.TripID).ToList();
    }

    private async Task OpenExpenseForm(long? OpTranID = null)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        _busy = true;

        OpTranModel opModel;

        DialogParameters parms = new DialogParameters();
        if (OpTranID != null)
        {
            opModel = Iservice.SelectByID(OpTranID);
            parms.Add("ReadOnly", true);
        }
        else
        {
            opModel = new OpTranModel() { TripID = Trip.TripID, TruckID = Trip.TruckID, PaymentMode = "Cash", Area = "Operation" };
        }

        parms.Add("model", opModel.Clone());
        var dialog = await DialogService.ShowAsync<Finance.Transactions.OpTranDialog>("ADD", parms, maxWidth);
        var result = await dialog.Result;
        if (!result.Canceled)
        {
            ExpenseTabSelected();
        }
        await Task.Delay(200);
        _busy = false;
    }

    private async Task OpenMileageShortageReceipt(MileageShortageReceiptModel omsrModel = null)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        _busy = true;
        DialogParameters parms = new DialogParameters();
        if (omsrModel == null)
        {
            omsrModel = new MileageShortageReceiptModel()
                {
                    TripID = Trip.TripID,
                    TripNo = (Trip.TripNumberDisplay.ToString()),
                    DriverID = Trip.DriverID,
                    ReceiptMode = "Cash",
                    RunningKM = TripInfoMdl?.RunKM ?? 0,
                    ConsumedFuel = TripInfoMdl?.Fuel ?? 0
                };
        }
        else
        {
            parms.Add("ReadOnly", true);
        }
        parms.Add("model", omsrModel.Clone());
        var dialog = await DialogService.ShowAsync<Finance.Transactions.MileageShortageReceiptDialog>("ADD", parms, maxWidth);
        var result = await dialog.Result;
        if (!result.Canceled)
        {
            MileageTabSelected();
        }
        await Task.Delay(200);
        _busy = false;
    }

    public void LoadGcs()
    {
        if (Trip == null)
            AssignedGCs = null;
        else
            AssignedGCs = Igc.SelectByTrip(Trip.TripID);
    }

    private async Task OpenFuelForm()
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        _busy = true;
        if (HasPermissionTripFuelServiceEdit)
        {
            DialogParameters parms = new DialogParameters();
            parms.Add("TripNumberDisplay", Trip.TripNumberDisplay);
            parms.Add("TruckNumber", TripInfoMdl.Truck);
            parms.Add("Tmodel", new TripFuelModel() { TripID = Trip.TripID, TruckID = Trip.TruckID });
            var dialog = await DialogService.ShowAsync<TripsFuelDialog>("ADD FUEL", parms, maxWidth);
            var result = await dialog.Result;
            var isCancel = result.Canceled;
            if (!isCancel)
            {
                Refresh(Trip);
                FuelTabSelected();
            }
        }
        else
        {
            bool? ResultModel = await DialogService.ShowMessageBoxAsync(
                "Permission denied!",
                "You don't have any permission to Add or Edit TripFuel.");
        }
        await Task.Delay(200);
        _busy = false;
    }

    private async Task TripLocked(bool value)
    {
        if (!value)
        {
            if (HasPermissionTripServiceDisableLock)
            {
                IsLocked = value;
                tripIservice.LockedTrip(Trip.TripID, false, UserID);
            }
            else
            {
                bool? ResultModel = await DialogService.ShowMessageBoxAsync(
                    "Permission denied!",
                    "You don't have any permission to Disable Lock Trip.");
            }
        }
        if (value)
        {
            if (HasPermissionTripServiceEnableLock)
            {
                bool? confirm = await DialogService.ShowMessageBoxAsync("Confirmation !",
                    "Are you sure, you want to Lock the Trip ?", "Yes", "No");
                if (confirm == true)
                {
                    IsLocked = value;
                    tripIservice.LockedTrip(Trip.TripID, true, UserID);
                }
            }
            else
            {
                bool? ResultModel = await DialogService.ShowMessageBoxAsync(
                    "Permission denied!",
                    "You don't have any permission to Enable Lock Trip.");
            }
        }
    }

    private async Task OverrideMileageShortage(bool value)
    {
        if (!value)
        {
            if (HasPermissionTripServiceOverrideMileageShortage)
            {
                IsMileageOverride = value;
                tripIservice.OverrideMileageShortage(Trip.TripID, false, UserID);
            }
            else
            {
                bool? ResultModel = await DialogService.ShowMessageBoxAsync(
                    "Permission denied!",
                    "You don't have any permission to Override Mileage Shortage.");
            }
        }
        if (value)
        {
            if (HasPermissionTripServiceOverrideMileageShortage)
            {
                bool? confirm = await DialogService.ShowMessageBoxAsync("Confirmation !",
                    "Are you sure, you want to Override Mileage Shortage ?", "Yes", "No");
                if (confirm == true)
                {
                    IsMileageOverride = value;
                    tripIservice.OverrideMileageShortage(Trip.TripID, true, UserID);
                }
            }
            else
            {
                bool? ResultModel = await DialogService.ShowMessageBoxAsync(
                    "Permission denied!",
                    "You don't have any permission to Enable Override Mileage Shortage.");
            }
        }
    }
