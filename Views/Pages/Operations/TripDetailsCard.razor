@using Views.Pages.Gc
<MudCard Class="@Class" Style="height:auto" Elevation="@Elevation">
    <MudCardHeader>
        <CardHeaderAvatar>
            <MudAvatar Color="Color.Tertiary"><MudIcon Icon="@Icons.Material.Filled.ModeOfTravel" Title="Trip Number" Color="Color.Primary" /></MudAvatar>
        </CardHeaderAvatar>
        <CardHeaderContent>
            <MudGrid>
                <MudItem xs="6">
                    <MudText Typo="Typo.h5" GutterBottom="true">
                        <MudIcon Icon="@Icons.Material.Filled.ConfirmationNumber" Title="Trip Number" Color="Color.Primary" />
                        <b>@trips.TripPrefix@trips.TripNumber</b>
                    </MudText>
                </MudItem>
                <MudItem xs="6">
                    <MudText Typo="Typo.h5" GutterBottom="true">
                        <MudIcon Icon="@Icons.Material.Filled.AirlineSeatReclineNormal" Title="Driver" Color="Color.Primary" />
                        <b>@AssignedDriver.DriverName</b>
                    </MudText>
                </MudItem>




            </MudGrid>



        </CardHeaderContent>
        <CardHeaderActions>
            <MudTooltip Text="Add Fuel">
                <MudIconButton Icon="@Icons.Material.Filled.LocalGasStation" Size="Size.Large" Color="Color.Success" @onclick="@(()=> OpenDialog(Tmodel))" />
            </MudTooltip>
            <MudTooltip Text="Add Expenses">
                <MudIconButton Icon="@Icons.Material.Filled.MenuBook" Color="Color.Success" Size="Size.Large" @onclick="@(()=> OpenDialog(Opmodel))" />
            </MudTooltip>
        </CardHeaderActions>
    </MudCardHeader>

    <MudCardContent>       

            <MudTabs Rounded="true" MinimumTabWidth="40px" Color="@Color.Transparent" PrevIcon="@Icons.Material.Filled.SkipPrevious" NextIcon="@Icons.Material.Filled.SkipNext" Class="shadow-sm shadow border-0 border">

                <MudTabPanel ToolTip="Trip Info" Icon="@Icons.Material.Filled.Info" >
                    <MudContainer Class="TabStyle">
                        @* <MudPaper Style="width:700px">*@
                        <MudList Style="width:700px">
                            <MudGrid>
                                <MudItem md="5">
                                    <MudListItem Avatar="@Icons.Material.Filled.DateRange" IconColor="Color.Primary">
                                        <b>@Convert.ToDateTime(@trips.TripDate).ToString("dd/MM/yyyy")</b>
                                    </MudListItem>
                                    <MudListItem Avatar="@Icons.Material.Filled.GasMeter" IconColor="Color.Primary">
                                        Running Km : <b>@TripInfoMdl?.RunKM</b>
                                    </MudListItem>
                                    <MudListItem Avatar="@Icons.Material.Filled.Construction" IconColor="Color.Primary">
                                        Total Fuel :<b>@TripInfoMdl?.Fuel</b>
                                    </MudListItem>
                                    <MudListItem Avatar="@Icons.Material.Filled.Construction" IconColor="Color.Primary">
                                        Total Expense :<b>@TotalExpense</b>
                                    </MudListItem>
                                </MudItem>

                                <MudItem md="5">
                                    <MudListItem Avatar="@Icons.Material.Filled.FireTruck" IconColor="Color.Primary">
                                        <b>@Truck?.RegNo</b>
                                    </MudListItem>
                                    <MudListItem Avatar="@Icons.Material.Filled.EditRoad" IconColor="Color.Primary">
                                        Mileage :<b>@TripInfoMdl?.Mileage</b>
                                    </MudListItem>
                                    <MudListItem Avatar="@Icons.Material.Filled.Money" IconColor="Color.Primary">
                                        Total Frieght :<b>@FrieghtAmount</b>
                                    </MudListItem>
                                </MudItem>
                            </MudGrid>

                        </MudList>
                        @*    </MudPaper>*@
                    </MudContainer>
                </MudTabPanel>
               <MudTabPanel ToolTip="Frieght" Icon="@Icons.Material.Filled.Money" OnClick="Frieght_Selecting">
                    <MudContainer Class="TabStyle">
                      
                        <MudGrid>
                            <MudItem md="12">

                                <MudTable Items="@TarifList" Dense="true" Hover="true" Striped="true" @bind-place="GcTarifModel" >


                                    <HeaderContent>
                                        <MudTh><MudTableSortLabel SortBy="new Func<GcTariffModel, object>(x=> x.GcNumber)" InitialDirection="SortDirection.Ascending">GC No</MudTableSortLabel></MudTh>
                                        <MudTh Style="width:180px;"><MudTableSortLabel SortBy="new Func<GcTariffModel, object>(x=> x.TariffTypeName)" InitialDirection="SortDirection.Ascending">Tarif type Name</MudTableSortLabel></MudTh>
                                        <MudTh><MudTableSortLabel SortBy="new Func<GcTariffModel, object>(x=> x.Amount)" InitialDirection="SortDirection.Ascending">Amount</MudTableSortLabel></MudTh>
                                    </HeaderContent>
                                    <RowTemplate>
                                        <MudTd DataLabel="Gc Number">@context.GcNumber</MudTd>
                                        <MudTd DataLabel="Tariff Type Name">@context.TariffTypeName</MudTd>
                                        <MudTd DataLabel="Amount">@context.Amount</MudTd>
                                    </RowTemplate>
                                </MudTable>
                            </MudItem>
                        </MudGrid>
                       
                    </MudContainer>
                </MudTabPanel>
                <MudTabPanel ToolTip="Consignments" OnClick="Consignments_Selected" Icon="@Icons.Material.Filled.Backpack"  >
                    <MudContainer Class="TabStyle">
                        <br />
                  
                        @if (AssignedGCs != null)

                        {
                            <MudGrid>
                                @foreach (var gc in AssignedGCs)
                                {

                                    <MudItem xs="6" lg="6" md="6">
                                        <GcItemCard item="gc" Style="@($"background:{Colors.Cyan.Lighten5};")"></GcItemCard>
                                    </MudItem>
                                }
                            </MudGrid>

                        }

                    
                    </MudContainer>
                </MudTabPanel>
                <MudTabPanel ToolTip="Events" Icon="@Icons.Material.Filled.Event" OnClick="Events_Selecting" >
                    <MudContainer Class="TabStyle">
                    @if (IsEventSelected)
                    {
                        <MudTimeline>
                            <TripEventsComponent Trip="@trips" OnEventCount="@OnEventCount"></TripEventsComponent>
                            @*@foreach (var item in TripEvents)
                            {
                            string timetext;
                            DateTime today = DateTime.Today;
                            @if (item.EventTime?.Date == today)
                            timetext = "Today " + item.EventTime?.ToString("hh:mm tt");
                            else if (item.EventTime?.Date.AddDays(1) == today)
                            timetext = "YesterDay " + item.EventTime?.ToString("hh:mm tt");
                            else timetext = item.EventTime?.ToString("ddd dd-MMM-yyyy hh:mm tt");

                            EventTypeModel et = EventTypes.First(x => x.EventTypeID == item.EventTypeID);


                            <MudTimelineItem Color="Color.Success" Elevation="10">
                            <MudCard Elevation="25" Style="@($"background:{Colors.Brown.Lighten5};")">
                            <MudCardContent>
                            <MudText Typo="Typo.h6" Color="Color.Primary">@et.EventStatusText </MudText>
                            @if (et.EventTypeID != 1)
                            {
                            <MudIconButton Size="Size.Small" Icon="@Icons.Material.Filled.Edit" OnClick="(() => UpdateEvent(item))"></MudIconButton>
                            }
                            <MudText Typo="Typo.button">@(et.IsStationary ? "Reached " : "Left ")  @item.OriginName </MudText>
                            <MudText Typo="Typo.body2" Class="mud-text-secondary">@timetext  </MudText>
                            </MudCardContent>
                            </MudCard>
                            </MudTimelineItem>
                            }*@
                        </MudTimeline>
                        }
                    </MudContainer>
                </MudTabPanel>
                <MudTabPanel ToolTip="Expenses" Icon="@Icons.Material.Filled.Receipt" OnClick="Expense_Selecting">
                    <MudContainer Class="TabStyle">   
                    
                        <MudTable Elevation="0" Items="@OptranList" Dense="true" Hover="true" Striped="true" @bind-place="Opmodel">

                                    <HeaderContent>
                                        <MudTh Style="width:160px;"><MudTableSortLabel SortBy="new Func<OpTranModel, object>(x=> x.DocumentDate)" InitialDirection="SortDirection.Ascending">Document No</MudTableSortLabel></MudTh>
                                        <MudTh><MudTableSortLabel SortBy="new Func<OpTranModel, object>(x=> x.DocumentNumber)" InitialDirection="SortDirection.Ascending">Doc Date</MudTableSortLabel></MudTh>
                                        <MudTh><MudTableSortLabel SortBy="new Func<OpTranModel, object>(x=> x.TotalAmount)" InitialDirection="SortDirection.Ascending">Amount</MudTableSortLabel></MudTh>
                                        <MudTh>Actions</MudTh>
                                    </HeaderContent>
                                    <RowTemplate>
                                        <MudTd DataLabel="DocumentNumber">@context.DocumentNumber</MudTd>
                                        <MudTd DataLabel="DocumnetDtae">@Convert.ToDateTime(@context.DocumentDate).ToString("dd/MM/yyyy")</MudTd>
                                        <MudTd DataLabel="Amount">@context.TotalAmount</MudTd>
                                        <MudTd DataLabel="">
                                            <MudFab @onclick="@(()=> OpenDialog(context))" Color="Color.Primary" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" IconSize="Size.Small" />
                                        </MudTd>
                                    </RowTemplate>
                                </MudTable>    
                                
                    </MudContainer>
                </MudTabPanel>
                <MudTabPanel ToolTip="Fuel Entries" Icon="@Icons.Material.Filled.ReadMore" OnClick="Fuel_Selecting">
                    <div class="TabStyle ">   
                       
                        <MudTable Elevation="0" Items="@TFuelList" Dense="true" Hover="true" Striped="true" @bind-place="Tmodel">
                            @*  <ToolBarContent>
                                    <MudText><b>Add Fuel</b></MudText>
                                    <MudIconButton Icon="@Icons.Material.Filled.Add" Title="Add"
                                    @onclick="@(()=> OpenDialog(Tmodel))" Color="Color.Dark"
                                    Size="Size.Small"></MudIconButton>

                                    <MudSpacer></MudSpacer>
                                    </ToolBarContent>*@
                            <HeaderContent>
                                <MudTh Style="width:160px;"><MudTableSortLabel SortBy="new Func<TripFuelModel, object>(x=> x.EntryDate)" InitialDirection="SortDirection.Ascending">Entry Date</MudTableSortLabel></MudTh>
                                <MudTh><MudTableSortLabel SortBy="new Func<TripFuelModel, object>(x=> x.FuelItemID)" InitialDirection="SortDirection.Ascending">Item</MudTableSortLabel></MudTh>
                                <MudTh><MudTableSortLabel SortBy="new Func<TripFuelModel, object>(x=> x.Quantity)" InitialDirection="SortDirection.Ascending">Quantity</MudTableSortLabel></MudTh>
                                <MudTh><MudTableSortLabel SortBy="new Func<TripFuelModel, object>(x=> x.RatePerLitre)" InitialDirection="SortDirection.Ascending">Rate/Ltr</MudTableSortLabel></MudTh>
                                @*<MudTh>Actions</MudTh>*@
                            </HeaderContent>
                            <RowTemplate>
                                <MudTd DataLabel="EntryDate">@Convert.ToDateTime(@context.EntryDate).ToString("dd/MM/yyyy")</MudTd>
                                <MudTd DataLabel="Item">@context.FuelItemID</MudTd>
                                <MudTd DataLabel="Quantity">@context.Quantity</MudTd>
                                <MudTd DataLabel="Frieght">@context.RatePerLitre</MudTd>
                                @*    <MudTd DataLabel="">
                                        <MudFab @onclick="@(()=> OpenDialog(context))" Color="Color.Primary" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" IconSize="Size.Small" />
                                        </MudTd>*@
                            </RowTemplate>
                            @* <FooterContent>
                                    <MudText>Total Frieght</MudText>
                                    </FooterContent>*@
                        </MudTable>
                    
                </div>
                </MudTabPanel>
            </MudTabs>

    </MudCardContent>   
</MudCard>
<style>
   

    .TabStyle {
        margin-top : 10px;
        padding : 5px;
        box-shadow: inset 2px 1px 3px #999;
        height: 250px;
        overflow: scroll;
    }
</style>
@code {
