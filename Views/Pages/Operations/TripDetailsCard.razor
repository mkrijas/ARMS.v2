@using Views.Pages.Gc
<MudCard Class="@Class" Style="height:370px">
    <MudCardHeader>
        <CardHeaderAvatar>
            <MudAvatar Color="Color.Tertiary">TM</MudAvatar>
        </CardHeaderAvatar>
        <CardHeaderContent>
            <MudGrid>
                <MudItem xs="4">
                <MudText Typo="Typo.body1" GutterBottom="true">
                    <MudIcon Icon="@Icons.Material.Filled.ConfirmationNumber" Title="Trip Number" Color="Color.Primary" />
                    <b>@trips.TripPrefix@trips.TripNumber</b>
                </MudText>
                 <MudText Typo="Typo.body2">
                        <MudIcon Icon="@Icons.Material.Filled.DateRange" Title="Trip Number" Color="Color.Primary" />
                        <b>@Convert.ToDateTime(@trips.TripDate).ToString("dd/MM/yyyy")</b>
                    </MudText>
             
            </MudItem>
              <MudItem xs="4">
                    <MudText Typo="Typo.body1" GutterBottom="true">
                        <MudIcon Icon="@Icons.Material.Filled.AirlineSeatFlat" Title="Driver" Color="Color.Primary" />
                        <b>@AssignedDriver.DriverName</b>
                    </MudText>
                    <MudText Typo="Typo.body1" GutterBottom="true">
                        <MudIcon Icon="@Icons.Material.Filled.FireTruck" Title="Driver" Color="Color.Primary" />
                        <b>@Truck?.RegNo</b>
                    </MudText>
                  </MudItem>
            <MudItem xs="4">
           
            </MudItem>
            </MudGrid>
            

           
        </CardHeaderContent>
    </MudCardHeader>
    <MudCardContent>
        <MudPaper>
        <MudTabs Rounded="true" Color="@Color.Transparent" PrevIcon="@Icons.Material.Filled.SkipPrevious" NextIcon="@Icons.Material.Filled.SkipNext" style="background-color:#E4E5E8">

                <MudTabPanel Text="Consignments" ToolTip="AssignedConsignments">
                    <MudContainer Style="height:220px; overflow-y:scroll">
                    <br />
                    @if (AssignedGCs != null)
                    {
                          <MudGrid>
                        @foreach (var gc in AssignedGCs)
                        {

                                <MudItem xs="6" lg="6" md="6">
                                        <GcItemCard item="gc" Style="@($"background:{Colors.Cyan.Lighten5};")" TransactionUpdated="TransactionUpdated"></GcItemCard>
                                </MudItem>
                        }
                        </MudGrid>
                     
                    }
                    

                </MudContainer>

            </MudTabPanel>
                <MudTabPanel Text="Events" ToolTip="Events">
                    <MudContainer Style="height:220px; overflow-y:scroll">
                    <MudTimeline>
                        @foreach (var item in TripEvents)
                        {
                            string timetext;
                            DateTime today = DateTime.Today;
                            @if (item.EventTime?.Date == today)
                                timetext = "Today " + item.EventTime?.ToString("hh:mm tt");
                            else if (item.EventTime?.Date.AddDays(1) == today)
                                timetext = "YesterDay " + item.EventTime?.ToString("hh:mm tt");
                            else timetext = item.EventTime?.ToString("ddd dd-MMM-yyyy hh:mm tt");

                            EventTypeModel et = EventTypes.First(x => x.EventTypeID == item.EventTypeID);


                            <MudTimelineItem Color="Color.Success" Elevation="10">
                                <MudCard Elevation="25" Style="@($"background:{Colors.Brown.Lighten5};")">
                                    <MudCardContent>
                                        <MudText Typo="Typo.h6" Color="Color.Primary">@et.EventStatusText </MudText>
                                        @if (et.EventTypeID != 1)
                                        {
                                            <MudIconButton Size="Size.Small" Icon="@Icons.Material.Filled.Edit" OnClick="(() => UpdateEvent(item))"></MudIconButton>
                                        }
                                        <MudText Typo="Typo.button">@(et.IsStationary ? "Reached " : "Left ")  @item.OriginName </MudText>
                                        <MudText Typo="Typo.body2" Class="mud-text-secondary">@timetext  </MudText>
                                    </MudCardContent>
                                </MudCard>
                            </MudTimelineItem>
                        }
                    </MudTimeline>
                    </MudContainer>
                </MudTabPanel>
            <MudTabPanel Text="Transactions" ToolTip="Accounting entries">
           
             @*   <MudItem md="12" lg="12">*@
                    <MudContainer Style="height:220px; overflow-y:scroll">
                        <MudGrid>
                            <br />
                            <MudTable Items="@OptranList" Dense="true" Hover="true" Striped="true"  @bind-place="Opmodel">
                                <ToolBarContent>
                                    <MudText>Add New</MudText>

                                    <MudIconButton Icon="@Icons.Material.Filled.Add" Title="Add" @onclick="@(()=> OpenDialog(Opmodel))" Color="Color.Dark" Size="Size.Small"></MudIconButton>

                                    <MudSpacer></MudSpacer>
                                </ToolBarContent>

                                <HeaderContent>
                                    <MudTh Style="width:160px;"><MudTableSortLabel SortBy="new Func<OpTranModel, object>(x=> x.DocumentDate)" InitialDirection="SortDirection.Ascending">Document No</MudTableSortLabel></MudTh>
                                    <MudTh Style="width:150px;"><MudTableSortLabel SortBy="new Func<OpTranModel, object>(x=> x.DocumentNumber)" InitialDirection="SortDirection.Ascending">Doc Date</MudTableSortLabel></MudTh>
                                    <MudTh><MudTableSortLabel SortBy="new Func<OpTranModel, object>(x=> x.TotalAmount)" InitialDirection="SortDirection.Ascending">Amount</MudTableSortLabel></MudTh>
                                    <MudTh>Actions</MudTh>
                                </HeaderContent>
                                <RowTemplate>
                                    <MudTd DataLabel="DocumentNumber">@context.DocumentNumber</MudTd>
                                    <MudTd DataLabel="DocumnetDtae">@context.DocumentDate</MudTd>
                                    <MudTd DataLabel="Amount">@context.TotalAmount</MudTd>
                                    <MudTd DataLabel="">
                                        <MudFab @onclick="@(()=> OpenDialog(context))" Color="Color.Primary" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" IconSize="Size.Small" />
                                    </MudTd>
                                </RowTemplate>
                            </MudTable>
                        </MudGrid>
                    </MudContainer>

            @*    </MudItem>
*@
        

            </MudTabPanel>
        
            <MudTabPanel Text="Fuleing" ToolTip="FuelEntries">
              
                    <MudContainer Style="height:220px; overflow-y:scroll">
                        <br />
                        <MudGrid>
                              
                            <MudTable Items="@TFuelList" Dense="true" Hover="true" Striped="true" @bind-place="Tmodel">
                                <ToolBarContent>
                                @*    <MudText><b>Add Fuel</b></MudText>
                                    <MudIconButton Icon="@Icons.Material.Filled.Add" Title="Add"
                                    @onclick="@(()=> OpenDialog(Tmodel))" Color="Color.Dark"
                                    Size="Size.Small"></MudIconButton>*@
                                    <MudButton @onclick="@(()=> OpenDialog(Tmodel))" Color="@Color.Transparent" StartIcon="@Icons.Outlined.Add" Variant="Variant.Filled">
                                        Add Fuel
                                    </MudButton>
                                    <MudSpacer></MudSpacer>
                                </ToolBarContent>

                                <HeaderContent>
                                    <MudTh Style="width:160px;"><MudTableSortLabel SortBy="new Func<TripFuelModel, object>(x=> x.EntryDate)" InitialDirection="SortDirection.Ascending">Entry Date</MudTableSortLabel></MudTh>
                                    <MudTh><MudTableSortLabel SortBy="new Func<TripFuelModel, object>(x=> x.FuelItemID)" InitialDirection="SortDirection.Ascending">Item</MudTableSortLabel></MudTh>
                                    <MudTh><MudTableSortLabel SortBy="new Func<TripFuelModel, object>(x=> x.Quantity)" InitialDirection="SortDirection.Ascending">Quantity</MudTableSortLabel></MudTh>
                                    <MudTh Style="width:150px;"><MudTableSortLabel SortBy="new Func<TripFuelModel, object>(x=> x.RatePerLitre)" InitialDirection="SortDirection.Ascending">Rate/Ltr</MudTableSortLabel></MudTh>
                                    @*<MudTh>Actions</MudTh>*@
                                </HeaderContent>
                                <RowTemplate>
                                    <MudTd DataLabel="EntryDate">@context.EntryDate</MudTd>
                                    <MudTd DataLabel="Item">@context.FuelItemID</MudTd>
                                    <MudTd DataLabel="Quantity">@context.Quantity</MudTd>
                                    <MudTd DataLabel="Frieght">@context.RatePerLitre</MudTd>
                                @*    <MudTd DataLabel="">
                                        <MudFab @onclick="@(()=> OpenDialog(context))" Color="Color.Primary" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" IconSize="Size.Small" />
                                    </MudTd>*@
                                </RowTemplate>
                         @* <FooterContent>
                              <MudText>Total Frieght</MudText>
                          </FooterContent>*@
                            </MudTable>
                          
                        </MudGrid>
                    </MudContainer>

              
            </MudTabPanel>
        </MudTabs>
        </MudPaper>
    </MudCardContent>
    @*<MudCardActions>
    <MudButton @onclick="@(() => Edit(trips.GcSetID))" Color="Color.Primary">EDIT</MudButton>
    <MudButton @onclick="@(() => EwayBill(trips.GcSetID))" Variant="Variant.Text"
    Color="@ewaycolor">Eway Bill</MudButton>*@
    @*  <MudButton @onclick="@(() => FillExpenses(trips.GcSetID))" Variant="Variant.Text" Color="@FillExpColor">Post Inc/Exp</MudButton>*@
    @*    </MudCardActions>*@
</MudCard>

@code {
    [Parameter]
    public string Class { get; set; }

    [Parameter]
    public string Style { get; set; }
    [Parameter]
    public TripModel trips { get; set; }

    private Color ewaycolor = new();
    private Color FillExpColor = new();
    //Transactions
    private List<OpTranModel> OptranList = new List<OpTranModel>();
    private OpTranModel Opmodel = new OpTranModel();
    //Fueling
    private List<TripFuelModel> TFuelList = new List<TripFuelModel>();
    public TripFuelModel Tmodel { get; set; } = new TripFuelModel();
    private List<CostCenterModel> costCenter = new();
    private List<DimensionModel> dimension = new();
    private List<InventoryItemModel> Ac = new();
    DialogOptions maxWidth = new DialogOptions() { MaxWidth = MaxWidth.Medium, FullWidth = true, CloseButton = true, CloseOnEscapeKey = true };

    public bool? IsPur = null;
    public string IsPurView = "invisible";
    //Event start
    private TruckModel Truck;
    private EventModel CurrentEvent { get; set; }
    private EventTypeModel EventType { get; set; }
    private List<EventModel> TripEvents = new();
    private List<EventTypeModel> EventTypes = new();
    private TripModel _trip;
    private DriverModel AssignedDriver { get; set; }
    public List<GcSetModel> AssignedGCs { get; set; }
    //EventEnd

    private async void Submit()
    {
        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;
        var brancIDString = authprov.User.Claims.First(x => x.Type == "BranchID").Value;
        int brancID = int.Parse(brancIDString);
        Tmodel.BranchID = brancID;
        Tmodel.UserInfo.UserID = user.Identity.Name;

        try
        {

            //Iservice.Update(Tmodel);
            Tmodel = new();
            snackbar.Add("Saved Successfully", Severity.Success);
            Tmodel = new();

        }
        catch (Exception ex)
        {
            snackbar.Add(ex.Message, Severity.Warning);
        }

    }

    protected override async Task OnInitializedAsync()
    {
        //IsPurView = "invisible";
        costCenter = costIservice.Select().ToList();
        dimension = dimensionIservice.Select().ToList();
        //Ac = IsInvService.SelectByID(0).ToList();
        Ac = IsInvService.SearchByDescription(string.Empty).ToList();
     
        foreach (var fitem in tripFuelIservice.SelectByTrip(trips.TripID))
        {
            TFuelList.Add(fitem);
        }
        foreach (var item in Iservice.SelectByTrip(trips.TripID))
        {
            OptranList.Add(item);
        }
        EventTypes = Ievent.GetEventTypes().ToList();
        AssignedDriver = trips.DriverID == null ? null : Idriver.SelectByID(trips.DriverID.Value);
        //string truck
    }
    private void totalAmt()
    {
        Tmodel.TotalAmount = (Tmodel.RatePerLitre * Tmodel.Quantity);
    }
    //TranStart
    private async Task OpenDialog(OpTranModel ema)
    {
        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;

        DialogParameters parms = new DialogParameters();
        parms.Add("model", ema);
        var dialog = DialogService.Show<Finance.Transactions.OpTranDialog>(ema.TripID == null ? "ADD" : "EDIT", parms, maxWidth);
        var result = await dialog.Result;
    }
    //tranEnd
    //Event start
    private async Task UpdateEvent(EventModel ev)
    {
        var parameters = new DialogParameters();
        parameters.Add("Truck", Truck);
        parameters.Add("CurrentTrip", tripIservice.Select(ev.TripID));
        parameters.Add("model", ev);

        var result = DialogService.Show<UpdateEventView>("Edit Event", parameters);
        var Data = await result.Result;
        LoadEvents();
    }

    protected async override Task OnParametersSetAsync()
    {
        if (_trip?.TripID != trips?.TripID)
        {
            _trip = new TripModel { TripID = trips?.TripID };
            LoadAll();
        }
    }
    private void TransactionUpdated(long? TransID)
    {
        //TransactionsListViewRef.Refresh();
    }
    private void LoadAll()
    {
        //CancelledStatus = string.Empty;
        if (trips != null)
        {
            //hidden = false;
            if (tripIservice.Select(trips.TripID)?.UserInfo.RecordStatus == 4)
            {
                //CancelledStatus = "Cancelled";
            }
        }
        else
        {
            // hidden = true;
        }

        Truck = Itruck.SelectByID(trips?.TruckID);
        LoadEvents();
        LoadGcs();
    }
    public void LoadGcs()
    {
        if (trips == null)
            AssignedGCs = null;
        else
            AssignedGCs = Igc.SelectByTrip(trips.TripID);
    }
    public void LoadEvents()
    {
        if (trips == null)
            TripEvents = new();
        else
            TripEvents = Ievent.SelectByTrip(trips.TripID).ToList();
    }
    //EventEnd
    //fueling
    private void OpenDialog(TripFuelModel Tmodel)
    {

        DialogParameters parms = new DialogParameters();
        //trips.TripID = selectedItem1.TripID;
        //model.OrderID = Order.OrderID;
        Tmodel.TripID = trips.TripID;
        parms.Add("Tmodel", Tmodel);

        DialogService.Show<TripsFuelDialog>("ADD FUEL", parms, maxWidth);
    }
    //Fuel end
}
