@using System.Threading;
@using Core.BaseModels.Finance.Transactions;
@using Views.Pages.Operations.Gc
@using Pages.Operations.Expenses
@attribute [Authorize]
@inject AuthenticationStateProvider auth
@inject IOpTranService Iservice
@inject ITripService tripIservice
@inject ITripFuelService tripFuelIservice
@inject ICostCenterService costIservice
@inject IGstUsageIDService usageIservice
@inject IDimensionService dimensionIservice
@inject MudBlazor.ISnackbar snackbar
@inject ITdsRateService tdsIService
@inject IChartOfAccountService accountService
@inject IBranchService brIservice
@inject IDialogService DialogService
@inject IInventoryItemService itemIservice
@inject IInventoryItemService IsInvService
@inject IEventService Ievent
@inject ITruckService Itruck
@inject IDriverService Idriver
@inject IGcService Igc
@inject IRoleService<RoleModel> Irole
@inject IMileageShortageReceiptService IMileageService

<MudCard Class="mt-3" Style="height:auto" Elevation="4">
    <MudCardHeader>
        <CardHeaderAvatar>
            <MudAvatar Color="Color.Dark" Size="Size.Medium">
                <MudIcon Icon="@Icons.Material.Filled.ModeOfTravel" Title="Trip Number" Color="Color.Warning" />
                </MudAvatar>
        </CardHeaderAvatar>
        <CardHeaderContent> 
                    <MudText Typo="Typo.h6" GutterBottom="true">
                        <b>@(Trip != null ? Trip.TripNumberDisplay : "")</b>
                <MudSwitch Checked="@IsLocked" CheckedChanged="((bool value)=>TripLocked(value))" Color="Color.Error" Label="Trip Locked" />
                    </MudText>
        </CardHeaderContent>
        <CardHeaderActions>
            <MudTooltip Text="Add Fuel">
                <MudIconButton Icon="@Icons.Material.Filled.LocalGasStation" Disabled="@IsLocked" Size="Size.Large" Color="Color.Primary" @onclick="@(()=> OpenFuelForm())" />
            </MudTooltip>
            <MudTooltip Text="Add Expenses">
                <MudIconButton Icon="@Icons.Material.Filled.MenuBook" Disabled="@IsLocked" Color="Color.Primary" Size="Size.Large" @onclick="@(()=> OpenExpenseForm())" />
            </MudTooltip>
            <MudTooltip Text="Add Mileage Shortage Receipt">
                <MudIconButton Icon="@Icons.Material.Filled.Toll" Disabled="@IsLocked" Color="Color.Primary" Size="Size.Large" @onclick="@(()=> OpenMileageShortageReceipt())" />
            </MudTooltip>
          
        </CardHeaderActions>
    </MudCardHeader>
    <MudCardContent>
        <MudTabs Rounded="true" MinimumTabWidth="40px" Color="@Color.Transparent" PrevIcon="@Icons.Material.Filled.SkipPrevious" NextIcon="@Icons.Material.Filled.SkipNext" Class="shadow-sm shadow border-0 border">
            <MudTabPanel ToolTip="Trip Info" Icon="@Icons.Material.Filled.Info">
                <div class="TabStyle">
                    <MudList Style="width:700px">
                        <MudGrid>
                            <MudItem md="6">
                                <MudListItem Avatar="@Icons.Material.Rounded.DateRange"   IconColor="Color.Dark" IconSize="Size.Small">
                                    <b>@Trip?.TripDate?.ToString("dd/MM/yyyy")</b>
                                </MudListItem>
                                <MudListItem Avatar="@Icons.Material.Rounded.GasMeter" IconColor="Color.Dark" IconSize="Size.Small">
                                    Running Km : <b>@TripInfoMdl?.RunKM</b>
                                </MudListItem>
                                <MudListItem Avatar="@Icons.Material.Rounded.Construction" IconColor="Color.Dark" IconSize="Size.Small">
                                    Total Fuel :<b>@TripInfoMdl?.Fuel</b>
                                </MudListItem>
                                <MudListItem Avatar="@Icons.Material.Rounded.Construction" IconColor="Color.Dark" IconSize="Size.Small">
                                    Total Expense :<b>@TripInfoMdl?.Expenses</b>
                                </MudListItem>
                            </MudItem>
                            <MudItem md="6">
                                <MudListItem Avatar="@Icons.Material.Rounded.FireTruck" IconColor="Color.Dark" IconSize="Size.Small">
                                    <b>@TripInfoMdl?.Truck</b>
                                </MudListItem>
                                <MudListItem Avatar="@Icons.Material.Rounded.AirlineSeatReclineNormal" IconColor="Color.Dark" IconSize="Size.Small">
                                    <b>@TripInfoMdl?.Driver</b>
                                </MudListItem>
                                <MudListItem Avatar="@Icons.Material.Rounded.EditRoad" IconColor="Color.Dark" IconSize="Size.Small">
                                    Mileage :<b>@TripInfoMdl?.Mileage</b>
                                </MudListItem>
                                <MudListItem Avatar="@Icons.Material.Rounded.Money" IconColor="Color.Dark" IconSize="Size.Small">
                                    Total Frieght :<b>@TripInfoMdl?.Freight</b>
                                </MudListItem>
                            </MudItem>
                        </MudGrid>
                    </MudList>
                </div>
            </MudTabPanel>
            <MudTabPanel ToolTip="Events" Icon="@Icons.Material.Filled.Event" OnClick="EventTabSelected">
                <div class="TabStyle">
                    @if (IsEventSelected)
                    {
                        <TripEventsComponent Trip="@Trip" IsLocked="@IsLocked"></TripEventsComponent>
                    }
                </div>
            </MudTabPanel>
            <MudTabPanel ToolTip="Consignments" OnClick="GcTabSelected" Icon="@Icons.Material.Filled.Backpack">
                <div class="TabStyle">
                    @if (AssignedGCs != null)
                    {
                        <MudGrid>
                            @foreach (var gc in AssignedGCs)
                            {
                                <MudItem xs="6" lg="6" md="6">
                                    <GcItemCard item="gc" Style="@($"background:{Colors.Purple.Lighten5};")" IsLocked="@IsLocked"></GcItemCard>
                                </MudItem>
                            }
                        </MudGrid>
                    }
                </div>
            </MudTabPanel>
            <MudTabPanel ToolTip="Frieght" Icon="@Icons.Material.Filled.Money" OnClick="FreightTabSelected">
                <div class="TabStyle">
                    <MudGrid>
                        <MudItem md="12">
                            <MudTable Items="@TarifList" Dense="true" Hover="true" Striped="true">
                                <HeaderContent>
                                    <MudTh><MudTableSortLabel SortBy="new Func<GcTariffModel, object>(x=> x.GcNumber)" InitialDirection="SortDirection.Ascending">GC No</MudTableSortLabel></MudTh>
                                    <MudTh Style="width:180px;"><MudTableSortLabel SortBy="new Func<GcTariffModel, object>(x=> x.TariffTypeName)" InitialDirection="SortDirection.Ascending">Tarif type Name</MudTableSortLabel></MudTh>
                                    <MudTh><MudTableSortLabel SortBy="new Func<GcTariffModel, object>(x=> x.Amount)" InitialDirection="SortDirection.Ascending">Amount</MudTableSortLabel></MudTh>
                                </HeaderContent>
                                <RowTemplate>
                                    <MudTd DataLabel="Gc Number">@context.GcNumber</MudTd>
                                    <MudTd DataLabel="Tariff Type Name">@context.TariffTypeName</MudTd>
                                    <MudTd DataLabel="Amount">@context.Amount</MudTd>
                                </RowTemplate>
                            </MudTable>
                        </MudItem>
                    </MudGrid>
                </div>
            </MudTabPanel>
            <MudTabPanel ToolTip="Expenses" Icon="@Icons.Material.Filled.Receipt" OnClick="ExpenseTabSelected">
                <div class=" TabStyle">
                    <MudTable Elevation="0" Items="@OptranList" Dense="true" Hover="true" Striped="true">
                        <HeaderContent>
                            <MudTh Style="width:160px;"><MudTableSortLabel SortBy="new Func<OpTranSubModel, object>(x=> x.ExpenseTitle)" InitialDirection="SortDirection.Ascending">Operation Head </MudTableSortLabel></MudTh>
                            <MudTh><MudTableSortLabel SortBy="new Func<OpTranSubModel, object>(x=> x.Reference)" InitialDirection="SortDirection.Ascending">Refernce</MudTableSortLabel></MudTh>
                            <MudTh><MudTableSortLabel SortBy="new Func<OpTranSubModel, object>(x=> x.Amount)" InitialDirection="SortDirection.Ascending">Amount</MudTableSortLabel></MudTh>
                            <MudTh>Actions</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd DataLabel="ExpenseTitle">@context.ExpenseTitle</MudTd>
                            <MudTd DataLabel="Reference">@context.Reference</MudTd>
                            <MudTd DataLabel="Amount">@context.Amount</MudTd>
                            <MudTd DataLabel="">
                                <MudFab @onclick="@(()=> OpenExpenseForm(context.OpTranID))" Color="Color.Primary" Icon="@Icons.Material.Filled.Numbers" Size="Size.Small" IconSize="Size.Small" />
                            </MudTd>
                        </RowTemplate>
                    </MudTable>
                </div>
            </MudTabPanel>
            <MudTabPanel ToolTip="Fuel & AdBlue Entries" Icon="@Icons.Material.Filled.ReadMore" OnClick="FuelTabSelected">
                <div class="TabStyle">
                    <MudTable Elevation="0" Items="@TFuelList" Dense="true" Hover="true" Striped="true">
                        <HeaderContent>
                            <MudTh Style="width:160px;"><MudTableSortLabel SortBy="new Func<TripFuelModel, object>(x=> x.EntryDate)" InitialDirection="SortDirection.Ascending">Entry Date</MudTableSortLabel></MudTh>
                            <MudTh><MudTableSortLabel SortBy="new Func<TripFuelModel, object>(x=> x.ItemType)" InitialDirection="SortDirection.Ascending">Item Type</MudTableSortLabel></MudTh>
                            <MudTh><MudTableSortLabel SortBy="new Func<TripFuelModel, object>(x=> x.FuelItemDescription)" InitialDirection="SortDirection.Ascending">Fuel Type</MudTableSortLabel></MudTh>
                            <MudTh><MudTableSortLabel SortBy="new Func<TripFuelModel, object>(x=> x.Quantity)" InitialDirection="SortDirection.Ascending">Quantity</MudTableSortLabel></MudTh>
                            <MudTh><MudTableSortLabel SortBy="new Func<TripFuelModel, object>(x=> x.RatePerLitre)" InitialDirection="SortDirection.Ascending">Rate/Ltr</MudTableSortLabel></MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd DataLabel="EntryDate">@Convert.ToDateTime(@context.EntryDate).ToString("dd/MM/yyyy")</MudTd>
                            <MudTd DataLabel="ItemType">@context.ItemType</MudTd>
                            <MudTd DataLabel="FuelType">@context.FuelItemDescription</MudTd>
                            <MudTd DataLabel="Quantity">@context.Quantity</MudTd>
                            <MudTd DataLabel="Frieght">@context.RatePerLitre</MudTd>
                        </RowTemplate>
                    </MudTable>
                </div>
            </MudTabPanel>

