@inject IEventService Ievent
@inject IDialogService DialogService

@if (TripEvents.Count > 0)
{

    <MudTimeline>
        @foreach (var item in TripEvents)
        {
            string timetext;
            DateTime today = DateTime.Today;
            @if (item.EventTime?.Date == today)
                timetext = "Today " + item.EventTime?.ToString("hh:mm tt");
            else if (item.EventTime?.Date.AddDays(1) == today)
                timetext = "YesterDay " + item.EventTime?.ToString("hh:mm tt");
            else timetext = item.EventTime?.ToString("ddd dd-MMM-yyyy hh:mm tt");

            EventTypeModel et = EventTypes.FirstOrDefault(x => x.EventTypeID == item.EventTypeID);

            <MudTimelineItem Color="Color.Success" Elevation="10" TimelineAlign="TimelineAlign.End">
                <ItemOpposite>
                    <MudText Color="Color.Dark" Typo="Typo.h6">@timetext</MudText>
                </ItemOpposite>
                <ItemContent>
                    <MudCard Elevation="25" Style="@($"background:{Colors.Brown.Lighten5};")">
                    <MudCardContent>
                        <MudText Typo="Typo.h6" Color="Color.Primary">@et?.EventStatusText </MudText>
                        @if (et?.EventTypeID != 1)
                        {
                            <MudIconButton Size="Size.Small" Icon="@Icons.Material.Filled.Edit" OnClick="(() => UpdateEvent(item))"></MudIconButton>
                        }
                        <MudText Typo="Typo.button">@(
                    et.IsStationary ? "Reached " : "Left "
                    )  @item.OriginName </MudText>
                        <MudText Typo="Typo.body2" Class="mud-text-secondary"> @item.BranchName </MudText>
                    </MudCardContent>
                </MudCard>
                </ItemContent>                
            </MudTimelineItem>
        }
    </MudTimeline>

}
@code {

    [Parameter]
    public TripModel Trip { get; set; }

    [Parameter]
    public EventCallback<int?> OnEventCount { get; set; }

    private List<EventModel> TripEvents = new();
    private List<EventTypeModel> EventTypes = new();



    protected async override Task OnInitializedAsync()
    {
        EventTypes = Ievent.GetEventTypes().ToList();
         await LoadEvents();
    }

    public async Task LoadEvents()
    {
        if (Trip == null)
            TripEvents = new();
        else
        {
            TripEvents = Ievent.SelectByTrip(Trip.TripID).ToList();
            await OnEventCount.InvokeAsync(TripEvents.Count());
        }
    }

    private async Task UpdateEvent(EventModel ev)
    {
        var parameters = new DialogParameters();        
        parameters.Add("CurrentTrip", Trip);
        parameters.Add("model", ev);

        var result = DialogService.Show<UpdateEventView>("Edit Event", parameters);
        var Data = await result.Result;
    }

}
