@page "/TriptransactionView"
@inject ITripTransactionService Iservice
@inject MudBlazor.ISnackbar snackbar
@attribute [Authorize]
@inject AuthenticationStateProvider auth

<MudGrid Spacing="4">
    <MudItem xs="12" md="12">
        <MudCard Elevation="10">
            <EditForm Model="@model" OnValidSubmit="OnValidSubmit">
                <DataAnnotationsValidator />
                <ValidationSummary />
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6">Add/Edit Transaction Types</MudText>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent>
                    <MudGrid Spacing="4">
                        <MudItem xs="12" md="6">
                            <MudTextField @bind-Value="@model.TTName" Label="Transaction Type" Variant="Variant.Outlined" Margin="Margin.Normal" For="@(() => model.TTName)"></MudTextField>
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <MudTextField @bind-Value="@model.Nature" Label="Nature (eg: FUEL)" Variant="Variant.Outlined" Margin="Margin.Normal" For="@(() => model.TTName)"></MudTextField>
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <MudSelect Label="Select Type" T="string" @bind-Value="@model.CrDr" Variant="Variant.Outlined" Margin="Margin.Normal" OffsetY="true" AdornmentColor="Color.Secondary">
                                <MudSelectItem  Value="@("Cr")" > Income </MudSelectItem>
                                <MudSelectItem Value="@("Cr")"> Expense </MudSelectItem>
                            </MudSelect>
                         </MudItem>
                            <MudItem xs="12" md="6">
                                <MudTextField @bind-Value="@model.Unit" Label="Unit" Variant="Variant.Outlined" Margin="Margin.Normal" For="@(() => model.TTName)"></MudTextField>
                            </MudItem>
                            <MudItem xs="12" md="6">
                                <MudCheckBox @bind-Checked="@model.AllowMultiple" Label="Allow Multiple?" For="@(() => model.AllowMultiple)" />
                            </MudItem>

                    </MudGrid>
                    <MudButton Variant="Variant.Filled" Color="Color.Success" ButtonType="ButtonType.Submit">Save</MudButton>

                </MudCardContent>
            </EditForm>
        </MudCard>
    </MudItem>
    <MudItem xs="12" md="12">
        <MudTable Items="@collection" Elevation="10" Filter="new Func<TripTransactionTypeModel, bool>(search)" @bind-model="model">
            <ToolBarContent>
                <MudText Typo="Typo.h6">Parties</MudText>
                <MudToolBarSpacer></MudToolBarSpacer>
                <MudTextField @bind-Value="searchString" Placeholder="Search ... "
                              Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                              IconSize="Size.Medium" Class="mt-0"></MudTextField>
            </ToolBarContent>
            <HeaderContent>
                <MudTh><MudTableSortLabel SortBy="new Func<TripTransactionTypeModel, object>(x=> x.TTName)" InitialDirection="SortDirection.Ascending">Transaction Type</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<TripTransactionTypeModel, object>(x=> x.Nature)" InitialDirection="SortDirection.Ascending">Nature</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<TripTransactionTypeModel, object>(x=> x.Unit)" InitialDirection="SortDirection.Ascending">Unit</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<TripTransactionTypeModel, object>(x=> x.CrDr)" InitialDirection="SortDirection.Ascending">Inc/Exp</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<TripTransactionTypeModel, object>(x=> x.AllowMultiple)" InitialDirection="SortDirection.Ascending">Allow Multiple</MudTableSortLabel></MudTh>                
                <MudTh>Actions</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Name">@context.TTName</MudTd>
                <MudTd DataLabel="Nature">@context.Nature</MudTd>
                <MudTd DataLabel="Unit">@context.Unit</MudTd>
                <MudTd DataLabel="Inc/Exp">@(context.CrDr == "Cr"?"Income":"Expense")</MudTd>
                <MudTd DataLabel="Allow Multiple">@context.AllowMultiple</MudTd>                
                <MudTd DataLabel="">                    
                    <MudFab @onclick="@(()=> Edit(context.TransactionTypeID))" Color="Color.Primary" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" IconSize="Size.Small" />
                    @*<MudFab @onclick="@(()=> Delete(context.TransactionTypeID))" Color="Color.Primary" Icon="@Icons.Material.Filled.Delete" Size="Size.Small" IconSize="Size.Small" />*@
                </MudTd>
            </RowTemplate>
            <PagerContent>
                <MudTablePager PageSizeOptions="new int[] { 5, 10, 20, 50, 100 }" />
            </PagerContent>
        </MudTable>
    </MudItem>



</MudGrid>
@code {

    private TripTransactionTypeModel model = new();
    private List<TripTransactionTypeModel> collection = new List<TripTransactionTypeModel>();
       
    private string searchString = "";

    protected override async Task OnInitializedAsync()
    {
        GetAll();
    }

    private void GetAll()
    {
        foreach (var item in Iservice.GetTypes())
        {
            collection.Add(item);
        }
    }

    private async Task OnValidSubmit(EditContext context)
    {
        var authprov = await auth.GetAuthenticationStateAsync();
        model.UserInfo.UserID = authprov.User.Identity.Name;

        try
        {
            model = Iservice.UpdateType(model);
            snackbar.Add("Saved Successfully", Severity.Success);
            if (collection.Exists(x => x.TransactionTypeID == model.TransactionTypeID))
            {
                collection[collection.FindIndex(x => x.TransactionTypeID == model.TransactionTypeID)] = model;
            }
            else
            {
                collection.Add(model);
            }
            model = new();
        }
        catch (Exception ex)
        {
            snackbar.Add(ex.Message, Severity.Warning);
        }
    }

    private void Edit(int id)
    {
        model = collection.FirstOrDefault(x => x.TransactionTypeID == id);
    }
    private void Delete(int id)
    {
        //await Iservice.Delete(id, "Rijas");
        //snackbar.Add("Deleted Successfully", Severity.Success);
        //await GetAll();
    }


    private bool search(TripTransactionTypeModel model)
    {
        if (model.TTName != null && model.TTName.Contains(searchString, StringComparison.OrdinalIgnoreCase))
        {
            return true;
        }
        return false;
    }
}



