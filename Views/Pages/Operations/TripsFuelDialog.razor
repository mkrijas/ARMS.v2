
@inject MudBlazor.ISnackbar snackbar
@inject AuthenticationStateProvider auth
@inject IInventoryItemService IsInvService
@inject IDimensionService dimensionIservice
@inject ICostCenterService costIservice
@attribute [Authorize]
@inject IDialogService DialogService
<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.Build" Class="mr-3 mb-n1" />
            Create Trip Fueling
        </MudText>
    </TitleContent>
    <DialogContent>
         <MudContainer Style="min-height:300px;max-height: 800px;">
                         <EditForm id="formtdsRate" Model="@model" OnValidSubmit="OnValidSubmit">
                <ObjectGraphDataAnnotationsValidator />
                <ValidationSummary />
                <MudPaper>
                     <MudGrid Spacing="2">
                    <MudItem xs="12" md="4">
                        <MudTextField @bind-Value="model.EntryDate" Label="Date" Variant="Variant.Outlined" Margin="Margin.Normal" For="@(() => model.EntryDate)"></MudTextField>
                    </MudItem>
                    <MudItem xs="12" md="4">
                        <MudSelect Label="Select Item " @bind-Value="model.FuelItemID" T="int?" Variant="Variant.Outlined" Margin="Margin.Dense" OffsetY="true" Direction="Direction.Top" AdornmentColor="Color.Secondary">
                            @foreach (var ditem in Ac)
                            {
                                <MudSelectItem Value="@ditem.InventoryItemID">@ditem.InventoryItemCode</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                      <MudItem xs="12" md="4">
                        <MudTextField @bind-Value="model.Quantity" Label="Quantity" Variant="Variant.Outlined" Margin="Margin.Normal" For="@(() => model.Quantity)"></MudTextField>
                      </MudItem>
                        <MudItem xs="12" md="4">
                            <MudCheckBox  Label="Is Purchase" T="bool" CheckedChanged="IsPurchase"></MudCheckBox>
                            </MudItem>
                         </MudGrid>
                </MudPaper>
                    
                 <MudPaper Class="@IsPurView">
                    <MudGrid Spacing="2">
                        <MudItem xs="12" md="12">
                           <PartySelector @bind-Value="model.PartyBranch"></PartySelector>
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <MudSelect Label="Select CostCenter" @bind-Value="model.Costcenter" T="int?" Variant="Variant.Outlined" Margin="Margin.Dense" OffsetY="true" Direction="Direction.Top" AdornmentColor="Color.Secondary">
                                @foreach (var ditem in costCenter)
                                {
                                    <MudSelectItem Value="@ditem.CostCenterID">@ditem.CostCenter</MudSelectItem>
                                }
                            </MudSelect>
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <MudSelect Label="Select Dimension" @bind-Value="model.Dimension" T="int?" Variant="Variant.Outlined" Margin="Margin.Dense" OffsetY="true" Direction="Direction.Top" AdornmentColor="Color.Secondary">
                                @foreach (var ditem in dimension)
                                {
                                    <MudSelectItem Value="@ditem.DimensionID">@ditem.Dimension</MudSelectItem>
                                }
                            </MudSelect>
                        </MudItem>
                         <MudItem xs="12" md="6">
                            <MudTextField @bind-Value="model.RatePerLitre" Label="Rate Per Liter" Variant="Variant.Outlined" Margin="Margin.Normal" For="@(() => model.RatePerLitre)"></MudTextField>
                             </MudItem>
                        <MudItem xs="12" md="6">
                            <MudTextField @bind-Value="model.TotalAmount" Label="Quantity" Variant="Variant.Outlined" Margin="Margin.Normal" For="@(() => model.TotalAmount)" ReadOnly="true"></MudTextField>
                        </MudItem>
                    </MudGrid>
                     </MudPaper>
                             </EditForm>
             </MudContainer>
    </DialogContent>
</MudDialog>


@code {
    [Parameter]
    public TripFuelModel model { get; set; }
    private List<CostCenterModel> costCenter = new();
    private List<DimensionModel> dimension = new();
    private List<InventoryItemModel> Ac = new();
    public bool IsPur { get; set; } = true;
    public string IsPurView { get; set; } = "Invisible";
    [CascadingParameter] MudDialogInstance MudDialog { get; set; }
    private void OnValidSubmit(EditContext context)
    {
        //model.MappedCoaID = SelectedAccount.CoaID;
        // MudDialog.Close(model);
    }
    protected override async Task  OnInitializedAsync()
    {
        costCenter = costIservice.Select().ToList();
        dimension = dimensionIservice.Select().ToList();
        //Ac = IsInvService.SelectByID(0).ToList();
    }
    private void IsPurchase()
    {
        IsPurView = "Visible";
    }
}
