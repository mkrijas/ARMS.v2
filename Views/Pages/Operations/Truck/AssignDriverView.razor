@using System.Threading;
@attribute [Authorize]
@inject AuthenticationStateProvider auth
@inject ITruckService Iservice
@inject IDriverService Idriver
@inject MudBlazor.ISnackbar snackbar
@inject IDialogService DialogService
@inject IRoleService<RoleModel> Irole

<MudDialog Class="admin-dialog-glass">
    <TitleContent>
        <div class="header-section mb-2 pt-4 px-4">
            <div class="d-flex align-center justify-space-between">
                <div class="d-flex align-center">
                    <div class="icon-badge primary-badge mr-4">
                        <div class="admin-header-icon-badge mb-3">
                            <MudIcon Icon="@Icons.Material.Filled.AssignmentInd" Color="Color.Secondary" Style="font-size: 3rem;" />
                        </div>
                    </div>
                    <div>
                        <MudText Typo="Typo.h5" Class="admin-title"><b>Crew Assignment</b></MudText>
                        <MudText Typo="Typo.body2" Class="admin-subtitle">Link a certified driver to the vehicle registry for active duty deployment.</MudText>
                    </div>
                </div>
            </div>
            <div class="title-accent mt-4"></div>
        </div>
    </TitleContent>
    <DialogContent>
        <MudContainer Class="admin-dialog-container">
            <div class="dialog-content-wrapper pa-4">
                <EditForm id="formAssign" Model="@Truck" OnValidSubmit="AssignDriver">
                    <div class="admin-glass-card pa-6 mb-6">
                        <MudGrid Spacing="4">
                            <MudItem xs="12" md="6">
                                <div class="pa-4 rounded-lg d-flex align-center" style="background: rgba(54, 117, 136, 0.05); border: 1px solid rgba(54, 117, 136, 0.1);">
                                    <MudIcon Icon="@Icons.Material.Filled.LocalShipping" Color="Color.Primary" Size="Size.Large" Class="mr-4" />
                                    <div>
                                        <MudText Typo="Typo.caption" Class="admin-subtitle">Vehicle Registry</MudText>
                                        <MudText Typo="Typo.h5"><b>@Truck.RegNo</b></MudText>
                                    </div>
                                </div>
                            </MudItem>
                            <MudItem xs="12" md="6">
                                <div class="pa-4 rounded-lg d-flex align-center" style="background: @(AssignedDriver == null ? "rgba(255, 152, 0, 0.05)" : "rgba(76, 175, 80, 0.05)"); border: 1px solid @(AssignedDriver == null ? "rgba(255, 152, 0, 0.2)" : "rgba(76, 175, 80, 0.2)");">
                                    <MudIcon Icon="@Icons.Material.Filled.AirlineSeatReclineNormal" Color="@(AssignedDriver == null ? Color.Warning : Color.Success)" Size="Size.Large" Class="mr-4" />
                                    <div>
                                        <MudText Typo="Typo.caption" Class="admin-subtitle">Currently Assigned</MudText>
                                        <MudText Typo="Typo.h5" Color="@(AssignedDriver == null ? Color.Warning : Color.Success)">
                                            <b>@(AssignedDriver?.DriverName ?? "UNASSIGNED")</b>
                                        </MudText>
                                    </div>
                                </div>
                            </MudItem>
                        </MudGrid>
                    </div>

                    <div class="admin-glass-card pa-6">
                        <MudGrid>
                            <MudItem xs="12">
                                <div class="d-flex align-center mb-4">
                                    <MudIcon Icon="@Icons.Material.Filled.PersonAdd" Color="Color.Primary" Class="mr-2" />
                                    <MudText Typo="Typo.subtitle1"><b>Deployment Dispatch</b></MudText>
                                </div>
                                <MudAutocomplete T="DriverModel" 
                                                 Label="Subject Driver" 
                                                 @bind-Value="SelectedDriver" 
                                                 ResetValueOnEmptyText="true" 
                                                 SearchFunc="SearchDrivers" 
                                                 ToStringFunc="@(e => e == null ? null : $"{e.DriverCode} | {e.DriverName}")" 
                                                 Variant="Variant.Outlined" 
                                                 Margin="Margin.Normal"
                                                 Class="modern-input"
                                                 Adornment="Adornment.Start"
                                                 AdornmentIcon="@Icons.Material.Filled.Search" />
                            </MudItem>
                        </MudGrid>
                    </div>
                </EditForm>
            </div>
        </MudContainer>
    </DialogContent>
    <DialogActions>
        <div class="d-flex w-100 flex-wrap pa-4 gap-3 align-center">
            @if (AssignedDriver != null)
            {
                <MudButton Variant="Variant.Outlined" Color="Color.Error" OnClick="RemoveDriver" Class="rounded-xl px-6" Style="background: rgba(244, 67, 54, 0.05) !important;">
                    Decommission Driver
                </MudButton>
            }
            <MudSpacer />
            <MudButton @onclick="Cancel" Variant="Variant.Outlined" Color="Color.Default" Style="border-radius: 12px; font-weight: 700; text-transform: none; border-color: rgba(0,0,0,0.15);">Discard</MudButton>
            <MudButton form="formAssign" Variant="Variant.Filled" ButtonType="ButtonType.Submit" Color="Color.Success" Style="background: var(--mud-palette-success); color: white; font-weight: 800; border-radius: 12px; text-transform: none; white-space: nowrap; padding: 8px 32px;" StartIcon="@Icons.Material.Filled.AssignmentTurnedIn">Authorize Assignment</MudButton>
        </div>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; }
    [Parameter] public TruckModel Truck { get; set; }
    [Parameter] public DriverModel AssignedDriver { get; set; }
    private DriverModel SelectedDriver = null;
    private List<DriverModel> drivers;
    string UserID;
    int BranchID;

    public bool HasPermissionITruckServiceAssignDriver { get; set; } = false;
    public int DocTypeID = 37;

    private void Cancel()
    {
        MudDialog.Cancel();
    }

    private async Task RemoveDriver()
    {
        if (HasPermissionITruckServiceAssignDriver)
        {
            int result = Iservice.UpdateDriver(Truck.TruckID, AssignedDriver.DriverID, false, UserID);
            DriverModel nullDriver = null;
            MudDialog.Close(DialogResult.Ok(nullDriver));
        }
        else
        {
            bool? result = await DialogService.ShowMessageBoxAsync(
                "Permission denied!",
                "You don't have any permission to Assign or Remove Driver in Truck.");
        }
    }

    protected override async Task OnInitializedAsync()
    {
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionITruckServiceAssignDriver = await Irole.HasClaim(DocTypeID.ToString(), "AssignDriver", ctc.Token);

        var authprov = await auth.GetAuthenticationStateAsync();
        UserID = authprov.User.Identity.Name;
        BranchID = int.Parse(authprov.User.Claims.FirstOrDefault(x => x.Type == "BranchID").Value);
        var driverID = Iservice.GetAssignedDriver(Truck.TruckID);
        if (driverID != null)
            AssignedDriver = Idriver.SelectByID(driverID.Value);
        drivers = Idriver.SelectByBranch(BranchID).Where(x => x.HasValidLicense && x.TruckID == null && x.UserInfo.RecordStatus == 3).ToList();
    }

    private async Task<IEnumerable<DriverModel>> SearchDrivers(string searchString, CancellationToken token)
    {
        return await Task.FromResult(drivers.Where(x => x.DriverName.Contains(searchString == null ? string.Empty : searchString, StringComparison.InvariantCultureIgnoreCase)
                                                    || (x.DriverCode.Contains(searchString == null ? string.Empty : searchString, StringComparison.InvariantCultureIgnoreCase))));
    }

    private async Task AssignDriver(EditContext context = null)
    {
        if (HasPermissionITruckServiceAssignDriver)
        {
            try
            {
                var authprov = await auth.GetAuthenticationStateAsync();
                int BranchIdLocal = 0;
                if (!int.TryParse(authprov.User.Claims.First(c => c.Type == "BranchID")?.Value, out BranchIdLocal))
                {
                    snackbar.Add("Branch is Not Selected", Severity.Warning);
                    return;
                }
                if (SelectedDriver == null)
                {
                    snackbar.Add("Please Select Driver", Severity.Warning);
                    return;
                }
                int? CurrentTruck = Idriver.GetAssignedTruck(SelectedDriver.DriverID);
                if (CurrentTruck != null)
                {
                    snackbar.Add("Already assigned to " + Iservice.SelectByID(CurrentTruck).RegNo, Severity.Warning);
                    return;
                }
                int result = Iservice.UpdateDriver(Truck.TruckID, SelectedDriver.DriverID, true, authprov.User.Identity.Name);
                MudDialog.Close(DialogResult.Ok(SelectedDriver));
            }
            catch (Exception ex)
            {
                snackbar.Add(ex.Message, Severity.Warning);
            }
        }
        else
        {
            bool? result = await DialogService.ShowMessageBoxAsync(
                "Permission denied!",
                "You don't have any permission to Assign or Remove Driver in Truck.");
        }
    }
}
