@using System.Threading;
@attribute [Authorize]
@inject AuthenticationStateProvider auth
@inject ITruckService Iservice
@inject IDriverService Idriver
@inject MudBlazor.ISnackbar snackbar
@inject IDialogService DialogService
@inject IRoleService<RoleModel> Irole

<MudDialog>
    <DialogContent>
        <MudGrid Spacing="4">
            <MudItem xs="12" md="12">
                <MudText Typo="Typo.h4"><MudIcon Icon="@Icons.Material.Filled.LocalShipping" /> @Truck.RegNo</MudText>
            </MudItem>
            <MudItem xs="12" md="12">
                @if (AssignedDriver == null)
                {
                    <MudText Typo="Typo.h4" Color="Color.Warning"><MudIcon Icon="@Icons.Material.Filled.AirlineSeatReclineNormal" Title="Driver" /> NONE</MudText>
                }
                else
                {
                    <MudText class="subbutn"><MudIcon Icon="@Icons.Material.Filled.AirlineSeatReclineNormal" Title="Driver" /> @AssignedDriver.DriverName</MudText>
                }
                <MudText></MudText>
            </MudItem>
            <MudItem xs="12" md="6">
                <MudAutocomplete T="DriverModel" Label="Select Driver" @bind-Value="SelectedDriver" ResetValueOnEmptyText="true" SearchFunc="SearchDrivers" ToStringFunc="@(e => e == null ? null : $"{e.DriverCode} | {e.DriverName}")" Variant="Variant.Outlined" Margin="Margin.Dense"></MudAutocomplete>
            </MudItem>
        </MudGrid>
    </DialogContent>
    <DialogActions>
        @if (AssignedDriver != null)
        {
            <MudButton OnClick="RemoveDriver">Remove Driver</MudButton>
        }
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton form="form" Variant="Variant.Filled" Class="scsbtn" ButtonType="ButtonType.Submit" OnClick="AssignDriver">Assign Driver</MudButton>
    </DialogActions>
</MudDialog>
  
@code {

    [CascadingParameter] MudDialogInstance MudDialog { get; set; }
    [Parameter] public TruckModel Truck { get; set; }
    [Parameter] public DriverModel AssignedDriver { get; set; }
    private DriverModel SelectedDriver = null;
    private List<DriverModel> drivers;
    string UserID;
    int BranchID;

    public bool HasPermissionITruckServiceAssignDriver { get; set; } = false;
    public int DocTypeID = 37;

    private void Cancel()
    {
        MudDialog.Cancel();
    }

    private async Task RemoveDriver()
    {
        if (HasPermissionITruckServiceAssignDriver)
        {
            int result = Iservice.UpdateDriver(Truck.TruckID, AssignedDriver.DriverID, false, UserID);
            DriverModel nullDriver = null;
            MudDialog.Close(DialogResult.Ok(nullDriver));
        }
        else
        {
            bool? result = await DialogService.ShowMessageBox(
                "Permission denied!",
                "You don't have any permission to Assign or Remove Driver in Truck.");
        }
    }

    protected override async Task OnInitializedAsync()
    {
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionITruckServiceAssignDriver = await Irole.HasClaim(DocTypeID.ToString(), "AssignDriver", ctc.Token);

        var authprov = await auth.GetAuthenticationStateAsync();
        UserID = authprov.User.Identity.Name;
        BranchID = int.Parse(authprov.User.Claims.FirstOrDefault(x => x.Type == "BranchID").Value);
        var driverID = Iservice.GetAssignedDriver(Truck.TruckID);
        if (driverID != null)
            AssignedDriver = Idriver.SelectByID(driverID.Value);
        drivers = Idriver.SelectByBranch(BranchID).Where(x => x.HasValidLicense && x.TruckID == null && x.UserInfo.RecordStatus == 3).ToList();
    }

    private async Task<IEnumerable<DriverModel>> SearchDrivers(string searchString)
    {
        return await Task.FromResult(drivers.Where(x => x.DriverName.Contains(searchString == null ? string.Empty : searchString, StringComparison.InvariantCultureIgnoreCase)
                                                    || (x.DriverCode.Contains(searchString == null ? string.Empty : searchString, StringComparison.InvariantCultureIgnoreCase))));
    }

    private async Task AssignDriver()
    {
        if (HasPermissionITruckServiceAssignDriver)
        {
            try
            {
                var authprov = await auth.GetAuthenticationStateAsync();
                int BranchID = 0;
                if (!int.TryParse(authprov.User.Claims.First(c => c.Type == "BranchID")?.Value, out BranchID))
                {
                    snackbar.Add("Branch is Not Selected", Severity.Warning);
                    return;
                }
                if (SelectedDriver == null)
                {
                    snackbar.Add("Please Select Driver", Severity.Warning);
                    return;
                }
                int? CurrentTruck = Idriver.GetAssignedTruck(SelectedDriver.DriverID);
                if (CurrentTruck != null)
                {
                    snackbar.Add("Already assigned to " + Iservice.SelectByID(CurrentTruck).RegNo, Severity.Warning);
                    return;
                }
                int result = Iservice.UpdateDriver(Truck.TruckID, SelectedDriver.DriverID, true, authprov.User.Identity.Name);
                MudDialog.Close(DialogResult.Ok(SelectedDriver));
            }
            catch (Exception ex)
            {
                snackbar.Add(ex.Message, Severity.Warning);
            }
        }
        else
        {
            bool? result = await DialogService.ShowMessageBox(
                "Permission denied!",
                "You don't have any permission to Assign or Remove Driver in Truck.");
        }
    }
}