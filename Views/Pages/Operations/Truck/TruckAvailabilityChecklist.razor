@using System.IO
@using System.Threading;
@using Core.BaseModels.Operations;
@using Core.IDataServices.Operations;
@inject AuthenticationStateProvider auth
@inject ITruckAvailabilityService Iservice
@inject IBranchService Ibranchservice
@inject IAssetService IassetService
@inject IAssetSettingsService Iassetsettingsservice
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject IRoleService<RoleModel> Irole

<MudDialog Class="admin-dialog-glass">
    <TitleContent>
        <div class="header-section mb-2 pt-4 px-4">
            <div class="d-flex align-center justify-space-between">
                <div class="d-flex align-center">
                    <div class="icon-badge primary-badge mr-4">
                        <div class="admin-header-icon-badge mb-3">
                            <MudIcon Icon="@Icons.Material.Filled.FactCheck" Color="Color.Secondary" Style="font-size: 3rem;" />
                        </div>
                    </div>
                    <div>
                        <MudText Typo="Typo.h5" Class="admin-title"><b>Vehicle Health Assessment</b></MudText>
                        <MudText Typo="Typo.body2" Class="admin-subtitle">Perform routine inspections and document condition with multi-media evidence.</MudText>
                    </div>
                </div>
            </div>
            <div class="title-accent mt-4"></div>
        </div>
    </TitleContent>
    <DialogContent>
        <MudContainer Class="admin-dialog-container">
            <div class="dialog-content-wrapper pa-4">
                <EditForm id="formAvailability" Model="@model" OnValidSubmit="Update">
                    <ObjectGraphDataAnnotationsValidator />
                    <ValidationSummary />
                    @if (model.CheckList != null && model.CheckList.Any())
                    {
                        <div class="admin-glass-card pa-6 mb-6">
                            <div class="d-flex align-center mb-6">
                                <MudIcon Icon="@Icons.Material.Filled.PlaylistAddCheck" Color="Color.Primary" Class="mr-2" />
                                <span class="admin-section-label mb-0">Systemic Condition Checklist</span>
                            </div>
                            
                            <div class="modern-checklist">
                                @foreach (var item in model.CheckList)
                                {
                                    <div class="checklist-item-modern mb-6 pa-4 @(model.RequestStatus == 0 ? "editable-item" : "readonly-item")" style="background: rgba(var(--mud-palette-primary-rgb), 0.03); border-radius: 12px; border-left: 4px solid var(--mud-palette-primary);">
                                        <div class="d-flex justify-between align-center mb-3">
                                            <MudText Typo="Typo.subtitle1" Class="fw-bold fw-600">@item.SettingsName</MudText>
                                            @if (model.RequestStatus != 0)
                                            {
                                                <MudChip T="string" Size="Size.Small" Color="@(item.Condition == "Excellent" ? Color.Success : item.Condition == "Good" ? Color.Info : Color.Warning)" Variant="Variant.Filled">@item.Condition</MudChip>
                                            }
                                        </div>

                                        @if (model.RequestStatus == 0)
                                        {
                                            <div class="checklist-controls">
                                                @if (item.ValueInput == true)
                                                {                                               
                                                    <MudTextField @bind-Value="item.Value" Label="Specific Measurement / Metric" Variant="Variant.Outlined" Margin="Margin.Dense" Class="modern-input mb-3" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Straighten"></MudTextField>
                                                }
                                                <MudRadioGroup T="string" @bind-Value="@item.Condition" Class="d-flex flex-wrap gap-4">
                                                    <MudRadio Value="@("Excellent")" Color="Color.Tertiary" UnCheckedColor="Color.Default" Dense="true">Excellent</MudRadio>
                                                    <MudRadio Value="@("Good")" Color="Color.Primary" UnCheckedColor="Color.Default" Dense="true">Good</MudRadio>
                                                    <MudRadio Value="@("Poor")" Color="Color.Secondary" UnCheckedColor="Color.Default" Dense="true">Poor</MudRadio>
                                                    <MudRadio Value="@("Not Available")" UnCheckedColor="Color.Default" Dense="true">N/A</MudRadio>
                                                </MudRadioGroup>
                                            </div>
                                        }
                                        else
                                        {
                                            <div class="d-flex align-center gap-4">
                                                @if (!string.IsNullOrEmpty(item.Value))
                                                {
                                                    <MudText Typo="Typo.body2" Class="color-muted">Value: <b class="color-text">@item.Value</b></MudText>
                                                }
                                                <MudText Typo="Typo.body2" Class="color-muted">Status: <b class="color-text">@item.Status</b></MudText>
                                            </div>
                                        }
                                    </div>
                                }
                            </div>
                        </div>
                    }

                    <div class="admin-glass-card pa-6">
                        <div class="d-flex align-center justify-between mb-6">
                            <div class="d-flex align-center">
                                <MudIcon Icon="@Icons.Material.Filled.Collections" Color="Color.Warning" Class="mr-2" />
                                <span class="admin-section-label mb-0">Multi-Media Documentation</span>
                            </div>
                            @if (model.RequestStatus == 0)
                            {
                                <MyFileUpload @ref="Mfu" AllowMultiple="true" Resize="false" DeleteExistingFile="false" FileName="@Guid.NewGuid().ToString()" FolderName="@("Truck/Transfer-"+model.RequestApprovalHistoryID.ToString())" Label="Append media evidence" FilePathChanged="FileUploaded"></MyFileUpload>
                            }
                        </div>

                        <div class="media-evidence-gallery">
                            <MudGrid Spacing="3">
                                @if (model?.Uploads != null && model.Uploads.Any())
                                {
                                    foreach (var imagePath in model.Uploads.Where(x => !string.IsNullOrWhiteSpace(x)))
                                    {
                                        var extension = Path.HasExtension(imagePath) ? Path.GetExtension(imagePath).ToLower() : string.Empty;
                                        var isVideo = extension is ".mp4" or ".mov" or ".avi";

                                        <MudItem xs="12" sm="6" md="4">
                                            <div class="premium-media-card">
                                                <div class="media-container @(isVideo ? "video-wrapper" : "image-wrapper")">
                                                    @if (isVideo)
                                                    {
                                                        <video src="@imagePath" controls />
                                                    }
                                                    else
                                                    {
                                                        <MudImage src="@imagePath" alt="Evidence" Fluid="true" ObjectFit="ObjectFit.Cover" Class="rounded-lg shadow-sm" Style="height: 180px; width: 100%;" />
                                                    }
                                                    
                                                    @if (model.RequestStatus == 0)
                                                    {
                                                        <div class="media-actions-overlay">
                                                            <MudIconButton Icon="@Icons.Material.Rounded.DeleteOutline" Color="Color.Error" Variant="Variant.Filled" OnClick="() => DeleteImage(imagePath)" Size="Size.Small" />
                                                            <MudIconButton Icon="@Icons.Material.Filled.FileDownload" Color="Color.Surface" Variant="Variant.Filled" Href="@imagePath" download Size="Size.Small" />
                                                        </div>
                                                    }
                                                    else
                                                    {
                                                        <div class="media-actions-overlay visible">
                                                            <MudIconButton Icon="@Icons.Material.Filled.FileDownload" Color="Color.Surface" Variant="Variant.Filled" Href="@imagePath" download Size="Size.Small" />
                                                        </div>
                                                    }
                                                </div>
                                            </div>
                                        </MudItem>
                                    }
                                }
                                else
                                {
                                    <MudItem xs="12">
                                        <div class="empty-media-state py-12 text-center rounded-lg border-2 border-dashed" style="border-color: rgba(var(--mud-palette-warning-rgb), 0.2); background: rgba(var(--mud-palette-warning-rgb), 0.02);">
                                            <MudIcon Icon="@Icons.Material.Filled.NoPhotography" Size="Size.Large" Color="Color.Warning" Style="opacity: 0.3" />
                                            <MudText Typo="Typo.body2" Class="color-muted mt-2">No visual evidence uploaded yet.</MudText>
                                        </div>
                                    </MudItem>
                                }
                            </MudGrid>
                        </div>
                    </div>
                </EditForm>
            </div>
        </MudContainer>
    </DialogContent>
    <DialogActions>
        <div class="d-flex w-100 flex-wrap pa-4 gap-3 align-center">
            <MudSpacer />
            <MudButton @onclick="Cancel" Variant="Variant.Outlined" Color="Color.Default" Style="border-radius: 12px; font-weight: 700; text-transform: none; border-color: rgba(0,0,0,0.15);">Discard</MudButton>
            <MudButton Disabled="@_busy" form="formAvailability" Variant="Variant.Filled" ButtonType="ButtonType.Submit" Color="Color.Success" Style="background: var(--mud-palette-success); color: white; font-weight: 800; border-radius: 12px; text-transform: none; white-space: nowrap; padding: 8px 24px;" StartIcon="@Icons.Material.Filled.DoneAll">Submit Assessment</MudButton>
        </div>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; }
    private bool _busy;
    [Parameter]
    public RequestApprovalHistoryModel model { get; set; } = new();
    private int? BranchID { get; set; } = 0;
    MyFileUpload Mfu;
    public AssetModel Asset { get; set; } = new();
    public bool HasPermissionTruckAvailabilityServiceEdit { get; set; } = false;
    public int TruckAvailabilityDocTypeID = 139;

    protected override async Task OnInitializedAsync()
    {
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionTruckAvailabilityServiceEdit = await Irole.HasClaim(TruckAvailabilityDocTypeID.ToString(), "Edit", ctc.Token);

        var authprov = await auth.GetAuthenticationStateAsync();
        var brancIDString = authprov.User.Claims.First(x => x.Type == "BranchID").Value;
        BranchID = int.Parse(brancIDString);
        
        model.CheckList = Iservice.GetCheckList(model.RequestApprovalHistoryID).ToList();

        if (model.CheckList == null || !model.CheckList.Any())
        {
            Asset = IassetService.SelectByTruckID(model.TruckID);
            model.CheckList = Iassetsettingsservice.GetSettings(Asset.SubClass.AssetSubClassID, model.TruckID).ToList();
        }

        if (model.Uploads == null)
            model.Uploads = new List<string>();
    }

    protected override void OnParametersSet()
    {

    }

    void Cancel()
    {
        MudDialog.Cancel();
    }

    // Method to handle file uploads
    private void FileUploaded(string filePath)
    {
        var webPath = "/" + filePath.Replace("\\", "/");
        model.Uploads.Add(webPath);
    }

    // Method to delete an image associated with the insurance claim
    private async Task DeleteImage(string imagePath)
    {
        model.Uploads.Remove(imagePath);
    }

    public async Task Update()
    {
        if (HasPermissionTruckAvailabilityServiceEdit)
        {
            var authprov = await auth.GetAuthenticationStateAsync();
            var user = authprov.User;

            if (model.Uploads == null || !model.Uploads.Any())
            {
                Snackbar.Add("At least one upload is required!", Severity.Warning);
                return;
            }

            if (model != null)
            {
                foreach (var item in model.CheckList)
                {
                    if (item.ValueInput == true)
                    {
                        if (string.IsNullOrWhiteSpace(item.Value))
                        {
                            Snackbar.Add($"Please provide value for '{item.SettingsName}'", Severity.Warning);
                            return;
                        }
                        if (string.IsNullOrWhiteSpace(item.Condition))
                        {
                            Snackbar.Add($"Please select condition for '{item.SettingsName}'", Severity.Warning);
                            return;
                        }
                    }
                }

                try
                {
                    Iservice.UpdateCheckist(model);
                    Snackbar.Add("Updated succesfully", Severity.Success);
                }
                catch (Exception ex)
                {
                    Snackbar.Add(ex.Message, Severity.Error);
                }
            }
            MudDialog.Close(DialogResult.Ok(model));
        }
        else
        {
            bool? ResultModel = await DialogService.ShowMessageBoxAsync(
                "Permission denied!",
                "You don't have any permission to Approve Truck Request.");
        }
    }
}

