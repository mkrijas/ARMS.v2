@using System.IO
@using System.Threading;
@using Core.BaseModels.Operations;
@using Core.IDataServices.Operations;
@inject AuthenticationStateProvider auth
@inject IDialogService DialogService
@inject ITruckAvailabilityService Iservice

<MudDialog>
    <TitleContent>
        <b>Checklist</b>
    </TitleContent>
    <DialogContent>
        @foreach (var item in CheckList)
        {
            <MudItem xs="12">
                <MudText>@item.SettingsName - @item.Value - @item.Condition  </MudText>
                <br />
            </MudItem>
        }
    </DialogContent>
</MudDialog>

@code {

    [CascadingParameter] MudDialogInstance MudDialog { get; set; }
    [Parameter]
    public int? ID { get; set; } = new();
    public List<AssetSettingsModel> CheckList { get; set; }

    protected override void OnInitialized()
    {
        CheckList = Iservice.GetCheckList(ID).ToList();
    }

    void Cancel()
    {
        MudDialog.Cancel();
    }
}