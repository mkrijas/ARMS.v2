@using System.Threading;
@using Core.BaseModels.Operations;
@using Core.IDataServices.Operations;
@inject AuthenticationStateProvider auth
@inject ITruckAvailabilityService Iservice
@inject IBranchService Ibranchservice
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject IRoleService<RoleModel> Irole

<MudDialog Class="admin-dialog-glass">
    <TitleContent>
        <div class="header-section mb-2 pt-4 px-4">
            <div class="d-flex align-center justify-space-between">
                <div class="d-flex align-center">
                    <div class="icon-badge primary-badge mr-4">
                        <div class="admin-header-icon-badge mb-3">
                            <MudIcon Icon="@Icons.Material.Filled.SwapHoriz" Color="Color.Secondary" Style="font-size: 3rem;" />
                        </div>
                    </div>
                    <div>
                        <MudText Typo="Typo.h5" Class="admin-title"><b>@(model.RequestApprovalHistoryID == null || model.RequestApprovalHistoryID == 0 ? "Fleet Requisition" : "Modify Requisition")</b></MudText>
                        <MudText Typo="Typo.body2" Class="admin-subtitle">Initiate a request for vehicle availability from other branches to meet operational demand.</MudText>
                    </div>
                </div>
            </div>
            <div class="title-accent mt-4"></div>
        </div>
    </TitleContent>
    <DialogContent>
        <MudContainer Class="admin-dialog-container">
            <div class="dialog-content-wrapper pa-4">
                <EditForm id="formRequest" Model="@model" OnValidSubmit="Submit">
                    <div class="admin-glass-card pa-6">
                        <DataAnnotationsValidator />
                        <ValidationSummary />
                        <MudGrid>
                            <MudItem xs="12">
                                <TruckSelector For="@(() => model.Truck)" @bind-Value="model.Truck" Filter="@filter" HomeOrOperation="Home" TruckIDsToRemove="@SelectedTruckIDs" VariantParameter="Variant.Outlined" MarginParameter="Margin.Normal" Class="modern-input" />
                            </MudItem>
                            <MudItem xs="12">
                                <div class="pa-4 rounded-lg mt-2" style="background: rgba(54, 117, 136, 0.05); border: 1px dashed rgba(54, 117, 136, 0.3);">
                                    <MudText Typo="Typo.caption" Class="admin-subtitle d-flex align-center">
                                        <MudIcon Icon="@Icons.Material.Filled.Info" Size="Size.Small" Class="mr-1" />
                                        Requests will be subject to approval by the source branch manager.
                                    </MudText>
                                </div>
                            </MudItem>
                        </MudGrid>
                    </div>
                </EditForm>
            </div>
        </MudContainer>
    </DialogContent>
    <DialogActions>
        <div class="d-flex w-100 flex-wrap pa-4 gap-3 align-center">
            <MudSpacer />
            <MudButton Variant="Variant.Outlined" Color="Color.Default" OnClick="Cancel" Style="border-radius: 12px; font-weight: 700; text-transform: none; border-color: rgba(0,0,0,0.15);">Discard</MudButton>
            <MudButton Disabled="@_busy" form="formRequest" Variant="Variant.Filled" Color="Color.Primary" ButtonType="ButtonType.Submit" Style="background: var(--mud-palette-primary); color: white; font-weight: 800; border-radius: 12px; text-transform: none; white-space: nowrap; padding: 8px 32px;" StartIcon="@Icons.Material.Filled.Send">Initialize Request</MudButton>
        </div>
    </DialogActions>
</MudDialog>

@code {

    private bool _busy;
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; }
    [Parameter]
    public RequestApprovalHistoryModel model { get; set; } = new();
    [Parameter]
    public List<int?> SelectedTruckIDs { get; set; } = new();
    private List<int?> UnAssignedTruckIds = new();
    private List<int?> CurrentBranchTruckIDs = new();
    private string filter { get; set; } = "All";
    private int? BranchID { get; set; } = 0;

    protected override async Task OnInitializedAsync()
    {

        var authprov = await auth.GetAuthenticationStateAsync();
        var brancIDString = authprov.User.Claims.First(x => x.Type == "BranchID").Value;
        BranchID = int.Parse(brancIDString);
        model.RequestedBranchID = BranchID;
        var result = Iservice.GetAllTruckIdsByBranchID(BranchID);
        if (result != null)
        {
            CurrentBranchTruckIDs = result.ToList();
        }
    }

    protected override void OnParametersSet()
    {

    }

    void Cancel()
    {
        MudDialog.Cancel();
    }

    public async Task Submit()
    {
        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;
        if (model.Truck == null || model.Truck.TruckID == 0)
        {
            bool? result = await DialogService.ShowMessageBoxAsync(
                "Warning",
                "Please, Select truck.", yesText: "OK");
            return;
        }
        if (CurrentBranchTruckIDs != null && CurrentBranchTruckIDs.Any(s => s == model.Truck.TruckID))
        {
            Snackbar.Add("Truck exists in current branch.", Severity.Error);
            return;
        }
        bool throwException = false;
        if (model != null)
        {
            if (model.RequestedUserInfo == null)
            {
                model.RequestedUserInfo = new();
            }
            model.RequestedUserInfo.UserID = user.Identity.Name;
            model.RequestStatus = 0;
            try
            {
                model = Iservice.UpdateOutgoing(model);
                if (model.RespondedBranchID == BranchID)
                {
                    model.RespondedUserInfo = new();
                    model.RespondedBranchID = BranchID;
                    model.RequestStatus = 2;
                    model.RespondedUserInfo.UserID = user.Identity.Name;
                    model = Iservice.UpdateStatus(model, null);
                    Snackbar.Add("Truck Returned", Severity.Success);
                }
                else
                    Snackbar.Add("Requested succesfully", Severity.Success);
            }
            catch (Exception ex)
            {
                throwException = true;
                Snackbar.Add(ex.Message, Severity.Error);
            }
        }
        if (!throwException)
        {
            MudDialog.Close(model);
        }
    }

    private void TruckSelected(TruckModel obj)
    {
        model.Truck = obj;
    }
} 
