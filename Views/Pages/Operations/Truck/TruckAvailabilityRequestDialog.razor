@using System.Threading;
@using Core.BaseModels.Operations;
@using Core.IDataServices.Operations;
@inject AuthenticationStateProvider auth
@inject ITruckAvailabilityService Iservice
@inject IBranchService Ibranchservice
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject IRoleService<RoleModel> Irole

<MudDialog>
    <TitleContent>
        @if (model.RequestApprovalHistoryID == null || model.RequestApprovalHistoryID == 0)
        {
            <MudText Typo="Typo.h6">
                <MudIcon Icon="@Icons.Material.Filled.Edit" Class="mr-3" /> Add Truck Request.
            </MudText>
        }
        else
        {
            <MudText Typo="Typo.h6">
                <MudIcon Icon="@Icons.Material.Filled.Edit" Class="mr-3" /> Edit Truck Request.
            </MudText>
        }
    </TitleContent>
    <DialogContent>
        <EditForm id="formDriver" Model="@model" OnValidSubmit="Submit">
            <DataAnnotationsValidator />
            <ValidationSummary />
            <MudItem xs="12" md="12">
                <TruckSelector Value="model.Truck" Filter="@filter" HomeOrOperation="Home" TruckIDsToRemove="@SelectedTruckIDs" VariantParameter="Variant.Outlined" MarginParameter="Margin.Normal" ValueChanged="TruckSelected" />
            </MudItem>
        </EditForm>
    </DialogContent>
    <DialogActions>
        <MudButton Style="margin: 0px 15px 12px 0px;" Variant="Variant.Filled" Color="Color.Primary" OnClick="Submit" Class="px-12">Request</MudButton>
    </DialogActions>
</MudDialog>

@code {

    [CascadingParameter] MudDialogInstance MudDialog { get; set; }
    [Parameter]
    public RequestApprovalHistoryModel model { get; set; } = new();
    [Parameter]
    public List<int?> SelectedTruckIDs { get; set; } = new();
    private List<int?> UnAssignedTruckIds = new();
    private List<int?> CurrentBranchTruckIDs = new();
    private string filter { get; set; } = "All";
    private int? BranchID { get; set; } = 0;

    protected override async Task OnInitializedAsync()
    {

        var authprov = await auth.GetAuthenticationStateAsync();
        var brancIDString = authprov.User.Claims.First(x => x.Type == "BranchID").Value;
        BranchID = int.Parse(brancIDString);
        model.RequestedBranchID = BranchID;
        var result = Iservice.GetAllTruckIdsByBranchID(BranchID);
        if (result != null)
        {
            CurrentBranchTruckIDs = result.ToList();
        }
    }

    protected override void OnParametersSet()
    {

    }

    void Cancel()
    {
        MudDialog.Cancel();
    }

    public async Task Submit()
    {
        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;
        if (model.Truck == null || model.Truck.TruckID == 0)
        {
            bool? result = await DialogService.ShowMessageBox(
                "Warning",
                "Please, Select truck.", yesText: "OK");
            return;
        }
        if (CurrentBranchTruckIDs != null && CurrentBranchTruckIDs.Any(s => s == model.Truck.TruckID))
        {
            Snackbar.Add("Truck exists in current branch.", Severity.Error);
            return;
        }
        bool throwException = false;
        if (model != null)
        {
            if (model.RequestedUserInfo == null)
            {
                model.RequestedUserInfo = new();
            }
            model.RequestedUserInfo.UserID = user.Identity.Name;
            model.RequestStatus = 0;
            try
            {
                model = Iservice.UpdateOutgoing(model);
                if (model.RespondedBranchID == BranchID)
                {
                    model.RespondedUserInfo = new();
                    model.RespondedBranchID = BranchID;
                    model.RequestStatus = 2;
                    model.RespondedUserInfo.UserID = user.Identity.Name;
                    model = Iservice.UpdateStatus(model);
                    Snackbar.Add("Truck Returned", Severity.Success);
                }
                else
                    Snackbar.Add("Requested succesfully", Severity.Success);
            }
            catch (Exception ex)
            {
                throwException = true;
                Snackbar.Add(ex.Message, Severity.Error);
            }
        }
        if (!throwException)
        {
            MudDialog.Close(model);
        }
    }

    private void TruckSelected(TruckModel obj)
    {
        model.Truck = obj;
    }
} 