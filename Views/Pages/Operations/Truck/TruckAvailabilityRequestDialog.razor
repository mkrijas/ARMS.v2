@using System.Threading;
@using Core.BaseModels.Operations;
@using Core.IDataServices.Operations;
@inject AuthenticationStateProvider auth
@inject ITruckAvailabilityService Iservice
@inject IBranchService Ibranchservice
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject IRoleService<RoleModel> Irole

<DialogForm @ref="@dialogForm" Title="@(model.RequestApprovalHistoryID == null || model.RequestApprovalHistoryID == 0 ? "Fleet Requisition" : "Modify Requisition")" Subtitle="Initiate a request for vehicle availability from other branches to meet operational demand." Icon="@Icons.Material.Filled.SwapHoriz" AdminStyle="true" formID="formRequest" model="@model">
    <FormContent>
        <div class="dialog-content-wrapper pa-2">
            <EditForm id="formRequest" Model="@model" OnValidSubmit="Submit">
                <div class="admin-glass-card pa-6">
                    <DataAnnotationsValidator />
                    <ValidationSummary />
                    <MudGrid>
                        <MudItem xs="12">
                            <TruckSelector Value="model.Truck" Filter="@filter" HomeOrOperation="Home" TruckIDsToRemove="@SelectedTruckIDs" VariantParameter="Variant.Outlined" MarginParameter="Margin.Normal" ValueChanged="TruckSelected" Class="modern-input" />
                        </MudItem>
                        <MudItem xs="12">
                            <div class="pa-4 rounded-lg mt-2" style="background: rgba(54, 117, 136, 0.05); border: 1px dashed rgba(54, 117, 136, 0.3);">
                                <MudText Typo="Typo.caption" Class="admin-subtitle d-flex align-center">
                                    <MudIcon Icon="@Icons.Material.Filled.Info" Size="Size.Small" Class="mr-1" />
                                    Requests will be subject to approval by the source branch manager.
                                </MudText>
                            </div>
                        </MudItem>
                    </MudGrid>
                </div>
            </EditForm>
        </div>
    </FormContent>
    <Actions>
        <div class="d-flex pa-4 gap-4 w-100 justify-end align-center">
            <MudSpacer />
            <MudButton Size="Size.Large" form="formRequest" Variant="Variant.Filled" Color="Color.Primary" ButtonType="ButtonType.Submit" Class="action-btn-primary px-10" Style="background: #367588 !important; color: white !important;">
                Initialize Request
            </MudButton>
        </div>
    </Actions>
</DialogForm>

@code {

    private DialogForm dialogForm;
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; }
    [Parameter]
    public RequestApprovalHistoryModel model { get; set; } = new();
    [Parameter]
    public List<int?> SelectedTruckIDs { get; set; } = new();
    private List<int?> UnAssignedTruckIds = new();
    private List<int?> CurrentBranchTruckIDs = new();
    private string filter { get; set; } = "All";
    private int? BranchID { get; set; } = 0;

    protected override async Task OnInitializedAsync()
    {

        var authprov = await auth.GetAuthenticationStateAsync();
        var brancIDString = authprov.User.Claims.First(x => x.Type == "BranchID").Value;
        BranchID = int.Parse(brancIDString);
        model.RequestedBranchID = BranchID;
        var result = Iservice.GetAllTruckIdsByBranchID(BranchID);
        if (result != null)
        {
            CurrentBranchTruckIDs = result.ToList();
        }
    }

    protected override void OnParametersSet()
    {

    }

    void Cancel()
    {
        MudDialog.Cancel();
    }

    public async Task Submit()
    {
        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;
        if (model.Truck == null || model.Truck.TruckID == 0)
        {
            bool? result = await DialogService.ShowMessageBoxAsync(
                "Warning",
                "Please, Select truck.", yesText: "OK");
            return;
        }
        if (CurrentBranchTruckIDs != null && CurrentBranchTruckIDs.Any(s => s == model.Truck.TruckID))
        {
            Snackbar.Add("Truck exists in current branch.", Severity.Error);
            return;
        }
        bool throwException = false;
        if (model != null)
        {
            if (model.RequestedUserInfo == null)
            {
                model.RequestedUserInfo = new();
            }
            model.RequestedUserInfo.UserID = user.Identity.Name;
            model.RequestStatus = 0;
            try
            {
                model = Iservice.UpdateOutgoing(model);
                if (model.RespondedBranchID == BranchID)
                {
                    model.RespondedUserInfo = new();
                    model.RespondedBranchID = BranchID;
                    model.RequestStatus = 2;
                    model.RespondedUserInfo.UserID = user.Identity.Name;
                    model = Iservice.UpdateStatus(model, null);
                    Snackbar.Add("Truck Returned", Severity.Success);
                }
                else
                    Snackbar.Add("Requested succesfully", Severity.Success);
            }
            catch (Exception ex)
            {
                throwException = true;
                Snackbar.Add(ex.Message, Severity.Error);
            }
        }
        if (!throwException)
        {
            MudDialog.Close(model);
        }
    }

    private void TruckSelected(TruckModel obj)
    {
        model.Truck = obj;
    }
} 
