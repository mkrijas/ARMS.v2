@using System.IO
@using System.Threading;
@using Core.BaseModels.Operations;
@using Core.IDataServices.Operations;
@inject AuthenticationStateProvider auth
@inject ITruckAvailabilityService Iservice
@inject IBranchService Ibranchservice
@inject IAssetService IassetService
@inject IAssetSettingsService Iassetsettingsservice
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject IRoleService<RoleModel> Irole

<MudDialog Class="admin-dialog-glass">
    <TitleContent>
        <div class="header-section mb-2 pt-4 px-4">
            <div class="d-flex align-center justify-space-between">
                <div class="d-flex align-center">
                    <div class="icon-badge primary-badge mr-4">
                        <div class="admin-header-icon-badge mb-3">
                            <MudIcon Icon="@(model.RequestStatus == 1 ? Icons.Material.Filled.CheckCircle : Icons.Material.Filled.VerifiedUser)" Color="Color.Secondary" Style="font-size: 3rem;" />
                        </div>
                    </div>
                    <div>
                        <MudText Typo="Typo.h5" Class="admin-title"><b>@(model.RequestStatus == 1 ? "Complete Transfer" : "Transfer Approval")</b></MudText>
                        <MudText Typo="Typo.body2" Class="admin-subtitle">@(model.RequestStatus == 1 ? "Verify checklist and finalize vehicle reception." : "Review transfer details and authorize vehicle availability.")</MudText>
                    </div>
                </div>
            </div>
            <div class="title-accent mt-4"></div>
        </div>
    </TitleContent>
    <DialogContent>
        <MudContainer Class="admin-dialog-container">
            <div class="dialog-content-wrapper pa-4">
                <EditForm id="formDriver" Model="@model" OnValidSubmit="@(() => Approve())">
                    <div class="admin-glass-card pa-6 mb-6">
                        <div class="d-flex align-center mb-6">
                            <MudIcon Icon="@Icons.Material.Filled.Info" Color="Color.Primary" Class="mr-2" />
                            <span class="admin-section-label mb-0">Core Information</span>
                        </div>
                        <ObjectGraphDataAnnotationsValidator />
                        <MudValidationSummary />
                        <MudGrid Spacing="3">
                            <MudItem xs="6">
                                <MudTextField @bind-Value="model.DocNumber" Label="Transfer ID" Variant="Variant.Outlined" Margin="Margin.Normal" ReadOnly Class="modern-input"></MudTextField>
                            </MudItem>
                            <MudItem xs="6">
                                <MudTextField @bind-Value="model.Truck.RegNo" Label="Vehicle Number" Variant="Variant.Outlined" Margin="Margin.Normal" ReadOnly Class="modern-input"></MudTextField>
                            </MudItem>
                            <MudItem xs="6">
                                <MudTextField @bind-Value="model.RequestedBranch.BranchName" Label="Source Branch" Variant="Variant.Outlined" Margin="Margin.Normal" ReadOnly Class="modern-input"></MudTextField>
                            </MudItem>
                            <MudItem xs="6">
                                <MudNumericField HideSpinButtons="true" @bind-Value="Odometer" Label="Current Odometer (KM)" Variant="Variant.Outlined" Margin="Margin.Normal" Class="modern-input"></MudNumericField>
                            </MudItem>
                            <MudItem xs="12">
                                <MudTextField @bind-Value="model.Remarks" Label="Operational Remarks" Variant="Variant.Outlined" Margin="Margin.Normal" For="@(() => model.Remarks)" Class="modern-input" Lines="2"></MudTextField>
                            </MudItem>
                        </MudGrid>
                    </div>

                    @if (model.CheckList != null && model.CheckList.Any())
                    {
                        <div class="admin-glass-card pa-0 overflow-hidden mb-6">
                            <div class="px-6 py-4 border-bottom-subtle d-flex align-center" style="background: rgba(54, 117, 136, 0.03); border-bottom: 1px solid rgba(54, 117, 136, 0.2);">
                                <MudIcon Icon="@Icons.Material.Filled.PlaylistAddCheck" Color="Color.Primary" Class="mr-2" />
                                <span class="admin-section-label mb-0">Verification Checklist</span>
                            </div>
                            <div class="pa-6">
                                <MudGrid Spacing="2">
                                    @foreach (var item in model.CheckList)
                                    {
                                        <MudItem xs="12" md="6">
                                            <div class="glass-inner-panel pa-3 d-flex align-center justify-space-between rounded-lg">
                                                <div>
                                                    <MudText Typo="Typo.body2"><b>@item.SettingsName</b></MudText>
                                                    <MudText Typo="Typo.caption" Class="color-muted">Value: @item.Value | @item.Condition</MudText>
                                                </div>
                                                @if (model.RequestStatus == 1)
                                                {
                                                    <MudCheckBox T="bool" Color="Color.Success" @bind-Checked="@item.IsRecieved" Dense="true"></MudCheckBox>
                                                }
                                            </div>
                                        </MudItem>
                                    }
                                </MudGrid>
                            </div>
                        </div>
                    }

                    @if (model?.Uploads != null && model.Uploads.Any())
                    {
                        <div class="admin-glass-card pa-0 overflow-hidden">
                            <div class="px-6 py-4 border-bottom-subtle d-flex align-center" style="background: rgba(255, 159, 67, 0.03); border-bottom: 1px solid rgba(255, 159, 67, 0.2);">
                                <MudIcon Icon="@Icons.Material.Filled.PhotoLibrary" Color="Color.Warning" Class="mr-2" />
                                <span class="admin-section-label mb-0">Evidence Repository</span>
                            </div>
                            <div class="pa-6">
                                <MudGrid Spacing="3">
                                    @foreach (var imagePath in model.Uploads.Where(x => !string.IsNullOrWhiteSpace(x)))
                                    {
                                        <MudItem xs="12" sm="6" md="4">
                                            <div class="glass-inner-panel p-2 position-relative rounded-lg overflow-hidden">
                                                @{
                                                    var extension = Path.HasExtension(imagePath) ? Path.GetExtension(imagePath).ToLower() : string.Empty;
                                                    var isVideo = extension is ".mp4" or ".mov" or ".avi";
                                                }
                                                @if (isVideo)
                                                {
                                                    <video src="@imagePath" controls style="width: 100%; border-radius: 8px;" />
                                                }
                                                else
                                                {
                                                    <MudImage Src="@imagePath" Alt="Evidence" Fluid="true" Class="rounded-lg mb-2" Style="width: 100%; height: 180px; object-fit: cover;" />
                                                }
                                                <div class="d-flex justify-center mt-2">
                                                    <MudButton Size="Size.Small" Variant="Variant.Text" StartIcon="@Icons.Material.Filled.Download" Color="Color.Primary" Href="@imagePath" download>Download</MudButton>
                                                </div>
                                            </div>
                                        </MudItem>
                                    }
                                </MudGrid>
                            </div>
                        </div>
                    }
                </EditForm>
            </div>
        </MudContainer>
    </DialogContent>
    <DialogActions>
        <div class="d-flex pa-4 gap-3 w-100 justify-end align-center">
            <MudButton Variant="Variant.Text" OnClick="Cancel" Class="px-6 rounded-lg">Exit</MudButton>
            @if (model.RequestStatus == 1)
            {
                <MudButton Variant="Variant.Filled" Color="Color.Success" OnClick="@(() => Complete(model.CheckList))" Class="px-10 rounded-pill" Style="background: var(--mud-palette-success) !important; color: white !important; border-radius: 12px; font-weight: 800; text-transform: none; padding: 12px 32px;">
                    Complete Reception
                </MudButton>
            }
            else
            {
                <MudButton Variant="Variant.Filled" Color="Color.Success" OnClick="@(() => Approve())" Class="px-8 rounded-pill" Style="background: var(--mud-palette-success) !important; color: white !important; border-radius: 12px; font-weight: 800; text-transform: none; padding: 12px 32px;">
                    Authorize Transfer
                </MudButton>
                <MudButton Variant="Variant.Filled" Color="Color.Error" OnClick="Reject" Class="px-8 rounded-pill" Style="background: var(--mud-palette-error) !important; color: white !important; border-radius: 12px; font-weight: 800; text-transform: none; padding: 12px 32px;">
                    Decline
                </MudButton>
            }
        </div>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; }
    [Parameter]
    public RequestApprovalHistoryModel model { get; set; } = new();
    private int branchID { get; set; } = 0;
    private int? BranchID { get; set; } = 0;
    private bool _busy;
    MyFileUpload Mfu;
    private int? Odometer;
    public AssetModel Asset { get; set; } = new();
    public bool HasPermissionTruckAvailabilityServiceEdit { get; set; } = false;
    public int TruckAvailabilityDocTypeID = 139;

    protected override async Task OnInitializedAsync()
    {
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionTruckAvailabilityServiceEdit = await Irole.HasClaim(TruckAvailabilityDocTypeID.ToString(), "Edit", ctc.Token);

        var authprov = await auth.GetAuthenticationStateAsync();
        var brancIDString = authprov.User.Claims.First(x => x.Type == "BranchID").Value;
        BranchID = int.Parse(brancIDString);
        model.RespondedBranchID = BranchID;
        branchID = model?.RespondedBranch?.BranchID ?? 0;

        model.CheckList = Iservice.GetCheckList(model.RequestApprovalHistoryID).ToList();

        if (model.Uploads == null)
            model.Uploads = new List<string>();
    }

    protected override void OnParametersSet()
    {

    }

    void Cancel()
    {
        MudDialog.Cancel();
    }

    // Method to handle file uploads
    private void FileUploaded(string filePath)
    {
        var webPath = "/" + filePath.Replace("\\", "/");
        model.Uploads.Add(webPath);
    }


    // Method to delete an image associated with the insurance claim
    private async Task DeleteImage(string imagePath)
    {
        model.Uploads.Remove(imagePath);
    }

    public async Task Approve()
    {
        if (HasPermissionTruckAvailabilityServiceEdit)
        {
            var authprov = await auth.GetAuthenticationStateAsync();
            var user = authprov.User;            
            
            if (Odometer == null)
            {
                Snackbar.Add("Odometer for Opening KM is required !", Severity.Warning);
                return;                
            }
            
            if (model.Truck == null || model.Truck.TruckID == 0)
            {
                bool? result = await DialogService.ShowMessageBoxAsync(
                    "Warning",
                    "Please, select truck.", yesText: "OK");
                return;
            }

            if (model != null)
            {   
                model.RespondedUserInfo = new();                
                model.OpeningKM = Odometer;
                model.RespondedUserInfo.UserID = user.Identity.Name;
                model.RequestStatus = 1;

                try
                {
                    Iservice.UpdateStatus(model, null);
                    Snackbar.Add("Approved succesfully", Severity.Success);
                }
                catch (Exception ex)
                {
                    Snackbar.Add(ex.Message, Severity.Error);
                }
            }
            MudDialog.Close(DialogResult.Ok(model));
        }
        else
        {
            bool? ResultModel = await DialogService.ShowMessageBoxAsync(
                "Permission denied!",
                "You don't have any permission to Approve Truck Request.");
        }
    }

    public async Task Complete(List<AssetSettingsModel> context)
    {
        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;
        if (Odometer == null)
        {
            Snackbar.Add("Odometer for Closing KM is required !", Severity.Warning);
            return;
        }
        if (Odometer < model.OpeningKM)
        {
            Snackbar.Add("Odometer for Closing KM cannot be lesser than Opening KM !", Severity.Warning);
            return;
        }
        if (model.Truck == null || model.Truck.TruckID == 0)
        {
            bool? result = await DialogService.ShowMessageBoxAsync(
                "Warning",
                "Please, Select truck.", yesText: "OK");
            return;
        }
        if (model != null)
        {            
            List<int?> RecievedList = context.Where(s => s.IsRecieved == true).Select(d => d.CheckListID).ToList();

            model.RequestStatus = 2;
            model.ClosingKM = Odometer;

            try
            {
                Iservice.UpdateStatus(model, RecievedList);
                Snackbar.Add("Completed succesfully", Severity.Success);
            }
            catch (Exception ex)
            {
                Snackbar.Add(ex.Message, Severity.Error);
            }
        }
        MudDialog.Close(DialogResult.Ok(model));
    }

    public async Task Reject()
    {
        if (HasPermissionTruckAvailabilityServiceEdit)
        {
            var authprov = await auth.GetAuthenticationStateAsync();
            var user = authprov.User;
            if (model.Truck == null || model.Truck.TruckID == 0)
            {
                bool? result = await DialogService.ShowMessageBoxAsync(
                    "Warning",
                    "Please, Select truck.", yesText: "OK");
                return;
            }
            if (model != null)
            {
                model.RespondedUserInfo = new();
                model.RequestStatus = 99;
                model.RespondedUserInfo.UserID = user.Identity.Name;
                try
                {
                    Iservice.UpdateStatus(model, null);
                    Snackbar.Add("Rejected succesfully", Severity.Success);
                }
                catch (Exception ex)
                {
                    Snackbar.Add(ex.Message, Severity.Error);
                }
            }
            MudDialog.Close(DialogResult.Ok(model));
        }
        else
        {
            bool? ResultModel = await DialogService.ShowMessageBoxAsync(
                "Permission denied!",
                "You don't have any permission to Reject Truck Request.");
        }
    }
}
