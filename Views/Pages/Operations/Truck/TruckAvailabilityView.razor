                                                <MudTable Elevation="0" Items="@(TFuelLists.TryGetValue(item.RequestApprovalHistoryID, out var tfuelList) ? tfuelList : new List<TripFuelModel>())" Dense="true" Hover="true" Striped="true">
                                                    <HeaderContent>
                                                        <MudTh Style="width:160px;"><MudTableSortLabel SortBy="new Func<TripFuelModel, object>(x=> x.EntryDate)" InitialDirection="SortDirection.Ascending">Entry Date</MudTableSortLabel></MudTh>
                                                        <MudTh><MudTableSortLabel SortBy="new Func<TripFuelModel, object>(x=> x.DocNumber)" InitialDirection="SortDirection.Ascending">Document No.</MudTableSortLabel></MudTh>
