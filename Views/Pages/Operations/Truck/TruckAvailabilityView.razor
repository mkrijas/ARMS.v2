                                    <MudCardContent Class="flex-grow-1 py-3 px-4">
                                         <MudTabs Rounded="true" MinimumTabWidth="40px" Color="Color.Transparent" SliderColor="Color.Secondary" PrevIcon="@Icons.Material.Filled.SkipPrevious" NextIcon="@Icons.Material.Filled.SkipNext" Class="mt-2">
                                            <MudTabPanel ToolTip="Info" Icon="@Icons.Material.Filled.Info">
                                                <div class="py-4" style="min-height: 220px;">
                                                     <MudGrid Spacing="3">
                                                        <MudItem xs="12">
                                                            <div class="d-flex align-center justify-space-between pa-2 rounded" style="background-color: var(--mud-palette-background-grey);">
                                                                <MudText Typo="Typo.caption"><b>@item.RespondedBranch.BranchName</b></MudText>
                                                                <MudIcon Icon="@Icons.Material.Filled.ArrowForward" Color="Color.Default" Size="Size.Small" />
                                                                <MudText Typo="Typo.caption"><b>@item.RequestedBranch.BranchName</b></MudText>
                                                            </div>
                                                        </MudItem>
                                                        <MudItem xs="6">
                                                            <MudText Typo="Typo.caption" Color="Color.Secondary">Truck No</MudText>
                                                            <MudText Typo="Typo.body2"><b>@item.Truck.RegNo</b></MudText>
                                                        </MudItem>
                                                         <MudItem xs="6">
                                                            <MudText Typo="Typo.caption" Color="Color.Secondary">Date</MudText>
                                                            <MudText Typo="Typo.body2">@item.RequestedUserInfo?.TimeStampField?.ToString("dd-MM-yyyy")</MudText>
                                                        </MudItem>
                                                         <MudItem xs="12" Class="d-flex align-center justify-space-between">
                                                            <MudText Typo="Typo.caption" Color="Color.Secondary">Status</MudText>
                                                            <MudChip T="string" Color="@GetStatusColor(item.StatusText)" Size="Size.Small" Variant="Variant.Text" Class="ma-0"><b>@item.StatusText</b></MudChip>
                                                        </MudItem>
                                                     </MudGrid>
                                                </div>
                                            </MudTabPanel>

                                            <MudTabPanel ToolTip="Expenses" Icon="@Icons.Material.Filled.Receipt" OnClick="(() => ExpenseTabSelected(item.RequestApprovalHistoryID))">
                                                <div class="pa-0" style="height: 220px; overflow-y: auto;">
                                                     <MudTable Elevation="0" Items="@(OptranLists.TryGetValue(item.RequestApprovalHistoryID, out var optranList) ? optranList : new List<OpTranSubModel>())" Dense="true" Hover="true" Striped="true" FixedHeader="true" Class="rounded-0">
                                                        <HeaderContent>
                                                            <MudTh>Head</MudTh>
