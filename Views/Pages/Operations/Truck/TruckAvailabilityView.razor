                                                </MudTooltip>
                                            }
                                            @if (item.RespondedBranchID == CurrentBranchId)
                                            {
                                                <MudTooltip Text="Checklist">
                                                    <MudIconButton Icon="@Icons.Material.Filled.Checklist" Color="Color.Primary" Size="Size.Small" OnClick="@(()=> OpenChecklist(item))" />
                                                </MudTooltip>
