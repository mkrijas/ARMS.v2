                                                            </MudText>
                                                        </MudItem>
                                                    </MudGrid>
                                                </div>
                                            </MudTabPanel>
                                            <MudTabPanel ToolTip="Expenses" Icon="@Icons.Material.Filled.Receipt" OnClick="(() => ExpenseTabSelected(item.RequestApprovalHistoryID))">
                                                 <div class="pa-0" style="height: 220px; overflow-y: auto;">
                                                    <MudTable Elevation="0" Items="@(OptranLists.TryGetValue(item.RequestApprovalHistoryID, out var optranList) ? optranList : new List<OpTranSubModel>())" Dense="true" Hover="true" Striped="true" FixedHeader="true" Class="rounded-0">
                                                        <HeaderContent>
                                                            <MudTh>Head</MudTh>
                                                            <MudTh>Amt</MudTh>
                                                        </HeaderContent>
                                                        <RowTemplate Context="expenses">
                                                            <MudTd DataLabel="Head">@expenses.ExpenseTitle</MudTd>
                                                            <MudTd DataLabel="Amt"><b>@expenses.Amount</b></MudTd>
                                                        </RowTemplate>
                                                    </MudTable>
                                                </div>
                                            </MudTabPanel>
                                            <MudTabPanel ToolTip="Fuel" Icon="@Icons.Material.Filled.LocalGasStation" OnClick="(() => FuelTabSelected(item.RequestApprovalHistoryID))">
                                                <div class="pa-0" style="height: 220px; overflow-y: auto;">
                                                    <MudTable Elevation="0" Items="@(TFuelLists.TryGetValue(item.RequestApprovalHistoryID, out var tfuelList) ? tfuelList : new List<TripFuelModel>())" Dense="true" Hover="true" Striped="true" FixedHeader="true" Class="rounded-0">
                                                        <HeaderContent>
                                                            <MudTh>Date</MudTh>
                                                            <MudTh>Qty</MudTh>
                                                        </HeaderContent>
                                                        <RowTemplate Context="fuel">
                                                            <MudTd DataLabel="Date">@Convert.ToDateTime(fuel.EntryDate).ToString("dd/MM")</MudTd>
                                                            <MudTd DataLabel="Qty"><b>@fuel.Quantity</b></MudTd>
                                                        </RowTemplate>
                                                    </MudTable>
                                                </div>
                                            </MudTabPanel>
                                            <MudTabPanel ToolTip="Mileage" Icon="@Icons.Material.Filled.Speed" OnClick="(() => MileageTabSelected(item.RequestApprovalHistoryID))">
                                                <div class="py-4" style="height: 220px; overflow-y: auto;">
                                                    @if (MileageLists.TryGetValue(item.RequestApprovalHistoryID, out var mileageList) && mileageList.Count > 0)
