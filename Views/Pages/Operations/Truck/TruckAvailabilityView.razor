@page "/TruckAvailabilityView"
@page "/TruckAvailabilityView/{id:int}"
@using ArmsModels.BaseModels.General
@using Core.BaseModels.Operations;
@using Core.IDataServices.Operations;
@using Microsoft.AspNetCore.SignalR.Client;
@using System.Threading;
@using Views.Data
@using System.Threading;
@using Core.BaseModels.Finance.Transactions;
@using Pages.Operations.Expenses

@attribute [Authorize]
@inject AuthenticationStateProvider auth
@inject ITruckAvailabilityService Iservice
@inject IOpTranService Iopservice
@inject ITripFuelService tripFuelIservice
@inject IMileageShortageReceiptService IMileageService
@inject IPushNotificationService IpushNotificationService
@inject MudBlazor.ISnackbar snackbar
@inject IDialogService DialogService
@inject IBranchService IbranchService
@inject IAssetDocumentService IAssetDocument
@inject NavigationManager NavigationManager
@inject SignalRService signalRService
@inject IPushNotificationService IpushNotificationService
@inject IRoleService<RoleModel> Irole

<MudContainer MaxWidth="MaxWidth.False" Class="pa-6">
    <MudGrid Spacing="4">
        <MudItem xs="12">
            <MudTabs Elevation="0" Rounded="true" ApplyEffectsToContainer="true" PanelClass="pa-0" Color="Color.Transparent" SliderColor="Color.Primary">
                <MudTabPanel Text="Truck Request" Icon="@Icons.Material.Filled.LocalShipping">
                    <MudPaper Elevation="0" Class="pa-4 mb-4 d-flex align-center justify-space-between rounded-lg" Style="background-color: var(--mud-palette-background-grey);">
                        <MudText Typo="Typo.h5" Color="Color.Primary"><b>Initiate Request</b></MudText>
                        <div class="d-flex align-center gap-4">
                             <MudTooltip Text="New Truck Request">
                                <MudFab StartIcon="@Icons.Material.Filled.Add" Title="Add" OnClick="@(()=> OpenDialogEditOutGoing(new RequestApprovalHistoryModel()))" Color="Color.Primary" Size="Size.Small" />
                            </MudTooltip>
                            <MudCheckBox T="bool" Label="Show Completed" ValueChanged="((bool value)=>CompletedChanged(value))" Value="@IsCompleted" Size="Size.Medium" Color="Color.Primary" />
                        </div>
                    </MudPaper>
                    
                    <MudGrid>
                        @foreach (var item in collectionOutGoing)
                        {
                            <MudItem xs="12" sm="6" md="6" lg="4" xl="3">
                                <MudCard Elevation="4" Class="rounded-xl h-100 d-flex flex-column transition-card mud-width-full" Style="border-top: 4px solid var(--mud-palette-primary);">
                                    <MudCardHeader Class="pb-2">
                                        <CardHeaderAvatar>
                                            <MudAvatar Color="Color.Primary" Variant="Variant.Filled" Rounded="true" Size="Size.Medium">
                                                <MudIcon Icon="@Icons.Material.Filled.LocalShipping" />
                                            </MudAvatar>
                                        </CardHeaderAvatar>
                                        <CardHeaderContent>
                                            <MudText Typo="Typo.h6"><b>@item.DocNumber</b></MudText>
                                            <MudText Typo="Typo.caption" Color="Color.Secondary">Request ID</MudText>
                                        </CardHeaderContent>
                                        <CardHeaderActions>
                                            <MudTooltip Text="Add Fuel">
                                                <MudIconButton Icon="@Icons.Material.Filled.LocalGasStation" Variant="Variant.Text" Color="Color.Warning" Size="Size.Small" OnClick="@(()=> OpenFuelForm(new TripFuelModel(){RequestApprovalHistoryID = item.RequestApprovalHistoryID , TruckID = item.TruckID}))" />
                                            </MudTooltip>
                                            <MudTooltip Text="Add Expenses">
                                                <MudIconButton Icon="@Icons.Material.Filled.AttachMoney" Variant="Variant.Text" Color="Color.Success" Size="Size.Small" OnClick="@(()=> OpenExpenseForm(new OpTranModel(){RequestApprovalHistoryID = item.RequestApprovalHistoryID}))" />
                                            </MudTooltip>
                                            <MudMenu Icon="@Icons.Material.Filled.MoreVert" Color="Color.Default" Size="Size.Small" AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight" Style="top: 6px; right: 5px;">
                                                 @if (item.RequestStatus != 2)
                                                {
                                                    @if (item.RequestStatus != 0)
                                                    {
                                                         if (item.RequestStatus == 99)
                                                        {
                                                            <MudMenuItem Disabled="true"><MudText Color="Color.Error">Rejected</MudText></MudMenuItem>
                                                        }
                                                        else
                                                        {
                                                            <MudMenuItem OnClick="@(()=> OpenDialogEditIncoming(item))">Complete Request</MudMenuItem>
                                                        }
                                                    }
                                                    else
                                                    {
                                                        <MudMenuItem OnClick="@(()=> OpenDialogEditOutGoing(item))">Edit</MudMenuItem>
                                                        <MudMenuItem OnClick="@(()=> OpenDialogDeleteOutGoing(item))">Remove</MudMenuItem>
                                                    }
                                                }
                                                else
                                                {
                                                     <MudMenuItem OnClick="@(()=> OpenMileageShortageReceipt(new MileageShortageReceiptModel(){RequestApprovalHistoryID = item.RequestApprovalHistoryID, DriverID = item.DriverID}))">Add Mileage Shortage</MudMenuItem>
                                                     <MudMenuItem OnClick="@(()=> OpenChecklist(item))">Checklist</MudMenuItem>
                                                }
                                            </MudMenu>
                                        </CardHeaderActions>
                                    </MudCardHeader>

                                    <MudCardContent Class="flex-grow-1 py-3 px-4">
                                        <MudTabs Rounded="true" MinimumTabWidth="40px" Color="Color.Transparent" SliderColor="Color.Secondary" PrevIcon="@Icons.Material.Filled.SkipPrevious" NextIcon="@Icons.Material.Filled.SkipNext" Class="mt-2">
                                            <MudTabPanel ToolTip="Info" Icon="@Icons.Material.Filled.Info">
                                                <div class="py-4" style="min-height: 220px;">
                                                    <MudGrid Spacing="3">
                                                        <MudItem xs="6">
                                                            <MudText Typo="Typo.caption" Color="Color.Secondary">Truck No</MudText>
                                                            <MudText Typo="Typo.body2"><b>@item.Truck.RegNo</b></MudText>
                                                        </MudItem>
                                                        <MudItem xs="6">
                                                            <MudText Typo="Typo.caption" Color="Color.Secondary">Date</MudText>
