    public void ExpenseTabSelected(int? requestApprovalHistoryID)
    {
        if (requestApprovalHistoryID.HasValue)
        {
            var opList = Iopservice.SelectByTransfer(requestApprovalHistoryID).ToList();
            var optranList = new List<OpTranSubModel>();
            foreach (var item in opList)
            {
                optranList.AddRange(Iopservice.GetExpenses(item.OpTranID).Where(x => x.Amount > 0).ToList());
            }
            OptranLists[requestApprovalHistoryID.Value] = optranList;
        }
    }

