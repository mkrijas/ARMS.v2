@page "/TruckAvailabilityView"
@page "/TruckAvailabilityView/{id:int}"
@using ArmsModels.BaseModels.General
@using Core.BaseModels.Operations;
@using Core.IDataServices.Operations;
@using Microsoft.AspNetCore.SignalR.Client;
@using System.Threading;
@using Views.Data
@using System.Threading;
@using Core.BaseModels.Finance.Transactions;
@using Pages.Operations.Expenses

@attribute [Authorize]
@inject AuthenticationStateProvider auth
@inject ITruckAvailabilityService Iservice
@inject IOpTranService Iopservice
@inject ITripFuelService tripFuelIservice
@inject IMileageShortageReceiptService IMileageService
@inject IPushNotificationService IpushNotificationService
@inject MudBlazor.ISnackbar snackbar
@inject IDialogService DialogService
@inject IBranchService IbranchService
@inject IAssetDocumentService IAssetDocument
@inject NavigationManager NavigationManager
@inject SignalRService signalRService
@inject IPushNotificationService IpushNotificationService
@inject IRoleService<RoleModel> Irole

<MudGrid Spacing="4">
    <MudItem xs="12">
        <MudTabs Elevation="2" Rounded="true" ApplyEffectsToContainer="true" PanelClass="pa-6">
            <MudTabPanel Text="Truck Request">
                <MudToolBar>
                    <MudText Typo="Typo.h6">Initiate Request</MudText>
                    <MudTooltip Text="New Truck Request">
                        <MudIconButton Icon="@Icons.Material.Filled.Add" Title="Add" @onclick="@(()=> OpenDialogEditOutGoing(new RequestApprovalHistoryModel()))" Color="Color.Dark" Size="Size.Small"></MudIconButton>
                    </MudTooltip>
                    <MudSpacer></MudSpacer>
                    <MudCheckBox T="bool" Label="Completed Entries" ValueChanged="((bool value)=>CompletedChanged(value))" Value="@IsCompleted" Size="Size.Medium" Color="Color.Primary" Class="tablefont margin0"></MudCheckBox>
                </MudToolBar>
                <MudGrid Class="mud-cols-xs-1 mud-cols-md-2 mud-cols-lg-2">
                    @foreach (var item in collectionOutGoing)
                    {
                        <MudItem sm="12" xl="4" lg="6">
                            <MudCard Class="mt-3" Style="height:auto" Elevation="2">
                                <MudCardHeader>
                                    <CardHeaderAvatar>
                                        <MudAvatar Color="Color.Tertiary"><MudIcon Icon="@Icons.Material.Filled.SwapHoriz" Title="Doc No" Color="Color.Primary" /></MudAvatar>
                                    </CardHeaderAvatar>
                                    <CardHeaderContent>
                                        <MudGrid>
                                            <MudItem xs="6">
                                                <MudText Typo="Typo.h6" GutterBottom="true">
                                                    <b>@item.DocNumber</b>
                                                </MudText>
                                            </MudItem>
                                        </MudGrid>
                                    </CardHeaderContent>
                                    <CardHeaderActions>
                                        <MudTooltip Text="Add Fuel">
                                            <MudIconButton Icon="@Icons.Material.Filled.LocalGasStation" Size="Size.Large" Color="Color.Success" @onclick="@(()=> OpenFuelForm(new TripFuelModel(){RequestApprovalHistoryID = item.RequestApprovalHistoryID , TruckID = item.TruckID}))" />
                                        </MudTooltip>
                                        <MudTooltip Text="Add Expenses">
                                            <MudIconButton Icon="@Icons.Material.Filled.MenuBook" Color="Color.Success" Size="Size.Large" @onclick="@(()=> OpenExpenseForm(new OpTranModel(){RequestApprovalHistoryID = item.RequestApprovalHistoryID}))" />
                                        </MudTooltip>
                                        @if (item.RequestStatus != 2)
                                        {
                                            @if (item.RequestStatus != 0)
                                            {
                                                @if (item.RequestStatus == 99)
                                                {
                                                    <MudText Color="Color.Error">Rejected</MudText>
                                                }
                                                else
                                                {
                                                    <MudTooltip Text="Complete">
                                                        <MudIconButton @onclick="@(()=> OpenDialogEditIncoming(item))" Color="Color.Primary" Icon="@Icons.Material.Filled.AddTask" Size="Size.Medium" IconSize="Size.Small" />
                                                    </MudTooltip>
                                                }
                                            }
                                            else
                                            {
                                                <MudTooltip Text="Edit">
                                                    <MudIconButton @onclick="@(()=> OpenDialogEditOutGoing(item))" Color="Color.Primary" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" IconSize="Size.Small" />
                                                </MudTooltip>
                                                <MudTooltip Text="Remove">
                                                    <MudIconButton @onclick="@(()=> OpenDialogDeleteOutGoing(item))" Color="Color.Primary" Icon="@Icons.Material.Filled.Remove" Size="Size.Small" IconSize="Size.Small" />
                                                </MudTooltip>
                                            }
                                        }
                                        else
                                        {
                                            <MudTooltip Text="Add Mileage Shortage Receipt">
                                                <MudIconButton Icon="@Icons.Material.Filled.Toll" Color="Color.Success" Size="Size.Large" @onclick="@(()=> OpenMileageShortageReceipt(new MileageShortageReceiptModel(){RequestApprovalHistoryID = item.RequestApprovalHistoryID, DriverID = item.DriverID}))" />
                                            </MudTooltip>
                                            <MudTooltip Text="Checklist">
                                                <MudIconButton Icon="@Icons.Material.Filled.Checklist" Color="Color.Primary" Size="Size.Small" @onclick="@(()=> OpenChecklist(item))" />
                                            </MudTooltip>
                                        }
                                    </CardHeaderActions>
                                </MudCardHeader>
                                <MudCardContent Style="height: 280px; overflow-y: auto;">
                                    <MudTabs Rounded="true" MinimumTabWidth="40px" Color="@Color.Transparent" PrevIcon="@Icons.Material.Filled.SkipPrevious" NextIcon="@Icons.Material.Filled.SkipNext" Class="shadow-sm shadow border-0 border">
                                        <MudTabPanel ToolTip="Transfer Info" Icon="@Icons.Material.Filled.Info">
                                            <div class="TabStyle">
                                                <MudList T="string" Style="width:700px">
                                                    <MudGrid>
                                                        <MudItem md="5">
                                                            <MudListItem T="string" Avatar="@Icons.Material.Filled.FireTruck" IconColor="Color.Primary">
                                                                <b>@item.Truck.RegNo</b>
                                                            </MudListItem>
                                                            <MudListItem T="string" Avatar="@Icons.Material.Filled.DateRange" IconColor="Color.Primary">
                                                                <b>@item.RequestedUserInfo?.TimeStampField?.ToString("dd/MM/yyyy")</b>
                                                            </MudListItem>
                                                        </MudItem>
                                                        <MudItem md="5">
                                                            <MudListItem T="string" Avatar="@Icons.Material.Filled.Approval" IconColor="Color.Primary">
                                                                Status :<b>@item.StatusText</b>
                                                            </MudListItem>
                                                            <MudListItem T="string" Avatar="@Icons.Material.Filled.Warehouse" IconColor="Color.Primary">
                                                                Responded Branch : <b>@item.RespondedBranch.BranchName <br> (@item.SOBranchName)</b>
                                                            </MudListItem>
                                                        </MudItem>
                                                    </MudGrid>
                                                </MudList>
                                            </div>
                                        </MudTabPanel>
                                        <MudTabPanel ToolTip="Expenses" Icon="@Icons.Material.Filled.Receipt" OnClick="(() => ExpenseTabSelected(item.RequestApprovalHistoryID))">
                                            <div class=" TabStyle">
                                                <MudTable Elevation="0" Items="@(OptranLists.TryGetValue(item.RequestApprovalHistoryID, out var optranList) ? optranList : new List<OpTranSubModel>())" Dense="true" Hover="true" Striped="true">
                                                    <HeaderContent>
                                                        <MudTh><MudTableSortLabel SortBy="new Func<OpTranSubModel, object>(x=> x.DocNo)" InitialDirection="SortDirection.Ascending">DocNo</MudTableSortLabel></MudTh>
                                                        <MudTh Style="width:160px;"><MudTableSortLabel SortBy="new Func<OpTranSubModel, object>(x=> x.ExpenseTitle)" InitialDirection="SortDirection.Ascending">Operation Head </MudTableSortLabel></MudTh>
                                                        <MudTh><MudTableSortLabel SortBy="new Func<OpTranSubModel, object>(x=> x.Reference)" InitialDirection="SortDirection.Ascending">Refernce</MudTableSortLabel></MudTh>
                                                        <MudTh><MudTableSortLabel SortBy="new Func<OpTranSubModel, object>(x=> x.Amount)" InitialDirection="SortDirection.Ascending">Amount</MudTableSortLabel></MudTh>
                                                        <MudTh>Actions</MudTh>
                                                    </HeaderContent>
                                                    <RowTemplate>
                                                        <MudTd DataLabel="DocNo">@context.DocNo</MudTd>
                                                        <MudTd DataLabel="ExpenseTitle">@context.ExpenseTitle</MudTd>
                                                        <MudTd DataLabel="Reference">@context.Reference</MudTd>
                                                        <MudTd DataLabel="Amount">@context.Amount</MudTd>
                                                        @* <MudTd DataLabel="">
                                                            <MudFab @onclick="@(()=> OpenExpenseForm(context))" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Numbers" Size="Size.Small" />
                                                        </MudTd> *@
                                                    </RowTemplate>
                                                </MudTable>
                                            </div>
                                        </MudTabPanel>
                                        <MudTabPanel ToolTip="Fuel & AdBlue Entries" Icon="@Icons.Material.Filled.ReadMore" OnClick="(() => FuelTabSelected(item.RequestApprovalHistoryID))">
                                            <div class="TabStyle">
                                                <MudTable Elevation="0" Items="@(TFuelLists.TryGetValue(item.RequestApprovalHistoryID, out var tfuelList) ? tfuelList : new List<TripFuelModel>())" Dense="true" Hover="true" Striped="true">
                                                    <HeaderContent>
                                                        <MudTh Style="width:160px;"><MudTableSortLabel SortBy="new Func<TripFuelModel, object>(x=> x.EntryDate)" InitialDirection="SortDirection.Ascending">Entry Date</MudTableSortLabel></MudTh>
                                                        <MudTh><MudTableSortLabel SortBy="new Func<TripFuelModel, object>(x=> x.DocNumber)" InitialDirection="SortDirection.Ascending">Document No.</MudTableSortLabel></MudTh>
                                                        <MudTh><MudTableSortLabel SortBy="new Func<TripFuelModel, object>(x=> x.ItemType)" InitialDirection="SortDirection.Ascending">Item Type</MudTableSortLabel></MudTh>
                                                        <MudTh><MudTableSortLabel SortBy="new Func<TripFuelModel, object>(x=> x.FuelItemDescription)" InitialDirection="SortDirection.Ascending">Fuel Type</MudTableSortLabel></MudTh>
                                                        <MudTh><MudTableSortLabel SortBy="new Func<TripFuelModel, object>(x=> x.Quantity)" InitialDirection="SortDirection.Ascending">Quantity</MudTableSortLabel></MudTh>
                                                        <MudTh><MudTableSortLabel SortBy="new Func<TripFuelModel, object>(x=> x.RatePerLitre)" InitialDirection="SortDirection.Ascending">Rate/Ltr</MudTableSortLabel></MudTh>
                                                    </HeaderContent>
                                                    <RowTemplate>
                                                        <MudTd DataLabel="EntryDate">@Convert.ToDateTime(@context.EntryDate).ToString("dd/MM/yyyy")</MudTd>
                                                        <MudTd DataLabel="DocNumber">@context.DocNumber</MudTd>
                                                        <MudTd DataLabel="ItemType">@context.ItemType</MudTd>
                                                        <MudTd DataLabel="FuelType">@context.FuelItemDescription</MudTd>
                                                        <MudTd DataLabel="Quantity">@context.Quantity</MudTd>
                                                        <MudTd DataLabel="Frieght">@context.RatePerLitre</MudTd>
                                                    </RowTemplate>
                                                </MudTable>
                                            </div>
                                        </MudTabPanel>
                                        <MudTabPanel ToolTip="Mileage Shortage Receipt" Icon="@Icons.Material.Filled.ReceiptLong" OnClick="(() => MileageTabSelected(item.RequestApprovalHistoryID))">
                                            <div class="TabStyle">
                                                <MudList T="string" Style="width:700px">
                                                    @if (MileageLists.TryGetValue(item.RequestApprovalHistoryID, out var mileageList) && mileageList.Count > 0)
                                                    {
                                                        <MudGrid>
                                                            <MudItem md="6">
                                                                <MudListItem T="string">
                                                                    Document Number : <b>@mileageList[0].DocumentNumber</b>
                                                                </MudListItem>
                                                                <MudListItem T="string">
                                                                    Running Km : <b>@mileageList[0].RunningKM</b>
                                                                </MudListItem>
                                                                <MudListItem T="string">
                                                                    Consumed Fuel : <b>@mileageList[0].ConsumedFuel</b>
                                                                </MudListItem>
                                                                <MudListItem T="string">
                                                                    Allotted Mileage :  <b>@mileageList[0].AllottedMileage</b> @* <b>@((MileageList[0].AllottedDistance/MileageList[0].ConsumedFuel).Value.ToString("0.00"))</b> *@
                                                                </MudListItem>
                                                            </MudItem>
                                                            <MudItem md="6">
                                                                <MudListItem T="string">
                                                                    Allotted Distance : <b>@mileageList[0].AllottedDistance</b>
                                                                </MudListItem>
                                                                <MudListItem T="string">
                                                                    Fuel Price : <b>@mileageList[0].FuelPrice</b>
                                                                </MudListItem>
                                                                <MudListItem T="string">
                                                                    Total Amount : <b>@mileageList[0].TotalAmount</b>
                                                                </MudListItem>
                                                            </MudItem>
                                                        </MudGrid>
                                                    }
                                                </MudList>
                                            </div>
                                        </MudTabPanel>
                                    </MudTabs>
                                </MudCardContent>
                            </MudCard>
                        </MudItem>
                    }
                </MudGrid>
            </MudTabPanel>
            <MudTabPanel Text="Truck Approve/ Reject">
                <MudGrid Class="mud-cols-xs-1 mud-cols-md-2 mud-cols-lg-2">
                    @foreach (var item in collectionIncoming)
                    {
                        <MudItem sm="12" xl="4" lg="6">
                            <MudCard Class="mt-3" Style="height:auto" Elevation="4">
                                <MudCardHeader>
                                    <CardHeaderAvatar>
                                        <MudAvatar Color="Color.Tertiary"><MudIcon Icon="@Icons.Material.Filled.SwapHoriz" Title="Doc No" Color="Color.Primary" /></MudAvatar>
                                    </CardHeaderAvatar>
                                    <CardHeaderContent>
                                        <MudGrid>
                                            <MudItem xs="6">
                                                <MudText Typo="Typo.h6" GutterBottom="true">
                                                    <b>@item.DocNumber</b>
                                                </MudText>
                                            </MudItem>
                                        </MudGrid>
                                    </CardHeaderContent>
                                    <CardHeaderActions>
                                        @if (item.RespondedBranchID == CurrentBranchId)
                                        {
                                            <MudTooltip Text="Checklist">
                                                <MudIconButton Icon="@Icons.Material.Filled.Checklist" Color="Color.Primary" Size="Size.Medium" @onclick="@(()=> OpenChecklist(item))" />
                                            </MudTooltip>
                                        }
                                        @if (item.Truck.HomeBranchID == CurrentBranchId)
                                        {
                                            <MudTooltip Text="Add Fuel">
                                                <MudIconButton Icon="@Icons.Material.Filled.LocalGasStation" Size="Size.Large" Color="Color.Success" @onclick="@(()=> OpenFuelForm(new TripFuelModel(){RequestApprovalHistoryID = item.RequestApprovalHistoryID , TruckID = item.TruckID}))" />
                                            </MudTooltip>
                                            <MudTooltip Text="Add Expenses">
                                                <MudIconButton Icon="@Icons.Material.Filled.MenuBook" Color="Color.Success" Size="Size.Large" @onclick="@(()=> OpenExpenseForm(new OpTranModel(){RequestApprovalHistoryID = item.RequestApprovalHistoryID}))" />
                                            </MudTooltip>
                                            <MudTooltip Text="Accept/Reject">
                                                <MudIconButton @onclick="@(()=> OpenDialogEditIncoming(item))" Color="Color.Primary" Icon="@Icons.Material.Filled.AddTask" Size="Size.Medium" IconSize="Size.Small" />
                                            </MudTooltip>
                                        }
                                    </CardHeaderActions>
                                </MudCardHeader>
                                <MudCardContent Style="height: 280px; overflow-y: auto;">
                                    <MudTabs Rounded="true" MinimumTabWidth="40px" Color="@Color.Transparent" PrevIcon="@Icons.Material.Filled.SkipPrevious" NextIcon="@Icons.Material.Filled.SkipNext" Class="shadow-sm shadow border-0 border">
                                        <MudTabPanel ToolTip="Transfer Info" Icon="@Icons.Material.Filled.Info">
                                            <div class="TabStyle">
                                                <MudList T="string" Style="width:700px">
                                                    <MudGrid>
                                                        <MudItem md="10">
                                                            <MudListItem T="string">
                                                                <b>@item.RespondedBranch.BranchName</b>
                                                                <b><MudIcon Icon="@Icons.Material.Filled.ArrowForward" Color="Color.Primary" Class="mx-2" /></b>
                                                                <b>@item.RequestedBranch.BranchName</b>
                                                            </MudListItem>
                                                        </MudItem>
                                                        <MudItem md="5">
