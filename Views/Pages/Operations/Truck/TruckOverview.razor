    }

    private void ProcessTyreLayout()
    {
        _parsedAxles.Clear();
        if (!_tyrePositions.Any()) return;

        var axleGroups = _tyrePositions.GroupBy(p => GetAxleName(p.Description));

        foreach (var group in axleGroups)
        {
            var axle = new AxleData
            {
                AxleName = group.Key,
                Order = GetAxleOrder(group.Key),
                Positions = group.OrderBy(p => GetColumnOrder(p.Description)).ToList()
            };
            _parsedAxles.Add(axle);
        }

        _parsedAxles = _parsedAxles.OrderBy(a => a.Order).ToList();
    }

    private string GetAxleName(string desc)
    {
        if (string.IsNullOrEmpty(desc)) return "Other Position";

        var lowercase = desc.ToLower();
        if (lowercase.Contains("front")) return "Front Axle";

        // Handle hyphenated names like "SECOND-AXLE" or "DRIVE-AXLE"
        var parts = desc.Split(new[] { ' ' }, StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length > 0)
        {
            var axleParts = new List<string>();
            foreach(var part in parts)
            {
                var p = part.ToLower();
                // Directional keywords that indicate we've passed the axle name
                if (p == "left" || p == "right" || p == "inner" || p == "outer") break;
                axleParts.Add(part);
            }
            if (axleParts.Any()) return string.Join(" ", axleParts);
        }

        return desc;
    }

    private int GetAxleOrder(string name)
    {
        var n = name.ToLower();
        if (n.Contains("front")) return 10;
        if (n.Contains("second")) return 12;
        if (n.Contains("steer")) return 15;

        if (n.Contains("drive"))
        {
            if (n.Contains("1st")) return 20;
            if (n.Contains("2nd")) return 21;
            return 25;
        }

        if (n.Contains("lift")) return 30;
        if (n.Contains("tag")) return 31;

        if (n.Contains("trailer"))
        {
            if (n.Contains("1st")) return 40;
            if (n.Contains("2nd")) return 41;
            if (n.Contains("3rd")) return 42;
            if (n.Contains("4th")) return 43;
            return 49;
        }

        return 100;
    }

    private int GetColumnOrder(string desc)
    {
        var d = desc.ToLower();
        if (d.Contains("outer left") || (d.Contains("left") && !d.Contains("outer") && !d.Contains("inner"))) return 1;
        if (d.Contains("inner left"))  return 2;
        if (d.Contains("inner right")) return 3;
        if (d.Contains("outer right") || (d.Contains("right") && !d.Contains("outer") && !d.Contains("inner"))) return 4;
        return 2; // Default to inner
    }

