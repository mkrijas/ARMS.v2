    private async Task LoadInitialTrucksList()
    {
        isLoading = true;
        try
        {
            // Assuming this loads a lightweight list of trucks. Passing no BranchID and "All" fetches all trucks usually.
            AllTrucks = await Task.Run(() => TruckService.SelectAllByBranch(false, null, "All", "AllOperation"));
        }
        catch (Exception ex)
        {
            Snackbar.Add("Failed to load trucks list.", Severity.Error);
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task<IEnumerable<TruckModel>> SearchTrucks(string value, CancellationToken token)
    {
        // if text is null or empty, return all trucks within reasonable limit
        if (string.IsNullOrEmpty(value))
            return AllTrucks.Take(10);

        return AllTrucks.Where(x => x.RegNo.Contains(value, StringComparison.InvariantCultureIgnoreCase)).Take(10);
    }

    private async Task LoadFullTruckDetails(int? truckId)
    {
        if (truckId == null) return;
        isLoading = true;
        await InvokeAsync(StateHasChanged); // Force update to show loading indicator
        try
        {
            var detailedTruck = TruckService.GetInfo(truckId);
            detailedTruck.CurrentEvent = iEventService.GetCurrentEvent(truckId.Value);            

            if (detailedTruck != null)
            {
                var registration = detailedTruck?.CurrentRegistration;                 

                // Initialize Mock values for specific truck
                InitializeDataFor(detailedTruck);

                // Fetch real tyre data
                _mountedTyres =  TyreService.SelectMountedTyresByID(truckId).ToList();
                _tyrePositions = TyreService.GetTyrePositionListUsingTruckTypeId(detailedTruck.TruckTypeID).ToList();


                var FromDate = DateTime.Now.AddDays(-365);
                _jobHistory = iJobcardService.GetJobsDoneForTruck(truckId.Value,FromDate,DateTime.Now).ToList();

                var _pmServices = iPmService.SelectByTruck(truckId.Value,3).ToList();
                _nextService = _pmServices.OrderBy(s => s.NDate).FirstOrDefault();

                _currentMaintenance = _jobHistory.Where(j =>  j.Status != "COMPLETED").FirstOrDefault();

                if (_tyrePositions.Any())
                {
                    ProcessTyreLayout();              
                }

                _selectedTruck = detailedTruck; // Update without triggering the setter
            }
            else
            {
                Snackbar.Add("Selected truck details could not be found.", Severity.Warning);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading truck details: {ex.Message}", Severity.Error);
        }
        finally
        {
            isLoading = false;
            await InvokeAsync(StateHasChanged);
        }
    }

