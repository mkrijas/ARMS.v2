    @code {
    
    private async Task OpenLiveMapDialog()
    {
        var options = new DialogOptions 
        { 
            CloseOnEscapeKey = true, 
            FullScreen = true,
            CloseButton = true
        };

        var parameters = new DialogParameters();
        
        // Subtract MudBlazor default header height (roughly 64px) for perfect full-screen flush rendering without scrollbars
        parameters.Add("Height", "calc(100vh - 64px)");
        parameters.Add("RegNo", _selectedTruck.RegNo);

        await DialogService.ShowAsync<TruckMapDisplay>("Live Fleet Mission Control", parameters, options);
    }
    
    private TruckModel _selectedTruck;
    private TruckModel SelectedTruck
    {
        get => _selectedTruck;
        set
        {
            if (_selectedTruck != value)
            {
                _selectedTruck = value;
                if (_selectedTruck != null)
                {
                    _ = LoadFullTruckDetails(_selectedTruck.TruckID);
                }
            }
        }
    }


    private IEnumerable<TruckModel> AllTrucks = new List<TruckModel>();
    private bool isLoading = false;

    #region mock // --- Mock Data Properties ---
    private long? _Odometer;
    private int _mockEngineHours;
    private double _FuelEfficiency;
    private double _mockBattery;
    private int _mockFuelLevel;
    private int _mockCoolantTemp;
    private int _mockDaysToService;
    private int _mockKmToService;
    private bool _mockHasActiveDefect;
    private int _Utilization;
    private int _Trips30Days;
