    private void InitializeDataFor(TruckModel truck)
    {
        DateTime last30Days = DateTime.Now.AddDays(-30);
        DateTime Today = DateTime.Now;
        _PastTrips = iTripService.GetTripsByTruckID(truck.TruckID, last30Days, Today)?.ToList();

        _currentEventType = iEventService.GetEventType(truck.CurrentEvent.EventTypeID ?? 0) ?? new EventTypeModel { EventTypeName = "Unknown" };

        _Odometer = truck.CurrentEvent.EventReading;

        if(_Odometer != null)
        {
            _mockEngineHours = (int)_Odometer / 25;
        }
        if (_PastTrips != null && _PastTrips.Count > 0)
        {
            _FuelEfficiency =  Convert.ToDouble(_PastTrips.Average(x => x.Mileage));
        }
        _mockBattery = 0;
        _mockFuelLevel = 0;
        _mockCoolantTemp = 0;
        _mockDaysToService = 0;
        _mockKmToService = 0;

        Random random = new Random();
        _mockHasActiveDefect = random.Next(2) == 1;

        _Trips30Days = _PastTrips.Count;
        _Utilization = _Trips30Days > 0 ? (int)((_PastTrips.Sum(x => x.RunDuration)  * 100) / 720) : 0;
        _IdleDays = 30 - (int)(30 * (_Utilization / 100.0));

        _Revenue = (decimal) _PastTrips.Sum(x => x.Freight);
        _Cost = (decimal)_PastTrips.Sum(x => x.Expenses);

        // Assets and Depreciation
        _assetInfo = iAssetService.SelectByID(truck.AssetID); 

        _aquisitionCost = (decimal)_assetInfo.BookValue;
        int ageYears = DateTime.Now.Year - truck.ManufacturedYear ?? (short)DateTime.Now.Year;
        if (ageYears <= 0) ageYears = 1;
        _Depreciation = _assetInfo.CumulatedDepreciation??0;
        _CurrentValue = _assetInfo.CurrentValue??0;

        // Populate Documents

        docs = iDocs.SelectByAsset(truck.AssetID,false).ToList();

        // Populate consignment info
        _Gcs = iGcService.SelectByTrip(truck.CurrentEvent.TripID).ToList();

    }

