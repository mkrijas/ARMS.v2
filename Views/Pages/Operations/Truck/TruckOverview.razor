                                    <div class="flex-grow-1"><InfoItem Label="Expiry Date" Value="@_mockRcValidTo.ToString("MMM dd, yyyy")" /></div>
                                </div>
                            </div>

                            <MudButton Variant="Variant.Text" StartIcon="@Icons.Material.Filled.FileDownload" Color="Color.Primary" Class="mt-4 rounded-lg align-self-start pa-2" Style="text-transform: none; font-weight: 700;">Download Base Copy</MudButton>
                        </MudPaper>
                    </MudItem>

                    @* Insurance Card *@
                    <MudItem xs="12" md="4">
                        <MudPaper Elevation="2" Class="pa-6 rounded-xl h-100 d-flex flex-column" Style="border: 1px solid rgba(var(--mud-palette-secondary-rgb), 0.1); background: linear-gradient(180deg, rgba(var(--mud-palette-surface-rgb), 1) 0%, rgba(var(--mud-palette-secondary-rgb), 0.02) 100%); overflow: hidden;">
                             <div class="d-flex justify-space-between align-start mb-4">
                                <div class="d-flex align-center gap-3">
                                    <div style="background: rgba(var(--mud-palette-secondary-rgb), 0.1); padding: 8px; border-radius: 12px;">
                                        <MudIcon Icon="@Icons.Material.Filled.Security" Color="Color.Secondary" />
                                    </div>
                                    <MudText Typo="Typo.h6" Class="fw-bold">Insurance Policy</MudText>
                                </div>
                                <div class="pa-2 rounded-pill px-3" style="background: rgba(25, 135, 84, 0.1); border: 1px solid rgba(25, 135, 84, 0.2);">
                                    <MudText Typo="Typo.caption" Style="color: #198754; font-weight: 800; text-transform: uppercase; letter-spacing: 0.5px;">Premium Paid</MudText>
                                </div>
                            </div>

                            <div class="flex-grow-1">
                                <InfoItem Label="Provider" Value="@_mockInsuranceProvider" />
                                <div class="d-flex gap-4 mt-2">
                                    <div class="flex-grow-1"><InfoItem Label="Policy Number" Value="@_mockInsurancePolicyNo" /></div>
                                    <div class="flex-grow-1"><InfoItem Label="Expiry Date" Value="@_mockInsuranceValidTo.ToString("MMM dd, yyyy")" /></div>
                                </div>
                            </div>

                            <MudButton Variant="Variant.Text" StartIcon="@Icons.Material.Filled.History" Color="Color.Secondary" Class="mt-4 rounded-lg align-self-start pa-2" Style="text-transform: none; font-weight: 700;">Renewal History</MudButton>
                        </MudPaper>
                    </MudItem>

                    @* Permit & Fitness Card *@
                    <MudItem xs="12" md="4">
                        <MudPaper Elevation="2" Class="pa-6 rounded-xl h-100 d-flex flex-column" Style="border: 1px solid rgba(var(--mud-palette-info-rgb), 0.1); background: linear-gradient(180deg, rgba(var(--mud-palette-surface-rgb), 1) 0%, rgba(var(--mud-palette-info-rgb), 0.02) 100%); overflow: hidden;">
                             <div class="d-flex justify-space-between align-start mb-4">
                                <div class="d-flex align-center gap-3">
                                    <div style="background: rgba(var(--mud-palette-info-rgb), 0.1); padding: 8px; border-radius: 12px;">
                                        <MudIcon Icon="@Icons.Material.Filled.FactCheck" Color="Color.Info" />
                                    </div>
                                    <MudText Typo="Typo.h6" Class="fw-bold">Permits & Fitness</MudText>
                                </div>
                                <div class="pa-2 rounded-pill px-3" style="background: rgba(25, 135, 84, 0.1); border: 1px solid rgba(25, 135, 84, 0.2);">
                                    <MudText Typo="Typo.caption" Style="color: #198754; font-weight: 800; text-transform: uppercase; letter-spacing: 0.5px;">Compliant</MudText>
                                </div>
                            </div>

                            <div class="flex-grow-1">
                                <div class="d-flex gap-4 mb-2">
                                    <div class="flex-grow-1"><InfoItem Label="National Permit" Value="@_mockPermitNo" /></div>
                                    <div class="flex-grow-1"><InfoItem Label="Valid To" Value="@_mockPermitValidTo.ToString("MMM dd, yyyy")" /></div>
                                </div>
                                <div class="d-flex gap-4 mt-2">
                                    <div class="flex-grow-1"><InfoItem Label="Fitness Number" Value="@_mockFcNo" /></div>
                                    <div class="flex-grow-1"><InfoItem Label="Valid To" Value="@_mockFcValidTo.ToString("MMM dd, yyyy")" /></div>
                                </div>
                            </div>

                            <MudButton Variant="Variant.Text" StartIcon="@Icons.Material.Filled.CalendarToday" Color="Color.Info" Class="mt-4 rounded-lg align-self-start pa-2" Style="text-transform: none; font-weight: 700;">Check Compliance</MudButton>
                        </MudPaper>
                    </MudItem>
                </MudGrid>
            </MudTabPanel>

             <MudTabPanel Text="Current Event" Icon="@Icons.Material.Filled.Event">
                @if (SelectedTruck.CurrentEvent != null && SelectedTruck.CurrentEvent.TruckEventID != null)
                {
                    <MudPaper Elevation="4" Class="pa-8 rounded-xl overflow-hidden" Style="border: 1px solid rgba(var(--mud-palette-warning-rgb), 0.1); background: linear-gradient(135deg, rgba(var(--mud-palette-surface-rgb), 1) 0%, rgba(var(--mud-palette-warning-rgb), 0.05) 100%);">
                        @* Header Section *@
                        <div class="d-flex justify-space-between align-center mb-8">
                            <div class="d-flex align-center gap-4">
                                <div style="background: var(--mud-palette-warning); padding: 12px; border-radius: 16px; box-shadow: 0 4px 12px rgba(var(--mud-palette-warning-rgb), 0.3);">
                                    <MudIcon Icon="@Icons.Material.Filled.Navigation" Color="Color.Surface" />
                                </div>
                                <div>
                                    <MudText Typo="Typo.h5" Class="fw-bold">Active Mission</MudText>
                                    <MudText Typo="Typo.caption" Color="Color.Secondary" Style="font-weight: 700; text-transform: uppercase;">ID: #@SelectedTruck.CurrentEvent.TruckEventID</MudText>
                                </div>
                            </div>
                            <div class="pa-2 rounded-pill px-4 d-flex align-center gap-2" style="background: rgba(var(--mud-palette-warning-rgb), 0.1); border: 1px solid rgba(var(--mud-palette-warning-rgb), 0.2);">
                                <div style="width: 8px; height: 8px; border-radius: 50%; background: var(--mud-palette-warning); animation: pulse 1.5s infinite;"></div>
                                <MudText Typo="Typo.caption" Style="color: var(--mud-palette-warning-darken); font-weight: 800; text-transform: uppercase;">In Transit</MudText>
                            </div>
                        </div>

                        @* Journey Visual Flow *@
                        <div class="journey-flow-container pa-6 mb-8 rounded-xl" style="background: rgba(var(--mud-palette-surface-rgb), 0.5); border: 1px solid rgba(0,0,0,0.05);">
                            <MudGrid AlignItems="Center">
                                <MudItem xs="4" Class="text-center">
                                    <MudIcon Icon="@Icons.Material.Filled.LocationOn" Color="Color.Primary" Size="Size.Large" Class="mb-2" />
                                    <MudText Typo="Typo.h6" Class="fw-bold">@SelectedTruck.CurrentEvent.OriginName</MudText>
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">Departure Point</MudText>
                                </MudItem>
                                
                                <MudItem xs="4" Class="d-flex flex-column align-center">
                                    <div style="width: 100%; height: 2px; background: linear-gradient(90deg, var(--mud-palette-primary) 0%, var(--mud-palette-warning) 50%, var(--mud-palette-success) 100%); position: relative; margin-bottom: 24px;">
                                        <div style="position: absolute; top: 50%; left: 65%; transform: translate(-50%, -50%); background: var(--mud-palette-warning); padding: 6px; border-radius: 50%; box-shadow: 0 0 10px var(--mud-palette-warning);">
                                            <MudIcon Icon="@Icons.Material.Filled.LocalShipping" Color="Color.Surface" Size="Size.Small" />
                                        </div>
                                    </div>
                                    <MudText Typo="Typo.body2" Class="fw-bold" Color="Color.Warning">65% Progress</MudText>
                                    <MudText Typo="Typo.caption">~14 hours remaining</MudText>
                                </MudItem>

                                <MudItem xs="4" Class="text-center">
                                    <MudIcon Icon="@Icons.Material.Filled.Flag" Color="Color.Success" Size="Size.Large" Class="mb-2" />
                                    <MudText Typo="Typo.h6" Class="fw-bold">@SelectedTruck.CurrentEvent.DestinationName</MudText>
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">Delivery Point</MudText>
                                </MudItem>
                            </MudGrid>
                        </div>

                        @* Detailed Stats Grid *@
                        <MudGrid Spacing="4">
                            <MudItem xs="12" md="3">
                                <InfoItem Label="Assignment" Value="Industrial Logistics" />
                            </MudItem>
                            <MudItem xs="12" md="3">
                                <InfoItem Label="Cargo Class" Value="Bulk Steel Products" />
                            </MudItem>
                            <MudItem xs="12" md="3">
                                <InfoItem Label="Event Time" Value="@SelectedTruck.CurrentEvent.EventTime?.ToString("MMM dd, HH:mm")" />
                            </MudItem>
                            <MudItem xs="12" md="3">
                                <InfoItem Label="Est. Arrival" Value="@SelectedTruck.CurrentEvent.EventTime?.AddHours(14).ToString("MMM dd, HH:mm")" />
                            </MudItem>
                        </MudGrid>

                        <div class="mt-8 d-flex gap-4">
                            <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Map" Class="rounded-pill px-6">View Live Map</MudButton>
                            <MudButton Variant="Variant.Outlined" Color="Color.Warning" StartIcon="@Icons.Material.Filled.PhoneAndroid" Class="rounded-pill px-6">Contact Driver</MudButton>
                        </div>
                    </MudPaper>
                }
                else
                {
                    <div class="pa-12 rounded-xl text-center" style="border: 2px dashed rgba(var(--mud-palette-primary-rgb), 0.2); background: rgba(var(--mud-palette-primary-rgb), 0.02);">
                         <MudIcon Icon="@Icons.Material.Filled.EventAvailable" Size="Size.Large" Color="Color.Primary" Class="mb-4" Style="font-size: 5rem; opacity: 0.3;" />
                         <MudText Typo="Typo.h5" Class="fw-bold">No Active Assignment</MudText>
                         <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mt-2">This truck is currently idle and ready for its next mission.</MudText>
                         <MudButton Variant="Variant.Filled" Color="Color.Primary" Class="mt-8 rounded-pill px-8" StartIcon="@Icons.Material.Filled.Add">Assign New Trip</MudButton>
                    </div>
                }
            </MudTabPanel>

            @* ---------------- NEW TABS WITH MOCK DATA ---------------- *@

            <MudTabPanel Text="Telematics" Icon="@Icons.Material.Filled.Sensors">
                <MudGrid>
                    <MudItem xs="12" md="4">
                        <MudPaper Elevation="4" Class="pa-6 d-flex align-center gap-6" Style="border-radius: 20px; border-left: 6px solid var(--mud-palette-info); background: linear-gradient(135deg, var(--mud-palette-surface) 0%, rgba(var(--mud-palette-info-rgb), 0.05) 100%);">
                            <div style="background: rgba(var(--mud-palette-info-rgb), 0.1); padding: 12px; border-radius: 16px;">
                                <MudIcon Icon="@Icons.Material.Filled.Speed" Color="Color.Info" Size="Size.Large" />
                            </div>
                            <div>
                                <MudText Typo="Typo.caption" Color="Color.Secondary" Style="font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px;">Odometer</MudText>
                                <MudText Typo="Typo.h5" Class="fw-bold">@(_mockOdometer.ToString("N0")) km</MudText>
                            </div>
                        </MudPaper>
                    </MudItem>
                    <MudItem xs="12" md="4">
                        <MudPaper Elevation="4" Class="pa-6 d-flex align-center gap-6" Style="border-radius: 20px; border-left: 6px solid var(--mud-palette-warning); background: linear-gradient(135deg, var(--mud-palette-surface) 0%, rgba(var(--mud-palette-warning-rgb), 0.05) 100%);">
                             <div style="background: rgba(var(--mud-palette-warning-rgb), 0.1); padding: 12px; border-radius: 16px;">
                                <MudIcon Icon="@Icons.Material.Filled.Timer" Color="Color.Warning" Size="Size.Large" />
                            </div>
                            <div>
                                <MudText Typo="Typo.caption" Color="Color.Secondary" Style="font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px;">Engine Runtime</MudText>
                                <MudText Typo="Typo.h5" Class="fw-bold">@(_mockEngineHours.ToString("N0")) hrs</MudText>
                            </div>
                        </MudPaper>
                    </MudItem>
                    <MudItem xs="12" md="4">
                        <MudPaper Elevation="4" Class="pa-6 d-flex align-center gap-6" Style="border-radius: 20px; border-left: 6px solid var(--mud-palette-success); background: linear-gradient(135deg, var(--mud-palette-surface) 0%, rgba(var(--mud-palette-success-rgb), 0.05) 100%);">
                             <div style="background: rgba(var(--mud-palette-success-rgb), 0.1); padding: 12px; border-radius: 16px;">
                                <MudIcon Icon="@Icons.Material.Filled.LocalGasStation" Color="Color.Success" Size="Size.Large" />
                            </div>
                            <div>
                                <MudText Typo="Typo.caption" Color="Color.Secondary" Style="font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px;">Efficiency</MudText>
                                <MudText Typo="Typo.h5" Class="fw-bold">@(_mockFuelEfficiency.ToString("F1")) km/L</MudText>
                            </div>
                        </MudPaper>
                    </MudItem>
                    
                    <MudItem xs="12" md="6">
                        <MudPaper Elevation="2" Class="pa-6" Style="border-radius: 20px;">
                            <MudText Typo="Typo.h6" Class="mb-6 fw-bold">Live Diagnostics</MudText>
                            <div class="mb-6">
                                <div class="d-flex justify-space-between mb-2">
                                    <MudText Typo="Typo.body2" Class="fw-bold">Battery Health</MudText>
                                    <MudText Typo="Typo.body2" Class="fw-bold text-success">@(_mockBattery)V</MudText>
                                </div>
                                <MudProgressLinear Color="Color.Success" Value="92" Size="Size.Large" Style="height: 10px; border-radius: 5px;" />
                            </div>

                            <div class="mb-6">
                                <div class="d-flex justify-space-between mb-2">
                                    <MudText Typo="Typo.body2" Class="fw-bold">Fuel Payload</MudText>
                                    <MudText Typo="Typo.body2" Class="fw-bold" Color="Color.Info">@(_mockFuelLevel)% (@($"{(_mockFuelLevel / 100.0 * (double)SelectedTruck?.FuelTankCapacity):F0}") L)</MudText>
                                </div>
                                <MudProgressLinear Color="Color.Info" Value="@_mockFuelLevel" Size="Size.Large" Style="height: 10px; border-radius: 5px;" />
                            </div>

                            <div>
                                <div class="d-flex justify-space-between mb-2">
                                    <MudText Typo="Typo.body2" Class="fw-bold">Coolant Status</MudText>
                                    <MudText Typo="Typo.body2" Class="fw-bold">@(_mockCoolantTemp)°C</MudText>
                                </div>
                                <MudProgressLinear Color="Color.Warning" Value="@_mockCoolantTemp" Max="120" Size="Size.Large" Style="height: 10px; border-radius: 5px;" />
                            </div>
                        </MudPaper>
                    </MudItem>

                    <MudItem xs="12">
                        <MudPaper Elevation="2" Class="pa-8 h-100" Style="border-radius: 24px;">
                             <div class="d-flex justify-space-between align-center mb-10">
                                 <div>
                                     <MudText Typo="Typo.h5" Class="fw-bold">Tire Matrix (TPMS)</MudText>
                                     <MudText Typo="Typo.caption" Color="Color.Secondary" Style="font-weight: 700;">Live Mounting Layout & Live Diagnostics</MudText>
                                 </div>
                                 <div class="d-flex gap-4">
                                     <div class="d-flex align-center gap-2">
                                         <div style="width: 12px; height: 12px; border-radius: 50%; background: var(--mud-palette-success);"></div>
                                         <MudText Typo="Typo.caption" Class="fw-bold">Optimal</MudText>
                                     </div>
                                     <div class="d-flex align-center gap-2">
                                         <div style="width: 12px; height: 12px; border-radius: 50%; background: var(--mud-palette-warning);"></div>
                                         <MudText Typo="Typo.caption" Class="fw-bold">Check Pressure</MudText>
                                     </div>
                                 </div>
                             </div>

                             @if (!_parsedAxles.Any())
                             {
                                 <div class="pa-12 text-center rounded-xl" style="background: rgba(0,0,0,0.02); border: 2px dashed rgba(0,0,0,0.1);">
                                     <MudIcon Icon="@Icons.Material.Filled.SearchOff" Size="Size.Large" Color="Color.Default" Class="mb-2" />
                                     <MudText Color="Color.Secondary">No tyre position layout defined for this truck type.</MudText>
                                 </div>
                             }
                             else
                             {
                                 <div class="truck-tpms-v2 mx-auto" style="overflow-x: auto;">
                                     @* Side Markers *@
                                     <div class="side-marker-label side-marker-left">LEFT SIDE</div>
                                     <div class="side-marker-label side-marker-right">RIGHT SIDE</div>

                                     @* Truck Front Hook *@
                                     <div class="truck-cab-visual">
                                         <div class="cab-nose"></div>
                                         <MudIcon Icon="@Icons.Material.Filled.LocalShipping" Color="Color.Surface" Size="Size.Large" />
                                         <MudText Typo="Typo.overline" Style="color: rgba(255,255,255,0.7); font-weight: 900; margin-top: 8px;">FRONT</MudText>
                                     </div>

                                     @* Chassis Spine (Horizontal) *@
                                     <div class="chassis-beam"></div>

                                     @foreach (var axle in _parsedAxles)
                                     {
                                         <div class="axle-row-container">
                                             <div class="axle-label-badge">@axle.AxleName</div>
                                             
                                             <div class="axle-line-refined">
                                                 @foreach (var pos in axle.Positions)
                                                 {
                                                     var col = GetColumnOrder(pos.Description);
                                                     var mounted = _mountedTyres.FirstOrDefault(t => t.PositionID == pos.PositionID);
                                                     var sideClass = col switch { 
                                                         1 => "p-outer-left", 
                                                         2 => "p-inner-left", 
                                                         3 => "p-inner-right", 
                                                         4 => "p-outer-right", 
                                                         _ => "" 
                                                     };

                                                     var rnd = new Random(SelectedTruck.RegNo.GetHashCode() + (axle.Order * 10) + col);
                                                     int psi = rnd.Next(98, 115);
                                                     var isWarning = psi < 105;
                                                     var brand = GetMockBrand(rnd);

                                                     <MudTooltip Text="@($"{pos.Description} {(mounted != null ? $" - {mounted.TyreNo} ({brand})" : " (Unmounted)")}")">
                                                         <div class="tpms-tire-card @sideClass @(mounted == null ? "status-empty" : (isWarning ? "status-warning" : ""))">
                                                             @if (mounted != null)
                                                             {
                                                                 <div class="tire-status-dot"></div>
                                                                 <div class="tire-serial-badge">@mounted.TyreNo</div>
                                                                 <div class="tire-brand-name">@brand</div>
                                                                 
                                                                 @* Hidden psi context for tooltip/hover effect feel *@
                                                                 <div style="font-size: 0.55rem; color: #6c757d; margin-top: 6px; font-weight: 700;">@psi PSI</div>
                                                             }
                                                             else
                                                             {
                                                                 <MudIcon Icon="@Icons.Material.Filled.Add" Size="Size.Small" />
                                                                 <div style="font-size: 0.5rem; text-transform: uppercase; margin-top: 4px;">Empty</div>
                                                             }
                                                         </div>
                                                     </MudTooltip>
                                                 }
                                             </div>
                                         </div>
                                     }
                                 </div>
                             }
                        </MudPaper>
                    </MudItem>
                </MudGrid>
            </MudTabPanel>

            <MudTabPanel Text="Maintenance" Icon="@Icons.Material.Filled.Handyman">
                <MudGrid>
                    <MudItem xs="12">
                         <MudCard Elevation="4" Class="mb-6 overflow-hidden" Style="border-radius: 20px; background: linear-gradient(135deg, var(--mud-palette-primary) 0%, var(--mud-palette-primary-darken) 100%);">
                            <MudCardContent Class="pa-8 d-flex justify-space-between align-center">
                                <div>
                                    <MudText Typo="Typo.h5" Style="color: white; font-weight: 800;">Next Service Window</MudText>
                                    <MudText Typo="Typo.body1" Style="color: rgba(255,255,255,0.7);">Standard Preventive Maintenance (Type A)</MudText>
                                </div>
                                <div class="text-right">
                                    <MudText Typo="Typo.h2" Style="color: white; font-weight: 900; line-height: 1;">@(_mockDaysToService) <span style="font-size: 1.5rem; opacity: 0.6;">Days</span></MudText>
                                    <MudText Typo="Typo.h6" Style="color: rgba(255,255,255,0.8); font-weight: 500;">or @(_mockKmToService.ToString("N0")) km</MudText>
                                </div>
                            </MudCardContent>
                            <div style="height: 6px; background: rgba(0,0,0,0.1); width: 100%;">
                                <div style="height: 100%; background: white; width: 75%; opacity: 0.3;"></div>
                            </div>
                        </MudCard>
                    </MudItem>

                    <MudItem xs="12" md="6">
                        <MudPaper Elevation="2" Class="pa-6" Style="border-radius: 20px;">
                            <MudText Typo="Typo.h6" Class="mb-6 fw-bold">Service Timeline</MudText>
                            <MudTimeline TimelinePosition="TimelinePosition.Start">
                                <MudTimelineItem Color="Color.Info" Size="Size.Small">
                                    <ItemContent>
                                        <MudText Typo="Typo.subtitle1" Class="fw-bold">Brake System Overhaul</MudText>
                                        <MudText Typo="Typo.caption" Color="Color.Secondary">@DateTime.Now.AddDays(-14).ToString("MMM dd, yyyy") • Main Workshop</MudText>
                                    </ItemContent>
                                </MudTimelineItem>
                                <MudTimelineItem Color="Color.Success" Size="Size.Small">
                                    <ItemContent>
                                        <MudText Typo="Typo.subtitle1" Class="fw-bold">Routine Oil & Filter Change</MudText>
                                        <MudText Typo="Typo.caption" Color="Color.Secondary">@DateTime.Now.AddDays(-45).ToString("MMM dd, yyyy") • Regional Hub</MudText>
                                    </ItemContent>
                                </MudTimelineItem>
                                <MudTimelineItem Color="Color.Warning" Size="Size.Small">
