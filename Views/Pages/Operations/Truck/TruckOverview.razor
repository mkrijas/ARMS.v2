@code {
    private TruckModel _selectedTruck;
    private TruckModel SelectedTruck
    {
        get => _selectedTruck;
        set
        {
            if (_selectedTruck != value)
            {
                _selectedTruck = value;
                if (_selectedTruck != null)
                {
                    _ = LoadFullTruckDetails(_selectedTruck.TruckID);
                }
            }
        }
    }

    private IEnumerable<TruckModel> AllTrucks = new List<TruckModel>();
    private bool isLoading = false;

    // --- Mock Data Properties ---
    private int _mockOdometer;
    private int _mockEngineHours;
    private double _mockFuelEfficiency;
    private double _mockBattery;
    private int _mockFuelLevel;
    private int _mockCoolantTemp;
    private int _mockDaysToService;
    private int _mockKmToService;
    private bool _mockHasActiveDefect;
    private int _mockUtilization;
    private int _mockTrips30Days;
    private int _mockIdleDays;
    private List<TyreMountedModel> _mountedTyres = new();
    private List<TyrePositionModel> _tyrePositions = new();
    private List<AxleData> _parsedAxles = new();

    private class AxleData
    {
        public string AxleName { get; set; }
        public int Order { get; set; }
        public List<TyrePositionModel> Positions { get; set; } = new();
    }
    private decimal _mockRevenue;
    private decimal _mockCost;
    private decimal _mockDepreciation;
    private decimal _mockCurrentValue;
    private List<MockTrip> _mockPastTrips = new();

    // Document Mock Properties
    private string _mockInsuranceProvider;
    private string _mockInsurancePolicyNo;
    private DateTime _mockInsuranceValidTo;
    private string _mockPermitNo;
    private DateTime _mockPermitValidTo;
    private string _mockFcNo;
    private DateTime _mockFcValidTo;
    private string _mockRcNo;
    private DateTime _mockRcValidTo;

    private class MockTrip
    {
        public string TripID { get; set; }
        public string Origin { get; set; }
        public string Destination { get; set; }
        public DateTime Date { get; set; }
        public int Distance { get; set; }
    }

    private void InitializeMockDataFor(TruckModel truck)
    {
        // Use RegNo hash to ensure consistent random data per truck
        var rnd = new Random(truck.RegNo.GetHashCode());

        _mockOdometer = rnd.Next(25000, 350000);
        _mockEngineHours = _mockOdometer / rnd.Next(35, 55);
        _mockFuelEfficiency = rnd.NextDouble() * (4.5 - 2.8) + 2.8;
        _mockBattery = Math.Round(rnd.NextDouble() * (14.2 - 12.5) + 12.5, 1);
        _mockFuelLevel = rnd.Next(15, 100);
        _mockCoolantTemp = rnd.Next(80, 95);

        _mockDaysToService = rnd.Next(5, 45);
        _mockKmToService = rnd.Next(1000, 8000);
        _mockHasActiveDefect = rnd.Next(0, 10) > 7; // 30% chance of defect

        _mockUtilization = rnd.Next(65, 95);
        _mockTrips30Days = rnd.Next(4, 15);
        _mockIdleDays = 30 - (int)(30 * (_mockUtilization / 100.0));

        _mockRevenue = (decimal)(rnd.NextDouble() * (8500000 - 1500000) + 1500000);
        _mockCost = (decimal)(rnd.NextDouble() * (450000 - 150000) + 150000);

        // Assets and Depreciation
        decimal acquisitionCost = _mockRevenue / 3.5m;
        int ageYears = DateTime.Now.Year - (truck.ManufacturedYear ?? (short)DateTime.Now.Year);
        if (ageYears <= 0) ageYears = 1;
        _mockDepreciation = acquisitionCost * (decimal)(ageYears * 0.12); // 12% annual depreciation
        _mockCurrentValue = acquisitionCost - _mockDepreciation;
        if (_mockCurrentValue < acquisitionCost * 0.2m) _mockCurrentValue = acquisitionCost * 0.2m; // Salvage value floor

        _mockPastTrips = new List<MockTrip>();
        string[] cities = { "Mumbai", "Delhi", "Chennai", "Kolkata", "Bangalore", "Hyderabad", "Pune", "Ahmedabad" };
        for(int i = 0; i < 5; i++)
        {
            _mockPastTrips.Add(new MockTrip {
                TripID = $"TRP-{rnd.Next(10000, 99999)}",
                Origin = cities[rnd.Next(cities.Length)],
                Destination = cities[rnd.Next(cities.Length)],
                Date = DateTime.Now.AddDays(-rnd.Next(5, 60)),
                Distance = rnd.Next(300, 1500)
            });
        }
        
        // Populate Documents
        _mockInsuranceProvider = "ICICI Lombard General";
        _mockInsurancePolicyNo = $"INS-{rnd.Next(1000000, 9999999)}";
        _mockInsuranceValidTo = DateTime.Now.AddDays(rnd.Next(30, 300));
        
        _mockPermitNo = $"PER-{rnd.Next(10000, 99999)}";
        _mockPermitValidTo = DateTime.Now.AddDays(rnd.Next(60, 365));
        
        _mockFcNo = $"FTC-{rnd.Next(10000, 99999)}";
        _mockFcValidTo = DateTime.Now.AddDays(rnd.Next(45, 180));

        _mockRcNo = $"REG-{rnd.Next(100000, 999999)}";
        _mockRcValidTo = DateTime.Now.AddYears(rnd.Next(5, 12));
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadInitialTrucksList();
    }

    private async Task LoadInitialTrucksList()
    {
        isLoading = true;
        try
        {
            // Assuming this loads a lightweight list of trucks. Passing no BranchID and "All" fetches all trucks usually.
            AllTrucks = await Task.Run(() => TruckService.SelectAllByBranch(false, null, "All", "AllOperation"));
        }
        catch (Exception ex)
        {
            Snackbar.Add("Failed to load trucks list.", Severity.Error);
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task<IEnumerable<TruckModel>> SearchTrucks(string value, CancellationToken token)
    {
        // if text is null or empty, return all trucks within reasonable limit
        if (string.IsNullOrEmpty(value))
            return AllTrucks.Take(10);

        return AllTrucks.Where(x => x.RegNo.Contains(value, StringComparison.InvariantCultureIgnoreCase)).Take(10);
    }

    private async Task LoadFullTruckDetails(int? truckId)
    {
        if (truckId == null) return;

        isLoading = true;
        await InvokeAsync(StateHasChanged); // Force update to show loading indicator

        try
        {
            var detailedTruck = await Task.Run(() => TruckService.SelectByID(truckId));
            var registration = await Task.Run(() => TruckService.GetRegistration(truckId));
            
            if (detailedTruck != null)
            {
                var rnd = new Random(detailedTruck.RegNo.GetHashCode());

                // Inject realistic mock data for empty properties to ensure UI isn't empty 
                // ONLY DO THIS FOR DEMO/MOCKING PURPOSES IF ACTUAL DATA IS MISSING
                detailedTruck.TruckType = string.IsNullOrWhiteSpace(detailedTruck.TruckType) ? "Heavy Commercial Vehicle" : detailedTruck.TruckType;
                detailedTruck.BodyType = string.IsNullOrWhiteSpace(detailedTruck.BodyType) ? "Bulker" : detailedTruck.BodyType;
                detailedTruck.BSType = string.IsNullOrWhiteSpace(detailedTruck.BSType) ? "BS-VI" : detailedTruck.BSType;
                detailedTruck.TransmissionType = string.IsNullOrWhiteSpace(detailedTruck.TransmissionType) ? "Manual 8-Speed" : detailedTruck.TransmissionType;
                detailedTruck.FuelType = string.IsNullOrWhiteSpace(detailedTruck.FuelType) ? "Diesel" : detailedTruck.FuelType;
                detailedTruck.ChassisNumber = string.IsNullOrWhiteSpace(detailedTruck.ChassisNumber) ? $"MAT{DateTime.Now.Ticks.ToString().Substring(0, 10)}" : detailedTruck.ChassisNumber;
                detailedTruck.EngineNumber = string.IsNullOrWhiteSpace(detailedTruck.EngineNumber) ? $"ENG{DateTime.Now.Ticks.ToString().Substring(2, 8)}" : detailedTruck.EngineNumber;
                
                detailedTruck.OperatingBranchName = string.IsNullOrWhiteSpace(detailedTruck.OperatingBranchName) ? "Main Hub (Mock)" : detailedTruck.OperatingBranchName;
                detailedTruck.HomeBranchName = string.IsNullOrWhiteSpace(detailedTruck.HomeBranchName) ? "Regional HQ" : detailedTruck.HomeBranchName;
                detailedTruck.DriverName = string.IsNullOrWhiteSpace(detailedTruck.DriverName) ? "Rajesh Kumar" : detailedTruck.DriverName;

                if (detailedTruck.AssetID == null || detailedTruck.AssetID == 0) detailedTruck.AssetID = rnd.Next(100, 999);
                if (detailedTruck.GpsDeviceID == null || detailedTruck.GpsDeviceID == 0) detailedTruck.GpsDeviceID = rnd.Next(10000, 99999);
                if (detailedTruck.FuelTankCapacity == null || detailedTruck.FuelTankCapacity == 0) detailedTruck.FuelTankCapacity = 350;
                if (detailedTruck.wheels == null || detailedTruck.wheels == 0) detailedTruck.wheels = 10;
                if (detailedTruck.UnladenWeight == null || detailedTruck.UnladenWeight == 0) detailedTruck.UnladenWeight = 8500;
                if (detailedTruck.GrossWeight == null || detailedTruck.GrossWeight == 0) detailedTruck.GrossWeight = 25000;
                if (detailedTruck.ManufacturedYear == null || detailedTruck.ManufacturedYear == 0) detailedTruck.ManufacturedYear = (short)DateTime.Now.AddYears(-3).Year;
                if (detailedTruck.PurchaseDate == null || detailedTruck.PurchaseDate == DateTime.MinValue) detailedTruck.PurchaseDate = DateTime.Now.AddYears(-rnd.Next(1, 4));

                if (registration == null || string.IsNullOrWhiteSpace(registration.RC))
                {
                    // Mock registration info
                    registration = new TruckRegistrationModel
                    {
                        RegNo = detailedTruck.RegNo,
                        EffectFrom = DateTime.Now.AddYears(-1),
                        EffectTo = DateTime.Now.AddYears(1),
                        RC = "rc_document_v2_signed.pdf"
                    };
                }
                
                // Keep genuine registration info if it has dates
                if(registration.EffectFrom == null) registration.EffectFrom = DateTime.Now.AddYears(-2);
                if(registration.EffectTo == null) registration.EffectTo = DateTime.Now.AddYears(2);
                if(string.IsNullOrWhiteSpace(registration.RC)) registration.RC = "rc_approved.pdf";

                detailedTruck.CurrentRegistration = registration;

                // Current Event mock
                if (detailedTruck.CurrentEvent == null || detailedTruck.CurrentEvent.TruckEventID == null || detailedTruck.CurrentEvent.TruckEventID == 0)
                {
                    detailedTruck.CurrentEvent = new EventModel
                    {
                        TruckEventID = rnd.Next(1000, 9999),
                        OriginName = "Loading Terminal A",
                        DestinationName = "Warehouse B",
                        EventTime = DateTime.Now.AddHours(-rnd.Next(1, 12)),
                        AcceptedKM = rnd.Next(100, 500)
                    };
                }

                // Initialize Mock values for specific truck
                InitializeMockDataFor(detailedTruck);

                // Fetch real tyre data
                _mountedTyres = (await Task.Run(() => TyreService.SelectMountedTyresByID(truckId))).ToList();
                var positions = (await Task.Run(() => TyreService.GetTyrePositionListUsingTruckTypeId(detailedTruck.TruckTypeID))).ToList();
                _tyrePositions = positions;

                if (_tyrePositions.Any())
                {
                    ProcessTyreLayout();
                }

                _selectedTruck = detailedTruck; // Update without triggering the setter
            }
            else
            {
                 Snackbar.Add("Selected truck details could not be found.", Severity.Warning);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading truck details: {ex.Message}", Severity.Error);
        }
        finally
        {
            isLoading = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private void ClearSelection()
    {
        _selectedTruck = null;
    }

    private void ProcessTyreLayout()
    {
        _parsedAxles.Clear();
        if (!_tyrePositions.Any()) return;

        var axleGroups = _tyrePositions.GroupBy(p => GetAxleName(p.Description));

        foreach (var group in axleGroups)
        {
            var axle = new AxleData
            {
                AxleName = group.Key,
                Order = GetAxleOrder(group.Key),
                Positions = group.OrderBy(p => GetColumnOrder(p.Description)).ToList()
            };
            _parsedAxles.Add(axle);
        }

        _parsedAxles = _parsedAxles.OrderBy(a => a.Order).ToList();
    }

    private string GetAxleName(string desc)
    {
        if (string.IsNullOrEmpty(desc)) return "Other Position";
        
        // Match standard axle patterns: "Front Axle", "1st Drive-Axle", "3rd Trailer-Axle"
        var lowercase = desc.ToLower();
        if (lowercase.Contains("front")) return "Front Axle";
        
        // Use regex or splitting to find groups like "1st Drive-Axle"
        var parts = desc.Split(' ');
        if (parts.Length > 1)
        {
            // Join parts until we hit a directional keyword
            var axleParts = new List<string>();
            foreach(var part in parts)
            {
                var p = part.ToLower();
                if (p == "left" || p == "right" || p == "inner" || p == "outer") break;
                axleParts.Add(part);
            }
            return string.Join(" ", axleParts);
        }
        
        return desc;
    }

    private int GetAxleOrder(string name)
    {
        var n = name.ToLower();
        if (n.Contains("front")) return 10;
        if (n.Contains("steer")) return 11;
        
        if (n.Contains("drive"))
        {
            if (n.Contains("1st")) return 20;
            if (n.Contains("2nd")) return 21;
            return 25;
        }
        
        if (n.Contains("trailer"))
        {
            if (n.Contains("1st")) return 30;
            if (n.Contains("2nd")) return 31;
            if (n.Contains("3rd")) return 32;
            if (n.Contains("4th")) return 33;
            return 39;
        }
        
        return 100;
    }

    private int GetColumnOrder(string desc)
    {
        var d = desc.ToLower();
        if (d.Contains("outer left")) return 1;
        if (d.Contains("inner left") || (d.Contains("left") && !d.Contains("outer") && !d.Contains("inner"))) return 2;
        if (d.Contains("inner right") || (d.Contains("right") && !d.Contains("outer") && !d.Contains("inner"))) return 3;
        if (d.Contains("outer right")) return 4;
        return 2; // Default to inner
    }

    private string GetMockBrand(Random rnd)
    {
        string[] brands = { "MRF", "Apollo", "CEAT", "Bridgestone", "Michelin", "JK Tyre" };
        return brands[rnd.Next(brands.Length)];
    }
}
