@using System.Threading;
@using System.Globalization
@attribute [Authorize]
@inject AuthenticationStateProvider auth
@inject MudBlazor.ISnackbar snackbar
@inject ITruckService Iservice
@inject IDialogService DialogService
@inject IRoleService<RoleModel> Irole

<MudDialog Class="admin-dialog-glass">
    <TitleContent>
        <div class="header-section mb-2 pt-4 px-4">
            <div class="d-flex align-center justify-space-between">
                <div class="d-flex align-center">
                    <div class="icon-badge primary-badge mr-4">
                        <div class="admin-header-icon-badge mb-3">
                            <MudIcon Icon="@Icons.Material.Filled.AppRegistration" Color="Color.Secondary" Style="font-size: 3rem;" />
                        </div>
                    </div>
                    <div>
                        <MudText Typo="Typo.h5" Class="admin-title"><b>Fleet Registration</b></MudText>
                        <MudText Typo="Typo.body2" Class="admin-subtitle">
                            Formalize and document vehicle registration records (RC) for compliance tracking.
                        </MudText>
                    </div>
                </div>
            </div>
            <div class="title-accent mt-4"></div>
        </div>
    </TitleContent>
    <DialogContent>
        <MudContainer Class="admin-dialog-container">
            <div class="dialog-content-wrapper pa-2" style="max-height:500px;overflow-y:auto">
                <EditForm id="truckForm" Model="@CurrentRegistration" OnValidSubmit="OnValidSubmit">
                    <div class="admin-glass-card pa-6">
                        <DataAnnotationsValidator />
                        <ValidationSummary />
                        <MudGrid Spacing="4">
                            <MudItem xs="12">
                                <MudTextField Immediate="true" Value="CurrentRegistration.RegNo" T="string" ValueChanged="RegNoUpdated" Class="ToUpperCase modern-input" Margin="Margin.Normal" Label="Registered Number" Variant="Variant.Outlined" For="@(() => CurrentRegistration.RegNo)" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Pin"></MudTextField>
                            </MudItem>
                            <MudItem xs="6">
                                <MudDatePicker Margin="Margin.Normal" Variant="Variant.Outlined" Label="Validity Start" DisableToolbar="true" Editable="true" @bind-Date="CurrentRegistration.EffectFrom" HelperText="Registry commencement date" Culture="@CultureInfo.GetCultureInfo("en-IN")" Class="modern-input" />
                            </MudItem>
                            <MudItem xs="6">
                                <MudDatePicker Margin="Margin.Normal" Variant="Variant.Outlined" Label="Validity Expiry" DisableToolbar="true" Editable="true" @bind-Date="CurrentRegistration.EffectTo" HelperText="Mandatory expiration date" Culture="@CultureInfo.GetCultureInfo("en-IN")" Class="modern-input" />
                            </MudItem>
                            <MudItem xs="12">
                                <div class="pa-4 rounded-lg" style="background: rgba(54, 117, 136, 0.05); border: 1px dashed rgba(54, 117, 136, 0.3);">
                                    <MyFileUpload FolderName="Truck/RC" FileName="@Guid.NewGuid().ToString()" Label="Upload RC Certificate (PDF/Image)" @bind-FilePath="CurrentRegistration.RC"></MyFileUpload>
                                    @if (!string.IsNullOrEmpty(CurrentRegistration.RC))
                                    {
                                        <div class="mt-2 d-flex align-center">
                                            <MudIcon Icon="@Icons.Material.Filled.Description" Color="Color.Primary" Class="mr-2" />
                                            <a href="@CurrentRegistration.RC" download="RC" class="admin-link">
                                                <b>Download Registered Certificate</b>
                                                <MudIcon Icon="@Icons.Material.Filled.Download" Size="Size.Small" />
                                            </a>
                                        </div>
                                    }
                                </div>
                            </MudItem>
                            <MudItem xs="12" Class="d-flex justify-center mt-4">
                                <div class="rc-preview-container rounded-lg overflow-hidden" style="width: 100%; border: 1px solid rgba(0,0,0,0.1); background: #f5f5f5;">
                                    @if (string.IsNullOrEmpty(CurrentRegistration.RC))
                                    {
                                        <MudImage Fluid ObjectFit="ObjectFit.Contain" Src="/ArmsStaticFiles/Truck/RC.webp" Alt="RC PREVIEW" Style="max-height: 250px; width: 100%;" />
                                    }
                                    else
                                    {
                                        <MudImage Fluid ObjectFit="ObjectFit.Contain" Src="@CurrentRegistration.RC" Alt="RC DOCUMENT" Style="max-height: 250px; width: 100%;" />
                                    }
                                </div>
                            </MudItem>
                        </MudGrid>
                    </div>
                </EditForm>
            </div>
        </MudContainer>
    </DialogContent>
    <DialogActions>
        <div class="d-flex w-100 flex-wrap pa-4 gap-3 align-center">
            <MudSpacer />
            <MudButton @onclick="Cancel" Variant="Variant.Outlined" Color="Color.Default" Style="border-radius: 12px; font-weight: 700; text-transform: none; border-color: rgba(0,0,0,0.15);">Discard</MudButton>
            <MudButton Disabled="@_busy" form="truckForm" Variant="Variant.Filled" ButtonType="ButtonType.Submit" Color="Color.Primary" Class="action-btn-primary px-10 rounded-pill" Style="background: var(--mud-palette-primary) !important; color: white !important;" StartIcon="@Icons.Material.Filled.TaskAlt">Authorize Registry</MudButton>
        </div>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; }

    [Parameter]
    public TruckRegistrationModel CurrentRegistration { get; set; }
    [Parameter]
    public int HomeBranchID { get; set; }
    private bool _busy;
    public int BranchID;

    private void Cancel() => MudDialog.Cancel();

    public bool HasPermissionITruckServiceEdit { get; set; } = false;
    public int DocTypeID = 37;

    protected override async Task OnInitializedAsync()
    {
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionITruckServiceEdit = await Irole.HasClaim(DocTypeID.ToString(), "Edit", ctc.Token);
        var authprov = await auth.GetAuthenticationStateAsync();
        var User = authprov.User;
        BranchID = int.Parse(User.Claims.First(x => x.Type == "BranchID").Value);
    }

    void RegNoUpdated(string val)
    {
        CurrentRegistration.RegNo = val.ToUpper();
    }

    private async void OnValidSubmit(EditContext context)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is being submitted!", Severity.Warning);
            return;
        }
        if (HomeBranchID != BranchID)
        {
            snackbar.Add("You don't have any permission to Add or Edit Registration!", Severity.Warning);
            return;
        }
        if (HasPermissionITruckServiceEdit)
        {
            if (CurrentRegistration.EffectTo == null || CurrentRegistration.EffectFrom == null)
            {
                snackbar.Add("Valid from date and valid to date should select.", Severity.Error);
                return;
            }
            if (CurrentRegistration.EffectTo >= CurrentRegistration.EffectFrom)
            {
                int? dateInvalidCount = Iservice.ValidateRegistrationDate(CurrentRegistration);
                if (dateInvalidCount > 0)
                {
                    snackbar.Add("Can not save because date is overlaping on another Registration.", Severity.Error);
                    return;
                }
                var authprov = await auth.GetAuthenticationStateAsync();
                var user = authprov.User;
                CurrentRegistration.UserInfo.UserID = user.Identity.Name;
                _busy = true;
                try
                {
                    int result = Iservice.UpdateRegistration(CurrentRegistration);
                    snackbar.Add("Saved Successfully", Severity.Success);
                    MudDialog.Close(result);
                }
                catch (Exception ex)
                {
                    snackbar.Add(ex.Message, Severity.Warning);
                }
                await Task.Delay(200);
                _busy = false;
            }
            else
            {
                snackbar.Add("Valid up to date should be greater valid from.", Severity.Error);
            }
        }
        else
        {
            bool? ResultModel = await DialogService.ShowMessageBoxAsync(
                "Permission denied!",
                "You don't have any permission to Add or Edit Truck.");
        }
    }
}
