@page "/TruckRegisterList"
@inject AuthenticationStateProvider auth
@attribute [Authorize]
@inject IDialogService DialogService
@inject ITruckService ItruckService

<MudPaper Class="pl-5" Elevation="4">
   
        <MudGrid Spacing="7">
            <MudItem xs="10" md="10" >
                <TruckSelector @bind-Value="SelectedTruck" />
            </MudItem>
            <MudItem xs="2" md="2">
                <MudButton OnClick="fetch" Variant="Variant.Filled" Color="Color.Success" Size="Size.Large" ButtonType="ButtonType.Submit">Fetch</MudButton>
            </MudItem>
        </MudGrid>
</MudPaper>
<br />
<br />
<MudTable Items="@collection" Elevation="8"  @bind-Truck="model">

    <HeaderContent>
        <MudTh><MudTableSortLabel SortBy="new Func<TruckRegistrationModel, object>(x=> x.RegNo)" InitialDirection="SortDirection.Ascending">Truck</MudTableSortLabel></MudTh>
        <MudTh><MudTh><MudTableSortLabel SortBy="new Func<TruckRegistrationModel, object>(x=> x.EffectFrom)" InitialDirection="SortDirection.Ascending">Valid From</MudTableSortLabel></MudTh></MudTh>
        <MudTh><MudTh><MudTableSortLabel SortBy="new Func<TruckRegistrationModel, object>(x=> x.EffectTo)" InitialDirection="SortDirection.Ascending">Valid To</MudTableSortLabel></MudTh></MudTh>
        
    </HeaderContent>
    <RowTemplate>
        <MudTd DataLabel="Truck">@context.RegNo</MudTd>
        <MudTd DataLabel="Valid From">@context.EffectFrom.Value.ToString("dd/MM/yyyy")</MudTd>
        <MudTd DataLabel="Valid To">@context.EffectTo.Value.ToString("dd/MM/yyyy")</MudTd>
    </RowTemplate>
    <PagerContent>
        <MudTablePager PageSizeOptions="new int[] { 5, 10, 20, 50, 100 }" />
    </PagerContent>
</MudTable>

