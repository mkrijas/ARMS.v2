@code {


    private TruckRegistrationModel  model = new TruckRegistrationModel();

    [Parameter]
    public TruckModel SelectedTruck { get; set; }

    [Parameter]
    public string SelectedTruckId { get; set; } = null;



    private List<TruckModel> TruckList = new List<TruckModel>();


    protected async override Task OnParametersSetAsync()
    {
        if(!string.IsNullOrWhiteSpace( SelectedTruckId))
        {
        int TruckId = 0; 
        Int32.TryParse(SelectedTruckId,out TruckId);
            var authState = await auth.GetAuthenticationStateAsync();
            var branch = int.Parse(authState.User.Claims.FirstOrDefault(x => x.Type == "BranchID").Value);
            TruckList = ItruckService.SelectByBranch(branch).ToList();
            if(TruckList != null && TruckList.Any(s => s.TruckID == TruckId))
            {
                SelectedTruck = TruckList.FirstOrDefault(s => s.TruckID == TruckId);
                fetch();
            }
        }
    }

    private List<TruckRegistrationModel> collection = new List<TruckRegistrationModel>();
    public async Task fetch()
    {
        collection = new();
        var authprov = await auth.GetAuthenticationStateAsync();
        var brancIDString = authprov.User.Claims.First(x => x.Type == "BranchID").Value;
        int branchID = int.Parse(brancIDString);     
         foreach (var item in ItruckService.GetRegistrationList(SelectedTruck?.TruckID??0).OrderBy(s=>s.EffectTo).ToList())
        {
            collection.Add(item);
            this.StateHasChanged();
        }

    }
}

