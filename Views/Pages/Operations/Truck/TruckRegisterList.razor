@page "/TruckRegisterList"
@page "/TruckRegisterList/{SelectedTruckId:int}"
@using System.Threading;
@inject AuthenticationStateProvider auth
@attribute [Authorize]
@inject IDialogService DialogService
@inject ITruckService ItruckService
@inject MudBlazor.ISnackbar snackbar
@inject IRoleService<RoleModel> Irole

<div class="admin-page-container">
    <div class="admin-header-tiered mb-6">
        <div class="d-flex align-center justify-space-between">
            <div>
                <MudText Typo="Typo.h4" Class="admin-title">Vehicle Registration Ledger</MudText>
                <MudText Typo="Typo.body2" Class="admin-subtitle">Track historical registration records and compliance cycles for the fleet.</MudText>
            </div>
            @if (SelectedTruck != null && SelectedTruck.TruckID != null)
            {
                <MudButton StartIcon="@Icons.Material.Filled.Add" Variant="Variant.Filled" Color="Color.Primary" Class="admin-register-btn" OnClick="@(()=> Edit(new TruckRegistrationModel()))">RENEW REGISTRATION</MudButton>
            }
        </div>
    </div>

    <div class="admin-glass-card mb-6 pa-4">
        <MudGrid>
            <MudItem xs="12">
                <TruckSelector Value="SelectedTruck" ValueChanged="SelectedTruckChanged" Filter="All" />
            </MudItem>
        </MudGrid>
    </div>

    @if (SelectedTruck != null && SelectedTruck.TruckID != null)
    {
        <div class="admin-glass-card pa-0 overflow-hidden">
            <MudTable Items="@collection" Elevation="0" Class="modern-admin-table">
                <ToolBarContent>
                    <div class="px-4 py-2">
                        <MudText Typo="Typo.h6" Class="fw-700">@SelectedTruck?.CurrentRegistration?.RegNo Registrations</MudText>
                    </div>
                </ToolBarContent>
                <HeaderContent>
                    <MudTh><MudTableSortLabel SortBy="new Func<TruckRegistrationModel, object>(x=> x.RegNo)" InitialDirection="SortDirection.Ascending"><span class="admin-header-text">VEHICLE NO</span></MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<TruckRegistrationModel, object>(x=> x.EffectFrom)" InitialDirection="SortDirection.Ascending"><span class="admin-header-text">VALID FROM</span></MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<TruckRegistrationModel, object>(x=> x.EffectTo)" InitialDirection="SortDirection.Ascending"><span class="admin-header-text">VALID TO</span></MudTableSortLabel></MudTh>
                    <MudTh Style="text-align: right;"><span class="admin-header-text">ACTIONS</span></MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Truck"><MudText Typo="Typo.body2" Class="admin-td-primary">@context.RegNo</MudText></MudTd>
                    <MudTd DataLabel="Valid From">@context.EffectFrom?.ToString("dd MMM yyyy")</MudTd>
                    <MudTd DataLabel="Valid To">
                        <div class="d-flex align-center">
                            <span class="@(context.EffectTo < DateTime.Today ? "text-danger fw-700" : "")">@context.EffectTo?.ToString("dd MMM yyyy")</span>
                            @if (context.EffectTo < DateTime.Today)
                            {
                                <MudIcon Icon="@Icons.Material.Filled.Warning" Color="Color.Error" Size="Size.Small" Class="ml-2" />
                            }
                        </div>
                    </MudTd>
                    <MudTd DataLabel="Actions" Style="text-align: right;">
                        <MudTooltip Text="Edit Record">
                            <MudIconButton OnClick="@(()=> Edit(context))" Color="Color.Primary" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Variant="Variant.Text" />
                        </MudTooltip>
                    </MudTd>
                </RowTemplate>
                <PagerContent>
                    <div class="pa-4">
                        <MudTablePager PageSizeOptions="new int[] { 10, 20, 50, 100 }" />
                    </div>
                </PagerContent>
            </MudTable>
        </div>
    }
    else
    {
        <div class="admin-glass-card pa-12 d-flex flex-column align-center justify-center opacity-50">
            <MudIcon Icon="@Icons.Material.Filled.FireTruck" Size="Size.Large" Class="mb-4" />
            <MudText Typo="Typo.h6">Select a vehicle from the dropdown above to view its registration history.</MudText>
        </div>
    }
</div>

@code {

    [Parameter]
    public TruckModel SelectedTruck { get; set; }
    [Parameter]
    public int? SelectedTruckID { get; set; }
    int BranchID;
    private List<TruckModel> TruckList = new List<TruckModel>();
    private List<TruckRegistrationModel> collection = new List<TruckRegistrationModel>();

    protected async override Task OnInitializedAsync()
    {
        var authState = await auth.GetAuthenticationStateAsync();
        BranchID = int.Parse(authState.User.Claims.FirstOrDefault(x => x.Type == "BranchID").Value);
        TruckList = ItruckService.Select(null).ToList();
        if (SelectedTruck == null)
        {
            SelectedTruck = TruckList.FirstOrDefault(s => s.TruckID == SelectedTruckID);
        }
        fetch();
    }

    async Task Edit(TruckRegistrationModel reg)
    {
        if (SelectedTruck == null && SelectedTruck.TruckID == null)
        {
            snackbar.Add("Please select truck", Severity.Error);
            return;
        }
        if (reg.TruckID == null)
        {
            reg.TruckID = SelectedTruck?.TruckID ?? null;
        }
        DialogOptions options = new DialogOptions() { MaxWidth = MaxWidth.Large, };
        DialogParameters parms = new();
        parms.Add("CurrentRegistration", reg.Clone());
        parms.Add("HomeBranchID", SelectedTruck.HomeBranchID);
        var dialog = await DialogService.ShowAsync<TruckRegisterDialog>("Registration", parms, options);
        var result = await dialog.Result;
        if (!result.Canceled)
        {
            fetch();
        }
    }

    void SelectedTruckChanged(TruckModel truck)
    {
        SelectedTruck = truck;
        fetch();
    }

    void fetch()
    {
        collection = ItruckService.GetRegistrationList(SelectedTruck?.TruckID ?? 0).OrderBy(s => s.RegID).ToList();
    }
}

