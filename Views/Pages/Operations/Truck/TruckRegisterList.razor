@code {

    
    private TruckRegistrationModel  model = new TruckRegistrationModel();

    [Parameter]
    public TruckModel SelectedTruck { get; set; }
    private List<TruckRegistrationModel> collection = new List<TruckRegistrationModel>();
    public async Task fetch()
    {
        collection = new();
        var authprov = await auth.GetAuthenticationStateAsync();
        var brancIDString = authprov.User.Claims.First(x => x.Type == "BranchID").Value;
        int branchID = int.Parse(brancIDString);     
         foreach (var item in ItruckService.GetRegistrationList(SelectedTruck?.TruckID??0).OrderBy(s=>s.EffectTo).ToList())
        {
            collection.Add(item);
            this.StateHasChanged();
        }

    }
}

