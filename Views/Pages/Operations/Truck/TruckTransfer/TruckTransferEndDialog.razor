@using System.Threading;
@using ArmsServices.DataServices
@inject AuthenticationStateProvider auth
@inject ITruckTransferService Iservice
@inject IBranchService Ibranchservice
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject IRoleService<RoleModel> Irole

<MudDialog Class="admin-dialog-glass">
    <TitleContent>
        <div class="header-section mb-2 pt-4 px-4">
            <div class="d-flex align-center justify-space-between">
                <div class="d-flex align-center">
                    <div class="icon-badge primary-badge mr-4">
                        <div class="admin-header-icon-badge mb-3">
                            <MudIcon Icon="@Icons.Material.Filled.FactCheck" Color="Color.Secondary" Style="font-size: 3rem;" />
                        </div>
                    </div>
                    <div>
                        <MudText Typo="Typo.h5" Class="admin-title"><b>Fleet Arrival Protocol</b></MudText>
                        <MudText Typo="Typo.body2" Class="admin-subtitle">Verify asset status and finalize inter-branch migration or authorize rejection.</MudText>
                    </div>
                </div>
            </div>
            <div class="title-accent mt-4"></div>
        </div>
    </TitleContent>
    <DialogContent>
        <MudContainer Class="admin-dialog-container">
            <div class="dialog-content-wrapper pa-4">
                <EditForm id="formTruckTransferEnd" Model="@model" OnValidSubmit="Accept">
                    <DataAnnotationsValidator />
                    
                    <div class="admin-glass-card pa-6 mb-6" style="border-left: 4px solid var(--mud-palette-info);">
                        <div class="d-flex align-center">
                            <MudIcon Icon="@Icons.Material.Filled.Info" Color="Color.Info" Class="mr-3" Size="Size.Large" />
                            <div>
                                <MudText Typo="Typo.subtitle1" Class="fw-600 color-info">Incoming Asset Acquisition</MudText>
                                <MudText Typo="Typo.body2">
                                    Reviewing transfer of vehicle <b>@model.Truck.RegNo</b> from <b>@model.InitiationBranch.BranchName</b>.
                                </MudText>
                            </div>
                        </div>
                    </div>

                    <div class="admin-glass-card pa-6">
                        <div class="d-flex align-center mb-6">
                            <MudIcon Icon="@Icons.Material.Filled.EditNote" Color="Color.Primary" Class="mr-2" />
                            <span class="admin-section-label mb-0">Arrival Verification</span>
                        </div>
                        
                        <MudGrid Spacing="3">
                            <MudItem xs="12">
                                <MudTextField @bind-Value="model.TruckTransferEndModel.TruckEvent.EventReading" Label="Verification Odometer Reading" Variant="Variant.Outlined" Margin="Margin.Normal" For="@(() => model.TruckTransferEndModel.TruckEvent.EventReading)" Required Class="modern-input" Adornment="Adornment.End" AdornmentText="KM" />
                            </MudItem>
                            <MudItem xs="12">
                                <MudTextField @bind-Value="model.TruckTransferEndModel.Remarks" Label="Acquisition Remarks" Variant="Variant.Outlined" Margin="Margin.Normal" For="@(() => model.Remarks)" Class="modern-input" Lines="3" Placeholder="Enter any relevant observations upon arrival..." />
                            </MudItem>
                        </MudGrid>
                    </div>
                </EditForm>
            </div>
        </MudContainer>
    </DialogContent>
    <DialogActions>
        <div class="d-flex w-100 flex-wrap pa-4 gap-4 align-center justify-center">
            <MudButton Disabled="@_busy" Variant="Variant.Filled" Color="Color.Success" OnClick="Accept" StartIcon="@Icons.Material.Filled.CheckCircle" Style="border-radius: 12px; font-weight: 800; text-transform: none; padding: 12px 32px;" Class="shadow-none">Accept Asset</MudButton>
            <MudButton Disabled="@_busy" Variant="Variant.Filled" Color="Color.Error" OnClick="Reject" StartIcon="@Icons.Material.Filled.Cancel" Style="border-radius: 12px; font-weight: 800; text-transform: none; padding: 12px 32px;" Class="shadow-none">Reject Transfer</MudButton>
            <MudButton @onclick="Cancel" Variant="Variant.Outlined" Color="Color.Default" Style="border-radius: 12px; font-weight: 700; text-transform: none; border-color: rgba(0,0,0,0.15);">Cancel</MudButton>
        </div>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; }
    private bool _busy;
    [Parameter]
    public TruckTransferInitiationModel model { get; set; } = new();

    void Cancel()
    {
        MudDialog.Cancel();
    }

    public async Task Accept()
    {
        await ProcessStatus(false);
    }

    public async Task Reject()
    {
        await ProcessStatus(true);
    }

    private async Task ProcessStatus(bool isReject)
    {
        if (_busy) return;
        
        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;
        
        if (model.Truck == null || model.Truck.TruckID == 0)
        {
            await DialogService.ShowMessageBoxAsync("Warning", "Asset identity not verified.", yesText: "OK");
            return;
        }
        
        _busy = true;
        try
        {
            model.IstruckReject = (byte)(isReject ? 1 : 0);
            model.TruckTransferEndModel.TruckEvent.UserInfo.UserID = user.Identity.Name;
            model.TruckTransferEndModel.TransferStatus = !isReject;
            
            Iservice.UpdateStatus(model);
            Snackbar.Add(isReject ? "Transfer Rejected" : "Asset Accepted Successfully", isReject ? Severity.Warning : Severity.Success);
            MudDialog.Close(DialogResult.Ok(model));
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally
        {
            await Task.Delay(200);
            _busy = false;
        }
    }
}
