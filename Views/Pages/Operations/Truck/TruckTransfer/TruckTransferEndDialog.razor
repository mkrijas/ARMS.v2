@inject AuthenticationStateProvider auth
@inject ITruckTransferService Iservice
@inject IBranchService Ibranchservice
@inject IDialogService DialogService
@inject ISnackbar Snackbar

@using System.Threading;
@inject IRoleService<RoleModel> Irole

<MudDialog>
    <TitleContent>

        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.Edit" Class="mr-3" /> Accep Or Reject Truck.
        </MudText>

    </TitleContent>
    <DialogContent>

        <MudContainer Style="max-height: 400px; overflow-y: scroll; margin-left:20px">
            <EditForm id="formDriver" Model="@model" OnValidSubmit="Accept">
                <ObjectGraphDataAnnotationsValidator />
                <ValidationSummary />

                <MudItem xs="12" md="12">
                    <MudTextField @bind-Value="model.Truck.RegNo" Label="Truck" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.Truck.RegNo)" Disabled></MudTextField>
                </MudItem>
                <MudItem xs="12" md="12">
                    <MudTextField @bind-Value="model.InitiationBranch.BranchName" Label="Initiation Branch" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.InitiationBranch.BranchName)" Disabled></MudTextField>
                </MudItem>
                <MudItem xs="12" md="12" Class="mb-6">
                    <MudTextField @bind-Value="model.TruckTransferEndModel.TruckEvent.EventReading" Label="EndKM" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.TruckTransferEndModel.TruckEvent.EventReading)" Required></MudTextField>
                </MudItem>
                <MudItem xs="12" md="12" Class="mb-6">
                    <MudTextField @bind-Value="model.TruckTransferEndModel.Remarks" Label="Remarks" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.Remarks)"></MudTextField>
                </MudItem>

            </EditForm>
        </MudContainer>

    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Accept" Class="px-12">Accept Truck</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Reject" Class="px-12">Reject Truck</MudButton>
    </DialogActions>
</MudDialog>

@code {

    [CascadingParameter] MudDialogInstance MudDialog { get; set; }

    [Parameter]
    public TruckTransferInitiationModel model { get; set; } = new();

    protected override async Task OnInitializedAsync()
    {
        branchID = model?.DestinationBranch?.BranchID ?? 0;
    }

    private int branchID { get; set; } = 0;

    protected override void OnParametersSet()
    {

    }


    void Cancel()
    {
        MudDialog.Cancel();
    }


    public async Task Accept()
    {
        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;
        if (model.Truck == null || model.Truck.TruckID == 0)
        {
            bool? result = await DialogService.ShowMessageBox(
            "Warning",
            "Please, Select truck.", yesText: "OK");

            return;
        }
        if (model != null)
        {
            model.IstruckReject = 0;
            model.TruckTransferEndModel.TruckEvent.UserInfo.UserID = user.Identity.Name;
            try
            {
                model.TruckTransferEndModel.TransferStatus = true;
                Iservice.UpdateStatus(model);
                Snackbar.Add("Transfered succesfully", Severity.Success);

            }
            catch (Exception ex)
            {
                Snackbar.Add(ex.Message, Severity.Error);
            }
        }
        MudDialog.Close(model);
    }


    public async Task Reject()
    {
        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;
        if (model.Truck == null || model.Truck.TruckID == 0)
        {
            bool? result = await DialogService.ShowMessageBox(
            "Warning",
            "Please, Select truck.", yesText: "OK");

            return;
        }
        if (model != null)
        {

            model.IstruckReject = 1;
            model.TruckTransferEndModel.TruckEvent.UserInfo.UserID = user.Identity.Name;
            try
            {

                model.TruckTransferEndModel.TransferStatus = false;
                Iservice.UpdateStatus(model);
                Snackbar.Add("Transfered succesfully", Severity.Success);

            }
            catch (Exception ex)
            {
                Snackbar.Add(ex.Message, Severity.Error);
            }
        }
        MudDialog.Close(model);
    }
}