@inject AuthenticationStateProvider auth
@inject ITruckTransferService Iservice
@inject IBranchService Ibranchservice
@inject IDialogService DialogService
@inject ISnackbar Snackbar

@using System.Threading;
@inject IRoleService<RoleModel> Irole

<MudDialog>
    <TitleContent>
        @if (model.TruckTransferInitiationID == null || model.TruckTransferInitiationID == 0)
        {
            <MudText Typo="Typo.h6">
                <MudIcon Icon="@Icons.Material.Filled.Edit" Class="mr-3" /> Add Truck Transfer Initiation.
            </MudText>
        }
        else
        {
            <MudText Typo="Typo.h6">
                <MudIcon Icon="@Icons.Material.Filled.Edit" Class="mr-3" /> Edit Truck Transfer Initiation.
            </MudText>
        }
    </TitleContent>
    <DialogContent>

        <MudContainer Style="max-height: 400px; overflow-y: scroll; margin-left:20px">
            <EditForm id="formDriver" Model="@model" OnValidSubmit="Submit">
                <DataAnnotationsValidator />
                <ValidationSummary />

                <MudItem xs="12" md="12">
                    <TruckSelector Value="model.Truck" Filter="@filter" VariantParameter="Variant.Outlined" MarginParameter="Margin.Normal" BranchID="branchID" ValueChanged="TruckSelected" />
                </MudItem>
                <MudItem xs="12" md="12">
                    <MudSelect Label="Destination Branch" Variant="Variant.Outlined" Margin="Margin.Dense" @bind-Value="model.DestinationBranch.BranchID" T="int?" OffsetY="true" Direction="Direction.Top" AdornmentColor="Color.Secondary" Required>
                        @foreach (BranchModel ditem in DestinationBranchList)
                        {
                            <MudSelectItem Value="@ditem.BranchID">@ditem.BranchName</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" md="12" Class="mb-6">
                    <MudTextField @bind-Value="model.TruckEvent.EventReading" Label="StartKM" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.TruckEvent.EventReading)" Required></MudTextField>
                </MudItem>
                <MudItem xs="12" md="12" Class="mb-6">
                    <MudTextField @bind-Value="model.Remarks" Label="Remarks" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => model.Remarks)"></MudTextField>
                </MudItem>

            </EditForm>
        </MudContainer>

    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Submit" Class="px-12">Submit</MudButton>
    </DialogActions>
</MudDialog>

@code {

    [CascadingParameter] MudDialogInstance MudDialog { get; set; }
    [Parameter]
    public TruckTransferInitiationModel model { get; set; } = new();
    private List<BranchModel> DestinationBranchList = new();


    private List<int?> UnAssignedTruckIds = new();
    private string filter { get; set; } = "UnAssigned";

    public bool HasPermissionEdit { get; set; } = true;
    public int DocTypeID = 33;

    protected override async Task OnInitializedAsync()
    {
        CancellationTokenSource ctc = new CancellationTokenSource();
        //HasPermissionEdit = await Irole.HasClaim(DocTypeID.ToString(), "Edit", ctc.Token);

        filter = "UnAssigned";
        branchID = model?.InitiationBranch?.BranchID ?? 0;
        DestinationBranchList = Ibranchservice.Select().Where(d => d.BranchID != branchID).ToList();
    }

    private int branchID { get; set; } = 0;

    protected override void OnParametersSet()
    {
    }
    void Cancel()
    {
        MudDialog.Cancel();
    }
    public async Task Submit()
    {
        if (HasPermissionEdit)
        {
            var authprov = await auth.GetAuthenticationStateAsync();
            var user = authprov.User;
            if (model.Truck == null || model.Truck.TruckID == 0)
            {
                bool? result = await DialogService.ShowMessageBox(
                "Warning",
                "Please, Select truck.", yesText: "OK");

                return;
            }
            if (model != null)
            {

                if (model.DestinationBranch == null)
                {
                    model.DestinationBranch = new();
                }
                if (model.TruckEvent == null)
                {
                    model.TruckEvent = new();
                }
                if (model.TruckEvent.UserInfo == null)
                {
                    model.TruckEvent.UserInfo = new();
                }
                model.TruckEvent.UserInfo.UserID = user.Identity.Name;
                try
                {
                    Iservice.UpdateOutgoing(model);
                    Snackbar.Add("Transfered succesfully", Severity.Success);

                }
                catch (Exception ex)
                {
                    Snackbar.Add(ex.Message, Severity.Error);
                }
            }

            MudDialog.Close(model);
        }
        else
        {
            bool? result = await DialogService.ShowMessageBox(
               "Permission denied!",
               "You dont have any permission to submit.");
        }
    }

    private void TruckSelected(TruckModel obj)
    {
        model.Truck = obj;
    }

}

