@using System.Threading;
@using ArmsServices.DataServices
@inject AuthenticationStateProvider auth
@inject ITruckTransferService Iservice
@inject IBranchService Ibranchservice
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject IRoleService<RoleModel> Irole

<MudDialog Class="admin-dialog-glass">
    <TitleContent>
        <div class="header-section mb-2 pt-4 px-4">
            <div class="d-flex align-center justify-space-between">
                <div class="d-flex align-center">
                    <div class="icon-badge primary-badge mr-4">
                        <div class="admin-header-icon-badge mb-3">
                            <MudIcon Icon="@Icons.Material.Filled.LocalShipping" Color="Color.Secondary" Style="font-size: 3rem;" />
                        </div>
                    </div>
                    <div>
                        <MudText Typo="Typo.h5" Class="admin-title"><b>@(model.TruckTransferInitiationID == null || model.TruckTransferInitiationID == 0 ? "Initiate Fleet Migration" : "Refine Migration Protocol")</b></MudText>
                        <MudText Typo="Typo.body2" Class="admin-subtitle">Formal documentation and authorization for inter-branch vehicle transfer.</MudText>
                    </div>
                </div>
            </div>
            <div class="title-accent mt-4"></div>
        </div>
    </TitleContent>
    <DialogContent>
        <MudContainer Class="admin-dialog-container">
            <div class="dialog-content-wrapper pa-4">
                <EditForm id="formTruckTransfer" Model="@model" OnValidSubmit="Submit">
                    <DataAnnotationsValidator />
                    
                    <div class="admin-glass-card pa-6 mb-6">
                        <div class="d-flex align-center mb-6">
                            <MudIcon Icon="@Icons.Material.Filled.Tune" Color="Color.Primary" Class="mr-2" />
                            <span class="admin-section-label mb-0">Asset & Destination Parameters</span>
                        </div>
                        
                        <MudGrid Spacing="3">
                            <MudItem xs="12">
                                <TruckSelector For="@(() => model.Truck)" Value="model.Truck" Filter="@filter" VariantParameter="Variant.Outlined" MarginParameter="Margin.Normal" BranchID="branchID" ValueChanged="TruckSelected" Class="modern-selector" />
                            </MudItem>
                            <MudItem xs="12">
                                <MudSelect For="@(() => model.DestinationBranch.BranchID)" Label="Designated Destination Branch" Variant="Variant.Outlined" Margin="Margin.Normal" @bind-Value="model.DestinationBranch.BranchID" T="int?" AdornmentColor="Color.Secondary" Required Class="modern-input" AdornmentIcon="@Icons.Material.Filled.Business">
                                    @foreach (BranchModel ditem in DestinationBranchList)
                                    {
                                        <MudSelectItem Value="@ditem.BranchID">@ditem.BranchName</MudSelectItem>
                                    }
                                </MudSelect>
                            </MudItem>
                            <MudItem xs="12" md="6">
                                <MudTextField @bind-Value="model.TruckEvent.EventReading" Label="Departure Odometer Verification" Variant="Variant.Outlined" Margin="Margin.Normal" For="@(() => model.TruckEvent.EventReading)" Required Class="modern-input" Adornment="Adornment.End" AdornmentText="KM" />
                            </MudItem>
                            <MudItem xs="12" md="6">
                                <MudTextField @bind-Value="model.Remarks" Label="Operational Remarks" Variant="Variant.Outlined" Margin="Margin.Normal" For="@(() => model.Remarks)" Class="modern-input" Placeholder="Enter transfer justification..." />
                            </MudItem>
                        </MudGrid>
                    </div>
                </EditForm>
            </div>
        </MudContainer>
    </DialogContent>
    <DialogActions>
        <div class="d-flex w-100 flex-wrap pa-4 gap-3 align-center">
            <MudSpacer />
            <MudButton @onclick="Cancel" Variant="Variant.Outlined" Color="Color.Default" Style="border-radius: 12px; font-weight: 700; text-transform: none; border-color: rgba(0,0,0,0.15);">Discard</MudButton>
            <MudButton Disabled="@_busy" form="formTruckTransfer" Variant="Variant.Filled" ButtonType="ButtonType.Submit" Color="Color.Success" Style="background: var(--mud-palette-success); color: white; font-weight: 800; border-radius: 12px; text-transform: none; white-space: nowrap; padding: 8px 24px;" StartIcon="@Icons.Material.Filled.DoneAll">Submit</MudButton>
        </div>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; }
    private bool _busy;
    [Parameter]
    public TruckTransferInitiationModel model { get; set; } = new();
    private List<BranchModel> DestinationBranchList = new();
    private string filter { get; set; } = "UnAssigned";
    private int branchID { get; set; } = 0;

    protected override async Task OnInitializedAsync()
    {
        filter = "UnAssigned";
        branchID = model?.InitiationBranch?.BranchID ?? 0;
        DestinationBranchList = Ibranchservice.Select().Where(d => d.BranchID != branchID).ToList();
    }

    void Cancel()
    {
        MudDialog.Cancel();
    }

    public async Task Submit()
    {
        if (_busy) return;
        
        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;
        if (model.Truck == null || model.Truck.TruckID == 0)
        {
            await DialogService.ShowMessageBoxAsync("Warning", "Please select a vehicle for transfer.", yesText: "OK");
            return;
        }
        
        _busy = true;
        try
        {
            if (model.DestinationBranch == null) model.DestinationBranch = new();
            if (model.TruckEvent == null) model.TruckEvent = new();
            if (model.TruckEvent.UserInfo == null) model.TruckEvent.UserInfo = new();
            
            model.TruckEvent.UserInfo.UserID = user.Identity.Name;
            Iservice.UpdateOutgoing(model);
            Snackbar.Add("Transfer Initiated Successfully", Severity.Success);
            MudDialog.Close(DialogResult.Ok(model));
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally
        {
            await Task.Delay(200);
            _busy = false;
        }
    }

    private void TruckSelected(TruckModel obj)
    {
        model.Truck = obj;
    }
}

    private void TruckSelected(TruckModel obj)
    {
        model.Truck = obj;
    }
}
