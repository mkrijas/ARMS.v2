@page "/TruckTransferView"

@using ArmsModels.BaseModels.General
@using ArmsServices.DataServices.General
@using Microsoft.AspNetCore.SignalR.Client;
@using System.Threading;
@using Views.Data

@inject ITruckTransferService Iservice
@inject IPushNotificationService IpushNotificationService
@inject MudBlazor.ISnackbar snackbar

@inject AuthenticationStateProvider auth
@attribute [Authorize]
@inject IDialogService DialogService
@inject IBranchService Ibranchservice
@inject NavigationManager NavigationManager
@inject SignalRService signalRService
@inject IRoleService<RoleModel> Irole


@using System.Threading;
@inject IRoleService<RoleModel> Irole

<MudGrid Spacing="4">
    <MudItem xs="12">
        <MudTabs Elevation="2" Rounded="true" ApplyEffectsToContainer="true" PanelClass="pa-6">
            <MudTabPanel Text="Truck Transfer Outgoing">
                <MudTable Items="@collectionOutGoing" Dense="true" Hover="true" Striped="true" Elevation="0" @bind-place="modelOutGoing">
                    <ToolBarContent>
                        <MudText Typo="Typo.h6">Initiate Transfer</MudText>
                        <MudTooltip Text="New Truck Transfer">
                            <MudIconButton Icon="@Icons.Material.Filled.Add" Title="Add" @onclick="@(()=> OpenDialogEditOutGoing(new TruckTransferInitiationModel()))" Color="Color.Dark" Size="Size.Small"></MudIconButton>
                        </MudTooltip>
                        <MudSpacer></MudSpacer>
                    </ToolBarContent>
                    <HeaderContent>
                        <MudTh><MudTableSortLabel SortBy="new Func<TruckTransferInitiationModel, object>(x=> x.Truck.RegNo)" InitialDirection="SortDirection.Ascending">Truck</MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<TruckTransferInitiationModel, object>(x=> x.DestinationBranch.BranchName)" InitialDirection="SortDirection.Ascending">Destination Branch</MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<TruckTransferInitiationModel, object>(x=> x.TruckEvent.EventReading)" InitialDirection="SortDirection.Ascending">Start KM</MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<TruckTransferInitiationModel, object>(x=> x.TruckTransferEndModel.StatusText)" InitialDirection="SortDirection.Ascending">Status</MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<TruckTransferInitiationModel, object>(x=> x.Remarks)" InitialDirection="SortDirection.Ascending">Remarks</MudTableSortLabel></MudTh>
                        <MudTh>Actions</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="Truck">@context.Truck.RegNo</MudTd>
                        <MudTd DataLabel="Destination Branch">@context.DestinationBranch.BranchName</MudTd>
                        <MudTd DataLabel="Start KM">@context.TruckEvent.EventReading</MudTd>
                        <MudTd DataLabel="Status">@context.TruckTransferEndModel.StatusText</MudTd>
                        <MudTd DataLabel="Remarks">@context.Remarks</MudTd>
                        <MudTd DataLabel="">
                            <MudTooltip Text="Edit">
                                <MudIconButton @onclick="@(()=> OpenDialogEditOutGoing(context))" Color="Color.Primary" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" IconSize="Size.Small" />
                            </MudTooltip>
                            <MudTooltip Text="Remove">
                                <MudIconButton @onclick="@(()=> OpenDialogDeleteOutGoing(context))" Color="Color.Primary" Icon="@Icons.Material.Filled.Remove" Size="Size.Small" IconSize="Size.Small" />
                            </MudTooltip>
                        </MudTd>
                    </RowTemplate>
                    <PagerContent>
                        <MudTablePager PageSizeOptions="new int[] { 5, 10, 20, 50, 100 }" />

                    </PagerContent>
                </MudTable>
            </MudTabPanel>
            <MudTabPanel Text="Truck Transfer Incoming">

                <MudTable Items="@collectionIncoming" Dense="true" Hover="true" Striped="true" Elevation="0" @bind-place="modelIncoming">

                    <HeaderContent>
                        <MudTh><MudTableSortLabel SortBy="new Func<TruckTransferInitiationModel, object>(x=> x.Truck.RegNo)" InitialDirection="SortDirection.Ascending">Truck</MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<TruckTransferInitiationModel, object>(x=> x.InitiationBranch.BranchName)" InitialDirection="SortDirection.Ascending">Initiation Branch</MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<TruckTransferInitiationModel, object>(x=> x.TruckTransferEndModel.StatusText)" InitialDirection="SortDirection.Ascending">Transfer Status</MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<TruckTransferInitiationModel, object>(x=> x.TruckEvent.EventReading)" InitialDirection="SortDirection.Ascending">Start KM</MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<TruckTransferInitiationModel, object>(x=> x.Remarks)" InitialDirection="SortDirection.Ascending">Remarks</MudTableSortLabel></MudTh>
                        <MudTh>Actions</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="Truck">@context.Truck.RegNo</MudTd>
                        <MudTd DataLabel="Initiation Branch">@context.InitiationBranch.BranchName</MudTd>
                        <MudTd DataLabel="Transfer Status">@context.TruckTransferEndModel.StatusText</MudTd>
                        <MudTd DataLabel="Start KM">@context.TruckEvent.EventReading</MudTd>
                        <MudTd DataLabel="Remarks">@context.Remarks</MudTd>
                        <MudTd DataLabel="">
                            <MudTooltip Text="Edit">
                                <MudIconButton @onclick="@(()=> OpenDialogEditIncoming(context))" Color="Color.Primary" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" IconSize="Size.Small" />
                            </MudTooltip>
                        </MudTd>

                    </RowTemplate>

                    <PagerContent>
                        <MudTablePager PageSizeOptions="new int[] { 5, 10, 20, 50, 100 }" />

                    </PagerContent>
                </MudTable>
            </MudTabPanel>
        </MudTabs>
    </MudItem>
</MudGrid>


@code {
    int CurrentBranchId = 0;

    private List<BranchModel> BranchList = new();


    protected override async Task OnInitializedAsync()
    {
        BranchList = Ibranchservice.Select().ToList();
        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;
        var brancIDString = authprov.User.Claims.First(x => x.Type == "BranchID").Value;
        CurrentBranchId = int.Parse(brancIDString);

        //chatHubService = new ChatHubService(NavigationManager, CurrentBranchId);
        //chatHubService.StartHubConnection();

        BranchList = Ibranchservice.Select().ToList();


        hubConnection = new HubConnectionBuilder().WithUrl(NavigationManager.ToAbsoluteUri("/chatHub")).Build();
        signalRService.RegisterReceivedMessage(e => Receive(e));
        //hubConnection.On<BranchModel, BranchModel, string, string, int, string>("ReceiveMessage", (InitiateBranch, ReceivedBranch, MessageTitle, MessageBody, RedirectedTo, MsgDatest) =>
        //{
        //    allNotificationMessages.Add(new PushNotificationModel()
        //        {
        //            MSgId = allNotificationMessages.Count() + 1,
        //            MessageID = 0,
        //            InitiateBranch = InitiateBranch,
        //            ReceivedBranch = ReceivedBranch,
        //            MessageTitle = MessageTitle,
        //            MessageBody = MessageBody,
        //            RedirectedTo = RedirectedTo,
        //            MsgDateString = MsgDatest
        //        });

        //});
        await hubConnection.StartAsync();

        await GetAllOutGoing();
        await GetAllIncoming();
    }


    #region SignaIR Notification

    private List<PushNotificationModel> allNotificationMessages = new List<PushNotificationModel>();
    private List<PushNotificationModel> currentNotificationMessages = new List<PushNotificationModel>();
    private PushNotificationModel notificationMessage = new PushNotificationModel();
    private HubConnection hubConnection;
    private string BoxCss = "none";


    void Receive(PushNotificationModel pushNotificationModel)
    {
        currentNotificationMessages = allNotificationMessages.Where(s => (s.ReceivedBranch?.BranchID ?? 0) == CurrentBranchId).ToList();
        InvokeAsync(() => StateHasChanged());
    }

    private async Task Send()
    {

        PushNotificationModel result = IpushNotificationService.UpdatePushNotification(notificationMessage);

        await hubConnection.SendAsync("SendMessages",
        result);


        notificationMessage.InitiateBranch = new();
        notificationMessage.ReceivedBranch = new();
        notificationMessage.MessageTitle = "";
        notificationMessage.MessageBody = "";
    }

    public bool IsConnected => hubConnection.State == HubConnectionState.Connected;

    private void NotificationHideShow()
    {
        if (BoxCss == "none") BoxCss = "block";
        else BoxCss = "none";
    }

    #endregion

    private async Task GetAll()
    {

        await GetAllOutGoing();
        await GetAllIncoming();
    }

    #region Outgoing


    private TruckTransferInitiationModel modelOutGoing = new();

    private List<TruckTransferInitiationModel> collectionOutGoing = new();

    string state = "Message box hasn't been opened yet";

    protected override void OnParametersSet()
    {
        //the param will be set now
        //GetAllOutGoing();

    }


    private async Task OpenDialogEditOutGoing(TruckTransferInitiationModel TruckTransferInitiation)
    {
        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;
        var brancIDString = authprov.User.Claims.First(x => x.Type == "BranchID").Value;

        if (TruckTransferInitiation.TruckEvent == null)
        {
            TruckTransferInitiation.TruckEvent = new();
        }
        TruckTransferInitiation.TruckEvent.UserInfo = new();
        if (TruckTransferInitiation.TruckEvent.UserInfo != null)
        {
            TruckTransferInitiation.TruckEvent.UserInfo.UserID = user.Identity.Name;
        }
        if (TruckTransferInitiation.InitiationBranch == null)
        {
            TruckTransferInitiation.InitiationBranch = new();
        }
        if (TruckTransferInitiation.DestinationBranch == null)
        {
            TruckTransferInitiation.DestinationBranch = new();
        }
        TruckTransferInitiation.InitiationBranch.BranchID = int.Parse(brancIDString);


        var modelOutGoing = new DialogParameters { ["model"] = TruckTransferInitiation };

        var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Medium };
        var dialog = DialogService.Show<TruckTransferInitiationDialog>("Simple Dialog", modelOutGoing, options);

        var result = await dialog.Result;

        var isCancelled = result.Cancelled;
        if (!isCancelled)
        {
            if (IsConnected)
            {

                    var ReturnData = (TruckTransferInitiationModel)result.Data;
                    notificationMessage.InitiateBranch = BranchList?.FirstOrDefault(s => s.BranchID == Convert.ToInt32(ReturnData?.InitiationBranch?.BranchID ?? 0)) ?? null;
                    notificationMessage.ReceivedBranch = BranchList?.FirstOrDefault(s => s.BranchID == Convert.ToInt32(ReturnData?.DestinationBranch?.BranchID ?? 0)) ?? null;
                    notificationMessage.MessageTitle = "Truck name " + (ReturnData?.Truck?.RegNo ?? "") + " is transfered to this branch.";
                    notificationMessage.MessageBody = "Truck name " + (ReturnData?.Truck?.RegNo ?? "") + " is transfered from " + (notificationMessage?.InitiateBranch?.BranchName ?? "") + " to this branch on " + (DateTime.Now).ToString() + ".";
                    notificationMessage.RedirectedTo = 0;
                    notificationMessage.ExpiredBy = 7;
                    notificationMessage.DocumentID = ReturnData.TruckTransferInitiationID;
                    notificationMessage.MsgDate = DateTime.Now;
                    await Send();
                }

            await GetAll();
        }
    }


    private async Task OpenDialogDeleteOutGoing(TruckTransferInitiationModel TruckTransferInitiation)
    {
        bool? result = await DialogService.ShowMessageBox(
            "Warning",
            "Are you sure you want to delete this entry?",
            yesText: "Delete!", cancelText: "Cancel");
        state = result == null ? "Cancelled" : "Deleted!";
        if (state == "Deleted!")
        {

            var authprov = await auth.GetAuthenticationStateAsync();
            var user = authprov.User;
            if (TruckTransferInitiation.TruckEvent == null)
            {
                TruckTransferInitiation.TruckEvent = new();
            }
            TruckTransferInitiation.TruckEvent.UserInfo = new();
            if (TruckTransferInitiation.TruckEvent.UserInfo != null)
            {
                TruckTransferInitiation.TruckEvent.UserInfo.UserID = user.Identity.Name;
                try
                {
                    Iservice.DeleteInitiation(TruckTransferInitiation.TruckTransferInitiationID, TruckTransferInitiation.TruckEvent.TruckEventID, TruckTransferInitiation.TruckEvent.UserInfo.UserID);

                }
                catch (Exception ex)
                {
                    snackbar.Add(ex.Message, Severity.Error);
                }
            }
            await GetAll();
        }
    }


    private async Task GetAllOutGoing()
    {

        collectionOutGoing = new();

        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;
        var brancIDString = authprov.User.Claims.First(x => x.Type == "BranchID").Value;
        if (modelOutGoing.TruckEvent == null)
        {
            modelOutGoing.TruckEvent = new();
        }
        modelOutGoing.TruckEvent.UserInfo = new();
        if (modelOutGoing.TruckEvent.UserInfo != null)
        {
            modelOutGoing.TruckEvent.UserInfo.UserID = user.Identity.Name;
        }
        if (modelOutGoing.InitiationBranch == null)
        {
            modelOutGoing.InitiationBranch = new();
        }
        modelOutGoing.InitiationBranch.BranchID = int.Parse(brancIDString);

        foreach (var item in Iservice.SelectOutgoingTrucks(modelOutGoing.InitiationBranch.BranchID))
        {
            collectionOutGoing.Add(item);
        }
    }
    #endregion

    #region Incoming


    private TruckTransferInitiationModel modelIncoming = new();

    private List<TruckTransferInitiationModel> collectionIncoming = new();

    //string state = "Message box hasn't been opened yet";
    //protected override void OnParametersSet()
    //{
    //    //the param will be set now
    //    GetAllIncoming();

    //}


    private async Task OpenDialogEditIncoming(TruckTransferInitiationModel TruckTransferEnd)
    {
        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;
        var brancIDString = authprov.User.Claims.First(x => x.Type == "BranchID").Value;
        if (TruckTransferEnd.TruckTransferEndModel == null)
        {
            TruckTransferEnd.TruckTransferEndModel = new();
        }
        if (TruckTransferEnd.TruckTransferEndModel.TruckEvent == null)
        {
            TruckTransferEnd.TruckTransferEndModel.TruckEvent = new();
        }
        TruckTransferEnd.TruckTransferEndModel.TruckEvent.UserInfo = new();
        if (TruckTransferEnd.TruckTransferEndModel.TruckEvent.UserInfo != null)
        {
            TruckTransferEnd.TruckTransferEndModel.TruckEvent.UserInfo.UserID = user.Identity.Name;
        }
        if (TruckTransferEnd.DestinationBranch == null)
        {
            TruckTransferEnd.DestinationBranch = new();
        }
        TruckTransferEnd.DestinationBranch.BranchID = int.Parse(brancIDString);


        var modelIncoming = new DialogParameters { ["model"] = TruckTransferEnd };

        var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Medium };
        var dialog = DialogService.Show<TruckTransferEndDialog>("Simple Dialog", modelIncoming, options);

        var result = await dialog.Result;

        var isCancelled = result.Cancelled;

        if (!isCancelled)
        {
            if (IsConnected)
            {
                var ReturnData = (TruckTransferInitiationModel)result.Data;
                if (ReturnData.IstruckReject == 1)
                {

                        notificationMessage.InitiateBranch = BranchList?.FirstOrDefault(s => s.BranchID == Convert.ToInt32(ReturnData?.DestinationBranch?.BranchID ?? 0)) ?? null;
                        notificationMessage.ReceivedBranch = BranchList?.FirstOrDefault(s => s.BranchID == Convert.ToInt32(ReturnData?.InitiationBranch?.BranchID ?? 0)) ?? null;
                        notificationMessage.MessageTitle = "Truck name " + (ReturnData?.Truck?.RegNo ?? "") + " is rejected.";
                        notificationMessage.MessageBody = "Truck name " + (ReturnData?.Truck?.RegNo ?? "") + " is rejected from " + (notificationMessage?.InitiateBranch?.BranchName ?? "") + " on " + (DateTime.Now).ToString() + ".";
                        notificationMessage.RedirectedTo = 0;
                        notificationMessage.MsgDate = DateTime.Now;
                        notificationMessage.ExpiredBy = 7;
                        notificationMessage.DocumentID = ReturnData.TruckTransferInitiationID;
                        await Send();
                    }
                }
                await GetAll();
            }
        }
        else
        {
            bool? ResultModel = await DialogService.ShowMessageBox(
                      "Permission denied!",
                      "You dont have any permission to Add or Edit.");
        }
    }


    private async Task GetAllIncoming()
    {
        collectionIncoming = new();
        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;
        var brancIDString = authprov.User.Claims.First(x => x.Type == "BranchID").Value;
        if (modelIncoming.TruckTransferEndModel == null)
        {
            modelIncoming.TruckTransferEndModel = new();
        }
        if (modelIncoming.TruckTransferEndModel.TruckEvent == null)
        {
            modelIncoming.TruckTransferEndModel.TruckEvent = new();
        }

        modelIncoming.TruckTransferEndModel.TruckEvent.UserInfo = new();
        modelIncoming.TruckTransferEndModel.TruckEvent.UserInfo.UserID = user.Identity.Name;
        if (modelIncoming.DestinationBranch == null)
        {
            modelIncoming.DestinationBranch = new();
        }
        modelIncoming.DestinationBranch.BranchID = int.Parse(brancIDString);

        foreach (var item in Iservice.SelectIncomingTrucks(modelIncoming.DestinationBranch?.BranchID ?? 0))
        {
            //if(item.TruckTransferEndModel.TruckTransferEndID == null || item.TruckTransferEndModel.TruckTransferEndID == 0)
            //{
            //    item.TruckTransferEndModel.TransferStatus = "Transfer Not Completed";
            //}
            //else
            //{
            //    item.TransferStatus = "Transfer Completed";
            //}
            if (item.TruckEvent == null)
            {
                item.TruckEvent = new();
            }
            collectionIncoming.Add(item);
        }


    }
    #endregion
}
