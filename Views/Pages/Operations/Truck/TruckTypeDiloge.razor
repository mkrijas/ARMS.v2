@page "/trucktypeadd"
@using System.Threading;
@using System.Globalization
@attribute [Authorize]
@inject AuthenticationStateProvider auth
@inject ITruckTypeService Iservice
@inject MudBlazor.ISnackbar snackbar
@inject ITruckTypeService Itrucktype
@inject IRoleService<RoleModel> Irole
@inject IDialogService DialogService

<MudDialog>
    <DialogContent>
        <EditForm id="truckTypeform" Model="@TypeModel" OnValidSubmit="OnValidSubmit">
            <DataAnnotationsValidator />
            <ValidationSummary />
            <MudGrid>
                <MudItem xs="12">
                    <MudTextField @bind-Value="@TypeModel.TruckType" Label="Truck Type" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => TypeModel.TruckType)"></MudTextField>
                </MudItem>
                <MudItem xs="12">
                    <MudSelect Variant="Variant.Outlined" Margin="Margin.Dense" T="string" Label="BS-Version" @bind-Value="@TypeModel.BSType">
                        @foreach (var i in BSType)
                        {
                            <MudSelectItem Value="@i">@i</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>                
                <MudItem xs="12">
                    <MudTextField @bind-Value="@TypeModel.Axles" Label="Axles" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => TypeModel.Axles)"></MudTextField>
                </MudItem>
                <MudItem xs="12">
                    <MudTextField @bind-Value="@TypeModel.wheels" Label="Wheels" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => TypeModel.wheels)"></MudTextField>
                </MudItem>
                <MudItem xs="12" Class="d-flex align-baseline">
                    Must Refill Adblue After <MudNumericField Class="d-inline-flex ml-3 mr-3"  @bind-Value="@TypeModel.AdBlueFrequency" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => TypeModel.wheels)"></MudNumericField> Trips atleast
                </MudItem>
            </MudGrid>
        </EditForm>
    </DialogContent>
    <DialogActions>
        <MudButton Disabled="@_busy" form="truckTypeform" Variant="Variant.Filled" Color="Color.Success" ButtonType="ButtonType.Submit">Save TruckType</MudButton>
    </DialogActions>
</MudDialog>

@code {

    [CascadingParameter] IMudDialogInstance MudDialog { get; set; }
    private List<string> BSType = new List<string>
    {
        "BS1",
        "BS2",
        "BS3",
        "BS4",
        "BS5",
        "BS6",
        "BS7",
        "BS8"
    };
    [Parameter]
    public TruckTypeModel TypeModel { get; set; }
    private bool _busy;
    public bool HasPermissionITruckTypeServiceEdit { get; set; } = false;
    public int DocTypeID = 38;

    protected override async Task OnInitializedAsync()
    {
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionITruckTypeServiceEdit = await Irole.HasClaim(DocTypeID.ToString(), "Edit", ctc.Token);
    }

    private async void OnValidSubmit(EditContext context)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is being submitted!", Severity.Warning);
            return;
        }
        _busy = true;
        if (HasPermissionITruckTypeServiceEdit)
        {
            var authprov = await auth.GetAuthenticationStateAsync();
            var user = authprov.User;
            TypeModel.UserInfo.UserID = user.Identity.Name;
            try
            {
                TypeModel = Iservice.Update(TypeModel);
                snackbar.Add("Saved Successfully", Severity.Success);
                MudDialog.Close(TypeModel);
                TypeModel = new TruckTypeModel();
            }
            catch (Exception ex)
            {
                snackbar.Add(ex.Message, Severity.Warning);
            }
        }
        else
        {
            bool? ResultModel = await DialogService.ShowMessageBox(
                "Permission denied!",
                "You don't have any permission to Add or Edit TruckType.");
        }
        await Task.Delay(200);
        _busy = false;
    }
}
