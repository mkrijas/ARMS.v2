@page "/trucktypeadd"
@using System.Threading;
@using System.Globalization
@attribute [Authorize]
@inject AuthenticationStateProvider auth
@inject ITruckTypeService Iservice
@inject MudBlazor.ISnackbar snackbar
@inject ITruckTypeService Itrucktype
@inject IRoleService<RoleModel> Irole
@inject IDialogService DialogService

<MudDialog Class="admin-dialog-glass">
    <TitleContent>
        <div class="header-section mb-2 pt-4 px-4">
            <div class="d-flex align-center justify-space-between">
                <div class="d-flex align-center">
                    <div class="icon-badge primary-badge mr-4">
                        <div class="admin-header-icon-badge mb-3">
                            <MudIcon Icon="@Icons.Material.Filled.LocalShipping" Color="Color.Secondary" Style="font-size: 3rem;" />
                        </div>
                    </div>
                    <div>
                        <MudText Typo="Typo.h5" Class="admin-title"><b>Vehicle Specification Master</b></MudText>
                        <MudText Typo="Typo.body2" Class="admin-subtitle">
                            Configure technical classifications and performance parameters for fleet assets.
                        </MudText>
                    </div>
                </div>
            </div>
            <div class="title-accent mt-4"></div>
        </div>
    </TitleContent>
    <DialogContent>
        <MudContainer Class="admin-dialog-container">
            <div class="dialog-content-wrapper pa-2">
                <EditForm id="truckTypeform" Model="@TypeModel" OnValidSubmit="OnValidSubmit">
                    <div class="admin-glass-card pa-6">
                        <DataAnnotationsValidator />
                        <MudValidationSummary />
                        <MudGrid Spacing="4">
                            <MudItem xs="12" md="6">
                                <MudTextField @bind-Value="@TypeModel.TruckType" Label="Vechicle Classification" Variant="Variant.Outlined" Margin="Margin.Normal" For="@(() => TypeModel.TruckType)" Class="modern-input" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Category"></MudTextField>
                            </MudItem>
                            <MudItem xs="12" md="6">
                                <MudSelect For="@(() => TypeModel.BSType)" Variant="Variant.Outlined" Margin="Margin.Normal" T="string" Label="BS-Compliance Standard" @bind-Value="@TypeModel.BSType" Class="modern-input">
                                    @foreach (var i in BSType)
                                    {
                                        <MudSelectItem Value="@i">@i</MudSelectItem>
                                    }
                                </MudSelect>
                            </MudItem>                
                            <MudItem xs="12" md="6">
                                <MudTextField @bind-Value="@TypeModel.Axles" Label="Chassis Axle Count" Variant="Variant.Outlined" Margin="Margin.Normal" For="@(() => TypeModel.Axles)" Class="modern-input" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.SettingsInputHdmi"></MudTextField>
                            </MudItem>
                            <MudItem xs="12" md="6">
                                <MudTextField @bind-Value="@TypeModel.wheels" Label="Total Wheel Configuration" Variant="Variant.Outlined" Margin="Margin.Normal" For="@(() => TypeModel.wheels)" Class="modern-input" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.PanoramaFishEye"></MudTextField>
                            </MudItem>
                            <MudItem xs="12">
                                <div class="pa-4 rounded-xl d-flex align-center" style="background: rgba(54, 117, 136, 0.05); border: 1px dashed rgba(54, 117, 136, 0.3);">
                                    <MudIcon Icon="@Icons.Material.Filled.WaterDrop" Color="Color.Primary" Class="mr-3" />
                                    <MudText Typo="Typo.body2" Class="mr-2"><b>Maintenance Protocol:</b> Mandatory Adblue replenishment after</MudText>
                                    <MudNumericField Style="max-width: 80px;" HideSpinButtons @bind-Value="@TypeModel.AdBlueFrequency" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => TypeModel.AdBlueFrequency)" Class="modern-input d-inline-flex mx-2"></MudNumericField>
                                    <MudText Typo="Typo.body2">operational cycles (trips).</MudText>
                                </div>
                            </MudItem>
                        </MudGrid>
                    </div>
                </EditForm>
            </div>
        </MudContainer>
    </DialogContent>
    <DialogActions>
        <div class="d-flex w-100 flex-wrap pa-4 gap-3 align-center">
            <MudSpacer />
            <MudButton @onclick="Cancel" Variant="Variant.Outlined" Color="Color.Default" Style="border-radius: 12px; font-weight: 700; text-transform: none; border-color: rgba(0,0,0,0.15);">Discard</MudButton>
            <MudButton Disabled="@_busy" form="truckTypeform" Variant="Variant.Filled" ButtonType="ButtonType.Submit" Color="Color.Primary" Class="action-btn-primary px-10 rounded-pill" Style="background: var(--mud-palette-primary) !important; color: white !important;" StartIcon="@Icons.Material.Filled.Save">Save Specifications</MudButton>
        </div>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; }
    private List<string> BSType = new List<string>
    {
        "BS1",
        "BS2",
        "BS3",
        "BS4",
        "BS5",
        "BS6",
        "BS7",
        "BS8"
    };
    [Parameter]
    public TruckTypeModel TypeModel { get; set; }
    private bool _busy;
    public bool HasPermissionITruckTypeServiceEdit { get; set; } = false;
    public int DocTypeID = 38;

    protected override async Task OnInitializedAsync()
    {
        if (TypeModel == null) TypeModel = new TruckTypeModel();
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionITruckTypeServiceEdit = await Irole.HasClaim(DocTypeID.ToString(), "Edit", ctc.Token);
    }

    private async void OnValidSubmit(EditContext context)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is being submitted!", Severity.Warning);
            return;
        }
        _busy = true;
        if (HasPermissionITruckTypeServiceEdit)
        {
            var authprov = await auth.GetAuthenticationStateAsync();
            var user = authprov.User;
            TypeModel.UserInfo.UserID = user.Identity.Name;
            try
            {
                TypeModel = Iservice.Update(TypeModel);
                snackbar.Add("Saved Successfully", Severity.Success);
                MudDialog.Close(DialogResult.Ok(TypeModel));
                TypeModel = new TruckTypeModel();
            }
            catch (Exception ex)
            {
                snackbar.Add(ex.Message, Severity.Warning);
            }
        }
        else
        {
            bool? ResultModel = await DialogService.ShowMessageBoxAsync(
                "Permission denied!",
                "You don't have any permission to Add or Edit TruckType.");
        }
        await Task.Delay(200);
        _busy = false;
    }

    private void Cancel()
    {
        MudDialog.Cancel();
    }
}
