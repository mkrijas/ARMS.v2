@page "/trucktypeadd"

@inject ITruckTypeService Iservice
@inject MudBlazor.ISnackbar snackbar
@inject ITruckTypeService Itrucktype
@inject AuthenticationStateProvider auth
@attribute [Authorize]

@using System.Globalization

@using System.Threading;
@inject IRoleService<RoleModel> Irole
@inject IDialogService DialogService


<MudDialog>
    <DialogContent>
        <EditForm id="truckTypeform" Model="@TypeModel" OnValidSubmit="OnValidSubmit">
            <DataAnnotationsValidator />
            <ValidationSummary />
            <MudTextField @bind-Value="@TypeModel.TruckType" Label="Truck Type" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => TypeModel.TruckType)"></MudTextField>
            <MudSelect Variant="Variant.Outlined" Margin="Margin.Dense" T="string" Label="BS-Version" @bind-Value="@TypeModel.BSType">
                @foreach (var i in BSType)
                {
                    <MudSelectItem Value="@i">@i</MudSelectItem>
                }
            </MudSelect>
            <MudTextField @bind-Value="@TypeModel.UnladenWeight" Label="Unladen Weight" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => TypeModel.UnladenWeight)"></MudTextField>
            <MudTextField @bind-Value="@TypeModel.GrossWeight" Label="Gross Weight" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => TypeModel.GrossWeight)"></MudTextField>
            <MudTextField @bind-Value="@TypeModel.Axles" Label="Axles" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => TypeModel.Axles)"></MudTextField>
            <MudTextField @bind-Value="@TypeModel.wheels" Label="Wheels" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => TypeModel.wheels)"></MudTextField>
        </EditForm>
    </DialogContent>
    <DialogActions>
        <MudButton form="truckTypeform" Variant="Variant.Filled" Color="Color.Success" ButtonType="ButtonType.Submit">Save TruckType</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] MudDialogInstance MudDialog { get; set; }

    private List<string> BSType = new List<string>
    {
        "BS-I",
        "BS-II",
        "BS-III",
        "BS-IV",
        "BS-V",
        "BS-VI",
    };

    [Parameter]
    public TruckTypeModel TypeModel { get; set; }

    public bool HasPermissionEdit { get; set; } = false;
    public int DocTypeID = 32;

    protected override async Task OnInitializedAsync()
    {
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionEdit = await Irole.HasClaim(DocTypeID.ToString(), "Edit", ctc.Token);
    }

    private async void OnValidSubmit(EditContext context)
    {
        if (HasPermissionEdit)
        {
            var authprov = await auth.GetAuthenticationStateAsync();
            var user = authprov.User;
            TypeModel.UserInfo.UserID = user.Identity.Name;
            try
            {
                TypeModel = Iservice.Update(TypeModel);
                snackbar.Add("Saved Successfully", Severity.Success);
                MudDialog.Close(TypeModel);
                TypeModel = new TruckTypeModel();

            }
            catch (Exception ex)
            {
                snackbar.Add(ex.Message, Severity.Warning);
            }
        }
        else
        {
            bool? ResultModel = await DialogService.ShowMessageBox(
                      "Permission denied!",
                      "You dont have any permission to Add or Edit.");
        }
    }

}