@page "/truckType"
@using System.Threading;
@using System.Globalization
@using Pages.Inventory.TyreManager
@attribute [Authorize]
@inject AuthenticationStateProvider auth
@inject ITruckTypeService Iservice
@inject MudBlazor.ISnackbar snackbar
@inject IDialogService DialogService
@inject IRoleService<RoleModel> Irole

<div class="admin-page-container">
    <div class="admin-header-tiered mb-6">
        <div class="d-flex align-center justify-space-between">
            <div>
                <MudText Typo="Typo.h4" Class="admin-title">Vehicle Architecture Engine</MudText>
                <MudText Typo="Typo.body2" Class="admin-subtitle">Define and manage technical vehicle specifications, axle configurations, and tyre layouts.</MudText>
            </div>
            <MudButton StartIcon="@Icons.Material.Filled.Add" Variant="Variant.Filled" Color="Color.Primary" Class="admin-register-btn" OnClick="@(()=> Edit(new TruckTypeModel()))" Disabled="@_busy">ADD SPECIFICATION</MudButton>
        </div>
    </div>

    <div class="admin-glass-card mb-6 pa-4">
        <div class="d-flex align-center gap-4">
            <div style="flex-grow: 1;">
                <MudTextField @bind-Value="searchTruckType" Placeholder="Search by truck type or BS-version..." Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" Variant="Variant.Outlined" Margin="Margin.Dense" Class="admin-input-group" Clearable="true" />
            </div>
        </div>
    </div>

    <div class="admin-glass-card pa-0 overflow-hidden">
        <MudTable Items="@collection" Elevation="0" Filter="new Func<TruckTypeModel, bool>(search)" Class="modern-admin-table" Hover="true">
            <HeaderContent>
                <MudTh><MudTableSortLabel SortBy="new Func<TruckTypeModel, object>(x=> x.TruckType)" InitialDirection="SortDirection.Ascending"><span class="admin-header-text">CLASSIFICATION</span></MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<TruckTypeModel, object>(x=> x.BSType)" InitialDirection="SortDirection.Ascending"><span class="admin-header-text">EMISSION STANDARD</span></MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<TruckTypeModel, object>(x=> x.Axles)" InitialDirection="SortDirection.Ascending"><span class="admin-header-text">AXLE CONFIG</span></MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<TruckTypeModel, object>(x=> x.wheels)" InitialDirection="SortDirection.Ascending"><span class="admin-header-text">WHEEL COUNT</span></MudTableSortLabel></MudTh>
                <MudTh Style="text-align: right;"><span class="admin-header-text">ACTIONS</span></MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="TruckType"><span class="admin-td-primary fw-600">@context.TruckType</span></MudTd>
                <MudTd DataLabel="BS-Version">
                    <MudChip T="string" Size="Size.Small" Color="Color.Info" Variant="Variant.Text" Class="fw-700">@context.BSType</MudChip>
                </MudTd>            
                <MudTd DataLabel="Axles">@context.Axles Axles</MudTd>
                <MudTd DataLabel="wheels">@context.wheels Wheels</MudTd>
                <MudTd DataLabel="Actions" Style="text-align: right;">
                    <div class="d-flex justify-end gap-1">
                        <MudTooltip Text="Edit Specification">
                            <MudIconButton OnClick="@(()=> Edit(context))" Color="Color.Primary" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Variant="Variant.Text" />
                        </MudTooltip>
                        <MudTooltip Text="Tyre Mapping">
                            <MudIconButton OnClick="@(()=> SelectTyrePosition(context))" Color="Color.Info" Icon="@Icons.Material.Filled.Checklist" Size="Size.Small" Variant="Variant.Text" />
                        </MudTooltip>
                        <MudTooltip Text="Remove Type">
                            <MudIconButton OnClick="@(()=> Delete(context))" Color="Color.Error" Icon="@Icons.Material.Filled.DeleteOutline" Size="Size.Small" Variant="Variant.Text" />
                        </MudTooltip>
                    </div>
                </MudTd>
            </RowTemplate>
            <PagerContent>
                <div class="pa-4">
                    <MudTablePager PageSizeOptions="new int[] { 10, 20, 50, 100 }" />
                </div>
            </PagerContent>
        </MudTable>
    </div>
</div>

@code {

    private TruckTypeModel model = new TruckTypeModel();
    private string searchTruckType = "";
    private List<TruckTypeModel> collection = new List<TruckTypeModel>();
    private bool _busy;
    public bool HasPermissionITruckTypeServiceEdit { get; set; } = false;
    public bool HasPermissionITruckTypeServiceDelete { get; set; } = false;
    public int DocTypeID = 38;

    protected override async Task OnInitializedAsync()
    {
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionITruckTypeServiceEdit = await Irole.HasClaim(DocTypeID.ToString(), "Edit", ctc.Token);
        HasPermissionITruckTypeServiceDelete = await Irole.HasClaim(DocTypeID.ToString(), "Delete", ctc.Token);

        await Task.Run(() => GetAll());
    }

    private void GetAll()
    {
        if (collection != null)
        {
            collection.Clear();
        }
        foreach (var item in Iservice.Select(0))
        {
            collection.Add(item);
        }
    }

    private async Task Edit(TruckTypeModel TypeModel)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        _busy = true;
        if (HasPermissionITruckTypeServiceEdit)
        {
            var Options = new DialogOptions { MaxWidth = MaxWidth.Small };
            DialogParameters tparms = new();
            tparms.Add("TypeModel", TypeModel.Clone());
            var dialog = await DialogService.ShowAsync<TruckTypeDiloge>("Truck type", tparms,Options);
            var result = await dialog.Result;

            // you can check if the modal was cancelled
            var isCancelled = result.Canceled;
            if (!isCancelled)
            {
                TruckTypeModel UpatedModel = (TruckTypeModel)result.Data;
                if (UpatedModel != null)
                {
                    if (collection.Exists(x => x.TruckTypeID == UpatedModel.TruckTypeID))
                    {
                        collection[collection.FindIndex(x => x.TruckTypeID == UpatedModel.TruckTypeID)] = UpatedModel;
                    }
                    else
                    {
                        collection.Add(UpatedModel);
                    }
                    UpatedModel = new();
                }
            }
        }
        else
        {
            bool? ResultModel = await DialogService.ShowMessageBoxAsync(
                "Permission denied!",
                "You don't have any permission to Add or Edit TruckType.");
        }
        await Task.Delay(200);
        _busy = false;
    }

    private async Task Delete(TruckTypeModel model)
    {
        if (HasPermissionITruckTypeServiceDelete)
        {
            bool? result = await DialogService.ShowMessageBoxAsync(
                "Warning !",
                "Are you sure, you want to delete - " + model.TruckType + " (" + model.BSType + ") ?");
            if (result == true)
            {
                var authprov = await auth.GetAuthenticationStateAsync();
                var user = authprov.User;
                int value = Iservice.Delete(model.TruckTypeID, user.Identity.Name);
                StateHasChanged();
                if (value != -1)
                {
                    if (collection != null && collection.Any(s => s.TruckTypeID == model.TruckTypeID))
                    {
                        collection.Remove(collection.FirstOrDefault(s => s.TruckTypeID == model.TruckTypeID));
                        snackbar.Add("Deleted Successfully", Severity.Success);
                    }
                }
            }
        }
        else
        {
            bool? result = await DialogService.ShowMessageBoxAsync(
                "Permission denied!",
                "You don't have any permission to Delete TruckType.");
        }
    }

    private async Task SelectTyrePosition(TruckTypeModel TypeModel)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        _busy = true;
        DialogParameters tparms = new DialogParameters();
        tparms.Add("TypeModel", TypeModel);
        var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Medium };
        var dialog = await DialogService.ShowAsync<TyrePositionDialog>("ADD/EDIT Tyre Position", tparms, options);
        var result = await dialog.Result;

        // you can check if the modal was cancelled
        var isCancelled = result.Canceled;
        if (!isCancelled)
        {

        }
        await Task.Delay(200);
        _busy = false;
    }

    private bool search(TruckTypeModel TruckType)
    {
        if (TruckType.TruckType != null && TruckType.TruckType.Contains(searchTruckType, StringComparison.OrdinalIgnoreCase))
        {
            return true;
        }
        return false;
    }
}

