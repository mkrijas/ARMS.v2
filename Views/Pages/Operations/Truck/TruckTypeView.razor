@page "/truckType"
@using System.Threading;
@using System.Globalization
@using Pages.Inventory.TyreManager
@attribute [Authorize]
@inject AuthenticationStateProvider auth
@inject ITruckTypeService Iservice
@inject MudBlazor.ISnackbar snackbar
@inject IDialogService DialogService
@inject IRoleService<RoleModel> Irole

<MudItem xs="12">
    <MudTable Items="@collection" RowsPerPage="10" Elevation="10" Filter="new Func<TruckTypeModel, bool>(search)" @bind-TruckType="model">
        <ToolBarContent>
            <MudText Typo="Typo.h6">Truck Types</MudText>
            <MudIconButton Icon="@Icons.Material.Filled.Add" Title="Add" @onclick="(()=>Edit(new TruckTypeModel()))" Color="Color.Dark" Size="Size.Small"></MudIconButton>
            <MudSpacer></MudSpacer>
            <MudTextField @bind-Value="searchTruckType" Placeholder="Search TruckTypes... " Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0"></MudTextField>
        </ToolBarContent>
        <HeaderContent>
            <MudTh><MudTableSortLabel SortBy="new Func<TruckTypeModel, object>(x=> x.TruckType)" InitialDirection="SortDirection.Ascending">TruckType</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel SortBy="new Func<TruckTypeModel, object>(x=> x.BSType)" InitialDirection="SortDirection.Ascending">BS-Version</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel SortBy="new Func<TruckTypeModel, object>(x=> x.Axles)" InitialDirection="SortDirection.Ascending">Axles</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel SortBy="new Func<TruckTypeModel, object>(x=> x.wheels)" InitialDirection="SortDirection.Ascending">wheels</MudTableSortLabel></MudTh>
            <MudTh>Actions</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="TruckType">@context.TruckType</MudTd>
            <MudTd DataLabel="BS-Version">@context.BSType</MudTd>            
            <MudTd DataLabel="Axles">@context.Axles</MudTd>
            <MudTd DataLabel="wheels">@context.wheels</MudTd>
            <MudTd DataLabel="">
                <MudFab @onclick="@(()=> Edit(context))" Color="Color.Primary" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" IconSize="Size.Small" />
                <MudFab @onclick="@(()=> Delete(context))" Color="Color.Primary" Icon="@Icons.Material.Filled.Delete" Size="Size.Small" IconSize="Size.Small" />
                <MudFab @onclick="@(()=> SelectTyrePosition(context))" Color="Color.Primary" Icon="@Icons.Material.Filled.Checklist" Size="Size.Small" IconSize="Size.Small" />
            </MudTd>
        </RowTemplate>
        <PagerContent>
            <MudTablePager PageSizeOptions="new int[] { 10, 20, 50, 100 }" />
        </PagerContent>
    </MudTable>
</MudItem>

@code {

    private TruckTypeModel model = new TruckTypeModel();
    private string searchTruckType = "";
    private List<TruckTypeModel> collection = new List<TruckTypeModel>();
    private bool _busy;
    public bool HasPermissionITruckTypeServiceEdit { get; set; } = false;
    public bool HasPermissionITruckTypeServiceDelete { get; set; } = false;
    public int DocTypeID = 38;

    protected override async Task OnInitializedAsync()
    {
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionITruckTypeServiceEdit = await Irole.HasClaim(DocTypeID.ToString(), "Edit", ctc.Token);
        HasPermissionITruckTypeServiceDelete = await Irole.HasClaim(DocTypeID.ToString(), "Delete", ctc.Token);

        await Task.Run(() => GetAll());
    }

    private void GetAll()
    {
        if (collection != null)
        {
            collection.Clear();
        }
        foreach (var item in Iservice.Select(0))
        {
            collection.Add(item);
        }
    }

    private async Task Edit(TruckTypeModel TypeModel)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        _busy = true;
        if (HasPermissionITruckTypeServiceEdit)
        {
            DialogParameters tparms = new();
            tparms.Add("TypeModel", TypeModel.Clone());
            var dialog = DialogService.Show<TruckTypeDiloge>("Truck type", tparms);
            var result = await dialog.Result;

            // you can check if the modal was cancelled
            var isCancelled = result.Canceled;
            if (!isCancelled)
            {
                TruckTypeModel UpatedModel = (TruckTypeModel)result.Data;
                if (UpatedModel != null)
                {
                    if (collection.Exists(x => x.TruckTypeID == UpatedModel.TruckTypeID))
                    {
                        collection[collection.FindIndex(x => x.TruckTypeID == UpatedModel.TruckTypeID)] = UpatedModel;
                    }
                    else
                    {
                        collection.Add(UpatedModel);
                    }
                    UpatedModel = new();
                }
            }
        }
        else
        {
            bool? ResultModel = await DialogService.ShowMessageBox(
                "Permission denied!",
                "You dont have any permission to Add or Edit TruckType.");
        }
        await Task.Delay(200);
        _busy = false;
    }

    private async Task Delete(TruckTypeModel model)
    {
        if (HasPermissionITruckTypeServiceDelete)
        {
            bool? result = await DialogService.ShowMessageBox(
                "Warning !",
                "Are you sure, you want to delete - " + model.TruckType + " (" + model.BSType + ") ?");
            if (result == true)
            {
                var authprov = await auth.GetAuthenticationStateAsync();
                var user = authprov.User;
                int value = Iservice.Delete(model.TruckTypeID, user.Identity.Name);
                StateHasChanged();
                if (value != -1)
                {
                    if (collection != null && collection.Any(s => s.TruckTypeID == model.TruckTypeID))
                    {
                        collection.Remove(collection.FirstOrDefault(s => s.TruckTypeID == model.TruckTypeID));
                        snackbar.Add("Deleted Successfully", Severity.Success);
                    }
                }
            }
        }
        else
        {
            bool? result = await DialogService.ShowMessageBox(
                "Permission denied!",
                "You dont have any permission to Delete TruckType.");
        }
    }

    private async Task SelectTyrePosition(TruckTypeModel TypeModel)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        _busy = true;
        DialogParameters tparms = new DialogParameters();
        tparms.Add("TypeModel", TypeModel);
        var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Medium };
        var dialog = DialogService.Show<TyrePositionDialog>("ADD/EDIT Tyre Position", tparms, options);
        var result = await dialog.Result;

        // you can check if the modal was cancelled
        var isCancelled = result.Canceled;
        if (!isCancelled)
        {

        }
        await Task.Delay(200);
        _busy = false;
    }

    private bool search(TruckTypeModel TruckType)
    {
        if (TruckType.TruckType != null && TruckType.TruckType.Contains(searchTruckType, StringComparison.OrdinalIgnoreCase))
        {
            return true;
        }
        return false;
    }
}