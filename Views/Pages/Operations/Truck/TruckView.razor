@page "/trucks"

@inject TruckDataArrayModel data
@inject ITruckService Iservice
@inject ITruckTypeService Itrucktype
@inject IBranchService Ibranch
@inject MudBlazor.ISnackbar snackbar
@inject AuthenticationStateProvider auth
@attribute [Authorize]
@inject IDialogService DialogService


@using System.Globalization
@using Views.Pages.Inventory



<MudTable Items="@collection" Elevation="8" Filter="new Func<TruckModel, bool>(search)" @bind-Truck="model">


    <ToolBarContent>
        <MudText Typo="Typo.h6">Truck</MudText>
        <MudIconButton Icon="@Icons.Material.Filled.Add" Title="Add" @onclick="@(()=> Edit(null))" Color="Color.Dark" Size="Size.Small"></MudIconButton>

        <MudSpacer></MudSpacer>
        <MudTextField @bind-Value="searchTruck" Placeholder="Search Trucks... "
                      Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                      IconSize="Size.Medium"></MudTextField>
    </ToolBarContent>

    <HeaderContent>
        <MudTh><MudTableSortLabel SortBy="new Func<TruckModel, object>(x=> x.RegNo)" InitialDirection="SortDirection.Ascending">Truck</MudTableSortLabel></MudTh>
        <MudTh><MudTh><MudTableSortLabel SortBy="new Func<TruckModel, object>(x=> x.TruckType)" InitialDirection="SortDirection.Ascending">Type</MudTableSortLabel></MudTh></MudTh>
        <MudTh><MudTh><MudTableSortLabel SortBy="new Func<TruckModel, object>(x=> x.FuelType)" InitialDirection="SortDirection.Ascending">Fuel Type</MudTableSortLabel></MudTh></MudTh>
        <MudTh><MudTh><MudTableSortLabel SortBy="new Func<TruckModel, object>(x=> x.FuelTankCapacity)" InitialDirection="SortDirection.Ascending">Fuel Capacity</MudTableSortLabel></MudTh></MudTh>
        <MudTh><MudTh><MudTableSortLabel SortBy="new Func<TruckModel, object>(x=> x.BodyType)" InitialDirection="SortDirection.Ascending">Body Type</MudTableSortLabel></MudTh></MudTh>
        <MudTh><MudTh><MudTableSortLabel SortBy="new Func<TruckModel, object>(x=> x.ManufacturedYear)" InitialDirection="SortDirection.Ascending">Year</MudTableSortLabel></MudTh></MudTh>
        <MudTh>Actions</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd DataLabel="Truck">@context.RegNo</MudTd>
        <MudTd DataLabel="TruckType">@context.TruckType</MudTd>
        <MudTd DataLabel="FuelType">@context.FuelType</MudTd>
        <MudTd DataLabel="FuelTankCapacity">@context.FuelTankCapacity</MudTd>
        <MudTd DataLabel="BodyType">@context.BodyType</MudTd>
        <MudTd DataLabel="ManufacturedYear">@context.ManufacturedYear</MudTd>
        <MudTd DataLabel="">
            <MudFab style="font-size:5px" @onclick="@(()=> Edit(context.TruckID))" Color="Color.Primary" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" IconSize="Size.Small" /><MudFab @onclick="@(()=> Delete(context.TruckID))" Color="Color.Primary" Icon="@Icons.Material.Filled.Delete" Size="Size.Small" IconSize="Size.Small" />
            <MudTooltip Text="Mount Details">
                <MudFab @onclick="@(()=> TruckMountDetails(context.TruckID))" Color="Color.Primary" Icon="@Icons.Material.Filled.TableView" Size="Size.Small" IconSize="Size.Small" />
            </MudTooltip>
        </MudTd>
    </RowTemplate>
    <PagerContent>
        <MudTablePager PageSizeOptions="new int[] { 5, 10, 20, 50, 100 }" />
    </PagerContent>
</MudTable>



