@page "/trucks"
@using System.Threading;
@using System.Globalization
@using OfficeOpenXml
@using System.IO
@using OfficeOpenXml.Style
@using Views.Pages.Inventory.TyreManager
@attribute [Authorize]
@inject AuthenticationStateProvider auth
@inject NavigationManager UriHelper;
@inject TruckDataArrayModel data
@inject ITruckService Iservice
@inject ITruckTypeService Itrucktype
@inject IBranchService Ibranch
@inject IDriverService Idriver
@inject IEventService Ievent
@inject MudBlazor.ISnackbar snackbar
@inject IDialogService DialogService
@inject IRoleService<RoleModel> Irole
@inject IJSRuntime JSRuntime



@if (_isLoading)
{
    <div @key="@("loader")" style="display: flex; justify-content: center; align-items: center; min-height: 400px;">
        <LoaderComponent IsFullScreen="true" 
                        ShowLogo="false" 
                        Size="medium" 
                        LoadingText="Loading Trucks" 
                        SubText="Please wait..." />
    </div>
}


else
{
<div @key="@("content")" class="admin-page-container">
    <div class="admin-header-tiered mb-6">
        <div class="d-flex align-center justify-space-between">
            <div>
                <MudText Typo="Typo.h4" Class="admin-title">Fleet Management</MudText>
                <MudText Typo="Typo.body2" Class="admin-subtitle">Monitor vehicle status, compliance, and operational assignments across all branches.</MudText>
            </div>
            <MudButton StartIcon="@Icons.Material.Filled.Add" Variant="Variant.Filled" Color="Color.Primary" Class="admin-register-btn" OnClick="@(()=> Edit(null))" Disabled="@_busy">REGISTER VEHICLE</MudButton>
        </div>
    </div>

    <div class="admin-glass-card pa-0 overflow-hidden">
        <MudTable Items="@collection" RowClassFunc="RowClassFunc" Elevation="0" Filter="new Func<TruckModel, bool>(search)" @bind-Truck="model" Class="modern-admin-table">
            <ToolBarContent>
                <div class="d-flex align-center gap-4 w-100 px-4 py-2">
                    <MudTextField @bind-Value="searchTruck" Placeholder="Search Trucks... " Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Variant="Variant.Outlined" Margin="Margin.Dense" Class="admin-input-group flex-grow-1" />
                    <MudButton OnClick="ExcelDownload" StartIcon="@Icons.Material.Outlined.Article" Variant="Variant.Filled" Color="Color.Primary" Class="action-btn-primary" Style="background: #367588; border-radius: 12px; height: 40px; color: white;">Export to Excel</MudButton>
                </div>
            </ToolBarContent>
    <HeaderContent>
        <MudTh><MudTableSortLabel SortBy="new Func<TruckModel, object>(x=> x.RegNo)" InitialDirection="SortDirection.Ascending"><span class="admin-header-text">VEHICLE NO</span></MudTableSortLabel></MudTh>
        <MudTh><MudTableSortLabel SortBy="new Func<TruckModel, object>(x=> x.TruckType)" InitialDirection="SortDirection.Ascending"><span class="admin-header-text">TYPE</span></MudTableSortLabel></MudTh>
        <MudTh><MudTableSortLabel SortBy="new Func<TruckModel, object>(x=> x.HomeBranchName)" InitialDirection="SortDirection.Ascending"><span class="admin-header-text">HOME BRANCH</span></MudTableSortLabel></MudTh>
        @if(BranchID == 7)
        {
            <MudTh><MudTableSortLabel SortBy="new Func<TruckModel, object>(x=> x.OperatingBranchName)" InitialDirection="SortDirection.Ascending"><span class="admin-header-text">OPERATING</span></MudTableSortLabel></MudTh>
        }
        <MudTh><MudTableSortLabel SortBy="new Func<TruckModel, object>(x=> x.FuelType)" InitialDirection="SortDirection.Ascending"><span class="admin-header-text">FUEL</span></MudTableSortLabel></MudTh>
        <MudTh><MudTableSortLabel SortBy="new Func<TruckModel, object>(x=> x.FuelTankCapacity)" InitialDirection="SortDirection.Ascending"><span class="admin-header-text">CAPACITY</span></MudTableSortLabel></MudTh>
        <MudTh><MudTableSortLabel SortBy="new Func<TruckModel, object>(x=> x.wheels)" InitialDirection="SortDirection.Ascending"><span class="admin-header-text">WHEELS</span></MudTableSortLabel></MudTh>
        <MudTh><MudTableSortLabel SortBy="new Func<TruckModel, object>(x=> x.BodyType)" InitialDirection="SortDirection.Ascending"><span class="admin-header-text">BODY</span></MudTableSortLabel></MudTh>
        <MudTh><MudTableSortLabel SortBy="new Func<TruckModel, object>(x=> x.ManufacturedYear)" InitialDirection="SortDirection.Ascending"><span class="admin-header-text">YEAR</span></MudTableSortLabel></MudTh>
        <MudTh Style="text-align: right;"><span class="admin-header-text">ACTIONS</span></MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd DataLabel="Truck">
            <div class="d-flex flex-column">
                <MudText Typo="Typo.body2" Class="admin-td-primary">@context.RegNo</MudText>
                @if (!context.CurrentRegistration.IsValid)
                {
                    <MudText Typo="Typo.caption" Color="Color.Error" Style="font-weight: 600;">(EXPIRED)</MudText>
                }
            </div>
        </MudTd>
        <MudTd DataLabel="TruckType"><MudChip T="string" Size="Size.Small" Variant="Variant.Text" Color="Color.Primary" Class="fw-700">@context.TruckType</MudChip></MudTd>
        <MudTd DataLabel="HomeBranchName"><MudText Typo="Typo.body2" Class="admin-td-secondary">@context.HomeBranchName</MudText></MudTd>
        @if (BranchID == 7)
        {
            <MudTd DataLabel="OperatingBranchName">@context.OperatingBranchName</MudTd>
        }
        <MudTd DataLabel="FuelType">@context.FuelType</MudTd>
        <MudTd DataLabel="FuelTankCapacity"><MudText Typo="Typo.body2" Class="admin-td-amount">@context.FuelTankCapacity.ToString() L</MudText></MudTd>
        <MudTd DataLabel="Wheels">@context.wheels</MudTd>
        <MudTd DataLabel="BodyType">@context.BodyType</MudTd>
        <MudTd DataLabel="ManufacturedYear">@context.ManufacturedYear</MudTd>
        <MudTd DataLabel="Actions" Style="text-align: right;">
            <div class="d-flex justify-end gap-1">
                <MudTooltip Text="Edit">
                    <MudIconButton OnClick="@(()=> Edit(context.TruckID))" Color="Color.Primary" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Variant="Variant.Text" />
                </MudTooltip>
                <MudTooltip Text="Delete">
                    <MudIconButton OnClick="@(()=> Delete(context))" Color="Color.Error" Icon="@Icons.Material.Filled.DeleteOutline" Size="Size.Small" Variant="Variant.Text" />
                </MudTooltip>
                <MudTooltip Text="Tyre Info">
                    <MudIconButton OnClick="@(()=> TruckMountDetails(context.TruckID))" Color="Color.Info" Icon="@Icons.Material.Filled.TableView" Size="Size.Small" Variant="Variant.Text" />
                </MudTooltip>
                <MudTooltip Text="Registration">
                    <MudIconButton OnClick="@(()=> RegisterNumberList(context))" Color="Color.Secondary" Icon="@Icons.Material.Filled.List" Size="Size.Small" Variant="Variant.Text" />
                </MudTooltip>
                <MudTooltip Text="Driver">
                    <MudIconButton OnClick="@(()=> AssignDriver(context))" Color="Color.Success" Icon="@Icons.Material.Filled.AirlineSeatReclineNormal" Size="Size.Small" Variant="Variant.Text" />
                </MudTooltip>
                @if(context.CurrentEvent.EventTypeID == 6)
                {
                    <MudTooltip Text="Non-Operating">
                        <MudIconButton OnClick="@(()=> Move(13, context))" Color="Color.Warning" Icon="@Icons.Material.Filled.MoveUp" Size="Size.Small" Variant="Variant.Text" />
                    </MudTooltip> 
                }
                @if (context.CurrentEvent.EventTypeID == 13)
                {
                    <MudTooltip Text="Undo">
                        <MudIconButton OnClick="@(()=> Move(6, context))" Color="Color.Warning" Icon="@Icons.Material.Filled.Undo" Size="Size.Small" Variant="Variant.Text" />
                    </MudTooltip>
                }
            </div>
        </MudTd>
    </RowTemplate>
    <PagerContent>
        <MudTablePager PageSizeOptions="new int[] { 10, 20, 50, 100 }" />
    </PagerContent>
        </MudTable>
    </div>
</div>




}

@code {

    private bool _isLoading = true;
    private DateTime _loadStartTime;

    private TruckModel model = new TruckModel();
    private string searchTruck = "";
    private List<TruckModel> collection = new List<TruckModel>();
    private List<TruckTypeModel> TruckTypes = new List<TruckTypeModel>();
    private List<BranchModel> Branches = new List<BranchModel>();
    private DriverModel AssignedDriver { get; set; }
    public string TruckRegisterListurl = "/TruckRegisterList";
    private bool _busy;
    int BranchID = 0;
    string AssignDriverLabel;

    public bool HasPermissionITruckServiceEdit { get; set; } = false;
    public bool HasPermissionITruckServiceDelete { get; set; } = false;
    public bool HasPermissionIEventServiceMove { get; set; } = false;
    public int DocTypeID = 37;
    public int EventDocTypeID = 48;

    protected override async Task OnInitializedAsync()
    {
        _loadStartTime = DateTime.Now;
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionITruckServiceEdit = await Irole.HasClaim(DocTypeID.ToString(), "Edit", ctc.Token);
        HasPermissionITruckServiceDelete = await Irole.HasClaim(DocTypeID.ToString(), "Delete", ctc.Token);
        HasPermissionIEventServiceMove = await Irole.HasClaim(EventDocTypeID.ToString(), "Move", ctc.Token);

        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;
        BranchID = int.Parse(user.Claims.FirstOrDefault(x => x.Type == "BranchID").Value);
        TruckTypes = Itrucktype.Select(0).ToList();
        Branches = Ibranch.Select().ToList();
        GetAll();
        await EnsureMinimumLoadTime();
        _isLoading = false;
    }

    private async Task EnsureMinimumLoadTime()
    {
        var elapsed = (DateTime.Now - _loadStartTime).TotalMilliseconds;
        if (elapsed < 100)
        {
            await Task.Delay(100 - (int)elapsed);
        }
    }

    private void GetAll()
    {
        collection = Iservice.SelectByBranch(BranchID, "All", "Operation").ToList();
    }

    private string RowClassFunc(TruckModel truck, Int32 index)
    {
        string classNames = string.Empty;
        if (!truck.CurrentRegistration.IsValid)
        {
            classNames += "InvalidRow ";
        }
        if (truck.HomeBranchID == BranchID && truck.CurrentBranchID != truck.HomeBranchID)
        {
            classNames += "InactiveTrucks ";
        }
        return classNames;
    }

    private async Task ExcelDownload()
    {
        var fileName = "TruckList.xlsx";
        var sheetName = "Sheet1"; // Change the sheet name as needed
        var fileBytes = GenerateExcelBytes(sheetName);

        await JSRuntime.InvokeVoidAsync("triggerFileDownload", fileName, Convert.ToBase64String(fileBytes));
    }

    private byte[] GenerateExcelBytes(string sheetName)
    {
        using (var package = new ExcelPackage())
        {
            var worksheet = package.Workbook.Worksheets.Add(sheetName);

            // Add column headers
            worksheet.Cells[1, 1].Value = "HomeBranch Name";
            worksheet.Cells[1, 2].Value = "OperatingBranch Name";
            worksheet.Cells[1, 3].Value = "Reg No";
            worksheet.Cells[1, 4].Value = "Truck Type";
            worksheet.Cells[1, 5].Value = "BS Type";
            worksheet.Cells[1, 6].Value = "Body Type";
            worksheet.Cells[1, 7].Value = "Transmission Type";
            worksheet.Cells[1, 8].Value = "Fuel Type";
            worksheet.Cells[1, 9].Value = "FuelTank Capacity";
            worksheet.Cells[1, 10].Value = "Wheels";
            worksheet.Cells[1, 11].Value = "Manufactured Year";
            worksheet.Cells[1, 12].Value = "Purchase Date Year";
            worksheet.Cells[1, 13].Value = "Valid From";
            worksheet.Cells[1, 14].Value = "Valid To";
            worksheet.Cells[1, 15].Value = "Engine Number";
            worksheet.Cells[1, 16].Value = "Chassis Number";
            worksheet.Cells[1, 17].Value = "Unladen Weight";
            worksheet.Cells[1, 18].Value = "Gross Weight";
            worksheet.Cells[1, 19].Value = "Status";
            for (int i = 1; i <= 19; i++)
            {
                worksheet.Cells[1, i].Style.Font.Bold = true;
            }

            //worksheet.Column(11).Style.Numberformat.Format = "dd-MM-yyyy"; // Date format
            worksheet.Column(17).Style.Numberformat.Format = "0.00"; // Integer format
            worksheet.Column(18).Style.Numberformat.Format = "0.00"; // Integer format

            // Add data rows
            int row = 2;
            foreach (var item in collection)
            {
                worksheet.Cells[row, 1].Value = item.HomeBranchName;
                worksheet.Cells[row, 2].Value = item.OperatingBranchName;
                worksheet.Cells[row, 3].Value = item.RegNo;
                worksheet.Cells[row, 4].Value = item.TruckType;
                worksheet.Cells[row, 5].Value = item.BSType;
                worksheet.Cells[row, 6].Value = item.BodyType;
                worksheet.Cells[row, 7].Value = item.TransmissionType;
                worksheet.Cells[row, 8].Value = item.FuelType;
                worksheet.Cells[row, 9].Value = item.FuelTankCapacity;
                worksheet.Cells[row, 10].Value = item.wheels;
                worksheet.Cells[row, 11].Value = item.ManufacturedYear;
                worksheet.Cells[row, 12].Value = item.PurchaseDate.Value.ToString("dd-MM-yyyy"); 
                worksheet.Cells[row, 13].Value = item.CurrentRegistration.EffectFrom.Value.ToString("dd-MM-yyyy");
                worksheet.Cells[row, 14].Value = item.CurrentRegistration.EffectTo.Value.ToString("dd-MM-yyyy");
                worksheet.Cells[row, 15].Value = item.EngineNumber;
                worksheet.Cells[row, 16].Value = item.ChassisNumber;
                worksheet.Cells[row, 17].Value = item.UnladenWeight;
                worksheet.Cells[row, 18].Value = item.GrossWeight;
                worksheet.Cells[row, 19].Value = item.CurrentEvent.EventTypeID == 13 ? "Non-Operating" : "Operating";

                if (!item.CurrentRegistration.IsValid)
                {
                    using (var range = worksheet.Cells[row, 1, row, 19])
                    {
                        range.Style.Fill.PatternType = ExcelFillStyle.Solid;
                        range.Style.Fill.BackgroundColor.SetColor(System.Drawing.Color.Red);
                    }
                }

                row++;
            }

            worksheet.Cells[worksheet.Dimension.Address].Style.Border.Top.Style = ExcelBorderStyle.Thin;
            worksheet.Cells[worksheet.Dimension.Address].Style.Border.Left.Style = ExcelBorderStyle.Thin;
            worksheet.Cells[worksheet.Dimension.Address].Style.Border.Right.Style = ExcelBorderStyle.Thin;
            worksheet.Cells[worksheet.Dimension.Address].Style.Border.Bottom.Style = ExcelBorderStyle.Thin;

            // Save the Excel package to a memory stream
            using (var stream = new MemoryStream())
            {
                package.SaveAs(stream);
                return stream.ToArray();
            }
        }
    }

    private async void TruckMountDetails(int? id)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        _busy = true;
        model = new();
        DialogOptions options = new DialogOptions()
            {
                MaxWidth = MaxWidth.Large,
            };
        if (id != null)
        {
            model = Iservice.SelectByID(id);
            model.CurrentRegistration = Iservice.GetRegistration(id);
        }
        DialogParameters parms = new();
        parms.Add("SelectedTruck", model.Clone());
        await DialogService.ShowAsync<MountTruckDetailsDialog>("ADD/EDIT", parms, options);
        await Task.Delay(200);
        _busy = false;
    }

    private async Task RegisterNumberList(TruckModel truck)
    {
        var truckIdstring = (truck?.TruckID ?? 0).ToString();
        UriHelper.NavigateTo($"TruckRegisterList/{truckIdstring}");
    }

    private async Task Edit(int? id)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        _busy = true;
        StateHasChanged();
        if (HasPermissionITruckServiceEdit)
        {
            model = new();
            DialogOptions options = new DialogOptions()
                {
                    MaxWidth = MaxWidth.Large,
                };
            if (id != null)
            {
                await Task.Run(() =>
                {
                    model = Iservice.SelectByID(id);
                    model.CurrentRegistration = Iservice.GetRegistration(id);
                });
            }
            DialogParameters parms = new();
            parms.Add("EditModel", model.Clone());
            var dialog = await DialogService.ShowAsync<Truckdilog>("Truck", parms, options);
            var result = await dialog.Result;
            if (!result.Canceled)
            {
                var data = (TruckModel)result.Data;
                if (data != null)
                {
                    if (id == null)
                    {
                        data.CurrentRegistration = Iservice.GetRegistration(data.TruckID);
                        collection.Add(data);
                    }
                    else
                    {
                        if (collection.Exists(x => x.TruckID == data.TruckID))
                        {
                            data.CurrentRegistration = Iservice.GetRegistration(data.TruckID);
                            collection[collection.FindIndex(x => x.TruckID == data.TruckID)] = data;
                        }
                    }
                }
            }
        }
        else
        {
            bool? ResultModel = await DialogService.ShowMessageBoxAsync(
                "Permission denied!",
                "You don't have any permission to Add or Edit Truck.");
        }
        await Task.Delay(200);
        _busy = false;
    }

    private async Task Delete(TruckModel model)
    {
        if (model.HomeBranchID != BranchID)
        {
            snackbar.Add("You don't have any permission to Delete Truck.", Severity.Warning);
            return;
        }

        if (HasPermissionITruckServiceDelete)
        {
            bool? result = await DialogService.ShowMessageBoxAsync(
                "Warning !",
                "Are you sure, you want to delete Truck : " + model.RegNo + " ?");
            if (result == true)
            {
                var authprov = await auth.GetAuthenticationStateAsync();
                var user = authprov.User;
                Iservice.Delete(model.TruckID, user.Identity.Name);
                snackbar.Add("Deleted Successfully", Severity.Error);
            }
            GetAll();
        }
        else
        {
            bool? result = await DialogService.ShowMessageBoxAsync(
                "Permission denied!",
                "You don't have any permission to Delete Truck.");
        }
    }

    private bool search(TruckModel Truck)
    {
        if (Truck?.RegNo != null && Truck.RegNo.Contains(searchTruck, StringComparison.OrdinalIgnoreCase))
        {
            return true;
        }
        else if (Truck.RegNo == null) return true;
        return false;
    }

    private async Task AssignDriver(TruckModel truck)
    {
        int? DriverID = Iservice.GetAssignedDriver(truck.TruckID);
        AssignedDriver = DriverID == null ? null : Idriver.SelectByID(DriverID.Value);
        AssignDriverLabel = AssignedDriver == null ? "Assign Driver" : "Replace Driver";

        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        _busy = true;
        var parameters = new DialogParameters();
        parameters.Add("Truck", truck);
        parameters.Add("AssignedDriver", AssignedDriver);
        var result = await DialogService.ShowAsync<AssignDriverView>(AssignDriverLabel, parameters);
        var Data = await result.Result;
        var ev = Data.Data;
        if (!Data.Canceled)
        {
            AssignedDriver = (DriverModel)ev;
            AssignDriverLabel = AssignedDriver == null ? "Assign Driver" : "Replace Driver";
        }
        await Task.Delay(200);
        _busy = false;
    }

    private async Task Move(byte? eventTypeId, TruckModel model)
    {
        if (HasPermissionIEventServiceMove)
        {
            string eventName = eventTypeId == 6 ? "UnAssigned" : "Non-Operating";

            bool? result = await DialogService.ShowMessageBoxAsync(
                "Warning!",
                $"Are you sure, you want to move {model.RegNo} Truck to {eventName} event?");
            if (result == true)
            {
                var authprov = await auth.GetAuthenticationStateAsync();
                var user = authprov.User;
                Ievent.MoveToNonOperating(eventTypeId, model.TruckID, user.Identity.Name);
                snackbar.Add("Moved Successfully", Severity.Success);
            }
            GetAll();
        }
        else
        {
            bool? result = await DialogService.ShowMessageBoxAsync(
                "Permission denied!",
                "You don't have any permission to Move Truck.");
        }
    }
}

