@page "/truckadd"
@using System.Threading;
@using System.Globalization
@attribute [Authorize]
@inject AuthenticationStateProvider auth
@inject TruckDataArrayModel data
@inject IConfigTable config
@inject ITruckService Iservice
@inject ITruckTypeService Itrucktype
@inject IBranchService Ibranch
@inject MudBlazor.ISnackbar snackbar
@inject IAssetService Iasset
@inject IRoleService<RoleModel> Irole
@inject IDialogService DialogService

<DialogForm @ref="@dialogForm" Title="Vehicle Master Registry" Subtitle="Maintain technical specifications, fleet identity, and branch ownership for operational assets." Icon="@Icons.Material.Filled.LocalShipping" AdminStyle="true" formID="truckForm" model="@EditModel" _busy="_busy">
    <FormContent>
        <div class="dialog-content-wrapper pa-2" style="max-height:600px;overflow-y:auto">
            @if (_loading)
            {
                <div class="pa-12 d-flex justify-center">
                    <LoaderComponent IsFullScreen="false" ShowLogo="false" Size="medium" LoadingText="Preparing technical specifications..."/>
                </div>
            }
            else
            {
                <EditForm id="truckForm" Model="@EditModel" OnValidSubmit="OnValidSubmit">
                    <div class="admin-glass-card pa-6">
                        <div class="d-flex align-center mb-6">
                            <MudIcon Icon="@Icons.Material.Filled.Assignment" Color="Color.Primary" Class="mr-2" />
                            <span class="admin-section-label mb-0">Identity & Registration</span>
                        </div>
                        <ObjectGraphDataAnnotationsValidator />
                        <MudValidationSummary />
                        <MudGrid Spacing="3">
                            <MudItem xs="12" md="6">
                                <MudTextField @bind-Value="EditModel.CurrentRegistration.RegNo" Class="ToUpperCase modern-input" Margin="Margin.Normal" Label="Registry Number" Variant="Variant.Outlined" For="@(() => EditModel.CurrentRegistration.RegNo)" Disabled=@(EditModel.TruckID == null?false:true) Required Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Pin"></MudTextField>
                             </MudItem>
                             <MudItem xs="12" md="6">
                                 <MudSelect ReadOnly Disabled Variant="Variant.Outlined" Label="Fleet Command Branch" @bind-Value="EditModel.HomeBranchID" Margin="Margin.Normal" AdornmentColor="Color.Primary" Class="modern-input">
                                     @foreach (var item in Branches)
                                    {
                                        <MudSelectItem Value="@item.BranchID">@item.BranchName</MudSelectItem>
                                    }
                                </MudSelect>
                            </MudItem>
                            <MudItem xs="12" md="6">
                                <MudDatePicker Margin="Margin.Normal" Variant="Variant.Outlined" Label="Effective From" DisableToolbar="true" Editable="true" @bind-Date="EditModel.CurrentRegistration.EffectFrom" Culture="@CultureInfo.GetCultureInfo("en-IN")" Disabled=@(EditModel.TruckID == null?false:true) Required Class="modern-input" />
                             </MudItem>
                             <MudItem xs="12" md="6">
                                 <MudDatePicker Margin="Margin.Normal" Variant="Variant.Outlined" Label="Valid Until" DisableToolbar="true" Editable="true" @bind-Date="EditModel.CurrentRegistration.EffectTo" Culture="@CultureInfo.GetCultureInfo("en-IN")" Disabled=@(EditModel.TruckID == null?false:true) Required Class="modern-input" />
                             </MudItem>
                        </MudGrid>
                    </div>

                    <div class="admin-glass-card pa-6 mt-6">
                        <div class="d-flex align-center mb-6">
                            <MudIcon Icon="@Icons.Material.Filled.Settings" Color="Color.Primary" Class="mr-2" />
                            <span class="admin-section-label mb-0">Technical Classifications</span>
                        </div>
                        <MudGrid Spacing="3">
                             <MudItem xs="12" md="6">
                                 <MudSelect Margin="Margin.Normal" Variant="Variant.Outlined" Label="Vehicle Category" @bind-Value="EditModel.TruckTypeID" Class="modern-input">
                                     @foreach (var item in TruckTypes)
                                    {
                                        <MudSelectItem Value="@item.TruckTypeID">@item.TruckType (@item.BSType)</MudSelectItem>
                                    }
                                </MudSelect>
                            </MudItem>
                            <MudItem xs="12" md="6">
                                <MudSelect Margin="Margin.Normal" Variant="Variant.Outlined" Label="Body Architecture" @bind-Value="EditModel.BodyType" Class="modern-input">
                                    @foreach (var item in data.BodyTypes)
                                    {
                                        <MudSelectItem Value="@item">@item</MudSelectItem>
                                    }
                                </MudSelect>
                            </MudItem>
                            <MudItem xs="12" md="6">
                                <MudTextField @bind-Value="EditModel.EngineNumber" Label="Powerplant ID (Engine)" Variant="Variant.Outlined" Margin="Margin.Normal" For="@(() => EditModel.EngineNumber)" Class="modern-input"></MudTextField>
                            </MudItem>
                            <MudItem xs="12" md="6">
                                <MudTextField @bind-Value="EditModel.ChassisNumber" Label="Structural ID (Chassis)" Variant="Variant.Outlined" Margin="Margin.Normal" For="@(() => EditModel.ChassisNumber)" Class="modern-input"></MudTextField>
                            </MudItem>
                            <MudItem xs="12" md="6">
                                <MudSelect Margin="Margin.Normal" Label="Energy Source" @bind-Value="EditModel.FuelType" Variant="Variant.Outlined" Class="modern-input">
                                    @foreach (var item in data.FuelTypes)
                                    {
                                        <MudSelectItem Value="@item">@item</MudSelectItem>
                                    }
                                </MudSelect>
                            </MudItem>
                            <MudItem xs="12" md="6">
                                <MudNumericField HideSpinButtons @bind-Value="EditModel.FuelTankCapacity" Label="Fuel Capacity (Ltrs)" Variant="Variant.Outlined" Margin="Margin.Normal" For="@(() => EditModel.FuelTankCapacity)" Class="modern-input"></MudNumericField>
                            </MudItem>
    
                            <MudItem xs="12" md="4">
                                <MudDatePicker Margin="Margin.Normal" Variant="Variant.Outlined" Label="Acquisition Date" DisableToolbar="true" Editable="true" @bind-Date="EditModel.PurchaseDate" DateFormat="dd/MM/yyyy" Class="modern-input" />
                            </MudItem>
                            <MudItem xs="12" md="4">
                                <MudTextField @bind-Value="EditModel.ManufacturedYear" Label="Production Year" Variant="Variant.Outlined" Margin="Margin.Normal" For="@(() => EditModel.ManufacturedYear)" Class="modern-input"></MudTextField>
                            </MudItem>
                            <MudItem xs="12" md="4">
                                <MudSelect Margin="Margin.Normal" Variant="Variant.Outlined" Label="Transmission" @bind-Value="EditModel.TransmissionType" Class="modern-input">
                                    @foreach (var item in data.TransmissionTypes)
                                    {
                                        <MudSelectItem Value="@item">@item</MudSelectItem>
                                    }
                                </MudSelect>
                            </MudItem>
                            <MudItem xs="12" md="6">
                                <AssetSelector Class="modern-input" Label="Linked Physical Asset" Value="SelectedAsset" PassedListAssets="PassedListAssets" ValueChanged="AssetSelected" BranchID="EditModel.HomeBranchID??0" SubClassID="AssetSubClassID" ClearOnSelect="true">
                                </AssetSelector>
                            </MudItem>
                            <MudItem xs="12" md="3">
                                <MudNumericField HideSpinButtons @bind-Value="@EditModel.UnladenWeight" Label="Kerb Weight (kg)" Variant="Variant.Outlined" Margin="Margin.Normal" For="@(() => EditModel.UnladenWeight)" Class="modern-input"></MudNumericField>
                            </MudItem>
                            <MudItem xs="12" md="3">
                                <MudNumericField HideSpinButtons @bind-Value="@EditModel.GrossWeight" Label="GVW (kg)" Variant="Variant.Outlined" Margin="Margin.Normal" For="@(() => EditModel.GrossWeight)" Class="modern-input"></MudNumericField>
                            </MudItem>
                        </MudGrid>
                    </div>
                </EditForm>
            }
        </div>
    </FormContent>
    <Actions>
        <div class="d-flex pa-4 gap-4 w-100 justify-end align-center">
            <MudButton Variant="Variant.Text" OnClick="Cancel">Discard</MudButton>
            <MudButton Size="Size.Large" Disabled="@_busy" form="truckForm" Variant="Variant.Filled" Color="Color.Primary" ButtonType="ButtonType.Submit" Class="action-btn-primary px-10" Style="background: #367588 !important; color: white !important;">
                Save Vehicle Specs
            </MudButton>
        </div>
    </Actions>
</DialogForm>

@code {

    private DialogForm dialogForm;
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; }
    [Parameter]
    public TruckModel EditModel { get; set; } = new();
    private List<TruckTypeModel> TruckTypes = new List<TruckTypeModel>();
    private List<BranchModel> Branches = new List<BranchModel>();
    public AssetModel SelectedAsset { get; set; } = new();
    int? AssetSubClassID;
    int BranchID;
    string UserID;
    public List<AssetModel> PassedListAssets = new();
    private bool _busy;
    private bool _loading = true;

    public bool HasPermissionITruckServiceEdit { get; set; } = false;
    public int DocTypeID = 37;

    protected override async Task OnInitializedAsync()
    {
        _loading = true;
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionITruckServiceEdit = await Irole.HasClaim(DocTypeID.ToString(), "Edit", ctc.Token);

        var authprov = await auth.GetAuthenticationStateAsync();
        var User = authprov.User;
        UserID = User.Identity.Name;
        BranchID = int.Parse(User.Claims.First(x => x.Type == "BranchID").Value);
        if (EditModel.HomeBranchID == null)
        {
            EditModel.HomeBranchID = BranchID;
        }

        await Task.Run(() => {
            ConfigModel cModel = config.GetAssetSubclassForTrucks();
            AssetSubClassID = int.Parse(cModel.ValueString);
            TruckTypes = Itrucktype.Select(0).ToList();
            Branches = Ibranch.Select().ToList();
            if ((EditModel.AssetID ?? 0) != 0)
            {
                SelectedAsset = Iasset.SelectByID(EditModel.AssetID);
            }
            else
            {
                SelectedAsset = null;
            }
            int selectesAssetId = SelectedAsset?.AssetID ?? 0;
            PassedListAssets = Iasset.SelectLinkedAssetsOnTruck().Where(s => s.AssetID != selectesAssetId).ToList();
        });

        _loading = false;
    }

    private void AssetSelected(AssetModel asset)
    {
        SelectedAsset = asset;
        EditModel.AssetID = asset?.AssetID;
    }

    private async void OnValidSubmit(EditContext context)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is being submitted!", Severity.Warning);
            return;
        }

        if (EditModel.HomeBranchID != BranchID)
        {
            snackbar.Add("You don't have any permission to Add or Edit Truck.", Severity.Warning);
            return;
        }

        if (HasPermissionITruckServiceEdit)
        {
            var authprov = await auth.GetAuthenticationStateAsync();
            var user = authprov.User;
            EditModel.UserInfo.UserID = user.Identity.Name;
            if (SelectedAsset == null || SelectedAsset.AssetID == 0)
            {
                snackbar.Add("Please select Link Asset.", Severity.Error);
                return;
            }
            _busy = true;
            EditModel.AssetID = SelectedAsset.AssetID;
            try
            {
                EditModel = Iservice.Update(EditModel);
                snackbar.Add("Saved Successfully", Severity.Success);
                dialogForm.Close(EditModel);
                EditModel = new TruckModel();
            }
            catch (Exception ex)
            {
                snackbar.Add(ex.Message, Severity.Warning);
            }
            await Task.Delay(200);
            _busy = false;
        }
        else
        {
            bool? result = await DialogService.ShowMessageBoxAsync(
                "Permission denied!",
                "You don't have any permission to Add or Edit Truck.");
        }
    }

    void Cancel()
    {
        EditModel = new();
        dialogForm.Cancel();
    }
}
