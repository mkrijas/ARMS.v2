@using Views.Pages.Operations.Gc
@attribute [Authorize]
@inject AuthenticationStateProvider auth
@inject NavigationManager UriHelper
@inject IDialogService DialogService
@inject IGcService Iservice
@inject MudBlazor.ISnackbar snackbar

<DialogForm @ref="@dialogForm" Title="Unload Quantity" Subtitle="Record the final quantities for consignments during the unloading process." Icon="@Icons.Material.Filled.Inventory" AdminStyle="true" formID="unloadForm" model="@GcsToUnload" SubmitText="Update Quantity" _busy="_busy">
    <FormContent>
       @*  <div class="dialog-content-wrapper pa-4"> *@
            <EditForm id="unloadForm" Model="@GcsToUnload" OnValidSubmit="UpdateQuantity">
            @* <div class="admin-glass-card pa-6"> *@
                <MudGrid Spacing="4">
                    @foreach (var item in GcsToUnload)
                    {
                        <MudItem xs="12">
                            <div class="pa-4 rounded-lg" style="background: rgba(54, 117, 136, 0.05); border-left: 4px solid #367588;">
                                <GcItemCard item="item" unloading=true></GcItemCard>
                            </div>
                        </MudItem>
                    }
                </MudGrid>
            @* </div> *@
            </EditForm>
        @* </div> *@
    </FormContent>
</DialogForm>

@code {

    [Parameter]
    public List<GcSetModel> GcsToUnload { get; set; }
    DialogForm dialogForm;
    private bool _busy;

    protected override void OnInitialized()
    {

    }

    public async Task UpdateQuantity(EditContext context = null)
    {      

        if (_busy)
        {
            snackbar.Add("Please wait while form is being submitted!", Severity.Warning);
            return;
        }
        _busy = true;

        if (GcsToUnload.Any(x => x.TotalUnloadingQuantity == null))
        {
            snackbar.Add("Unload Quantity not entrered", Severity.Error);
            return;
        }

        dialogForm.Close(GcsToUnload);
        await Task.Delay(200);
        _busy = false;
    }
}
