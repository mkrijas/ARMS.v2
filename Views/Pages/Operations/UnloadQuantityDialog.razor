@using Views.Pages.Operations.Gc
@attribute [Authorize]
@inject AuthenticationStateProvider auth
@inject NavigationManager UriHelper
@inject IDialogService DialogService
@inject IGcService Iservice
@inject MudBlazor.ISnackbar snackbar

<MudDialog>
    <DialogContent>
        <MudGrid Spacing="4">
            @foreach (var item in collection1)
            {
                <MudItem xs="12" md="12" xl="12">
                    <GcItemCard item="item" unloading=true></GcItemCard>
                </MudItem>
            }
        </MudGrid>
    </DialogContent>
    <DialogActions>
        <MudButton Disabled="@_busy" @onclick="UpdateQuantity" Color="Color.Success">Update Quantity</MudButton>
    </DialogActions>
</MudDialog>

@code {

    [Parameter]
    public long TripID { get; set; }
    private List<GcSetModel> collection1 = new();
    [CascadingParameter] MudDialogInstance MudDialog { get; set; }
    private bool _busy;

    protected override void OnInitialized()
    {
        List<GcSetModel> collection = new();
        collection = Iservice.SelectedUnloadEvent(TripID);
        foreach (var item in collection)
        {
            if (item.TotalUnloadingQuantity == null)
            {
                item.TotalUnloadingQuantity = item.TotalBillQuantity;
            }
            collection1.Add(item);
        }
    }

    public async void UpdateQuantity()
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is being submitted!", Severity.Warning);
            return;
        }
        _busy = true;
        MudDialog.Close(collection1);
        await Task.Delay(2000);
        _busy = false;
    }
}