@using Views.Pages.Operations.Gc
@attribute [Authorize]
@inject AuthenticationStateProvider auth
@inject NavigationManager UriHelper
@inject IDialogService DialogService
@inject IGcService Iservice
@inject MudBlazor.ISnackbar snackbar

<DialogForm @ref="@dialogForm" Title="Unload Quantity" Subtitle="Record the final quantities for consignments during the unloading process." Icon="@Icons.Material.Filled.Inventory" AdminStyle="true" model="@GcsToUnload" _busy="_busy">
    <FormContent>
        <div class="dialog-content-wrapper pa-4">
            <div class="admin-glass-card pa-6">
                <MudGrid Spacing="4">
                    @foreach (var item in GcsToUnload)
                    {
                        <MudItem xs="12">
                            <div class="glass-inner-panel pa-2 rounded-lg">
                                <GcItemCard item="item" unloading=true></GcItemCard>
                            </div>
                        </MudItem>
                    }
                </MudGrid>
            </div>
        </div>
    </FormContent>
    <Actions>
        <MudButton Disabled="@_busy" @onclick="UpdateQuantity" Variant="Variant.Filled" Color="Color.Success" StartIcon="@Icons.Material.Filled.Save">Update Quantity</MudButton>
    </Actions>
</DialogForm>

@code {

    [Parameter]
    public List<GcSetModel> GcsToUnload { get; set; }
    DialogForm dialogForm;
    private bool _busy;

    protected override void OnInitialized()
    {

    }

    public async void UpdateQuantity()
    {      

        if (_busy)
        {
            snackbar.Add("Please wait while form is being submitted!", Severity.Warning);
            return;
        }
        _busy = true;

        if (GcsToUnload.Any(x => x.TotalUnloadingQuantity == null))
        {
            snackbar.Add("Unload Quantity not entrered", Severity.Error);
            return;
        }

        dialogForm.Close(GcsToUnload);
        await Task.Delay(200);
        _busy = false;
    }
}
