@using Views.Pages.Operations.Gc
@attribute [Authorize]
@inject AuthenticationStateProvider auth
@inject NavigationManager UriHelper
@inject IDialogService DialogService
@inject IGcService Iservice
@inject MudBlazor.ISnackbar snackbar

<MudDialog Class="admin-dialog-glass">
    <TitleContent>
        <div class="header-section mb-2 pt-4 px-4">
            <div class="d-flex align-center justify-space-between">
                <div class="d-flex align-center">
                    <div class="icon-badge primary-badge mr-4">
                        <div class="admin-header-icon-badge mb-3">
                            <MudIcon Icon="@Icons.Material.Filled.Inventory" Color="Color.Secondary" Style="font-size: 3rem;" />
                        </div>
                    </div>
                    <div>
                        <MudText Typo="Typo.h5" Class="admin-title"><b>Unload Quantity Verification</b></MudText>
                        <MudText Typo="Typo.body2" Class="admin-subtitle">
                            Record the final quantities for consignments during the unloading process.
                        </MudText>
                    </div>
                </div>
            </div>
            <div class="title-accent mt-4"></div>
        </div>
    </TitleContent>
    <DialogContent>
        <MudContainer Class="admin-dialog-container">
            <div class="dialog-content-wrapper pa-4">
                <EditForm id="unloadForm" Model="@GcsToUnload" OnValidSubmit="UpdateQuantity">
                    <MudGrid Spacing="4">
                        @foreach (var item in GcsToUnload)
                        {
                            <MudItem xs="12">
                                <div class="pa-4 rounded-lg" style="background: rgba(54, 117, 136, 0.05); border-left: 4px solid #367588;">
                                    <GcItemCard item="item" unloading=true></GcItemCard>
                                </div>
                            </MudItem>
                        }
                    </MudGrid>
                </EditForm>
            </div>
        </MudContainer>
    </DialogContent>
    <DialogActions>
        <div class="d-flex w-100 flex-wrap pa-4 gap-3 align-center">
            <MudSpacer />
            <MudButton @onclick="Cancel" Variant="Variant.Outlined" Color="Color.Default" Style="border-radius: 12px; font-weight: 700; text-transform: none; border-color: rgba(0,0,0,0.15);">Discard</MudButton>
            <MudButton Disabled="@_busy" form="unloadForm" Variant="Variant.Filled" ButtonType="ButtonType.Submit" Color="Color.Success" Style="background: var(--mud-palette-success); color: white; font-weight: 800; border-radius: 12px; text-transform: none; white-space: nowrap; padding: 8px 24px;" StartIcon="@Icons.Material.Filled.DoneAll">Update Quantity</MudButton>
        </div>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; }

    [Parameter]
    public List<GcSetModel> GcsToUnload { get; set; }
    private bool _busy;

    private void Cancel() => MudDialog.Cancel();

    protected override void OnInitialized()
    {

    }

    public async Task UpdateQuantity(EditContext context = null)
    {      

        if (_busy)
        {
            snackbar.Add("Please wait while form is being submitted!", Severity.Warning);
            return;
        }
        _busy = true;

        if (GcsToUnload.Any(x => x.TotalUnloadingQuantity == null))
        {
            snackbar.Add("Unload Quantity not entrered", Severity.Error);
            return;
        }

        MudDialog.Close(DialogResult.Ok(GcsToUnload));
        await Task.Delay(200);
        _busy = false;
    }
}
