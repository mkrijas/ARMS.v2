@using Views.Pages.Operations.Gc
@attribute [Authorize]
@inject AuthenticationStateProvider auth
@inject NavigationManager UriHelper
@inject IDialogService DialogService
@inject IGcService Iservice
@inject MudBlazor.ISnackbar snackbar

<MudDialog>
    <DialogContent>
        <MudGrid Spacing="4">
            @foreach (var item in GcsToUnload)
            {
                <MudItem xs="12" md="6">
                    <GcItemCard item="item" unloading=true></GcItemCard>
                </MudItem>
            }
        </MudGrid>
    </DialogContent>
    <DialogActions>
        <MudButton Disabled="@_busy" @onclick="UpdateQuantity" Color="Color.Success">Update Quantity</MudButton>
    </DialogActions>
</MudDialog>

@code {

    [Parameter]
    public List<GcSetModel> GcsToUnload { get; set; }
    [CascadingParameter] MudDialogInstance MudDialog { get; set; }
    private bool _busy;

    protected override void OnInitialized()
    {

    }

    public async void UpdateQuantity()
    {      

        if (_busy)
        {
            snackbar.Add("Please wait while form is being submitted!", Severity.Warning);
            return;
        }
        _busy = true;

        if (GcsToUnload.Any(x => x.SetUnloadQuantity == null))
        {
            snackbar.Add("Unload Quantity not entrered", Severity.Error);
            return;
        }

        MudDialog.Close(GcsToUnload);
        await Task.Delay(200);
        _busy = false;
    }
}