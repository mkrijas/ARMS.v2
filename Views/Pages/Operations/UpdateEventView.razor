    // {
    //     if (item != null && item.Gcs != null && item.Gcs.Any(s => s.EwayBill != null && s.EwayBill.ExpireOn != null && (s.EwayBill.ExpireOn - DateTime.Now).Value.TotalHours >= 4))
    //     {
