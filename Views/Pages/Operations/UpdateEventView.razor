@inject ITripService Iservice
@inject IPlaceService Iplace
@inject IEventService Ievent
@inject ITripService Itrip
@inject IGcService Igc
@inject IDriverService Idriver


@inject MudBlazor.ISnackbar snackbar
@attribute [Authorize]
@inject AuthenticationStateProvider auth



<MudDialog>
    <DialogContent>
        @if (IsLoading)
        {
            <MudProgressCircular Color="Color.Primary" Style="height:70px;width:70px;" Indeterminate="true" />
        }
        else
        {
            <EditForm id="formEvent" Model="@model" OnValidSubmit="OnValidSubmit">
                <DataAnnotationsValidator />
                <ValidationSummary />
                <MudGrid Spacing="4">

                    <MudItem xs="12" md="12">
                        <MudText Class="subbutn"><MudIcon Icon="@Icons.Material.Filled.Transform" Title="Trip Number" /> @CurrentTrip.TripPrefix @CurrentTrip.TripNumber</MudText>
                    </MudItem>

                    <MudItem xs="12" md="12">
                        <MudText Class="subbutn"><MudIcon Icon="@Icons.Material.Filled.LocalShipping" Title="Truck" /> @Truck.RegNo</MudText>
                    </MudItem>

                    <MudItem xs="12" md="12">
                        @if (AssignedDriver == null)
                        {
                            <MudText Typo="Typo.h4" Color="Color.Warning"><MudIcon Icon="@Icons.Material.Filled.AirlineSeatReclineNormal" Title="Driver" /> UNASSAIGNED</MudText>
                        }
                        else
                        {
                            <MudText Typo="Typo.h4" Color="Color.Primary"><MudIcon Icon="@Icons.Material.Filled.AirlineSeatReclineNormal" Title="Driver" /> @AssignedDriver.DriverName</MudText>
                        }
                        <MudText></MudText>
                    </MudItem>

                    <MudItem xs="12" md="6">
                        <MudSelect Label="Select Action" T="byte?" Value="model.EventTypeID" OffsetY="true" Variant="Variant.Outlined" AdornmentColor="Color.Secondary" ValueChanged="EventSelected">
                            @foreach (var item in EventTypes)
                            {
                                <MudSelectItem T="byte?" Value="@item.EventTypeID">@item.EventTypeName</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>

                    <MudItem xs="12" md="6" >
                        <MudAutocomplete Variant="Variant.Outlined" T="PlaceModel" Label=@(SelectedEvent.IsStationary?"Place":"Origin") @bind-Value="Origin" ResetValueOnEmptyText="true" Clearable="true"
                                     SearchFunc="SearchPlaces" ToStringFunc="@(e => e == null ? null : $"{e.PlaceName}")" Disabled="true"></MudAutocomplete>
                    </MudItem>
                    <MudItem xs="12" md="6" hidden="@SelectedEvent.IsStationary">
                        <MudSelect Label="Select Destination Event" T="byte?" @bind-Value="model.DefaultNextEventTypeID" OffsetY="true" Variant="Variant.Outlined" AdornmentColor="Color.Secondary">
                            @foreach (var item in EventTypes)
                            {
                                <MudSelectItem T="byte?" Value="@item.EventTypeID">@item.EventTypeName</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>

                    <MudItem xs="12" md="6" hidden="@SelectedEvent.IsStationary">
                        <MudAutocomplete Variant="Variant.Outlined" T="PlaceModel" Label="Destination" @bind-Value="Destination" ResetValueOnEmptyText="true" Clearable="true"
                                     SearchFunc="SearchPlaces" ToStringFunc="@(e => e == null ? null : $"{e.PlaceName}")"></MudAutocomplete>
                    </MudItem>

                    <MudItem xs="12" md="6" hidden="@(SelectedEvent.EventTypeID != 4)">
                        <MudSelect Variant="Variant.Outlined" Label="Select GCs To Unload" MultiSelection="true" MultiSelectionTextFunc="@(new Func<List<string>, string>(GetMultiSelectionText))"
                               T="GcSetModel" OffsetY="true" AdornmentColor="Color.Secondary" @bind-SelectedValues="SelectedGCs">
                            @foreach (var item in GCsToUnload)
                            {
                                <MudSelectItem T="GcSetModel" Value="@item">@item.SetGcNumber</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>

                    <MudItem xs="12" md="6">
                        <MudTextField @bind-Value="model.EventReading" Label="Audometer Reading" Variant="Variant.Outlined"></MudTextField>
                    </MudItem>

                    <MudItem xs="12">
                        <MyDateTimePicker Label="Event" @bind-Value="model.EventTime"></MyDateTimePicker>
                    </MudItem>

                    <MudItem xs="12" md="6">
                        @*<input type="datetime-local" @bind-value="@model.EventTime"  />*@
                        <MudTextField Label="Date n Time" Format="s" Variant="Variant.Outlined" @bind-Value="@model.EventTime" InputType="InputType.DateTimeLocal"></MudTextField>
                        @*<MyDateTimePicker Label="Event" @bind-Value="model.EventTime"></MyDateTimePicker>*@
                    </MudItem>

                   

                </MudGrid>
            </EditForm>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton form="formEvent" Variant="Variant.Filled" Color="Color.Success" ButtonType="ButtonType.Submit">@ButtonLabel</MudButton>
    </DialogActions>
</MudDialog>

@code {

    [CascadingParameter] MudDialogInstance MudDialog { get; set; }

    [Parameter] public TruckModel Truck { get; set; }
    [Parameter] public DriverModel AssignedDriver { get; set; }
    [Parameter] public TripModel CurrentTrip { get; set; }
    [Parameter] public EventModel CurrentEvent { get; set; }

    [Parameter]
    public EventModel model { get; set; } = new();

    private bool IsLoading = false;
    private string ButtonLabel = "Select an Event";

    bool isSubmitting;

    private PlaceModel Origin = new();
    private PlaceModel Destination = new();
    private long? KmReading;

    private List<PlaceModel> places = new();
    private List<EventTypeModel> EventTypes;    
    private EventTypeModel SelectedEvent = new();

    private List<GcSetModel> GCsToUnload = new();
    private IEnumerable<GcSetModel> SelectedGCs = new HashSet<GcSetModel>();
    private void Cancel()
    {
        MudDialog.Cancel();
    }


    protected override async Task OnInitializedAsync()
    {        
        EventTypes = Ievent.GetEventTypes().Where(x => x.EventTypeID != 1 && x.IsTripRelated).ToList();
        places = Iplace.Select(0).ToList();
        int? OriginID = null, DestinationID = null;

        if (model.TruckEventID == null)
        {
            KmReading = CurrentEvent?.EventReading;
            OriginID = CurrentEvent?.DestinationID;
            model.DriverID = AssignedDriver?.DriverID;
            model.TripID = CurrentTrip.TripID;
            model.TruckID = Truck.TruckID;

        }
        else
        {
            OriginID = model.OriginID;
            DestinationID = model.DestinationID;
            SelectedEvent = Ievent.GetEventType(model.EventTypeID);
            AssignedDriver = Idriver.SelectByID(model.DriverID);
        }

        Origin = OriginID == null ? null : await Iplace.SelectByID(OriginID.Value);
        Destination = DestinationID == null ? null : await Iplace.SelectByID(DestinationID.Value);
    }


    private async Task<IEnumerable<PlaceModel>> SearchPlaces(string searchString)
    {
        return await Task.FromResult(places.Where(x => x.PlaceName.Contains(searchString == null ? string.Empty : searchString, StringComparison.InvariantCultureIgnoreCase)));
    }

    private async Task OnValidSubmit(EditContext context)
    {

        List<GcSetModel> gcSetList =  Igc.SelectToUnload(model.TripID);
        if(gcSetList != null && gcSetList.Count() != 0)
        {
            if(gcSetList.Any())
            {
                 snackbar.Add("The trip is not unloaded", Severity.Warning);
                return;
            }
        }

        if (isSubmitting)
            return;

        isSubmitting = true;

        try
        {
            var authprov = await auth.GetAuthenticationStateAsync();
            int BranchID = 0;
            if (!int.TryParse(authprov.User.Claims.First(c => c.Type == "BranchID")?.Value, out BranchID))
            {
                snackbar.Add("Branch is Not Selected", Severity.Warning);
                return;
            }

            if (model.TruckEventID == null && SelectedEvent.IsDriverRequired == true && AssignedDriver == null)
            {
                snackbar.Add("Cannot start this event without Driver", Severity.Warning);
                return;
            }

            model.BranchID = BranchID;
            model.DestinationID = SelectedEvent.IsStationary ? Origin.PlaceID : Destination.PlaceID;
            model.OriginID = Origin.PlaceID;
            model.EventTypeID = SelectedEvent.EventTypeID;
            model.UserInfo.UserID = authprov.User.Identity.Name;

            if (!ValidateEvent(model))
            {
                return;
            }
            model = Ievent.Update(model);

            if (SelectedEvent.EventTypeID == 4)
            {
                if (!SelectedGCs.Any())
                {
                    snackbar.Add("No GCs selected to Unload!", Severity.Warning);
                    return;
                }
                else
                {
                    foreach (GcSetModel item in SelectedGCs)
                    {
                        Igc.BeginUnload(CurrentTrip.TripID, item.GcSetID);
                    }
                }
            }
            CurrentEvent = model;
            MudDialog.Close(DialogResult.Ok(model));
        }
        catch (Exception ex)
        {
            snackbar.Add(ex.Message, Severity.Warning);
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private bool ValidateEvent(EventModel ev)
    {
        EventModel preEvent = new();
        EventModel NextEvent = new();

        if (ev.TruckEventID == null)
        {
            preEvent = CurrentEvent;
            NextEvent = null;
        }
        else
        {
            preEvent = Ievent.GetPreviousEvent(ev.TruckEventID);
            NextEvent = Ievent.GetNextEvent(ev.TruckEventID);

        }

        if (preEvent != null && model.EventTime < preEvent.EventTime)
        {
            snackbar.Add("Event Time cannot be before preivious event", Severity.Error);
            return false;
        }
        else if (NextEvent != null && model.EventTime > NextEvent.EventTime)
        {
            snackbar.Add("Event Time cannot be before preivious event", Severity.Error);
            return false;
        }
        else
        if ((preEvent != null && preEvent.EventTypeID == SelectedEvent.EventTypeID) || (NextEvent != null && NextEvent.EventTypeID == SelectedEvent.EventTypeID))
        {
            snackbar.Add("Cannot enter an event twice in a row", Severity.Warning);
            return false;
        }
        return true;
    }

    private string GetMultiSelectionText(List<string> Gcs)
    {
        return $"{SelectedGCs.Count()}  Gc{(Gcs.Count > 1 ? "s" : "")} Selected ";
    }

    private void EventSelected(byte? e)
    {
        SelectedEvent = Ievent.GetEventType(e);
        model.EventTypeID = e;
        if (SelectedEvent.EventTypeName != null)
        {
            model.DefaultNextEventTypeID = EventTypes.FirstOrDefault(x => x.EventTypeID == e).DefaultNextEventTypeID;
            ButtonLabel = SelectedEvent.EventTypeName;
            if (SelectedEvent.EventTypeID == 4)
            {
                GCsToUnload = Igc.SelectToUnload(CurrentTrip.TripID).ToList();
            }
        }
        else
            ButtonLabel = "Select an Event";
    }
   

   
}
