@using System.Threading;
@attribute [Authorize]
@inject AuthenticationStateProvider auth
@inject SignalRService signalRService
@inject ITripService Iservice
@inject IPlaceService Iplace
@inject IEventService Ievent
@inject ITripService Itrip
@inject IGcService Igc
@inject IDriverService Idriver
@inject ITruckService Itruck
@inject IDialogService DialogService
@inject IBranchSettingsService branchSettingsService
@inject IConfigTable configTable;
@inject MudBlazor.ISnackbar snackbar
@inject IPushNotificationService IpushNotificationService
@inject IRoleService<RoleModel> Irole

<MudDialog>
    <DialogContent>
        @if (IsLoading)
        {
            <MudProgressCircular Color="Color.Primary" Style="height:70px;width:70px;" Indeterminate="true" />
        }
        else
        {
            <EditForm id="formEvent" Model="@model" OnValidSubmit="OnValidSubmit">
                <FluentValidationValidator />
                <DataAnnotationsValidator />
                <ValidationSummary />
                <MudGrid Spacing="4">
                    <MudItem xs="12" md="12">
                        <MudText Class="subbutn"><MudIcon Icon="@Icons.Material.Filled.Transform" Title="Trip Number" />@CurrentTrip.TripNumberDisplay</MudText>
                    </MudItem>
                    <MudItem xs="12" md="12">
                        <MudText Class="subbutn"><MudIcon Icon="@Icons.Material.Filled.LocalShipping" Title="Truck" /> @Truck.RegNo</MudText>
                    </MudItem>
                    <MudItem xs="12" md="12">
                        @if (AssignedDriver == null)
                        {
                            <MudText Typo="Typo.h4" Color="Color.Warning"><MudIcon Icon="@Icons.Material.Filled.AirlineSeatReclineNormal" Title="Driver" /> UNASSAIGNED</MudText>
                        }
                        else
                        {
                            <MudText Typo="Typo.h4" Color="Color.Primary"><MudIcon Icon="@Icons.Material.Filled.AirlineSeatReclineNormal" Title="Driver" /> @AssignedDriver.DriverName</MudText>
                        }
                        <MudText></MudText>
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudSelect Label="Select Action" T="byte?" Value="model.EventTypeID" OffsetY="true" Variant="Variant.Outlined" AdornmentColor="Color.Secondary" ValueChanged="EventSelected" Disabled="@(IsDisableSelectAction)">
                            @foreach (var item in EventTypes)
                            {
                                <MudSelectItem T="byte?" Value="@item.EventTypeID">@item.EventTypeName</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudAutocomplete Variant="Variant.Outlined" T="PlaceModel" Label=@(SelectedEvent.IsStationary?"Place":"Origin") Value="@OriginPlace" ValueChanged="@((e)=> {OriginPlace = e; model.OriginID = e.PlaceID;model.DestinationID = SelectedEvent.IsStationary ? model.OriginID : model.DestinationID;})" ResetValueOnEmptyText="true" Clearable="true"
                                         SearchFunc="SearchPlaces" ToStringFunc="@(e => e == null ? null : $"{e.PlaceName}")" Disabled="true"></MudAutocomplete>
                    </MudItem>
                    <MudItem xs="12" md="6" hidden="@SelectedEvent.IsStationary">
                        <MudSelect Label="Select Destination Event" T="byte?" @bind-Value="model.NextEventTypeID" OffsetY="true" Variant="Variant.Outlined" AdornmentColor="Color.Secondary">
                            @foreach (var item in DestinationEventTypes)
                            {
                                <MudSelectItem T="byte?" Value="@item.EventTypeID">@item.EventTypeName</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>

                    <MudItem xs="12" md="6" hidden="@SelectedEvent.IsStationary">
                        <MudAutocomplete Variant="Variant.Outlined" T="PlaceModel" Label="Destination" Value="Destination" ValueChanged="((e)=> {Destination =e ; model.DestinationID =e?.PlaceID??null;})" ResetValueOnEmptyText="true" Clearable="true"
                                         SearchFunc="SearchPlaces" ToStringFunc="@(e => e == null ? null : $"{e.PlaceName}")"></MudAutocomplete>
                    </MudItem>
                    <MudItem xs="12" md="6" hidden="@(SelectedEvent.EventTypeID != 4)">
                        <MudSelect Variant="Variant.Outlined" Label="Select GCs To Unload" MultiSelection="true" MultiSelectionTextFunc="@(new Func<List<string>, string>(GetMultiSelectionText))"
                                   T="GcSetModel" OffsetY="true" AdornmentColor="Color.Secondary" @bind-SelectedValues="SelectedGCs">
                            @foreach (var item in GCsToUnload)
                            {
                                <MudSelectItem T="GcSetModel" Value="@item">@item.SetGcNumber</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudNumericField HideSpinButtons @bind-Value="model.EventReading" Label="Audometer Reading" Variant="Variant.Outlined" HelperText="@PreEvent?.EventReading?.ToString()"></MudNumericField>
                         <ValidationMessage For="@(() => model.EventReading)" />
                     </MudItem>
                     <MudItem xs="12" md="6">
                        <MudTextField Label="Date n Time" Format="s" Variant="Variant.Outlined" @bind-Value="@model.EventTime" InputType="InputType.DateTimeLocal" Max="@DateTime.Now.ToString("yyyy-MM-ddTHH:mm")" Min="2024-04-01T00:00"></MudTextField>
                     </MudItem>
                 </MudGrid>
             </EditForm>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Disabled="@_busy" form="formEvent" Variant="Variant.Filled" Color="Color.Success" ButtonType="ButtonType.Submit">@ButtonLabel</MudButton>
    </DialogActions>
</MudDialog>

@code {

    [CascadingParameter] MudDialogInstance MudDialog { get; set; }
    [Parameter] public TruckModel Truck { get; set; }
    [Parameter] public DriverModel AssignedDriver { get; set; }
    [Parameter] public TripModel CurrentTrip { get; set; }
    [Parameter] public EventModel model { get; set; } = new();
    bool IsDisableSelectAction { get; set; } = false;
    private EventModel PreEvent { get; set; }
    EventTypeModel PreEventType;
    private bool IsLoading = false;
    private string ButtonLabel = "Select an Event";
    bool isSubmitting;
    private PlaceModel OriginPlace = new();
    private PlaceModel Destination = new();
    private List<PlaceModel> places = new();
    private List<EventTypeModel> EventTypes;
    private List<EventTypeModel> DestinationEventTypes;
    private EventTypeModel SelectedEvent = new();
    private List<GcSetModel> GCsToUnload = new();
    private IEnumerable<GcSetModel> SelectedGCs = new HashSet<GcSetModel>();
    private bool _busy;
    public bool HasPermissionEventServiceEdit { get; set; } = false;
    public int DocTypeID = 48;

    private void Cancel()
    {
        MudDialog.Cancel();
    }

    public string UserID { get; set; }
    public int BranchID { get; set; }

    #region SignaIR Notification
    private List<PushNotificationModel> currentNotificationMessages = new List<PushNotificationModel>();
    private PushNotificationModel notificationMessage = new PushNotificationModel();
    #endregion

    protected override async Task OnInitializedAsync()
    {
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionEventServiceEdit = await Irole.HasClaim(DocTypeID.ToString(), "Edit", ctc.Token);

        EventTypes = Ievent.GetEventTypes().Where(x => x.EventTypeID != 1 && x.IsTripRelated).ToList();
        places = Iplace.Select(0, null).ToList();
        PreEvent = model.TruckEventID == null ? Ievent.GetCurrentEvent(Truck.TruckID) : Ievent.GetPreviousEvent(model.TruckEventID);
        PreEventType = Ievent.GetEventType(PreEvent.EventTypeID);

        int? OriginID = null, DestinationID = null;
        DestinationEventTypes = EventTypes.ToList();
        if (Truck == null)
        {
            Truck = Itruck.SelectByID(CurrentTrip.TruckID);
        }
        AssignedDriver = AssignedDriver ?? Idriver.SelectByID(model.DriverID);
        if (model.TruckEventID == null)
        {
            if (PreEventType != null)
            {
                model.EventReading = PreEventType.IsStationary ? PreEvent.EventReading : null;
            }
            OriginID = model.OriginID ?? PreEvent?.DestinationID;
            model.DriverID = model.DriverID ?? AssignedDriver?.DriverID;
            model.TripID = model.TripID ?? CurrentTrip?.TripID;
            model.TruckID = model.TruckID ?? Truck.TruckID;
        }
        else
        {
            OriginID = model.OriginID;
            DestinationID = model.DestinationID;
            SelectedEvent = Ievent.GetEventType(model.EventTypeID);
        }
        var authprov = await auth.GetAuthenticationStateAsync();
        if (!int.TryParse(authprov.User.Claims.First(c => c.Type == "BranchID")?.Value, out int BranchID))
        {
            snackbar.Add("Branch is Not Selected", Severity.Warning);
            return;
        }
        model.BranchID = BranchID;
        model.UserInfo.UserID = authprov.User.Identity.Name;
        OriginPlace = OriginID == null ? null : await Iplace.SelectByID(OriginID.Value);
        model.OriginID = OriginID;
        model.DestinationID = DestinationID;
        Destination = DestinationID == null ? null : await Iplace.SelectByID(DestinationID.Value);
        if (model.TruckEventID == null)
        {
            if (Itrip.Select(model.TripID)?.UserInfo.RecordStatus == 4)
            {
                EventSelected(Convert.ToByte(configTable.GetCloseTripEventTypeID().ValueString));
                IsDisableSelectAction = true;
            }
            else if (PreEventType != null)
            {
                var limitPostEvent = PreEventType.LimitPostEvent;
                var postEvent = PreEventType.DefaultNextEventTypeID;

                if (limitPostEvent != null)
                {
                    IsDisableSelectAction = true;
                    EventSelected(limitPostEvent);
                }
                else if (postEvent != null)
                {
                    EventSelected(postEvent);
                }                
            }
        }
        var user = authprov.User;
        UserID = user.Identity.Name;
        BranchID = int.Parse(authprov.User.Claims.First(x => x.Type == "BranchID").Value);
        await signalRService.StartAsync();
    }

    protected override async Task OnParametersSetAsync()
    {

    }

    private async Task<IEnumerable<PlaceModel>> SearchPlaces(string searchString)
    {
        return await Task.FromResult(places.Where(x => x.PlaceName.Contains(searchString == null ? string.Empty : searchString, StringComparison.InvariantCultureIgnoreCase)));
    }

    private async Task OnValidSubmit(EditContext context)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        if (HasPermissionEventServiceEdit)
        {
            if (model.EventTime <= DateTime.Now)
            {
                List<GcSetModel> gcSetList = Igc.SelectToUnload(model.TripID);
                if (gcSetList != null && gcSetList.Count() != 0)
                {
                    if (gcSetList.Any() && model.EventTypeID == 6)
                    {
                        snackbar.Add("The trip is not unloaded", Severity.Warning);
                        return;
                    }
                }
                if (isSubmitting)
                    return;
                isSubmitting = true;
                _busy = true;
                try
                {
                    if (model.TruckEventID == null && SelectedEvent.IsDriverRequired == true && AssignedDriver == null)
                    {
                        snackbar.Add("Cannot start this event without Driver", Severity.Warning);
                        return;
                    }
                    model.EventTypeID = SelectedEvent.EventTypeID;
                    if (model.EventTypeID == 5 && model.TruckEventID == null)
                    {
                        List<GcSetModel> GcsToUnload = new();
                        GcsToUnload = Igc.SelectedUnloadEvent(model.TripID);
                        if (GcsToUnload.Count == 0)
                        {
                            snackbar.Add("No Consignment being Unloaded", Severity.Error);
                            return;
                        }

                        foreach (var item in GcsToUnload)
                        {
                            if (item.SetUnloadQuantity == null)
                            {
                                item.SetUnloadQuantity = item.TotalBillQuantity;
                            }
                        }

                        DialogParameters parms = new DialogParameters();
                        parms.Add("GcsToUnload", GcsToUnload);
                        var dialog = DialogService.Show<UnloadQuantityDialog>("Unloading Consignment", parms);
                        var result = await dialog.Result;
                        if (!result.Canceled)
                        {
                            List<GcSetModel> gcs = (List<GcSetModel>)result.Data;
                            foreach (var item in gcs)
                            {
                                Igc.UpdateUnloadingQuantity(item);
                            }
                        }
                        else
                        {
                            return;
                        }
                    }
                    if (model.EventTypeID == 6)
                    {
                        bool IsbranchSetting = branchSettingsService.IsEnabled(model.BranchID, 109);
                        if (IsbranchSetting)
                        {
                            DialogOptions DialogWidth = new DialogOptions() { MaxWidth = MaxWidth.Small, FullWidth = true };
                            var dialog = DialogService.Show<AcceptedKMDialog>("Update Accepted KM", DialogWidth);
                            var result = await dialog.Result;
                            if (!result.Canceled)
                            {
                                int AcceptedKM = (int)result.Data;
                                model.AcceptedKM = AcceptedKM;
                            }
                            else
                            {
                                return;
                            }
                        }
                    }
                    if (!ValidateEvent(model))
                    {
                        return;
                    }
                    if (SelectedEvent.EventTypeID == 4 && model.TruckEventID == null)
                    {
                        if (!SelectedGCs.Any())
                        {
                            snackbar.Add("No GCs selected to Unload!", Severity.Warning);
                            return;
                        }
                    }

                    model = Ievent.Update(model);

                    if (SelectedEvent.EventTypeID == 4)
                    {
                        foreach (GcSetModel item in SelectedGCs)
                        {
                            Igc.BeginUnload(CurrentTrip.TripID, item.GcSetID);                           
                        }
                    }
                    MudDialog.Close(DialogResult.Ok(model));
                }
                catch (Exception ex)
                {
                    snackbar.Add(ex.Message, Severity.Warning);
                }
                finally
                {
                    isSubmitting = false;
                    await Task.Delay(200);
                    _busy = false;
                }
            }
            else
            {
                snackbar.Add("EventDate cannot be a greater than today's date.", Severity.Warning);
            }
        }
        else
        {
            bool? ResultModel = await DialogService.ShowMessageBox(
                "Permission denied!",
                "You don't have any permission to Add or Edit Event.");
        }
    }


