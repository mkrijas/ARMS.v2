@attribute [Authorize]
@inject AuthenticationStateProvider auth
@inject SignalRService signalRService
@inject ITripService Iservice
@inject IPlaceService Iplace
@inject IEventService Ievent
@inject ITripService Itrip
@inject IGcService Igc
@inject IDriverService Idriver
@inject ITruckService Itruck
@inject IDialogService DialogService
@inject IBranchSettingsService branchSettingsService
@inject IConfigTable configTable
@inject MudBlazor.ISnackbar snackbar
@inject IPushNotificationService IpushNotificationService
@inject IRoleService<RoleModel> Irole

<MudDialog Class="admin-dialog-glass">
    <TitleContent>
        <div class="header-section mb-2 pt-4 px-4">
            <div class="d-flex align-center justify-space-between">
                <div class="d-flex align-center">
                    <div class="icon-badge primary-badge mr-4">
                        <div class="admin-header-icon-badge mb-3">
                            <MudIcon Icon="@Icons.Material.Filled.Timeline" Color="Color.Secondary" Style="font-size: 3rem;" />
                        </div>
                    </div>
                    <div>
                        <MudText Typo="Typo.h5" Class="admin-title"><b>Trip Event Management</b></MudText>
                        <MudText Typo="Typo.body2" Class="admin-subtitle">Track and update vehicle events throughout the logistics lifecycle.</MudText>
                    </div>
                </div>
            </div>
            <div class="title-accent mt-4"></div>
        </div>
    </TitleContent>
    <DialogContent>
        <MudContainer Class="admin-dialog-container">
            @if (IsLoading)
            {
                <div style="display: flex; justify-content: center; align-items: center; min-height: 400px;">
                    <LoaderComponent IsFullScreen="false" ShowLogo="false" Size="medium" LoadingText="Syncing Events..." SubText="Updating logistics trail" />
                </div>
            }
            else
            {
                <div class="dialog-content-wrapper pa-4">
                    <EditForm id="formEvent" Model="@model" OnValidSubmit="OnValidSubmit">
                        <FluentValidationValidator />
                        <DataAnnotationsValidator />
                        
                        <!-- Trip Context Header -->
                        <div class="admin-glass-card pa-6 mb-6" style="background: linear-gradient(135.47deg, rgba(54, 117, 136, 0.05) 0%, rgba(54, 117, 136, 0.02) 100%);">
                            <MudGrid Spacing="2">
                                <MudItem xs="12" md="4" Class="d-flex align-center">
                                    <div class="premium-icon-box mr-3">
                                        <MudIcon Icon="@Icons.Material.Filled.Transform" Size="Size.Small" />
                                    </div>
                                    <div>
                                        <MudText Typo="Typo.caption" Class="color-muted d-block uppercase ls-1">Trip Number</MudText>
                                        <MudText Typo="Typo.body1" Class="fw-bold">@CurrentTrip.TripNumberDisplay</MudText>
                                    </div>
                                </MudItem>
                                <MudItem xs="12" md="4" Class="d-flex align-center">
                                    <div class="premium-icon-box mr-3" style="background: rgba(255, 159, 67, 0.1); color: #ff9f43;">
                                        <MudIcon Icon="@Icons.Material.Filled.LocalShipping" Size="Size.Small" />
                                    </div>
                                    <div>
                                        <MudText Typo="Typo.caption" Class="color-muted d-block uppercase ls-1">Vehicle</MudText>
                                        <MudText Typo="Typo.body1" Class="fw-bold">@Truck.RegNo</MudText>
                                    </div>
                                </MudItem>
                                <MudItem xs="12" md="4" Class="d-flex align-center">
                                    <div class="premium-icon-box mr-3" style="background: rgba(40, 199, 111, 0.1); color: #28c76f;">
                                        <MudIcon Icon="@Icons.Material.Filled.AirlineSeatReclineNormal" Size="Size.Small" />
                                    </div>
                                    <div>
                                        <MudText Typo="Typo.caption" Class="color-muted d-block uppercase ls-1">Assigned Driver</MudText>
                                        @if (AssignedDriver == null)
                                        {
                                            <MudText Typo="Typo.body1" Color="Color.Warning" Class="fw-bold">UNASSIGNED</MudText>
                                        }
                                        else
                                        {
                                            <MudText Typo="Typo.body1" Color="Color.Primary" Class="fw-bold">@AssignedDriver.DriverName</MudText>
                                        }
                                    </div>
                                </MudItem>
                            </MudGrid>
                        </div>

                        <div class="admin-glass-card pa-6">
                            <div class="d-flex align-center mb-6">
                                <MudIcon Icon="@Icons.Material.Filled.EditLocationAlt" Color="Color.Primary" Class="mr-2" />
                                <span class="admin-section-label mb-0">Event Configuration</span>
                            </div>
                            
                            <MudGrid Spacing="3">
                                <MudItem xs="12" md="6">
                                    <MudSelect For="@(() => model.EventTypeID)" Label="Select Action" T="byte?" Value="model.EventTypeID" Variant="Variant.Outlined" Margin="Margin.Normal" ValueChanged="EventSelected" Disabled="@(IsDisableSelectAction)" Class="modern-input" Placeholder="Choose event type...">
                                        @foreach (var item in EventTypes)
                                        {
                                            <MudSelectItem T="byte?" Value="@item.EventTypeID">@item.EventTypeName</MudSelectItem>
                                        }
                                    </MudSelect>
                                </MudItem>
                                <MudItem xs="12" md="6">
                                    <MudAutocomplete Variant="Variant.Outlined" T="PlaceModel" Label="@(SelectedEvent.IsStationary ? "Point of Interest" : "Origin Branch")" Value="@OriginPlace" ValueChanged="@((e)=> {OriginPlace = e; model.OriginID = e.PlaceID;model.DestinationID = SelectedEvent.IsStationary ? model.OriginID : model.DestinationID;})" ResetValueOnEmptyText="true" Clearable="true" Margin="Margin.Normal"
                                                     SearchFunc="SearchPlaces" ToStringFunc="@(e => e?.PlaceName)" Disabled="true" MaxItems="50" Class="modern-input"></MudAutocomplete>
                                </MudItem>
                                
                                <MudItem xs="12" md="6" hidden="@SelectedEvent.IsStationary">
                                    <MudSelect For="@(() => model.NextEventTypeID)" Label="Predicted Progression" T="byte?" @bind-Value="model.NextEventTypeID" Variant="Variant.Outlined" Margin="Margin.Normal" Class="modern-input">
                                        @foreach (var item in DestinationEventTypes)
                                        {
                                            <MudSelectItem T="byte?" Value="@item.EventTypeID">@item.EventTypeName</MudSelectItem>
                                        }
                                    </MudSelect>
                                </MudItem>

                                <MudItem xs="12" md="6" hidden="@SelectedEvent.IsStationary">
                                    <MudAutocomplete Variant="Variant.Outlined" T="PlaceModel" Label="Destination Terminal" Value="Destination" ValueChanged="@((e)=> {Destination =e ; model.DestinationID =e?.PlaceID??null;})" ResetValueOnEmptyText="true" Clearable="true" Margin="Margin.Normal"
                                                     SearchFunc="SearchPlaces" ToStringFunc="@(e => e == null ? null : $"{e.PlaceName}")" MaxItems="50" Class="modern-input"></MudAutocomplete>
                                </MudItem>

                                <MudItem xs="12" md="6" hidden="@(SelectedEvent.EventTypeID != 4)">
                                    <MudSelect Variant="Variant.Outlined" Label="Select Consignments to Unload" MultiSelection="true" MultiSelectionTextFunc="GetMultiSelectionText" Margin="Margin.Normal"
                                               T="GcSetModel" @bind-SelectedValues="SelectedGCs" Class="modern-input">
                                        @foreach (var item in GCsToUnload)
                                        {
                                            <MudSelectItem T="GcSetModel" Value="@item">@item.SetGcNumber</MudSelectItem>
                                        }
                                    </MudSelect>
                                </MudItem>

                                <MudItem xs="12" md="6">
                                    <MudNumericField HideSpinButtons @bind-Value="model.EventReading" Label="Odometer Metric" Variant="Variant.Outlined" Margin="Margin.Normal" HelperText='@($"Previous: {PreEvent?.EventReading?.ToString() ?? "N/A"}")' Class="modern-input" Adornment="Adornment.End" AdornmentText="KM"></MudNumericField>
                                     <ValidationMessage For="@(() => model.EventReading)" />
                                 </MudItem>
                                 <MudItem xs="12" md="6">
                                    <MudTextField Label="Chronological Timestamp" Format="s" Variant="Variant.Outlined" Margin="Margin.Normal" @bind-Value="@model.EventTime" InputType="InputType.DateTimeLocal" Max='@DateTime.Now.ToString("yyyy-MM-ddTHH:mm")' Min="2024-04-01T00:00" Class="modern-input" Adornment="Adornment.End" AdornmentIcon="@Icons.Material.Filled.Event"></MudTextField>
                                 </MudItem>
                             </MudGrid>
                        </div>
                    </EditForm>
                </div>
            }
        </MudContainer>
    </DialogContent>
    <DialogActions>
        <div class="d-flex w-100 flex-wrap pa-4 gap-3 align-center">
            <MudSpacer />
            <MudButton @onclick="Cancel" Variant="Variant.Outlined" Color="Color.Default" Style="border-radius: 12px; font-weight: 700; text-transform: none; border-color: rgba(0,0,0,0.15);">Discard</MudButton>
            <MudButton Disabled="@_busy" form="formEvent" Variant="Variant.Filled" ButtonType="ButtonType.Submit" Color="Color.Success" Style="background: var(--mud-palette-success); color: white; font-weight: 800; border-radius: 12px; text-transform: none; white-space: nowrap; padding: 8px 24px;" StartIcon="@Icons.Material.Filled.DoneAll">Submit</MudButton>
        </div>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; }
    [Parameter] public TruckModel Truck { get; set; }
    [Parameter] public DriverModel AssignedDriver { get; set; }
    [Parameter] public TripModel CurrentTrip { get; set; }
    [Parameter] public EventModel model { get; set; } = new();

    bool IsDisableSelectAction { get; set; } = false;
    private EventModel PreEvent { get; set; }
    EventTypeModel PreEventType;
    private bool IsLoading = false;
    private string ButtonLabel = "Select an Event";
    bool isSubmitting;
    private PlaceModel OriginPlace = new();
    private PlaceModel Destination = new();
    private List<PlaceModel> places = new();
    private List<EventTypeModel> EventTypes = new();
    private List<EventTypeModel> DestinationEventTypes = new();
    private EventTypeModel SelectedEvent = new();
    private List<GcSetModel> GCsToUnload = new();
    private IReadOnlyCollection<GcSetModel> SelectedGCs = new HashSet<GcSetModel>();
    private bool _busy;
    public bool HasPermissionEventServiceEdit { get; set; } = false;
    public int DocTypeID = 48;

    private void Cancel()
    {
        MudDialog.Cancel();
    }

    public string UserID { get; set; }
    public int BranchID { get; set; }

    #region SignaIR Notification
    private List<PushNotificationModel> currentNotificationMessages = new List<PushNotificationModel>();
    private PushNotificationModel notificationMessage = new PushNotificationModel();
    #endregion

    protected override async Task OnInitializedAsync()
    {
        IsLoading = true;
        CancellationTokenSource ctc = new CancellationTokenSource();
        HasPermissionEventServiceEdit = await Irole.HasClaim(DocTypeID.ToString(), "Edit", ctc.Token);

        EventTypes = Ievent.GetEventTypes().Where(x => x.EventTypeID != 1 && x.IsTripRelated).ToList();
        places = Iplace.Select(0, null).ToList();
        PreEvent = model.TruckEventID == null ? Ievent.GetCurrentEvent(Truck.TruckID) : Ievent.GetPreviousEvent(model.TruckEventID);
        PreEventType = Ievent.GetEventType(PreEvent.EventTypeID);

        int? OriginID = null, DestinationID = null;
        DestinationEventTypes = EventTypes.ToList();
        if (Truck == null)
        {
            Truck = Itruck.SelectByID(CurrentTrip.TruckID);
        }
        AssignedDriver = AssignedDriver ?? Idriver.SelectByID(model.DriverID);
        if (model.TruckEventID == null)
        {
            if (PreEventType != null)
            {
                model.EventReading = PreEventType.IsStationary ? PreEvent.EventReading : null;
            }
            OriginID = model.OriginID ?? PreEvent?.DestinationID;
            model.DriverID = model.DriverID ?? AssignedDriver?.DriverID;
            model.TripID = model.TripID ?? CurrentTrip?.TripID;
            model.TruckID = model.TruckID ?? Truck.TruckID;
        }
        else
        {
            OriginID = model.OriginID;
            DestinationID = model.DestinationID;
            SelectedEvent = Ievent.GetEventType(model.EventTypeID);
        }
        var authprov = await auth.GetAuthenticationStateAsync();
        if (!int.TryParse(authprov.User.Claims.First(c => c.Type == "BranchID")?.Value, out int branchIdLocal))
        {
            snackbar.Add("Branch is Not Selected", Severity.Warning);
            return;
        }
        model.BranchID = branchIdLocal;
        model.UserInfo.UserID = authprov.User.Identity.Name;
        OriginPlace = OriginID == null ? null : await Iplace.SelectByID(OriginID.Value);
        model.OriginID = OriginID;
        model.DestinationID = DestinationID;
        Destination = DestinationID == null ? null : await Iplace.SelectByID(DestinationID.Value);
        if (model.TruckEventID == null)
        {
            if (Itrip.Select(model.TripID)?.UserInfo.RecordStatus == 4)
            {
                EventSelected(Convert.ToByte(configTable.GetCloseTripEventTypeID().ValueString));
                IsDisableSelectAction = true;
            }
            else if (PreEventType != null)
            {
                var limitPostEvent = PreEventType.LimitPostEvent;
                var postEvent = PreEventType.DefaultNextEventTypeID;

                if (limitPostEvent != null)
                {
                    IsDisableSelectAction = true;
                    EventSelected(limitPostEvent);
                }
                else if (postEvent != null)
                {
                    EventSelected(postEvent);
                }                
            }
        }
        var user = authprov.User;
        UserID = user.Identity.Name;
        BranchID = int.Parse(authprov.User.Claims.First(x => x.Type == "BranchID").Value);
        await signalRService.StartAsync();
        IsLoading = false;
    }

    protected override async Task OnParametersSetAsync()
    {

    }

    private async Task<IEnumerable<PlaceModel>> SearchPlaces(string searchString, CancellationToken token)
    {
        return await Task.FromResult(places.Where(x => x.PlaceName.Contains(searchString == null ? string.Empty : searchString, StringComparison.InvariantCultureIgnoreCase)));
    }

    private async Task OnValidSubmit(EditContext context)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        if (HasPermissionEventServiceEdit)
        {
            if (model.EventTime <= DateTime.Now)
            {
                List<GcSetModel> gcSetList = Igc.SelectToUnload(model.TripID);
                if (gcSetList != null && gcSetList.Count() != 0)
                {
                    if (gcSetList.Any() && model.EventTypeID == 6)
                    {
                        snackbar.Add("The trip is not unloaded", Severity.Warning);
                        return;
                    }
                }
                if (isSubmitting)
                    return;
                isSubmitting = true;
                _busy = true;
                try
                {
                    if (model.TruckEventID == null && SelectedEvent.IsDriverRequired == true && AssignedDriver == null)
                    {
                        snackbar.Add("Cannot start this event without Driver", Severity.Warning);
                        return;
                    }
                    model.EventTypeID = SelectedEvent.EventTypeID;
                    if (model.EventTypeID == 5 && model.TruckEventID == null)
                    {
                        List<GcSetModel> GcsToUnload = new();
                        GcsToUnload = Igc.SelectedUnloadEvent(model.TripID);
                        if (GcsToUnload.Count == 0)
                        {
                            snackbar.Add("No Consignment being Unloaded", Severity.Error);
                            return;
                        }

                        foreach (var item in GcsToUnload)
                        {
                            if (item.SetUnloadQuantity == null)
                            {
                                item.SetUnloadQuantity = item.TotalBillQuantity;
                            }
                        }

                        DialogParameters parms = new DialogParameters();
                        parms.Add("GcsToUnload", GcsToUnload);
                        var dialog = await DialogService.ShowAsync<UnloadQuantityDialog>("Unloading Consignment", parms);
                        var result = await dialog.Result;
                        if (!result.Canceled)
                        {
                            List<GcSetModel> gcs = (List<GcSetModel>)result.Data;
                            foreach (var item in gcs)
                            {
                                Igc.UpdateUnloadingQuantity(item);
                            }
                        }
                        else
                        {
                            return;
                        }
                    }
                    if (model.EventTypeID == 6)
                    {
                        bool IsbranchSetting = branchSettingsService.IsEnabled(model.BranchID, 109);
                        if (IsbranchSetting)
                        {
                            DialogOptions DialogWidth = new DialogOptions() { MaxWidth = MaxWidth.Small, FullWidth = true };
                            var dialog = await DialogService.ShowAsync<AcceptedKMDialog>("Update Accepted KM", DialogWidth);
                            var result = await dialog.Result;
                            if (!result.Canceled)
                            {
                                int AcceptedKM = (int)result.Data;
                                model.AcceptedKM = AcceptedKM;
                            }
                            else
                            {
                                return;
                            }
                        }

                        List<GcSetModel> tripgc = Igc.SelectByTrip(model.TripID);

                        if (tripgc.Count() == 0 && CurrentTrip.UserInfo.RecordStatus == 3)
                        {
                            snackbar.Add("Cannot close trip", Severity.Warning);
                            return;
                        }
                    }
                    if (!ValidateEvent(model))
                    {
                        return;
                    }
                    if (SelectedEvent.EventTypeID == 4 && model.TruckEventID == null)
                    {
                        if (!SelectedGCs.Any())
                        {
                            snackbar.Add("No GCs selected to Unload!", Severity.Warning);
                            return;
                        }
                    }

                    model = Ievent.Update(model);

                    if (SelectedEvent.EventTypeID == 4)
                    {
                        foreach (GcSetModel item in SelectedGCs)
                        {
                            Igc.BeginUnload(CurrentTrip.TripID, item.GcSetID);                           
                        }
                    }
                    MudDialog.Close(DialogResult.Ok(model));
                }
                catch (Exception ex)
                {
                    snackbar.Add(ex.Message, Severity.Warning);
                }
                finally
                {
                    isSubmitting = false;
                    await Task.Delay(200);
                    _busy = false;
                }
            }
            else
            {
                snackbar.Add("EventDate cannot be a greater than today's date.", Severity.Warning);
            }
        }
        else
        {
            bool? ResultModel = await DialogService.ShowMessageBoxAsync(
                "Permission denied!",
                "You don't have any permission to Add or Edit Event.");
        }
    }


