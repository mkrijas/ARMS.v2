  @inject IPlaceService Iservice
@inject IDistrictService Idistrict
@inject MudBlazor.ISnackbar snackbar
@inject AuthenticationStateProvider auth
@attribute [Authorize]
@inject IDialogService DialogService
<MudDialog >
 
    <DialogActions> 
<MudItem xs="12" md="4">
        <MudCard Elevation="10">
            <EditForm Model="@model" OnValidSubmit="OnValidSubmit">
                <DataAnnotationsValidator />
                <ValidationSummary/>
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6">Add/Edit Places</MudText>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent>
                    <MudTextField @bind-Value="@model.PlaceName" Label="Place" Variant="Variant.Outlined" Margin="Margin.Normal" For="@(() => model.PlaceName)"></MudTextField>
                    <MudTextField @bind-Value="@model.PinCode" Label="PinCode" Variant="Variant.Outlined" Margin="Margin.Normal" For="@(() => model.PinCode)"></MudTextField>
                    <MudAutocomplete T="DistrictModel" Label="District" @bind-Value="@model.District" ResetValueOnEmptyText="true"
                                     SearchFunc="@Search" ToStringFunc="@(e=> e==null?null : $"{e.DistrictName}")"
                                     Immediate="true"></MudAutocomplete>
                    <br />
                    <MudButton Variant="Variant.Filled" Color="Color.Success" ButtonType="ButtonType.Submit">Save Place</MudButton>

                </MudCardContent>
            </EditForm>
        </MudCard>
    </MudItem>
    </DialogActions>
    </MudDialog>
@code {
      private PlaceModel model = new PlaceModel();
    private List<PlaceModel> collection = new List<PlaceModel>();
    public List<DistrictModel> districts = new List<DistrictModel>();

    private string searchPlace = "";
     private async Task<IEnumerable<DistrictModel>> Search(string searchString)
    {
        return await Task.FromResult(districts.Where(x => x.DistrictName.Contains(searchString == null ? string.Empty : searchString, StringComparison.InvariantCultureIgnoreCase)));
    }

    private  void GetAll()
    {
        foreach (var place in Iservice.Select(0))
        {
            collection.Add(place);
        }
    }

    private async void OnValidSubmit(EditContext context)
    {
        if (!districts.Select(x => x.DistrictName).Contains(model.District.DistrictName))
        {
            snackbar.Add("Invalid District", Severity.Error);
            return;
        }

        //try
        //{
        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;
        model.UserInfo.UserID = user.Identity.Name;
        model.DistrictID = model.District.DistrictID;

        try {
            model = await Iservice.Update(model);

            if (collection.Exists(x => x.PlaceID == model.PlaceID))
            {
                collection[collection.FindIndex(x => x.PlaceID == model.PlaceID)] = model;
            }
            else
            {
                collection.Add(model);
            }
            model = new PlaceModel();
            snackbar.Add("Saved Successfully", Severity.Success);
            StateHasChanged();
        }
        catch (Exception ex)
        {
            snackbar.Add(ex.Message, Severity.Warning);
        }
    }



    private void Edit(int? id)
    {
        model = collection.FirstOrDefault(x => x.PlaceID == id);
    }
    private async void Delete(int? id)
    {
        await Iservice.Delete(id, "Rijas");
        snackbar.Add("Deleted Successfully", Severity.Success);
        GetAll();
    }

}
