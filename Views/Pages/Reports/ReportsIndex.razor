@page "/reports-index"
@layout Views.Shared.MainLayout
@inject NavigationManager nav

<MudContainer MaxWidth="MaxWidth.False" Class="mt-4">
    <MudText Typo="Typo.h5" Class="mb-4"><b>Reports Dashboard</b></MudText>

    <MudGrid>
        <!-- Operations Reports -->
        <MudItem xs="12" sm="6" md="4">
            <MudCard Elevation="4" Class="pa-4 h-100">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6" Color="Color.Primary">Operations</MudText>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent>
                    <MudList T="string" Clickable="true" Dense="true">
                         <MudListItem T="string" OnClick="@(() => nav.NavigateTo("/OperationSummaryReport"))" Icon="@Icons.Material.Filled.Assessment">Operation Summary</MudListItem>
                         <MudListItem T="string" OnClick="@(() => nav.NavigateTo("/DriverPerformanceReport"))" Icon="@Icons.Material.Filled.PermIdentity">Driver Performance</MudListItem>
                         <MudListItem T="string" OnClick="@(() => nav.NavigateTo("/TripEventsReport"))" Icon="@Icons.Material.Filled.Event">Trip Events</MudListItem>
                         <MudListItem T="string" OnClick="@(() => nav.NavigateTo("/ClosingReport"))" Icon="@Icons.Material.Filled.AssignmentTurnedIn">Closing Report</MudListItem>
                         <MudListItem T="string" OnClick="@(() => nav.NavigateTo("/DamageCompensationReport"))" Icon="@Icons.Material.Filled.ReportProblem">Damage Compensation</MudListItem>
                         <MudListItem T="string" OnClick="@(() => nav.NavigateTo("/FuelConsumptionReport"))" Icon="@Icons.Material.Filled.LocalGasStation">Fuel Consumption</MudListItem>
                         <MudListItem T="string" OnClick="@(() => nav.NavigateTo("/HaltingReport"))" Icon="@Icons.Material.Filled.Timer">Halting Report</MudListItem>
                         <MudListItem T="string" OnClick="@(() => nav.NavigateTo("/MileageReport"))" Icon="@Icons.Material.Filled.Speed">Mileage Report</MudListItem>
                         <MudListItem T="string" OnClick="@(() => nav.NavigateTo("/DocumentExpiryReport"))" Icon="@Icons.Material.Filled.Folder">Document Expiry</MudListItem>
                         <MudListItem T="string" OnClick="@(() => nav.NavigateTo("/ROIReport"))" Icon="@Icons.Material.Filled.AttachMoney">ROI Report</MudListItem>
                         <MudListItem T="string" OnClick="@(() => nav.NavigateTo("/UnsettledTripAdvanceReport"))" Icon="@Icons.Material.Filled.MoneyOff">Unsettled Trip Advance</MudListItem>
                         <MudListItem T="string" OnClick="@(() => nav.NavigateTo("/TruckUtilizationReport"))" Icon="@Icons.Material.Filled.ShowChart">Truck Utilization</MudListItem>
                         <MudListItem T="string" OnClick="@(() => nav.NavigateTo("/TruckTransferHistoryReport"))" Icon="@Icons.Material.Filled.History">Truck Transfer History</MudListItem>
                         <MudListItem T="string" OnClick="@(() => nav.NavigateTo("/TruckTransferExpenseReport"))" Icon="@Icons.Material.Filled.MonetizationOn">Truck Transfer Expense</MudListItem>
                         <MudListItem T="string" OnClick="@(() => nav.NavigateTo("/TruckStatusReport"))" Icon="@Icons.Material.Filled.LocalShipping">Truck Status</MudListItem>
                         <MudListItem T="string" OnClick="@(() => nav.NavigateTo("/TruckPerformanceReport"))" Icon="@Icons.Material.Filled.TrendingUp">Truck Performance</MudListItem>
                         <MudListItem T="string" OnClick="@(() => nav.NavigateTo("/TruckAllDocumentReport"))" Icon="@Icons.Material.Filled.Description">Truck Documents</MudListItem>
                         <MudListItem T="string" OnClick="@(() => nav.NavigateTo("/PODReport"))" Icon="@Icons.Material.Filled.ReceiptLong">POD Report</MudListItem>
                         <MudListItem T="string" OnClick="@(() => nav.NavigateTo("/FuelToAdBlueRatioReport"))" Icon="@Icons.Material.Filled.Opacity">Fuel/AdBlue Register</MudListItem>
                         <MudListItem T="string" OnClick="@(() => nav.NavigateTo("/ConsignmentNoteReport"))" Icon="@Icons.Material.Filled.Note">Consignment Note</MudListItem>
                         <MudListItem T="string" OnClick="@(() => nav.NavigateTo("/OverridedMileageShortageReport"))" Icon="@Icons.Material.Filled.Speed">Overrided Mileage Shortage</MudListItem>
                         <MudListItem T="string" OnClick="@(() => nav.NavigateTo("/FasTagExpenseReport"))" Icon="@Icons.Material.Filled.DirectionsCar">FasTag Expense</MudListItem>
                         <MudListItem T="string" OnClick="@(() => nav.NavigateTo("/DespatchReport"))" Icon="@Icons.Material.Filled.Send">Despatch Report</MudListItem>
                         <MudListItem T="string" OnClick="@(() => nav.NavigateTo("/TripExpenseByPostingGroupReport"))" Icon="@Icons.Material.Filled.GroupWork">Trip Expense (Group)</MudListItem>
                         <MudListItem T="string" OnClick="@(() => nav.NavigateTo("/AssetTransferReport"))" Icon="@Icons.Material.Filled.SwapHoriz">Asset Transfer</MudListItem>
                    </MudList>
                </MudCardContent>
            </MudCard>
        </MudItem>

        <!-- Finance Reports -->
         <MudItem xs="12" sm="6" md="4">
            <MudCard Elevation="4" Class="pa-4 h-100">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6" Color="Color.Success">Finance</MudText>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent>
                    <MudList T="string" Clickable="true" Dense="true">
                         <MudListItem T="string" OnClick="@(() => nav.NavigateTo("/FundFlowReport"))" Icon="@Icons.Material.Filled.AttachMoney">Fund Flow</MudListItem>
                         <MudListItem T="string" OnClick="@(() => nav.NavigateTo("/FinanceReport"))" Icon="@Icons.Material.Filled.AccountBalance">Payment To Supplier</MudListItem>
                         <MudListItem T="string" OnClick="@(() => nav.NavigateTo("/GstrReports"))" Icon="@Icons.Material.Filled.Receipt">GSTR One</MudListItem>
                         <MudListItem T="string" OnClick="@(() => nav.NavigateTo("/SalesRegisterReport"))" Icon="@Icons.Material.Filled.PointOfSale">Sales Register</MudListItem>
                         <MudListItem T="string" OnClick="@(() => nav.NavigateTo("/PurchaseRegisterReport"))" Icon="@Icons.Material.Filled.ShoppingCart">Purchase Register</MudListItem>
                         <MudListItem T="string" OnClick="@(() => nav.NavigateTo("/BankLedgerReport"))" Icon="@Icons.Material.Filled.AccountBalanceWallet">Bank Ledger</MudListItem>
                         <MudListItem T="string" OnClick="@(() => nav.NavigateTo("/CashLedgerReport"))" Icon="@Icons.Material.Filled.Money">Cash Ledger</MudListItem>
                         <MudListItem T="string" OnClick="@(() => nav.NavigateTo("/DriverSalaryPayableReport"))" Icon="@Icons.Material.Filled.Payment">Driver Salary Payable</MudListItem>
                         <MudListItem T="string" OnClick="@(() => nav.NavigateTo("/TdsPayableReport"))" Icon="@Icons.Material.Filled.Assignment">TDS Payable</MudListItem>
                         <MudListItem T="string" OnClick="@(() => nav.NavigateTo("/DaybookReport"))" Icon="@Icons.Material.Filled.Book">Daybook (Finance Txn)</MudListItem>
                         <MudListItem T="string" OnClick="@(() => nav.NavigateTo("/UsageCodeReport"))" Icon="@Icons.Material.Filled.Code">Usage Code</MudListItem>
                         <MudListItem T="string" OnClick="@(() => nav.NavigateTo("/UnApprovedDocumentsReport"))" Icon="@Icons.Material.Filled.PendingActions">Unapproved Documents</MudListItem>
                         <MudListItem T="string" OnClick="@(() => nav.NavigateTo("/PartyLedgerReport"))" Icon="@Icons.Material.Filled.Person">Party Ledger</MudListItem>
                         <MudListItem T="string" OnClick="@(() => nav.NavigateTo("/PartyBalanceSummaryReport"))" Icon="@Icons.Material.Filled.Summarize">Party Balance Summary</MudListItem>
                         <MudListItem T="string" OnClick="@(() => nav.NavigateTo("/JobCardPurchaseReport"))" Icon="@Icons.Material.Filled.ShoppingBag">Job Card Purchase</MudListItem>
                         <MudListItem T="string" OnClick="@(() => nav.NavigateTo("/FundBalanceSummery"))" Icon="@Icons.Material.Filled.AccountBalance">Fund Balance Summary</MudListItem>
                         <MudListItem T="string" OnClick="@(() => nav.NavigateTo("/FinanceTrialBalanceReport"))" Icon="@Icons.Material.Filled.Calculate">Trial Balance</MudListItem>
                         <MudListItem T="string" OnClick="@(() => nav.NavigateTo("/FinanceAccountLedgerReport"))" Icon="@Icons.Material.Filled.MenuBook">Account Ledger</MudListItem>
                         <MudListItem T="string" OnClick="@(() => nav.NavigateTo("/ReceiptsandPaymentsReport"))" Icon="@Icons.Material.Filled.ReceiptLong">Receipts & Payments</MudListItem>
                         <MudListItem T="string" OnClick="@(() => nav.NavigateTo("/financialstatements"))" Icon="@Icons.Material.Filled.InsertChart">Financial Statements</MudListItem>
                         <MudListItem T="string" OnClick="@(() => nav.NavigateTo("/StockistFreightCollectedReport"))" Icon="@Icons.Material.Filled.LocalShipping">Stockist Freight Collected</MudListItem>
                         <MudListItem T="string" OnClick="@(() => nav.NavigateTo("/OutstandingBills"))" Icon="@Icons.Material.Filled.MoneyOff">Outstanding Bills</MudListItem>
                         <MudListItem T="string" OnClick="@(() => nav.NavigateTo("/PendingMemos"))" Icon="@Icons.Material.Filled.Pending">Pending Payments</MudListItem>
                         <MudListItem T="string" OnClick="@(() => nav.NavigateTo("/AssetLedgerReport"))" Icon="@Icons.Material.Filled.Book">Asset Ledger</MudListItem>
                    </MudList>
                </MudCardContent>
            </MudCard>
        </MudItem>

        <!-- Inventory Reports -->
         <MudItem xs="12" sm="6" md="4">
            <MudCard Elevation="4" Class="pa-4 h-100">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6" Color="Color.Secondary">Inventory</MudText>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent>
                     <MudList T="string" Clickable="true" Dense="true">
                         <MudListItem T="string" OnClick="@(() => nav.NavigateTo("/InventorySummaryReport"))" Icon="@Icons.Material.Filled.Inventory">Inventory Summary</MudListItem>
                         <MudListItem T="string" OnClick="@(() => nav.NavigateTo("/TruckWiseTyreReport"))" Icon="@Icons.Material.Filled.LocalShipping">Truck Wise Tyre</MudListItem>
                         <MudListItem T="string" OnClick="@(() => nav.NavigateTo("/TyreMasterReport"))" Icon="@Icons.Material.Filled.TireRepair">Tyre Master</MudListItem>
                         <MudListItem T="string" OnClick="@(() => nav.NavigateTo("/TyreResoleReport"))" Icon="@Icons.Material.Filled.Refresh">Tyre Resole</MudListItem>
                    </MudList>
                </MudCardContent>
            </MudCard>
        </MudItem>

        <!-- Maintenance Reports -->
         <MudItem xs="12" sm="6" md="4">
            <MudCard Elevation="4" Class="pa-4 h-100">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6" Color="Color.Warning">Maintenance</MudText>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent>
                     <MudList T="string" Clickable="true" Dense="true">
                         <MudListItem T="string" OnClick="@(() => nav.NavigateTo("/InsuranceStatusReport"))" Icon="@Icons.Material.Filled.Security">Insurance Status</MudListItem>
                         <MudListItem T="string" OnClick="@(() => nav.NavigateTo("/JobMaintenanceReport"))" Icon="@Icons.Material.Filled.Work">Job Maintenance</MudListItem>
                         <MudListItem T="string" OnClick="@(() => nav.NavigateTo("/TruckMaintenanceReport"))" Icon="@Icons.Material.Filled.Build">Truck Maintenance</MudListItem>
                         <MudListItem T="string" OnClick="@(() => nav.NavigateTo("/MechanicWorkReport"))" Icon="@Icons.Material.Filled.Engineering">Mechanic Work</MudListItem>
                    </MudList>
                </MudCardContent>
            </MudCard>
        </MudItem>

        <!-- Assets Reports -->
        @* <MudItem xs="12" sm="6" md="4">
            <MudCard Elevation="4" Class="pa-4 h-100">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6" Color="Color.Info">Assets</MudText>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent>
                    <MudList T="string" Clickable="true" Dense="true">
                         <MudListItem T="string" OnClick="@(() => nav.NavigateTo("/AssetRegisterReport"))" Icon="@Icons.Material.Filled.ListAlt">Asset Register</MudListItem>
                         <MudListItem T="string" OnClick="@(() => nav.NavigateTo("/AssetLedgerReport"))" Icon="@Icons.Material.Filled.Book">Asset Ledger</MudListItem>
                    </MudList>
                </MudCardContent>
            </MudCard>
        </MudItem> *@

