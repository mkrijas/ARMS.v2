@page "/trucks"

@inject TruckDataArrayModel data
@inject ITruckService Iservice
@inject ITruckTypeService Itrucktype
@inject IBranchService Ibranch
@inject MudBlazor.ISnackbar snackbar
@inject AuthenticationStateProvider auth
@attribute [Authorize]

@using System.Globalization


<MudGrid Spacing="4">
    <MudItem xs="12">
        <MudCard Elevation="10">
            <EditForm Model="@model" OnValidSubmit="OnValidSubmit">
                <DataAnnotationsValidator />
                <ValidationSummary />
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6">Add/Edit Trucks</MudText>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent>
                    <MudGrid>
                        <MudItem xs="6">
                            <MudTextField @bind-Value="@model.CurrentRegistration.RegNo" Label="Registered Number" Variant="Variant.Text" Margin="Margin.Normal" For="@(() => model.CurrentRegistration.RegNo)"></MudTextField>
                        </MudItem>
                        <MudItem xs="6">
                            <MudSelect Label="Home Branch" @bind-Value="model.HomeBranchID" OffsetY="true" AdornmentColor="Color.Secondary">
                                @foreach (var item in Branches)
                                {
                                    <MudSelectItem Value="@item.BranchID">@item.BranchName</MudSelectItem>
                                }
                            </MudSelect>
                        </MudItem>
                        <MudItem xs="6">
                            <MudDatePicker Label="valid from" DisableToolbar="true" Editable="true" @bind-Date="@model.CurrentRegistration.EffectFrom" HelperText="Enter Date" Culture="@CultureInfo.GetCultureInfo("en-IN")" />
                        </MudItem>
                        <MudItem xs="6">
                            <MudDatePicker Label="Valid up to" DisableToolbar="true" Editable="true" @bind-Date="@model.CurrentRegistration.EffectTo" HelperText="Enter Date" Culture="@CultureInfo.GetCultureInfo("en-IN")" />
                        </MudItem>
                        <MudItem xs="6">
                            <MudSelect Label="Select Type" @bind-Value="model.TruckTypeID" OffsetY="true" AdornmentColor="Color.Secondary">
                                @foreach (var item in TruckTypes)
                                {
                                    <MudSelectItem Value="@item.TruckTypeID">@item.TruckType</MudSelectItem>
                                }
                            </MudSelect>
                        </MudItem>
                        <MudItem xs="6">
                            <MudSelect Label="Select Body Type" @bind-Value="model.BodyType" OffsetY="true" AdornmentColor="Color.Secondary">
                                @foreach (var item in data.BodyTypes)
                                {
                                    <MudSelectItem Value="@item">@item</MudSelectItem>
                                }
                            </MudSelect>
                        </MudItem>
                        <MudItem xs="6">
                            <MudTextField @bind-Value="@model.EngineNumber" Label="Engine Number" Variant="Variant.Text" Margin="Margin.Normal" For="@(() => model.EngineNumber)"></MudTextField>
                        </MudItem>
                        <MudItem xs="6">
                            <MudTextField @bind-Value="@model.ChassisNumber" Label="Chassis Number" Variant="Variant.Text" Margin="Margin.Normal" For="@(() => model.ChassisNumber)"></MudTextField>
                        </MudItem>
                        <MudItem xs="6">
                            <MudSelect Label="Select Fuel Type" @bind-Value="model.FuelType" OffsetY="true" AdornmentColor="Color.Secondary">
                                @foreach (var item in data.FuelTypes)
                                {
                                    <MudSelectItem Value="@item">@item</MudSelectItem>
                                }
                            </MudSelect>
                        </MudItem>
                        <MudItem xs="6">
                            <MudTextField @bind-Value="@model.FuelTankCapacity" Label="FuelTank Capacity" Variant="Variant.Text" Margin="Margin.Normal" For="@(() => model.FuelTankCapacity)"></MudTextField>
                        </MudItem>
                        <MudItem xs="6">
                            <MudDatePicker Label="Purchase Date" DisableToolbar="true" Editable="true" @bind-Date="model.PurchaseDate" HelperText="Enter Date" DateFormat="dd/MM/yyyy" />
                        </MudItem>
                        <MudItem xs="6">
                            <MudTextField @bind-Value="@model.ManufacturedYear" Label="Manufactured Year" Variant="Variant.Text" Margin="Margin.Normal" For="@(() => model.ManufacturedYear)"></MudTextField>
                        </MudItem>
                        <MudItem xs="6">
                            <MudSelect Label="Select Transmission Type" @bind-Value="model.TransmissionType" OffsetY="true" AdornmentColor="Color.Secondary">
                                @foreach (var item in data.TransmissionTypes)
                                {
                                    <MudSelectItem Value="@item">@item</MudSelectItem>
                                }
                            </MudSelect>
                        </MudItem>
                    </MudGrid>
                    <br />
                    <MudButton Variant="Variant.Filled" Color="Color.Success" ButtonType="ButtonType.Submit">Save Truck</MudButton>

                </MudCardContent>
            </EditForm>
        </MudCard>
    </MudItem>
    <MudItem xs="12">
        <MudTable Items="@collection" Elevation="10" Filter="new Func<TruckModel, bool>(search)" @bind-Truck="model">
            <ToolBarContent>
                <MudText Typo="Typo.h6">Trucks</MudText>
                <MudToolBarSpacer></MudToolBarSpacer>
                <MudTextField @bind-Value="searchTruck" Truckholder="Search Trucks... "
                              Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                              IconSize="Size.Medium" Class="mt-0"></MudTextField>
            </ToolBarContent>
            <HeaderContent>
                <MudTh><MudTableSortLabel SortBy="new Func<TruckModel, object>(x=> x.RegNo)" InitialDirection="SortDirection.Ascending">Truck</MudTableSortLabel></MudTh>
                <MudTh><MudTh><MudTableSortLabel SortBy="new Func<TruckModel, object>(x=> x.TruckType)" InitialDirection="SortDirection.Ascending">Type</MudTableSortLabel></MudTh></MudTh>
                <MudTh><MudTh><MudTableSortLabel SortBy="new Func<TruckModel, object>(x=> x.FuelType)" InitialDirection="SortDirection.Ascending">Fuel Type</MudTableSortLabel></MudTh></MudTh>
                <MudTh><MudTh><MudTableSortLabel SortBy="new Func<TruckModel, object>(x=> x.FuelTankCapacity)" InitialDirection="SortDirection.Ascending">Fuel Capacity</MudTableSortLabel></MudTh></MudTh>
                <MudTh><MudTh><MudTableSortLabel SortBy="new Func<TruckModel, object>(x=> x.BodyType)" InitialDirection="SortDirection.Ascending">Body Type</MudTableSortLabel></MudTh></MudTh>
                <MudTh><MudTh><MudTableSortLabel SortBy="new Func<TruckModel, object>(x=> x.ManufacturedYear)" InitialDirection="SortDirection.Ascending">Year</MudTableSortLabel></MudTh></MudTh>
                <MudTh>Actions</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Truck">@context.RegNo</MudTd>
                <MudTd DataLabel="TruckType">@context.TruckType</MudTd>
                <MudTd DataLabel="FuelType">@context.FuelType</MudTd>
                <MudTd DataLabel="FuelTankCapacity">@context.FuelTankCapacity</MudTd>
                <MudTd DataLabel="BodyType">@context.BodyType</MudTd>
                <MudTd DataLabel="ManufacturedYear">@context.ManufacturedYear</MudTd>
                <MudTd DataLabel="">
                    <MudFab @onclick="@(()=> Edit(context.TruckID))" Color="Color.Primary" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" IconSize="Size.Small" />
                    <MudFab @onclick="@(()=> Delete(context.TruckID))" Color="Color.Primary" Icon="@Icons.Material.Filled.Delete" Size="Size.Small" IconSize="Size.Small" />
                </MudTd>
            </RowTemplate>
            <PagerContent>
                <MudTablePager PageSizeOptions="new int[] { 5, 10, 20, 50, 100 }" />
            </PagerContent>
        </MudTable>
    </MudItem>



</MudGrid>
@code {

    private TruckModel model = new TruckModel();

    private string searchTruck = "";
    private List<TruckModel> collection = new List<TruckModel>();
    private List<TruckTypeModel> TruckTypes = new List<TruckTypeModel>();
    private List<BranchModel> Branches = new List<BranchModel>();


    protected override async Task OnInitializedAsync()
    {
        await Task.Run(() => GetAll());
        TruckTypes = Itrucktype.Select(0).ToList();
        Branches = Ibranch.Select().ToList();
    }

    private void GetAll()
    {
        collection.Clear();
        foreach (var item in Iservice.Select(0))
        {
            collection.Add(item);
        }
    }

    private async void OnValidSubmit(EditContext context)
    {
      
        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;
        model.UserInfo.UserID = user.Identity.Name;
        try
        {
            model = Iservice.Update(model);

            snackbar.Add("Saved Successfully", Severity.Success);
            if (collection.Exists(x => x.TruckID == model.TruckID))
            {
                collection[collection.FindIndex(x => x.TruckID == model.TruckID)] = model;
            }
            else
            {
                collection.Add(model);
            }
            model = new TruckModel();           
        }
        catch (Exception ex)
        {
            snackbar.Add(ex.Message, Severity.Warning);
        }
    }

    private void Edit(int id)
    {
        model = Iservice.SelectByID(id);
        model.CurrentRegistration = Iservice.GetRegistration(model.TruckID);
    }
    private void Delete(int id)
    {
        Iservice.Delete(id, "Rijas");
        snackbar.Add("Deleted Successfully", Severity.Success);
        GetAll();
    }


    private bool search(TruckModel Truck)
    {
        if (Truck.RegNo != null && Truck.RegNo.Contains(searchTruck, StringComparison.OrdinalIgnoreCase))
        {
            return true;
        }
        else if (Truck.RegNo == null) return true;
        return false;
    }
}


