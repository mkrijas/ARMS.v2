

@using Views.Data
@inject AuthenticationStateProvider auth
@inject NavigationManager nav
@inject ISessionStorageService sessionStorage

<div style="height: 100vh; width: 100vw; overflow: hidden; display: flex;">
    
    <!-- Left Side: Branding & Image (Hidden on mobile) -->
    <!-- Using bgImage.jpg with the abstract overlay style from Landing Page for consistency -->
    <div class="d-none d-md-flex flex-column justify-center align-start pa-12" 
         style="width: 60%; background-image: url('ArmsStaticFiles/bgImage.jpg'); background-size: cover; background-position: center; position: relative;">
        
        <!-- Gradient Overlay -->
        <div style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; background: linear-gradient(135deg, rgba(30, 30, 45, 0.9), rgba(255, 159, 67, 0.8));"></div>
        
        <!-- Content on top of image -->
        <div style="z-index: 2; color: white; max-width: 600px;">
            <div class="d-flex align-center gap-3 mb-6">
                 <!-- Logo in White for dark background -->
                 <MudIcon Icon="@Icons.Material.Filled.LocalShipping" Size="Size.Large" Style="color: white; font-size: 3rem;" />
                 <MudText Typo="Typo.h4" Style="font-weight: 800; letter-spacing: 1px;">ARMS v2</MudText>
            </div>
            
            <MudText Typo="Typo.h2" Class="mb-4" Style="font-weight: 700; line-height: 1.2;">
                Manage your Fleet <br/> with Confidence.
            </MudText>
            <MudText Typo="Typo.h5" Style="font-weight: 300; opacity: 0.9;">
                The #1 Logistics Management Solution for enterprise tracking, analytics, and asset control.
            </MudText>
        </div>
    </div>

    <!-- Right Side: Login Form -->
    <div class="d-flex flex-column justify-center align-center pa-8" style="flex: 1; background-color: white;">
        
        <div style="width: 100%; max-width: 450px;">
            <!-- Mobile Logo (only visible on small screens) -->
            <div class="d-md-none mb-8 d-flex align-center justify-center">
                 <img src="images/ARMS.V2_Logo.png" style="height: 50px;" />
            </div>

            <div class="mb-8">
                <MudText Typo="Typo.h4" Style="font-weight: 700; color: #5E5873;" Class="mb-2">Welcome to ARMS! 👋</MudText>
                <MudText Typo="Typo.body1" Style="color: #6E6B7B;">Please sign-in to your account and start the adventure</MudText>
            </div>

            <EditForm Model="user" OnValidSubmit="OnValidSubmit">
                <DataAnnotationsValidator />
                
                <MudTextField @bind-Value="user.UserID" 
                              Label="Username" 
                              Variant="Variant.Outlined" 
                              Class="mb-6"
                              Adornment="Adornment.End"
                              AdornmentColor="Color.Primary"
                              FullWidth="true" 
                              Style="background-color: #F8F8F8;" />
                
                <MudTextField InputType="InputType.Password" 
                              @bind-Value="user.Password" 
                              Label="Password" 
                              Variant="Variant.Outlined" 
                              Class="mb-2"
                              Adornment="Adornment.End" 
                              AdornmentIcon="@Icons.Material.Filled.VisibilityOff"
                              FullWidth="true" 
                              Style="background-color: #F8F8F8;" />
                
                <div class="d-flex justify-space-between align-center mb-6">
                    <MudCheckBox T="bool" Label="Remember Me" Color="Color.Primary" Dense="true" Style="font-size: 0.9rem;" />
                    <MudLink Href="#" Underline="Underline.None" Style="color: #FF9F43; font-weight: 600;">Forgot Password?</MudLink>
                </div>

                <MudButton ButtonType="ButtonType.Submit" 
                           Variant="Variant.Filled" 
                           Color="Color.Primary" 
                           Size="Size.Large" 
                           FullWidth="true" 
                           Class="py-3"
                           Style="font-weight: 700; border-radius: 6px; box-shadow: 0 4px 14px 0 rgba(255, 159, 67, 0.39);">
                    Sign in
                </MudButton>
            </EditForm>
            
            <div class="mt-8 d-flex justify-center gap-1">
                <MudText Typo="Typo.body2" Style="color: #6E6B7B;">New on our platform?</MudText>
                <MudLink Href="#" Underline="Underline.None" Style="color: #FF9F43; font-weight: 600;">Create an account</MudLink>
            </div>
            
            <!-- Social Login Divider -->
            <div class="d-flex align-center my-8">
                <MudDivider Class="flex-grow-1" />
                <MudText Typo="Typo.caption" Class="mx-4" Style="color: #B9B9C3;">OR</MudText>
                <MudDivider Class="flex-grow-1" />
            </div>
            
            <div class="d-flex justify-center gap-4">
                <MudIconButton Icon="@Icons.Custom.Brands.Facebook" Color="Color.Inherit" Style="color: #3b5998;" />
                <MudIconButton Icon="@Icons.Custom.Brands.Twitter" Color="Color.Inherit" Style="color: #1da1f2;" />
                <MudIconButton Icon="@Icons.Custom.Brands.Google" Color="Color.Inherit" Style="color: #db4437;" />
                <MudIconButton Icon="@Icons.Custom.Brands.GitHub" Color="Color.Inherit" Style="color: #333333;" />
            </div>

        </div>
    </div>
</div>

@code {
    private User user;

    protected override Task OnInitializedAsync()
    {
        user = new User();
        return base.OnInitializedAsync();
    }

    private async Task<bool> OnValidSubmit()
    {
        ((CustomAuthenticationSatetProvider)auth).AuthenticateUser(user.UserID);
        nav.NavigateTo("/");
        await sessionStorage.SetItemAsync("userID", user.UserID);

        return await Task.FromResult(true);
    }

    class User
    {
        public string UserID { get; set; }
        public string Password { get; set; }
        public string UserName { get; set; }
        public List<int> branches { get; set; }
    }
}
