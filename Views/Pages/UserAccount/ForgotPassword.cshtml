@page
@model ForgotPasswordModel
@{
    Layout = null;
    ViewData["Title"] = "Forgot Password?";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ARMS v2</title>
    <link rel="stylesheet" href="~/css/bootstrap/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" />
    <style>
        body {
            background-color: #f4f5f7;
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
            margin: 0;
            display: flex;
            align-items: center;
            justify-content: center;
            min-height: 100vh;
        }
        .card-custom {
            background: #ffffff;
            border-radius: 8px;
            box-shadow: 0 4px 24px 0 rgba(34, 41, 47, 0.1);
            padding: 2.5rem;
            width: 100%;
            max-width: 450px;
            border: none;
        }
        .brand-logo {
            display: flex;
            align-items: center;
            gap: 10px;
            margin-bottom: 2rem;
            justify-content: center;
            color: #FF9F43;
            text-decoration: none;
        }
        .brand-name {
            font-size: 1.8rem;
            font-weight: 800;
            letter-spacing: 1px;
            color: #5E5873;
        }
        .card-title {
            font-weight: 700;
            color: #5E5873;
            font-size: 1.5rem;
            margin-bottom: 0.5rem;
        }
        .card-subtitle {
            color: #6E6B7B;
            font-size: 0.95rem;
            margin-bottom: 1.5rem;
        }
        .form-label {
            font-weight: 600;
            color: #5E5873;
            font-size: 0.85rem;
            margin-bottom: 0.5rem;
        }
        .form-control-custom {
            background-color: #F8F8F8 !important;
            border: 1px solid #D8D6DE !important;
            border-radius: 6px !important;
            padding: 0.75rem 1rem !important;
            color: #6E6B7B !important;
            transition: border-color 0.15s ease-in-out, box-shadow 0.15s ease-in-out !important;
        }
        .form-control-custom:focus {
            border-color: #FF9F43 !important;
            box-shadow: 0 3px 8px 0 rgba(255, 159, 67, 0.2) !important;
            outline: none !important;
        }
        .btn-custom {
            background: #FF9F43 !important;
            color: white !important;
            border: none !important;
            padding: 0.75rem 1.5rem !important;
            font-weight: 700 !important;
            border-radius: 6px !important;
            box-shadow: 0 4px 14px 0 rgba(255, 159, 67, 0.4) !important;
            transition: all 0.2s ease-in-out !important;
            width: 100%;
        }
        .btn-custom:hover {
            background: #E08730 !important;
            box-shadow: 0 6px 20px 0 rgba(255, 159, 67, 0.5) !important;
        }
        .link-custom {
            color: #FF9F43;
            font-weight: 600;
            text-decoration: none;
            transition: color 0.15s ease-in-out;
            display: inline-flex;
            align-items: center;
            gap: 5px;
        }
        .link-custom:hover {
            color: #E08730;
            text-decoration: none;
        }
        .back-to-login {
            display: flex;
            justify-content: center;
            margin-top: 1.5rem;
        }
        .text-danger {
            font-size: 0.85rem;
            margin-top: 0.25rem;
        }
    </style>
</head>
<body>
    <div class="card-custom">
        <a href="/login" class="brand-logo">
            <!-- Inline SVG for truck icon to match localShipping MudIcon -->
            <svg viewBox="0 0 24 24" width="36" height="36" fill="currentColor">
                <path d="M20 8h-3V4H3c-1.1 0-2 .9-2 2v11h2c0 1.66 1.34 3 3 3s3-1.34 3-3h6c0 1.66 1.34 3 3 3s3-1.34 3-3h2v-5l-3-4zM6 18.5c-.83 0-1.5-.67-1.5-1.5s.67-1.5 1.5-1.5 1.5.67 1.5 1.5-.67 1.5-1.5 1.5zm13.5-9l2.25 3H17V9.5h2.5zM18 18.5c-.83 0-1.5-.67-1.5-1.5s.67-1.5 1.5-1.5 1.5.67 1.5 1.5-.67 1.5-1.5 1.5z"/>
            </svg>
            <span class="brand-name">ARMS v2</span>
        </a>

        <div class="mb-4">
            <h2 class="card-title">Forgot Password? 🔒</h2>
            <p class="card-subtitle">Enter your email and we'll send you instructions to reset your password</p>
        </div>

        <form method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
            
            <div class="mb-4">
                <label asp-for="Input.Email" class="form-label">Email Address</label>
                <input asp-for="Input.Email" class="form-control form-control-custom" placeholder="john@example.com" autocomplete="username" aria-required="true" />
                <span asp-validation-for="Input.Email" class="text-danger"></span>
            </div>

            <button type="submit" class="btn btn-custom">Send Reset Link</button>
        </form>

        <div class="back-to-login">
            <a href="/login" class="link-custom">
                <!-- Arrow back icon -->
                <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor" style="vertical-align: middle;">
                    <path d="M20 11H7.83l5.59-5.59L12 4l-8 8 8 8 1.41-1.41L7.83 13H20v-2z"/>
                </svg>
                Back to Login
            </a>
        </div>
    </div>

    <partial name="_ValidationScriptsPartial" />
</body>
</html>
