@using Views.Data
@using System.ComponentModel.DataAnnotations
@using Microsoft.AspNetCore.Identity
@using ArmsModels.BaseModels

@inject AuthenticationStateProvider auth
@inject NavigationManager nav
@inject ISessionStorageService sessionStorage
@inject UserManager<UserModel> _userManager
@inject MudBlazor.ISnackbar snackbar

@inject IJSRuntime JSRuntime

<MudDialog DisableSidePadding="true" Class="login-dialog-transparent" Options="dialogOptions">
    <DialogContent>
        <!-- Rope Container - Clicks here trigger Cancel (Close Animation) -->
        <div class="rope-container @(isClosing ? "exiting" : "")" @onclick="Cancel">
            <!-- Constrained Wrapper for Alignment - Handles Horizontal Sway -->
            <div class="rope-align-wrapper" @onclick:stopPropagation>
                <!-- Ropes (Siblings for independent animation) -->
                <div class="rope rope-left"></div>
                <div class="rope rope-right"></div>
                
                <!-- Card Container with Animation -->
                <div class="hanging-card">
                    <!-- Hooks -->
                    <div class="hook hook-left"></div>
                    <div class="hook hook-right"></div>
                    
                    <!-- Main Login Card -->
                    <MudPaper Elevation="4" Class="pa-8 login-paper" Style="background: rgba(255, 255, 255, 0.95); border-radius: 8px; position: relative; backdrop-filter: blur(10px); box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);">
                        <!-- Close Button -->
                        <MudIconButton Icon="@Icons.Material.Filled.Close" 
                                       OnClick="Cancel" 
                                       Size="Size.Small" 
                                       Style="position: absolute; top: 20px; right: 10px; background: rgba(255, 255, 255, 0.9); color: #5E5873; z-index: 20; filter: drop-shadow(0px 2px 2px rgba(0,0,0,0.6));" />

                        <div class="d-flex flex-column align-center">
                            <MudText Typo="Typo.h5" Style="font-weight: 800; color: #5E5873;" Class="mb-2">Welcome Back!</MudText>
                            <MudText Typo="Typo.body2" Style="color: #6E6B7B;" Class="mb-6">Sign in to continue to ARMS v2</MudText>
    
                            <EditForm Model="user" OnValidSubmit="OnValidSubmit" style="width: 100%;">
                                <DataAnnotationsValidator />
                                
                                <MudTextField @bind-Value="user.UserID"
                                              id="login-username"
                                              Label="Username" 
                                              Variant="Variant.Outlined" 
                                              Class="mb-4"
                                              Adornment="Adornment.End"
                                              AdornmentColor="Color.Primary"
                                              FullWidth="true" 
                                              Margin="Margin.Dense"
                                              For="@(() => user.UserID)" />
                                
                                <MudTextField InputType="@(_showPassword ? InputType.Text : InputType.Password)" 
                                              @bind-Value="user.Password" 
                                              Label="Password" 
                                              Variant="Variant.Outlined" 
                                              Class="mb-2"
                                              Adornment="Adornment.End" 
                                              AdornmentIcon="@(_showPassword ? Icons.Material.Filled.Visibility : Icons.Material.Filled.VisibilityOff)"
                                              OnAdornmentClick="TogglePasswordVisibility"
                                              FullWidth="true" 
                                              Margin="Margin.Dense" 
                                              For="@(() => user.Password)" />
                                
                                <div class="d-flex justify-space-between align-center mb-4">
                                    <MudCheckBox T="bool" Label="Remember Me" Color="Color.Primary" Dense="true" Size="Size.Small" />
                                    <MudLink Href="#" Underline="Underline.None" Typo="Typo.caption" Style="color: #FF9F43; font-weight: 600;">Forgot Password?</MudLink>
                                </div>
    
                                <MudButton ButtonType="ButtonType.Submit" 
                                           Variant="Variant.Filled" 
                                           Color="Color.Primary" 
                                           Size="Size.Large" 
                                           FullWidth="true" 
                                           Disabled="@_loading"
                                           Class="py-2"
                                           Style="font-weight: 700; box-shadow: 0 4px 14px 0 rgba(255, 159, 67, 0.39);">
                                    @if (_loading)
                                    {
                                        <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true" />
                                        <MudText Class="ms-2">Logging in...</MudText>
                                    }
                                    else
                                    {
                                        <MudText>Login</MudText>
                                    }
                                </MudButton>
                            </EditForm>
                        </div>
                    </MudPaper>
                </div>
            </div>
        </div>
    </DialogContent>
</MudDialog>



@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; }

    private User user = new User();
    private DialogOptions dialogOptions = new DialogOptions() { NoHeader = true, BackgroundClass = "login-overlay", MaxWidth = MaxWidth.Small };
    private bool _showPassword = false;
    private void TogglePasswordVisibility() => _showPassword = !_showPassword;
    private bool isClosing = false;
    // Removed _usernameField

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await Task.Delay(1600); // 1. Wait for animation
            try {
                // Robust Focus: Find the wrapper, then the input
                await JSRuntime.InvokeVoidAsync("eval", "var el = document.getElementById('login-username'); if(el) { var inp = el.querySelector('input'); if(inp) inp.focus(); else el.focus(); }");
            } catch {}
        }
    }

    private bool _loading = false;

    private async Task<bool> OnValidSubmit()
    {
        _loading = true;
        StateHasChanged();

        try
        {
            var appUser = await _userManager.FindByIdAsync(user.UserID);
            
            if (appUser == null)
            {
                snackbar.Add("Invalid Username or Password", Severity.Error);
                _loading = false;
                return false;
            }

            var checkPassword = await _userManager.CheckPasswordAsync(appUser, user.Password);

            if (!checkPassword)
            {
                snackbar.Add("Invalid Username or Password", Severity.Error);
                _loading = false;
                return false;
            }

            ((CustomAuthenticationSatetProvider)auth).AuthenticateUser(user.UserID);
            await sessionStorage.SetItemAsync("userID", user.UserID);
            MudDialog.Close(DialogResult.Ok(true));
            return true;
        }
        catch (Exception ex)
        {
            snackbar.Add("Error during login: " + ex.Message, Severity.Error);
            _loading = false;
            return false;
        }
        finally
        {
            // Note: If success, dialog closes, so no need to set _loading=false here usually, 
            // but for safety in case of non-exceptional failures:
            _loading = false;
            StateHasChanged();
        }
    }

    private async Task Cancel()
    {
        isClosing = true;
        StateHasChanged(); // Trigger UI update to apply .exiting class
        await Task.Delay(1300); // Wait for fall animation to complete
        MudDialog.Cancel();
    }

    class User
    {
        [Required(ErrorMessage = "Username is required")]
        public string UserID { get; set; }
        [Required(ErrorMessage = "Password is required")]
        public string Password { get; set; }
    }
}
