@page "/UserAccount/Register"
@model RegisterModel
@{
    Layout = null; 
    ViewData["Title"] = "Register";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ARMS V2</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body {
            margin: 0;
            padding: 0;
            font-family: 'Inter', sans-serif;
            background: #F8F9FA;
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            overflow: hidden;
            position: relative;
        }

        /* Abstract Amber Background */
        .bg-overlay {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: linear-gradient(135deg, #FF9F43 0%, #FFB36B 100%);
            clip-path: polygon(0 0, 100% 0, 100% 45%, 0% 100%);
            z-index: -1;
        }
        
        .glass-card {
            background: rgba(255, 255, 255, 0.95);
            backdrop-filter: blur(10px);
            border-radius: 16px;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
            padding: 40px;
            width: 100%;
            max-width: 450px;
            text-align: center;
        }

        .brand-logo {
            display: flex;
            align-items: center;
            justify-content: center;
            margin-bottom: 24px;
            gap: 10px;
        }

        .brand-logo svg {
            color: #FF9F43;
            width: 32px;
            height: 32px;
        }

        .brand-text {
            font-size: 24px;
            font-weight: 800;
            color: #5E5873;
            letter-spacing: 1px;
        }

        h4 {
            color: #5E5873;
            font-weight: 600;
            margin-bottom: 8px;
            margin-top: 0;
        }

        p.subtitle {
            color: #6E6B7B;
            font-size: 14px;
            margin-bottom: 32px;
        }

        .form-group {
            margin-bottom: 20px;
            text-align: left;
        }

        label {
            font-size: 12px;
            font-weight: 600;
            color: #5E5873;
            margin-bottom: 6px;
            display: block;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        input.form-control {
            width: 100%;
            padding: 12px 16px;
            border: 1px solid #D8D6DE;
            border-radius: 6px;
            font-size: 14px;
            color: #6E6B7B;
            transition: border-color 0.2s;
            box-sizing: border-box;
            outline: none;
        }

        input.form-control:focus {
            border-color: #FF9F43;
            box-shadow: 0 0 0 3px rgba(255, 159, 67, 0.1);
        }

        button.btn-primary {
            background-color: #FF9F43;
            color: white;
            border: none;
            border-radius: 6px;
            padding: 12px;
            width: 100%;
            font-weight: 600;
            font-size: 14px;
            cursor: pointer;
            transition: background-color 0.2s, transform 0.1s;
            box-shadow: 0 4px 12px rgba(255, 159, 67, 0.4);
            margin-top: 10px;
        }

        button.btn-primary:hover {
            background-color: #e58e3c;
            transform: translateY(-1px);
        }

        button.btn-primary:active {
            transform: translateY(0);
        }

        .text-danger {
            color: #EA5455;
            font-size: 12px;
            margin-top: 4px;
            display: block;
        }

        .login-link {
            margin-top: 20px;
            font-size: 14px;
            color: #6E6B7B;
        }

        .login-link a {
            color: #FF9F43;
            text-decoration: none;
            font-weight: 600;
        }
        
        .login-link a:hover {
            text-decoration: underline;
        }

    </style>
</head>
<body>
    <div class="bg-overlay"></div>

    <div class="glass-card">
        <div class="brand-logo">
           <!-- Truck Icon SVG -->
           <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
              <path d="M20 8h-3V4H3c-1.1 0-2 .9-2 2v11h2c0 1.66 1.34 3 3 3s3-1.34 3-3h6c0 1.66 1.34 3 3 3s3-1.34 3-3h2v-5l-3-4zM6 18.5c-.83 0-1.5-.67-1.5-1.5s.67-1.5 1.5-1.5 1.5.67 1.5 1.5-.67 1.5-1.5 1.5zm13.5-9l1.96 2.5H17V9.5h2.5zm-1.5 9c-.83 0-1.5-.67-1.5-1.5s.67-1.5 1.5-1.5 1.5.67 1.5 1.5-.67 1.5-1.5 1.5z"/>
           </svg>
           <span class="brand-text">ARMS V2</span>
        </div>

        <h4>Start your journey 🚀</h4>
        <p class="subtitle">Create an account to manage your fleet.</p>

        <form asp-route-returnUrl="@Model.ReturnUrl" method="post">
            <div asp-validation-summary="All" class="text-danger" style="margin-bottom: 15px; text-align: left;"></div>
            
            <div class="form-group">
                <label asp-for="Input.UserID">Username</label>
                <input asp-for="Input.UserID" class="form-control" placeholder="johndoe" />
                <span asp-validation-for="Input.UserID" class="text-danger"></span>
            </div>
             <div class="form-group">
                <label asp-for="Input.Phone">Phone Number</label>
                <input asp-for="Input.Phone" class="form-control" placeholder="123-456-7890" />
                <span asp-validation-for="Input.Phone" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Input.Email">Email</label>
                <input asp-for="Input.Email" class="form-control" placeholder="john@example.com" />
                <span asp-validation-for="Input.Email" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Input.Password">Password</label>
                <input asp-for="Input.Password" class="form-control" placeholder="············" />
                <span asp-validation-for="Input.Password" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Input.ConfirmPassword">Confirm Password</label>
                <input asp-for="Input.ConfirmPassword" class="form-control" placeholder="············" />
                <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
            </div>

            <button type="submit" class="btn-primary">Sign up</button>
        </form>

        <div class="login-link">
            Already have an account? <a href="/UserAccount/Login">Sign in instead</a>
        </div>
    </div>

    @section Scripts {
        <partial name="_ValidationScriptsPartial" />
    }
</body>
</html>
