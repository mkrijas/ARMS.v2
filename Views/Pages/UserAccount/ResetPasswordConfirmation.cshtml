@page
@model ResetPasswordConfirmationModel
@{
    Layout = null;
    ViewData["Title"] = "Password Reset Confirmed";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ARMS v2</title>
    <link rel="stylesheet" href="~/css/bootstrap/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" />
    <style>
        body {
            background-color: #f4f5f7;
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
            margin: 0;
            display: flex;
            align-items: center;
            justify-content: center;
            min-height: 100vh;
        }
        .card-custom {
            background: #ffffff;
            border-radius: 8px;
            box-shadow: 0 4px 24px 0 rgba(34, 41, 47, 0.1);
            padding: 2.5rem;
            width: 100%;
            max-width: 450px;
            border: none;
            text-align: center;
        }
        .brand-logo {
            display: flex;
            align-items: center;
            gap: 10px;
            margin-bottom: 2rem;
            justify-content: center;
            color: #FF9F43;
            text-decoration: none;
        }
        .brand-name {
            font-size: 1.8rem;
            font-weight: 800;
            letter-spacing: 1px;
            color: #5E5873;
        }
        .card-title {
            font-weight: 700;
            color: #5E5873;
            font-size: 1.5rem;
            margin-bottom: 0.5rem;
        }
        .card-subtitle {
            color: #6E6B7B;
            font-size: 0.95rem;
            margin-bottom: 1.5rem;
            line-height: 1.5;
        }
        .icon-badge {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 72px;
            height: 72px;
            border-radius: 50%;
            background: rgba(40, 199, 111, 0.15); /* Green overlay for success */
            color: #28C76F; /* Success green */
            margin-bottom: 1.5rem;
        }
        .btn-custom {
            background: #FF9F43 !important;
            color: white !important;
            border: none !important;
            padding: 0.75rem 1.5rem !important;
            font-weight: 700 !important;
            border-radius: 6px !important;
            box-shadow: 0 4px 14px 0 rgba(255, 159, 67, 0.4) !important;
            transition: all 0.2s ease-in-out !important;
            width: 100%;
            text-decoration: none;
            display: inline-block;
        }
        .btn-custom:hover {
            background: #E08730 !important;
            box-shadow: 0 6px 20px 0 rgba(255, 159, 67, 0.5) !important;
            color: white !important;
            text-decoration: none;
        }
    </style>
</head>
<body>
    <div class="card-custom">
        <a href="/login" class="brand-logo">
            <svg viewBox="0 0 24 24" width="36" height="36" fill="currentColor">
                <path d="M20 8h-3V4H3c-1.1 0-2 .9-2 2v11h2c0 1.66 1.34 3 3 3s3-1.34 3-3h6c0 1.66 1.34 3 3 3s3-1.34 3-3h2v-5l-3-4zM6 18.5c-.83 0-1.5-.67-1.5-1.5s.67-1.5 1.5-1.5 1.5.67 1.5 1.5-.67 1.5-1.5 1.5zm13.5-9l2.25 3H17V9.5h2.5zM18 18.5c-.83 0-1.5-.67-1.5-1.5s.67-1.5 1.5-1.5 1.5.67 1.5 1.5-.67 1.5-1.5 1.5z"/>
            </svg>
            <span class="brand-name">ARMS v2</span>
        </a>

        <div class="icon-badge">
            <!-- Success/checkmark icon -->
            <svg viewBox="0 0 24 24" width="36" height="36" fill="currentColor">
                <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/>
            </svg>
        </div>

        <div class="mb-4">
            <h2 class="card-title">Password Reset! 🎉</h2>
            <p class="card-subtitle">
                Your password has been successfully reset. You can now log in using your new credentials.
            </p>
        </div>

        <a href="/login" class="btn btn-custom">Proceed to Sign In</a>
    </div>
</body>
</html>
