

<MudGrid Spacing="4">
    @if (@Label != null)
    {
        <MudItem xs="12">
            <MudText Typo="Typo.subtitle2">@Label</MudText>
        </MudItem>
    }
    <MudItem xs="12" md="12">
        <MudTextField @bind-Value="Account.BeneficiaryName" Label="BeneficiaryName" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => Account.BeneficiaryName)"></MudTextField>
    </MudItem>
    <MudItem xs="12" md="12">
        <MudTextField @bind-Value="Account.AccountNumber" Label="AccountNumber" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => Account.AccountNumber)"></MudTextField>
    </MudItem>
    <MudItem xs="12" md="12">
        <MudTextField @bind-Value="Account.IfscCode" Label="IfscCode" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => Account.IfscCode)"></MudTextField>
    </MudItem>
   
</MudGrid>
@code {

    [Parameter]
    public BankAccountModel Account { get; set; }
    [Parameter]
    public string Label { get; set; } = "Bank Account Info";


}
