

<MudGrid>
    @if (!HideLabel)
    {
        <MudItem xs="12">
            <MudText Typo="Typo.subtitle2">@Label</MudText>
        </MudItem>
    }
    <MudItem xs="12" md="4">
        <MudTextField @bind-Value="Address.Building" Label="Building" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => Address.Building)"></MudTextField>
    </MudItem>
    <MudItem xs="12" md="4">
        <MudTextField @bind-Value="Address.Street" Label="Street" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => Address.Street)"></MudTextField>
    </MudItem>
    @if (!HidePlace)
    {
        <MudItem xs="12" md="4">
            <MudTextField @bind-Value="Address.Place" Label="Place" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => Address.Place)"></MudTextField>
        </MudItem>
    }
    <MudItem xs="12" md="4">
        <MudTextField @bind-Value="Address.City" Label="City" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => Address.City)"></MudTextField>
    </MudItem>
    <MudItem xs="12" md="4">
        <MudNumericField HideSpinButtons MaxLength="6" @bind-Value="Address.PinCode" Label="PinCode" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => Address.PinCode)"></MudNumericField>
    </MudItem>
</MudGrid>
@code {

    [Parameter]
    public AddressModel Address { get; set; }
    [Parameter]
    public string Label { get; set; } = "Address Info";
    [Parameter]
    public bool HideLabel { get; set; }
    [Parameter]
    public bool HidePlace { get; set; } = false;


}
