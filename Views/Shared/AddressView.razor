

<MudGrid Spacing="4">
    @if (@Label != null)
    {
        <MudItem xs="12">
            <MudText Typo="Typo.subtitle2">@Label</MudText>
        </MudItem>
    }
    <MudItem xs="12" md="4">
        <MudTextField @bind-Value="Address.Building" Label="Building" Variant="Variant.Outlined" Margin="Margin.Normal" For="@(() => Address.Building)"></MudTextField>
    </MudItem>
    <MudItem xs="12" md="4">
        <MudTextField @bind-Value="Address.Street" Label="Street" Variant="Variant.Outlined" Margin="Margin.Normal" For="@(() => Address.Street)"></MudTextField>
    </MudItem>
    <MudItem xs="12" md="4">
        <MudTextField @bind-Value="Address.Place" Label="Place" Variant="Variant.Outlined" Margin="Margin.Normal" For="@(() => Address.Place)"></MudTextField>
    </MudItem>
    <MudItem xs="12" md="4">
        <MudTextField @bind-Value="Address.City" Label="City" Variant="Variant.Outlined" Margin="Margin.Normal" For="@(() => Address.City)"></MudTextField>
    </MudItem>
    <MudItem xs="12" md="4">
        <MudTextField @bind-Value="Address.PinCode" Label="PinCode" Variant="Variant.Outlined" Margin="Margin.Normal" For="@(() => Address.PinCode)"></MudTextField>
    </MudItem>
</MudGrid>
@code {

    [Parameter]
    public AddressModel Address { get; set; }
    [Parameter]
    public string Label { get; set; } = "Address Info";


}
