    private async Task OpenDialogComplexAsset(AssetModel tds)
    {
        AssetModel assetModel = new AssetModel();

        assetModel.IsComplex = false;
        if (tds.AssetID != null)
        {
            assetModel.ParentAssetID = tds.AssetID;
        }

        DialogParameters parms = new DialogParameters();
        parms.Add("model", assetModel);
        var dialog = DialogService.Show<AssetSimpleDialog>(assetModel.AssetID == null ? "ADD" : "EDIT", parms, maxWidth);
        var result = await dialog.Result;
