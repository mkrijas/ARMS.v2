    [Parameter] public AssetViewModel Model { get; set; }
    DialogOptions maxWidth = new DialogOptions() { MaxWidth = MaxWidth.Medium, FullWidth = true };
    private bool Show;
    private string btnIcon = Icons.Material.Filled.ArrowDownward;
    private void ToggleShow()
    {
        this.Show = !this.Show;       
        btnIcon = this.Show?Icons.Material.Filled.ArrowUpward:Icons.Material.Filled.ArrowDownward;
    }
       

    private bool hasChildren => this.Model?.Children?.Count > 0;

    private string buttonText => this.Show ? "Hide" : "Show";

    private string buttonCss => this.Show ? "btn-dark" : "btn-primary";

    private string HeaderCols => this.hasChildren ? "col-11" : "col-12";
    protected override async Task OnInitializedAsync()
    {


