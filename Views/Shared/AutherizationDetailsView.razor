@inject IDataAuthorizationService Iservice
@inject NavigationManager uriHelper;
@inject MudBlazor.ISnackbar snackbar
@inject AuthenticationStateProvider auth
@attribute [Authorize]
@inject IDialogService DialogService

<MudDialog>
    <TitleContent><h3>Autherization Details</h3></TitleContent>
    <DialogContent>
        <MudPaper>
            <MudContainer Style="max-height: 450px; overflow-y: scroll">
                <MudGrid>
                    <MudItem xs="12" md="12">
                        <MudTable Items="@collection" Dense="true" Hover="true" Striped="true" Elevation="10" @bind-place="model">
                            <ToolBarContent>
                                <MudText Typo="Typo.h6">DataAuthorization Status </MudText>
                                <MudSpacer></MudSpacer>
                            </ToolBarContent>
                            <HeaderContent>
                                <MudTh><MudTableSortLabel SortBy="new Func<DataAuthorizationModel, object>(x=> x.AuthType)" InitialDirection="SortDirection.Ascending">AuthType</MudTableSortLabel></MudTh>
                                <MudTh><MudTableSortLabel SortBy="new Func<DataAuthorizationModel, object>(x=> x.IsCompleted)" InitialDirection="SortDirection.Ascending">IsCompleted</MudTableSortLabel></MudTh>
                                <MudTh><MudTableSortLabel SortBy="new Func<DataAuthorizationModel, object>(x=> x.UserInfo.UserID)" InitialDirection="SortDirection.Ascending">Verify By</MudTableSortLabel></MudTh>
                                <MudTh>Actions</MudTh>
                            </HeaderContent>
                            <RowTemplate>
                                <MudTd DataLabel="DocumentNumber">@context.AuthType</MudTd>
                                <MudTd DataLabel="PaymentMode">@context.IsCompleted</MudTd>
                                <MudTd DataLabel="TotalAmount">@context.UserInfo?.UserID</MudTd>
                                <MudTd DataLabel="">
                                    @* <MudTooltip Text="View authentication Status">
                                    <MudFab @onclick="@(()=> authentication(context))" Color="Color.Warning" StartIcon="@Icons.Material.Filled.Verified" Size="Size.Small" />
                                    </MudTooltip>*@
                                    @if (authlevelID != null)
                                    {
                                        @if (@context.AuthLevelID == authlevelID)
                                        {
                                            <MudTooltip Text="Pending for Verification">
                                                <MudFab @onclick="@(()=> OpenDialog(context))" Color="Color.Success" StartIcon="@Icons.Material.Filled.Check" Size="Size.Small" />
                                            </MudTooltip>
                                        }
                                        @if (@context.AuthLevelID != authlevelID)
                                        {
                                            <MudFab @onclick="@(()=> OpenDialog(context))" Disabled="true" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Check" Size="Size.Small" />
                                        }
                                    }
                                </MudTd>
                            </RowTemplate>
                            <PagerContent>
                                <MudTablePager PageSizeOptions="new int[] { 10, 20, 50, 100 }" />
                                @*  <MudButton OnClick="selected" Variant="Variant.Filled" Color="Color.Success" ButtonType="ButtonType.Submit">Submit</MudButton>*@
                            </PagerContent>
                        </MudTable>
                    </MudItem>
                </MudGrid>
            </MudContainer>
        </MudPaper>
    </DialogContent>
    <DialogActions>
        @* @if(@model.ApprovedInfo.RecordStatus!=1)
        {
        <MudButton @onclick="CreatePaymentMemo" Variant="Variant.Filled" Color="Color.Success" >Submit</MudButton>
        }
        <MudButton @onclick="Cancel" Variant="Variant.Filled" Color="Color.Primary" >Cancel</MudButton>
        *@
    </DialogActions>
</MudDialog>

@code {

    [Parameter]
    public int? DocTypeID { get; set; }
    [Parameter]
    public int? DocumentID { get; set; }
    private DataAuthorizationModel model = new DataAuthorizationModel();
    public int? authlevelID;
    private List<DataAuthorizationModel> collection = new List<DataAuthorizationModel>();
    private List<DataAuthorizationModel> collection1 = new List<DataAuthorizationModel>();
    private bool _busy;

    protected override void OnInitialized()
    {
        GetAll();
    }

    private void GetAll()
    {
        collection = Iservice.GetAuthStatus(DocTypeID, DocumentID).OrderBy(x => x.AuthLevelID).ToList();
        collection1 = collection.Where(x => x.IsCompleted == false).ToList();
        if (collection1.Count > 0)
        {
            authlevelID = collection1.Min(x => x.AuthLevelID.Value);
        }
    }

    public async Task OpenDialog(DataAuthorizationModel statusModel)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        _busy = true;
        DataAuthorizationModel dataAuthorizationModel = new();
        dataAuthorizationModel.AuthLevelID = statusModel.AuthLevelID;
        dataAuthorizationModel.DocTypeID = statusModel.DocTypeID;
        dataAuthorizationModel.DocumentID = statusModel.DocumentID;

        DialogParameters parms = new DialogParameters();
        parms.Add("model", dataAuthorizationModel);
        var dialog = DialogService.Show<AutherizationVerificationDialog>(dataAuthorizationModel.ID == null ? "ADD" : "EDIT", parms);
        var result = await dialog.Result;

        if (!result.Canceled)
        {
            GetAll();
        }
        GetAll();
        await Task.Delay(200);
        _busy = false;
    }
}

