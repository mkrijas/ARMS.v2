    <MudPaper Elevation="0" Class="pa-4 mt-6 border-solid border-2 mud-border-lines-default" Outlined="true">
        <MudTable Items="@collection" Dense="true" Elevation="0" Hover="true" Breakpoint="Breakpoint.Sm" Striped="true">
            <ToolBarContent>
                <MudText Typo="Typo.h6" Class="fw-bold"><MudIcon Icon="@Icons.Material.Filled.VerifiedUser" Class="mr-2 mb-n1" />Verification Status</MudText>
                <MudSpacer />
            </ToolBarContent>
            <HeaderContent>
                <MudTh><MudText Typo="Typo.subtitle2" Class="fw-bold">Verification Type</MudText></MudTh>
                <MudTh Style="text-align: right;"><MudText Typo="Typo.subtitle2" Class="fw-bold">Verified By / Action</MudText></MudTh>
            </HeaderContent>
            <RowTemplate>
                @{
                    Color typeColor = context.IsCompleted ? Color.Success : Color.Default;
                    if(context.AuthLevelID == 100 && context.IsCompleted) typeColor = Color.Error;
                }
                <MudTd DataLabel="Verification Type">
                    <MudText Typo="Typo.body2" Color="@typeColor" Class="fw-bold">@context.AuthType</MudText>
                </MudTd>
                <MudTd DataLabel="Verified By / Action" Style="text-align: right;">
                    @if (!Rejected && !Authorized && authlevelID != null && (context.AuthLevelID == authlevelID))
                    {
                        <MudButton OnClick="@(()=> OpenDialog(context))" Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Check" Size="Size.Small" Class="rounded-pill px-4">Verify</MudButton>
                    }
                    else if (!Rejected && !Authorized && authlevelID != null && (context.AuthLevelID == 100))
                    {
                        <MudButton OnClick="@(()=> OpenDialog(context))" Variant="Variant.Filled" Color="Color.Error" StartIcon="@Icons.Material.Filled.Close" Size="Size.Small" Class="rounded-pill px-4">Reject</MudButton>
                    }
                    else if (!Rejected && !Authorized && authlevelID != null && context.AuthLevelID > authlevelID)
                    {
                        <MudChip T="string" Size="Size.Small" Color="Color.Warning" Variant="Variant.Outlined">Pending</MudChip>
                    }
                    else
                    {
                        @if (context.IsCompleted && context.AuthLevelID == 100)
                        {
                            <MudChip T="string" Size="Size.Small" Color="Color.Error" Variant="Variant.Filled">Rejected: @context.DisplayString</MudChip>
                        }
                        else if (context.IsCompleted)
                        {
                            <MudText Typo="Typo.body2" Color="Color.Success" Class="fw-bold">@context.DisplayString</MudText>
                        }
                        else
                        {
                            <MudText Typo="Typo.body2">@context.DisplayString</MudText>
                        }
                    }
                </MudTd>
            </RowTemplate>
        </MudTable>
    </MudPaper>
}

@code {

    [Parameter]
    public int? DocTypeID { get; set; }
    [Parameter]
    public int? DocumentID { get; set; }
    [Parameter]
    public EventCallback<DataApprovedStatus> OnApprove { get; set; }
    [Parameter]
    public EventCallback<DataApprovedStatus> OnReject { get; set; }
    [Parameter]
    public bool ApproveWithin { get; set; }
    [Parameter]
    public string PageToRedirectLink { get; set; } = string.Empty;
    [Parameter]
    public string DocNumber { get; set; }
    [Parameter]
    public DateTime? DocDate { get; set; }
    [Parameter]
    public string DocType { get; set; }
    [Parameter]
    public UserInfoModel CreatedBy { get; set; }

    public int BranchID { get; set; }
    public string UserID { get; set; }
    private bool _busy;
    public int? authlevelID;
    public bool Authorized = false;
    bool Rejected = false;
    private List<DataAuthorizationModel> collection = new List<DataAuthorizationModel>();
    private List<DataAuthorizationModel> collectionTemp = new List<DataAuthorizationModel>();

    protected override async Task OnInitializedAsync()
    {
        GetAll();

        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;
        BranchID = int.Parse(user.Claims.First(x => x.Type == "BranchID").Value);
        UserID = user.Identity.Name;
    }

    private void GetAll()
    {
        collection = new();
        collection.Add(new DataAuthorizationModel
            {
                AuthType = "Created By",
                UserInfo = CreatedBy,
                IsCompleted = true
            });
        collectionTemp = Iservice.GetAuthStatus(DocTypeID, DocumentID).OrderBy(x => x.AuthLevelID).ToList();
        collection.AddRange(collectionTemp);
        authlevelID = collection.Where(x => x.IsCompleted == false).Min(y => y.AuthLevelID);
        Authorized = collection.Any(x => x.AuthLevelID == 99 && x.IsCompleted);
        Rejected = collection.Any(x => x.AuthLevelID == 100 && x.IsCompleted);
    }

    public async Task OpenDialog(DataAuthorizationModel statusModel)
    {
        CancellationTokenSource ctc = new CancellationTokenSource();
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        var HasClaim = await Irole.HasClaim(statusModel.DocTypeID.ToString(), statusModel.ClaimValue, ctc.Token);
        _busy = true;
        DialogParameters parms = new DialogParameters();
        parms.Add("model", statusModel);
        parms.Add("ApproveWithin", ApproveWithin);
        var dialog = await DialogService.ShowAsync<AutherizationVerificationDialog>(statusModel?.ID == null ? "ADD" : "EDIT", parms);
        var result = await dialog.Result;


        if (!result.Canceled)
        {
            DataApprovedStatus aprd = new DataApprovedStatus();
            aprd = (DataApprovedStatus)result.Data;

            if (aprd.IsApprove)
            {
                await OnApprove.InvokeAsync(aprd);

            }
            else if(aprd.AuthLevelID == 100)
            {
                await OnReject.InvokeAsync(aprd);
            }
            GetAll();
        }
        await Task.Delay(200);
        _busy = false;
    }
}

