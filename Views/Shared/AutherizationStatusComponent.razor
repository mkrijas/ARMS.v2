@inject IDataAuthorizationService Iservice
@inject AuthenticationStateProvider auth
@inject SignalRService signalRService
@inject IPushNotificationService IpushNotificationService
@inject IDialogService DialogService
@inject MudBlazor.ISnackbar snackbar
@attribute [Authorize]


@if (collection.Any())
{
    <MudContainer>
        <MudGrid>
            <MudItem xs="5">
                <b> Verification Type</b>
            </MudItem>
            <MudItem xs="7">
                <b>   Verified By</b>
            </MudItem>
            @foreach (var item in collection)
            {
                Color color = item.IsCompleted ? Color.Primary : Color.Error;
                <MudItem xs="5">
                    <MudText Color="@color"> @item.AuthType     </MudText>
                </MudItem>
                <MudItem xs="7">
                   
                    @if (!Rejected && !Authorized && authlevelID != null && (item.AuthLevelID == authlevelID))
                    {
                        <MudTooltip Text="Pending for Verification">
                            <MudFab @onclick="@(()=> OpenDialog(item))" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Check" Size="Size.Small" IconSize="Size.Small" />
                        </MudTooltip>
                    }
                    else if (!Rejected && !Authorized && authlevelID != null && (item.AuthLevelID == 100))
                    {
                        <MudTooltip Text="Reject the Entry">
                            <MudFab @onclick="@(()=> OpenDialog(item))" Color="Color.Error" StartIcon="@Icons.Material.Filled.Close" Size="Size.Small" IconSize="Size.Small" />
                        </MudTooltip>
                    }
                    else if (!Rejected && !Authorized && authlevelID != null && item.AuthLevelID > authlevelID)
                    {
                        <MudText Color="@color"> Pending </MudText>
                    }
                    else
                    {
                        <MudText Color="@color"> @item.DisplayString </MudText>
                    }
                </MudItem>
            }
        </MudGrid>
    </MudContainer>
}

@code {

    [Parameter]
    public int? DocTypeID { get; set; }
    [Parameter]
    public int? DocumentID { get; set; }
    [Parameter]
    public EventCallback<DataApprovedStatus> OnApprove { get; set; }

    [Parameter]
    public bool ApproveWithin { get; set; }
    [Parameter]
    public string PageToRedirectLink { get; set; } = string.Empty;
    [Parameter]
    public string DocNumber { get; set; }
    [Parameter]
    public DateTime? DocDate { get; set; }
    [Parameter]
    public string DocType { get; set; }



    public int BranchID { get; set; }
    public string UserID { get; set; }
    private bool _busy;
    public int? authlevelID;
    public bool Authorized = false;
    bool Rejected = false;
    private List<DataAuthorizationModel> collection = new List<DataAuthorizationModel>();



    #region SignaIR Notification
    //private IEnumerable<PushNotificationModel> allNotificationMessages = null;
    //private List<PushNotificationModel> currentNotificationMessages = new List<PushNotificationModel>();
    // private PushNotificationModel notificationMessage = new PushNotificationModel();
    #endregion

    protected override async Task OnInitializedAsync()
    {
        GetAll();

        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;
        BranchID = int.Parse(user.Claims.First(x => x.Type == "BranchID").Value);
        UserID = user.Identity.Name;
    }

    private void GetAll()
    {
        collection = Iservice.GetAuthStatus(DocTypeID, DocumentID).OrderBy(x => x.AuthLevelID).ToList();
        authlevelID = collection.Where(x => x.IsCompleted == false).Min(y => y.AuthLevelID);
        Authorized = collection.Any(x => x.AuthLevelID == 99 && x.IsCompleted);
        Rejected = collection.Any(x => x.AuthLevelID == 100 && x.IsCompleted);
    }

    public async Task OpenDialog(DataAuthorizationModel statusModel)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        _busy = true;
        DialogParameters parms = new DialogParameters();
        parms.Add("model", statusModel);
        parms.Add("ApproveWithin", ApproveWithin);
        var dialog = DialogService.Show<AutherizationVerificationDialog>(statusModel?.ID == null ? "ADD" : "EDIT", parms);
        var result = await dialog.Result;

        
        if (!result.Canceled)
        {
            DataApprovedStatus aprd = new DataApprovedStatus();
            aprd = (DataApprovedStatus)result.Data;

            if (aprd.IsApprove)
            {
                await OnApprove.InvokeAsync(aprd);
               
            }
           
            GetAll();
        }
        await Task.Delay(200);
        _busy = false;
    }
}