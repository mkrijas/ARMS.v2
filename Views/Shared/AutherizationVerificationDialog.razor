@inject IDataAuthorizationService Iservice
@inject NavigationManager uriHelper
@inject MudBlazor.ISnackbar snackbar
@inject AuthenticationStateProvider auth
@attribute [Authorize]
@inject IDialogService DialogService
@inject IRoleService<RoleModel> Irole
@using System.Threading;

<MudDialog Class="rounded-xl overflow-hidden">
    <TitleContent>
        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="pa-2">
            <MudStack Row="true" AlignItems="AlignItems.Center">
                <MudIcon Icon="@(model.AuthLevelID == 100 ? Icons.Material.Filled.Block : Icons.Material.Filled.VerifiedUser)" 
                         Color="@(model.AuthLevelID == 100 ? Color.Error : Color.Primary)" 
                         Class="mr-2" />
                <MudText Typo="Typo.h6" Class="fw-bold">@model.AuthType</MudText>
            </MudStack>
            @* <MudIconButton Icon="@Icons.Material.Filled.Close" OnClick="Reject" Size="Size.Small" /> *@
        </MudStack>
    </TitleContent>
    <DialogContent>
        <MudPaper Elevation="0" Class="pa-4 rounded-lg" Style="background: var(--mud-palette-background-grey);">
            <MudTextField @bind-Value="model.Remarks" 
                          Lines="4" 
                          Label="Verification Remarks" 
                          Variant="Variant.Outlined" 
                          Margin="Margin.Normal" 
                          Placeholder="Enter any specific notes or reasons for this action..."
                          For="@(() => model.Remarks)"
                          Class="bg-white" />
            <MudText Typo="Typo.caption" Class="mt-2 mud-text-secondary italic">
                Your remarks will be visible to other verifiers in the journey.
            </MudText>
        </MudPaper>
    </DialogContent>
    <DialogActions>
        <MudStack Row="true" Spacing="2" Class="pa-4 pt-0">
            <MudButton @onclick="Reject" 
                       Variant="Variant.Outlined" 
                       Color="Color.Default" 
                       Class="rounded-pill px-6">Cancel</MudButton>
            <MudButton Disabled="@_busy" 
                       @onclick="Approve" 
                       Variant="Variant.Filled" 
                       Color="@(model.AuthLevelID == 100 ? Color.Error : Color.Success)" 
                       StartIcon="@(model.AuthLevelID == 100 ? Icons.Material.Filled.Close : Icons.Material.Filled.Check)"
                       Class="rounded-pill px-8">
                @if(_busy)
                {
                    <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true"/>
                    <MudText Class="ms-2">Processing...</MudText>
                }
                else
                {
                    @btn_txt1
                }
            </MudButton>
        </MudStack>
    </DialogActions>
</MudDialog>

    @code {

    [CascadingParameter] IMudDialogInstance MudDialog { get; set; }
    [Parameter]
    public DataAuthorizationModel model { get; set; }
    [Parameter]
    public bool ApproveWithin { get; set; }

    public string btn_txt1 = "Verify";
    public string btn_txt2 = "Cancel";
    public bool IsApprove = false;
    public bool _busy;

    protected override void OnInitialized()
    {
        if (model.AuthLevelID == 99)
        {
            btn_txt1 = "Approve";
            IsApprove = true;
        }
        else if(model.AuthLevelID == 100)
        {
            btn_txt1 = "Reject";
        }
        if (model.UserInfo == null)
        {
            model.UserInfo = new();
        }
    }

    private void Reject()
    {
        MudDialog.Cancel();
    }

    public async Task Approve()
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is being submitted!", Severity.Warning);
            return;
        }
        _busy = true;

        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;
        model.UserInfo.UserID = user.Identity.Name;
        DataApprovedStatus aprvd = new DataApprovedStatus();
        aprvd.IsApprove = IsApprove;
        aprvd.AuthLevelID = model.AuthLevelID.Value;
        aprvd.Remarks = model.Remarks;
        try
        {
            CancellationTokenSource ctc = new CancellationTokenSource();
            var Permission = await Irole.HasClaim(model.DocTypeID.ToString(), model.ClaimValue , ctc.Token);

            if (Permission)
            {
                if (!IsApprove)
                {
                    Iservice.Update(model);
                    snackbar.Add("Verified Successfully", Severity.Success);
                }
                else if (ApproveWithin)
                {
                    Iservice.Update(model);
                    snackbar.Add("Approved Successfully", Severity.Success);
                }
                model = new();
                MudDialog.Close(aprvd);
            }
            else
            {
                snackbar.Add("Permission Denied!", Severity.Warning);
            }
        }
        catch (Exception ex)
        {
            snackbar.Add(ex.Message, Severity.Warning);
        }
        await Task.Delay(200);
        _busy = false;
    }
}
