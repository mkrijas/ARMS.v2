

<MudGrid>
    <MudItem xs="12" md="6">
        <MudTextField MaxLength="18" @bind-Value="BankAccount.BeneficiaryName" Label="Beneficiary Name" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => BankAccount.BeneficiaryName)" />
    </MudItem>
    <MudItem xs="12" md="6">
        <MudNumericField HideSpinButtons MaxLength="18" @bind-Value="BankAccount.AccountNumber" Label="Account Number" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => BankAccount.AccountNumber)" />
     </MudItem>
     <MudItem xs="12" md="6">
         <MudTextField MaxLength="11" @bind-Value="BankAccount.IfscCode" Label="IFSC Code" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => BankAccount.IfscCode)" />
     </MudItem>
     <MudItem xs="12" md="6">
         <MudTextField MaxLength="9" @bind-Value="BankAccount.MicrCode" Label="MICR Code" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => BankAccount.MicrCode)" />
     </MudItem>
     <MudItem xs="12" md="6">
         <MudTextField MaxLength="8" @bind-Value="BankAccount.SwiftCode" Label="SWIFT Code" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => BankAccount.SwiftCode)" />
     </MudItem>
     <MudItem xs="12" md="6">
         <MudTextField @bind-Value="BankAccount.BankTitle" Label="Bank Name" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => BankAccount.BankTitle)" />
     </MudItem>
     <MudItem xs="12" md="6">
         <MudTextField @bind-Value="BankAccount.BankBranch" Label="Bank Branch" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => BankAccount.BankBranch)" />
     </MudItem>
 </MudGrid>

 @code {

    [Parameter]
    public BankAccountModel BankAccount { get; set; }


}
