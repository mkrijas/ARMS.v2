@using Views.Pages.FMS.InsuranceClaim
@using Views.Pages.FMS.Jobcard
@attribute [Authorize]
@inject AuthenticationStateProvider auth
@inject IBreakdownService IBreakdown
@inject IAssetService Iasset
@inject IDialogService DialogService
@inject MudBlazor.ISnackbar snackbar
@inject NavigationManager nav

<div class="admin-glass-card pa-0 overflow-hidden mb-4 @(MainModel.IsClaimInitiated ? "opacity-90" : "")">
    <div class="px-6 py-4 border-bottom-subtle d-flex align-center justify-space-between" style="background: rgba(var(--mud-palette-primary-rgb), 0.05);">
        <div class="d-flex align-center">
            <div class="icon-badge primary-badge-soft mr-3">
                <MudIcon Icon="@Icons.Material.Filled.Assignment" Size="Size.Small" />
            </div>
            <div>
                <MudText Typo="Typo.subtitle1" Class="fw-700">@MainModel.BreakdownNumber</MudText>
                <div class="d-flex align-center opa-60">
                    <MudIcon Icon="@Icons.Material.Filled.LocalShipping" Size="Size.Small" Class="mr-1" />
                    <MudText Typo="Typo.caption" Class="fw-600">@MainModel.RegNo</MudText>
                </div>
            </div>
        </div>
        <div class="d-flex align-center gap-4">
            <div class="d-flex align-center">
                <MudIcon Icon="@Icons.Material.Filled.History" Size="Size.Small" Class="mr-1 opa-50" />
                <MudText Typo="Typo.caption" Class="fw-600">@MainModel.BreakdownTime</MudText>
            </div>
            <div class="d-flex align-center">
                <MudIcon Icon="@Icons.Material.Filled.Phone" Size="Size.Small" Class="mr-1 opa-50" />
                <MudText Typo="Typo.caption" Class="fw-600">@MainModel.ContactNumber</MudText>
            </div>
        </div>
    </div>

    <div class="pa-6">
        <MudGrid Spacing="3" Class="align-end">
            <MudItem xs="12" md="4">
                <MudText Typo="Typo.caption" Class="admin-section-label mb-2 d-block">Incident Classification</MudText>
                <MudSelect T="string" Value="BreakdownType" ValueChanged="UpdateBreakdown" Variant="Variant.Outlined" Margin="Margin.Dense" Class="modern-input" AnchorOrigin="Origin.BottomCenter" AdornmentColor="Color.Primary">
                    @foreach (var ditem in BreakdownTypes)
                    {
                        <MudSelectItem Value="@ditem">@ditem</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" md="8">
                <MudText Typo="Typo.caption" Class="admin-section-label mb-2 d-block">Technical Analysis & Narrative</MudText>
                <div class="pa-3 rounded-lg bg-light-surface border-subtle min-h-10">
                    <MudText Typo="Typo.body2">@MainModel.Detail</MudText>
                </div>
            </MudItem>
        </MudGrid>

        <MudDivider Class="my-6 opacity-30" />

        <div class="d-flex align-center justify-space-between">
            <div class="d-flex gap-2">
                @if (!HideControls)
                {
                    <MudButton Disabled="@_busy" Color="Color.Primary" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.AddTask" OnClick="@(()=>CreateJobcard(MainModel))" Class="fw-600">ISSUE JOBCARD</MudButton>
                    <MudButton Disabled="@_busy" Color="Color.Error" Variant="Variant.Text" StartIcon="@Icons.Material.Filled.Close" OnClick="@(()=>RejectBreakdown(MainModel))">REJECT INCIDENT</MudButton>
                    <MudButton Disabled="MainModel.IsClaimInitiated" Color="Color.Info" Variant="Variant.Text" StartIcon="@Icons.Material.Filled.AppRegistration" OnClick="@(()=>BeginInsuranceClaim(MainModel))">INITIATE CLAIM</MudButton>
                }
            </div>
            <MudTooltip Text="Generate Analysis Report">
                <MudIconButton OnClick="@(()=> PrintJobRequest(MainModel.BreakdownID))" Color="Color.Secondary" Icon="@Icons.Material.Filled.Print" Size="Size.Small" Variant="Variant.Outlined" Class="rounded-lg" />
            </MudTooltip>
        </div>

        <div class="mt-6">
            <MudExpansionPanels Elevation="0" Class="border-subtle rounded-lg overflow-hidden">
                <MudExpansionPanel HideIcon="false" Class="pa-0">
                    <TitleContent>
                        <div class="d-flex align-center">
                            <MudIcon Icon="@Icons.Material.Filled.Calculate" Size="Size.Small" Class="mr-2 opa-60" />
                            <MudText Typo="Typo.subtitle2" Class="fw-700">Financial Estimates (@MainModel.EstimateList.Count)</MudText>
                        </div>
                    </TitleContent>
                    <ChildContent>
                        <div class="pa-2">
                            <MudTable Items="@MainModel.EstimateList" Elevation="0" Dense="true" Hover="true" Class="modern-admin-table border-none">
                                <HeaderContent>
                                    <MudTh>DESCRIPTION</MudTh>
                                    <MudTh>AMOUNT</MudTh>
                                    <MudTh>EVIDENCE</MudTh>
                                    <MudTh Style="text-align: right;">AUDIT STATUS</MudTh>
                                </HeaderContent>
                                <RowTemplate Context="est">
                                    <MudTd DataLabel="Description">@est.Description</MudTd>
                                    <MudTd DataLabel="Amount"><span class="fw-700">@est.Amount</span></MudTd>
                                    <MudTd DataLabel="Evidence">
                                        @if (est.ImagePath == null)
                                        {
                                            <MyFileUpload FileName="@Guid.NewGuid().ToString()" FolderName="BreakdownEst" Label="ATTACH DOCUMENT" FilePath="@est.ImagePath" FilePathChanged="((e)=> SaveImagePath(est, e))" AcceptOnlyPdf="true"></MyFileUpload>
                                        }
                                        else
                                        {
                                            <div class="d-flex align-center">
                                                <MudIconButton Icon="@Icons.Material.Filled.Download" Color="Color.Primary" Size="Size.Small" Href="@est.ImagePath" Target="_blank" />
                                                @if (!ReadOnly)
                                                {
                                                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small" OnClick="@(e => Remove(est))" />
                                                }
                                            </div>
                                        }
                                    </MudTd>
                                    <MudTd DataLabel="Status" Style="text-align: right;">
                                        @if (est.UserInfo.RecordStatus != 3)
                                        {
                                            <div class="d-flex justify-end gap-1">
                                                <MudButton OnClick="@(e => Approve(est))" Variant="Variant.Text" Color="Color.Success" Size="Size.Small">APPROVE</MudButton>
                                                <MudButton OnClick="@(e => Delete(est))" Variant="Variant.Text" Color="Color.Error" Size="Size.Small">DELETE</MudButton>
                                            </div>
                                        }
                                        else
                                        {
                                            <div class="d-flex flex-column align-end">
                                                <MudChip T="string" Color="Color.Success" Size="Size.Small" Variant="Variant.Text" Class="fw-700 ma-0">VERIFIED</MudChip>
                                                <span class="small opa-50">BY @est.ApprovedUserID</span>
                                            </div>
                                        }
                                    </MudTd>
                                </RowTemplate>
                            </MudTable>

                            @if (!ReadOnly)
                            {
                                <div class="pa-4 mt-2 bg-light-surface rounded-lg border-2 border-dashed">
                                    <MudGrid Spacing="2" Class="align-center">
                                        <MudItem xs="12" md="4">
                                            <MudTextField T="string" @bind-Text="model.Description" Label="Specify Component/Work" Variant="Variant.Outlined" Margin="Margin.Dense" Class="modern-input" />
                                        </MudItem>
                                        <MudItem xs="12" md="3">
                                            <MudNumericField HideSpinButtons @bind-Value="model.Amount" Label="Valuation" Variant="Variant.Outlined" Margin="Margin.Dense" Class="modern-input" Adornment="Adornment.Start" AdornmentText="$" />
                                        </MudItem>
                                        <MudItem xs="12" md="3">
                                            @if (model.ImagePath == null)
                                            {
                                                <MyFileUpload FileName="@Guid.NewGuid().ToString()" FolderName="BreakdownEst" Label="ATTACH DOCUMENT" FilePath="@model.ImagePath" FilePathChanged="((e)=> SaveImagePath(model, e))" AcceptOnlyPdf="true" />
                                            }
                                            else
                                            {
                                                <div class="d-flex align-center justify-center">
                                                    <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" Size="Size.Small" />
                                                    <MudText Typo="Typo.caption" Class="ml-1 fw-600">Attached</MudText>
                                                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small" OnClick="@(e => Remove(model))" />
                                                </div>
                                            }
                                        </MudItem>
                                        <MudItem xs="12" md="2" Class="d-flex justify-end">
                                            <MudIconButton OnClick="@(e => SaveEst(MainModel, model))" Color="Color.Success" Icon="@Icons.Material.Filled.Save" Variant="Variant.Filled" />
                                        </MudItem>
                                    </MudGrid>
                                </div>
                            }
                        </div>
                    </ChildContent>
                </MudExpansionPanel>
            </MudExpansionPanels>
        </div>
    </div>
</div>

@code {

    [Parameter]
    public BreakdownModel MainModel { get; set; }
    [Parameter]
    public bool HideControls { get; set; } = false;
    [Parameter]
    public bool ReadOnly { get; set; }
    [Parameter]
    public EventCallback OnBreakdownRejected { get; set; }
    private EstimateListModel model = new();
    private List<EstimateListModel> EstListModel = new();
    private bool _busy;
    private string BreakdownType;

    private List<string> BreakdownTypes = new()
    { "Accident Claim", "Accident Non Claim", "Work Order", "General Service", "FC Work", "Periodic Service", "Special Work" , "Tyre Work", "Engine Work", "Body Work", "Gear Box Work", "Differential Work", "Clutch Work", "Battery"};


    protected override async Task OnInitializedAsync()
    {
        EstListModel = IBreakdown.SelectEstimate(MainModel.BreakdownID).ToList();
        MainModel.EstimateList = EstListModel;
        BreakdownType = MainModel.BreakdownType;
    }

    private void UpdateBreakdown(string obj)
    { 
        BreakdownType = obj;
        MainModel.BreakdownType = BreakdownType;
        MainModel = IBreakdown.Update(MainModel); 
    }

    public async Task Approve(EstimateListModel a)
    {
        if (a.Description == null || a.Description == "")
        {
            snackbar.Add("Description is mandatory !", Severity.Error);
            return;
        }
        if (a.Amount == null)
        {
            snackbar.Add("Estimate Amount is mandatory !", Severity.Error);
            return;
        }
        if (a.ImagePath == null)
        {
            snackbar.Add("File is mandatory !", Severity.Error);
            return;
        }
        try
        {
            var authProvider = await auth.GetAuthenticationStateAsync();
            string UserID = authProvider.User.Identity.Name;
            var result = IBreakdown.ApproveEstimate(a.ID, UserID);
            if (result == 1)
            {
                var estimatelistItem = MainModel.EstimateList.FirstOrDefault(e => e.ID == a.ID);
                estimatelistItem.ApprovedUserID = UserID;
                estimatelistItem.UserInfo.RecordStatus = 3;
                snackbar.Add("Approved Successfully.", Severity.Success);
            }
        }
        catch (Exception ex)
        {
            snackbar.Add(ex.Message, Severity.Error);
        }
    }

    public async Task Delete(EstimateListModel a)
    {
        try
        {
            var authProvider = await auth.GetAuthenticationStateAsync();
            string UserID = authProvider.User.Identity.Name;
            var result = IBreakdown.DeleteEstimate(a.ID, UserID);
            if (result == 1)
            {
                var estimatelistItem = MainModel.EstimateList.FirstOrDefault(e => e.ID == a.ID);
                MainModel.EstimateList.Remove(estimatelistItem);
                snackbar.Add("Deleted Successfully.", Severity.Success);
            }
        }
        catch (Exception ex)
        {
            snackbar.Add(ex.Message, Severity.Error);
        }
    }

    public async Task Remove(EstimateListModel a)
    {
        try
        {
            var authProvider = await auth.GetAuthenticationStateAsync();
            string UserID = authProvider.User.Identity.Name;
            a.ImagePath = null;
            if (a.ID != null)
            {
                var result = IBreakdown.RemoveEstimate(a.ID, UserID);
            }
            snackbar.Add("Image Removed Successfully.", Severity.Success);
        }
        catch (Exception ex)
        {
            snackbar.Add(ex.Message, Severity.Error);
        }
    }

    public async Task SaveEst(BreakdownModel a, EstimateListModel b)
    {
        if (b.Description == null || b.Description == "")
        {
            snackbar.Add("Description is mandatory !", Severity.Error);
            return;
        }
        if (b.Amount == null)
        {
            snackbar.Add("Estimate Amount is mandatory !", Severity.Error);
            return;
        }
        if (b.ImagePath == null)
        {
            snackbar.Add("File is mandatory !", Severity.Error);
            return;
        }
        try
        {
            var authProvider = await auth.GetAuthenticationStateAsync();
            string UserID = authProvider.User.Identity.Name;
            b.UserInfo.UserID = UserID;
            b.BreakdownID = a.BreakdownID;
            model = IBreakdown.UpdateEstimate(b);
            a.EstimateList.Add(model);
            model = new();
        }
        catch (Exception ex)
        {
            snackbar.Add(ex.Message, Severity.Error);
        }
    }

    private async Task SaveImagePath(EstimateListModel a, string filePath)
    {
        try
        {
            @if (filePath != null)
            {
                @if (a.ID != null)
                {
                    var authProvider = await auth.GetAuthenticationStateAsync();
                    string UserID = authProvider.User.Identity.Name;
                    a.ImagePath = filePath;
                    var result = IBreakdown.AddImgEstimate(a.ID, filePath, UserID);
                    snackbar.Add("Image Saved Successfully.", Severity.Success);
                }
                else
                {
                    model.ImagePath = filePath;
                }
            }
            else
            {
                snackbar.Add("File Error", Severity.Error);
            }
            StateHasChanged();
        }
        catch (Exception ex)
        {
            snackbar.Add(ex.Message, Severity.Error);
        }
    }

    private async Task CreateJobcard(BreakdownModel Breakdown)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        _busy = true;
        var parameters = new DialogParameters();
        parameters.Add("Breakdown", Breakdown.Clone());
        DialogOptions maxWidth = new DialogOptions() { MaxWidth = MaxWidth.Medium, FullWidth = true };
        var dialog = await DialogService.ShowAsync<CreateJobcardDialog>("Initiate Jobcard", parameters, maxWidth);
        var result = await dialog.Result;
        if (!result.Canceled)
        {
            JobcardModel jobcard = (JobcardModel)result.Data;
            nav.NavigateTo("jobcard/" + jobcard.TruckID);
        }
        await Task.Delay(200);
        _busy = false;
    }
    
    private async Task RejectBreakdown(BreakdownModel Breakdown)
    {
        bool? result = await DialogService.ShowMessageBoxAsync(
            "Warning !",
            "Are you sure, you want to reject work order - " + Breakdown.RegNo + " ?");

        if (result == true)
        {
            var authprov = await auth.GetAuthenticationStateAsync();
            var user = authprov.User;
            IBreakdown.RejectBreakdown(Breakdown.BreakdownID, user.Identity.Name);
            snackbar.Add("Rejected Successfully", Severity.Success);

            // Notify parent that the breakdown was rejected
            await OnBreakdownRejected.InvokeAsync(null);
        }
    }

    private async Task BeginInsuranceClaim(BreakdownModel Breakdown)
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        _busy = true;
        InsuranceClaimModel model = new() { IsOpen = true };
        var asset = Iasset.SelectByTruckID(Breakdown.TruckID);
        model.TruckRegNo = Breakdown.RegNo;
        model.BreakdownID = Breakdown.BreakdownID;
        model.Asset = asset;
        InsuranceClaimModel Model = model;
        var parameters = new DialogParameters();
        parameters.Add("Model", Model.Clone());
        parameters.Add("ReadOnly", false);
        parameters.Add("Jobcard", true);
        DialogOptions maxWidth = new DialogOptions() { MaxWidth = MaxWidth.Medium, FullWidth = true };
        var dialog = await DialogService.ShowAsync<ClaimDialog>("Initiate Claim", parameters, maxWidth);
        var result = await dialog.Result;
        if (!result.Canceled)
        {
            model = (InsuranceClaimModel)result.Data;
            Breakdown.IsClaimInitiated = true;
        }
        model = new();
        await Task.Delay(200);
        _busy = false;
    }

    public Dictionary<string, string> ReportParameters { get; set; } = new();

    private async Task PrintJobRequest(int? BreakdownID)
    {
        ReportParameters.Clear();
        ReportParameters.Add("BreakDownID", BreakdownID.ToString());
        var parameters = new DialogParameters();
        parameters.Add("Parameters", ReportParameters); // Add the dictionary as a parameter
        parameters.Add("ReportName", "PrintJobRequestForm");

        DialogOptions maxWidth = new DialogOptions() { MaxWidth = MaxWidth.Medium, FullWidth = true };
        var result = await DialogService.ShowAsync<PrintDialog>("PRINT", parameters, maxWidth);
    }
}
