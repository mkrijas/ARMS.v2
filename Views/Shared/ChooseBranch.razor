@inject IUserService iservice
@inject AuthenticationStateProvider auth



<MudDialog >
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.SelectAll" Class="mr-3 mb-n1" />
            Select Branch
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudList Clickable="true" @bind-SelectedItem="@listItem">
            @foreach (UserBranchRoleModel item in branches)
            {
                <MudListItem Text="@item.Branch.BranchName" Icon="@Icons.Material.Filled.Inbox"  />
            }
        </MudList>
    </DialogContent>
    <DialogActions>        
        <MudButton Color="Color.Error" OnClick="SetBranchRole">Enter</MudButton>
    </DialogActions>
</MudDialog>



@code {
    [CascadingParameter] MudDialogInstance MudDialog { get; set; }

    [Parameter]
    public string BranchName { get; set; }

    MudListItem listItem;

    private List<UserBranchRoleModel> branches = new();

    protected override async Task OnInitializedAsync()
    {       
        var authprov = await auth.GetAuthenticationStateAsync();

        branches = iservice.GetBranchesNRoles(authprov.User.Identity.Name).ToList();
    }   

    private void SetBranchRole()
    {
        if (listItem != null)
        {
            UserBranchRoleModel model = branches.Find(x => x.Branch.BranchName == listItem?.Text);
            MudDialog.Close(DialogResult.Ok(model));
        }
    }
}
