@inject IUserService iservice




<MudDialog >
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.SelectAll" Class="mr-3 mb-n1" />
            Select Branch
        </MudText>
    </TitleContent>
    <DialogContent>        
        <MudList Clickable="true" SelectedItem="@listItem" SelectedItemChanged="SetBranchRole">
            @foreach (UserBranchRoleModel item in branches)
            {
                <MudListItem Value="@item" Text="@item.Branch.BranchName" Icon="@Icons.Material.Filled.Inbox"  />
            }
        </MudList>
        @if(branches == null || !branches.Any())
        {
            <MudText Color="Color.Error"><p>No branches allocated please contact admin.</p></MudText>
        }
    </DialogContent>   
</MudDialog>



@code {
    [CascadingParameter] MudDialogInstance MudDialog { get; set; }

    [Parameter]
    public string UserID { get; set; }

    public string BranchName { get; set; }

    MudListItem listItem;

    private List<UserBranchRoleModel> branches = new();

    protected override  void OnInitialized()
    {
        branches = iservice.GetBranchesNRoles(UserID).ToList();
        if(branches.Count == 1)
        {
            MudDialog.Close(DialogResult.Ok(branches.First()));
        }
    }

    private void SetBranchRole(MudListItem item)
    {
        listItem = item;
        if (listItem != null)
        {
            UserBranchRoleModel model = (UserBranchRoleModel)listItem?.Value;
            MudDialog.Close(DialogResult.Ok(model));
        }
    }
}
