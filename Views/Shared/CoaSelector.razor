@inject IChartOfAccountService accountService

@if(IsLoaded)
{
    <MudAutocomplete Class="@Class"  T="ChartOfAccountModel" Variant="Variant.Outlined" Margin="Margin.Dense" Label="@Label" @bind-Value="Value" ResetValueOnEmptyText="true"
         Clearable="true"  SearchFunc="SearchAccounts" Text="@Value?.AccountName" ToStringFunc="@(e => (e == null || string.IsNullOrEmpty(e.AccountName)) ? null : $"{e.AccountName+" | "+e.AccountCode}")"></MudAutocomplete>

}
else
{
   <MudText> Loading..... </MudText> 
}
@code {
    private List<ChartOfAccountModel> accountList = new();    

    [Parameter]
    public ChartOfAccountModel Value
    {
        get => _value;
        set
        {
            if (_value == value) return;
            _value = value;
            ValueChanged.InvokeAsync(value);
        }
    }

    [Parameter]
    public EventCallback<ChartOfAccountModel> ValueChanged { get; set; }

    [Parameter]
    public string Class { get; set; }

    [Parameter]
    public string Label { get; set; } = "Select Account";

    private ChartOfAccountModel _value;
    private bool IsLoaded = false;
    

     private async Task<IEnumerable<ChartOfAccountModel>> SearchAccounts(string searchString)
    {
        await Task.Delay(3);

        return accountList.Where(x => (x.AccountName +" "+x.AccountCode).Contains(searchString == null ? string.Empty : searchString, StringComparison.InvariantCultureIgnoreCase));
    }
   

    protected override void OnInitialized()
    {
        accountList = accountService.FilterSubLedgers(string.Empty).ToList();
        IsLoaded = true;
    }
}
