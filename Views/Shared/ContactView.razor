<MudDivider DividerType="DividerType.Inset" />
@if (@Index != null)
{
    <b>Contact @(Index+1)</b>
}
<MudGrid Spacing="4">
    <MudItem md="6">
        <MudTextField Label="Contact Name" @bind-Value="Model.ContactName" Variant="Variant.Outlined" For="@(() => Model.ContactName)"></MudTextField>        
    </MudItem>
    <MudItem md="6">
        <MudTextField Label="Reference" @bind-Value="Model.AdditionalInfo" Variant="Variant.Outlined" For="@(() => Model.AdditionalInfo)"></MudTextField>        
    </MudItem>
    <MudItem md="6">
        <MudNumericField HideSpinButtons="true" Label="Phone" @bind-Value="Model.Phone" InputType="InputType.Number"  Variant="Variant.Outlined" For="@(() => Model.Phone)" MaxLength="10"></MudNumericField>        
    </MudItem>
    <MudItem md="6">
        <MudTextField Label="Email" @bind-Value="Model.Email" InputMode = "InputMode.email" Variant="Variant.Outlined"  InputType="InputType.Email" For="@(() => Model.Email)"></MudTextField>        
    </MudItem>
</MudGrid>

@code {

    [Parameter]
    public ContactModel Model { get; set; }

    [Parameter]
    public int? Index { get; set; }

}
