<MudDivider DividerType="DividerType.Inset" />
<b>Contact @(Index+1)</b>
<MudGrid Spacing="4">
    <MudItem>
        <MudTextField Label="Contact Name" @bind-Value="Model.ContactName" Variant="Variant.Outlined" Required></MudTextField>        
    </MudItem>
    <MudItem>
        <MudTextField Label="Reference" @bind-Value="Model.AdditionalInfo" Variant="Variant.Outlined"></MudTextField>        
    </MudItem>
    <MudItem>
        <MudTextField Label="Phone" @bind-Value="Model.Phone" InputType="InputType.Number"  Variant="Variant.Outlined" Required></MudTextField>        
    </MudItem>
    <MudItem>
        <MudTextField Label="Email" @bind-Value="Model.Email" InputMode = "InputMode.email" Variant="Variant.Outlined"  InputType="InputType.Email" Required></MudTextField>        
    </MudItem>
    
</MudGrid>

@code {

    [Parameter]
    public ContactModel Model { get; set; }

    [Parameter]
    public int Index { get; set; }



}
