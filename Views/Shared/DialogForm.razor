@using System.ComponentModel.DataAnnotations
@using Views.Pages.Finance.Transactions
@inject IAccountInfoService Iservice

<MudDialog Class="@(AdminStyle ? "admin-dialog-glass" : "")" @key="TotalAmount">
    <TitleContent>
        @if (AdminStyle)
        {
            <div class="header-section mb-2 pt-4 px-4">
                <div class="d-flex align-center justify-space-between">
                    <div class="d-flex align-center">
                        <div class="icon-badge primary-badge mr-4">
                            <div class="admin-header-icon-badge mb-3">
                                <MudIcon Icon="@Icon" Color="Color.Secondary" Style="font-size: 3rem;" />
                            </div>
                        </div>
                        <div>
                            <MudText Typo="Typo.h5" Class="admin-title"><b>@Title</b></MudText>
                            <MudText Typo="Typo.body2" Class="admin-subtitle">
                                @Subtitle
                            </MudText>
                        </div>
                    </div>

                    <div class="d-flex flex-column align-end" @key="DisplayAmount">
                        <MudText Typo="Typo.caption"
                                 Class="admin-subtitle"
                                 Style="font-weight: 700; text-transform: uppercase; letter-spacing: 1px;">
                            Total Amount
                        </MudText>
                        <MudText Typo="Typo.h5" Style="font-weight: 900; color: #FF9F43;">
                            ₹ @DisplayAmount
                        </MudText>
                    </div>
                </div>

                <div class="title-accent mt-4"></div>
            </div>
        }
        else
        {
            <div class="admin-header-tiered px-8 pt-8 pb-4 text-center">
                <div class="admin-header-icon-badge mb-3">
                    <MudIcon Icon="@Icon" Color="Color.Primary" Style="font-size: 3rem; color: #FF9F43 !important;" />
                </div>
                <MudText Typo="Typo.h5" Style="font-weight: 800; color: #141A46; letter-spacing: -0.5px;">@Title</MudText>
                <MudText Typo="Typo.body2" Style="color: #667085; font-weight: 500;" Class="mt-1">@Subtitle</MudText>
                <div class="header-accent-divider mx-auto mt-4" style="background: linear-gradient(90deg, transparent, #FF9F43, transparent);"></div>
            </div>

            @if (!string.IsNullOrEmpty(DisplayDocNum) || DisplayAmount > 0)
            {
                <div class="d-flex align-center justify-space-between w-100 px-8 pb-4" @key="DisplayAmount">
                    <div class="d-flex align-center">
                        <div>
                            <MudText Typo="Typo.caption" Style="color: #718096; font-weight: 600;">
                                #( @(DisplayDocNum ?? "NEW") ) @(!string.IsNullOrEmpty(DisplayStatus) ? "•" : "") <span style="color: #4caf50;">@DisplayStatus</span>
                            </MudText>
                        </div>
                    </div>
                    <div class="text-right d-none d-md-block">
                        <MudText Typo="Typo.caption" Style="color: var(--admin-text-muted); font-weight: 800; text-transform: uppercase; letter-spacing: 1px;">
                            TOTAL AMOUNT
                        </MudText>
                        <MudText Typo="Typo.h5" Style="font-weight: 900; color: #FF9F43;">
                            ₹ @(string.Format("{0:N1}", DisplayAmount))
                        </MudText>
                    </div>
                </div>
            }

            <ReverseInfoComponent DocumentDetails="DocumentDetails"></ReverseInfoComponent>
        }
    </TitleContent>

    <DialogContent>
        <MudContainer Class="@(AdminStyle ? "admin-dialog-container" : "dialogInset")">
            @FormContent

            @if (ReadOnly && VerificationStatus != null)
            {
                @VerificationStatus
            }

            @if (ShowAccountInfo && ReadOnly && model is TransactionBaseModel baseModel && baseModel.MID != null)
            {
                <AccountInfoDialog MID="@baseModel.MID"></AccountInfoDialog>
                @if (TdsMID != null)
                {
                    <MudDivider DividerType="DividerType.Middle" Class="my-3"></MudDivider>
                    <AccountInfoDialog MID="@TdsMID"></AccountInfoDialog>
                }
            }
        </MudContainer>
    </DialogContent>

    <DialogActions>
        <div class="d-flex w-100 px-4 pb-4 align-center gap-3">
            @if (ShowFileUpload && model is TransactionBaseModel baseModel)
            {
                <FileUpload_multiple FolderName="FinanceDocuments"
                                     FileName="@Guid.NewGuid().ToString()"
                                     OnFileRemoved="RemoveFileChange"
                                     model="@baseModel"
                                     ReadOnly="@ReadOnly">
                </FileUpload_multiple>
            }

            @if (!ReadOnly && Actions != null)
            {
                @Actions
            }

            <MudSpacer></MudSpacer>

            @if (ReadOnly)
            {
                <MudButton Variant="Variant.Outlined"
                           Color="Color.Default"
                           OnClick="Cancel"
                           Style="border-radius: 12px; font-weight: 700; text-transform: none;">
                    Close
                </MudButton>
            }
            else
            {
                <MudButton @onclick="Cancel"
                           Variant="Variant.Outlined"
                           Color="Color.Default"
                           Style="@(AdminStyle ? "border-radius: 12px; font-weight: 700; text-transform: none; border-color: rgba(0,0,0,0.15);" : "border-radius: 6px; font-weight: 700; text-transform: none; border-color: rgba(0,0,0,0.15);")">
                    Cancel
                </MudButton>

                <MudButton Disabled="@_busy"
                           form="@formID"
                           Variant="Variant.Filled"
                           ButtonType="ButtonType.Submit"
                           Color="Color.Success"
                           Style="@(AdminStyle ? "background: var(--mud-palette-success); color: white; font-weight: 800; border-radius: 12px; text-transform: none; white-space: nowrap; padding: 8px 24px;" : "background: #FF9F43; color: white; font-weight: 800; border-radius: 6px; text-transform: none; white-space: nowrap; padding: 8px 24px;")"
                           StartIcon="@Icons.Material.Filled.DoneAll">
                    @SubmitText
                </MudButton>
            }
        </div>
    </DialogActions>
</MudDialog>

<style>
    :root {
        --dialog-bars-height: 260px;
    }

    .dialogInset {
        margin-top: 10px;
        padding: 24px;
        max-height: calc(100vh - var(--dialog-bars-height));
        overflow-y: auto;
        overflow-x: hidden;
        background-color: transparent;
        border-radius: 0 0 24px 24px;
    }

    .admin-dialog-container {
        padding: 0 0px 0px 0px;
        max-height: calc(100vh - 280px);
        overflow-y: auto;
        overflow-x: hidden;
    }

    .admin-dialog-glass {
        background: rgba(255, 255, 255, 0.8) !important;
        backdrop-filter: blur(20px) !important;
        -webkit-backdrop-filter: blur(20px) !important;
        border-radius: 32px !important;
    }

    .admin-title {
        font-family: 'Outfit', sans-serif;
        font-weight: 800;
        color: #141A46;
        letter-spacing: -0.5px;
    }

    .admin-subtitle {
        color: #667085;
        font-weight: 500;
    }

    .title-accent {
        width: 100%;
        height: 1px;
        background: linear-gradient(90deg, #367588 0%, rgba(54, 117, 136, 0.3) 100%);
    }

    .icon-badge {
        width: 48px;
        height: 48px;
        border-radius: 14px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .primary-badge {
        background: rgba(54, 117, 136, 0.3);
        color: #367588;
    }
</style>

@code {

    [Parameter]
    public bool AdminStyle { get; set; } = false;

    [Parameter]
    public string Subtitle { get; set; }

    [Parameter]
    public string Icon { get; set; } = Icons.Material.Filled.ReceiptLong;

    [CascadingParameter]
    IMudDialogInstance MudDialog { get; set; }

    [Parameter]
    public string Title { get; set; }

    [Parameter]
    public string formID { get; set; }

    [Parameter]
    public bool ReadOnly { get; set; }

    [Parameter]
    public EventCallback<bool> OnFileRemoved { get; set; }

    [Parameter]
    public TransactionBaseModel model { get; set; }

    [Parameter]
    public string DocumentNumber { get; set; }

    [Parameter]
    public string AuthStatus { get; set; }

    [Parameter]
    public bool ShowFileUpload { get; set; } = true;

    [Parameter]
    public bool ShowAccountInfo { get; set; } = true;

    [Parameter]
    public RenderFragment Actions { get; set; }

    [Parameter]
    public RenderFragment FormContent { get; set; }

    [Parameter]
    public RenderFragment VerificationStatus { get; set; }

    [Parameter]
    public bool _busy { get; set; } = false;

    [Parameter]
    public string SubmitText { get; set; } = "Submit";

    [Parameter]
    public EventCallback<EditContext> OnSubmit { get; set; }

    [Parameter]
    public decimal? TotalAmount { get; set; }

    [Parameter]
    public DocumentInfoModel DocumentDetails { get; set; } = new();

    private string DisplayDocNum =>
        !string.IsNullOrEmpty(DocumentNumber)
            ? DocumentNumber
            : model?.DocumentNumber;

    private decimal DisplayAmount =>
        TotalAmount ?? (model?.TotalAmount ?? 0);

    private string DisplayStatus =>
        !string.IsNullOrEmpty(AuthStatus)
            ? AuthStatus
            : model?.AuthStatus;

    private ValidationMessageStore messageStore;
    private int? TdsMID;

    protected override void OnInitialized()
    {
        if (model is TransactionBaseModel baseModel)
        {
            TdsMID = Iservice.GetTdsMID(baseModel.MID);
        }
    }

    public async Task RemoveFileChange(bool val)
    {
        await OnFileRemoved.InvokeAsync(true);
    }

    public void Close(object obj)
    {
        MudDialog.Close(obj);
    }

    public void Cancel() => MudDialog.Cancel();

    public void Refresh()
    {
        InvokeAsync(StateHasChanged);
    }

    public bool validate(object obj, EditContext editContext)
    {
        messageStore?.Clear();
        messageStore = new(editContext);

        var context = new ValidationContext(obj, serviceProvider: null, items: null);
        var validationResults = new List<ValidationResult>();
        bool isValid = Validator.TryValidateObject(obj, context, validationResults, true);

        if (!isValid)
        {
            foreach (var i in validationResults)
            {
                messageStore.Add(() => i.MemberNames, i.ErrorMessage);
            }

            editContext.NotifyValidationStateChanged();
            return false;
        }

        messageStore.Clear();
        return true;
    }
}