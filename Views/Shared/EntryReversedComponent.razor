@using Core.BaseModels.Finance;
@using Core.IDataServices.Finance;
@inject AuthenticationStateProvider auth
@inject SignalRService signalRService
@inject IPushNotificationService IpushNotificationService
@inject IDialogService DialogService
@inject MudBlazor.ISnackbar snackbar
@inject IReverseEntryService IreverseEntryService
@attribute [Authorize]

@if (IsReversed != null && !(IsReversed.Value))
{
    <MudIconButton @onclick="@(()=> ReverseTransactionDialogOpen())" Color="Color.Error" Title="Reverse Entry" Icon="@Icons.Material.Filled.ArrowBack" Size="Size.Small" Class="ml-2" Variant="Variant.Filled" />
}

@code {

    [Parameter]
    public int? DocTypeID { get; set; }
    [Parameter]
    public int? DocumentID { get; set; }
    [Parameter]
    public int? MID { get; set; }
    [Parameter]
    public string DocumentNumber { get; set; }

    //[Parameter]
    //public string PageToRedirectLink { get; set; }
    //[Parameter]
    //public string DocNumber { get; set; }
    //[Parameter]
    //public DateTime? DocDate { get; set; }
    //[Parameter]
    //public string DocType { get; set; }

    public int BranchID { get; set; }
    public string UserID { get; set; }
    private bool _busy;
    public bool? IsReversed = false;

    // [Inject] IDialogService DialogService { get; set; }
    [Parameter]
    public decimal? TDS { get; set; }
    private bool showEntryReversedComponent = false;

    //#region SignaIR Notification
    //private IEnumerable<PushNotificationModel> allNotificationMessages = null;
    //private List<PushNotificationModel> currentNotificationMessages = new List<PushNotificationModel>();
    //private PushNotificationModel notificationMessage = new PushNotificationModel();
    //#endregion

    protected override async Task OnInitializedAsync()
    {

        GetAll();
        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;
        BranchID = int.Parse(user.Claims.First(x => x.Type == "BranchID").Value);
        UserID = user.Identity.Name;
        IsReversed = IreverseEntryService.IsAlreadyReversed(DocumentID, DocTypeID);

        //allNotificationMessages = IpushNotificationService.SelectUnAknowledgedAndNonTimeElapsedNotifications(BranchID).ToList();
        //currentNotificationMessages = allNotificationMessages.Where(y => (y?.ReceivedBranch?.BranchID ?? 0) == BranchID).ToList();

        // await signalRService.StartAsync();
    }

    private void GetAll()
    {

    }

    private async void ReverseTDS()
    {
        // Your logic to reverse TDS
        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;
        UserID = user.Identity.Name;
        var ReturnData = new CancellationReasonCodesByDocumentType();
        ReturnData.MID = MID;
        ReturnData.DocumentID = DocumentID;
        ReturnData.DocumentNumber = DocumentNumber;
        ReturnData.UserInfo = new ArmsModels.SharedModels.UserInfoModel();
        ReturnData.UserInfo.UserID = UserID;
        ReturnData.DocumentTypeID = DocTypeID;
        var resultSub = IreverseEntryService.TDSReverseUpdate(ReturnData);
        if (resultSub != null)
        {
            snackbar.Add("Reversed successfully!", Severity.Success);
            IsReversed = true;
            return;
        }

    }

    private async Task ShowDialog()
    {
        var parameters = new DialogParameters();
        parameters.Add("ContentText", "Do you want to reverse TDS?");
        parameters.Add("ButtonText", "Yes");
        parameters.Add("Color", Color.Primary);
        var options = new DialogOptions()
            {
                CloseButton = true,
                MaxWidth = MaxWidth.Small,
                FullWidth = true
            };
        var dialog = DialogService.Show<ConfirmDialog>("Confirm", parameters, options);
        var result = await dialog.Result;
        if (!result.Cancelled)
        {
            ReverseTDS();
            showEntryReversedComponent = true;
        }
    }

    private async Task ReverseTransactionDialogOpen()
    {
        if (_busy)
        {
            snackbar.Add("Please wait while form is closing!", Severity.Warning);
            return;
        }
        _busy = true;
        try
        {

            DialogOptions maxWidth = new DialogOptions() { MaxWidth = MaxWidth.Large, FullWidth = true, ClassBackground = "blur" };
            DialogParameters parms = new DialogParameters();
            parms.Add("DocumentTypeID", DocTypeID);
            parms.Add("DocumentNumber", DocumentNumber);
            var dialog = DialogService.Show<ReverseTransactionDialog>("Reverse Transaction", parms, maxWidth);
            var result = await dialog.Result;
            var isCancelled = result.Canceled;
            if (!isCancelled)
            {
                var ReturnData = (CancellationReasonCodesByDocumentType)result.Data;
                ReturnData.MID = MID;
                ReturnData.DocumentID = DocumentID;
                ReturnData.DocumentNumber = DocumentNumber;
                var resultSub = IreverseEntryService.Update(ReturnData);
                if (resultSub != null)
                {
                    decimal tdsValue = TDS ?? 0;
                    if (tdsValue != 0)
                    {
                        ShowDialog();
                    }
                    snackbar.Add("Reversed successfully!", Severity.Success);
                    IsReversed = true;
                    return;
                }
            }
        }
        catch (Exception ex)
        {
            snackbar.Add(ex.Message, Severity.Warning);
        }
        //await GetAll(IsApproved, NumberOfRecords);

        await Task.Delay(200);
        _busy = false;
    }
}