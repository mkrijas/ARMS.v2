@using MudBlazor

<div class="info-item-premium pa-4 rounded-xl d-flex flex-column" style="background: rgba(var(--mud-palette-surface-rgb), 0.6); border: 1px solid rgba(var(--mud-palette-primary-rgb), 0.08); backdrop-filter: blur(8px); transition: all 0.3s ease; height: 100%;">
    <MudText Typo="Typo.caption" Style="color: var(--mud-palette-primary); font-weight: 800; text-transform: uppercase; letter-spacing: 1.5px; opacity: 0.6; margin-bottom: 4px; font-size: 0.7rem;">@Label</MudText>
    <MudText Typo="Typo.body1" Class="fw-bold" Style="color: var(--mud-palette-text-primary); font-size: 1.1rem; line-height: 1.2;">@(string.IsNullOrWhiteSpace(Value) ? "—" : Value)</MudText>
</div>

<style>
    .info-item-premium:hover {
        background: rgba(var(--mud-palette-surface-rgb), 0.9);
        border-color: rgba(var(--mud-palette-primary-rgb), 0.2);
        transform: translateY(-2px);
        box-shadow: 0 8px 24px -12px rgba(var(--mud-palette-primary-rgb), 0.3);
    }
</style>

@code {
    [Parameter] public string Label { get; set; }
    [Parameter] public string Value { get; set; }
}
