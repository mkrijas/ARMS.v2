@inject IInventoryItemService itemIservice

@if(IsLoaded)
{
    <MudAutocomplete SelectValueOnTab Class="@Class"  T="InventoryItemModel" Variant="Variant.Outlined" Margin="Margin.Dense" Label="@LabelName" @bind-Value="Value" ResetValueOnEmptyText="true"
         Clearable="true"  SearchFunc="SearchItems" Text="@Value?.InventoryItemCode" ToStringFunc="@(e => (e == null || string.IsNullOrEmpty(e.InventoryItemCode)) ? null : string.Format("{0}",e.InventoryItemCode))"></MudAutocomplete>

}
else
{
   <MudText> Loading..... </MudText> 
}
@code {
    private List<InventoryItemModel> itemsList = new();    

    [Parameter]
    public InventoryItemModel Value
    {
        get => _value;
        set
        {
            if (_value == value) return;
            _value = value;
            ValueChanged.InvokeAsync(value);
        }
    }

    [Parameter]
    public EventCallback<InventoryItemModel> ValueChanged { get; set; }

    [Parameter]
    public string Class { get; set; }

    [Parameter]
    public string LabelName { get; set; }

    [Parameter]
    public int? AccountGroup { get; set; } = 0;// Select Child Accounts under this value


    private InventoryItemModel _value;
    private bool IsLoaded = false;




    private async Task<IEnumerable<InventoryItemModel>> SearchItems(string searchString)
    {
        await Task.Delay(5);
        return itemsList.Where(x => (x.ItemDecription +" "+x.InventoryItemCode).Contains(searchString == null ? string.Empty : searchString, StringComparison.InvariantCultureIgnoreCase));
    }


    protected override void OnInitialized()
    {
        LabelName = "Items";
        itemsList = itemIservice.SearchByDescription(string.Empty).ToList();
        IsLoaded = true;
    }
}
