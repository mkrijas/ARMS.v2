            H6 = new H6Typography() { FontFamily = new[] { "Inter", "sans-serif" }, FontWeight = "500", FontSize = "1.25rem", LineHeight = "1.6", LetterSpacing = ".0075em" },
            Button = new ButtonTypography() { FontFamily = new[] { "Inter", "sans-serif" }, FontWeight = "500", FontSize = "0.875rem", LineHeight = "1.75", LetterSpacing = ".02857em", TextTransform = "capitalize" },
            Body1 = new Body1Typography() { FontFamily = new[] { "Inter", "sans-serif" }, FontWeight = "400", FontSize = "1rem", LineHeight = "1.5", LetterSpacing = ".00938em" },
            Body2 = new Body2Typography() { FontFamily = new[] { "Inter", "sans-serif" }, FontWeight = "400", FontSize = "0.875rem", LineHeight = "1.43", LetterSpacing = ".01071em" },
