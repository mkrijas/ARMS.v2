@inherits LayoutComponentBase
@using MudBlazor
@using Views.Data
@inject AuthenticationStateProvider auth

<MudThemeProvider Theme="@MyCustomTheme" />
<MudDialogProvider />
<MudPopoverProvider />
<MudSnackbarProvider />

<MudLayout>
    <AuthorizeView>
        <Authorized>
             <!-- TopBanner -->
             <div style="position: sticky; top: 0; z-index: 1200; width: 100%;">
                 <Views.Shared.TopBanner ShowDrawerIcon="true" OnDrawerToggle="@ToggleDrawer" />
             </div>

             <!-- Drawer -->
             <MudDrawer @bind-Open="@_drawerOpen" Elevation="1" Width="375px" Variant="@DrawerVariant.Temporary" Style="z-index: 10001;">
                 <MudDrawerHeader Class="d-flex align-content-center">                            
                        <img src="images/thailogo.png" height="30px" />                           
                    <MudText Typo="Typo.h5">
                        <b>@context.User.Claims.FirstOrDefault(x => x.Type == "BranchName")?.Value</b>
                    </MudText>
                 </MudDrawerHeader>
                 <MudNavMenu>
                      <Views.Shared.NavMenu IsOpen="@_drawerOpen" />
                 </MudNavMenu>
                 
                <MudSpacer />
                <div class="pa-4 d-flex align-center gap-3">
                        <MudAvatar Class="animated-avatar" Style="height:56px; width:56px; background: transparent; box-shadow: 0 4px 10px rgba(0,0,0,0.08);" Image="" >
                            <img src="images/user_avatar_v2.png" style="width:100%; height:100%; object-fit: contain;" />
                        </MudAvatar>
                    <div class="d-flex flex-column justify-center">
                        <MudText Style="font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; font-weight: 600; font-size: 1rem; color: #212121; line-height: 1.2;">@context.User.Identity.Name</MudText>
                        <MudText Style="font-family: 'Segoe UI', sans-serif; color: #9E9E9E; text-transform: uppercase; font-size: 0.75rem; letter-spacing: 0.5px;">@context.User.Claims.FirstOrDefault(x => x.Type == "Role")?.Value</MudText>
                    </div>
                </div>
             </MudDrawer>
        </Authorized>
    </AuthorizeView>

    <MudMainContent Class="pa-0" Style="height: 100vh; overflow-y: auto; overflow-x: hidden;">
        @Body
    </MudMainContent>
</MudLayout>

@code {
    private bool _drawerOpen = false;

    private void ToggleDrawer()
    {
        _drawerOpen = !_drawerOpen;
    }

    MudTheme MyCustomTheme = new MudTheme()
    {
        PaletteLight = new PaletteLight()
        {
            Primary = "#FF9F43", // Amber / Orange
            Secondary = "#000000", // Black
            AppbarBackground = "#FF9F43", 
            AppbarText = "#FFFFFF", 
            DrawerBackground = "#FFFFFF", 
            DrawerText = "#5E5873",
            DrawerIcon = "#5E5873",
            Surface = "#FFFFFF",
            Background = "#F8F8F8", 
            TextPrimary = "#5E5873", 
            TextSecondary = "#999999",
            ActionDefault = "#FF9F43",
            ActionDisabled = "#BABFC7",
            ActionDisabledBackground = "#E5E7EB"
        },
        Typography = new Typography()
        {
            H1 = new H1Typography() { FontFamily = new[] { "Inter", "sans-serif" }, FontWeight = "700", FontSize = "2.5rem", LineHeight = "1.2", LetterSpacing = "-.01562em" },
            H2 = new H2Typography() { FontFamily = new[] { "Inter", "sans-serif" }, FontWeight = "300", FontSize = "3.75rem", LineHeight = "1.2", LetterSpacing = "-.00833em" },
            H3 = new H3Typography() { FontFamily = new[] { "Inter", "sans-serif" }, FontWeight = "400", FontSize = "3rem", LineHeight = "1.167", LetterSpacing = "0" },
            H4 = new H4Typography() { FontFamily = new[] { "Inter", "sans-serif" }, FontWeight = "400", FontSize = "2.125rem", LineHeight = "1.235", LetterSpacing = ".00735em" },
            H5 = new H5Typography() { FontFamily = new[] { "Inter", "sans-serif" }, FontWeight = "400", FontSize = "1.5rem", LineHeight = "1.334", LetterSpacing = "0" },
            H6 = new H6Typography() { FontFamily = new[] { "Inter", "sans-serif" }, FontWeight = "500", FontSize = "1.25rem", LineHeight = "1.6", LetterSpacing = ".0075em" },
            Button = new ButtonTypography() { FontFamily = new[] { "Inter", "sans-serif" }, FontWeight = "500", FontSize = "0.875rem", LineHeight = "1.75", LetterSpacing = ".02857em", TextTransform = "capitalize" },
            Body1 = new Body1Typography() { FontFamily = new[] { "Inter", "sans-serif" }, FontWeight = "400", FontSize = "1rem", LineHeight = "1.5", LetterSpacing = ".00938em" },
            Body2 = new Body2Typography() { FontFamily = new[] { "Inter", "sans-serif" }, FontWeight = "400", FontSize = "0.875rem", LineHeight = "1.43", LetterSpacing = ".01071em" },
            Caption = new CaptionTypography() { FontFamily = new[] { "Inter", "sans-serif" }, FontWeight = "400", FontSize = "0.75rem", LineHeight = "1.66", LetterSpacing = ".03333em" },
            Subtitle1 = new Subtitle1Typography() { FontFamily = new[] { "Inter", "sans-serif" }, FontWeight = "400", FontSize = "1rem", LineHeight = "1.75", LetterSpacing = ".00938em" },
            Subtitle2 = new Subtitle2Typography() { FontFamily = new[] { "Inter", "sans-serif" }, FontWeight = "500", FontSize = "0.875rem", LineHeight = "1.57", LetterSpacing = ".00714em" }
        },
        LayoutProperties = new LayoutProperties()
        {
            DefaultBorderRadius = "6px",
            DrawerWidthLeft = "260px"
        }
    };
}
