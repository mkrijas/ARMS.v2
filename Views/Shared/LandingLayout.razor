            Subtitle2 = new Subtitle2Typography() { FontFamily = new[] { "Inter", "sans-serif" }, FontWeight = "500", FontSize = "0.875rem", LineHeight = "1.57", LetterSpacing = ".00714em" }
        },
        LayoutProperties = new LayoutProperties()
        {
            DefaultBorderRadius = "6px",
            DrawerWidthLeft = "260px"
        }
