@inherits LayoutComponentBase
@using MudBlazor
@using Views.Data

<MudThemeProvider Theme="@MyCustomTheme" />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudMainContent Class="pa-0" Style="height: 100vh; overflow: hidden;">
        @Body
    </MudMainContent>
</MudLayout>

@code {
    MudTheme MyCustomTheme = new MudTheme()
    {
        PaletteLight = new PaletteLight()
        {
            Primary = "#FF9F43", // Amber / Orange
            Secondary = "#28C76F", // Green Accent
            AppbarBackground = "#FFFFFF",
            AppbarText = "#6E6B7B", 
            DrawerBackground = "#FFFFFF", 
            DrawerText = "#5E5873",
            DrawerIcon = "#5E5873",
            Surface = "#FFFFFF",
            Background = "#F8F8F8", 
            TextPrimary = "#5E5873", 
            TextSecondary = "#999999",
            ActionDefault = "#FF9F43",
            ActionDisabled = "#BABFC7",
            ActionDisabledBackground = "#E5E7EB"
        },
        Typography = new Typography()
        {
            H1 = new H1Typography() { FontFamily = new[] { "Inter", "sans-serif" }, FontWeight = "700", FontSize = "2.5rem", LineHeight = "1.2", LetterSpacing = "-.01562em" },
            H2 = new H2Typography() { FontFamily = new[] { "Inter", "sans-serif" }, FontWeight = "300", FontSize = "3.75rem", LineHeight = "1.2", LetterSpacing = "-.00833em" },
            H3 = new H3Typography() { FontFamily = new[] { "Inter", "sans-serif" }, FontWeight = "400", FontSize = "3rem", LineHeight = "1.167", LetterSpacing = "0" },
