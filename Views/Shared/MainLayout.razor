@inherits LayoutComponentBase
@using System.Security.Claims
@using Pages.UserAccount
@using Microsoft.AspNetCore.Hosting;
@using Microsoft.Extensions.Hosting;
@inject NavigationManager uriHelper;
@inject MudBlazor.ISnackbar snackbar
@inject IWebHostEnvironment env
@inject ICatalogNameProvider DataBaseCatlogName

<CascadingValue Value="this">

    <div class="page">
        <MudLayout>
            <TopBanner ShowDrawerIcon="true" OnDrawerToggle="@ToggleDrawer" />
            <AuthorizeView>
                <Authorized>
                    <MudDrawer @bind-Open="@open" Elevation="1" Width="375px" Variant="@DrawerVariant.Temporary" >
                        <MudDrawerHeader Class="d-flex align-content-center">                            
                                <img src="images/thailogo.png" height="30px" />                           
                            <MudText Typo="Typo.h5">
                                <b>@context.User.Claims.FirstOrDefault(x => x.Type == "BranchName")?.Value</b>
                            </MudText>
                        </MudDrawerHeader>
                        <Views.Shared.NavMenu IsOpen="@open" />
                        
                        <MudSpacer />
                        <div class="pa-4 d-flex align-center justify-center gap-3">
                             <MudAvatar Class="animated-avatar" Style="height:50px; width:50px; background: transparent; box-shadow: 0 4px 10px rgba(0,0,0,0.08);" Image="" >
                                 <img src="images/user_avatar_v2.png" style="width:100%; height:100%; object-fit: contain;" />
                             </MudAvatar>
                            <div class="d-flex flex-column justify-center">
                                <MudText Style="font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; font-weight: 600; font-size: 1rem; color: #212121; line-height: 1.2;">@context.User.Identity.Name</MudText>
                                <MudText Style="font-family: 'Segoe UI', sans-serif; color: #9E9E9E; text-transform: uppercase; font-size: 0.75rem; letter-spacing: 0.5px;">@context.User.Claims.FirstOrDefault(x => x.Type == "Role")?.Value</MudText>
                            </div>
                        </div>
                    </MudDrawer>
                </Authorized>
            </AuthorizeView>
            <MudMainContent Class="pa-0">
                <MudContainer MaxWidth="MaxWidth.False" Class="mt-16 px-4">
                    @Body
                </MudContainer>
            </MudMainContent>
        </MudLayout>

    </div>
</CascadingValue>

<MudThemeProvider Theme="@MyCustomTheme" />
<MudPopoverProvider />
<MudSnackbarProvider />
<MudDialogProvider FullWidth="true"
                   MaxWidth="MaxWidth.Small"
                   CloseButton="true"
                   NoHeader="false"
                   Position="DialogPosition.Center" />



@code
