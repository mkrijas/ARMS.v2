    <MudItem xs="6">
        <MudTextField Label="@Label" Variant="Variant.Outlined" T="DateTime?" Margin="Margin.Dense" @bind-Value="@Value" InputType="InputType.DateTimeLocal"></MudTextField>
    </MudItem>    
</MudGrid>

@code {

    [Parameter]
    public string Label { get; set; }

    [Parameter]    
    public DateTime? Value
    {
        get => _value;
        set
        {
            if (_value == value) return;
            _value = value;
            ValueChanged.InvokeAsync(value);
        }
    }

    [Parameter]
    public EventCallback<DateTime?> ValueChanged { get; set; }



    private DateTime? _value = DateTime.Now;  
}
