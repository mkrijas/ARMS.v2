@using System.IO
@using Microsoft.AspNetCore.Hosting;
@inject IWebHostEnvironment _env;
@inject MudBlazor.ISnackbar snackbar
@inject IDialogService DialogService

@using System.Security.AccessControl
@using MimeTypes

<InputFile id="@FileName" OnChange="UploadImage" hidden />
<MudButton HtmlTag="label" for="@FileName">@Label</MudButton>

@code {
    [Parameter] public string FileName { get; set; } = "Original";
    [Parameter] public string FolderName { get; set; }
    [Parameter] public string Label { get; set; }
    [Parameter] public bool Resize { get; set; } = false;

    [Parameter]
    public string FilePath { get; set; }

    [Parameter] public bool AcceptOnlyPdf { get; set; } = false;

    [Parameter]
    public EventCallback<string> FilePathChanged { get; set; }

    private string _filepath
    {
        get => FilePath;
        set
        {
            if (FilePath == value) return;
            FilePath = value;
            FilePathChanged.InvokeAsync(value);
        }
    }

    private async Task UploadImage(InputFileChangeEventArgs e)
    {
        IBrowserFile DocImage = e.File;
        if (AcceptOnlyPdf && !IsPdfFile(DocImage.ContentType))
        {
            snackbar.Add("Only Allows PDF Files", Severity.Warning);
            return;
        }

        string PhysicalPath = Path.Combine(_env.WebRootPath, "ArmsStaticFiles", FolderName);
        string VirtualPath = Path.Combine("ArmsStaticFiles", FolderName);
        var result = await UploadImage(DocImage, FileName, PhysicalPath);
        if (result != null)
        {
            _filepath = Path.Combine(VirtualPath, result);
        }
    }

    private bool IsPdfFile(string contentType)
    {
        return contentType.ToLower() == "application/pdf";
    }

    private async Task<string> UploadImage(IBrowserFile file, string filename, string physicalPath)
    {
        string DerivedFileName = null;
        if (file.Size > 0 && file.Size < 2097153)
        {
            if (filename == "Original")
            {
                DerivedFileName = file.Name;
            }
            else
            {
                DerivedFileName = filename + MimeTypeMap.GetExtension(file.ContentType);
            }

            DirectoryInfo di = new DirectoryInfo(physicalPath);
            if (!di.Exists)
            {
                System.IO.Directory.CreateDirectory(physicalPath);
            }

            string filePath = Path.Combine(physicalPath, DerivedFileName);

            if (_filepath != null)
            {
                string oldfileName = Path.Combine(_env.WebRootPath, FilePath);
                if (File.Exists(oldfileName))
                {
                    File.Delete(oldfileName);
                }
            }

            if (Resize)
            {
                file = await ResizeImage(file);
            }

            try
            {
                Stream stream = file.OpenReadStream(2097152);
                //FileStream fs = File.Create(filePath);
                FileStream fs = new(filePath, FileMode.Create);
                await stream.CopyToAsync(fs);
                stream.Close();
                fs.Close();
            }
            catch (Exception ex)
            {
                snackbar.Add(ex.Message, Severity.Error);
            }
        }
        else
        {
            bool? result = await DialogService.ShowMessageBox(
                "Oops !",
                "Uploaded file should not be greater than 2MB.");
        }
        return DerivedFileName;
    }


    private async Task<IBrowserFile> ResizeImage(IBrowserFile file)
    {
        return await file.RequestImageFileAsync("image/jpg", 250, 250);
    }


    public bool DeleteFile(string path)
    {
        try
        {
            File.Delete(Path.Combine(_env.WebRootPath, path));
            return true;
        }
        catch (Exception ex)
        {
            snackbar.Add(ex.Message, Severity.Error);
            return false;
        }
    }
}
