@using System.IO
@using Microsoft.AspNetCore.Hosting
@inject IWebHostEnvironment _env
@inject MudBlazor.ISnackbar snackbar
@inject IDialogService DialogService

@using System.Security.AccessControl
@using MimeTypes

<InputFile id="@FileName" OnChange="UploadImage" hidden multiple="@AllowMultiple" accept="@GetAcceptedTypes()" />
<MudButton HtmlTag="label" for="@FileName">@Label</MudButton>

@code {
    [Parameter] public string FileName { get; set; } = "Original";
    [Parameter] public string FolderName { get; set; }
    [Parameter] public string Label { get; set; } = "Upload File";
    [Parameter] public bool Resize { get; set; } = false;
    [Parameter] public bool DeleteExistingFile { get; set; } = true;
    [Parameter] public bool AcceptOnlyPdf { get; set; } = false;
    [Parameter] public bool AllowMultiple { get; set; } = false;

    [Parameter] public string FilePath { get; set; }
    [Parameter] public EventCallback<string> FilePathChanged { get; set; }

    private string _filepath
    {
        get => FilePath;
        set
        {
            if (FilePath == value) return;
            FilePath = value;
            FilePathChanged.InvokeAsync(value);
        }
    }

    private string GetAcceptedTypes()
    {
        if (AcceptOnlyPdf) return ".pdf";
        return "image/*,video/*,.pdf";
    }

    private async Task UploadImage(InputFileChangeEventArgs e)
    {
        foreach (var file in e.GetMultipleFiles())
        {
            if (AcceptOnlyPdf && !IsPdfFile(file.ContentType))
            {
                snackbar.Add("Only PDF files are allowed.", Severity.Warning);
                return;
            }

            if (!AcceptOnlyPdf && !IsSupportedFileType(file.ContentType))
            {
                snackbar.Add("Only images, videos, or PDF files are allowed.", Severity.Warning);
                return;
            }

            string physicalPath = Path.Combine(_env.WebRootPath, "ArmsStaticFiles", FolderName);
            string virtualPath = Path.Combine("ArmsStaticFiles", FolderName);
            var result = await UploadFile(file, FileName, physicalPath);

            if (result != null)
            {
                _filepath = Path.Combine(virtualPath, result);
            }
        }
    }

    private bool IsPdfFile(string contentType)
    {
        return contentType.ToLower() == "application/pdf";
    }

    private bool IsSupportedFileType(string contentType)
    {
        return contentType.StartsWith("image/") || contentType.StartsWith("video/") || IsPdfFile(contentType);
    }

    private async Task<string> UploadFile(IBrowserFile file, string filename, string physicalPath)
    {
        string derivedFileName = null;

        if (file.Size > 0 && file.Size < 5097153) // < 2MB
        {
            string extension = MimeTypeMap.GetExtension(file.ContentType);
            derivedFileName = filename == "Original" ? file.Name : filename + extension;

            DirectoryInfo di = new(physicalPath);
            if (!di.Exists)
            {
                Directory.CreateDirectory(physicalPath);
            }

            string filePath = Path.Combine(physicalPath, derivedFileName);

            if (_filepath != null && DeleteExistingFile)
            {
                string oldFilePath = Path.Combine(_env.WebRootPath, FilePath);
                if (File.Exists(oldFilePath))
                {
                    File.Delete(oldFilePath);
                }
            }

            if (Resize && file.ContentType.StartsWith("image/"))
            {
                file = await ResizeImage(file);
            }

            try
            {
                using Stream stream = file.OpenReadStream(5097152);
                using FileStream fs = new(filePath, FileMode.Create);
                await stream.CopyToAsync(fs);
            }
            catch (Exception ex)
            {
                snackbar.Add($"Upload failed: {ex.Message}", Severity.Error);
            }
        }
        else
        {
            await DialogService.ShowMessageBox("Oops!", "Uploaded file should not be greater than 2MB.");
        }

        return derivedFileName;
    }

    private async Task<IBrowserFile> ResizeImage(IBrowserFile file)
    {
        return await file.RequestImageFileAsync("image/jpg", 250, 250);
    }

    public bool DeleteFile(string path)
    {
        try
        {
            File.Delete(Path.Combine(_env.WebRootPath, path));
            return true;
        }
        catch (Exception ex)
        {
            snackbar.Add($"Delete failed: {ex.Message}", Severity.Error);
            return false;
        }
    }
}
