
<MudTextField @bind-Value="@FilterText" Placeholder="Search..." Variant="Variant.Outlined" Margin="Margin.Dense" Class="m-4 flex-grow-0 " @ref="@tf" />

@if (string.IsNullOrEmpty(FilterText))
{
    @foreach (var item in GetAll())
    {
        <NavMenuGroup MenuItem="@item" />
    }
}
else
{
    Reset();
    @foreach (var item in Filter(FilterText, navlist))
    {
        <NavMenuGroup MenuItem="@item" />
    }
}

@code {
    string FilterText;

    MudTextField<string> tf;

    [Parameter]
    public bool IsOpen { get; set; } = false;

    List<NavMenuModel> navlist = new();

    protected override void OnInitialized()
    {
        base.OnInitialized();
        Reset();
    }

    protected override async Task OnParametersSetAsync()
    {
        if (IsOpen && tf != null)
            await tf.FocusAsync();
    }

    private IEnumerable<NavMenuModel> GetAll()
    {
        foreach (var item in navlist)
        {
            yield return item;
        }
    }

    private IEnumerable<NavMenuModel> Filter(string txt, List<NavMenuModel> items)
    {
        foreach (var item in items)
        {
            item.Expanded = false; 
           
            var filteredChildren = Filter(txt, item.navItems).ToList();
        
            bool isMatching = !item.IsGroup && item.Title.Contains(txt, StringComparison.OrdinalIgnoreCase);
            if (isMatching || filteredChildren.Any())
            {
                item.Expanded = true;
                item.navItems = filteredChildren;
                yield return item;
            }
        }
    }

