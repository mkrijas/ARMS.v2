
<MudPaper Width="250px" Class="d-inline-flex MenuClass" Square="true">
    <MudNavMenu Class="mud-width-full">
        <div class="px-6 py-2 logo" >
            <MudText Typo="Typo.h5"  Color="Color.Error" ><b>ARMS</b></MudText>
            <MudText Typo="Typo.subtitle2" Class="text-black-50 mt-2"  Style="align-self:center"   ><b>TEAM THAI</b></MudText>
        </div>
        <MudDivider  />
        <div class="py-3 menuContainer">
            <MudNavLink Href="/dashboard" Icon="@Icons.Filled.Dashboard" IconColor="Color.Surface">Dashboard</MudNavLink>
            <MudNavLink Href="/operations" Icon="@Icons.Filled.AllInclusive" IconColor="Color.Tertiary">Activity Screen</MudNavLink>

            <MudNavGroup Title="Orders" Icon="@Icons.Filled.GraphicEq" IconColor="Color.Inherit" Expanded="false">
                <MudNavLink Href="/order" Icon="@Icons.Filled.Hvac">Manage Orders</MudNavLink>
                <MudNavGroup Title="Routes" Icon="@Icons.Filled.AltRoute" Expanded="true">
                    <MudNavLink Href="/route" IconColor="Color.Success">Routes</MudNavLink>
                    <MudNavLink Href="/place">Places</MudNavLink>
                </MudNavGroup>
                <MudNavGroup Title="GCs" Icon="@Icons.Filled.Today" IconColor="Color.Inherit" Expanded="true">
                    <MudNavLink Href="/consignee" IconColor="Color.Primary">Consignee</MudNavLink>
                    <MudNavLink Href="/content" IconColor="Color.Primary">Content</MudNavLink>
                    <MudNavLink Href="/gc" IconColor="Color.Success">UnAssigned GCs</MudNavLink>
                </MudNavGroup>
                <MudNavLink Href="/TariffTypes" IconColor="Color.Success">Tariff Master</MudNavLink>
                <MudNavLink Href="/TripReviewPage" IconColor="Color.Success">Trip Manager</MudNavLink>                
            </MudNavGroup>

            <MudNavGroup Title="General" Icon="@Icons.Filled.Settings" IconColor="Color.Inherit" Expanded="false">
                <MudNavLink Href="/party" IconColor="Color.Tertiary">Parties</MudNavLink>
                <MudNavLink Href="/branch" IconColor="Color.Success">Branch</MudNavLink>
                <MudNavLink Href="/gst" IconColor="Color.Primary">GST</MudNavLink>
            </MudNavGroup>

            <MudNavGroup Title="Trucks" Icon="@Icons.Filled.DirectionsBusFilled" IconColor="Color.Inherit" Expanded="false">
                <MudNavLink Href="/trucks" IconColor="Color.Success">Truck</MudNavLink>
                <MudNavLink Href="/truckType" IconColor="Color.Primary">Truck Models</MudNavLink>
                <MudNavLink Href="/DocumentType" IconColor="Color.Primary">Document Types</MudNavLink>
                <MudNavLink Href="/Document" IconColor="Color.Primary">Documents</MudNavLink>
            </MudNavGroup>
            <MudNavGroup Title="Drivers" Icon="@Icons.Filled.People" IconColor="Color.Inherit" Expanded="false">
                <MudNavLink Href="/driver" IconColor="Color.Success">Driver Master</MudNavLink>                
            </MudNavGroup>
        </div>
    </MudNavMenu>
</MudPaper>


