
<div class="nav-menu-container pa-2">
    <div class="search-container px-4 py-2">
        <MudTextField @bind-Value="@FilterText" 
                      Placeholder="Search Menu..." 
                      Variant="Variant.Outlined" 
                      Margin="Margin.Dense" 
                      Adornment="Adornment.Start"
                      AdornmentIcon="@Icons.Material.Filled.Search"
                      Class="menu-search-field"
                      @ref="@tf" />
    </div>

    <div class="menu-items scroll-container mt-2">
        @if (string.IsNullOrEmpty(FilterText))
        {
            @foreach (var item in GetAll())
            {
                <NavMenuGroup @key="item.ID" MenuItem="@item" />
            }
        }
        else
        {
            @foreach (var item in Filter(FilterText, navlist))
            {
                <NavMenuGroup @key="item.ID" MenuItem="@item" />
            }
        }
    </div>
</div>

@code {
    string FilterText;

    MudTextField<string> tf;

    [Parameter]
    public bool IsOpen { get; set; } = false;

    List<NavMenuModel> navlist = new();

    protected override void OnInitialized()
    {
        base.OnInitialized();
        Reset();
    }

    protected override async Task OnParametersSetAsync()
    {
        if (IsOpen && tf != null)
            await tf.FocusAsync();
    }

    private IEnumerable<NavMenuModel> GetAll()
    {
        foreach (var item in navlist)
        {
            yield return item;
        }
    }

    private IEnumerable<NavMenuModel> Filter(string txt, List<NavMenuModel> items)
    {
        if (string.IsNullOrWhiteSpace(txt))
        {
            foreach (var item in items)
            {
                    item.Expanded = false;
                    yield return item;
            }
            yield break;
        }

        foreach (var item in items)
        {
            // Create a conceptual copy or check logic without modifying the original if possible,
            // but for simple expand/collapse behavior on the existing model (which is bound),
            // ensure we don't return partial trees that confuse Blazor.
            
            // Note: If we really want to filter safely, we should probably yield deeply cloned items 
            // OR just rely on visibility. But for now, fixing the structure:

            var filteredChildren = Filter(txt, item.navItems ?? new List<NavMenuModel>()).ToList();
        
            bool isMatching = !item.IsGroup && (item.Title?.Contains(txt, StringComparison.OrdinalIgnoreCase) ?? false);
            bool hasMatchingChildren = filteredChildren.Any();

            if (isMatching || hasMatchingChildren)
            {
                // We usually shouldn't modify state inside a projection (Filter), 
                // but if we are just setting Expanded it might be okay IF we don't mess up the render tree keys.
                // The fatal error usually comes from the iterator changing the collection or removing items 
                // that Blazor is tracking.
                item.Expanded = true; 
                // item.navItems = filteredChildren; // <--- THIS IS THE CULPRIT. Modifying the list properties in place.
                
                // Instead of modifying item.navItems, we should return a new model or just the item itself 
                // and let the recursive call handle it. 
                // However, the UI iterates children. If we don't modify children, the UI shows all children.

                // SAFE FIX: Return a NEW NavMenuModel (shallow copy) with filtered children
                var newItem = new NavMenuModel 
                {
                     ID = item.ID,
                     Title = item.Title,
                     Icon = item.Icon,
                     IconColor = item.IconColor,
                     href = item.href,
                     IsGroup = item.IsGroup,
                     Expanded = true,
                     navItems = filteredChildren // Use the new filtered list
                };
                yield return newItem;
            }
        }
    }

