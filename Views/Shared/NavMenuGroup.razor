@using Views.Data

  <MudNavGroup Title="@menuGroup.Title" Icon="@menuGroup.Icon" IconColor="@menuGroup.IconColor" Expanded="@menuGroup.Expanded" >
      
    @foreach (var item in menuGroup?.navItems)
    {
         if(item.IsGroup)
        {
            <NavMenuGroup  menuGroup="item"  ></NavMenuGroup>
        }
        else
        {
            <MudNavLink Href="@item.href" Icon="@item.Icon" IconColor="@item.IconColor">@item.Title</MudNavLink>
        }
    }
           

  </MudNavGroup>


@code {

    
    [Parameter]
    public NavMenuModel menuGroup { get; set; }




}






