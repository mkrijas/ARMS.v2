@using Views.Data



@if (MenuItem.IsGroup)
{
    <MudNavGroup Title="@MenuItem.Title" Icon="@MenuItem.Icon" IconColor="@MenuItem.IconColor" Expanded="@MenuItem.Expanded">
        @foreach (var item in MenuItem?.navItems)
        {
            <NavMenuGroup MenuItem="item"></NavMenuGroup>
        }
        <MudDivider DividerType="DividerType.Middle" Class="my-6" />
    </MudNavGroup>
}
else
{
    <MudNavLink Href="@MenuItem.href" Icon="@MenuItem.Icon" IconColor="@MenuItem.IconColor" Match="NavLinkMatch.All">@MenuItem.Title</MudNavLink>
}




@code {


    [Parameter]
    public NavMenuModel MenuItem { get; set; }




}






