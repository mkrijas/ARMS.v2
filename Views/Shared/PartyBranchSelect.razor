@inject IPartyService partyIservice
@inject IPartyBranchService partyBranchIservice

<MudGrid>
  <MudItem xs="12" md="6">
        <MudAutocomplete T="PartyModel" Value="SelectedParty" ValueChanged="getBranch"
                                         Variant="Variant.Outlined" Margin="Margin.Dense" Label="Select Vendor" ResetValueOnEmptyText="true"
                                         SearchFunc="@SearchParty" ToStringFunc="@(e => e?.PartyName)">
                                         </MudAutocomplete>
                    @* <MudSelect Label="Select Vendor"   T="PartyModel" Value="SelectedParty"  ValueChanged="getBranch" ToStringFunc="@(e=> e?.PartyName)"   Variant="Variant.Outlined" Margin="Margin.Dense" OffsetY="true" Direction="Direction.Top" AdornmentColor="Color.Secondary">
                            @foreach (var ditem in partyList)
                            {
                                <MudSelectItem Value="@ditem">@ditem.PartyName</MudSelectItem>
                            }
                        </MudSelect>    *@
                    </MudItem>

                     <MudItem xs="12" md="6">
                     <MudSelect Label="Select vendor place" @bind-Value="Value" T="PartyBranchModel" ToStringFunc="@(e=> e?.Address.Place)"   Variant="Variant.Outlined" Margin="Margin.Dense" OffsetY="true" Direction="Direction.Top" AdornmentColor="Color.Secondary">
                            @foreach (var ditem in partybranch)
                            {
                                <MudSelectItem Value="@ditem">@ditem.Address.Place</MudSelectItem>
                            }
                        </MudSelect>    
           </MudItem>
</MudGrid>

@code {
    private List<PartyModel> partyList = new();
    private List<PartyBranchModel> partybranch = new();
    private PartyModel SelectedParty = new();    


    [Parameter]
    public PartyBranchModel Value
    {
        get => _value;
        set
        {
            if (_value == value) return;
            //
            _value = value;
            ValueChanged.InvokeAsync(value);
        }
    }

    [Parameter]
    public EventCallback<PartyBranchModel> ValueChanged { get; set; }
    private PartyBranchModel _value;


    protected override async Task OnInitializedAsync()
    {
        partyList = await partyIservice.Select(0).ToListAsync();

        if (Value?.PartyID != null)
        {            
            var party = await partyIservice.SelectByID(Value.PartyID);           
            getBranch(party);
        }
    }

    private void getBranch(PartyModel party)
    {        
        SelectedParty = party;
        partybranch = partyBranchIservice.SelectByParty(party?.PartyID).ToList();        

        if(!partybranch.Where(x=> x.GstID == Value?.GstID).Any())
        {
            Value = null;
        }
    }

   private async Task<IEnumerable<PartyModel>> SearchParty(string searchString)
    {
        return await Task.FromResult(partyList.Where(x => x.PartyName.Contains(searchString == null ? string.Empty : searchString, StringComparison.InvariantCultureIgnoreCase)));
    }

}
