@inject IPartyService partyIservice
@inject IPartyBranchService partyBranchIservice

<MudGrid>
  <MudItem xs="12" md="6">
                     <MudSelect Label="Select Vendor"   T="PartyModel" Value="SelectedParty"  ValueChanged="getBranch"  Variant="Variant.Outlined" Margin="Margin.Dense" OffsetY="true" Direction="Direction.Top" AdornmentColor="Color.Secondary">
                            @foreach (var ditem in partyList)
                            {
                                <MudSelectItem Value="@ditem">@ditem.PartyName</MudSelectItem>
                            }
                        </MudSelect>    
                    </MudItem>

                     <MudItem xs="12" md="6">
                     <MudSelect Label="Select vendor place" @bind-Value="Value" T="PartyBranchModel" ToStringFunc="@(e=> e?.Address?.Place + "," + e?.GstNo)"  Variant="Variant.Outlined" Margin="Margin.Dense" OffsetY="true" Direction="Direction.Top" AdornmentColor="Color.Secondary">
                            @foreach (var ditem in partybranch)
                            {
                                <MudSelectItem Value="@ditem.GstID">@ditem.Address.Place</MudSelectItem>
                            }
                        </MudSelect>    
           </MudItem>
</MudGrid>

@code {
    private List<PartyModel> partyList = new();
    private List<PartyBranchModel> partybranch = new();
    private PartyModel SelectedParty = new();


    [Parameter]
    public PartyBranchModel Value
    {
        get => _value;
        set
        {
            if (_value == value) return;
           // SetParty(value);
            _value = value;
            ValueChanged.InvokeAsync(value);
        }
    }

    [Parameter]
    public EventCallback<PartyBranchModel> ValueChanged { get; set; }
    private PartyBranchModel _value;


    protected override void OnInitialized()
    {

    }

    private void getBranch(PartyModel party)
    {        
        SelectedParty = party;
        partybranch = partyBranchIservice.SelectByParty(party.PartyID).ToList();        
    }


    private void SetParty(PartyBranchModel pb)
    {        
        SelectedParty = partyIservice.SelectByID(pb.PartyID).Result;
        partybranch = partyBranchIservice.SelectByParty(SelectedParty.PartyID).ToList();
    }

}
