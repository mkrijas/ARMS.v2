@inject IChartOfAccountService accountService

@if (IsLoaded)
{
    <MudAutocomplete Class="@Class" T="ChartOfAccountModel" Variant="Variant.Outlined" Margin="Margin.Dense" Label="@LabelName" @bind-Value="Value" ResetValueOnEmptyText="true"
                 Clearable="true" SearchFunc="SearchAccounts" Text="@Value?.AccountCode" ToStringFunc="@(e => e == null ? null : $"{e.AccountCode}")"></MudAutocomplete>

}
else
{
    <MudText> Loading..... </MudText>
}
@code {

    private List<ChartOfAccountModel> codeList = new();
    [Parameter]
    public ChartOfAccountModel Value
    {
        get => _value;
        set
        {
            if (_value == value) return;
            _value = value;
            ValueChanged.InvokeAsync(value);
        }
    }
    [Parameter]
    public EventCallback<ChartOfAccountModel> ValueChanged { get; set; }

    [Parameter]
    public string Class { get; set; }

    [Parameter]
    public string LabelName { get; set; }
    [Parameter]
    public int? CoaID { get; set; } = 0;

    private ChartOfAccountModel _value;

    private bool IsLoaded = false;

    private async Task<IEnumerable<ChartOfAccountModel>> SearchAccounts(string searchString)
    {
        await Task.Delay(5);

        return codeList.Where(x => (x.AccountCode).Contains(searchString == null ? string.Empty : searchString, StringComparison.InvariantCultureIgnoreCase));
    }


    protected override void OnInitialized()
    {
        codeList = accountService.SelectChildren(CoaID).ToList();
        IsLoaded = true;
    }
}
