@inject IChartOfAccountService accountService
@inject AuthenticationStateProvider auth
@inject TruckDataArrayModel data

@if (IsLoaded)
{
    <MudGrid>
         <MudItem xs="12" md="2">
                        <MudSelect Label="Mode" @bind-Value="PaymentMode" SelectedValuesChanged="Modechanged" T="string" Variant="Variant.Outlined" Margin="Margin.Dense" OffsetY="true" Direction="Direction.Top" AdornmentColor="Color.Secondary">
                            <MudSelectItem Value="@("Bank")" />
                            <MudSelectItem Value="@("Cash")" />


                        </MudSelect>
                    </MudItem>

<MudItem xs="12" md="4">
    <MudAutocomplete Class="@Class" T="AccountRuleDefinitionModel" Variant="Variant.Outlined" Margin="Margin.Dense" Label="@LabelName" @bind-Value="Value" ResetValueOnEmptyText="true"
                 Clearable="true" SearchFunc="SearchAccounts" Text="@Value?.Title" ToStringFunc="@(e => (e == null || string.IsNullOrEmpty(e.Title)) ? null : string.Format("{0} | {1}",e.ArdCode,e.Title))"></MudAutocomplete>
   </MudItem>



   @if(PaymentMode=="Bank")
        {
            <MudItem xs="12" md="3">
                            <MudSelect  Label="Select Payment Mode" @bind-Value="@Value.BankTools" Variant="Variant.Outlined" Margin="Margin.Dense" OffsetY="true" Direction="Direction.Top" AdornmentColor="Color.Secondary">
                                @foreach (var item in data.BankTools)
                                {
                                <MudSelectItem Value="@item">@item</MudSelectItem>
                                }
                        </MudSelect>
             </MudItem>
             <MudItem xs="12" md="3">
                  <MudTextField @bind-Value="@Value.BankCharges" Label="BankCharges" Variant="Variant.Outlined" Margin="Margin.Dense" ></MudTextField>

               </MudItem>
        }
    </MudGrid>
}
else
{
    <MudText> Loading..... </MudText>
}
@code {
    [Parameter]
    public EventCallback<AccountRuleDefinitionModel> ValueChanged { get; set; }


    private List<AccountRuleDefinitionModel> codeListt = new();
    [Parameter]
    public AccountRuleDefinitionModel Value
    {
        get => _value;
        set
        {
            if (_value == value) return;
            _value = value;
            ValueChanged.InvokeAsync(value);
        }
    }

    [Parameter]
    public string Class { get; set; }

    [Parameter]
    public string LabelName { get; set; }


    public string PaymentMode { get; set; }
    //public string BankCharges { get; set; } 
    //public string BankTools { get; set; } 

    private AccountRuleDefinitionModel _value;

    private bool IsLoaded = false;

    private async Task<IEnumerable<AccountRuleDefinitionModel>> SearchAccounts(string searchString)
    {
        await Task.Delay(5);

        return codeListt.Where(x => (x.ArdCode).Contains(searchString == null ? string.Empty : searchString, StringComparison.InvariantCultureIgnoreCase));

    }
    public async Task Modechanged()
    {

        await getAll();
    }

    protected override async Task OnInitializedAsync()
    {
        if(Value.paymentMode!=null)
        {
            PaymentMode = Value.paymentMode;
        }
        else{

            PaymentMode = "Bank";
        }
        await getAll();
    }
    public async Task getAll()
    {
        var authprov = await auth.GetAuthenticationStateAsync();
        var brancIDString = authprov.User.Claims.First(x => x.Type == "BranchID").Value;
        int branchID = int.Parse(brancIDString);
        codeListt = accountService.GetPaymentCodes(branchID,PaymentMode).ToList();
        IsLoaded = true;
       
    }
}
