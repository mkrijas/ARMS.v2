@inject IChartOfAccountService accountService
@inject AuthenticationStateProvider auth

@if (IsLoaded)
{
    <MudGrid>
         <MudItem xs="12" md="4">
                        <MudSelect Label="Mode" @bind-Value="PaymentMode" SelectedValuesChanged="valuechanged" T="string" Variant="Variant.Outlined" Margin="Margin.Dense" OffsetY="true" Direction="Direction.Top" AdornmentColor="Color.Secondary">
                            <MudSelectItem Value="@("Bank")" />
                            <MudSelectItem Value="@("Cash")" />


                        </MudSelect>
                    </MudItem>

<MudItem xs="12" md="8">
    <MudAutocomplete Class="@Class" T="AccountRuleDefinitionModel" Variant="Variant.Outlined" Margin="Margin.Dense" Label="@LabelName" @bind-Value="Value" ResetValueOnEmptyText="true"
                 Clearable="true" SearchFunc="SearchAccounts" Text="@Value?.ArdCode" ToStringFunc="@(e => e == null ? null : $"{e.ArdCode}")"></MudAutocomplete>
   </MudItem>
             </MudGrid>
}
else
{
    <MudText> Loading..... </MudText>
}
@code {

    private List<ChartOfAccountModel> codeList = new();
    private List<AccountRuleDefinitionModel> codeListt = new();
    [Parameter]
    public AccountRuleDefinitionModel Value
    {
        get => _value;
        set
        {
            if (_value == value) return;
            _value = value;
            ValueChanged.InvokeAsync(value);
        }
    }
    [Parameter]
    public EventCallback<AccountRuleDefinitionModel> ValueChanged { get; set; }

    [Parameter]
    public string Class { get; set; }

    [Parameter]
    public string LabelName { get; set; }

    public int? CoaID { get; set; } = 0;
    [Parameter]
    public string PaymentMode { get; set; } = "Bank";

    private AccountRuleDefinitionModel _value;

    private bool IsLoaded = false;

    private async Task<IEnumerable<AccountRuleDefinitionModel>> SearchAccounts(string searchString)
    {
        await Task.Delay(5);

        // return codeList.Where(x => (x.AccountCode).Contains(searchString == null ? string.Empty : searchString, StringComparison.InvariantCultureIgnoreCase));
        return codeListt.Where(x => (x.ArdCode).Contains(searchString == null ? string.Empty : searchString, StringComparison.InvariantCultureIgnoreCase));

    }
    public void valuechanged()
    {
        // PaymentMode = e.Value.ToString();
        _value.paymentMode = PaymentMode;
        getAll();
    }

    protected override async Task OnInitializedAsync()
    {
        //codeList = accountService.SelectChildren(CoaID).ToList();
        await getAll();
    }
    public async Task getAll()
    {
        var authprov = await auth.GetAuthenticationStateAsync();
        var brancIDString = authprov.User.Claims.First(x => x.Type == "BranchID").Value;
        int branchID = int.Parse(brancIDString);
        codeListt = accountService.GetPaymentCodes(branchID,PaymentMode).ToList();
        IsLoaded = true;
    }
}
