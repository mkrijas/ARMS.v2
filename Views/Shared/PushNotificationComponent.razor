@using ArmsModels.BaseModels.General
@using ArmsServices.DataServices.General
@using Microsoft.AspNetCore.SignalR.Client;
@using Microsoft.Extensions.Configuration;
@using TableDependency.SqlClient;
@using TableDependency.SqlClient.Base.EventArgs;
@using Views.Data
@using System.Threading;

@inject MudBlazor.ISnackbar snackbar
@inject SignalRService signalRService
@inject AuthenticationStateProvider auth
@attribute [Authorize]
@inject NavigationManager NavigationManager
@inject IDialogService DialogService
@inject IRoleService<RoleModel> Irole
@inject IPushNotificationService IpushNotificationService
@inject IConfiguration configuration



<MudOverlay @bind-Visible="@IsOpen" OnClick="@OverlayVisibleChanged" DarkBackground="true" AutoClose></MudOverlay>

    <MudBadge Visible="@(currentNotificationMessages.Count > 0)"
              Content="@currentNotificationMessages.Count"
              Origin="Origin.TopRight" Color="Color.Error" Overlap="true" Class="mx-2">
        <MudButton OnClick="@Toggle" StartIcon="@Icons.Material.Filled.Home" Color="Color.Inherit" Variant="Variant.Text" Class="px-2">
            <MudText Typo="Typo.subtitle2" Style="font-weight: 600;">@BranchName</MudText>
        </MudButton>
    </MudBadge>

    <MudPopover Open="@IsOpen"
                AnchorOrigin="Origin.BottomCenter"
                TransformOrigin="Origin.TopCenter"
                OverflowBehavior="OverflowBehavior.FlipOnOpen"
                Paper="true"
                Elevation="4"
                Class="pa-0">
        
        <div class="d-flex justify-space-between align-center px-3 py-2" style="background-color: #f8f8f8; border-bottom: 1px solid #eee;">
             <MudText Typo="Typo.subtitle2" Color="Color.Primary"><b>Notifications</b></MudText>
             <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small" OnClick="@(() => IsOpen = false)" />
        </div>

        <div style="max-height: 400px; overflow-y: auto; padding: 10px; min-width: 300px;">
            @if (currentNotificationMessages.Any())
            {
                @foreach (var nmObj in currentNotificationMessages.Take(Take))
                {
                    <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined" Class="my-2" ShowCloseIcon="true"
                              CloseIconClicked="(() => AknowledgedCurrentItem(nmObj.MessageID))" Style="background-color: #fff8e1;">
                        <div class="d-flex flex-column">
                             <MudText Typo="Typo.caption" Style="color: #757575; margin-bottom: 4px;">
                                 <MudIcon Icon="@Icons.Material.Filled.AccessTime" Size="Size.Small" Style="font-size: 0.7rem; vertical-align: middle;" /> 
                                 @nmObj.MessageTimeSpan
                             </MudText>
                             <MudText Typo="Typo.subtitle2" Style="color:#d18213; font-weight: 700;">@nmObj.MessageTitle</MudText>
                             <MudText Typo="Typo.body2" Class="mt-1">@nmObj.MessageBody</MudText>
                             
                            @if (!string.IsNullOrEmpty(nmObj.PageToRedirectLink))
                            {
                                <MudLink Href="#" OnClick="@(() => RedirectToLink(nmObj.PageToRedirectLink, nmObj.DocumentID))" Typo="Typo.caption" Class="mt-2" Underline="Underline.Always">
                                    <b>CLICK HERE</b>
                                </MudLink>
                            }
                        </div>
                    </MudAlert>
                }
            }
            else
            {
                <div class="d-flex flex-column align-center justify-center py-4">
                    <MudIcon Icon="@Icons.Material.Outlined.NotificationsNone" Size="Size.Large" Color="Color.Default" />
                    <MudText Typo="Typo.body2" Class="mt-2" Color="Color.Secondary">No new notifications</MudText>
                </div>
            }
        </div>

        @if (Take > 1 && currentNotificationMessages.Count() > 1)
        {
            <div style="text-align:center; padding: 8px; border-top: 1px solid #eee;">
                <MudButton OnClick="@AknowledgeAllInTheList" Variant="Variant.Text" Color="Color.Primary" Size="Size.Small">ACKNOWLEDGE ALL</MudButton>
            </div>
        }
    </MudPopover>

@code {

    [Parameter]
    public string BranchName { get; set; }

    #region SignaIR Notification
    private List<PushNotificationModel> currentNotificationMessages = new List<PushNotificationModel>();
    private HubConnection hubConnection;
    private string BoxCss = "none";
    List<PushNotificationGroupModel> GroupList = new();
    int Take = 5;

    string UserID;
    int BranchID = 0;
    bool IsOpen;

    void Toggle()
    {
        IsOpen = !IsOpen;
        Take = 5;
    }

    void OverlayVisibleChanged()
    {
        if (IsOpen)
            IsOpen = false;
    }

    protected override async Task OnInitializedAsync()
    {
        var authprov = await auth.GetAuthenticationStateAsync();
        var user = authprov.User;
        var brancIDString = authprov.User.Claims.FirstOrDefault(x => x.Type == "BranchID")?.Value;
        int.TryParse(brancIDString, out BranchID);
        UserID = user.Identity.Name;

        getNotifications();

        if (hubConnection == null || hubConnection.State == HubConnectionState.Disconnected)
        {
            hubConnection = new HubConnectionBuilder().WithUrl(NavigationManager.ToAbsoluteUri("/chatHub")).Build();
            hubConnection.On<string>("ReceiveMessage", async Triggered =>
            {
                getNotifications();
                Take = 1;
                IsOpen = currentNotificationMessages.Any();
                await InvokeAsync(() => StateHasChanged());
            });
            await hubConnection.StartAsync();
        }
    }

    private void getNotifications()
    {
        if (BranchID != 0)
        {
            CancellationTokenSource ctc = new CancellationTokenSource();
            currentNotificationMessages = IpushNotificationService.SelectActiveNotifications(BranchID, UserID).ToList();
        }
    }

    private void NotificationHideShow()
    {
        if (BoxCss == "none") BoxCss = "block"; else BoxCss = "none";
    }

    private async Task AknowledgeAllInTheList()
    {
        try
        {
            string MessageIDs = string.Join(",", currentNotificationMessages.Select(d => d.MessageID).ToList());
            var authprov = await auth.GetAuthenticationStateAsync();
            var user = authprov.User;
            var UserID = user.Identity.Name;

            int c = IpushNotificationService.AknowledgedSelectedItems(MessageIDs, UserID);

            // Clear all notifications after acknowledgment
            currentNotificationMessages.Clear();
            IsOpen = false; // Close popover if all notifications are acknowledged

            await InvokeAsync(StateHasChanged);
        }
        catch (Exception ex)
        {
            snackbar.Add(ex.Message, Severity.Error);
        }
    }

    private async Task AknowledgedCurrentItem(int? MessageID)
    {
        if (MessageID != null)
        {
            var CurrentMessage = currentNotificationMessages.FirstOrDefault(s => s.MessageID == MessageID);
            if (CurrentMessage != null && await Irole.HasClaim(CurrentMessage.DocumentTypeID.ToString(), "View"))
            {
                var authprov = await auth.GetAuthenticationStateAsync();
                var user = authprov.User;
                var UserID = user.Identity.Name;

                int c = IpushNotificationService.AknowledgedCurrentItem(MessageID, UserID);

                // Remove the acknowledged item from the list
                currentNotificationMessages.Remove(CurrentMessage);

                // If no messages left, close the popover
                if (!currentNotificationMessages.Any())
                {
                    IsOpen = false;
                }

                await InvokeAsync(StateHasChanged); // Force UI refresh
            }
            else
            {
                await DialogService.ShowMessageBox("Permission denied!", "You don't have permission to acknowledge.");
            }
        }
    }

    private void RedirectToLink(string RedirectToLink, int? DocumentID)
    {
        if (!string.IsNullOrEmpty(RedirectToLink))
        {
            if (DocumentID != null && DocumentID != 0)
            {
                RedirectToLink = RedirectToLink + "/" + DocumentID?.ToString() ?? "";
            }
            NavigationManager.NavigateTo(RedirectToLink);
        }
    }
    #endregion
}
