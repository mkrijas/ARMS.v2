@using System.Net
@inject IJSRuntime JSRuntime

<style>
    .rptStyle {
        height: 800px;
        background-color: white;
        border: 1px solid #D5D5D5;
        border-radius: 6px
    }
</style>

<MudPaper Style="padding: 22px 22px 18px 22px;">
    @* src set exclusively via JS to avoid Blazor re-renders causing double requests *@
    <iframe id="PreviewClaim" class="rptStyle" scrolling="auto"></iframe>
</MudPaper>

@code {

    [Parameter]
    public string ReportName { get; set; }

    [Parameter]
    public Dictionary<string, string> Parameters { get; set; }

    private string _lastRenderedUrl = string.Empty;

    public void setReportName(string RepName) { /* kept for backward compat */ }

    public async Task RenderReport()
    {
        if (string.IsNullOrEmpty(ReportName))
            return;

        // ── URL STRATEGY ─────────────────────────────────────────────────────────────
        // Use the SSRS DIRECT RENDER URL (not Pages/ReportViewer.aspx).
        //
        // Pages/ReportViewer.aspx requires an AJAX Delta POST cycle:
        //   GET → viewer shell (0 of 0) → ScriptManager Delta POST → rendered report
        // This cycle cannot be proxied reliably (ScriptManager errors / infinite loops).
        //
        // The DIRECT RENDER URL returns the full rendered report HTML in a SINGLE GET:
        //   /ssrs-proxy/{reportPath}?rs:Command=Render&rs:Format=HTML4.0&rc:Toolbar=true
        // Proxy maps this to:
        //   http://ssrs-server/ReportServer?/{reportPath}&rs:Command=Render&rs:Format=HTML4.0
        // SSRS returns the rendered HTML directly — no AJAX, no ScriptManager, no loop.
        // ─────────────────────────────────────────────────────────────────────────────
        var reportPath = $"ARMS_V2/ARMS_Reports/{ReportName}";

        var url = $"/ssrs-proxy/{reportPath}";
        url += $"?rs:Command=Render&rs:Format=HTML4.0&rc:Toolbar=false&rc:Parameters=false";

        if (Parameters != null)
        {
            foreach (var item in Parameters)
            {
                url += $"&{item.Key}={Uri.EscapeDataString(item.Value)}";
            }
        }

        // Deduplicate — skip if URL unchanged (prevents double-fire from Blazor re-renders)
        if (url == _lastRenderedUrl)
            return;

        _lastRenderedUrl = url;

        await JSRuntime.InvokeVoidAsync("console.log", $"[ReportViewer] Loading: {url}");
        await JSRuntime.InvokeVoidAsync("runReport", url);
    }
}
