@code {

    // URL = $"ssrs-proxy/Pages/ReportViewer.aspx?%2fARMS_V2%2fARMS_Reports%2f{_ReportName}"

    [Parameter]
    public string ReportName { get; set; }
    [Parameter]
    public Dictionary<string, string> Parameters { get; set; }
    private string URL { get; set; } = string.Empty;
    bool progress = false;
    private string _ReportName;


    protected override void OnParametersSet()
    {
        setReportName(ReportName);

        // Build the report path
        var reportPath = $"ARMS_V2/ARMS_Reports/{ReportName}";

        // Build query string
        var baseParams = new List<string>
        {
            "rc:embed=true",
            "rc:showbackbutton=true",
            "rs:Command=Render",
            "rc:Parameters=false"
        };

        if (Parameters != null)
        {
            foreach (var kv in Parameters)
            {
                baseParams.Add($"{kv.Key}={Uri.EscapeDataString(kv.Value)}");
            }
        }
        var queryString = string.Join("&", baseParams);

        // Set the URL for the iframe
        URL = $"/ssrs-proxy/{reportPath}?{queryString}";
    }


    public void setReportName(string RepName)
    {
        _ReportName = RepName;
    }

    

    public async Task RenderReport()
    {
        progress = true;

        // SSRS report path (NOT URL encoded for path, only for query values)
        var reportPath = $"ARMS_V2/ARMS_Reports/{_ReportName}";

        // Base command & render parameters
        var baseParams = new List<string>
    {
        "rc:embed=true",
        "rc:showbackbutton=true",
        "rs:Command=Render",
        "rc:Parameters=false"
    };

        // Add your report parameters
        foreach (var kv in Parameters)
        {
            baseParams.Add($"{kv.Key}={Uri.EscapeDataString(kv.Value)}");
        }

        var queryString = string.Join("&", baseParams);

        // Final URL - DO NOT encode path, only encode query values
        URL = $"/ssrs-proxy/{reportPath}?{queryString}";

        await JSRuntime.InvokeVoidAsync("console.log", $"Report URL: {URL}");

        //await JSRuntime.InvokeAsync<bool>("runReport", URL);

        progress = false;
    }

}


