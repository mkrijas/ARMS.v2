
         <iframe id="PreviewClaim" style="float: left; right: 5px; top: 65px;  background-color:white;" src="@URL"></iframe>


@code {

    [Parameter]
    public string ReportName { get; set; }
    [Parameter]
    public Dictionary<string,string> Parameters { get; set; }
    private string URL { get; set; } = string.Empty;


    protected override void OnParametersSet()
    {
        if (ReportName != null)
        {
            URL = "http://10.200.50.39/ReportServer/Pages/ReportViewer.aspx?%2fARMS_Reports%2f" + ReportName + "&rc:Parameters=false&rs:Command=Render&rc:Format=EXCEL";
            foreach (var item in Parameters)
            {
                URL = URL + "&" + item.Key + "=" + item.Value;
            }
        }
        // &branch=CBE&br=1&ason=10/01/2021&ev=0
    }

}
