@using System.Net
@implements IDisposable
@inject IJSRuntime JSRuntime

<style>
    .rptStyle {
        height: 800px;
        background-color: white;
        border: 1px solid #D5D5D5;
        border-radius: 6px;
    }
    .report-loader-wrapper {
        height: 800px;
        display: flex;
        align-items: center;
        justify-content: center;
        border: 1px solid #D5D5D5;
        border-radius: 6px;
        overflow: hidden;   /* ensure loader stays within this box */
    }
</style>

<MudPaper Style="padding: 22px 22px 18px 22px;">
    @if (_isLoading)
    {
        <div class="report-loader-wrapper">
            <LoaderComponent IsFullScreen="false"
                             ShowLogo="false"
                             Size="medium"
                             LoadingText="Loading Report"
                             SubText="Fetching data from SSRS..." />
        </div>
    }

    @* iframe always in DOM; visually hidden while loader is active *@
    <iframe id="PreviewClaim"
            class="rptStyle"
            scrolling="auto"
            style="@(_isLoading ? "display:none;" : "")">
    </iframe>
</MudPaper>

@code {

    [Parameter] public string ReportName  { get; set; }
    [Parameter] public Dictionary<string, string> Parameters { get; set; }

    // ── State ─────────────────────────────────────────────────────────────────
    private bool   _renderRequested = false;
    private string _pendingUrl      = string.Empty;
    private bool   _isLoading       = false;
    private DotNetObjectReference<ReportViewer> _dotNetRef;

    // ── Lifecycle ─────────────────────────────────────────────────────────────

    protected override void OnInitialized()
    {
        _dotNetRef = DotNetObjectReference.Create(this);
    }

    /// <summary>
    /// Runs AFTER Blazor propagates fresh [Parameter] values.
    /// Builds the URL when _renderRequested is true and a valid ReportName is available.
    /// This handles the case where the parent doesn't provide an explicit name override.
    /// </summary>
    protected override Task OnParametersSetAsync()
    {
        if (_renderRequested && !string.IsNullOrEmpty(ReportName))
        {
            _renderRequested = false;
            _pendingUrl = BuildUrl(ReportName);
        }
        return Task.CompletedTask;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!string.IsNullOrEmpty(_pendingUrl))
        {
            var url     = _pendingUrl;
            _pendingUrl = string.Empty;
            await JSRuntime.InvokeVoidAsync("runReportWithCallback", url, _dotNetRef);
        }
    }

    // ── Public API ────────────────────────────────────────────────────────────

    public void setReportName(string RepName) { }   // backward compat

    /// <summary>
    /// Called by the parent page on "View Report" click.
    /// 
    /// Two modes:
    ///   1. No arg (default):  sets _renderRequested=true; OnParametersSetAsync builds
    ///      the URL once Blazor has propagated the fresh ReportName parameter.
    ///      Works for all pages except those that reset ReportName=null after this call.
    ///
    ///   2. reportNameOverride provided:  URL is built immediately using this value
    ///      + the current Parameters dictionary. Use this for pages that set
    ///      ReportName=null after calling RenderReport().
    /// </summary>
    public async Task RenderReport(string reportNameOverride = null)
    {
        _isLoading  = true;
        _pendingUrl = string.Empty;   // clear any stale request

        if (!string.IsNullOrEmpty(reportNameOverride))
        {
            // Build immediately — caller has the correct name right now
            _renderRequested = false;
            _pendingUrl = BuildUrl(reportNameOverride);
        }
        else
        {
            // Wait for Blazor to propagate the [Parameter] ReportName via OnParametersSetAsync
            _renderRequested = true;
        }

        StateHasChanged();
        await Task.CompletedTask;
    }

    [JSInvokable]
    public void OnIframeLoadComplete()
    {
        _isLoading = false;
        StateHasChanged();
    }

    public void Dispose()
    {
        _dotNetRef?.Dispose();
    }

    // ── Helpers ───────────────────────────────────────────────────────────────

    private string BuildUrl(string reportName)
    {
        var url = $"/ssrs-proxy/ARMS_V2/ARMS_Reports/{reportName}?rs:Command=Render&rs:Format=HTML4.0&rc:Toolbar=false&rc:Parameters=false";
        if (Parameters != null)
            foreach (var item in Parameters)
                url += $"&{item.Key}={Uri.EscapeDataString(item.Value)}";
        return url;
    }
}
