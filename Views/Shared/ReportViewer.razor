@using System.Net
@inject IJSRuntime JSRuntime

<style>
    .rptStyle {
        height: 800px;
        background-color: white;
        border: 1px solid #D5D5D5;
        border-radius: 6px
    }
</style>

<MudPaper Style="padding: 22px 22px 18px 22px;">
    @* src set exclusively via JS in OnAfterRenderAsync — never via Blazor binding *@
    <iframe id="PreviewClaim" class="rptStyle" scrolling="auto"></iframe>
</MudPaper>

@code {

    [Parameter]
    public string ReportName { get; set; }

    [Parameter]
    public Dictionary<string, string> Parameters { get; set; }

    // URL queued by RenderReport(); consumed by OnAfterRenderAsync
    private string _pendingUrl = string.Empty;
    private string _lastRenderedUrl = string.Empty;

    public void setReportName(string RepName) { /* kept for backward compat */ }

    /// <summary>
    /// Called by the parent page when it wants to display a report.
    /// Queues the URL and triggers a Blazor re-render so OnAfterRenderAsync
    /// can safely invoke JS after Blazor has committed the DOM.
    /// </summary>

    public async Task RenderReport()
    {
        if (string.IsNullOrEmpty(ReportName))
            return;

        // ── URL STRATEGY ─────────────────────────────────────────────────────────────
        // Use the SSRS DIRECT RENDER URL (not Pages/ReportViewer.aspx).
        // The proxy maps:
        //   /ssrs-proxy/{reportPath}?rs:Command=Render&rs:Format=HTML4.0
        // → http://ssrs-server/ReportServer?/{reportPath}&rs:Command=Render&rs:Format=HTML4.0
        // SSRS returns fully-rendered HTML in a single GET — no AJAX, no ScriptManager.
        // ─────────────────────────────────────────────────────────────────────────────
        var reportPath = $"ARMS_V2/ARMS_Reports/{ReportName}";
        var url = $"/ssrs-proxy/{reportPath}?rs:Command=Render&rs:Format=HTML4.0&rc:Toolbar=false&rc:Parameters=false";

        if (Parameters != null)
        {
            foreach (var item in Parameters)
                url += $"&{item.Key}={Uri.EscapeDataString(item.Value)}";
        }

        if (url == _lastRenderedUrl)
            return;

        // Queue the URL — OnAfterRenderAsync will pick it up after the next render
        _pendingUrl = url;
        StateHasChanged(); // request a re-render so OnAfterRenderAsync fires
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!string.IsNullOrEmpty(_pendingUrl))
        {
            var url = _pendingUrl;
            _pendingUrl = string.Empty;   // clear before await to prevent double-fire
            _lastRenderedUrl = url;

            await JSRuntime.InvokeVoidAsync("console.log", $"[ReportViewer] Loading: {url}");
            await JSRuntime.InvokeVoidAsync("runReport", url);
        }
    }
}

