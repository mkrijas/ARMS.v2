@inject IAssetService Iasset
@using System.Threading

@if (IsLoaded)
{
    <MudAutocomplete 
        Variant="Variant.Outlined" 
        Margin="Margin.Dense"         
        SelectValueOnTab 
        ResetValueOnEmptyText
        Clearable
        CoerceValue
        @ref="_autoComplete" 
        Class="@Class" 
        T="AssetModel"         
        Label="@Label" 
        @bind-Value="_value" 
        AdornmentColor="Color.Secondary" 
        SearchFunc="SearchAsset" 
        ToStringFunc="@(e => (e == null || string.IsNullOrWhiteSpace(e.AssetCode) && string.IsNullOrWhiteSpace(e.Description)) ? null : string.Format("{0} | {1}",e.AssetCode,e.Description))"
        ></MudAutocomplete>

}
else
{
    <MudText> Loading..... </MudText>
}

@code {

    [Parameter] public EventCallback<bool> SetAssets { get; set; }
    [Parameter] public string Label { get; set; } = "Select Asset";
    [Parameter] public int BranchID { get; set; } = 0;
    [Parameter] public int? SubClassID { get; set; } = null;
    [Parameter] public bool ClearOnSelect { get; set; } = false;
    [Parameter] public bool LimitToMainAssets { get; set; } = false;

    [Parameter]
    public AssetModel Value { get; set; }

    private AssetModel _value
    {
        get => Value;
        set
        {
            if (Value == value) return;
            Value = value;
            ValueChanged.InvokeAsync(value);
        }
    }

    private List<AssetModel> AssetList = new();
    private MudAutocomplete<AssetModel> _autoComplete { get; set; } = new();

    // private async Task Enter(KeyboardEventArgs e)
    // {
    //     if (e.Code == "Enter" || e.Code == "NumpadEnter")
    //     {         
    //         await SetAssets.InvokeAsync();
    //         if (ClearOnSelect)
    //         {
    //             await _autoComplete.ResetAsync();
    //         }
    //         await SearchAsset("", CancellationToken.None);
    //     }
    //}

    [Parameter]
    public EventCallback<AssetModel> ValueChanged { get; set; }

    [Parameter]
    public string Class { get; set; }
    private bool IsLoaded = false;

    [Parameter]
    public List<AssetModel> PassedListAssets { get; set; }

    private async Task<IEnumerable<AssetModel>> SearchAsset(string searchString, CancellationToken token)
    {
        await Task.Delay(3, token);

        if (PassedListAssets != null && PassedListAssets.Count() != 0)
        {
            var result = AssetList.Where(x => (!PassedListAssets.Any(g => g.AssetID == x.AssetID)) && string.Join(x.AssetCode, " ", x.Description).Contains(searchString == null ? string.Empty : searchString, StringComparison.InvariantCultureIgnoreCase));
            return result;
        }
        else
        {
            return AssetList.Where(x => string.Join(x.AssetCode, " ", x.Description).Contains(searchString == null ? string.Empty : searchString, StringComparison.InvariantCultureIgnoreCase));

        }
    }

    protected override void OnInitialized()
    {
        if (PassedListAssets != null && PassedListAssets.Count() != 0)
        {
            AssetList = Iasset.SelectBySubClass(BranchID, SubClassID).Where(s => !PassedListAssets.Any(g => g.AssetID == s.AssetID)).ToList();
        }
        else
        {
            AssetList = Iasset.SelectBySubClass(BranchID, SubClassID).ToList();
        }

        if(LimitToMainAssets)
        {
            AssetList = AssetList.Where(x => x.ParentAssetID is null).ToList();
        }
        IsLoaded = true;
    }
}
