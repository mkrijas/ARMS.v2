@inject IAssetService Iasset

@if (IsLoaded)
{
    <MudAutocomplete Variant="Variant.Outlined" SelectValueOnTab @ref="_autoComplete" Class="@Class" T="AssetModel" OnKeyUp="Enter" Label="@Label" @bind-Value="Value" AdornmentColor="Color.Secondary" ResetValueOnEmptyText="true"
                 Clearable="true" SearchFunc="SearchAsset" ToStringFunc="@(e => e == null ? null : string.Format("{0} | {1}",e.AssetCode,e.Description))" ></MudAutocomplete>

}
else
{
    <MudText> Loading..... </MudText>
}

@code {
    private List<AssetModel> AssetList = new();
    private MudAutocomplete<AssetModel> _autoComplete {get;set;}
    [Parameter] public EventCallback<bool> SetAssets { get; set; }
    [Parameter] public string Label { get; set; } = "Select Asset";
    [Parameter] public int BranchID { get; set; } = 0;         
    
    [Parameter]
    public AssetModel Value
    {
        get => _value;
        set
        {
            if (_value == value) return;
            _value = value;
            ValueChanged.InvokeAsync(value);
        }
    }

    private async Task Enter(KeyboardEventArgs e)
    {
        if (e.Code == "Enter" || e.Code == "NumpadEnter")
        {
            await SetAssets.InvokeAsync();
            await _autoComplete.Clear();
            await SearchAsset("");
        }
    }

    [Parameter]
    public EventCallback<AssetModel> ValueChanged { get; set; }

    [Parameter]
    public string Class { get; set; }

    private AssetModel _value;
    private bool IsLoaded = false;

    [Parameter]
    public List<AssetModel> PassedListAssets { get; set; }

    private async Task<IEnumerable<AssetModel>> SearchAsset(string searchString)
    {
        await Task.Delay(3);

        if (PassedListAssets != null && PassedListAssets.Count() != 0)
        {
            var result = AssetList.Where(x => (!PassedListAssets.Any(g => g.AssetID == x.AssetID)) && x.AssetCode.Contains(searchString == null ? string.Empty : searchString, StringComparison.InvariantCultureIgnoreCase));
            return result;
        }
        else
        {
            return AssetList.Where(x => x.AssetCode.Contains(searchString == null ? string.Empty : searchString, StringComparison.InvariantCultureIgnoreCase));

        }
    }

    protected override void OnInitialized()
    {
        if (PassedListAssets != null && PassedListAssets.Count() != 0)
        {
            AssetList = Iasset.SelectByBranch(BranchID,false).Where(s => !PassedListAssets.Any(g => g.AssetID == s.AssetID)).ToList();
        }
        else
        {
            AssetList = Iasset.GetAttachedAssets(null).ToList();
        }
        IsLoaded = true;
    }
}
