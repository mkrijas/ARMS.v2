@inject IBranchService BrService

@if (IsLoaded)
{
    <MudAutocomplete Class="@Class" T="BranchModel" Variant="Variant.Outlined" Margin="Margin.Dense" Label="@LabelName" @bind-Value="Value" ResetValueOnEmptyText="true"
                 Clearable="true" SearchFunc="SearchAccounts" Text="@Value?.BranchName" ToStringFunc="@(e => (e == null || string.IsNullOrEmpty(e.BranchName)) ? null : string.Format("{0} | {1}",e.BranchCode,e.BranchName))"></MudAutocomplete>

}
else
{
    <MudText> Loading..... </MudText>
}
@code {
  
    private List<BranchModel> BranchList = new();
    [Parameter]
    public BranchModel Value
    {
        get => _value;
        set
        {
            if (_value == value) return;
            _value = value;
            ValueChanged.InvokeAsync(value);
        }
    }
    [Parameter]
    public EventCallback<BranchModel> ValueChanged { get; set; }

    [Parameter]
    public string Class { get; set; }

    [Parameter]
    public string LabelName { get; set; }

    private BranchModel _value;

    private bool IsLoaded = false;

    private async Task<IEnumerable<BranchModel>> SearchAccounts(string searchString)
    {
        await Task.Delay(5);

        return BranchList.Where(x => (x.BranchCode + " " + x.BranchName).Contains(searchString == null ? string.Empty : searchString, StringComparison.InvariantCultureIgnoreCase));
    }


    protected override void OnInitialized()
    {
        BranchList = BrService.Select().ToList();
        IsLoaded = true;
    }
}
