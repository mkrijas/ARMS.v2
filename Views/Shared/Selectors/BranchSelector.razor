@inject IBranchService BrService

@if (IsLoaded)
{
    <MudAutocomplete Disabled="IsDisabled" Class="@Class" T="BranchModel" Variant="Variant.Outlined" Margin="Margin.Dense" Label="@LabelName" @bind-Value="Value" ResetValueOnEmptyText="true"
                 Clearable="true" SearchFunc="SearchAccounts" Text="@Value?.BranchName" ToStringFunc="@(e => (e == null || string.IsNullOrEmpty(e.BranchName)) ? null : string.Format("{0} | {1}",e.BranchAbbrev,e.BranchName))"></MudAutocomplete>
}
else
{
    <MudText> Loading..... </MudText>
}
@code {
    [Parameter]
    public bool IsDisabled { get; set; } = false;

    [Parameter]
    public BranchModel Value
    {
        get => _value;
        set
        {
            if (_value != value)
            {
                _value = value;
                ValueChanged.InvokeAsync(_value);
            }
        }
    }
    [Parameter]
    public EventCallback<BranchModel> ValueChanged { get; set; }

    [Parameter]
    public int? Except { get; set; } = 0;

    [Parameter]
    public string Class { get; set; }

    [Parameter]
    public string LabelName { get; set; }

    private BranchModel _value;
    private List<BranchModel> BranchList = new();
    private bool IsLoaded = false;

    private async Task<IEnumerable<BranchModel>> SearchAccounts(string searchString)
    {
        await Task.Delay(3);
        return BranchList.Where(x => (x.BranchAbbrev + " " + 
        x.BranchName).Contains(searchString == null ? string.Empty : searchString, StringComparison.InvariantCultureIgnoreCase)
        && x.BranchID != Except);
    }


    protected override void OnInitialized()
    {
        BranchList = BrService.Select().Where(b => b.BranchID != Except).ToList();
        IsLoaded = true;
    }
}
