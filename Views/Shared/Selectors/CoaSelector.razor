@inject IChartOfAccountService accountService

@if(IsLoaded)
{
    <MudAutocomplete Class="@Class"  T="ChartOfAccountModel" Variant="Variant.Outlined" Margin="Margin.Dense" Label="@LabelName" @bind-Value="Value" ResetValueOnEmptyText="true"
                     Clearable="true" SearchFunc="SearchAccounts" Text="@Value?.AccountName" ToStringFunc="@(e => (e == null || string.IsNullOrEmpty(e.AccountName)) ? null : string.Format("{0} | {1}",e.AccountCode,e.AccountName))" Disabled="IsDisable"></MudAutocomplete>

}
else
{
   <MudText> Loading..... </MudText> 
}
@code {
    private List<ChartOfAccountModel> accountList = new();
    [Parameter]
    public bool IsDisable { get; set; } = false;
    [Parameter]
    public ChartOfAccountModel Value
    {
        get => _value;
        set
        {
            if (_value == value) return;
            _value = value;
            ValueChanged.InvokeAsync(value);
        }
    }

    [Parameter]
    public EventCallback<ChartOfAccountModel> ValueChanged { get; set; }

    [Parameter]
    public string Class { get; set; }

    [Parameter]
    public string LabelName { get; set; }

    [Parameter]
    public int? AccountGroup { get; set; } = 0;// Select Child Accounts under this value

    [Parameter]
    public bool IsFetchAll { get; set; } = false;

    private ChartOfAccountModel _value;
    private bool IsLoaded = false;



    // private async Task<IEnumerable<ChartOfAccountModel>> SearchAccounts(string searchString)
    //{
    //    await Task.Delay(3);

    //    return accountList.Where(x => x.AccountName.Contains(searchString == null ? string.Empty : searchString, StringComparison.InvariantCultureIgnoreCase));
    //}

    private async Task<IEnumerable<ChartOfAccountModel>> SearchAccounts(string searchString)
    {
        await Task.Delay(5);

        return accountList.Where(x => (x.AccountName +" "+x.AccountCode).Contains(searchString == null ? string.Empty : searchString, StringComparison.InvariantCultureIgnoreCase));
    }


    protected override void OnInitialized()
    {
        if(IsFetchAll)
        {

            accountList = accountService.AllLedgers().ToList();
            IsLoaded = true;
        }
        else
        {
            accountList = accountService.SelectByGroup(AccountGroup).ToList();
            IsLoaded = true;
        }
    }
}
