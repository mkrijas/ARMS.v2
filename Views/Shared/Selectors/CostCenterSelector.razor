@inject ICostCenterService IccService

<MudSelect ReadOnly="ReadOnly" Label="Cost Center" Value="@Value" ValueChanged="SelectedCostCenter" T="int?"
Variant="Variant.Outlined" Margin="Margin.Dense" OffsetY="true" Direction="Direction.Top" AdornmentColor="Color.Secondary"
For="@(() => Value)" >
    @foreach (var ditem in costCenters)
    {
        <MudSelectItem Value="@ditem.CostCenterID">@ditem.CostCenter</MudSelectItem>
    }
</MudSelect>



@code {

    [Parameter]
    public bool ReadOnly { get; set; }

    [Parameter]
    public int? Value
    {
        get => _value;
        set
        {
            if (_value == value) return;
            _value = value;
            ValueChanged.InvokeAsync(value);
        }
    }

    [Parameter]
    public string ValueText
    {
        get => _valueText;
        set
        {
            if (_valueText == value) return;
            _valueText = value;
            ValueTextChanged.InvokeAsync(value);
        }
    }

    [Parameter]
    public EventCallback<int?> ValueChanged { get; set; }

    [Parameter]
    public EventCallback<string> ValueTextChanged { get; set; }

    private int? _value;

    private string _valueText;

    private List<CostCenterModel> costCenters = new();

    protected override void OnInitialized()
    {
        costCenters = IccService.Select().ToList();
        if (costCenters.Any(x => x.CostCenterID == Value))
        {
            ValueText = costCenters.FirstOrDefault(x => x.CostCenterID == Value).CostCenter;
        }
    }

    async Task SelectedCostCenter(int? val)
    {
        Value = val;
        ValueText = costCenters.FirstOrDefault(x => x.CostCenterID == Value).CostCenter;
    }
}
