@inject IDimensionService dimensionIservice

<MudSelect ReadOnly="ReadOnly" Label="Select Dimension" @bind-Value="@Value" T="int?" 
Variant="Variant.Outlined" Margin="Margin.Dense" OffsetY="true" Direction="Direction.Top"
           AdornmentColor="Color.Secondary"For="@(() => Value)" >
    @foreach (var ditem in dimensions)
    {
        <MudSelectItem Value="@ditem.DimensionID">@ditem.Dimension</MudSelectItem>
    }
</MudSelect>

@code {

    [Parameter]
    public bool ReadOnly { get; set; }

    [Parameter]
    public int? Value
    {
        get => _value;
        set
        {
            if (_value == value) return;
            _value = value;
            ValueChanged.InvokeAsync(value);
        }
    }

    [Parameter]
    public EventCallback<int?> ValueChanged { get; set; }

    private int? _value;

    private List<DimensionModel> dimensions = new();

    protected override void OnInitialized()
    {
        dimensions = dimensionIservice.Select().ToList();
    }

}
