@if (page == "Asset")
{
    <MudSelect ReadOnly=@ReadOnly Value="@Value" ValueChanged="SelectedMechanism" T="string" Variant="Variant.Outlined" Margin="Margin.Dense" AdornmentColor="Color.Secondary" AnchorOrigin="Origin.BottomCenter">
        @foreach (var ditem in GstMechanismList)
        {
            <MudSelectItem Value="@ditem">@ditem</MudSelectItem>
        }
    </MudSelect>
}
else
{
    <MudSelect ReadOnly=@ReadOnly Label="Gst Mechanism" Value="@Value" ValueChanged="SelectedMechanism" T="string" Variant="Variant.Outlined" Margin="Margin.Dense" AdornmentColor="Color.Secondary" AnchorOrigin="Origin.BottomCenter">
        @foreach (var ditem in GstMechanismList)
        {
            <MudSelectItem Value="@ditem">@ditem</MudSelectItem>
        }
    </MudSelect>
}

@code {

    private List<string> GstMechanismList = new List<string>() { "FCM", "RCM", "INELIGIBLE", "NON TAXABLE", "NON GST", "EXEMPTED" };
    private string _value;
    [Parameter]
    public bool ReadOnly { get; set; } = false;

    [Parameter]
    public EventCallback<string> ValueChanged { get; set; }

    [Parameter]
    public string page { get; set; }

    [Parameter]
    public String Value
    {
        get => _value;
        set
        {
            if (_value == value) return;
            _value = value;
            ValueChanged.InvokeAsync(value);
        }
    }

    async Task SelectedMechanism(string val)
    {
        Value = val;
    }
}
