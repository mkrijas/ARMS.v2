@inject IInventoryItemService itemIservice

@if (IsLoaded)
{
    <MudAutocomplete SelectValueOnTab id="@ElementID" Class="@Class" T="InventoryItemModel" Variant="Variant.Outlined" Margin="Margin.Dense" Label="@LabelName" @bind-Value="Value" ResetValueOnEmptyText="true"
                 Clearable="true" SearchFunc="SearchItems" Text="@Value?.ItemDecription" ToStringFunc="@(e =>  string.IsNullOrEmpty(e?.InventoryItemCode) ? null : string.Format("{0} | {1}",e.InventoryItemCode,e.ItemDecription))"></MudAutocomplete>

}
else
{
    <MudText> Loading..... </MudText>
}
@code {
    private List<InventoryItemModel> itemsList = new();

    [Parameter]
    public InventoryItemModel Value
    {
        get => _value;
        set
        {
            if (_value == value) return;
            _value = value;
            ValueChanged.InvokeAsync(value);
        }
    }

    [Parameter]
    public EventCallback<InventoryItemModel> ValueChanged { get; set; }

    [Parameter]
    public string Class { get; set; }

    [Parameter]
    public string LabelName { get; set; } = "Select Item";

    [Parameter]
    public string ElementID { get; set; } = "UsageID";

    [Parameter]
    public int? ItemGroup { get; set; } = 0;// Select Children under this value


    private InventoryItemModel _value;
    private bool IsLoaded = false;

    private async Task<IEnumerable<InventoryItemModel>> SearchItems(string searchString)
    {
        await Task.Delay(3);
        return itemsList.Where(x => (x.ItemDecription + " " + x.InventoryItemCode).Contains(searchString == null ? string.Empty : searchString, StringComparison.InvariantCultureIgnoreCase));
    }

    protected override void OnInitialized()
    {        
        itemsList = itemIservice.SelectByGroup(ItemGroup).ToList();
        IsLoaded = true;
    }
}
