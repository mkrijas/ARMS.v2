@inject IInventoryItemService itemIservice

@if (IsLoaded)
{
    <MudAutocomplete ReadOnly="ReadOnly" autocomplete="Select-an-Item" SelectValueOnTab id="@ElementID" Class="@Class" 
        T="InventoryItemModel" Variant="@CurrentVariant" Margin="@CurrentMargine" Label="@LabelName" @bind-Value="Value" 
        ResetValueOnEmptyText="true" Clearable="true" SearchFunc="SearchItems" 
        ToStringFunc="@(e =>  string.IsNullOrEmpty(e?.InventoryItemCode) ? null : string.Format("{0} | {1} - {2}",e.InventoryItemCode,e.ItemGroup.ItemGroupDescription,e.ItemDescription))"></MudAutocomplete>
}
else
{
    <MudText> Loading..... </MudText>
}
@code {

    private List<InventoryItemModel> itemsList = new();
    [Parameter]
    public bool ReadOnly { get; set; }
    [Parameter]
    public InventoryItemModel Value
    {
        get => _value;
        set
        {
            if (_value == value) return;
            _value = value;
            ValueChanged.InvokeAsync(value);
        }
    }

    [Parameter]
    public EventCallback<InventoryItemModel> ValueChanged { get; set; }
    [Parameter]
    public string Class { get; set; }
    [Parameter]
    public string LabelName { get; set; } = "Select Item";
    [Parameter]
    public string ElementID { get; set; } = "UsageID";
    [Parameter]
    public int? ItemGroup { get; set; } = 0;// Select Children under this value
    [Parameter]
    public string ItemGroup2 { get; set; } = null;
    [Parameter]
    public Margin CurrentMargine { get; set; } = Margin.Dense;
    [Parameter]
    public Variant CurrentVariant { get; set; } = Variant.Outlined;

    private InventoryItemModel _value;
    private bool IsLoaded = false;

    private async Task<IEnumerable<InventoryItemModel>> SearchItems(string searchString)
    {
        await Task.Delay(3);
        return itemsList.Where(x => (x.ItemDescription + " " + x.InventoryItemCode + x.ItemGroup.ItemGroupDescription).Contains(searchString == null ? string.Empty : searchString, StringComparison.InvariantCultureIgnoreCase));
    }

    protected override void OnInitialized()
    {
        itemsList = itemIservice.SelectByGroup(ItemGroup).ToList();
        if(ItemGroup2=="Fuel")
        {
            itemsList = itemsList.Where(x => x.ItemGroup.Group2ID == 6).ToList();
        }
        if (ItemGroup2 == "AdBlue")
        {
            itemsList = itemsList.Where(x => x.ItemGroup.Group2ID == 1).ToList();
        }
        IsLoaded = true;
        if (CurrentMargine == Margin.None)
        {
            CurrentMargine = Margin.Dense;
        }
    }
}