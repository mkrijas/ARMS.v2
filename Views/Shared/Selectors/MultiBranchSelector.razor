@inject IBranchService ibranch




<MudDialog>
    <TitleContent>
        <h4>Select Branches</h4>         
        <MudCheckBox Checked="SelectAll" CheckedChanged="SelectAllChanged" T="bool" Label="Select All" Size="Size.Large" Color="Color.Success"></MudCheckBox>
    </TitleContent>
    <DialogContent>       
        <MudGrid Class="p-5">
            @foreach (var item in AllBranches)
            {
                <MudItem xs="6" md="4" xl="3"  Class="m-0 p-0">
                    <MudCheckBox T="bool" Checked="@(UpdatedBranches.Any(x =>  x == item.BranchID.Value))" CheckedChanged="@((e)=> CheckedChanged(e,item.BranchID.Value))" Label="@item.BranchName" Color="Color.Primary" ></MudCheckBox>
                </MudItem>
            }
        </MudGrid>
    </DialogContent>
    <DialogActions>
        <MudButton ButtonType="ButtonType.Button" OnClick="@Submit" > Submit</MudButton>
    </DialogActions>
</MudDialog>





@code {
    [CascadingParameter] MudDialogInstance MudDialog { get; set; }

    [Parameter]
    public List<int> SelectedBranches { get; set; }

    List<int> UpdatedBranches = new();
    List<BranchModel> AllBranches = new();
    bool SelectAll;

    protected override void OnInitialized()
    {
        AllBranches = ibranch.Select().ToList();
        foreach(var item in SelectedBranches)
        {
            UpdatedBranches.Add(item);
        }
        SetSelectAll();
    }

    void SetSelectAll()
    {
        SelectAll = UpdatedBranches.Count == AllBranches.Count;        
    }


    void CheckedChanged(bool val, int BranchID)
    {
        if (val)
        {
            UpdatedBranches.Add(BranchID);
        }
        else
        {
            UpdatedBranches.Remove(BranchID);
        }
        SetSelectAll();
    }

    void Submit()
    {
        MudDialog.Close(UpdatedBranches);
    }


    void SelectAllChanged(bool val)
    {
        SelectAll = val;
        if (val)
        {
            foreach (var item in AllBranches.Select(x => x.BranchID.Value).Except(UpdatedBranches))
            {
                UpdatedBranches.Add(item);
            }
        }
        else
        {
            UpdatedBranches.Clear();
        }
    }

}
