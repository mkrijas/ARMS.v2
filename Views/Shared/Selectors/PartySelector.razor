@inject IPartyService partyIservice
@using System.Linq.Expressions


<MudAutocomplete SelectValueOnTab T="PartyModel" @bind-Value="@Value"
                 Variant="Variant.Outlined" Margin="Margin.Dense" Label="@label" ResetValueOnEmptyText="true"
                 For="@For" ReadOnly="@ReadOnly"
                 SearchFunc="@SearchParty" ToStringFunc="@(e => (e == null || string.IsNullOrEmpty(e.TradeName)) ? null : string.Format("{0} | {1}",e.PartyCode,e.TradeName))">
</MudAutocomplete>

@code {


    [Parameter]
    public string NatureOfBusiness { get; set; } = "Select";

    [Parameter]
    public int? BranchID { get; set; } = null;

    [Parameter]
    public bool ReadOnly { get; set; }

    [Parameter]
    public PartyModel Value
    {
        get => _value;
        set
        {
            if (_value == value) return;
            _value = value;
            ValueChanged.InvokeAsync(value);
        }
    }
    [Parameter]
    public string label{ get; set; }

    [Parameter]
    public bool IncludeRenter { get; set; } = false;

    [Parameter]
    public bool IncludeSisterConcern { get; set; } = false;

    [Parameter]
    public Expression<Func<PartyModel>> For { get; set; }

    [Parameter]
    public EventCallback<PartyModel> ValueChanged { get; set; }
    private PartyModel _value;


    private List<PartyModel> partyList = new();

    protected override void OnParametersSet()
    {
        if (String.IsNullOrEmpty(label))
        {

            if (NatureOfBusiness == "Select" || string.IsNullOrWhiteSpace(NatureOfBusiness))
            {
                label = "Select Party";
            }
            else
            {
                label = "Select " + NatureOfBusiness;
            }
        }
        var RenterNatureBusiness = IncludeRenter ? "Renter" : "none";
        var SisterNatureBusiness = IncludeRenter ? "SisterConcern" : "none";
        if (BranchID is null)
        {
            partyList = partyIservice.Select(null).Where(y => NatureOfBusiness == "Select" || y.NatureOfBusiness == NatureOfBusiness || y.NatureOfBusiness == RenterNatureBusiness || y.NatureOfBusiness == SisterNatureBusiness).ToList();
        }
        else
        {
            partyList = partyIservice.SelectByBranch(BranchID).Where(y => NatureOfBusiness == "Select" || y.NatureOfBusiness == NatureOfBusiness || y.NatureOfBusiness == RenterNatureBusiness || y.NatureOfBusiness == SisterNatureBusiness).ToList();           
        }        
    }


    private async Task<IEnumerable<PartyModel>> SearchParty(string searchString)
    {
        await Task.Delay(5);
        if (searchString is null)
            return partyList;
        return await Task.FromResult(partyList.Where(x => (x.TradeName + " " + x.PartyCode).Contains(searchString, StringComparison.InvariantCultureIgnoreCase)));
    }
}
