@inject IChartOfAccountService accountService
@inject AuthenticationStateProvider auth
@inject TruckDataArrayModel data
@using System.Linq.Expressions

@if (IsLoaded)
{
    <MudElement Class="d-flex flex-grow-1 gap-4">
        @if (!HideMode)
        {
            <MudSelect Disabled="@ReadOnly" Label="Mode" Class="flex-auto" Value="@PaymentMode" ValueChanged="Modechanged" T="string" Variant="Variant.Outlined" Margin="Margin.Dense" OffsetY="true" AnchorOrigin="Origin.BottomCenter" AdornmentColor="Color.Secondary" For="@(() => PaymentMode)">
                <MudSelectItem @key="@("Bank")" Value="@("Bank")" />
                <MudSelectItem @key="@("Cash")" Value="@("Cash")" />
                <MudSelectItem @key="@("Wallet")" Value="@("Wallet")" />
            </MudSelect>
        }
        <MudAutocomplete Disabled="@ReadOnly" Class="flex-auto" T="PaymentCodeModel" Variant="Variant.Outlined" Margin="Margin.Dense" Label="@LabelName" Value="@PaymentCode" ValueChanged="_ardCodeChanged" ResetValueOnEmptyText="true"
                         Clearable="true" SearchFunc="SearchAccounts" ToStringFunc="@(e => (e == null || string.IsNullOrEmpty(e.ArdCode)) ? null : string.Format("{0} | {1}",e.ArdCode,e.Title))"></MudAutocomplete>
        <ValidationMessage For="@(()=> ArdCode)"></ValidationMessage>

        @if (PaymentMode == "Bank")
        {
            @if (!HideTool)
            {
                <MudSelect Disabled="@ReadOnly" Class="flex-shrink-0" Style="min-width:200px;" T="string" Label="Bank Tool" Value="@BankTool" ValueChanged="_BankToolChanged" Variant="Variant.Outlined" Margin="Margin.Dense" OffsetY="true" AnchorOrigin="Origin.BottomCenter" AdornmentColor="Color.Secondary" For="@(()=> BankTool)">
                    @foreach (var item in data.BankTools)
                    {
                        <MudSelectItem Value="@item">@item</MudSelectItem>
                    }
                </MudSelect>
            }
            @if (!HideBankCharges)
            {
                <MudTextField Disabled="@ReadOnly" Class="flex-none" T="decimal?" Value="@BankCharges" ValueChanged="_BankChargesChanged" Label="BankCharges" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(()=> BankCharges)"></MudTextField>
            }
        }
    </MudElement>
}
else
{
    <MudText> Loading..... </MudText>
}

@code {
    [Parameter]
    public int BranchID { get; set; } = 0;
    [Parameter]
    public bool ReadOnly { get; set; } = false;
    [Parameter]
    public string Class { get; set; }
    [Parameter]
    public bool HideMode { get; set; } = false;
    [Parameter]
    public bool HideBankCharges { get; set; } = false;
    [Parameter]
    public bool HideTool { get; set; } = false;
    [Parameter]
    public string LabelName { get; set; } = "Select";




    [Parameter]
    public string PaymentMode { get; set; }
    [Parameter]
    public EventCallback<string> PaymentModeChanged { get; set; }
    [Parameter]
    public string ArdCode { get; set; }
    [Parameter]
    public EventCallback<string> ArdCodeChanged { get; set; }
    [Parameter]
    public int? CoaID { get; set; }
    [Parameter]
    public EventCallback<int?> CoaIDChanged { get; set; }
    [Parameter]
    public decimal? BankCharges { get; set; }
    [Parameter]
    public EventCallback<decimal?> BankChargesChanged { get; set; }
    [Parameter]
    public string BankTool { get; set; }
    [Parameter]
    public EventCallback<string> BankToolChanged { get; set; }




    List<PaymentCodeModel> paymentCodes = new();
    PaymentCodeModel PaymentCode = new();
    bool IsLoaded = false;

    private async Task<IEnumerable<PaymentCodeModel>> SearchAccounts(string searchString)
    {
        await Task.Delay(5);
        return paymentCodes.Where(x => 
            (x.ArdCode).Contains(searchString == null ? string.Empty : searchString, StringComparison.InvariantCultureIgnoreCase)
          ||(x.Title).Contains(searchString == null ? string.Empty : searchString, StringComparison.InvariantCultureIgnoreCase)
        );
    }

    async Task Modechanged(string mode)
    {
        PaymentMode = mode;
        PaymentCode = null;
        await getAll();
        await PaymentModeChanged.InvokeAsync(mode);
      
    }

    async Task _ardCodeChanged(PaymentCodeModel ard)
    {
        PaymentCode = ard;
        ArdCode = ard?.ArdCode;
        CoaID = ard?.CoaID;
        await ArdCodeChanged.InvokeAsync(ard?.ArdCode);
        await CoaIDChanged.InvokeAsync(ard?.CoaID);
    }

    async Task _BankChargesChanged(decimal? val)
    {
        BankCharges = val;
        await BankChargesChanged.InvokeAsync(val);
    }

    async Task _BankToolChanged(string val)
    {
        BankTool = val;
        await BankToolChanged.InvokeAsync(val);
    }

    protected override async Task OnInitializedAsync()
    {
        await getAll();
        PaymentCode = paymentCodes.FirstOrDefault(s => s.CoaID == CoaID && s.ArdCode == ArdCode);        
    }

    public async Task getAll()
    {
        @if (BranchID != 0)
        {
            paymentCodes = accountService.GetPaymentCodes(BranchID, PaymentMode).ToList();
        }
        else
        {
            var authprov = await auth.GetAuthenticationStateAsync();
            var brancIDString = authprov.User.Claims.First(x => x.Type == "BranchID").Value;
            int branchID = int.Parse(brancIDString);
            paymentCodes = accountService.GetPaymentCodes(branchID, PaymentMode).ToList();
        }
        if (CoaID is null && paymentCodes.Count == 1)
        {
            await _ardCodeChanged(paymentCodes.First());
        }
        IsLoaded = true;
    }
}