@inject IRepairWorkService Ijob

<MudAutocomplete ReadOnly="@ReadOnly" T="RepairJobModel" Variant="Variant.Outlined" Margin="Margin.Dense" Label="Job" @bind-Value="@_value" ResetValueOnEmptyText="true"
                 Class="@Class"     SearchFunc="SearchJob" ToStringFunc="@(e => e == null ? null : $"{e.Title}")"></MudAutocomplete>


@code {

    private List<RepairJobModel> jobslist = new(); 


   
    private RepairJobModel _value
    {
        get => Value;
        set
        {
            if (Value != value)
            {
                Value = value;                
                ValueChanged.InvokeAsync(value);
            }            
        }
    }  

    [Parameter]
    public RepairJobModel Value { get; set; }

    [Parameter]
    public EventCallback<RepairJobModel> ValueChanged { get; set; }

    [Parameter]
    public bool ReadOnly { get; set; } = false;

    [Parameter]
    public string Class { get; set; }




    private async Task<IEnumerable<RepairJobModel>> SearchJob(string searchString)
    {
        await Task.Delay(3);
        if(string.IsNullOrWhiteSpace(searchString))
        {
            return jobslist;
        }
        return jobslist.Where(x => x.Title != null && x.Title.Contains(searchString == null ? string.Empty : searchString, StringComparison.InvariantCultureIgnoreCase));
    }


    protected override void OnInitialized()
    {
        jobslist = Ijob.SelectJob(null, null, null).ToList();
    }
}
