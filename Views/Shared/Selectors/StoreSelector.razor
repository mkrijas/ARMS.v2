@inject IStoreService storeIservice
@if (IsLoaded)
{
    <MudAutocomplete SelectValueOnTab Clearable ResetValueOnEmptyText Strict T="StoreModel"
                 Variant="@VariantParameter" Margin="@MarginParameter" Label="Select Store"
                 @bind-Value="Value" SearchFunc="SearchStore" Class="@Class" Disabled="@IsDisabled"
                 ToStringFunc="@(e => e == null ? null : $"{e.StoreName}")"></MudAutocomplete>

}
else
{
    <MudText> Loading..... </MudText>
}

@code {
    private List<StoreModel> store = new();

    [Parameter]
    public StoreModel Value
    {
        get => _value;
        set
        {
            if (_value == value) return;
            _value = value;
            ValueChanged.InvokeAsync(value);
        }
    }

    [Parameter]
    public EventCallback<StoreModel> ValueChanged { get; set; }

    [Parameter]
    public bool IsDisabled { get; set; } = false;


    [Parameter]
    public string Class { get; set; }

    [Parameter]
    public int BranchID { get; set; }


    private StoreModel _value;
    private bool IsLoaded = false;
    [Parameter]
    public MudBlazor.Variant VariantParameter { get; set; } = MudBlazor.Variant.Outlined;
    [Parameter]
    public MudBlazor.Margin MarginParameter { get; set; } = MudBlazor.Margin.Dense;

    private async Task<IEnumerable<StoreModel>> SearchStore(string searchString)
    {
        await Task.Delay(3);
        return store.Where(x => (x.StoreName == null && string.IsNullOrWhiteSpace(searchString))  ||  x.StoreName!= null && x.StoreName.Contains(searchString == null ? string.Empty : searchString, StringComparison.InvariantCultureIgnoreCase));
    }


    protected override void OnInitialized()
    {

        store = storeIservice.SelectByBranch(BranchID).ToList();
        IsLoaded = true;

        if (VariantParameter == null)
        {
            VariantParameter = MudBlazor.Variant.Outlined;
        }
        if (MarginParameter == null)
        {
            MarginParameter = MudBlazor.Margin.Dense;
        }
        if (IsDisabled == null)
        {
            IsDisabled = false;
        }
    }
}
