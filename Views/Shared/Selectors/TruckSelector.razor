@inject ITruckService Itruck

@if (IsLoaded)
{
    <MudAutocomplete SelectValueOnTab Clearable ResetValueOnEmptyText Strict T="TruckModel" CoerceValue
                 Variant="@VariantParameter" Margin="@MarginParameter" Label="Select Truck"
                 @bind-Value="_value" SearchFunc="SearchTruck" Class="@Class" Disabled="@IsDisabled"
                 ToStringFunc="@(e => e == null ? null : $"{e.RegNo}")"></MudAutocomplete>

}
else
{
    <MudText> Loading..... </MudText>
}

@code {
    private List<TruckModel> TruckList = new();

    [Parameter]
    public TruckModel Value { get; set; }

    [Parameter]
    public EventCallback<TruckModel> ValueChanged { get; set; }

     private TruckModel _value
    {
        get => Value;
        set
        {
            if (Value == value) return;
            Value = value;
            ValueChanged.InvokeAsync(value);
        }
    }
    


    [Parameter]
    public bool IsDisabled { get; set; } = false;
    [Parameter]
    public string Class { get; set; }
    [Parameter]
    public int? BranchID { get; set; }
    [Parameter]
    public string Filter { get; set; } = null;
    [Parameter]
    public string HomeOrOperation { get; set; } = "Operation";
    [Parameter]
    public List<int?> TruckIDsToRemove { get; set; } = null;



   

    private bool IsLoaded = false;
    [Parameter]
    public MudBlazor.Variant VariantParameter { get; set; } = MudBlazor.Variant.Outlined;
    [Parameter]
    public MudBlazor.Margin MarginParameter { get; set; } = MudBlazor.Margin.Dense;

    private async Task<IEnumerable<TruckModel>> SearchTruck(string searchString)
    {
        await Task.Delay(3);
        return TruckList.Where(x => (x.RegNo== null && string.IsNullOrWhiteSpace(searchString))  ||  x.RegNo!= null && x.RegNo.Contains(searchString == null ? string.Empty : searchString, StringComparison.InvariantCultureIgnoreCase));
    }


    protected override void OnInitialized()
    {
        var Result = Itruck.SelectByBranch(BranchID, Filter, HomeOrOperation).ToList();
        if (TruckIDsToRemove != null && Result.Any(g => TruckIDsToRemove.Any(d=> d == g.TruckID)))
        {
            if (Result.Any(g => !TruckIDsToRemove.Any(d => d == g.TruckID)))
            {
                TruckList = Result.Where(g => !TruckIDsToRemove.Any(d => d == g.TruckID)).ToList();

            }
        }
        else
        {
            TruckList = Result;
        }
        IsLoaded = true;

        // if (VariantParameter == null)
        // {
        //     VariantParameter = MudBlazor.Variant.Outlined;
        // }
        // if (MarginParameter == null)
        // {
        //     MarginParameter = MudBlazor.Margin.Dense;
        // }
        // if (IsDisabled == null)
        // {
        //     IsDisabled = false;
        // }
    }
}
