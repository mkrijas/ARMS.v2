@inject ITruckService Itruck
@using System.Threading

    <div style="position: relative;">
        @if(_isLoading)
    {
        <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="absolute-loader"  />        
    }
    else
    {
        <MudAutocomplete SelectValueOnTab Clearable ResetValueOnEmptyText Strict T="TruckModel" CoerceValue
                         Variant="@VariantParameter" Margin="@MarginParameter" Label="Select Truck"
                         @bind-Value="_value" SearchFunc="SearchTruck" Class="@Class" Disabled="@IsDisabled"
                         ToStringFunc="@(e => e == null ? null : $"{e.RegNo}")"></MudAutocomplete>
    }   
    </div>



@code {
    private List<TruckModel> TruckList = new();

    [Parameter]
    public TruckModel Value { get; set; }

    [Parameter]
    public EventCallback<TruckModel> ValueChanged { get; set; }

    private TruckModel _value
    {
        get => Value;
        set
        {
            if (Value == value) return;
            Value = value;
            ValueChanged.InvokeAsync(value);
        }
    }

    [Parameter]
    public bool IsDisabled { get; set; } = false;
    [Parameter]
    public string Class { get; set; }
    [Parameter]
    public int? BranchID { get; set; }
    [Parameter]
    public string Filter { get; set; } = null;
    [Parameter]
    public string HomeOrOperation { get; set; } = "Operation";
    [Parameter]
    public List<int?> TruckIDsToRemove { get; set; } = null;

    int? previousBranchID;
    private bool _isLoading = false;
    [Parameter]
    public MudBlazor.Variant VariantParameter { get; set; } = MudBlazor.Variant.Outlined;
    [Parameter]
    public MudBlazor.Margin MarginParameter { get; set; } = MudBlazor.Margin.Dense;

    private async Task<IEnumerable<TruckModel>> SearchTruck(string searchString, CancellationToken token)
    {
        await Task.Delay(3);
        if (TruckList == null)
            return new List<TruckModel>();

        if (string.IsNullOrWhiteSpace(searchString))
            return TruckList;

        return TruckList.Where(x => x.RegNo != null && x.RegNo.Contains(searchString, StringComparison.InvariantCultureIgnoreCase));
    }


    protected override async Task OnParametersSetAsync()
    {
        try
        {
            if ((previousBranchID != BranchID && BranchID != 0) || TruckList.Count == 0 || (TruckList.Count == 0 && !string.IsNullOrEmpty(Filter)))
            {
                _isLoading = true;
                StateHasChanged(); // Show loader immediately
                
                await Task.Yield(); // Use Yield to allow UI update before blocking work if synchronous, though Itruck is likely synchronous-looking here

                var Result = Itruck.SelectByBranch(BranchID, Filter, HomeOrOperation)?.ToList() ?? new List<TruckModel>();
                
                if (TruckIDsToRemove != null && Result.Any())
                {
                   TruckList = Result.Where(g => !TruckIDsToRemove.Contains(g.TruckID)).ToList();
                }
                else
                {
                    TruckList = Result;
                }
                previousBranchID = BranchID;
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading trucks: {ex.Message}");
            TruckList = new List<TruckModel>();
        }
        finally
        {
            _isLoading = false;
        }
    }
}
