@inject ITyreService Iasset
@using System.Threading
@using System.Linq.Expressions
@inject AuthenticationStateProvider auth

@if (IsLoaded)
{
    <MudAutocomplete Variant="Variant.Outlined" SelectValueOnTab @ref="_autoComplete" 
    Class="@Class" T="TyreModel" Label="@Label" @bind-Value="Value" 
    AdornmentColor="Color.Secondary" AdornmentIcon="@Icons.Material.Rounded.Add" 
    OnAdornmentClick="AddTyres" For="@For" DebounceInterval="300" MinCharacters="1"
    Clearable="false" SearchFunc="SearchTyre" ToStringFunc="@(e => e == null ? null : string.Format("{0}",e.TyreSerialNumber))" ></MudAutocomplete>

}
else
{
    <MudText> Loading..... </MudText>
}

@code {
    private List<TyreModel> TyreList = new();
    private MudAutocomplete<TyreModel> _autoComplete {get;set;}
    [Parameter] public EventCallback<bool> SetTyres { get; set; }
    [Parameter] public string Label { get; set; } = "Select Tyre";
    [Parameter] public int BranchID { get; set; } = 0;         

    [Parameter]
    public TyreModel Value
    {
        get => _value;
        set
        {
            if (_value == value) return;
            _value = value;
            ValueChanged.InvokeAsync(value);
        }
    }

    [Parameter]
    public EventCallback<TyreModel> ValueChanged { get; set; }

    [Parameter]
    public string Class { get; set; }

    private async Task AddTyres()
    {        
        if (Value != null)
        {
            await SetTyres.InvokeAsync();
            await _autoComplete.ResetAsync();
            await SearchTyre("", CancellationToken.None);
        }
    }

    private TyreModel _value;
    private bool IsLoaded = false;

    [Parameter]
    public List<TyreModel> PassedListTyres { get; set; }

    [Parameter]
    public Expression<Func<TyreModel>> For { get; set; }

    private async Task<IEnumerable<TyreModel>> SearchTyre(string searchString, CancellationToken token)
    {
        if (string.IsNullOrWhiteSpace(searchString)) return TyreList;

        if (PassedListTyres != null && PassedListTyres.Count() != 0)
        {
            var result = TyreList.Where(x => (!PassedListTyres.Any(g => g.TyreID == x.TyreID)) && x.TyreSerialNumber.Contains(searchString == null ? string.Empty : searchString, StringComparison.InvariantCultureIgnoreCase));
            return result;
        }
        else
        {
            return TyreList.Where(x => x.TyreSerialNumber.Contains(searchString == null ? string.Empty : searchString, StringComparison.InvariantCultureIgnoreCase));
        }
    }

    protected override void OnParametersSet()
    {
        if (BranchID != 0)
        {
            if (PassedListTyres != null && PassedListTyres.Count() != 0)
            {
                TyreList = Iasset.SelectUnmontedTyresByBranch(BranchID).Where(s => !PassedListTyres.Any(g => g.TyreID == s.TyreID)).ToList();
            }
            else
            {
                TyreList = Iasset.SelectUnmontedTyresByBranch(BranchID).ToList();
            }
            IsLoaded = true;
        }
    }
}
