@inject IGstUsageIDService usageService

@if(IsLoaded)
{
    <MudAutocomplete 
        id="@ElementID" 
        ResetValueOnEmptyText 
        SelectValueOnTab  
        T="GstUsageCodeModel"                 
        Variant="Variant.Outlined" 
        Margin="Margin.Dense" 
        Label="@LabelName" 
        @bind-Value="@Value"
        autocomplete = "nope"
        Clearable="true" 
        SearchFunc="SearchUsageID" 
        Text="@Value?.Description" 
        Class="@Class"
        ToStringFunc="@(e => (e == null || string.IsNullOrEmpty(e.Description)) ? null : string.Format("{0} | {1}",e.UsageCode,e.Description))"></MudAutocomplete>

}
else
{
   <MudText> Loading..... </MudText> 
}
@code {
    private List<GstUsageCodeModel> usageList = new();    

    [Parameter]
    public GstUsageCodeModel Value
    {
        get => _value;
        set
        {
            if (_value == value) return;
            _value = value;
            ValueChanged.InvokeAsync(value);
        }
    }

    [Parameter]
    public EventCallback<GstUsageCodeModel> ValueChanged { get; set; }

    [Parameter]
    public string Class { get; set; }

    [Parameter]
    public string LabelName { get; set; } = "Select Usage Code";

    [Parameter]
    public string ElementID { get; set; } = "UsageID";

    [Parameter]
    public int? AccountGroup { get; set; } = 0;// Select Child Accounts under this value

    [Parameter]
    public string Area { get; set; } = null;


    private GstUsageCodeModel _value;
    private bool IsLoaded = false;
   

    private async Task<IEnumerable<GstUsageCodeModel>> SearchUsageID(string searchString)
    {
        await Task.Delay(3);
        return usageList.Where(x => (x.Description +" "+x.UsageCode).Contains(searchString == null ? string.Empty : searchString, StringComparison.InvariantCultureIgnoreCase));
    }
    
    //tariif,usage,oprations
    protected override void OnInitialized()
    {
        usageList = usageService.SelectByArea(Area,System.DateTime.Now).ToList();
        IsLoaded = true;
    }
   
}
