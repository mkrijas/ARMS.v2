@inject IConsigneeService Iservice
@inject IDialogService Idialog
@* @inherits ViewComponentBase<SundryReceiptModel> *@

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h5"> Select Received Freights</MudText>
    </TitleContent>
    <DialogContent>
            @* <MudSpacer></MudSpacer>
            <MudTextField @bind-Value="searchTerm" Placeholder="Search Sundry Receipt..." Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0" @onkeyup="HandleSearchKeyUp">
            </MudTextField> *@
        <MudTable T="StockistFreightReceivableModel" Items="@_receivables" Filter="new Func<StockistFreightReceivableModel, bool>(search)">
            <ToolBarContent>
                <MudSpacer></MudSpacer>
                <MudTextField @bind-Value="searchStockistFreight" Placeholder="Search Stockist Freight... " Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0"></MudTextField>
            </ToolBarContent>
                <HeaderContent>
                    <MudTh></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<StockistFreightReceivableModel, object>(x => x.Consignee.ConsigneeName)" InitialDirection="SortDirection.Ascending">Name of Party</MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<StockistFreightReceivableModel, object>(x => x.Consignee.Mobile)" InitialDirection="SortDirection.Ascending">Contact</MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<StockistFreightReceivableModel, object>(x => x.Amount)" InitialDirection="SortDirection.Ascending">Amount</MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<StockistFreightReceivableModel, object>(x => x.DocumentDate)" InitialDirection="SortDirection.Ascending">Date</MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<StockistFreightReceivableModel, object>(x => x.EntryRef)" InitialDirection="SortDirection.Ascending">Gc Reference</MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<StockistFreightReceivableModel, object>(x => x.InvoiceNo)" InitialDirection="SortDirection.Ascending">Invoice Number</MudTableSortLabel></MudTh>
                    </HeaderContent>
                <RowTemplate>
                    <MudTd><MudCheckBox T="bool" @bind-Value="@context.IsChecked"></MudCheckBox></MudTd>
                    <MudTd DataLabel="name">@context.Consignee.ConsigneeName</MudTd>
                    <MudTd DataLabel="Mobile">@context.Consignee.Mobile</MudTd>
                    <MudTd DataLabel="Amount">@context.Amount</MudTd>
                    <MudTd DataLabel="date">@context.DocumentDate</MudTd>
                    <MudTd DataLabel="Ref">@context.EntryRef</MudTd>
                    <MudTd DataLabel="InvoiceNo">@context.InvoiceNo</MudTd>
                </RowTemplate>
                <PagerContent>
                    <MudTablePager PageSizeOptions="new int[] { 10, 25, 50, 100 }" />
                </PagerContent>
                <FooterContent>
                    <MudTd colspan="5">Select All</MudTd>
                </FooterContent>
            </MudTable>
    </DialogContent>
    <DialogActions>
        <MudButton ButtonType="ButtonType.Button" OnClick="Submit" Color="Color.Primary"> Proceed </MudButton>
    </DialogActions>
</MudDialog>

@code {

    [CascadingParameter]
    IMudDialogInstance MudDialog { get; set; }
    [Parameter]
    public int? ConsigneeID { get; set; } = null;
    [Parameter]
    public int? BranchID { get; set; }

    private List<StockistFreightReceivableModel> _receivables = new List<StockistFreightReceivableModel>();
    private HashSet<StockistFreightReceivableModel> _Selected = new HashSet<StockistFreightReceivableModel>();
    private List<StockistFreightReceivableModel> stockists = new List<StockistFreightReceivableModel>();
    //private HashSet<StockistFreightReceivableModel> _SelectedItems = new HashSet<StockistFreightReceivableModel>();
    private string searchStockistFreight = "";

    protected override async Task OnInitializedAsync()
    {
        _receivables = Iservice.GetStockistFreightReceivables((ConsigneeID ?? 0), BranchID).ToList();
    }

    private void Submit()
    {
        MudDialog.Close(DialogResult.Ok(_receivables.Where(x => x.IsChecked).ToList()));
    }

    private bool search(StockistFreightReceivableModel Stockist)
    {
        if ((Stockist.Consignee.ConsigneeName != null && Stockist.Consignee.ConsigneeName.Contains(searchStockistFreight, StringComparison.OrdinalIgnoreCase)) || 
        (Stockist.InvoiceNo != null && Stockist.InvoiceNo.Contains(searchStockistFreight, StringComparison.OrdinalIgnoreCase)))
        {
            return true;
        }
        return false;
    }

    private void GetSelectedItems(HashSet<StockistFreightReceivableModel> stockistFreights)
    {
        foreach(var item in stockistFreights)
        {
            _Selected.Add(item);
            stockists.Add(item);
        }
    }
}
