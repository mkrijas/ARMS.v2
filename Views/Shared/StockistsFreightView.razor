@inject IConsigneeService Iservice
@inject IDialogService Idialog



<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h5"> Select Received Freights</MudText>
    </TitleContent>
    <DialogContent>

        <MudTable T="StockistFreightReceivableModel"
                  Items="@_receivables" MultiSelection="true"
                  @bind-SelectedItems="@_Selected" Hover="true">
            <HeaderContent>
                <MudTh>Name of Party</MudTh>
                <MudTh>Contact</MudTh>
                <MudTh>Amount</MudTh>
                <MudTh>Date</MudTh>
                <MudTh>Gc Reference</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="name">@context.Consignee.ConsigneeName</MudTd>
                    <MudTd DataLabel="Mobile">@context.Consignee.Mobile</MudTd>
                    <MudTd DataLabel="Amount">@context.Amount</MudTd>
                    <MudTd DataLabel="date">@context.DocumentDate</MudTd>
                    <MudTd DataLabel="Ref">@context.EntryRef</MudTd>
                </RowTemplate>
                <PagerContent>
                    <MudTablePager PageSizeOptions="new int[] { 10, 25, 50, 100 }" />
                </PagerContent>
                <FooterContent>
                    <MudTd colspan="5">Select All</MudTd>
                </FooterContent>
            </MudTable>
        </DialogContent>
        <DialogActions>
            <MudButton ButtonType="ButtonType.Button" OnClick="Submit" Color="Color.Primary"> Proceed </MudButton>
        </DialogActions>

    </MudDialog>




    @code {
    [CascadingParameter]
    MudDialogInstance MudDialog { get; set; }

    [Parameter]
    public int? ConsigneeID { get; set; } = null;
    [Parameter]
    public int? BranchID { get; set; }

    private List<StockistFreightReceivableModel> _receivables = new List<StockistFreightReceivableModel>();
    private HashSet<StockistFreightReceivableModel> _Selected = new HashSet<StockistFreightReceivableModel>();

    protected override async Task OnInitializedAsync()
    {

        _receivables = Iservice.GetStockistFreightReceivables((ConsigneeID ?? 0), BranchID).ToList();
    }


    private void Submit()
    {
        MudDialog.Close(DialogResult.Ok(_Selected.ToList()));
    }
}
