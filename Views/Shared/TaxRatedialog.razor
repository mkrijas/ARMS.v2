@inject IDialogService DialogService
@inject IConfiguration configuration
@using Microsoft.Extensions.Configuration
@inject NavigationManager uriHelper;
@inject MudBlazor.ISnackbar snackbar
@inject AuthenticationStateProvider auth
@attribute [Authorize]
<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.Terminal" Class="mr-3 mb-n1" />
            GST/TDS
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudPaper>
            <br />
            <MudContainer Style="max-height: 700px;">
                <EditForm id="formtdsRate" Model="@tax" OnValidSubmit="OnValidSubmit2">
                    <ObjectGraphDataAnnotationsValidator />
                    <ValidationSummary />
                    <MudGrid Spacing="3">
                        <br />

                        @*  <MudItem xs="12" md="12">
                        <MudTextField @bind-Value="tax.GstRate" ReadOnly="ReadOnly" Label="GST" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => tax.GstRate)"></MudTextField>
                        </MudItem>*@
                        <MudItem xs="12" md="12">
                            <MudTextField @bind-Value="tax.CGST" ReadOnly="ReadOnly" Label="CGST" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => tax.CGST)"></MudTextField>
                        </MudItem>

                        <MudItem xs="12" md="12">
                            <MudTextField @bind-Value="tax.SGST" Label="SGST" ReadOnly="ReadOnly" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => tax.SGST)"></MudTextField>
                        </MudItem>

                        <MudItem xs="12" md="12">
                            <MudTextField @bind-Value="tax.IGST" Label="IGST" ReadOnly="ReadOnly" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => tax.IGST)"></MudTextField>
                        </MudItem>
                        <MudItem xs="12" md="12">
                            <MudTextField @bind-Value="tax.TDS" ReadOnly="ReadOnly" Label="TDS" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => tax.TDS)"></MudTextField>
                        </MudItem>
                        <MudItem xs="12" md="12">
                        </MudItem>
                        <MudItem xs="12" md="6">
                        </MudItem>
                        <MudItem xs="12" md="12">


                        </MudItem>
                        <MudItem xs="12" md="12">
                            <MudButton OnClick="OnValidSubmit2" form="formtdsRate" Variant="Variant.Filled" Color="Color.Primary" ButtonType="ButtonType.Button">Update</MudButton>
                        </MudItem>
                        <br />

                    </MudGrid>
                </EditForm>
            </MudContainer>

            <br />
        </MudPaper>
    </DialogContent>
</MudDialog>

@code {

    [Parameter]
    public GstModel tax { get; set; }
    [Parameter]
    public bool ReadOnly { get; set; }
    [CascadingParameter] MudDialogInstance MudDialog2 { get; set; }
    private void Cancel()
    {
        MudDialog2.Cancel();
    }
    private void OnValidSubmit2()
    {
        if (tax.SGST == null)
        {
            tax.SGST = 0;
        }
        if (tax.CGST == null)
        {
            tax.CGST = 0;
        }
        if (tax.IGST == null)
        {
            tax.IGST = 0;
        }
        tax.GstRate = tax.SGST + tax.IGST + tax.CGST;
        MudDialog2.Close(tax);
    }

}
