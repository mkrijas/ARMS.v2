@inject IDialogService DialogService
@inject IConfiguration configuration
@using Microsoft.Extensions.Configuration
@inject NavigationManager uriHelper;
@inject MudBlazor.ISnackbar snackbar
@inject AuthenticationStateProvider auth
@attribute [Authorize]
<MudDialog>
    <TitleContent>
         <MudText Typo="Typo.h6">
        <MudIcon Icon="@Icons.Material.Filled.Terminal" Class="mr-3 mb-n1" />
        Tax Rates
        </MudText>
        </TitleContent>
       <DialogContent>
        
            <MudPaper>
            <br />
                <MudContainer Style="max-height: 700px;">
<MudGrid Spacing="4">
    <br />

      <MudItem xs="12" md="4">
        <MudTextField @bind-Value="tax.GstRate" ReadOnly="IsReadOnly" Label="GST" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => tax.GstRate)"></MudTextField>
          </MudItem>
    <MudItem xs="12" md="4">
                    <MudTextField @bind-Value="tax.Cgst" ReadOnly="IsReadOnly" Label="CGST" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => tax.Cgst)"></MudTextField>
    </MudItem>

    <MudItem xs="12" md="4">
                    <MudTextField @bind-Value="tax.Sgst" Label="SGST" ReadOnly="IsReadOnly" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => tax.Sgst)"></MudTextField>
          </MudItem>

<MudItem xs="12" md="4">
                    <MudTextField @bind-Value="tax.Igst" Label="IGST" ReadOnly="IsReadOnly" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => tax.Igst)"></MudTextField>
          </MudItem>
    <MudItem xs="12" md="4">
        <MudTextField @bind-Value="tax.TDS" ReadOnly="IsReadOnly" Label="TDS" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => tax.TDS)"></MudTextField>
    </MudItem>
    <MudItem xs="12" md="4">
        </MudItem>
                    <MudItem xs="12" md="6">
                    </MudItem>
                    <MudItem xs="12" md="4">

                   
    </MudItem>
    <MudItem xs="12" md="2">
                        <MudButton Variant="Variant.Filled" Color="Color.Success" OnClick="Cancel">Close</MudButton>
        </MudItem>
    <br />
  
</MudGrid>
            
</MudContainer>
            <br />
        </MudPaper>
</DialogContent>
    </MudDialog>

@code {

    [Parameter]
    public GstModel tax { get; set; }
    [Parameter]
    public bool IsReadOnly { get; set; }
    [CascadingParameter] MudDialogInstance MudDialog { get; set; }
    private void Cancel()
    {
        MudDialog.Cancel();
    }

}
