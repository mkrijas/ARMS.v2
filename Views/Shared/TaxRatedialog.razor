@inject IDialogService DialogService
@inject IConfiguration configuration
@using Microsoft.Extensions.Configuration
@inject NavigationManager uriHelper;
@inject MudBlazor.ISnackbar snackbar
@inject AuthenticationStateProvider auth
@attribute [Authorize]
<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.Terminal" Class="mr-3 mb-n1" />
            GST/TDS
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudPaper>
            <br />
            <MudContainer Style="max-height: 700px;">
                <EditForm id="formtdsRate" Model="@tax" OnValidSubmit="OnValidSubmit2">
                    <ObjectGraphDataAnnotationsValidator />
                    <ValidationSummary />
                    <MudGrid Spacing="3">
                        <br />
                        @*<MudItem xs="12" md="12">
                        <MudTextField @bind-Value="tax.GstRate" ReadOnly="ReadOnly" Label="GST" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => tax.GstRate)"></MudTextField>
                        </MudItem>*@
                        <MudItem xs="12" md="12">
                            <MudTextField @bind-Value="tax.CGST" ReadOnly="ReadOnly" Label="CGST" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => tax.CGST)"></MudTextField>
                        </MudItem>
                        <MudItem xs="12" md="12">
                            <MudTextField @bind-Value="tax.SGST" Label="SGST" ReadOnly="ReadOnly" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => tax.SGST)"></MudTextField>
                        </MudItem>
                        <MudItem xs="12" md="12">
                            <MudTextField @bind-Value="tax.IGST" Label="IGST" ReadOnly="ReadOnly" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => tax.IGST)"></MudTextField>
                        </MudItem>
                        <MudItem xs="12" md="12">
                            <MudTextField @bind-Value="tax.TDS" ReadOnly="ReadOnly" Label="TDS" Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => tax.TDS)"></MudTextField>
                        </MudItem>
                        @if (!ReadOnly)
                        {
                            <MudItem xs="12" md="12">
                                <MudButton Disabled="@_busy" Variant="Variant.Filled" Color="Color.Primary" ButtonType="ButtonType.Submit">Update</MudButton>
                            </MudItem>
                        }
                        <br />
                    </MudGrid>
                </EditForm>
            </MudContainer>
            <br />
        </MudPaper>
    </DialogContent>
</MudDialog>

@code {

    [Parameter]
    public GstModel tax { get; set; }
    [Parameter]
    public bool ReadOnly { get; set; }
    [CascadingParameter] IMudDialogInstance MudDialog2 { get; set; }
    private bool _busy;

    private void Cancel()
    {
        MudDialog2.Cancel();
    }

    private async Task OnValidSubmit2(EditContext context)
    {
        var isValid = context.Validate();
        
        if (_busy)
        {
            snackbar.Add("Please wait while form is being submitted!", Severity.Warning);
            return;
        }
        if (!isValid)
        {
            return;
        }
        _busy = true;

        if (tax.SGST == null)
        {
            tax.SGST = 0;
        }
        if (tax.CGST == null)
        {
            tax.CGST = 0;
        }
        if (tax.IGST == null)
        {
            tax.IGST = 0;
        }
        tax.GstRate = tax.SGST + tax.IGST + tax.CGST;

        MudDialog2.Close(tax);

        await Task.Delay(200);
        _busy = false;
    }
}
